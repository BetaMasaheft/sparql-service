p2/addition/e1"/><dcterms:hasPart rdf:resource="YaleMs29p2/addition/a2"/><dcterms:hasPart rdf:resource="YaleMs29p2/addition/e2"/><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</crm:P57_has_number_of_parts><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2"><betmas:formerlyAlsoListedAs rdf:resource="https://betamasaheft.eu/EMIP03157"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart rdf:resource="https://betamasaheft.eu/LIT2375Synaxa"/><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</crm:P57_has_number_of_parts><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.1"/><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.2"/><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.3"/><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.4"/><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.5"/><dcterms:hasPart rdf:resource="YaleMs29p2/msitem/ms_i1.6"/><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.1"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Mäggabit</dcterms:hasPart><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</crm:P57_has_number_of_parts><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.2"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Miyazya.  has the name ወልደ ሰንባት, written into the blank, written in
                           a different hand.  has a note of
                           ownership in a different hand: This book belongs to the church, ዋሻ ሚካኤል during the time of Emperor Menilek
                           (1868–1913) and Governor (Ras) Hailu (1858–1950), and Qängazmač Alemu,
                           and church manager ቄሰ ገበዝ ተገኝ, and
                           Märigeta ዛይህመ, church scholar, in the
                           year of Evangelist Saint John, it was purchased. ቄሰ ገበዝ ተገኝ, whose baptismal name is ወልደ ተንሣኤ, is the one bought it as the property of the
                           church ዋሻ ሚካኤል</dcterms:hasPart><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</crm:P57_has_number_of_parts><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.3"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Gǝnbot</dcterms:hasPart><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</crm:P57_has_number_of_parts><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.4"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Säne</dcterms:hasPart><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</crm:P57_has_number_of_parts><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.5"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Ḥamle</dcterms:hasPart><crm:P57_has_number_of_parts rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</crm:P57_has_number_of_parts><betmas:hasLocus><betmas:Locus><betmas:locusFrom/><betmas:locusTo/></betmas:Locus></betmas:hasLocus></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/YaleMs29p2/msitem/ms_i1.6"><rdf:type rdf:resource="https://betamasaheft.eu/msitem"/><rdf:type rdf:resource="https://w3id.org/sdc/ontology#UniCont"/><dcterms:hasPart>For Näḥase. It appears that the hand changes half way through  facs contains two prayers that

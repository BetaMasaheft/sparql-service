amasaheft.eu"/><dcterms:bibliographicCitation>LIT3169Cosmas</dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Alessandro Bausi</dc:contributor><rdf:type rdf:resource="https://betamasaheft.eu/ChristianLiterature"/><rdf:type rdf:resource="https://betamasaheft.eu/Hagiography"/><rdf:type rdf:resource="https://betamasaheft.eu/Translation"/><dc:title>Martyrdom of Cosmas and Damian</dc:title><dc:title xml:lang="gez">ስምዖሙ፡ ለቆዝሞስ፡ ወዲምያኖስ፡</dc:title><crm:P102_has_title rdf:resource="https://betamasaheft.eu/LIT3169Cosmas/title/t1" xml:lang="gez"/><dc:title xml:lang="gez">Sǝmʿomu la-Qozmos wa-Dimyānos</dc:title><dc:title xml:lang="en">Martyrdom of Cosmas and Damian</dc:title><dc:title xml:lang="gez"> ቆዝሞስ፡ ወድምያኖስ፡ ወአቢሞስ፡ ለወንድየስ፡ ወአብራንዮስ፡ ወእሞሙ፡ ተውደደ፡</dc:title><crm:P102_has_title rdf:resource="https://betamasaheft.eu/LIT3169Cosmas/title/t2" xml:lang="gez"/><dc:title xml:lang="gez">Qozmos wa-Dǝmyānos wa-ʾAbimos Lawandyas wa-ʾAbrānyos waʾǝmomu Tawdada</dc:title><dc:title xml:lang="en">Cosmas and Damian and Arithmius and Leontius and Abranius and their mother Theodata</dc:title><dc:title xml:lang="en">Martyrdom of Cosmos and Damian (Arabic version)</dc:title><crm:P102_has_title rdf:resource="https://betamasaheft.eu/LIT3169Cosmas/title/t3ar" xml:lang="en"/><dc:source rdf:resource="https://betamasaheft.eu/BLorient686"/><dc:source rdf:resource="https://betamasaheft.eu/BLorient687"/><dc:source rdf:resource="https://betamasaheft.eu/BLorient689"/><dc:source rdf:resource="https://betamasaheft.eu/BLorient691"/><dc:source rdf:resource="https://betamasaheft.eu/BNFabb92"/><dc:source rdf:resource="https://betamasaheft.eu/BNFabb110"/><dc:source rdf:resource="https://betamasaheft.eu/EMML1479"/><dc:source rdf:resource="https://betamasaheft.eu/EMML6903"/><dc:source rdf:resource="https://betamasaheft.eu/EM
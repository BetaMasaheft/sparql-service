                  Šayḫ
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E67_Birth"/><crm:P78_is_identified_by>1283 </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E69_Death"/><crm:P78_is_identified_by>1355 A note in TOSG00029, 42r mentions the years of the birth and death of Ḥāǧǧ Ādam. He is likely Šayḫ Ādam ʻAbd Allāh. There is a further note in TOSG00029, 27v.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS2840IHA/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS2840IHA"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC0322IHA"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Toba</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS2840IHA/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS2840IHA"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS2628IHA"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>ابا رايا</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS2840IHA/person/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS2840IHA"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS3177IHA"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>شيخ راضيا</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS2840IHA/person/annotation/3"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS2840IHA"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS0823IHA"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2
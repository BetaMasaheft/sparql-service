                  rās
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by> He was an important official in the reign of King Lǝbna Dǝngǝl. 
                  He was the governor of Bāle. In  1527 he led a punitive expedition against 
                  Aḥmad and he was victorious against him. 
                     </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>governor</snap:occupation></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3287Dagalhan"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS6229LebnaDe"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS6229LebnaDe"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS6229LebnaDe"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3287Dagalhan"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/EnmityFor-https://betamasaheft.eu/PRS1500Ahmad"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/EnmityFor-https://betamasaheft.eu/PRS1500Ahmad"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#EnmityFor"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS1500Ahmad"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3287Dagalhan"><betmas:husbandOf rdf:resource="https://betamasaheft.eu/PRS1826AmataWe"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS3287Dagalhan/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS3287Dagalhan"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC1743Bale"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Bāle</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS3287Dagalhan/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS3287Dagalhan"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS6229LebnaDe"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Lǝbna Dǝngǝl</lawd:hasName></oa:Annotation
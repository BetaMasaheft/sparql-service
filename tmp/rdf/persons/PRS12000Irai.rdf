                            Forschungsumgebung / Beta maṣāḥǝft,  Akademie der Wissenschaften in Hamburg</dc:publisher><dcterms:isPartOf rdf:resource="https://betamasaheft.eu"/><dcterms:bibliographicCitation>PRS12000Irai</dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Alessandro Bausi</dc:contributor><dc:contributor>Dorothea Reule</dc:contributor><skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q4055278"/><foaf:gender>female</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ኢራኢ፡</foaf:name><foaf:name xml:lang="gez">ʾIrāʾi</foaf:name><foaf:name xml:lang="en">Iraja</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>Martyred and venerated on 28 Maskaram together with her brother ʾAbādir.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>Abadir and Iraja are Coptic saints, reported to have been children of the sister of Basilides, "the father of kings".
                        According to their legend, Abadir and Iraja fled from Antioch to Alexandria. 
                        They were arrested there and brought to Antinoe in Upper Egypt, where they were beheaded along with Cluthus, a physician and priest, and another 3,685 companions.
                        
                    </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS12000Irai"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/SisterOf-https://betamasaheft.eu/PRS1005Abadir"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/SisterOf-https://betamasaheft.eu/PRS1005Abadir"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#SisterOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS1005Abadir"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS12000Irai"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT2375Synaxa"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS12000Irai"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT2727RepCh11"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS12000Irai"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT4825GadlaAbIrai"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS12000Irai/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS12000Irai"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS1005Abadir"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>ʾAbādir</lawd:hasName></oa:Annotation></rdf:RDF>
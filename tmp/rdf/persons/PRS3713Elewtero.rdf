on><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">grc</dc:language><rdf:type rdf:resource="https://betamasaheft.eu/martyr"/><rdf:type rdf:resource="https://betamasaheft.eu/saint"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ኤሌውትሮስ፡ </foaf:name><foaf:name xml:lang="gez">ʾElewtǝros</foaf:name><foaf:name xml:lang="en">Eleutherius</foaf:name><foaf:name xml:lang="grc">Ἐλευθέριος</foaf:name><foaf:name xml:lang="gez">እላውትሮስ፡</foaf:name><foaf:name xml:lang="gez">ʾƎlāwtǝros</foaf:name><foaf:name>Eleutherus</foaf:name><foaf:name>Eleftherios</foaf:name><foaf:name>Liberalis</foaf:name><foaf:name>Liberator</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">0138-01-01</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>Supposedly a bishop in Illyria, Dalmatia, with his mother, Anthia. He was a Roman, educated by Bishop Dynamius. At the age of twenty, Eleutherius himself became a bishop and was arrested for converting an imperial official. 
                  He was clubbed to death and Anthia was beheaded.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3713Elewtero"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT3167Eleutheris"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3713Elewtero"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS3820enteya"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS3820enteya"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#SonOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS3820enteya"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS3713Elewtero"><skos:exactMatch rdf:resource="https://en.wikipedia.org/wiki/Eleutherius_and_Antia"/></rdf:Description></rdf:RDF>
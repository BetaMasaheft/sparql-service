c:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q4117944"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ማቴዎስ፡</foaf:name><foaf:name xml:lang="gez">Mātewos I</foaf:name><foaf:name xml:lang="en">Matthew I</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1408-01-01</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1408-01-01</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He was a patriarch of Alexandria from 1378 until his death and a contemporary of ʾaḍe Dāwit and 
                   ʾabbā Salāmā with whom he maintained relations.  There is a depiction of him in the church 
                  of Dabra Maʿār as well as a hagiographic composition in his honour presereved in 
                  the manuscript EMML 8071.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>Patriarch </snap:occupation></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6903Matthew/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6903Matthew"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC2298DabraM"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Dabra Maʿār</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6903Matthew/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6903Matthew"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS3429DawitII"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Dāwit</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6903Matthew/person/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6903Matthew"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS8387SalamaI"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>ʾabbā Salāmā</lawd:hasName></oa:Annotation></rdf:RDF>
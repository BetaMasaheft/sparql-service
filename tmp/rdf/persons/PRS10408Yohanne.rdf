:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Solomon Gebreyes</dc:contributor><dc:contributor>AlessandroBausi</dc:contributor><dc:contributor>SiegbertUhlig</dc:contributor><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ዮሐንስ፡ ከማ፡</foaf:name><foaf:name xml:lang="gez">Yoḥannǝs Kamā</foaf:name><foaf:name>
                  ʾƎč̣č̣age
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by/></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He was the seventh head  of the monastery of Dabra Libānos
                  who succeeded his predecessor
                   
                     ʾabuna  Yoḥannǝs Sǝwwur and he was a contemporary 
                  of King 
                     Yǝsḥaq. His tenure was remarkable for the development of the monastery of Dabra Libānos and its literature. 

                  It is believed that Gadla Filǝṗṗos
                  of  
                  
                    ʾabuna Filǝṗṗos was written during his tenure.
                 </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>Abbot</snap:occupation></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS10408Yohanne"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS10342Yeshaq"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS10342Yeshaq"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS10342Yeshaq"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS10408Yohanne/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS10408Yohanne"/><oa:hasBody rdf:resource="https://betamasaheft.eu/INS0341DL"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Dabra Libānos</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS10408Yohanne/place/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS10408Yohanne"/><oa:hasBody rdf:resource="https://betamasaheft.eu/INS0341DL"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Dabra Libānos</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS10408Yohanne/place/annotation/3"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS10408Yohanne"/><oa:hasBody rdf:resource="https://betamasaheft.eu/INS0341DL"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Dabra Libānos</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS10408Yohanne/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS10408Yohanne"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS10421Yohanne"/><oa:annotatedAt rdf:d
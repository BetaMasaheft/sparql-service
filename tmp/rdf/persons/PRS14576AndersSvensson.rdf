                            Forschungsumgebung / Beta maṣāḥǝft The Red Sea Press Albert Bonnier,  Akademie der Wissenschaften in Hamburg</dc:publisher><dcterms:isPartOf rdf:resource="https://betamasaheft.eu"/><dcterms:bibliographicCitation>PRS14576AndersSvensson</dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">ti</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">sv</dc:language><dc:contributor>Alessandro Bausi</dc:contributor><dc:contributor>Jonas Karlsson</dc:contributor><dc:contributor>Ezra Gebremedhin</dc:contributor><dc:contributor>TorstenDahl</dc:contributor><skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q115903389"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="sv">Anders Svensson</foaf:name><foaf:name xml:lang="ti">ቀሺ ሜንሶን</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E67_Birth"/><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1894-04-07</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1894-04-07</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E69_Death"/><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1928-06-04</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1928-06-04</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>
                        Anders Svensson, born in Nävlinge socken in 1849, was ordained a 
                        priest in Lund in 1874, and became a missionary for
                        Swedish Evangelical Mission in Eritrea in 1877. He was a teacher at the school outside
                        Imkullo. From 1885 to 1897, he was the head of the school, 
                        which from 1890 was located in Zazega. 
                        As the chairman of the missionary conference (missionskonferens)
                        from 1886 to 1913, he travelled through the entire area where the SEM was active, ordaining priests and
                        consecrating churches and graveyards.
                        He is buried in Zazega. According to ,
                        he was locally known as ቀሺ ሜንሶን
                        (Qašši Menson),
                        which is the name attested in Uppsala, Uppsala University Library, Q 15:24 o.
                    </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS14576AndersSvensson"><lawd:hasAttestation rdf:resource="https://betamasaheft.eu/UppQ1524o"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS14576AndersSvensson"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/ProfessionalRelationship-https://betamasaheft.eu/PRS14574GabraLeul"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/ProfessionalRelationship-https://betamasaheft.eu/PRS14574GabraLeul"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#ProfessionalRelationship"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS14574GabraLeul"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS14576AndersSvensson/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS14576AndersSvensson"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC2852Emkull"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Ǝmkullu</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS14576AndersSvensson/place/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS14576AndersSvensson"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC5393Saazza"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Ṣäʿazzäga</lawd:hasName></oa:Annotation></rdf:RDF>
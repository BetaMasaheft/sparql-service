phicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Solomon Gebreyes</dc:contributor><dc:contributor>Alessandro Bausi</dc:contributor><dc:contributor>SiegbertUhlig</dc:contributor><dc:contributor>AlessandroBausi</dc:contributor><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ርቱዐ፡ ሃይማኖት፡</foaf:name><foaf:name xml:lang="gez">Rǝtuʿa Hāymānot</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by> It is the pen name of several traditional scholars of the Ethiopian Orthodox Church. 
                  This name is also used as an epithet of spiritual leaders such as 
                  John Chrysostom, 
                  King Dāwit II, ʾabbā 
                     Giyorgis of Saglā and King 
                  Zarʾa Yāʿqob. 
                  It is the name of the author of several texts. </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>writer</snap:occupation></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT6799RHintro"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2113OntheB"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2095OnHowO"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2096OnHowO"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2092OnFast"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2090OnFast"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2091OnFast"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2118OntheD"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2109OntheA"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2137OntheP"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS8121RetuaH"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT2129OntheH
itation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">ar</dc:language><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ታዬ፡</foaf:name><foaf:name xml:lang="gez">Tāyye</foaf:name><foaf:name>qaññāzmāč</foaf:name><foaf:name xml:lang="ar">نور أحمد</foaf:name><foaf:name xml:lang="ar">Nūr Aḥmad</foaf:name><foaf:name>sayyid</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He had served as bodyguard at the court of Ḫāyla Śǝllāse I, before he 
                  converted from Christianity to Islam and adopted the name sayyid Nūr Aḥmad. He lead the inter-religious and inter-ethnic 
                  pilgrimage-site in Fārāqāsā (Arsi) after 1952 until pilgrimage was discontinued under the Darg in 1974.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS9353Tayye"><betmas:formerlyAlsoListedAs rdf:resource="https://betamasaheft.eu/PRS7621NurAhma"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS9353Tayye"><betmas:isSuccessorOf rdf:resource="https://betamasaheft.eu/PRS7141Momina"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS9353Tayye/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS9353Tayye"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS5226haylase"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-20+02:00</oa:annotatedAt><lawd:hasName>Ḫāyla Śǝllāse I</lawd:hasName></oa:Annotation></rdf:RDF>
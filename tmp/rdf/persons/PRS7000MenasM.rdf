>PRS7000MenasM</dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Solomon Gebreyes</dc:contributor><dc:contributor>Alessandro Bausi</dc:contributor><dc:contributor>SiegbertUhlig</dc:contributor><rdf:type rdf:resource="https://betamasaheft.eu/saint"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ሜናስ፡</foaf:name><foaf:name xml:lang="gez">Menās</foaf:name><foaf:name xml:lang="gez">ሚናስ፡</foaf:name><foaf:name xml:lang="gez">Minās</foaf:name><foaf:name>
                  ʾabbā 
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by/></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by/></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He was  a saint  and martyr venerated in the Byzantine empire  and all over the Christian Orient, especially in 
                        Egypt. He was supposedly martyred during the Diocletian
                        persecution of Christians  in Kotyaion. Minās seems to have been a popular saint in 
                        Ethiopia to which both his frequent representations in art as well as the name of 16th century 
               
                           
                     ʾaṣeMinās, named after him, testify.
                     </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7000MenasM"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/EnmityFor-https://betamasaheft.eu/PRS3581Diocleti"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/EnmityFor-https://betamasaheft.eu/PRS3581Diocleti"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#EnmityFor"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS3581Diocleti"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7000MenasM"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT1616Homily"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7000MenasM/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7000MenasM"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC2056Byzant"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Byzantine empire</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7000MenasM/place/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7000MenasM"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC2804Egypt"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Egypt</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7000MenasM/place/annotation/3"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7000MenasM"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC3010Ethiop"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Ethiopia</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7000MenasM/place/annotation/4"><oa:hasTarget rdf:resource="https://betamasaheft.eu/
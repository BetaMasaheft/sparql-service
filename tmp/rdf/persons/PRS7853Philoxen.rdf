on><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">syr</dc:language><skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q973954"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ፍልክሲኖስ፡ ዘሀገረ፡ ምንብግ፡</foaf:name><foaf:name xml:lang="gez">Fǝlǝksinos za-hagara Mǝnbǝg</foaf:name><foaf:name xml:lang="en">Philoxenus of Mabbog</foaf:name><foaf:name xml:lang="syr">ܦܝܠܠܘܟܣܝܢܘܣ ܕܡܒܘܓ</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>523</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by> He was one of the most notable Syriac prose writers and a vehement champion of Miaphysitism. In
               Ethiopia he is known above all as an author of a monastic treaty Filkǝsyos, which
             however is a misattribution. In fact, what might be actual translations of his works into Gǝʿǝz are
           very rare but cf. eg. EMML 1763, f. 129r-132v.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>writer</snap:occupation></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7853Philoxen"><skos:exactMatch rdf:resource="http://syriaca.org/person/44"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7853Philoxen"><saws:isAttributedAuthorOf rdf:resource="https://betamasaheft.eu/LIT3990Prayer"/></rdf:Description></rdf:RDF>
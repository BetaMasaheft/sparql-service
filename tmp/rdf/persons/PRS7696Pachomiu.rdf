                  ʾabbā
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">0294-01-01</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">0294-01-01</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">0356-01-01</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">0356-01-01</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by> He was the founder of cenobitic monasticism. He was born of pagan parents
                  in Upper Egypt. His first contact with
                  Christianity occurred in 312, when he was a conscript in the Roman
                  army. Then, Pachomius came into contact
                  with several well known ascetics and decided to pursue that path under the
                  guidance of the hermit named Palamon.
                  Finally, he established his own monastery in between 318 and 323. </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7696Pachomiu"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS6298Libanos"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS6298Libanos"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS6298Libanos"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7696Pachomiu"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS2209Athanasi"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS2209Athanasi"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS2209Athanasi"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7696Pachomiu/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7696Pachomiu"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC2804Egypt"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Egypt</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7696Pachomiu/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7696Pachomiu"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS7696Pachomiu"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Pachomius</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7696Pachomiu/person/annotation/2"><oa:hasTarget rdf:resource="https:
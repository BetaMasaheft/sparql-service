cCitation>PRS6859MasqalK</dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Solomon Gebreyes</dc:contributor><dc:contributor>SiegbertUhlig</dc:contributor><skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q60522711"/><foaf:gender>female</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">መስቀል፡ ክብራ፡</foaf:name><foaf:name xml:lang="gez">Masqal Kǝbrā</foaf:name><foaf:name>
                  baʿalta biḥat
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by/></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>She was the wife of King Lālibalā who  played a major role during his reign. She was responsible
                  for the fall of the metropolitan Mikāʿel II who had to return to Egypt after four years in Ethiopia.
                  She is also credited with the building of some churches at Lālibalā. Her title can be interpreted as the "Lady of biḥat"
               </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation>queen</snap:occupation></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS6859MasqalK"><betmas:wifeOf rdf:resource="https://betamasaheft.eu/PRS6152Lalibala"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS6859MasqalK"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/MotherOf-https://betamasaheft.eu/PRS10363Yetbara"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/MotherOf-https://betamasaheft.eu/PRS10363Yetbara"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#MotherOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS10363Yetbara"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS6859MasqalK"><ecrm:P129i_is_subject_of rdf:resource="https://betamasaheft.eu/LIT1481GadlaM"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6859MasqalK/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6859MasqalK"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC4244Laliba"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Lālibalā</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6859MasqalK/place/annotation/2"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6859MasqalK"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC1914Bihat"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>biḥat</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS6859MasqalK/person/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS6859MasqalK"/><oa:hasBody rdf:resource="https://betamasaheft.eu/PRS6152Lalibala"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedA
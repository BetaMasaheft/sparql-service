/dcterms:bibliographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">gez</dc:language><dc:contributor>Solomon Gebreyes</dc:contributor><dc:contributor>Alessandro Bausi</dc:contributor><dc:contributor>BorisTuraiev</dc:contributor><dc:contributor>AlessandroBausi</dc:contributor><dc:contributor>SiegbertUhlig</dc:contributor><rdf:type rdf:resource="https://betamasaheft.eu/saint"/><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="gez">ዘርአ፡ አብርሀም፡</foaf:name><foaf:name xml:lang="gez">Zarʾa ʾAbrǝham</foaf:name><foaf:name>
                  ʾabbā
               </foaf:name><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He was a saintly monk of  the spiritual line of ʾabbā 
                  ʾAnorewos "the Elder" in the 15th century. 
                  He was born from  his father ʾAmmǝḫa Ṣǝyon who was the head of the 
                  royal army and Zarʾa ʾAbrǝham was raised to be a soldier 
                  and assumed his father's position after the later death. However, he left his military role and became a warrior for God.</crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS10616ZaraA"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS1883Ammehas"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS1883Ammehas"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#SonOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS1883Ammehas"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS10616ZaraA"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS9858Walatta"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS9858Walatta"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#SonOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS9858Walatta"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS10616ZaraA"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS1955Anorewos"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS1955Anorewos"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS1955Anorewos"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS10616ZaraA"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS4070FereMik"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/AllianceWith-https://betamasaheft.eu/PRS4070FereMik"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#AllianceWith"/><snap:bon
iographicCitation><dc:format>xml</dc:format><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">en</dc:language><dc:language rdf:datatype="http://www.w3.org/2001/XMLSchema#language">am</dc:language><dc:contributor>SiegbertUhlig</dc:contributor><foaf:gender>male</foaf:gender><rdf:type rdf:resource="https://betamasaheft.eu/ontology/pers"/><foaf:name xml:lang="am">ምርጫ፡ ወርቄ፡
               </foaf:name><foaf:name>Mǝrč̣ā Warqe</foaf:name><foaf:name xml:lang="en">M. Warkee</foaf:name><foaf:name>liqa makʷās</foaf:name><foaf:name>lǝǧ</foaf:name><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E67_Birth"/><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1825-01-01</crm:P79_beginning_is_qualified_by><crm:P80_end_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1825-01-01</crm:P80_end_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><rdf:type rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E69_Death"/><crm:P79_beginning_is_qualified_by rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1896-01-01</crm:P79_beginning_is_qualified_by></crm:E52_Time-span></crm:P4_has_time_span><crm:P4_has_time_span><crm:E52_Time-span><crm:P78_is_identified_by>He was one of the first foreign-educated Ethiopians who acted as a diplomat, secretary and interpreter.
Mǝrč̣ā Warqe received his education at the British missionary school of John Wilson in Bombay.
In 1849 he left India and founded a school in ʿAdwā together with his
brother Gäbru Wärqe. Later, Mǝrč̣ā Warqe became a follower of Tewodros II.
He played a crucial political role during the British military compaign led by Robert Cornelis Napier.
Mǝrč̣ā Warqe established contact between Robert Cornelis Napier and Yoḥannǝs IV,
thus securing support for Yoḥannǝs IV after the downfall of Tewodros II.
In 1875 Mǝrč̣ā Warqe was an envoy of Yoḥannǝs IV in Cairo.
In 1884 he acted as a secretary of Yoḥannǝs IV, and in 1896 he served as
an interpreter for Mangašā Yoḥannǝs.
               </crm:P78_is_identified_by></crm:E52_Time-span></crm:P4_has_time_span><snap:occupation/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7019MercaWa"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/GrandchildOf-https://betamasaheft.eu/PRS4506Garabed"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/GrandchildOf-https://betamasaheft.eu/PRS4506Garabed"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#GrandchildOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS4506Garabed"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7019MercaWa"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS10055WarqeK"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/SonOf-https://betamasaheft.eu/PRS10055WarqeK"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#SonOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS10055WarqeK"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/PRS7019MercaWa"><snap:hasBond rdf:resource="https://betamasaheft.eu/bond/BrotherOf-https://betamasaheft.eu/PRS4398GabruWa"/></rdf:Description><rdf:Description rdf:about="https://betamasaheft.eu/bond/BrotherOf-https://betamasaheft.eu/PRS4398GabruWa"><rdf:type rdf:resource="http://data.snapdrgn.net/ontology/snap#BrotherOf"/><snap:bond-with rdf:resource="https://betamasaheft.eu/PRS4398GabruWa"/></rdf:Description><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7019MercaWa/place/annotation/1"><oa:hasTarget rdf:resource="https://betamasaheft.eu/PRS7019MercaWa"/><oa:hasBody rdf:resource="https://betamasaheft.eu/LOC1956Bombay"/><oa:annotatedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-05+02:00</oa:annotatedAt><lawd:hasName>Bombay</lawd:hasName></oa:Annotation><oa:Annotation rdf:about="https://betamasaheft.eu/PRS7019MercaWa/place/annotation/2"><oa:hasTarget rdf:resource="h
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="52">Fols 1–52</locus>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1340EnochE">መጽሐፈ፡ ሄኖክ፡ ነቢይ።</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ መሐሪ፡ ወመስተሣህል፡ ርኁ<sic resp="DR">ቅ</sic>፡ መዓት፡ ወብዙኃ፡ ምሕረት፡ ወጻድቅ፡ እጽሕፍ፡ አንሰ፡
                                መጽሐፈ፡ ሄኖክ፡ ነቢይ፡ በረከቱ፡ ወሀብተ፡ ረድኤቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ 
                                <del rend="erasure" extent="unknown"/>
                        <add place="overstrike">
                           <persName ref="https://betamasaheft.eu/PRS11707WaldaS">ወል<sic resp="DR">ዳ</sic>፡ ሳሙኤል፡</persName>
                        </add> 
                                ለዓለመ፡ ዓለም፡ አሜን።</incipit>
                            <listBibl type="text">
                                <bibl corresp="http://zotero.org/groups/358366/items/Q9VK72SZ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1851Henoch"/><title level="m">Liber Henoch aethiopice, ad quinque codicum fidem editus, cum variis lectionibus</title><author><forename>August</forename><surname>Dillmann</surname></author><pubPlace>Lipsiae</pubPlace><publisher>Sumptibus Fr. Chr. Guil. Vogelii</publisher><date>1851</date><biblScope unit="volume">12</biblScope><note type="url">https://archive.org/details/bub_gb_DigVAAAAQAAJ</note><note type="tags"><note type="tag">Enoch</note><note type="tag">Apocrypha</note><note type="tag">bm:Dillmann1851Henoch</note></note><note type="tag">Enoch</note><note type="tag">Apocrypha</note><note type="tag">bm:Dillmann1851Henoch</note></bibl>
                            </listBibl>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="53" to="80">Fols 53–80</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1688Job">ʾIyob</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ዘኢዮብ፡ ጻድቅ፡ በረከቱ፡ ትኩን፡ ምስለ፡ ፍቁሩ፡ 
                                <persName role="owner" ref="https://betamasaheft.eu/PRS11707WaldaS">ወልደ፡ ሳሙኤል።</persName>
                     </incipit>
                            <explicit xml:lang="gez">ወፈጺሞ፡ መዋዕሊሁ፡ ወጽሑፍ፡ ከመ፡ ይትነሣእ፡ ካዕበ፡ ምስለ፡ ዘያነሥኦሙ፡ እግዙአብሔር። ወከመዝ፡
                            ትርጓሜሁ፡ እመጽሐፈ፡ ሶርያ፡ ብሔሩሰ፡ ኀበ፡ ይነብር፡ አውስጢድ፡ ዘደወለ፡ ኤዶምያስ፡ ዘዓረብ። ወሰመይዎ፡ ስሞ፡ ኢዮባብ፡ ወአውሰበ፡ ብእሲተ፡
                            ዓረባዊተ። ወወለደት፡ ሎቱ፡ ወልደ፡ ዘስሙ፡ ሄኖን፡ ወውእቱ፡ አቡሆሙ፡ ለዝኁራን፡ ወልደ፡ ወልዱ፡ ለኤሳው፡
                                <add place="above">ኢዮብ፡ ውእቱ፡</add>
                            ባቡራሰ፡ ወኃምስ፡ ውእቱ፡ እምአብርሃም፡ ወእሉ፡ ነገሥት፡ እለ፡ ነግሡ፡ በኤዶም፡ ወውእቱ፡ ኰነነ፡ በሐውርተ፡ ቀዳሚ፡ ባለቅ፡ ወልደ፡ ቤዖር፡ ወስመ፡ ሀገሩ፡ 
                            ዲነባ፡ ወእምድኅረ፡ ባለቅ፡ ኢዮባብ፡ ዘስሙ፡ ኢዮብ፡ ወእምድኅሬሁ፡ አሶም፡ ወዘነ<sic resp="DR">ገ</sic>ሠ፡ በብሔረ፡ ቴማን፡ ወእምድኅሬሁ፡
                                አዳድ፡ ወልደ፡ በረደ፡ ዘቀተሎሙ፡ ለምድያም፡
                            በሐቅለ፡ ሞአብ፡ ስመ፡ ሀገሩ፡ ጌቴም። ወእለሂ፡ መጽኡ፡ ኀቤሁ፡ አዕርክቲሁ፡ ኤልፋዝ፡ ዘእምደቂቀ፡ ኤሳው፡ ንጉሠ፡ ቴማን፡ ወበልዳዶስ፡ መስፍነ፡ አውኬናዎን፡
                            ወሳፍር፡ ንጉሠ፡ አሜኔዎን። <space extent="2" unit="lines"/> 
                        
                        <supplied reason="undefined" resp="PRS4747Goldschm">አብ</supplied>ርሃም፡ ወለዶ፡ ለይስሐቅ። ይስሐቅ፡ ወለዶ፡
                                ለዔሳው። ዔሳው፡ ወለዶ፡ ለዛራ፤
                                ዛራ፡ ወለዶ፡ ለራጕኤል። ራጕኤል፡ ወለዶ፡ ለኢዮብ፡ ከመዝ፡ ውእቱ፡ ልደቱ።</explicit>
                            <note>The chapters are not numbered and many chapter beginnings are not indicated,
                                but most are rubricated.</note>
                            <note>
                        <persName ref="https://betamasaheft.eu/PRS4747Goldschm">Lazarus Goldschmidt</persName> characterizes the translation as arbitrary, words and sentences not present
                            in the Masoretic text have been added and some numbers and dates diverge from it.</note>
                            
                     
                        </msItem>
                        

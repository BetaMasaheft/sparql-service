                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic"> 
                                <date notBefore="1700" notAfter="1799" cert="low"/>
                                <seg type="script">Written by one hand, very good handwriting.</seg>
                                <seg type="rubrication">Some lines, chapter beginnings and all titles of chapters (<foreign xml:lang="gez">ምዕራፋት፡</foreign>), 
                                    chapter numbers in <ref target="#ms_i3"/>.</seg>
                            </handNote>
                            <handNote xml:id="h2" script="Ethiopic" corresp="https://betamasaheft.eu/FSUrueppII1#a1"> 
                            </handNote>
                            <handNote xml:id="h3" script="Ethiopic">
                                <seg type="script">Later hand, added the name of <persName ref="https://betamasaheft.eu/PRS11707WaldaS">Walda Sāmuʾel</persName> in <ref target="#ms_i1"/>.</seg>
                            </handNote>
                        </handDesc>
                        
                        <additions>
                            <list>
                                <item xml:id="e1">
                                    <desc>Emendations and conjectures have been added on every page.</desc>
                                </item>
                                
                                <item xml:id="e2">
                                    <desc>The name of <persName ref="https://betamasaheft.eu/PRS8249Ruppell">Eduard Rüppell</persName> has been added on the first page.</desc>
                                </item>
                                
                                <item xml:id="a1" corresp="#h2">
                                    <desc type="DonationNote">Donation note stating that this manuscript belonged to <persName ref="https://betamasaheft.eu/PRS11707WaldaS">Walda Sāmuʾel</persName>, 
                                        who donated it to <placeName ref="https://betamasaheft.eu/INS0316Waldb">Waldǝbbā</placeName>.</desc>
                                    <q xml:lang="gez">ዝንቱ፡ መጽሐፍ፡ ዘአቡነ፡ <persName ref="https://betamasaheft.eu/PRS11707WaldaS">ወልደ፡ ሳሙኤል፡</persName> 
                                        ዘወሀ<sic resp="DR">በ</sic>፡ 
                                        ለ<placeName ref="https://betamasaheft.eu/INS0316Waldb">መቅደ<sic resp="DR">ስ</sic>፡ አቡነ፡ ሳሙኤል፡ ዘ<sic resp="DR">ደገ</sic>መ፡ ዋሊ፡</placeName> 
                                        ከመ፡ ይኩኖ፡ ለመድኃኒተ፡ ሥ<sic resp="DR">ገ</sic>፡ ለነፍስ፡ ወመጠነ፡ ሤጡኒ፡ ወቄት፡ ተኍለት፡ ድሪም።</q>
                                </item>
                                
                                <item xml:id="a2">
                                    <desc type="Unclear">Note written on the third column of the same page as <ref target="#a1"/> stating that whoever wishes to carry this book out of the church has
                                    to leave a deposit of two dinar.</desc>
                                    <q xml:lang="gez">ዘአውፅአ፡ ዘንተ፡ መጽሐፈ፡ እምቤተ፡ ክርስቲያን፡ ይኩን፡ ዕዳሁ፡ ፪ዲናረ።</q>
                                </item>
                                
                            </list>
                        </additions>
                        

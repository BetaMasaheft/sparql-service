         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0522</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ አብ፡ ወበስመ፡ ዋሕድ፡ ወልዱ፨</l>
                  <l n="2">ወመንፈስ፡ ቅዱስ፡ ሕያው፡ ዘፈቃዶሙ፡ ፈቃዱ፨</l>
                  <l n="3">ውዳሴ፡ መልክእከ፡ እጽሐፍ፡ ለለ፡ አሐዱ፡ አሐዱ፨</l>
                  <l n="4">ሐድፈኒ፡ ለወልድከ፡ እምባሕረ፡ ኀጢአት፡ አዕዱ፨</l>
                  <l n="5">ከመ፡ ኢያሥጥመኒ፡ አባ፡ ለዓለም፡ ሞገዱ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ መከ፡ ጣዕመ፡ ወይን፡ ሠናይ፨</l>
                  <l n="2">ዘያስተፌሥሕ፡ አልባበ፡ በጊዜ፡ ስታይ፨</l>
                  <l n="3">ኮከበ፡ ጽባሕ፡ ዮሐንስ፡ ተላዌ፡ ፀሓይ፨</l>
                  <l n="4">ዘበልደትከ፡ ይትፌሣሕ፡ ሰማይ፨</l>
                  <l n="5">ወበጥምቀትከ፡ ትትሐሠይ፡ ቀላይ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በልብሰ፡ ገርዜን፡ ክቡር፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ ሠናየ፡ ዜና፡ ወዝክር፨</l>
                  <l n="3">ብፁዕ፡ ዮሐንስ፡ ዘደብረ፡ ቢዘን፡ መምህር፨</l>
                  <l n="4">መላእክት፡ ይሴብሑከ፡ በቃለ፡ ሐዋዝ፡ መዝሙር፨</l>
                  <l n="5">ወበጊዜ፡ ሞትከ፡ ታድለቀልቅ፡ ምድር፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ እብል፡ ለመልክእከ፡ በፍጻሜ፨</l>
                  <l n="2">ውስተ፡ ደብረ፡ ቢዘን፡ ቅድስት፡ ሥርጉተ፡ ደመና፡ ወጊሜ፨</l>
                  <l n="3">መምህረ፡ ሃይማኖት፡ ዮሐንስ፡ ወምዑዝ፡ ከመ፡ አበሜ፨</l>
                  <l n="4">ዘትሁብ፡ ሰላመ፡ አብ፡ ወእለ፡ መጽኡ፡ በሱላሜ፨</l>
                  <l n="5">ሶበ፡ ተጋብኡ፡ ይስምዑ፡ ትርጓሜ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ እብል፡ ለመልክኣቲከ፡ ኵሎን፨</l>
                  <l n="2">ዘበበ፡ ክፍሎን፨</l>
                  <l n="3">ነቢየ፡ ወንጌል፡ ዮሐንስ፡ ዘደብረ፡ ቢዘን፨</l>
                  <l n="4">አይጸግብ፡ በነጽሮ፡ ሥነ፡ መልክእከ፡ ዐይን፨</l>
                  <l n="5">ወእምነ፡ ሰሚዕ፡ ዜና፡ ገድልከ፡ ኢይጸግብ፡ እዝን፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ስብሐት፡ ለአብ፡ ዘእምቅድመ፡ ዓለም፡ ሀሎ፨</l>
                  <l n="2">ወስብሐት፡ ለወልድ፡ ዘኮነ፡ ቃሎ፨</l>
                  <l n="3">ለመንፈስ፡ ቅዱስ፡ ስብሐት፡ በቃለ፡ ብፅዓን፡ እንዘ፡ አሌዕሎ፨</l>
                  <l n="4">እስመ፡ ሰማዕኩ፡ እምንእስየ፡ ለዮሐንስ፡ ገድሎ፨</l>
                  <l n="5">ወግብረ፡ መልክኡ፡ ፈጸምኩ፡ ሰሚዕየ፡ ኵሎ፨</l>
               </lg>
            </div>
         </div>
      </body>

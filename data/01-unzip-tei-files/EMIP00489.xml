               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>

                  <msItem xml:id="ms_i1"><locus from="1r" to="103v" facs="001">Fols 1r–103v</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>Incomplete at the beginning and end. <ref type="work" corresp="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</ref> is missing</note>

                  <msItem xml:id="ms_i1.1"><locus from="1r" to="78v" facs="001">Fols 1r–78v</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note>beginning at the end of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps64"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps64</span></ref></note>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                  </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="78v" to="93v" facs="079">Fols 78v–93v</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note>incomplete at the end (through the end of the thirteenth canticle)</note>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="94r" to="102r" facs="094">Fols 94r–102r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <note>incomplete at the beginning</note>
                  </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="102r" to="103v" facs="102">Fols 102r–103v</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <note>incomplete at the end</note>
                      <msItem xml:id="ms_i1.4.1"><locus from="102r" facs="102">Fols 102r and following</locus><title>Monday</title></msItem>
                      <msItem xml:id="ms_i1.4.2"><locus from="103r" facs="103">Fols 103r and following</locus><title>Tuesday</title></msItem>
                  </msItem>
                </msItem>
               </msContents>

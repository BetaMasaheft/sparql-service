                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word God is not rubricated in the first three works; the word Mary is not rubricated in the final two works</desc>
                  <desc>There is no columetric layout of text</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#Inside front cover" facs="001">Fols. Inside,, </locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#5r" facs="005">Fol. 5r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1065RoadtoCalvary">Road to Calvary</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#21r" facs="021">Fol. 21r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="frame" xml:id="d8">
                    Decorative designs:
                    <locus target="#9r #32v #49v #59v #63v #71r #102r" facs="009 033 050 060 064 071 102">folss. 9r, 32v, 49v, 59v, 63v, 71r, 102r, </locus> (line of alternating red and black dots);
                    <locus target="#22r" facs="022">22r</locus> (line of black dots)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <locus target="#1r #7v #10r #12v #27v" facs="001 008 010 013 028">Fols. 1r, 7v, 10r, 12v, 27v</locus>
                    <desc>etc., words of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#9r #24v #28v #34v #36v" facs="009 025 029 035 037">Fols. 9r, 24v, 28v, 34v, 36v</locus>
                    <desc>etc., lines of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#23v" facs="024">f. 23v, line 14</locus>
                    <locus target="#24r" facs="024">f. 24r, line 5</locus>
                    <desc>
                    lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted;
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#38v" facs="039">Fol. 38v</locus>
                    <desc>
                    erasure markings are visible;
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#6v #7r #7v #13v #17v" facs="007 008 014 018">Fols. 6v, 7r, 7v, 13v, 17v</locus>
                    <desc>etc., text has been removed
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, three Coptic chain stitches attached with bridle attachments to carved boards with bone or ivory inlays, strap of fabric around the spine.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="other">bone or ivory inlays</material>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

                     <layoutDesc>
                       <layout columns="1" writtenLines="17 19">
                         <locus from="1r" to="102r" facs="001">Fols 1r–102r</locus>
                       </layout>
                       <layout columns="2" writtenLines="17 19">
                         <locus from="102r" to="103v" facs="102">Fols 102r–103v</locus>
                       </layout>
                     </layoutDesc>

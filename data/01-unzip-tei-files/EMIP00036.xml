               <msContents>
                  <summary>Miracles of Mary, ተአምረ፡ ማርያም፡, Image of Mercurius, መልክአ መርቆሬዎስ, Three Miracles of Mercerius, ተአምረ፡ መርቆሬዎስ, Two Miracles of Täklä Haymanot, ተአምረ፡ ተክለ ሃይማኖት, Ten Miracles of Jesus, ተአምረ፡ ኢየሱስ፡</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1v" to="35r" facs="004"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1.1"><locus from="1v" to="7r" facs="004"/><title type="complete" ref="https://betamasaheft.eu/LIT1968Mashaf">Maṣḥafa śǝrʿāt za-waṣʾa ʾǝm-manbara Mārqos ḥawāryā ʾǝm-makāna
          maʿāllǝqā</title>
                        <note>Extended version of Introductory Rite from Mu‘allaqa, incomplete at the beginning</note>
                        <incipit xml:lang="gez"><gap reason="omitted"/>አሜን። ኦእግዝእትየ፡ ቅድስት።ወድንግል፡ በ፪ማርያም፡ ወላዲተ፡ አምላክ፡ እሙ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ከሃሊ። ሶበ፡ ይትነበብ፡ መጽሐፈ፡ ተአምርኪ፡ አክናፈኪ፡ ጸልሊ። ወሕንባባቲህዩ፡ አልዕሊ። ወአዕፂቂሁ፡ አጽድሊ።</incipit>
                      </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="7r" to="8v" facs="009"/><title>Introductory exhortation</title></msItem>
                    <msItem xml:id="ms_i1.3"><locus from="9r" to="15r" facs="011"/><title>Four miracles, each concluded with a rhyming hymn</title>
                        <msItem xml:id="ms_i1.3.1"><locus from="9r" facs="011"/><title>Bishop Hildefonsus of Toledo</title></msItem>
                        <msItem xml:id="ms_i1.3.2"><locus from="11v" facs="014"/><title>The farmer to whom Mary spoke</title></msItem>
                        <msItem xml:id="ms_i1.3.3"><locus from="12v" facs="015"/><title>The old man from Akhmim whom Mary made young</title></msItem>
                        <msItem xml:id="ms_i1.3.4"><locus from="13v" facs="016"/><title><foreign xml:lang="gez">ዮሐንስ፡ በከንሲ፡</foreign> whose sight Mary restored with her milk</title></msItem>
                    </msItem>

                    <msItem xml:id="ms_i1.4"><locus from="15r" to="16r" facs="017"/><title type="complete" ref="https://betamasaheft.eu/LIT3056RepCh336">Hymn to Our Lady Mary</title>
                        <incipit xml:lang="gez">እሰግድ።ለኪ፡ ወእዌድሰኪ፡ ኦእግዝእትየ፡ ማርያም፡ ለፀሐየ፡ ጽድቅ፡ ሠረገላሁ። እሰግድ፡ ለኪ፡ ኦእግዝእትየ፡ ማርያም፡ ለመርዓዌ፡ ሰ[ማ]ይ፡ ጽርሑ።</incipit>
                      </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="16r" facs="018"/><title>Fifth miracle: The man who lost his mind when he lost his property</title></msItem>

                    <msItem xml:id="ms_i1.6"><locus from="17v" to="21r" facs="020"/>
                        <title>Image of Mercurius, <foreign xml:lang="gez">መልክዐ፡ መርቆሬዎስ፡</foreign> (possibly <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>)</title>
                        <note>The beginning has been erased to make room for a painting</note>
                        <incipit xml:lang="gez">ዘተከ፡ ብዙኃ። ሶበ፡ ሰማዕከ፡ እምወንጌል፡ በዓለመ።ዕበድ፡ ዘረብኃ። እምነ፡ ድልወቱ፡ ወአቅሙ፡ ያጠሪ፡ ስራኃ። ሰላም፡ ለከናፍሪከ፡<gap reason="omitted"/></incipit>
                      </msItem>

                    <msItem xml:id="ms_i1.7">
                        <locus from="21r" to="22v" facs="023"/>
                        <title>Three Miracles of Mercurius</title>
                        <msItem xml:id="ms_i1.7.1"><locus from="21r" facs="023"/><title>How a pagan was able to kill some one by the help of the Martyr</title>
                           <incipit xml:lang="gez">ተአምሪሁ፡<gap reason="omitted"/>ተብህለ፡ ከመ፡ ሀሎ፡ ፩አረማዊ፡ ወርእዮሙ፡ ለቅዱሳን፡ ክርስቲያን፡ እንዘ፡ የሐውሩ፡ ውስተ፡ ቤተ፡ ክርስቲያኑ፡<gap reason="omitted"/></incipit>
                         </msItem>
                        <msItem xml:id="ms_i1.7.2"><locus from="21v" facs="024"/>
                           <title>How the lips of a paramour and a wife of another man remained stuck to each other when they kissed each other as she was preparing drinks for the feast of the Martyr</title>
                           <incipit xml:lang="gez">ወሀሎ፡ [፩]ብእሲ፡ ዘሠረቀ፡ ብእሲተ፡ ካልዑ፡ ወበዕለተ፡ ተዝካሩ፡ ለብፁዕ፡ ወለቅዱስ፡ መርቆሬዎስ፡ እንዘ፡ ታስተዳሉ፡ [ስ]ቴ፡ ለበዓል<gap reason="omitted"/></incipit>
                         </msItem>
                        <msItem xml:id="ms_i1.7.3"><locus from="22r" facs="024"/>
                           <title>How the lips of a paramour and a wife of another man remained stuck to each other when they kissed each other as she was preparing drinks for the feast of the Martyr</title>
                           <incipit xml:lang="gez">ተአምሪሁ፡ ለብፁዕ፡ ወለቅዱስ፡ ነስተጋድል፡ መርቆሬዎስ፡ ጸሎቱ፡<gap reason="omitted"/>ወአመ፡ በዓሉ፡ ለቅዱስ፡ መርቆሬዎስ፡ ዘዕለተ፡ ቅዳሴ፡ ቤቱ፡ ወፅአ፡ ፩ብእሲ፡ ከመ፡ ይሕርስ፡ ገራኅቶ፡<gap reason="omitted"/></incipit>
                         </msItem>
                       </msItem>

                    <msItem xml:id="ms_i1.8"><locus from="22v" to="24v" facs="025"/><title type="incomplete" ref="https://betamasaheft.eu/LIT3971Taamme">Taʾammǝra Takla Hāymānot</title>
                        <msItem xml:id="ms_i1.8.1"><locus from="22v" facs="025"/><title>How <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName> called a pagan woman to join the monastic community of Däbrä Libanos</title>
                           <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>ወእምዝ፡ ንጽሕፍ፡ እንከ፡ ቅድመ፡ ዘተገብረ፡ በደብረ፡ ሊባኖስ፡ ተአምር፡ ወካዕበ፡ ይቤ፡ ዓዲ፡ በውስተ፡ አሕጉር፡ ስምዑ፡ ፍቁራንየ፡<gap reason="omitted"/>ወሀለወት፡ አሐቲ፡ ብእሲት፡ አረማዊት፡<gap reason="omitted"/></incipit>
                         </msItem>
                        <msItem xml:id="ms_i1.8.2"><locus from="24v" facs="027"/><title>How a mule refused to eat the grain belonging to (the monastery of) <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName></title>
                           <incipit xml:lang="gez">ተአምሪሁ፡<gap reason="omitted"/>ወከማሁ፡ በካልእትኒ፡ ሀገር፡ እምእክለ፡ አቡነ፡ ቅዱስ፡ ተክለ፡ ሃይማኖት፡ ወሀብዎ፡ ለበቅል፡<gap reason="omitted"/></incipit>
                         </msItem>
                       </msItem>

                    <msItem xml:id="ms_i1.9">
                        <locus from="25v" to="35r" facs="028"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2382Taamme">Taʾammǝra ʾIyasus</title>
                          <msItem xml:id="ms_i1.9.1"><locus from="25v" facs="028"/><title type="complete" ref="https://betamasaheft.eu/LIT6016MJCalf">Miracle of Jesus: The stolen calf</title></msItem>
                          <msItem xml:id="ms_i1.9.2"><locus from="26r" facs="028"/><title>The lions of the land of Asqalon</title></msItem>
                          <msItem xml:id="ms_i1.9.3"><locus from="27r" facs="029"/><title>The changing of the water to wine at the wedding Cana of Galilee</title></msItem>
                          <msItem xml:id="ms_i1.9.4"><locus from="28v" facs="031"/><title>The adulteress</title></msItem>
                          <msItem xml:id="ms_i1.9.5"><locus from="29v" facs="032"/><title type="complete" ref="https://betamasaheft.eu/LIT6013MJPresentation">Miracle of Jesus: The presentation of Jesus at the
          temple</title></msItem>
                          <msItem xml:id="ms_i1.9.6"><locus from="31r" facs="033"/><title type="complete" ref="https://betamasaheft.eu/LIT6012MJSalome">Miracle of Jesus: Salome praises Jesus</title></msItem>
                          <msItem xml:id="ms_i1.9.7"><locus from="32r" facs="034"/><title>Healing of the Blind and dumb man</title></msItem>
                          <msItem xml:id="ms_i1.9.8"><locus from="33r" facs="035"/><title>Christ tells how it would be at his second coming</title>
                           <incipit xml:lang="gez">ወአሜሃ፡ ይጸርሕ፡ ገብርኤል፡ መልዓክ፡ ላዕለ፡ ምስጢራትየ፡ ወሚካኤል፡ መልዓክ፡ ይነፍሕ፡ ቀርነ፡ ወትርዕድ፡ ምድር፡ ወኵሉ፡ ዘውስቴታ፡ ወዓዲ፡ ሰማያትኒ፡<gap reason="omitted"/></incipit>
                          </msItem>
                          <msItem xml:id="ms_i1.9.9"><locus from="34r" facs="036"/><title>The betrayal of Judas Iscariot</title>
                           <incipit xml:lang="gez">ተአምር፡ ዘገብረ፡ እግዚእነ፡<gap reason="omitted"/>ወእምዝ፡ ይቤሎሙ፡ ለአርዳኢሁ፡ ተንሥኡ፡ ንዑ፡ እምውስተ፡ ጽርሕ፡ ወወፅኡ፡ ኵሎሙ፡ ወቦኡ፡ ውስተ፡ ገነት፡ ወሶበ፡ ነበሩ፡ ህየ፡ ወይቤሎሙ፡ እግዚእ፡ ኢየሱስ፡ ናሁ፡ ቀርበ፡ ኀቤየ፡ ዘያገብአኒ፡<gap reason="omitted"/></incipit>
                         </msItem>
                         <msItem xml:id="ms_i1.9.10"><locus from="35r" facs="037"/><title>How the high priests conspired to bribe (the witnesses against Christ?)</title>
                           <note>incomplete at the end</note>
                         </msItem>
                       </msItem>
                     </msItem>

               </msContents>

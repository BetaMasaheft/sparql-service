                        <item xml:id="a5_763">
                           <locus target="#48r-48v">-48r-48v</locus>
                           <q xml:lang="ar">باب الرعاف والحيض والمذي والودي وأن يبول فى الفراش يكتب وعلق عليه</q>
                           <desc>Loose folio</desc>
                           <note>The text is faded.</note>
                           <note>
                              <desc>
                                 Quotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT2042IHA">باب للرعاف ولكثرة الحيض</ref>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="3r" to="3v">3r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1196IHA">تخميس قصيدة طيبة الاسماء</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسم الله الرحمن الرحيم|ألذ كلَام المرء فى طول محياه| وأحسن مايلقاه من أجر أخراه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>تحن وتلتاه القلوب صبابة اليه فلا زالت تحن وتلتاه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="97v">4r-97v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT0032IHA">مسائل التعليم في الفقه على مذهب الامام الشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v ">-4v </locus>بسم الله الرحمن الرحيم وبه نستعين. الحمد لله الذي فرض علينا شرايع الاسلام ومعرفة صحيح المعاصلة وفاسدها </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#97v">-97v</locus>وما هو تحته ثم على بيت المال تبرعا ثم عينا [افراضا] وهو [بدال ناجد] مسلم</explicit>
                     <note>Some folios are missing and some others are disordered.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="98r" to="98r">98r-98r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0941IHA">نظم الامر الناهي المؤيد بالمدد</title>
                     <incipit xml:lang="ar">
                        <locus target="#98r">-98r</locus>اللهم صل وسلم على سيدنا ومولانا محمد \ الامر الناهي المويّد بالمدد الإلهى \ الامر بشهادة ان لا اله الا الله وان محمدا رسول الله \ الناهى عن الشرك بالله الامر بالاقرار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98r">-98r</locus>الامر بالسعي والطواف \ الناهى عن الغلو والإسراف \ الامر بالتلبية والإحرام || الناهى عن النفقه<note>The last words are the catchword.</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="98v" to="98v">98v-98v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0221IHA#s143IHA">لامية الأفعال, باب المفعل والمفعِل
                    ومعانيهما</title>
                     <incipit xml:lang="ar">
                        <locus target="#98v">-98v</locus>مظلمة مطلع المجـمع محمدة  مذمة منسك مضـنة البخلا مزلة مفرق مضـلة ومدب محشر مسـكن محل من نزلاَ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98v">-98v</locus>واقـبـر ومـن ارب وثـلث اربـعها  كذا لمهلك التـثليث قد بـذلاَ
وكالصحيح الذي اليا عيـنـه وعـلى  راي تـوقـف ولا تـعـد الذي نـقـلاَ</explicit>
                     <note/>
                     <note/>
                  </msItem>

                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>

                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote xml:id="d1">
                      Decorative designs:
                      <locus target="#1r #18r #47v #53v #109v" facs="005 022 052 114">folss. 1r, 18r, 47v, 53v, 109v, </locus> (haräg);
                      <locus target="#64v #180v" facs="069 185">64v, 180v, </locus> (a line of full stops);
                      <locus target="#17v #77v #88v #95v #124r #127v #135r #139v #142v #158r" facs="022 082 093 100 128 132 139 144 147 162">17v, 77v, 88v, 95v, 124r, 127v, 135r, 139v, 142v, 158r</locus>
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1">
                      <desc>
                        Blank: <locus from="ir(ecto)" to="ivr(ecto)" facs="001">fols ir(ecto)–ivr(ecto), </locus>, <locus target="#181r" facs="185">181r</locus>
                      </desc>
                      </item>
                      <item xml:id="e2">
                      <desc>
                        <locus target="#ivv(erso)" facs="005">Fol. ivv(erso)</locus> text, effaced
                      </desc>
                      </item>
                      <item xml:id="a1">
                      <desc type="ScribalSignature">
                        <locus target="#166v" facs="171">Fol. 166v</locus> Scribe: <foreign xml:lang="gez">አለቀ፡ ተክለ፡ ማርያም፡</foreign> of Gondar
                      </desc>
                      </item>
                      <item xml:id="a2">
                      <desc>
                        <locus target="#181v #182r #182v" facs="186 187">Folss. 181v, 182r, 182v, </locus>, Notes of birthdays, in black ink and rather contemporary with the manuscript:
                        1915 (<locus target="#181v" facs="186"> f. 181v, col. 1</locus>),
                        1918 (<locus target="#181v" facs="186"> f. 181v, col. 2</locus>),
                        1923, (<locus target="#182r" facs="186"> f. 182r, col. 1</locus>),
                        1926 (<locus target="#182r" facs="186"> f. 182r, col. 2</locus>).
                        Ones added later in blue ink pen:
                        1917 (<locus target="#181v" facs="186"> f.181v, col. 1</locus>),
                        19?? (<locus target="#181v" facs="186"> f. 181v, col. 2</locus>),
                        1944 (<locus target="#182r" facs="186">, col. 1</locus>), and
                         1942 and 1947 (<locus target="#182r" facs="186"> f. 182r, col. 2</locus>). All dates are EC
                      </desc>
                      </item>
                      <item xml:id="e3">
                        <desc>
                          Scribal intervention: words of text are written interlinearly (<locus target="#22v #59v #106v #122v" facs="027 064 127">folss. 22v, 59v, 106v, 122v, </locus>, etc.);
                          and lines of text are written interlinearly (<locus target="#47r #49v #94v #138r" facs="051 054 099 142">47r, 49v, 94v, 138r, </locus>, etc.);
                          erasure markings are visible (<locus target="#24v" facs="029">24v, </locus>); text has been removed (e.g., <locus target="#80v #171v" facs="085 176">80v, 171v</locus>).
                        </desc>
                      </item>
                      <item xml:id="e4">
                        <desc>
                          The scribe regularly has to complete a line of text on another line.
                          Much of the problem is addressed through the selection of an appropriate aspect ratio for the codex combined with an
                          appropriate script size. But, where the line of text is still too long, the scribe completes the line of text above
                          the end of the line (throughout).
                        </desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 134 x 100 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

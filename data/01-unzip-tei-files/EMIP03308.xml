               <msContents>
                  <summary>Image of Mik’ael, Image of Gabri’el, Prayer of Mary, Mystagogia</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="17v" facs="002">Fols 2r–17v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa
                                                  Mikāʾel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ: ስመ: ልዑል: ዘተሳተፈ:</incipit>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="17v" to="22r" facs="018">Fols 17v–22r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa
                                                  Gabrǝʾel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <incipit xml:lang="gez">ሰላመ: ገብርኤል: መልአክ: በላዕለ: ማርያም: ዘአዕረፈ:</incipit>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="22r" to="48r" facs="022">Fols 22r–48r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">, the first quire of this work is in reverse order since the quire has been turned upside down in relation to the rest of the book</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i4"><locus from="52r" to="61r" facs="052">Fols 52r–61r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">61</measure>

                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#49r #49v #50r" facs="049 050">Fols. 49r, 49v, 50r</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> against disease, <foreign xml:lang="gez">ጸሎት: በእንተ: ሕማም፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    The shade of red ink indicates a time frame in the early 20th century
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#47r #47v #48r #48v" facs="047 048 049">Fols. 47r, 47v, 48r, 48v</locus>
                    <desc type="OwnershipNote">
                    Concluding prayer and note of ownership, written in a different hand, in red ink. The owner is <foreign xml:lang="gez">ገብረ፡ ኢየሲስ፡</foreign>, Gabra Iyassus; the sacribe is <foreign xml:lang="gez">በቀለ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#17v" facs="018">Fol. 17v</locus>
                    <desc>
                    The name, <foreign xml:lang="gez">ወልደ፡ እግዚእ፡</foreign>, Walda Egzia is written, in red ink, in the left margin. It appears again, in black ink, on <locus target="#48v" facs="049">fol. 48v</locus>
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    The book is held in the shipping package in which it came from Ethiopia: Return address: Lidya Melaku, C/O Melat Solomon P.O. Box 3948, Addis Ababa, Ethiopia.  Recipient: Kenneth Hobby, 65 Mohawk Dr, Searcy AR 72143, United States.  The book is wrapped in an Ethiopian Newspaper, photos of which were taken
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="false">
                    <decoNote xml:id="b1">Parchment. Simple wooden boards, the front one of which is broken and repaired with thread. The book has been rebound.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1950">Early-twentieth century</origDate>
                  </origin>
               </history>

                        <additions>
<list>
<item xml:id="e1">
    <desc><persName ref="https://betamasaheft.eu/PRS13743RamhaS">Ramḫā Śǝllāse</persName> and <persName ref="https://betamasaheft.eu/PRS13742HaylaI">Ḫāyla ʾIyasus</persName> are mentioned in supplications throughout.
      <foreign xml:lang="gez">ንጉሥነ፡ ሰሎሞን፡</foreign>, probably to be identified with  <persName ref="https://betamasaheft.eu/PRS5618IyasuII">ʾIyāsu III</persName>,
        is mentioned in supplications until <locus target="#185r"/>; on <locus target="#186r"/>, 
        <foreign xml:lang="gez">ለነፍሰ፡ ንጉሥነ፡ ሰሎሞን፡</foreign>, probably to be identified with
        <persName ref="https://betamasaheft.eu/PRS8421Salomon">Salomon I</persName> occurs; starting from <locus target="#186v"/>, both occur.</desc>
</item>
    
    <item xml:id="e2">
        <locus target="#191vb"/>
        <desc>The colophon mentions a <persName role="sponsor" ref="https://betamasaheft.eu/PRS13745Iyasu">ʾIyāsu</persName> as sponsor of the manuscript.</desc>
    </item>
    
    <item xml:id="a1">
        <locus target="#4v"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
            Fāsiladas za-Qahā, probably to be identified with <placeName ref="https://betamasaheft.eu/INS0935Fasiladas">Fāsiladas</placeName>.</desc>
        <q xml:lang="gez">ስንክሳር፡ ዘቅዱስ፡ <placeName ref="https://betamasaheft.eu/INS0935Fasiladas">ፋሲለደስ፡ ዘቀሃ።</placeName>
        </q>
    </item>
    
    <item xml:id="a2">
        <locus target="#5r"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
            <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
        <q xml:lang="gez">ስንክሳር፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
        </q>
    </item>
</list>

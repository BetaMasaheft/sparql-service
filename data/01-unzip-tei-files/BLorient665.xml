                    <history>
                        <origin>
                            <origDate notBefore="1784" notAfter="1788" evidence="reign"/>
                        </origin>
                        <provenance>The manuscript had very probably belonged to <placeName ref="https://betamasaheft.eu/INS0935Fasiladas">Fāsiladas</placeName>, 
                            from where it was taken by <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. 
                            It was then looted by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.
                        </provenance>

                    </history>


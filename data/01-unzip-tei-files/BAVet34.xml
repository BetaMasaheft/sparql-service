               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="42v"/>
                     <title>Ordinary of the mass and Anaphora of the Apostles</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="7v"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddase">Ordinary of the mass</title>
                        <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ ጸሎተ፡ ቍርባን፡ ዘይትነበብ። በከመ፡ ሥሩዕ።</incipit>
                        <note>The text begins in correspondence with <bibl corresp="http://zotero.org/groups/358366/items/U677IG76"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Mercer1915Liturgy"/><title level="m">The Ethiopic liturgy: its sources, development, and present form</title><title level="s">The Hale lectures, Western theological seminary, Chicago</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Samuel Alfred Browne</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Mercer</t:surname></author><pubPlace>Milwaukee; London</pubPlace><publisher>Young churchman Co. ; A.R. Mowbray &amp; Co.</publisher><date>1915</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">The Hale lectures, Western theological seminary, Chicago</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">Ill. Series of 1914-5</t:biblScope></series><biblScope unit="volume">Ill. Series of 1914-5</biblScope><note type="url">https://archive.org/details/ethiopicliturgyi00mercuoft</note><citedRange>403 (ed.), 304 (tr.)</citedRange></bibl>.</note>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="16v" to="22"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1104Anapho">Anaphora of the Apostles</title>
                        <note>The text is untitled. It terminates in correspondence with <bibl corresp="http://zotero.org/groups/358366/items/U677IG76"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Mercer1915Liturgy"/><title level="m">The Ethiopic liturgy: its sources, development, and present form</title><title level="s">The Hale lectures, Western theological seminary, Chicago</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Samuel Alfred Browne</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Mercer</t:surname></author><pubPlace>Milwaukee; London</pubPlace><publisher>Young churchman Co. ; A.R. Mowbray &amp; Co.</publisher><date>1915</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">The Hale lectures, Western theological seminary, Chicago</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">Ill. Series of 1914-5</t:biblScope></series><biblScope unit="volume">Ill. Series of 1914-5</biblScope><note type="url">https://archive.org/details/ethiopicliturgyi00mercuoft</note><citedRange>462b l. 2 (ed.), 870 l. 27 (tr.)</citedRange></bibl>
                        </note>
                     </msItem>    
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="42v" to="53"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">ቅዳሴ፡ ዘእግዚእነ፡</title>
                     <explicit xml:lang="gez">
                        ወስክ፡ ሎሙሂ፡ 
                           <sic>ወሎነሂ፡</sic>
                         ሀይማኖተከ፡ ወፈሪሆተ፡ ስምከ፡ በ፩ወልድከ፡ ለዓለመ፡ ዓለም።
                     </explicit>   
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="53v" to="78v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ዝቅዳሴ፡ ዘአባ፡ ህርያቆስ፡</title>
                     <note>The last blessing is: <q xml:lang="gez">እግዚአብሔር፡ ይምሐረነ፡ በጸሎታ፡ ወበስእለታ፡ ለዓለመ፡ ዓለም፡ አሜን፨</q>.</note>   
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="78v" to="90v"/>
                     <title ref="https://betamasaheft.eu/LIT3120Anapho">ቅዳሴ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ኤጲስ፡ ቆጶስ፡</title>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="91" to="92"/>
                     <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1693John">Gospel of John</ref> 4:4-12</title>
                  </msItem>
                  

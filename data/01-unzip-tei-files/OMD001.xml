               <ab>
                  <pb n="1r"/>
                  <lb n="1"/><hi rend="rubric">በስመ አብ፡ ወወል
                  <lb n="2"/>ድ፡ ወመንፈስ፡ ቅዱስ
                  <lb n="3"/>፩፡</hi> አምላክ፡ ጸሎት
                     <lb n="4"/>በእንተ፡ ማዕሠ
               <lb n="5"/>ረ፡ አጋንንት፡ በስሙ
               <lb n="6"/>ለአብ በስሙ፡ ለመን
               <lb n="7"/>ፈስ፡ ቅዱስ፡ ታኦስ፡
                  <lb n="8"/><hi rend="rubric">ማስያስ፡ አቅዴፌር
               <lb n="9"/>ለሐራፈር፡ ሐራፌኬ
                     <lb n="10"/>ህ፡ ፍልፍማኤል፡ በ</hi>
               <lb n="11"/>ስመ፡ ሳዶር፡ አላዶር 
               <lb n="12"/>ዳናት፡ አዴራ፡ ሮዳ
               <lb n="13"/>ስ፡ እብስቱር፡ ፀባዖት
               <lb n="14"/>፡ ሸጭርዋቅ፡ እምር
               <lb n="15"/>አሥር፡ ወእንሱራፌ
                  <lb n="16"/>፡ አንሂሃ፡ <hi rend="rubric">፡ ቀያጢን፡ አ
               <lb n="17"/>ንቀጥቃጢን፡ ወያፍ
                     <lb n="18"/>ጢን፡ እልህያሹን፡ መር
                     <lb n="19"/>ኮብዮን፡ ማኅፈረኪ፡
                     <lb n="20"/>ወያሹን፡ ሊሃላ፡ ኢየ
                     <lb n="21"/>ሱስ፡ ክርስቶስ</hi> በሰይ
                  <lb n="22"/>ፈ ሚካኤል፡ ወገብር
                     <lb n="23"/>ኤል፡ ይትገዘም፡ ወፃ
                     <lb n="24"/>ዕ፡ መንፈስ፡ ርኩስ፡ ወ
                     <lb n="25"/>ዘአኃዘ፡ እደ፡ ሰብእ፡ ወ
                     <lb n="26"/>ተግባረ፡ ሰብእ፡ ይይ
                  <lb n="27"/><hi rend="rubric">ትገዘም፡ ወይፃዕ፡ መንፈስ፡ 
                     <lb n="28"/>ርኩስ፡ ወዘአኃዞ፡ እዶ፡ <del rend="expunctuated">ወ</del>ሰ
               <lb n="29"/>ብእ፡ ወተግባረ፡ ሰብእ
               <lb n="30"/>ይደምስስ፡ ኀበ፡ ዘቦአ፡ ዝ
               <lb n="31"/>ንቱ፡ ጸሎት፡ እምላዕለ፡
               <lb n="32"/>ነፍሱ፡ ወሥጋሁ፡ ለገብር
                     <lb n="33"/>ከ፡ <add place="overstrike"><persName role="owner" ref="https://betamasaheft.eu/PRS13565GabraS">ገብረ፡ ሥላሴ፡</persName></add></hi> አልፍ 
               <lb n="34"/>፡ አልፍ፡ ፃዕ፡ ወፂአከ፡ ኢት
                     <lb n="35"/>ግባዕ፡ ይቤለከ፡ እግዚአ
                     <lb n="36"/>ብሔር፡ ወዝክረ፡ ስም
               <lb n="37"/>ከ፡ ይደምስስ፡ ለዓለመ
                  <lb n="38"/>፡ <hi rend="rubric">ዓለም፡ ያቁድ፡ ያቁድኅ
                  <lb n="39"/>አንተ፡ ባርያ፡ ወአንተ፡ ጋ
                  <lb n="40"/>ኔን፡ አንተ፡ ሰይጣን፡ ወ
                  <lb n="41"/>አንተ፡ ትግርትያ፡ አንተ</hi>
                  <lb n="42"/>፡ ዓይነት፡ ወአንተ፡ ቡዳ፡ አ
                  <lb n="43"/>ንተ፡ ዘትትሜሰል፡ በብዙ
                  <lb n="44"/>ኅ፡ <del rend="expunctuated">ፆ</del>ፇታ፡ አህያ፡ ሸምራ
                  <lb n="45"/>ኤል፡ ኃይለ፡ እግዚአብሔር
                  <lb n="46"/>እግዚእ፡ ያሸኩት፡ ሩሃ
                  <lb n="47"/>ል፡ ጋዴ፡ ዓምደ፡ <hi rend="rubric">ብርሃ
                  <lb n="48"/>ን፡ ልብሰ፡ ብርሃን፡ ይበር

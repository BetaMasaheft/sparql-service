                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Early 19th century</date>
                        <list type="abbreviations">
                           <item>ሃ፡ ሉ፡ or ሃሌ፡ ሉ፡ for ሃሌ፡ ሉያ፡</item>
                           <item>ሃ፡ ሃ፡ ሃ፡ for threefold ሃሌ፡ ሉያ፡</item>
                           <item>
                              <abbr>ፍ፡ ረ፡ or ፍቱ፡ ረ፡</abbr> for <expan>ፍቱሐ፡ ረስያ፡ </expan> (cp. <locus target="#18r">18r</locus>, 18v, 19r passim).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipits of the texts; directives for
                           the ministers; the word ሃሌ፡ ሉያ፡; names of the donors (cp. fols. 11rb,
                           l.7; 17ra, l.4; 76v-77r passim, etc.); elements of the punctuation signs;
                           most of the abbreviations; Additio I.
 
 The text on fol. 3r is
                           written alternately in black and red lines.</seg>
                     </handNote>
                  </handDesc>

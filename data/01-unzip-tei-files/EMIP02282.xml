                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ዮሐንስ</foreign>
                  <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                  <foreign xml:lang="gez">መንፈስ፡ ቅዱስ፡</foreign>

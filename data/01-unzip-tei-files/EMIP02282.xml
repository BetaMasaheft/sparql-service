                  </seg>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus><desc>A <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> (member of the Trinity?) flanked by two <term key="angel" ana="#angel"/>s with <term key="sword" ana="#sword"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>, surrounded by two of the Four Living Creatures: the <term key="angel" ana="#angel"/> and the eagle</desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> with hand-crosses and censures</desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> flanked by two <term key="angel" ana="#angel"/>s with <term key="sword" ana="#sword"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d5"><locus target="#93v" facs="096">Fol. 93v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> with hand-crosses</desc></decoNote>
                  <decoNote type="miniature" xml:id="d6"><locus target="#94r" facs="096">Fol. 94r</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> with hand-crosses</desc></decoNote>
                  <decoNote type="frame" xml:id="d7">
                  Decorative designs:
                  <locus target="#1r #40v #46v #73r" facs="003 043 049 075">folss. 1r, 40v, 46v, 73r, </locus> (ornamental bands added secondarily, probably for the tourist market);
                  <locus target="#6r #10v #12v #17v #40r #73r" facs="008 013 015 020 042 075">6r, 10v, 12v, 17v, 40r, 73r</locus> (multiple full stops)
                  </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#ms_i1">Fols. ms_i1, </locus>
                    <locus target="#17v #22r #48r #54v #59r #76r #86r" facs="020 024 050 057 061 078 088">17v, 22r, 48r, 54v, 59r, 76r, 86r</locus>
                    <desc>Headings for the days of the week: Saturday, Tuesday, Wednesday, Sunday (by a different hand), Thursday (by a different hand), Friday, Sunday</desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#56v" facs="059">Fol. 56v</locus>
                    badly faded text written in pencil
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#1 #40 #46 #73" facs="003 042 048 075">Fols. 1, 40, 46, 73</locus>
                    black thread sewn into fore edge to mark location of ornamental bands as navigation system
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#48" facs="050">Fol. 48</locus>
                    purple thread sewn into fore edge to mark reading as navigation system
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#59" facs="061">Fol. 59</locus>
                    white thread sewn into fore edge to mark reading as navigation system
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                      words of text are written interlinearly (<locus target="#35r #39r #54r #74r #76v" facs="037 041 056 076 079">folss. 35r, 39r, 54r, 74r, 76v, </locus>, etc.);
                      words of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted (<locus target="#2r #81v" facs="004 084">2r, 81v, </locus>);
                      text has been removed (<locus target="#15v #16r #22v #31v" facs="018 025 034">15v, 16r, 22v, 31v</locus>).
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, wrapped with cloth.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="textile"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

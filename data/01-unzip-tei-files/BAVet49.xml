                  <msItem xml:id="ms_i2">
                     <locus from="49r" to="68r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾtǝna Māryām ba-Dabra Golgotā</title> 
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡ ዘጸለየት፡ አመ፡ ፳ወ፩፡ በወርኃ፡ 
                        ሰኔ፡ በደብረ፡ ጎል<supplied reason="omitted">ጎ</supplied>ጎታ፡ ዝውእ<supplied reason="omitted">ቱ</supplied>፡ መቃብረ፡ እግዚ<supplied reason="omitted">እ</supplied>ነ፡ 
                        ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ ትብል፡ እግዚእየ፡ 
                           <sic>ወአምለኪየ፨</sic>
                         ወወልድየ፡ ወንጉሥየ፡ ኢየሱስ፡ ክርስቶስ፨ ዘተወልድከ፡ እምኔየ፡ ወጠበውከ፡ ሐሊበ፡ 
                        እምአጥባትየ፡
                     </incipit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="68v" to="84r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title> 

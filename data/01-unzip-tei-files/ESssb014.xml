               <msContents>
                  <summary>I) Maftǝḥe śǝrāy “Undoing of Charms”: 15 protective prayers (fols.
                     1r-56r)
 
 Additio 1.</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="56r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1824Mafteh">Maftǝḥe śǝrāy “Undoing of Charms”:
                        15 protective prayers</title>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">57.0</measure> folios, of which
                              <measure unit="leaf" type="blank"/> blank 57v, in <measure unit="quire"/> quires (unknown). <dimensions type="outer">
                              <height unit="mm">100</height>
                              <width unit="mm">90</width>
                              <depth unit="mm">30</depth>
                           </dimensions>
                        </extent>
                        <foliation>Foliated by the Ethio-SPaRe team</foliation>
                        <collation>The quire structure cannot be exactly established
                           due to the condition of the Ms.
                        </collation>
                        <condition key="good">The sewing is damaged and repaired with modern thread.
                           
 The Ms. is affected by humidity in the upper corners.
 The
                           bottom corners are dirty and show signs of intensive use; some fols. are
                           worn out.
 Some fols. may be missing, some are misplaced (<locus target="#49">49</locus>).</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" writtenLines="8">
                           <dimensions unit="mm">
                              <height>60</height>
                              <width>58</width>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">15</dim>
                              <dim type="bottom">30</dim>
                              <dim type="right">19</dim>
                              <dim type="left">11</dim>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <note>All data for <locus target="#2r">2r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Ruling and pricking are visible.</ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are visible.</ab>
                           <ab type="pricking"> Ruling pricks are visible.</ab>
                           <ab type="ruling"> The upper line is written above the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Very fine, regular.</seg>
                        <seg type="ink">Black and red (vivid vermillion).</seg>
                        <date>Late 17th early 18th century.</date>
                        <seg type="rubrication">Divine names; name of the (original) owner (erased);
                           four lines alternating with black lines on the incipit page (fol. 1r);
                           one or two lines on the incipit of each prayer; elements of the
                           punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="drawing" xml:id="d1">
                        <locus target="#3v">f. 3v: </locus>
                        <desc>Anthropomorphic motif (eyes) included in text divider.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d2">
                        <locus target="#4r">f. 4r: </locus>
                        <desc>“Seal of Solomon”.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d3">
                        <locus target="#12v">f. 12v: </locus>
                        <desc>“Seal of Solomon”.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d4">
                        <locus target="#43v">f. 43v: </locus>
                        <desc>Geometric motifs, grid design.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d5">
                        <locus target="#56r">f. 56r: </locus>
                        <desc>Angelic script.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d6">
                        <locus target="#56v">f. 56v: </locus>
                        <desc>Geometric motifs</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#57r">f. 57r</locus>
                           <desc type="ProtectivePrayer">Protective prayer.</desc>
                           <q xml:lang="gez">
                               በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡
                              ፯ውናኤል፡ ፯ መ[n.l.]ሮየኤል። ፯አማኑኤል፡ ማ[n.l.]…</q>
                           
                           <note> Written in a secondary hand with some distinctive features: round
                              small letter, big forked serifs of vowel marker in ዝ, distinctive
                              curvy hook in vowel marker of letters ቅ and ት. </note>
                        </item>
                        <item xml:id="e1"><desc>Minor notes (partly erased): <locus target="#6r">6r</locus>, 13v, 14r, 55v, 56r, 56v.</desc> </item>
                        <item xml:id="e2"><desc>Interlinear correction:
                              <locus target="#34r">34r</locus>.</desc></item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two leather boards.
 One pair of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Some quires are reinforced with small
                           parchment guards.</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origPlace>
                        <placeName ref="https://betamasaheft.eu/INS0111SSB">Bet Ḥāwāryāt</placeName>
                     </origPlace>
                     <origDate notBefore="1650" notAfter="1750"/>
                  </origin>
                  <provenance>The name of the original owner, most probably
                     Takla Hāymānot (s. fol. 42r), has been erased throughout the Ms. and replaced
                     with Gabra Ḥǝywat (<locus target="#3v">3v</locus>) and Tasfā Mikāʾel (<locus target="#24v">24v</locus>).</provenance>
               </history>

               <msContents>
                  <summary>Gospel of John, Prayer of Sankaramon, Prayer that Jeremiah prayed, Greeting to Phanuel</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="57v" facs="003">Fols 3r–57v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1"><locus target="#3r" facs="003">Fol. 3r</locus><title>Monday</title></msItem>
                      <msItem xml:id="ms_i1.2"><locus target="#12v" facs="013">Fol. 12v</locus><title>Saturday</title></msItem>
                      <msItem xml:id="ms_i1.3"><locus target="#37v" facs="038">Fol. 37v</locus><title>Thursday</title></msItem>
                      <msItem xml:id="ms_i1.4"><locus target="#47r" facs="047">Fol. 47r</locus><title>Friday</title></msItem>
                      <msItem xml:id="ms_i1.5"><locus target="#54r" facs="054">Fol. 54r</locus><title>Sunday</title></msItem>


                  <colophon xml:id="coloph1">
                  <locus target="#57v" facs="058">Fol. 57v</locus>
                  <note>written in the form of a five-line rhyming hymn</note>
                  <foreign xml:lang="gez">
                    ዝ፡ መጽሐፍ፡ (ሚካኤል፡) ወጸሐፊሁ፡ ኃጥእ፡ ወአባሲ፡ [….] ምግባራቲሁ፡ ርኵስ።
                    በኃይለ፡ ወንጌሉ፡ ይዕቀቦ፡ (ለገብሩ፡ ሚካኤል፡) ወለኵልነ፡ ይምሐረነ፡ ክርስቶስ።
                    በሥጋ ወነፍስ።
                    ያድኀነነ፡ እምእደ፡ ዲያብሎስ።
                    በወንጌሉ፡ ሐዲስ፤ ወበሥጋሁ፡ ቅዱስ፡ ለዓለመ፡ ዓለም፡ አሜን፡</foreign>.
                    Translation:
                    <q>This book belongs to Mika’el. The scribe is sinner and transgressor [….].
                      By power of his gospel may Christ protect and forgive us
                      in flesh and soul.
                      And may he save us from the hand of the devil
                      by the new gospel, and by his holy body. Forever and ever, Amen</q>
                </colophon>

                </msItem>

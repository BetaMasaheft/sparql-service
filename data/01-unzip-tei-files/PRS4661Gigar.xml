         <listPerson>
            <person sex="1" sameAs="wd:Q342829">
               
               <persName xml:lang="gez" xml:id="n1" type="birth">ጊጋር፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Gigār</persName>
               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
               <occupation type="ruler">Emperor</occupation>
               
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>

               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName>
               </residence>

               <floruit notBefore="1821" notAfter="1830">He was one of the nominal kings of the Zamana Masāfǝnt, who was placed on the throne by 
                  <persName ref="https://betamasaheft.eu/PRS4870GugsaMa">Gugsā Marsā</persName> and deposed by <persName ref="https://betamasaheft.eu/PRS3617DoriGug">Dori Gugsā</persName> in <date>1830</date>. 
                  He was a monk before he was enthroned. Gigār made a number of land grants which are recorded both in the <ref type="work" corresp="https://betamasaheft.eu/LIT1913Mashaf">Mäṣḥafä Aksum</ref>
                  and in the marginalia of the manuscripts in the <placeName ref="https://betamasaheft.eu/INS00001BL">British Library</placeName> 
                  . He also made grants directly to the churches 
                  like <placeName ref="https://betamasaheft.eu/LOC2248DabraB">Dabra Bǝrhān Śǝllāse</placeName> and <placeName ref="https://betamasaheft.eu/LOC3407GemjaB">Gǝmǧā Bet Māryām</placeName>.</floruit>
            </person>
            
         </listPerson>
    

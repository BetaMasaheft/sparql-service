               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="141r">2v-141r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1236IHA">كتاب مفتاح مجمع البركات فى الصلاة والسلام على فضل
                    البريات</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الله الرحمن الرحيم الحمد لله العلي للجيد المفتاح العليم الغني الحميد الجواد الكريم المتفضل بالنعيم المقيم على العبيد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#140v-141r">-140v-141r</locus>محمد صلاة تحسن لنا بها بها ختا ما اللهم صل وسلم على سيدنا محمد وعلى ال محمد صلاة تجعل لنا الجنة مستقر او مقاما والحمد لله رب العالمين دهر او عاما </explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>
                        <extent>
                           <measure unit="folio">145</measure>
                                        Pre: <measure unit="folio">0</measure>
                                        Post: <measure unit="folio">0</measure>
                        </extent>
                     </supportDesc>

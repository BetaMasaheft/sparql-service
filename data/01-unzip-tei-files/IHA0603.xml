                  <handDesc>
                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA0603#ms_i0"/>
                  </handDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1_1598">
                           <locus target="#2v-3v">-2v-3v</locus>
                           <q xml:lang="ar">بسم الله الرحمن الرحيم الحمد لله ذى الجود والافضال المان بالنوال قبل السؤال للوقف للصواب فى الاقوال وللافعال والصلاة والسلام على صفوة الارسال الذى هو عين مدد الحق بلا زوال وعلى اله وصحبه كمل الرجال 
وبعد فقد اخبرنى من اثقه من الاخوان اصلح الله لي وله الحال وبلغه الامال وسقاه من شراب الوصال وقال قد اشتغلت بقرءة هذه الصلوة فى ليلة الجمعة فاخذتنى سنة والصلوة فى يدى </q>
                           <desc>Muqaddima</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1598">
                           <locus target="#4r">-4r</locus>
                           <q xml:lang="ar">كتاب مفتاح مجمع البركات فى الصلاة والسلام على فضل البريات تاليف الشيخ العارف بالله تعالى ذى الاخلاص للرضية ولا حوال السنية والمعارف الالاهية والعلم اللدنية وذى الباع الواسع فى الحضرة المعنوية الذى هام فى اودية الفناء والبقاء والغيبة الحضور اعنى به الشيخ محمد يس امد الله حياته واعاد علينا من بركاته وبركات علومه وسقانا من حميا شرابه امين امين امين ا م ي ن</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                        <item xml:id="a2_1598">
                           <locus target="#141r">-141r</locus>
                           <q xml:lang="ar">يا قارئ الخطي سالتك بالذى امات واحي والعظام رميم بغفران زلتى من الله الحليم فانه لا يزال رحيم</q>
                           <desc>Scribal verses</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_1598">
                           <locus target="#141r">-141r</locus>
                           <q xml:lang="ar">وعدد جميع هذه الصلاة غشسه</q>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#144v">-144v</locus>
                           <q>ونقل عن الأمام اليافعي في كتابه بستان القول انه ورد عن النبي صلى الله عليه وسلم انه قال من صلى على يوم الجمعة الف مرة بهذه الصلاة</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#143v">-143v</locus>
                           <q>فى فلك الأسماء والصفات وتشرق بهما علي فى بهار الظاعة وليل العادة كلية وجزية هيكلاو قلبا وروحا وسرا وتميط على ظلمات غواش الشرعية حتى تضيئ لي بنورك فى نور قدسك يا الله يا نور يا هادي ويكرر ذالك كثيرا [...] فائدة وقال حكيم من الحكم من عمل سبعة دون سبعة لم ينتفع</q>
                           <note/>
                        </item>
                        <item xml:id="a3">
                           <locus target="#1v">-1v</locus>
                           <desc>Fawā'id / Masā'il</desc>
                           <q>فائدة وقال حكيم من الحكماء من عمل سبعة دون سبعة لم ينتفع بما يعمل او لها ان يعمل بالخوف دون الحذ ريعتى يقول انى اخاف عذاب الله ولا يحذر من الذنوب فلا ينفعه ذلك القول شياء</q>
                           <note/>
                        </item>
                        <item xml:id="a4">
                           <locus target="#2r">-2r</locus>
                           <desc>Fawā'id / Masā'il</desc>
                           <q>فائدة قال صاحب مجمع الاحباب ونقل عن الامام ابى حنيفة رضي الله عنه انه قال رأيت رب العزة فى المنام تسعة وتسعين مرة وقلت فى نفسى ان رايته تمام الماىة لاسلئيه</q>
                           <note/>
                        </item>
                        <item xml:id="a5">
                           <locus target="#141v">-141v</locus>
                           <desc>Adʻiya and doxologies</desc>
                           <q>اللهم انى اسئلك بذلك العلية وبصفاتك السنية ان تصلي وتسلم على سيدنا محمد وعلى ال سيدنا محمد</q>
                           <note/>
                        </item>
                        <item xml:id="a6">
                           <locus target="#142r">-142r</locus>
                           <q>ابجد هوز حطي كلمن سعفص قرشت ثخذ ضظغ</q>
                           <note>Abǧad</note>
                        </item>
                        <item xml:id="a7">
                           <locus target="#14v">-14v</locus>
                           <desc>Phrases in Amharic and Arabic letters</desc>
                           <q xml:lang="am"/>
                           <note/>
                        </item>
                     </t:list>
                  </additions>

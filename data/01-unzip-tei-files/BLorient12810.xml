                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1v" to="4v"/><locus from="54v" to="56r"/>
                            <title ref="https://betamasaheft.eu/LIT1956Mashaf">Maṣḥafa nuzāze</title> 
                            <incipit xml:lang="gez">በስመ፡ አብ፡ በል፡ መጽሐፈ፡ ኑዛዜ፡ መጽሐፈ፡ ኅድገተ፡ <sic resp="PRS8999Strelcyn">ኃቲአት፡</sic> ወአበሳ፡ ስርዋ፡ 
                                ለጥበብ፡ ፈሪሃ፡ እግዚአብሔር፤ ስርዋ፡ ለኃጢአት፡ አምልኮ፡ ባዕድ፡ ቀቲለ፡ ነፍስ፡ ጸሊአ፡ ቢጽ፡ ቀቲል፡ በልሳን፡ አፍቅሮ፡ ንዋየ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="5r" to="52r"/>
                            <title ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba ṭabibān</title> 
                            <incipit xml:lang="gez">ኦእግዚአብሔር፡ ጠቢበ፡ ጠቢባን፡ ከሃሊ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="52v" to="54r"/>
                            <title ref="https://betamasaheft.eu/LIT6790Salam">Salām-hymn to Kiros</title> 
                            <incipit xml:lang="gez">በእ<corr resp="PRS8999Strelcyn">ን</corr>ቲአከ፡ ተብህለ፡ እመድሉተ፡ ሰማይ፡ ወምድር፡ ይፈደፍድ፡ ጥቀ፡ 
                                ዘእግርከ፡ ጽፍር፡ ኪሮስ፡ ምሉዓ፡ ክብር። ሰላም፡ ለከ፡ ለከናፍርከ፡ ኪሮስ፡ አፈ፡ አምላክ፡ ሰአሞ፡ አንተኑ፡ ዮሐንስ፡ ነቢየ፡ ፍጽም፡ ንጽሕከ፡ ሶበ፡ አደም፡ ሰላም፡ ለከ፡ ወሶበ፡ 
                                ኃዘልከ፡ ኪሮስ። ሥጋ፡ አረጋይ፡ <sic>ጕኁቅ፡</sic> ተወለጠ፡ ብ<pb n="53r"/>ከ፡ አምላክ፡ መብረቅ፡ ክርስቶስ፡ አምላከ፡ ጽድቅ፡ ሰላም፡ ለከ፡ ሞተ፡ 
                                ኃጥአን፡ ጸዋግ፡ ወሞተ፡ ጻድቃን፡ በክብር፡ አዘዘከ፡ ኪሮስ፡ እግዚአብሔር፡ ከመ፡ ትርአይ፡ <sic>ማደረ፡</sic> ክብር፡ ሰላም፡ ለክ። ሰላም፡ ለከ፡ ለሚሳኤል፡ ግፉዕ፡ 
                                መንገለ፡ የማኑ፡ ወጽግሙ፡ </incipit>
                        </msItem>

                           <note>In black ink, carelessly written.</note>
                           <note/>
                        </item>
                        <item xml:id="a7_362">
                           <locus target="#105r">-105r</locus>
                           <q xml:lang="ar">اعوذ بالله من النار ومن شر الكفار ومن غضب الجبار العزة لله ولرسوله وللمؤمنين</q>
                           <desc>Marginalia</desc>
                           <note>Placed at the beginning of sūra 9.</note>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a5_362">
                           <locus target="#38v">-38v</locus>
                           <q xml:lang="ar">كتب بزيادة الالف في الرسم \ فظا عليظ كلاهما بالظاء</q>
                           <desc>Marginalia</desc>
                           <note>Note on spelling</note>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                           </note>
                        </item>
                        <item xml:id="a6_362">
                           <locus target="#80v">-80v</locus>
                           <q xml:lang="ar">الهى من الذى من الذى دعاك قلم تجبه ومن الذي استحان بك [...] بحق القرءان العظيم وبحرمته رسولك الكريم وبحرمة جميع الانبياء والمرسلين واقض حواأجنا سريعا وهذه الحاجة وحوائج المسلمين | اللهم بحق سورة الانعام وبحق اسماء العظام وبعرشك العظيم افعل بنا ما انت اهلم ولا تفعل بنا نحن اهلم انك العلى [...] واهل المغفره برحمتك يا ارحم الراحمين</q>
                           <desc>Marginalia</desc>
                           <note>.</note>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                              <term key="Magic" ana="#Magic"/>
                           </note>
                        </item>
                        <item xml:id="a0_362">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Taǧwīd marks and comments</q>
                           <desc>Marginalia</desc>
                           <note>Recitation marks. Interlinear marks, comments in the margins in red.</note>
                           <note>
                              <term key="Koran" ana="#Koran"/>
                           </note>
                        </item>

                    <msContents>
                      <msItem xml:id="ms_i1">
                        <locus from="1ra" to="77vb"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT2290Sargis">Teaching of Jacob</title>
                         <textLang mainLang="gez"/>
                         <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወል</hi>ድ፡ ወመንፈስ፡ ቅዱ<hi rend="rubric">ስ፡
                           ፩፡ አምላክ፡ ፍቁራንየ፡</hi> ስምዑ፡ ዘ<hi rend="rubric">ኮነ፡ በመዋዕለ፡ ሀ</hi>ርቃል፡ ንጉሠ፡ ሮ<hi rend="rubric">ም፡ በእንተ፡ ብእ</hi>ሲ፡
                           ዘስሙ፡ ሰርጊ<hi rend="rubric">ስ፡ አብርጋዊ፡ ዘእ</hi>ምሥራዊተ፡ ንጉሥ፡ ናሁ፡ ሤሞ፡ መስፍነ፡ ላዕለ፡ ክልኤ፡ አህጉር፡ አፍራጊያ፡
                         </incipit>
                        </msItem>

                         <msItem xml:id="ms_i2">
                           <locus from="78ra" to="113va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2461Testam">Testamentum Domini</title>
                                 <textLang mainLang="gez"/>
                              <incipit xml:lang="gez"><hi rend="rubric">ኪዳን፡ ዘእግዚእነ፡ ወመ</hi>ድኃኒነ፡
                              ኢየሱስ፡ ክርስ<hi rend="rubric">ቶስ፡
                                ወኮነ፡ እንከ፡ እም</hi>ድሕረ፡ ተንሥኣ፡ እግዚ<hi rend="rubric">እነ፡
                                ኢየሱስ፡ ክርስቶስ፡</hi>እምነ፡ ምዉታን፡ አስተር<hi rend="rubric">ኣየነ፡
                                ወተገሰ፡ እምቶማ</hi>ስ፡ ወማቴዎስ፡ ወዮሐን<hi rend="rubric">ስ፡ ወተፈዊሰነ፡
                                ከመ፡ ተ</hi>ንሥኣ፡ ሊቅ፡ ወደቅነ፡
                              </incipit>
                             </msItem>


                             <msItem xml:id="ms_i3">
                               <locus from="113va" to="130va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2462Testam">Testamentum Domini in Galilea</title>
                                <textLang mainLang="gez"/>
                                  <incipit xml:lang="gez"><gap reason="omitted"/>መድኃኒነ፡ ኢየሱስ፡ ክርስቶስ። አንሰ፡ ርኢኩ፡ እምአፍአሃ፡ እስከ፡ ውስጣ፡ ኅብራ፡ ወግብራ፡ ነኪር፡ ወዕፁት፡ ክልኤ፡ ገቦሃ፡ ፍትሑ፡
                                በምግባሮሙ።</incipit>
                                 </msItem>

                                    <msItem xml:id="ms_i4">
                                      <locus from="131ra" to="146vb"/>
                                       <title type="complete" ref="https://betamasaheft.eu/LIT1254Dagemm">Dāgǝm mǝṣʾatu la-Krǝstos wa-tǝnśāʾe mǝwwǝtān</title>
                                         <incipit xml:lang="gez"><hi rend="rubric">ዳግም፡ ምጽአቱ፡ ለክርስቶስ፡</hi>
                                         ወትንሣኤ፡ ምውታን። ዘነገ<hi rend="rubric">ሮ፡ ለጴጥሮስ፡ እለ፡ ይመው</hi>ቱ፡ በእንተ፡ ኃጢአቶሙ፡ እስ<hi rend="rubric">መ፡ ኢዓቀቡ፡
                                         ትእዛዞ፡ ለእግዚ</hi>አብሔር፡ ፈጣሪሆሙ፡ ወዘንተ፡ ሐለየ፡ ከመ<supplied reason="omitted">፡</supplied> ያእምር፡ ምሥጢሮሙ፡ ለወልደ፡ እግዚአብሔር፡
                                       </incipit>
                                       <note>The text contains a part of <ref type="work" corresp="https://betamasaheft.eu/LIT1127Apocal">Apocalypse of Peter</ref>,
                                     see <bibl corresp="http://zotero.org/groups/358366/items/HEKUWHSR"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi2016TowardsPeter"/><title level="a">Towards a Re-edition of the Ethiopic Dossier of the “Apocalypse of Peter”</title><title level="j">Apocrypha</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Alessandro</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bausi</t:surname></author><date>2016</date><biblScope unit="volume">27</biblScope><biblScope unit="page">179-196</biblScope><citedRange unit="page">186</citedRange></bibl>.</note>
                                        </msItem>

                                        <msItem xml:id="ms_i5">
                                          <locus from="146vb" to="157vb"/>
                                           <title type="incomplete" ref="https://betamasaheft.eu/LIT2132OntheJ">Baʾǝnta kʷǝnnane ḫāṭǝʾān</title>
                                             <textLang mainLang="gez"/>
                                           <incipit xml:lang="gez"><hi rend="rubric">ነገረ፡ ምሥጢር፡ ክቡር፡ ወስውር፡ ወተ<gap reason="illegible" unit="chars" quantity="1"/>ሥ<gap reason="illegible" unit="chars" quantity="1"/>ቱ፡
                                             ለዝንቱ፡ ነገር፡ በእንተ፡ ኵነኔ፡ ኃጥኣን፡ ወሐተቶ፡ ጴጥሮስ፡ ለእግዚአብሔር፡ በእንተ፡ ምሕረተ፡ አዳም።</hi> ወሐልይዎ፡ ኦአኃውየ፡ ወኢያእብድክሙ፡
                                         </incipit>
                                            </msItem>
                    </msContents>


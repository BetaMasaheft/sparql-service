               <t:persName>
                  <t:forename> Christian Friedrich August</t:forename>
                  <t:surname>Dillmann</t:surname> 
               </t:persName>
               
               <t:occupation type="academic">scholar</t:occupation>
               <t:nationality type="Germany"/>
               <t:faith type="Christianity"/>
               <t:birth when="1823"/>
               <t:floruit notBefore="1840" notAfter="1894">He was one of the most prominent Ethiopisants of the 19th century. 
                  He is also referred to as the founder of modern day Ethiopian Studies. Dillmann was a Protestant theologian by training. He received his PhD from
                  <t:placeName ref="https://www.wikidata.org/entity/Q3806">Tübingen</t:placeName> University in <t:date>1846</t:date>. Thereafter, he devoted his life entirely to scholarly work in the field of Ethiopian Studies and Old Testament Studies. 
               </t:floruit>
               <t:death when="1894"/>
            </t:person>
            

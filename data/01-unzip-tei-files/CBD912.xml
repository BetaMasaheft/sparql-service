               <msContents><summary>Gospel of Matthew, ወንጌል፡ ዘማቴዎስ፡, Gospel of Mark, ወንጌል፡ ዘማርቆስ፡</summary></msContents>
               <physDesc>
                  <decoDesc>
                     <decoNote xml:id="d1" type="miniature"><desc>f. I r: Gesù parla al popolo (il discorso della montagna</desc></decoNote>
                     <decoNote xml:id="d2" type="miniature"><desc>f. 2 r: Gesù
                        guarisce il lebbroso</desc></decoNote>
                     <decoNote xml:id="d3" type="miniature"><desc>f. 3 v: Il centurione chiede a Gesù di guarire il suo ragazzo</desc></decoNote>
                     <decoNote xml:id="d4" type="miniature"><desc>f. 4 r: La guarigione del ragazzo</desc></decoNote>
                     <decoNote xml:id="d5" type="miniature"><desc>f. 5 r: Gesù guarisce la suocera di
                        S. Pietro</desc></decoNote>
                     <decoNote xml:id="d6" type="miniature"><desc>f. 6 v: Gesù scaccia i demoni</desc></decoNote>
                     <decoNote xml:id="d7" type="miniature"><desc>f. 7 r: Gesù dice allo Scriba ed al Discepolo</desc></decoNote>
                     <decoNote xml:id="d8" type="miniature"><desc>f. 8 v: Gesù nella barca</desc></decoNote>
                     <decoNote xml:id="d9" type="miniature"><desc>f. 9 v: Gesù guarisce gli ossessi
                        nel paese dei Geraseni;</desc></decoNote>
                     <decoNote xml:id="d10" type="miniature"><desc>f. 10 r: Gesù manda i demoni nei porci</desc></decoNote>
                     <decoNote xml:id="d11" type="miniature"><desc>f. 11 r: Il miracolo
                        del paralitico</desc></decoNote>
                     <decoNote xml:id="d12" type="miniature"><desc>f. I 2 v: la cena in casa di Simeone</desc></decoNote>
                     <decoNote xml:id="d13" type="miniature"><desc>f. 13 r: Gesù è richiesto di visitare la fanciulla morta</desc></decoNote>
                     <decoNote xml:id="d14" type="miniature"><desc>f. 1 3 v: L'emorroissa</desc></decoNote>
                     <decoNote xml:id="d15" type="miniature"><desc>f. 14 v: La resurrezione
                        della fanciulla</desc></decoNote>
                     <decoNote xml:id="d16" type="miniature"><desc>f. 15 v: Gesù guarisce i ciechi</desc></decoNote>
                     <decoNote xml:id="d17" type="miniature"><desc>f. 16 v: Gesù guarisce il muto
                        ossesso</desc></decoNote>
                     <decoNote xml:id="d18" type="miniature"><desc>f. 17 r: Gesù conferisce il potere agli Apostoli</desc></decoNote>
                     <decoNote xml:id="d19" type="miniature"><desc>f. 20 r: I Discepoli
                        raccolgono grano durante il sabbato</desc></decoNote>
                     <decoNote xml:id="d20" type="miniature"><desc>f. 21 v: Il miracolo della mano secca</desc></decoNote>
                     <decoNote xml:id="d21" type="miniature"><desc>f. 22 r: Gesù disputa con i Farisei</desc></decoNote>
                     <decoNote xml:id="d22" type="miniature"><desc>f. 23 r: Gesù innanzi a Caifa</desc></decoNote>
                     <decoNote xml:id="d23" type="miniature"><desc>f. 24 r: Ecce
                        Homo</desc></decoNote>
                     <decoNote xml:id="d24" type="miniature"><desc>f. 25 r: la Flagellazione</desc></decoNote>
                     <decoNote xml:id="d25" type="miniature"><desc>f. 26 r: Gesù prende in spalla la Croce. Pilato
                        si lava le mani</desc></decoNote>
                     <decoNote xml:id="d26" type="miniature"><desc>f. 27 r: il Cireneo aiuta Gesù</desc></decoNote>
                     <decoNote xml:id="d27" type="miniature"><desc>f. 28 r: Longino ferisce il costato
                        del Crocifisso</desc></decoNote>
                     <decoNote xml:id="d28" type="miniature"><desc>f. 28 v: Giuseppe di Arimatea chiede a Pilato il corpo di Gesù</desc></decoNote>
                     <decoNote xml:id="d29" type="miniature"><desc>f. 29 r: la Deposizione ed il Santo Sepolcro</desc></decoNote>
                     <decoNote xml:id="d30" type="miniature"><desc>f. 30 r: la Resurrezione</desc></decoNote>
                     <decoNote xml:id="d31" type="miniature"><desc>f. 31 r: l'Angelo annunzia la Resurrezione alle sante donne. Gesù appare ai Discepoli</desc></decoNote>
                  </decoDesc>

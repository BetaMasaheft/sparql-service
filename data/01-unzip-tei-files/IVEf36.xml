                         </handNote>
                  </handDesc>


                  <additions>
                      <list>
                        <item xml:id="a1">
                           <locus target="#1r"/>
                          <desc type="Unclear"/>
                           <note>A table containing "exclamations" or "chants" (ቃል),
                          numbered, accompanied by the first words of exctracts from the Gospels.</note>
                          </item>

                           <item xml:id="a2">
                            <locus target="#1v"/>
                                <desc type="MagicText"/>
                                <note>Magic prayer against pain in the eyes, written in poor hand.</note>
                                </item>



                            <item xml:id="a3">
                              <locus from="49r"/>
                               <desc type="MagicText"/>
                               <note>Conjuration against the diseases <foreign xml:lang="gez">ሥራይ</foreign>
                                and <foreign xml:lang="gez">ሕንዛዣ</foreign>.</note>
                             </item>

                             <item xml:id="a4">
                               <locus from="56r"/>
                                <desc type="MagicText"/>
                                <note>Magic prayer against pain in the eyes, written in good hand.</note>
                              </item>

                              <item xml:id="a5">
                                <locus from="57v"/>
                                 <desc type="MagicText" xml:lang="am"/>
                                 <note>Conjuration in Amharic.</note>
                               </item>

                               <item xml:id="a6">
                                 <locus from="57v"/>
                                  <desc type="CalendaricNote" xml:lang="am"/>
                                  <note>A folded parchment leaf containing a table with the indications of
                                    the shadow length according to the months, days and hours on the recto-side;
                                    possibly canonical descriptions for priests on the verso-side.</note>
                                </item>
                           </list>


                  </additions>



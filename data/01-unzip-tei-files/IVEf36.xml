               <msContents>
                  <summary/>


                  <msItem xml:id="ms_i1">
                    <locus from="2r" to="55v"/>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1850Malkea">ጉባኤ፡ መልክእ፡</title>
                      <textLang mainLang="gez"/>

                     <msItem xml:id="ms_i1.1">
                        <locus from="26v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">Lǝssāna sabʾ</title>
                        <incipit xml:lang="gez">ናሁ፡ ተማኅፀንኩ፡ በኆኅያተ፡ ስምከ፡</incipit>
                        <incipit xml:lang="en">Behold, I entrast myself to the letters of your names...</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="36v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1356eqaban">ዕቀበኒ፡</title>
                       <incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡ በእንተ፡ ዘኀደርከ፡ በከርሠ፡ ማርያም፡</incipit>
                       <incipit xml:lang="en">O Jesus Christ, protect me for the sake of your dwelling
                       in the womb of Mary...</incipit>
                      </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="46v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3024RepCh304">ተፈሥሒ፡ ኦምልእተ፡ ጸጋ፡</title>
                        <incipit>
                          <lb n="1"/>ተፈሥሒ፡ ኦምልእተ፡ ጸጋ፡ እግዝእትነ፡ ማርያም፡ ንግሥተ፡ ንገሥታት፡
                          <lb n="2"/>ዘጸገይኪ፡ ጽጌ፡ በድንግልና፡ ተፍጻሜተ፡ ኵሉ፡ ሠናያት፨
                      </incipit>
                        </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="50r"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2965RepCh246">መልክአ፡ ገብርኤል፡</title>
                        <note>Incomplete, contains only 26 strophes.</note>
                        <incipit>
                          <lb n="1"/>በሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአዕረፈ፡
                          <lb n="2"/>ከመ፡ እዜኑ፡ ሕዳጠ፡ ወአኮ፡ ትሩፈ፡፨
                      </incipit>
                     </msItem>

                        </msItem>
                     </msContents>


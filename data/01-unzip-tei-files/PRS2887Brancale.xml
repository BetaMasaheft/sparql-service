      <t:body>
         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q3339574">
               <t:persName xml:id="n1" type="main">
                  <t:forename>Nicolò</t:forename>
                  
                  <t:surname>Brancaleone</t:surname> 
               </t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">ማርቆርዮስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Mārqoryos</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">መርቆሬዎስ፡ አፍርንጋዊ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Marqorewos ʾAfrǝngāwi</t:persName>
           
                 
                  
                  
               <t:nationality type="Italy"/>
                  <t:faith type="notSpecified"/>
                  <t:occupation type="literary">painter</t:occupation>
                  
               <t:floruit notBefore="1482" notAfter="1530">He was a Venetian  
                  painter who worked in the court of 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName> 
                  during the 15th  and early 16th century. 
                  He also served as a painter for the ruling elite class which is revealed in several accounts in a manuscript of 
                  <t:ref type="work" corresp="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</t:ref> copied for the 
                  <t:placeName ref="https://betamasaheft.eu/LOC3736Hagara">Hāgara Māryām</t:placeName>. </t:floruit>
                  
                  
               </t:person>
               
         </t:listPerson>
         

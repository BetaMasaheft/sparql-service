                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_1126">
                           <locus target="#8r">-8r</locus>
                           <q xml:lang="ar">صدق الله العظيم \ وبلغ رسوله النبي الكريم \ والحمد لله رب العالمين \ وصلي الله على سيدنا محمد وعلى اله وصحبه \ وسلم تسليما</q>
                           <note>Taṣdīq rubricated, followed by a taṣliya by another hand</note>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#Lower board">-Lower board</locus>
                           <desc>« al-waraqa fī maǧīkum 
Sind b. rayyis (?) šayḫ ‘Umar bi-tārīḫ al-ṯulūṯ iṯnayn min šahr Ramaḍān sana 1076 » 
= mars/avril 1666.</desc>
                           <q/>
                           <note>On a fol. pasted on the board.</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#8r">-8r</locus>
                           <desc>« bi-Harar (?) », further on « al-maqā[la] (?) »</desc>
                           <q/>
                           <note>On a strip of paper used to repair the manuscript.</note>
                        </item>
                     </t:list>

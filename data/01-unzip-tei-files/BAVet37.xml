                  <msItem xml:id="ms_i3">
                     <locus from="80r" to="89v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4299Prayer">Prayer of Our Lady Mary to Jesus Christ at the sepulchre</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ኢየሱስ፡ ክርስቶስ፡ ትፍሥሕት፡ ለኵሉ፡ ዓለም። ኢየሱስ፡ ክርስቶስ፡
                        ያሥተፈሥሕ፡ ኵሎ። ኢየሱስ፡ ክርስቶስ፡ ትፍሥሕት፡ ለኵሉ፨ ኢየሱስ፡ ክርስቶስ፡ አንተ፡ ብርሃን፡ ለዕውራን፨ ኢየሱስ፡ ክርስቶስ፡ አንተ፡ ልብስ፡ ለዕሩቃን፨ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        ወተራከብከ፡ ምስለ፡ ማር<supplied reason="omitted">ያ</supplied>ም፡ እምከ፨ ወይቤላ፡ ኢየሱስ፡ ማርያም፡ እምየ፡ መኑ፡ አምጽአኪ፡ ዝየ፡ በዛቲ፡ ዕለት፨ ወትቤሎ፡ ማርያም፡ እሙ፡
                        ወልድየ፡ ስምከ፡ ወጸሎተ፡ ዚአከ፡ ኀበ፡ አቡከ፡ አብጽሐኒ፡ ዝየ፡ <add place="inline">
                           <supplied reason="omitted">ዮም፡</supplied>
                        </add> በዛቲ፡ ዕለት፨ = ፨ ወይቤላ፡
                        ኢየሱስ፡ ክርስቶስ፡ ንሥኢ፡ ዘንተ፡ ይኩንኪ፡ ዝንቱ፡ ማዕተብ፡ ወዝንቱ፡ ጸሎት፡ ዘአቡየ፡ መሐሪ፡ ወአንበረ፡ ዲበ፡ መን<supplied reason="omitted">በ</supplied>ረ፡ ሰሎሞን፡ ወኢይክል፡
                        ይቅረብ፡ መንፈስ፡ ርኩስ፡ ይፍታሕ፡ ኵሎ፡ ሥራያተ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ዘጸውዓቶ፡ እሙ፡
                        በቅድመ፡ አንቀጸ፡ መቃብር፨ ወትቤ፡ ሀራፑን፨ ሀራፑን፨ እሙ፡ ዘጸውዓቶ፡ በኀበ፡ አንቀጸ፡ መአብር፡ ዳግመ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ኢየሱስ፡ ክርስቶስ፡ ባርክ፡ ላዕሌየ፡ ላዕለ፡ ገብርከ፨ ወባርክ፡ ላዕለ፡ ቤትየ፨ ወባርክ፡ 
                           <sic>ለዕለ፡</sic>
                         ዘእበልዕ፨ ወባርክ፡ ላዕለ፡ ዘእሰቲ፨ ወባርክ፡ ላዕለ፡ ትርኣስየ፨ ወባርክ፡
                        ላዕለ፡ ትርጋፅየ፨ ወባርክ፡ ላዕለ፡ ኵሉ፡ ዘአኀዝኩ፡ በእዴየ፨ ወይእዜኒ፡ 
                           <sic>ኢንተ፡</sic>
                         ኢየሱስ፡ ክርስቶስ፡ ወአቡከ፡ መሐሪ፡ ወመንፈስ፡ ቅዱስ፡ ማሕየዊ፡
                        
                           <sic>ትኵን፡</sic>
                         ምስሌየ፡ አሜን፨ ወበኵሉ፡ ንብረትየ፡ ወበኵሉ፡ መንገድየ፨ ኀበ፡ አሐውር፡ ወኀበ፡ እወፅእ፡ ወኀበ፡ እገብእ፡ ወኀበ፡ እወፍር፡ ኀበ፡ አአቱ፨ = ፨
                        ኀበ፡ እቀውም፡ ወኀበ፡ እትቀመጥ፡ ወትምሐረኒ፡ ወትሣሀለኒ፡ ወትስረይ፡ ሊተ፡ ኵሎ፡ ኃጢአትየ፡ በዳግም፡ 
                           <sic>ምጽአትከ፨</sic>
                         ኢዮ፨ ኢዮ፨ ኢዮ፨ ዳኬ፨ ዳኬ፨
                        ዳኬ፨ ለዓለመ፡ ዓለም፡ አሜን፨ ፨
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="89v" to="95v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3138Negeranni">Nǝgǝranni sǝmaka</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ ዘተስእለቶ፡ ማርያም፡ ለእግዚእነ፡ ወትቤሎ፡ ንግረኒ፡
                        ስመከ፡ ወይቤላ፡ እፎ፡ እነግረኪ፡ ስምየ፡ ዘዕፁብ፡ ወግሩም፡ ሰምዮቱ፡ ለስምየ፨ ወትቤሎ፡ ንግረኒ፡ ስመከ፨ ወይቤላ፡ እመ፡ መጽኡ፡ 
                           <sic>መለእክት፡</sic>
                         ኀቤየ፡
                        እነግረኪ፡ ስምየ፨ ወትቤሎ፡ ንግረኒ፡ ስምከ፨ ወይቤላ፡ እመ፡ መጽኡ፡ ሊቃነ፡ መላእክት፡ ኀቤየ፡ እነግረኪ፡ ስምየ፨ ወትቤሎ፡ ንግረኒ፡ ስመከ፨ ወይቤላ፡ እመ፡ ነገርኩኪ፡ በሀገር፡ ይነድድ፡ እሳት፡ በምድር፨
                        ወትቤሎ፡ ንግረኒ፡ ስመከ፨ ወይቤላ፡ እመ፡ ነገርኩኪ፡ በዳግም፡ ይጠፍኡ፡ እንስሳ፡ ገዳም፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ወበዘፈጠረ፡ ኵሎ፡ በአማኑኤል፡ ስመከ፡ ተማኅፀንኩ፡ አነ፡ ገብርከ፡ <subst>
                           <del rend="erasure">ገብረ፡ ክርስቶስ፡</del>
                           <add place="overstrike">አቤል፡</add>
                        </subst>
                        ነፍስየ፡ ወሥጋየ፡ 
                           <sic>አማኀፅን።</sic>
                         ወውሉድየ፨ ወንዋይየ፡ ወጥሪትየ፨ ዘቤት፡ ወዘገዳም፨ ዘርሑቅ፡ ወዘቅሩብ፡ በእደ፡ እግዚአብሔር፡ የማናይ፨ በዘአቀማ፡
                        ወአኀዛ፡ ለዓለም፨ በዘአነሞ፡ ለሰማይ፡ በአጽባዕቱ፨ በተባዕታይ፡ ማይ፨ እንዘ፡ ሥፍሑ፡ አብ፡ ወፋእሙኒ፡ ወልድ፡ ወመንፈስ፡ ቅዱስ፡ መስቄሁ፡ 
                           <sic>ወፍጸሜሁ፨ = ፨</sic>
                        
                        በዝንቱ፡ አስማተ፡ 
                           <sic>ሥለስ፡</sic>
                         ተማኅፀንኩ፡ አነ፡ ገብርከ፨ አ<del rend="erasure">ቤል፡</del> ለዓለመ፡ ዓለም፡ አሜን፨ አሜን፨ ወአሜን፨
                        ለይኩን፡ ለይኩን። ለይኩን፨
                     </explicit>
                     <note>The name of <persName role="owner" ref="https://betamasaheft.eu/PRS11355Abel">ʾAbel</persName>, a later owner of the book, is written over another erased name,
                        <persName role="owner" ref="https://betamasaheft.eu/PRS11354GabraK">Gabra Krǝstos</persName>.</note>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="96r" to="123v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4298Taamho">Taʾammǝḫotā la-Māryām</title>
                    <msItem xml:id="ms_i5.1">
                       <locus from="96r" to="99r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT4298Taamho#HeavenlySpirits">Taʾammǝḫotā la-Māryām, No item: chapter: HeavenlySpirits</title>
                       <incipit xml:lang="gez">
                          በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ንቀድም፡ በረድኤተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ንጽሐፍ፡
                          
                              <sic>ተአምኆታ፡</sic>
                            ለማርያም፡ ድንግል፡ ንጽሕት፡ ዘከመ፡ አምኅዋ፡ በውስተ፡ 
                              <sic>ሰብዕ፡</sic>
                            ሰማይ፡ እንተ፡ ስማ፡ ሴሌ፨
                          በውስተ፡ 
                              <sic>መከን፡</sic>
                            እንተ፡ ስማ፡ በጌዮን፨ ወይነብሩ፡ ህየ፡ ሐራ፡ ሰማይ፨ ወየዐቅብ፡ አናቅጺሃ፡ ወአዕማዲሃ፡ ወኀዋኅዊሃ፡ ፊልጶስ፡ ሐዋርያ፨ ወአምኅዋ፡
                          ከመዝ፡ እንዘ፡ ይብልዋ፨ አማኅናኪ፡ ድንግል፡ ንዌድ<add place="inline">
                              <supplied reason="omitted">ሰኪ፡ ድ</supplied>
                           </add>ንግል፡ ወንብለኪ፡ ሰላም፡ ለኪ፡
                          ድንግል፡ ማርያም፡ ማኅቶተ፡ ኵሉ፡ ዓለም፨ ሰላም፡ ድንግል፡ ወላዲተ፡ ፍሕም፨ ሰላም፡ ለኪ፡ ድንግል፡ ብርሃን፡ ዘኢይጸልም፨
                       </incipit>
                       <explicit xml:lang="gez">
                          ሰላም፡ ለኪ፡ ድንግል፡ ሰረገላተ፡ ምእናም፨ ሰላም፡ ለኪ፡ ድንግል፡ ወለተ፡ ኢያቄም፨ ወሊተኒ፡ ለገብርኪ፡ ረስይኒ፡ እኩን፡ ድርገተ፡ ምስሌሆሙ፡ እስከ፡ ለዓለመ፡ ዓለም፡ ወአድኅንኒ፡ እመስገርቱ፡
                          
                              <sic>ለሰይጠን፨</sic>
                            አሜን፨ አሜን፡ ወአሜን፨
                       </explicit>
                    </msItem>
                     <msItem xml:id="ms_i5.2">
                        <locus from="99v" to="101v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4298Taamho#Priests">Taʾammǝḫotā la-Māryām, Salutation from the priests</title>
                        <incipit xml:lang="gez">
                           
                              <sic>ወከዕበ፡</sic>
                            ወደስዋ፡ ወአምኅዋ፡ 
                              <sic>ከህናት፡</sic>

               <msContents>
                  <summary>Psalter, ዳዊት፡; Image of David, Mälk‘a Dawit, መልክአ፡ ዳዊት፡; Excerpt of Horologium for the Night Hours of Abba Giyorgis, ሰዓታት፡ ዘአባ፡ ጊዮርጊስ፡; Image of the Praises of Mary, መልክአ፡ ውዳሴ፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="148r" facs="003"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>

                    <msItem xml:id="ms_i1.1"><locus from="1r" to="94v" facs="003"/><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="94v" to="104r" facs="097"/><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title></msItem>
                    <msItem xml:id="ms_i1.3"><locus from="105r" to="111v" facs="107"/><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title><note>The variant form known as ǝbǝrayǝsṭ, or Hebraic version</note></msItem>
                    <msItem xml:id="ms_i1.4"><locus from="112ra" to="123ra" facs="107"/><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title><note>arranged for the days of the week</note></msItem>
                    <msItem xml:id="ms_i1.5"><locus from="123ra" to="126vb" facs="125"/><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title></msItem>
                  </msItem>
               <msItem xml:id="ms_i2">
                    <locus from="112r" to="114r" facs="114"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3052RepCh332">Hymn to David</title>
                    <incipit xml:lang="gez">
                      እምሥርወ፡ ዕሴይ፡ እስመ፡ ሠረፅከ፡ እማኅፀና፡ ለሩት። ናስተበፅዓከ፡ ዘለፈ፡ በንባበ፡ ዝንቱ፡ ስብሐት። <lb/>
                      ኦ፡ ብፁዕል ንጉሠ፡ እስራኤል፤ ዳዊት። <lb/>
                      እስመ ተከሥተ፡ ወተረክበ፡፡ባሕርየ፡ ውሣባይ፡ ሕይወ፡ እመዝገበ፡ ክርሣ፡ ለማርያም፡ ዘለከ፡ ወለት፡<gap reason="omitted"/>
                    </incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <locus from="114r" to="114v" facs="116"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa saʿātāt</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                    <locus from="127r" to="132r" facs="129"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1869Malkea">Malkǝʾa wǝddāse Māryām</title>
                    <incipit xml:lang="gez">
                      <note> Incipit for Monday: </note>
                      ፈቀደ፡ እግዚእ፡ ለአዳም፡ ያግዞ፡<lb/>
                      ሥጋኪ፡ ንጹሐ፡ አመ፡ ረሰየ፡ አራዞ፡<lb/>
                      ማርያም፡ ዕፍረት፡ ለምሕረት፡ ወለናዝዞ፡<lb/>
                      ይቅብአኒ፡ ዕፍረተ፡ ጽድቅ፡ ወይምእዘኒ፡ አምዕዞ፡<lb/>
                      የማነ፡ ዕዴኪ፡ እዴየ፡ እኂዞ፡
                      </incipit>
                      <incipit xml:lang="gez">
                      <note> Incipit for Wednesday <locus target="#129" facs="131"> f. 129, col. 2, line 2</locus></note>):
                      ሕዝቅኤል፡ ነቢይ፡ በእንቲአኪ፡ እንዘ፡ ይብል፡ ጸርሐ፡<lb/>
                      ርኢኩ፡ ኆኅተ፡ በምሥራቅ፡ ዘኅቱም፡ መናሥግቲሃ፡<lb/>
                      ማርያም፡ ድንግል፡ ዘትሠረገዊ፡ ንጽሐ፡<lb/>
                      ለዝክረ፡ ስምኪ፡ ይትፌሣ[ሕ] ፡ ፍሥሐ፡<lb/>
                      ከመ፡ ዘረከበ፡ ምህርካ፡ ብዙኃ፡
                    </incipit>
                    </msItem>

                  <title type="complete" ref="https://betamasaheft.eu/LIT2998RepCh278">Hymn to Za-Mikāʾel
                                                  ʾAragāwi</title>
                  <incipit xml:lang="gez">እምድኅረ፡ ብዙኃን ቀደምት፡ እለ፡ ወጠኑ፡</incipit>
                  <textLang mainLang="gez"/>
                </msItem>

                <msItem xml:id="ms_i27">
                  <locus from="114v" to="115v" facs="117">Fols 114v–115v</locus>
                  <title>Hymn to Aragawi, “Rock of the Gospel, planted, and tabernacle of light, bright.”</title>
                  <textLang mainLang="gez"/>
                  <incipit xml:lang="gez">
                    ኰኵሐ፡ ወንጌል፡ ተኩል፨
                    ወደብተራ፡ ብርሃን፡ ጽዱል።
                    አረጋዊ፡ ጴጥሮስ፡ ሰባኬ፡ ወንጌል፨
                    ኃይል፡ መስተጋድል፨
                  </incipit>
                  <explicit xml:lang="gez">
                    ሰላም፡ ለከ፨ ለለ፡ ንብለከ፡ ሰላመ፡ ሰላመ፡ ዳኅና፡ ኀበነ፡ አረጋዊ፡ መምህርነ፨
                    ህየንተ፡ መልአክ፡ ካዕበ፡ ዘየዓቅበነ፨
                    ጸሎትከ፡ ተሀሉ፡ ምስሌነ፨
                  </explicit>
                </msItem>

                <msItem xml:id="ms_i28">
                  <locus from="115v" to="121v" facs="118">Fols 115v–121v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2919RepCh200">Malkǝʾ-hymn to
                                                  ʾabbā Garimā</title>
                  <textLang mainLang="gez"/>
                </msItem>

                <msItem xml:id="ms_i29">
                  <locus from="121v" to="122v" facs="124">Fols 121v–122v</locus>
                  <title>Hymn to Garima, “Blessedness for you, Garima,” <foreign xml:lang="gez">ብፅዓን፡ ለከ፡ ገሪማ፡</foreign></title>
                  <textLang mainLang="gez"/>
                  <incipit xml:lang="gez">

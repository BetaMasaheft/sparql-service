                <msItem xml:id="ms_i25">
                  <locus from="110v" to="111r" facs="113">Fols 110v–111r</locus>
                  <title>Hymn to Anna, Mother of Mary, “Greeting to you, sweet of memory and name,” <foreign xml:lang="gez">ሰላም፡ ለኪ፡ ጥዕም፡ ዝክር፡ ወስም፡</foreign></title>
                  <textLang mainLang="gez"/>
                  <incipit xml:lang="gez">
                    ሰላም፡ ለኪ፡ ጥዕም፡ ዝክር፡ ወስም፨
                    በፄወ፡ መለኮት፡ ቅሱም፨
                    ሐና፡ ብፅዕት፡ እመ፡ ማርያም፡ ዘነገሥኪ፡ በአርያም፡
                  </incipit>
                  <explicit xml:lang="gez">
                    ሰላም፡ ለኪ፨ እመኒ፡ መጽአኒ፡ መልአከ፡ ሞት፡ መሣጢ፨
                    መጽሐፈ፡ ዕዳየ፡ እንዘ፡ ትሰጥጢ፨
                    ወላህየ፡ በሐሤት፡ ወልጢ፨
                    ለገብርኪ፡ አምደ፡ ሚካኤል፡ ለዓለመ፡ ዓለም፡ አሜን፨
                  </explicit>
                </msItem>

                <msItem xml:id="ms_i26">

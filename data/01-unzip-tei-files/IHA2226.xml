               <msContents>
                  <summary>This is a microfilm where are collected various excerpts of manuscripts, some corresponding to materials already present in the collection, and some not. Therefore the numbering of folios will be given according to the frame number of the microfilm.
Frames 1-26 correspond to the same manuscript of DWL00024-3A3.
</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="3r">1v-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4266IHA">دعاء لا اله الا الله احد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم | لا اله الا الله | احدوا لا الله | احدو احدوا الله | احدو احدوا الله | واحد بلا شريك | واحد بلا وزير | واحد بلا شبيه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>نوره كان السمعتين؟ | جدهم صلوا عليه | فاطمي بنت الرسول | وعلي زوج البتول | ذوا الفقار سيف المسلول | صلوات الله عليه | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="3r">3r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4361IHA">نظم الأبجد</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسم الله الرحمن الرحيم لا اله الا الله | بألف ألأوك | وبالبآآآآ بهآؤك | بالتا توبتك | بالثا ثوابك | بالجيم جمالك </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>وباليا يسرك | المنشرح ذكرك | ورفعنا جدك | وتعلى نورك | محمد رسول الله محمد حبيب الله | محمد من عند الله | الله لطيف بالعباد | رب لطيف بالعباد | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="14v" to="16v">14v-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3862IHA">نظم بسم الإله الواحد المعبود</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>بسم الله الرحمن الرحيم | باسم الاله الواحد المعبود والخلق كلهم له عبيد | وانه فرد وتر واحد منزه وعن والد والد؟ | وواحد بالذات والصفات بيده الحياة والممات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>محمد محمد رسول وليس ياتى بعده نزول | ثم صلاة الله داىما تترى؟ على النبي المصطفى خير الورى | اجمع لنا خير الدنيا والاخرا أطفع لنا شر الدنيا والاخرة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="17r" to="19v">17r-19v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4376IHA">Poem in Old Harari (14)</title>
                     <incipit xml:lang="ar">
                        <locus target="#17r">-17r</locus>بسم الله الرحمن الرحيم | الله ملحيوا صديقوا نب ليوي از لبين ملحيوا صديقوا نب ليوي | الله شيلميوا صديقوا نب ليوي نور بن شيلميوا صديقوا نب ليوي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>نب أي مك جارزوا عمر كفتانى مك جارب زناروا عمر سبراني | قرشات صنم زوا عمر سبرانى عمر فر تليوى ايمان ديجوي | [...]  عمر زالله فرتلى ذروا ورداتي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="20r" to="20v">20r-20v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4377IHA">مدح شيخ عمر</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>أعوذ بالله من الشيطان الرجيم بسم الله الرحمن الرحيم الله جباروا زرحمت مختاروا عالم الأسراروا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20v">-20v</locus>حمد وجوبوا الله رحمانوا شكر الكمالوا الله رحيموا وا | اللهم ارحم بال شيخ عمر اللهم انفعنا بركاتهم أمين</explicit>
                     <note>
                        <p>
                           Dedicated to
                        : <persName ref="https://betamasaheft.eu/PRS3119IHA">ʻUmar ʻAlī</persName>
                        </p>
                        <p>
                           Dedicated to
                        : <persName ref="https://betamasaheft.eu/PRS3119IHA">ʻUmar ʻAlī</persName>
                        </p>
                     </note>
                     <note>Possibly dedicated to Sheikh Umar Aliye.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="21r" to="21r">21r-21r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#21r">-21r</locus>بسم الله الرحمن الرحيم اللهم ارحمنا بالقران العظيم وانفعنا بالايات والذكر الحكيم وبارك لنا في السبع المثاني والقران العظيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#21r">-21r</locus>واخر دعواهم ان الحمد لله رب العالمين وصلي الله علي سيدنا محمد واله وصحبه وسلم تسليما امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="21v" to="22r">21v-22r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4379IHA">مناجاة علي ابن ابي طالب</title>
                     <incipit xml:lang="ar">
                        <locus target="#21v">-21v</locus>بسم الله الرحمن الرحيم الهي الهي الهي [...] وسيدي ه اجب دعوتي يا من يجيب ويسمع | لك الحمد يا ذا الجود والمجد والعلي  تباركت تعطي من تشأ وتمتع | الهي وخلاقي وحرزي وموئلي اليك لدي الاعسار واليسرا فزع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>الهي فانشرني علي دين احمد منيئا تقيا قانتا لك خضع | الهي ولا تحرمني الهي وسيسي شفاعتك الكبرى وذاك مشفع | وسل عليذ ما دعاك موحد ونجاك اخيار ببابك ركع</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="23r" to="24r">23r-24r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4380IHA">عذبتني بالمطل منها سعادي</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>عذبتني بالمطل منها سعادى وبراني وهدركني العبادي | وجفاني من بعد ما هجرني طيب عيشي وزاد جفني سهادي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>ارحموا الصب لا يكون مريضا قربكم غير انه لا يراد | لا يجوز؟ البكاء الا عليكم وعلي وصلكم يليق الجهاد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="24v" to="25v">24v-25v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4381IHA">Poem in Old Harari (15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>بسم الله الرحمن الرحيم بسم الله حرمت ذوبى يا الهي ترحم لنا | الرحمن حرمت ذوبى يا الهي ترحم لنا الرحيم حرمت ذوبي يا الهي لنا | محمد حرمت ذوبى يا الهي لنا صديقخ حرمت ذوبى يا الهي لنا ترحم لنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>دينت ذوابي جماس تبريتما دين تمام بان ذينت ذواي جماس منبر س دين اما رايخن | عالم علم ذوب ختفيشا نفسي تحتفى عالم ذلليب بادوا حريادوا ان من بالنا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="26v" to="32r">26v-32r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4382IHA">اسماء الشجر والعروق (١)</title>
                     <incipit xml:lang="ar">
                        <locus target="#26v">-26v</locus>باب أسماء الشجر والعروق الرقارى أي الطفارى اى اندوب؟  العرق الصالح بعتران اى معتران القراسم اى رحن </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>سلم اى واط حبق اى طقش صبر اى عپرت ابنوس اى عبال فاخر اى خدى داروف اى اجي العوسج اى يمابح؟</explicit>
                     <note>Several reproductions of the same two folios, placed at the end of a manuscript.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="32v" to="33r">32v-33r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4384IHA">اسماء الشجر والعروق (٢)</title>
                     <incipit xml:lang="ar">
                        <locus target="#32v">-32v</locus>باب اسما الشجر والعروق | هندب النز؟ الشبت وملوكى قصيط خردل برد فلفل </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33r">-33r</locus>الدلب عقب العلق عيقت الكبر قنع السرنج المقل هو ورق العدس هو النلس اللوبيا هو الدجر؟ </explicit>
                     <note>The same pictures are in ff. 37v-39.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="33v" to="37r">33v-37r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4385IHA">Glossary of names of plants</title>
                     <incipit xml:lang="ar">
                        <locus target="#35v">-35v</locus>بسم الله الرحمن الرحيم | حرف الالف ارب اى طلبح افستين لها رايحة لريحة تشبه الزعتر اسحل اى مدير انجدان وهو الحلتيت ارز أي زحيه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#37r">-37r</locus>حرف اليا يتوع أي انحد أي حلتيت ياسمين اى طبع </explicit>
                     <note>Several reproductions of the same 4 pages (2 folios). The order of pages is not preserved.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3r" to="3v">3r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0938IHA">قصيدة في اسماء الله "ألف: إله واحد منفرد بذاته"</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسم الله الرحمن الرحيم ألف إله واحد منفرد بذاته | باء بديع باعث تفرد في بقائه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>نور نصير ناصر نور السما وارض واو وفي وافى وفى لاوليائه | هأ هو الذى الهدى لمن ارتضى من دينه لا الف لا يخيب من قام الى سؤاله | يآ يعلم ما تكن به الصدور وما وما يخفى | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="3v" to="3v">3v-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4366IHA">نظم صلوات على نببنا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>صلوات على نبينا محمد واله وصحبه صلاتنا | تجرى على ازواجه واغفر لنا ذنعبنا | نور لنا قلوبنا واستر لنا عيوبنا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>بلغ عنا مرادنا | صلاتنا سلامنا | محمد شفعنا | دآئمة طيبة | دوام شمس ربنا | اللهم صل على سيدنا محمد وعلى ال محمد </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="4r" to="5v">4r-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4369IHA">نظم بسم الله نور</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>بسم الله الرحمن الرحيم | بسم الله نورا عالم المستورا باعث المنصورا صلى الله عليه | بسم الله نورا لمن أعطاه حورا هادى المغرورا صلى الله عليه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5v">-5v</locus>واله الاسرار وصحبه الاخيار سادة الابرار صلى الله عليه | تمت المداىحة في النبي المصطفى تمت الذكر المصطفى صلى الله عليه </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="5v" to="9r">5v-9r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4370IHA">مدح النبي وفاطمة بااللغة الهررية</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله الرحمن الرحيم | احت اسيخلقوا نورب زخلقوا محمد ديجلنى | عرشوا اميخلقوا نورب زخلقوا محمد يجلنى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>ست فاطمي ذرسولليى اكبر النساي | ست فاطمي ذرسولليى فضل خش النبوردا | ست فاطمي ذرسوالليى نور معرب ذالي </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="9v" to="10v">9v-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4371IHA">Poem in Old Harari (11)</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>بسم الله الرحمن الرحيم | الله موجود بالكمال قبل الزمان بلا مكان | الله زان النار ما اللها ذان ا يتيحري | الله عزيز نبيز عزيز والله مومن عزيز ني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>حمدحلا لهادى انولنا لماح أي الحمد رلله ربنا داىمة كاملة </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="11r" to="12r">11r-12r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4372IHA">Poem in Old Harari (12)</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>بسم الله الرحمن الرحيم نب رخوا احجيجذوا نب حبيو واحجيجذو | نب حيات احجيجذوا نب قبلة احجيجذوا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12r">-12r</locus>
وداجوا ايوباا نواس نال وداجوا معت رهنوا مس نال | وداجوا تالله مجنبى نسيتنا يالوا بكمال يد يجح حمدا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="12r" to="12v">12r-12v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4373IHA">Poem in Old Harari (13)</title>
                     <incipit xml:lang="ar">
                        <locus target="#12r">-12r</locus>بسم الله الرحمن الرحيم | بسم الله مجن الرحمن الرحيم مجنا | عرش بيم؟ زالبى مجن عرش كرس ب زالبى؟ مجنا | سم زالب مجن سم زال دت زالبى مجنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>حمديني وداج سطنوا اسن فاط قدا | حمدينى المرسنوا اسن فاط قدا ه تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="13r" to="14v">13r-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4375IHA">مدح شيخ ابادر بسم الله الرحمن الرحيم اولا فالحمد لله
                    اخرا</title>
                     <incipit xml:lang="ar">
                        <locus target="#13r">-13r</locus>بسم الله الرحمن الرحيم | أولا فحمد الله اخرا فشكر الله رب يسر مدح الشيخ | المدد يا شيخ ابادر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14v">-14v</locus>للهوى في القلب كي وفوادى بك حي نشر مدحى فيكم طي | المدد يا شيخ ابادر</explicit>
                     <note/>
                     <note/>

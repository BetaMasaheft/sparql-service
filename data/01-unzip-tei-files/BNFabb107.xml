                        <msItem xml:id="ms_i3">
                            <locus from="2va" to="5vb"/>
                            <title ref="https://betamasaheft.eu/LIT5926PsalmBE">Yǝtbārak ʾƎgziʾabǝḥer ʾamlāka ʾƎsrāʾel liqāna malāʾǝkt
          Mikāʾel wa-Gabrǝʾel Surāfel wa-Kirubel...</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">ይትባረክ፡ እግዚአብሔር፡ አምላከ፡ እስራኤ</hi>ል፡ አምላከ፡ ለኵሉ፡ ዘሥጋ፡ ወለኵሉ፡ መንፈስ፡  ሊቃነ፡ መላእክት፡ ሚካኤል፡ ወገብርኤል፡ ሱራፌል፡ ወኪሩቤል፡ </incipit>
                            <explicit xml:lang="gez">አልቦ፡ ዘይትማሰሎ፡ እምቅድመ፡ ህሊናሁ፡ የአምር፡ ኵሉ፡ ዘይቄድስዎ፡ ሥልጣኑ፡ ዘኢየኃልቅ፡ እግዚአ፡ ኵሉ፡ ፍጥረት፡ አሜን።</explicit>
                            <listBibl type="text">
                                <bibl corresp="http://zotero.org/groups/358366/items/6BANA3I5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Aescoly1951Recueil"/><title level="m">Recueil de textes falachas. Introduction. Textes éthiopiens. (édition critique et traduction). Index</title><title level="s">Travaux et mémoires de l’Institut d’ethnologie</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Aaron Zeev</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Aešcoly</t:surname></author><pubPlace>Paris</pubPlace><publisher>Institut d’ethnologie</publisher><date>1951</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Travaux et mémoires de l’Institut d’ethnologie</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">55</t:biblScope></series><biblScope unit="volume">55</biblScope><note type="url">https://gallica.bnf.fr/ark:/12148/bpt6k26168q.image</note><citedRange unit="page">158-169</citedRange></bibl>

                        <msContents>
                            <msItem xml:id="p1_i1">
                                <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1763Legend">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ ዘቅዱስ፡ ሱስንዮስ፡</title>
                                <textLang mainLang="gez"/>
                                <note>The text occupies left column, lines 1-105. Originally the prayer was written for a female owner.</note>
                            </msItem>
                            <msItem xml:id="p1_i2">
                              <title type="complete" ref="https://betamasaheft.eu/LIT5695MagicPrayer">Magic Prayer Against Illnesses and Demons</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">ይሎፍሐም፡ ሎሐም፡ ሎፍሃም፡</incipit>
                              <note>The text occupies right column, lines 1-65.</note>
                            </msItem>
                            <msItem xml:id="p1_i3">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2765RepCh49">Malkǝʾ-hymn (Salām) to Phanuel</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">ሰላም፡ ለከ፡ ሰዳዴ፡ ሰይጣናት፡</incipit>
                              <note>The text occupies right column, lines 66-102.</note>
                            </msItem>
                        </msContents>

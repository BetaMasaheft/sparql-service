                  <decoDesc>

                     <decoNote type="other" xml:id="d2">
                        <p>Readings are indicated by the names of the days of the week and feasts written in red in the main hand, encircled with black frames, in the top margin of the folios.  </p>
                        
                     </decoNote>
                     <decoNote type="mixed" xml:id="d3">
                        <p>Crude polychrome ornamental band (anthropomorphic motif: human face)on fol. <locus target="#3r"/>. </p>
                        
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <p>Fol. <locus target="#3ra"/>: በስመ፡አብ፡ወወልድ፡ወመንፈስ፡ቅዱስ፡፩አምላክ፡ባርከነ፡እግዚኦ፤በበረከተ፡ነቢያት፡ቅዱሳን፡በአቡነ፡አዳም፡በአቤል፡... </p>
                           
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">
                           <p>Ethiopian binding. Two wooden boards.</p>
                           <p>Two pairs of sewing stations.</p>
                           
                        </decoNote>
                     </binding>
                  </bindingDesc>

                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">Second half of the 18th – first half of the 19th-century script;  Mediocre but careful hand. <note>
                           <p>Unknown</p>
                           
                        </note>
                        <note>
                           <p>Omitted letters or words are added interlineally or in the margin, fol. <locus target="#5v"/>
                              <locus from="18ra"/>b, <locus target="#22ba #23rb"/>etc. </p>
                        </note>

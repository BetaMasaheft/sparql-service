                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="1ra" to="101vb">1ra-101vb</locus>, <seg type="script">Hand a:
                           careful, regular, well-trained. </seg>
                        <seg type="ink">Black; red.</seg>
                        <date>First half of the 17th century.</date>
                        <list type="abbreviations">
                           <item>ይ(፡)ካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይ(፡)ዲ፡ for ይበል፡ ዲያቆን፡</item>
                           <item>ይ(፡)ሕ፡ for ይበል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; first words (headings or parts of
                           headings) of constituent texts; directives for the ministers; most of the
                           abbreviations; elements of the punctuation signs and Ethiopic
                           numerals.
 
 The incipit parts of most of the constituent texts
                           are written alternately in red and black lines (s. fols. 75rb, 83vb,
                           90va, etc.).</seg>
                     </handNote>


         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ወጠንኩ፡ እንዘ፡ ኢያስተሐልፍ፡ ዕድሜ፨</l>
                  <l n="2">ሰላመ፡ መልክእከ፡ እንብብ፡ እንተ፡ አልቦቱ፡ ፍጻሜ፨</l>
                  <l n="3">መክበበ፡ ሃይማኖት፡ አንተ፡ ዘዮሐንስ፡ ጽጌ፡ አበሜ፨</l>
                  <l n="4">አለብወኒ፡ መጻሕፍተ፡ ወመሀረኒ፡ ትርጓሜ፨</l>
                  <l n="5">ከመ፡ ለቲቶ፡ መሀረ፡ ጳውሎስ፡ ዘሮሜ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሀሎ፡ ወይሄሉ፨</l>
                  <l n="2">እንዘ፡ ከመ፡ መና፡ ይጥዕም፡ ዘወረደ፡ እምላእሉ፨</l>
                  <l n="3">ዘዮሐንስ፡ ባሕርይ፡ ለዮሴፍ፡ ንዋየ፡ ብዕሉ፨</l>
                  <l n="4">መኑ፡ ከማከ፡ እግዚኦ፡ እምእለ፡ ገዳማተ፡ ዔሉ፨</l>
                  <l n="5">ዘየሐውር፡ ውስተ፡ ኀይል፡ ደቂቅከ፡ ይብሉ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ መካነ፡ ሰላም፡ ወዕርቅ፨</l>
                  <l n="2">እለ፡ በውስቴታ፡ ተረክቡ፡ አምንፈሳውያን፡ ደቂቅ፨</l>
                  <l n="3">ዘዮሐንስ፡ ወልዱ፡ ለተክለ፡ ሃይማኖት፡ ጻድው፨</l>
                  <l n="4">ማእምረ፡ እምአመ፡ ኮንከ፡ በስብከተ፡ ገብርኤል፡ ሊቅ፨</l>
                  <l n="5">ደብረ፡ ሊባኖስ፡ ሐጻኒትከ፡ ትዌድሰከ፡ በጻህቅ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ተዐብዮ፡ ነፍስየ፡ ለእግዚአብሔር፡ እስመ፡ ጸውዐኒ፡ በሥምረቱ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እንግር፡ እስከ፡ ፍጻሜሁ፡ እምጥንቱ፨</l>
                  <l n="3">ዘዮሐንስ፡ ዘንተ፡ ተዘኪረከ፡ ባሕቱ፨</l>
                  <l n="4">ጸውእ፡ ስምከ፡ ለዘበኅሊና፡ እፈቱ፨</l>
                  <l n="5">እምጻማ፡ እዴከ፡ ሀበኒ፡ በከንቱ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ዘዮሐንስ፡ ኖኅ፡ አመ፡ ድምሳሴ፡ ሰብእ፡ በጽሐ፨</l>
                  <l n="2">ለድጽቀ፡ ሃይማኖት፡ ኮንከ፡ ወራሲሃ፨</l>
                  <l n="3">ዘብኵሕ፡ ሕበሪሃ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሶበ፡ ላዕሌየ፡ ተንሥኡ፡ ዕደወ፡ ሙስና፡ ወሀጕል፨</l>
                  <l n="2">አሐዱ፡ ኀይልከ፡ ገብርኤል፨</l>
                  <l n="3">ጸወነ፡ መድኃኒት፡ ይኩነኒ፡ ወምስካየ፡ ሣህል፨</l>
                  <l n="4">ጼና፡ ኵሉ፡ ዘዮሐንስ፡ ኮል፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
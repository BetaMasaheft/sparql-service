                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc type="Asmat">
                    <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> Against illness.
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> Aleph, written by a secondary hand.
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#185v" facs="188">Fol. 185v</locus>
                    Prayers for healing and protection. Written in secondary hands
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <locus target="#186r" facs="188"> f. 186r, left</locus>
                    Calendar of the Shadows of the Months, Ḥäsäbä Säʿatat, <foreign xml:lang="gez">ሐሰበ፡ ሰዓታት፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc type="GuestText">
                    <locus target="#186r" facs="188"> f. 186r, right</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4624Prayer">Ṣalot baʾǝnta ḥǝmāma
                                                  wǝgāt</title>. Concludes with magical characters.
                    Incipit: <foreign xml:lang="gez">ምድምያስ፡ ምድምያስ፡ ምድምያስ፡ የሐቂ፡ የሐቂ፡ ያብ[ራ]ሳቂ፡ አድኅኖ፡ ለወልደ፡ [ብ]ራስቂ፡ አድኅኖ፡ እምሕማመ፡ ውግዓት፡ ለገብርከ፡ ልብነ፡ ድንግል።</foreign>
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                      Text has been added in the margins by an untrained hand throughout the manuscript (e.g., <locus target="#159v #160v" facs="162 163">fols. 159v, 160v</locus>).
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    scrawls
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#52v #53r" facs="055"> f. 52v-53r, bottom</locus>
                    scribal exercise of several lines of <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Chp58">Mazmura Dāwit,
                                                  Chp58</title>
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#71v" facs="074">Fol. 71v</locus>
                    The midpoint of the Psalms is marked with the text <foreign xml:lang="gez">መንፈቀ፡ ዳዊት፡</foreign> ʿhalf of the Psalterʾ
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc type="OwnershipNote">
                    <locus target="#142r" facs="144">Fol. 142r</locus>
                    a prayer for the owner of the manuscript. The name of the owner has been erased
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <desc>
                    <locus target="#186r" facs="188">Fol. 186r</locus>
                    mentions Lǝbnä Dǝngǝl (<foreign xml:lang="gez">ልብነ፡ ድንግል፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#186v" facs="187">Fol. 186v</locus>
                    pen trials of the syllabary (<foreign xml:lang="gez">ፊዳል፡</foreign> ʿfidalʾ)
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                      words of text are written interlinearly (<locus target="#1r #2r #4r #5r #6v" facs="003 004 006 007 009">folss. 1r, 2r, 4r, 5r, 6v, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#19v #28r #34r #90v #101v" facs="022 030 036 093 104">19v, 28r, 34r, 90v, 101v, </locus>, etc.);
                      lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted (<locus target="#15r #41v #101v" facs="017 044 104">15r, 41v, 101v, </locus>);
                      erasure markings are visible (<locus target="#11v #21r #44v #49v #50v" facs="014 023 047 052 053">11v, 21r, 44v, 49v, 50v, </locus>, etc.);
                      text has been removed (<locus target="#5r #6r #7v #12r #14v" facs="007 008 010 014 017">5r, 6r, 7v, 12r, 14v</locus>, etc.)
                    </desc>
                    </item>
                  </list>

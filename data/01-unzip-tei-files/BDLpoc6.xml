                  <msContents>
                     
                     <msItem xml:id="p2_i1">
                        <locus from="1" to="2">Fols 1–2</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2904RepCh185">Malkǝʾ-hymn to Abraham, Isaac and Jacob</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                           <lb/> ሰላም፡ ለዝክረ፡ ስምክሙ፡ ክቡር፡ ወልዑል።
                           <lb/> እምዝክረ፡ አበው፡ ቀደምት፡ ሠናያነ፡ ምግባር፡ ወቃል።
                           <lb/>አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ በጌራተ፡ አሚን፡ ክሉል።
                           <lb/> ከመ፡ እንብብ፡ ስብሐቲክሙ፡ <sic resp="PRS3562Dillmann">በዝሙረ፡</sic> ሐዲሰ፡  ፊደል።
                           <lb/>   አፈ፡ ልቡናየ፡ ይክሥት፡ ጰራቅሊጦስ፡ <sic resp="PRS3562Dillmann">ኃይል።</sic>
                        </incipit>
                     </msItem>
                     
                     
                     
                     <msItem xml:id="p2_i2">
                        <locus target="#1">Fol. 1</locus>
                        <title type="complete">Explanation of Greek words</title>
                        <textLang mainLang="gez" otherLangs="grc"/>
                        <note>Intermixed with the stanzas of <ref target="#p2_i1"/> are explanations of Greek words.</note>
                        <colophon xml:id="coloph1" xml:lang="gez">
                           መልአ፡ መዋዕለ፡ ዓመትየ፡ <date calendar="evangelists">፴ወ፫ በዘመነ፡ ማርቆስ፡ ወንጌላዊ፡</date>
                           እንዘ፡ ሀሎ፡ መጥቅዕ፡ ፲ወ፪ ወአበቅቴሂ፡ ፲ወ፰ በ፰ ዓመተ፡ መንግሥቱ፡ ለንጉሥ፡ <persName ref="https://betamasaheft.eu/PRS9038Susenyos">ሱስንዮስ።</persName>
                        </colophon>
                     </msItem>
                     
                     
                     

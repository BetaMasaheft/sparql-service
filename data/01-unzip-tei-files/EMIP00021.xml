               <msContents>
                  <summary>Praises of Mary, <foreign xml:lang="gez">ውዳሴ፡ ማርያም፡</foreign>, Gate of Light</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="20v" facs="001">Fols 1r–20v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="20v" to="27v" facs="021">Fols 20v–27v, </locus>
                     <locus from="29r" to="29v" facs="029">29r–29v, </locus>
                     <locus from="31r" to="31v" facs="031">31r–31v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  </msItem>

               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">32</measure>
                           <measure unit="quire">3</measure>
                           <dimensions type="outer" unit="mm">
                              <height>140</height>
                              <width>123</width>
                              <depth>42</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Quire descriptions: quires 1–3 balanced, but several loose folios have been sewn to folios. Navigation system: at least one example (f. 19) where red string was sewn into the  corner of a folios to mark content divisions.</note>
                          <note>Analyzed as three quires (but there is much displacement of folios in the current rebinding).</note>
                          <list>
                              <item xml:id="q1" n="1">
                                 <dim unit="leaf">11</dim>
                                 <locus from="1" to="11" facs="001">Fols 1–11</locus>
                                 <note>
                                    <locus target="#11" facs="011">Fol. 11</locus> is sewn onto folio 10.</note>
                              Quire 1:
                              11 added
                            </item>
                              <item xml:id="q2" n="2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="12" to="19" facs="012">Fols 12–19</locus>
                              Quire 2
                            </item>
                              <item xml:id="q3" n="3">
                                 <dim unit="leaf">13</dim>
                                 <locus from="20" to="32" facs="020">Fols 20–32</locus>
                                 <note>
                                    <locus from="28" to="32" facs="028">Fols 28–32</locus> seem to be separate sheets sewn onto quire 3.</note>
                              Quire 3
                              9 added
                              10 added
                              11 added
                              12 added
                              13 added
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top" atLeast="12" atMost="14">12-14</dim>
                              <dim type="bottom" atLeast="33" atMost="35">33-35</dim>
                              <dim type="right" atLeast="15" atMost="17">15-17</dim>
                              <dim type="left">8</dim>
                           </dimensions>
                       </layout>
                       <layout columns="2" writtenLines="14"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                      <locus target="#Inside front cover" facs="001">Fols. Inside,, </locus>
                      <desc>Crude drawing in pencil</desc>
                    </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                      <locus target="#Inside back cover" facs="033">Fols. Inside,, </locus>
                      <desc>Crude drawing of talisman face</desc>
                    </decoNote>
                    <decoNote type="frame" xml:id="d3">
                      <desc>Decorative designs: <locus target="#1r #2v" facs="001 003">fols. 1r, 2v</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red)</desc>
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="e1">
                          <locus target="#3v #4r" facs="004">Fols. 3v, 4r</locus>
                           <desc>Practice on how to write a letter</desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#13v #14r #14v #15r #15v #16r" facs="014 015 016">Fols. 13v, 14r, 14v, 15r, 15v, 16r</locus>
                           <desc type="GuestText">Isolated sentence from <title type="incomplete" ref="https://betamasaheft.eu/LIT2362Songof#Chp1">Song of Songs,
                                                  Chp1</title></desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#32r" facs="032">Fol. 32r</locus>
                           <desc type="GuestText">Words and sentences copied from <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>, in crude hands
                        </desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#10r #16r #23r" facs="010 016 023">Fols. 10r, 16r, 23r</locus>
                           <desc>Overlooked words of text are written interlinearly</desc>
                        </item>
                        <item xml:id="e3">
                        <desc>Rebound in some disorder. The general condition of the vellum is dirty</desc>
                      </item>
                        <item xml:id="e4">
                           <locus target="#32v" facs="033">Fol. 32v</locus>
                              <desc>blank</desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                        <decoNote xml:id="b1">Rebound, attached to rough-hewn boards both of which have been broken about 2–3 cm from the spine and the outer portion of the covers have been replaced with rough-hewn boards but with grain going perpendicular to the grain of the original boards.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

          <msContents>
            <summary>Psalter, ዳዊት፡</summary>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="167v" facs="003">Fols 1r–167v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <msItem xml:id="ms_i1.1">
                <locus from="1r" to="126v" facs="003">Fols 1r–126v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Psalm 151 contains the long version,
                  including the phrase “and he picked up from the brook three stones in the name of
                  the trinity.” </title>
                <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> with the simple
                  modern system</note>
              </msItem>
              <msItem xml:id="ms_i1.2">
                <locus from="127r" to="139r" facs="129">Fols 127r–139r</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                <msItem xml:id="ms_i1.2.1">
                  <locus from="131r" to="132r" facs="133">Fols 131r–132r</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2257salota#Hannah">The Prayer of
                                                  Hannah, mother of Samuel the Prophet,
                                                  Hannah</title>
                  <note>here identified as <q><foreign xml:lang="gez">ጸሎተ፡ ሐና፡ አመ፡ አመ፡ ሰሙኤል፡
                        ነቢይ፡</foreign>, 1Sa 2:1–10</q></note>
                </msItem>
              </msItem>
              <msItem xml:id="ms_i1.3">
                <locus from="139r" to="148r" facs="141">Fols 139r–148r</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                <note>Hebraic Edition</note>
              </msItem>
              <msItem xml:id="ms_i1.4">
                <locus from="143r" to="151v" facs="145">Fols 143r–151v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                <note>introduced by a miracle of Mary in which she teaches Ephrem the Syrian to
                  praise her</note>
                <msItem xml:id="ms_i1.4.1">
                  <locus from="149r" facs="151">Fols 149r and following</locus>
                  <title>Monday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.2">
                  <locus from="150v" facs="153">Fols 150v and following</locus>
                  <title>Tuesday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.3">
                  <locus from="152r" facs="154">Fols 152r and following</locus>
                  <title>Wednesday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.4">
                  <locus from="154v" facs="157">Fols 154v and following</locus>
                  <title>Thursday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.5">
                  <locus from="157r" facs="159">Fols 157r and following</locus>
                  <title>Friday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.6">
                  <locus from="158v" facs="161">Fols 158v and following</locus>
                  <title>Saturday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.7">
                  <locus from="160r" facs="162">Fols 160r and following</locus>
                  <title>Sunday</title>
                </msItem>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="162r" to="167v" facs="164">Fols 162r–167v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
              </msItem>
            </msItem>
          </msContents>
          <physDesc>
            <objectDesc form="Codex">
              <supportDesc>
                <support>
                  <material key="parchment"/>
                </support>
                <extent>
                  <measure unit="leaf">ii + 169</measure>
                  <dimensions type="outer" unit="mm">
                    <height>186</height>
                    <width>127</width>
                    <depth/>
                  </dimensions>
                </extent>
              </supportDesc>
              <layoutDesc>
                <layout columns="1" writtenLines="23">
                  <locus from="1r" to="148r" facs="003">Fols 1r–148r</locus>
                </layout>
                <layout columns="2" writtenLines="23">
                  <locus from="149r" to="167v" facs="151">Fols 149r–167v</locus>
                </layout>
              </layoutDesc>
            </objectDesc>
            <handDesc>
              <handNote xml:id="h1" script="Ethiopic">Ṣaḥafihu
                <seg type="rubrication">
                  <locus target="#ms_i1.1">Fol. ms_i1.1</locus>
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                </seg>
              </handNote>
            </handDesc>
            <decoDesc>
              <decoNote type="miniature" xml:id="d1">
                <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref> (the scene is depicted with
                  David’s body in profile, though his face shows both eyes), before him (right) are
                  three people. One (at the bottom) lies prostrate and holds <term key="shield" ana="#shield"/>
                  and rifle. A second stands before David with a Psalter in hand. Above, a third
                  holds a <term key="sword" ana="#sword"/> over his shoulder. A crude hand has written, <q>“This
                    Psalter belongs to <foreign xml:lang="gez">ቄስ፡ መሬ፡</foreign>.”</q></desc>
              </decoNote>
              <decoNote type="miniature" xml:id="d2"><locus target="#43v" facs="046">Fol. 43v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and
                  the <term key="dragon" ana="#dragon"/> with caption <q><foreign xml:lang="gez">ቅዱስ
                      ጊዮር[ጊ]ስ</foreign></q></desc></decoNote>
              <decoNote type="miniature" xml:id="d3"><locus target="#148v" facs="151">Fol. 148v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> (right) holding hand <term key="cross" ana="#cross"/>, before Saint Ephrem(?) (left) also holding objects in his hands. Above two
                    <term key="angel" ana="#angel"/>s hover over Mary</desc></decoNote>
            </decoDesc>
            <additions>
              <list>
                <item xml:id="e1">
                  <locus target="#66r" facs="068">Fol. 66r</locus>
                  <desc>Psalm 77 does not mark the midpoint</desc>
                </item>
                <item xml:id="e2">
                  <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                  <desc>stamp of the Yale University Library</desc>
                </item>
                <item xml:id="a1">
                  <locus target="#162r" facs="164">Fol. 162r</locus>
                  <desc> mentions the scribe <foreign xml:lang="gez">ጸሐፊሁ፡ ኃይለ፡</foreign> [the
                    second name is erased]</desc>
                </item>
                <item xml:id="e3">
                  <locus target="#Inside back cover" facs="172">Fols. Inside,, </locus>
                  <desc>owner plate of the Yale University Library: Gift of Thomas Ewart
                    Marston</desc>
                </item>
                <item xml:id="e4">
                  <locus target="#ir(ecto) #iv(erso) #168r #168v #169v" facs="001 002 170 171 172">Fols. ir(ecto), iv(erso), 168r, 168v, 169v</locus>
                  <desc>Blank</desc>
                </item>
                <item xml:id="a2">
                  <locus target="#167v" facs="170">Fol. 167v</locus>
                  <desc type="ScribalNoteCompleting"><q>“the end of the Dawit on Tahsas 11 in the
                      peace of God.”</q></desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="partly">
                <decoNote xml:id="b1">Parchment. Wooden boards (the front one is broken and
                  stitched), half bound with leather, with four chain stitches.</decoNote>
                <decoNote xml:id="b2" type="bindingMaterial">
                  <material key="parchment"/>
                  <material key="wood"/>
                  <material key="leather"/>
                </decoNote>
              </binding>
            </bindingDesc>
          </physDesc>

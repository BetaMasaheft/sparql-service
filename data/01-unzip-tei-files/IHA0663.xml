               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="3r">1r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1474IHA">نظم دية من مات بسهم الوداد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>دية من مات بسهم الوداد \ وران لاحبا فى ذلك انوار نعمة الجواد كنز [مكانى؟] \ وذحير الاحباب ايها منصوح \ ذليل عبد كم اليمن بنوح \ لفقد وصلكم قلبه مجروح </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>يا نابيع لانوار يا بدر جليا \ يا عنبر [.؟.] يا مسك زكيا \ عليك الصلاة وخر التحيا \ ولاءال وصحب وكل لاصفيا دوما بلا حد ما طاب لغرم \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3v" to="5r">3v-5r</locus>
                     <title ref="https://betamasaheft.eu/LIT1475IHA">نظم يا بحر الصفاء مصطفى</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>صلى لله عليك يا بحر الصفاء مصطفى يا صاحب [.؟.] \ أيا من احرق لب وفؤادء \ يا غاية المقصود يا عين المرادء \ يا ملجاء بحاني يا مركب ذادء \ ومتى راحتى بلقياكم هادى ايا ماحى كفر وشقاء \ قد هامو وغابو كل لاحباء </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>شمس دار الجلال كعبة لمرسلا \ تاج اول لعزم تابوت برساله بل طاوس كل لاحباء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5v" to="10r">5v-10r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <title ref="https://betamasaheft.eu/LIT1476IHA">نظم صلى الله وسلم على من اسمه محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>صلى لله وسلم على من اسمه محمد تمام حبه غاية المرام \ الحمد لله لغفار \ الضى اعطنا المختار \ محمد سيد لانام \ صلوات لله الديان \ وسلام لله المنان \ عليكم يا بدر تمام </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>الصلاة وكذ السلام \ على من اسمه تمام \ ولاال وصحب الكرام \ يا الله يا مولى العلام \ فرزقنا احسن لختام \ بجاه مصطفى لانام \ تمت</explicit>
                     <note>Every third verse has the rhyme mīm.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="10r" to="11v">10r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1478IHA">نظم هبت الريح</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>صلى الله على مصطفى حبيب الولى عليه السلام \ هبت الريح ياجى عطر تفوح لاهل الغرام \ متى وصالى لذلك الجناب العالى يا خير الانام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>سلام العلام على ذخيرتى للقيام ولأال الأنجم \ سلام رب على لمصطفى العرب وصحب لكرام \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="11v" to="11v">11v-11v</locus>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1479IHA">Poem in ʻaǧamī Oromo (4)</title>
                     <incipit xml:lang="ar">
                        <locus target="#11v">-11v</locus>صلى لله وسلم على مصطفى حبيب لمولى سيد لعلى ولسفلى \ فارو[.؟.] بت ىخلقى \ مدح كيسن غغى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>تاءتن بؤ أكغو \ ناكتا قا يا شمس لعلى </explicit>
                     <note>Vocalized. The text seems to end with a catchword.</note>
                     <note/>
                  </msItem>
               </msContents>

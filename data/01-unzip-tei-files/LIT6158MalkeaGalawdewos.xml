        <body>
            <div type="bibliography">
                
                <listBibl type="editions">
                    
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>
            </div>
            <div type="edition" xml:lang="gez"><note>from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ለአዳም፡ ዘፈጠሮ፨</l>
                        <l n="2">መልክአ፡ ውዳሴከ፡ እጽሕግ፡ እምብዙኅ፡ በአኅፅሮ፨</l>
                        <l n="3">ተራድአኒ፡ እትናገር፡ እንዘ፡ ብየ፡ ኢያእምሮ፨</l>
                        <l n="4">ገላውዴዎስ፡ እምአእምሮከ፡ ምልአኒ፡ አእምሮ፨</l>
                        <l n="5">ከመ፡ እንብብ፡ ለከ፡ በሐዋዝ፡ ዘምሮ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ሥነ፡ ጸውዖቱ፡ ዘአደመ፨</l>
                        <l n="2">እምሥነ፡ ከዋክብት፡ ወወርኅ፡ ዘአሠርገዉ፡ ዓለመ፨</l>
                        <l n="3">ገላውዴዎስ፡ ግበር፡ ትእምርተ፡ ሃይማኖት፡ መድምመ፨</l>
                        <l n="4">አቡከ፡ ሙሴ፡ በዘመነ፡ ፈርዖን፡ ቅድመ፨</l>
                        <l n="5">ማየ፡ በሥልጣኑ፡ ከመ፡ ገብረ፡ ደመ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለሥዕርትከ፡ በማየ፡ ሃይማኖት፡ መንፈስ፡ ቅዱስ፨</l>
                        <l n="2">ዘበቈለ፡ ቦቱ፡ ዲበ፡ ምድር፡ ሥጋከ፡ ርእስ፨</l>
                        <l n="3">ገላውዴዎስ፡ ድንግል፡ እንዘ፡ ሀሎከ፡ በከርሥ፨</l>
                        <l n="4">ቀደስኩከ፡ ይቤ፡ ከመ፡ ኍልቈ፡ ስሙ፡ ኃምስ፨</l>
                        <l n="5">ወልደ፡ ባሕርይሁ፡ ለአብ፡ ኢየሱስ፡ ክርስቶስ፨</l>
                    </lg>
                    <lg type="stanza" n="29">
                        <l n="1">ሰላም፡ ለሰኳንዊከ፡ እምፍኖተ፡ ምግባር፡ ዘኢተአቅጻ፨</l>
                        <l n="2">እምቁመተ፡ ካህድ፡ ይድኀፃ፨</l>
                        <l n="3">ገላውዴዎስ፡ ምላህ፡ እምልብነ፡ ሥርወ፡ ዐመፃ፨</l>
                        <l n="4">ለነፍስነ፡ ወርኅ፡ ከመ፡ ኢብዛኅ፡ ሕፀፃ፨</l>
                        <l n="5">እምነ፡ ምልአታ፡ ዐባይ፡ ወሥሩዕ፡ ተግሣፃ፨</l>
                    </lg>
                    <lg type="stanza" n="37">
                        <l n="1">ሰላም፡ ለመቃብሪከ፡ መቃብረ፡ ጻድቃን፡ ዘተብህለ፨</l>
                        <l n="2">እለ፡ ያማስና፡ ወይነ፡ ዘኢረሰያሁ፡ ምጽላለ፨</l>
                        <l n="3">ገላውዴዎስ፡ ለነ፡ እምኢያብዘኅከ፡ ስኢለ፨</l>
                        <l n="4">ኢትረክብ፡ አባ፡ እምአስዋክ፡ አስካለ፨</l>
                        <l n="5">ወእምነ፡ ዓፅ፡ ዘይት፡ በላዕ፡ እክለ፨</l>
                    </lg>
                </div>
                <div type="textpart" xml:id="tarafa-malke">
                    <lg type="stanza" n="1">
                        <l n="1">በዐይነ፡ ኅሊና፡ ወልብ፡ መንፈስ፡ ቅዱስ፡ ርእዮ፨</l>
                        <l n="2">ሠናያተከ፡ ብዙኀ፡ ወሃይማኖተከ፡ በአሌልዮ፨</l>
                        <l n="3">ገላውዴዎስ፡ ሕቱም፡ በደመ፡ በግዕ፡ ዘቀራንዮ፨</l>
                        <l n="4">አጽንዐከ፡ ወዐቀበከ፡ እምነገረ፡ ኵሉ፡ ጌግዮ፨</l>
                        <l n="5">ከመ፡ በዐለ፡ ቤት፡ ትጉህ፡ የዐቅብ፡ ንዋዮ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለገላውዴዎስ፡ ለኅሊና፡ ልቡ፡ ብእሴ፡ ገነት፨</l>
                        <l n="2">አህጉራተ፡ ዓለም፡ ዘልብ፡ እንዘ፡ ይመርሖ፡ ምሕረት፨</l>
                        <l n="3">ቀተልዎ፡ ግብተ፡ በዘኢይትአመር፡ ሞት፨</l>
                        <l n="4">ሶበ፡ ረከብዎ፡ በውሣጤ፡ ኅቡእ፡ ፍኖት፨</l>
                        <l n="5">ፈያታውያን፡ ዘአምላክ፡ ሀብታት፨</l>
                    </lg>
                </div>
            </div>
            
            
            <div type="edition">
                <note>The following text is taken from <ref type="mss" corresp="https://betamasaheft.eu/EMIP00487">Portland, Ethiopic Manuscript Imaging Project, Kaleab Addis Project 61</ref>.</note>
                  <div type="textpart" subtype="stanza" xml:id="Stanza1" xml:lang="gez" n="1">
                    <label>Stanza 1</label>
                    <ab>
                      ሰላም፡ ለዝክረ፡ ስምከ፡ ስነ፡ ሰውዖቱ፡ ዘአደመ።
                      እምስነ፡ ከዋክብት፡ ወወርኅ፡ ዘአሠርገዉ፡ ዓለም።
                      ገላውዴዎስ፡ ግበር፡ ትእምርተ፡ ሃይማኖት፡ መድምመ።
                      አቡከ፡ ሙሴ፡ በዘመነ፡ ፈርዖን፡ ቅድመ።
                      ማየ፡፡በሥልጣኑ፡ ከመ፡ ገብረ፡ ደመ።
                    </ab>
                </div>
                </div>
        </body>
    </text></TEI>
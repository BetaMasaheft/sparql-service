               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="14v">1v-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s19IHA">قران, Twelfth ǧuz’ (12/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>وَمَا مِنْ دَابَةٍ فى الأَرْضِ إِلَّا عَلَى اللَهِ رِزْقٌهَا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14v">-14v</locus>وَاِنَّ اللَهَ لَا يَهْدِى الكفرين كَيْدَ الخَإِينِيْنَ</explicit>
                     <note>11:6-12:52.</note>
                     <note/>
                  </msItem>

                        <decoNote xml:id="b1">Parchment, 164 x 128 x 58 mm, four Coptic chain stitches (repaired) attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

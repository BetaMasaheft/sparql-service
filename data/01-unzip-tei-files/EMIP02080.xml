                        </item>
                        <item xml:id="e2">
                           <desc>Identified in the insurance hand list as Case 67/7</desc>
                        </item>
                        <item xml:id="e3">
                          <locus target="#1 #14 #25 #29 #36 #50" facs="003 016 027 031 038 052">Fols. 1, 14, 25, 29, 36, 50</locus>
                           <desc>purple yarn is sewn into the fore edge as navigation system</desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#9r #12r #12v #14v #22v" facs="011 014 015 017 025">Fols. 9r, 12r, 12v, 14v, 22v</locus>
                           <desc>etc., words of text are written interlinearly</desc>
                          </item>
                          <item xml:id="e5">
                          <locus target="#32r" facs="034"> f. 32r, line 1</locus>
                          <desc>words of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted</desc>
                          </item>
                          <item xml:id="e6">
                          <locus target="#11v #14r #16r #16v #22r" facs="014 016 018 019 024">Fols. 11v, 14r, 16r, 16v, 22r</locus>

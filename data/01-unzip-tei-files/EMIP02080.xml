                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#25v #37v #48v #50r #57r" facs="028 040 051 052 059">fols. 25v, 37v, 48v, 50r, 57r</locus> (multiple full stops)

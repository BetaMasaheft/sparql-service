                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#iv(erso)" facs="002"> f. iv(erso), upper </locus>
                           <desc type="GuestText">
                              excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2930RepCh211">Malkǝʾa ʾAbuna
                                                  Takla Hāymānot</title>, for protection against wild animals
                            </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#iv(erso)" facs="002"> f. iv(erso), lower</locus>
                          <desc>Medicinal instruction‎</desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#iir(ecto)" facs="003">Fol. iir(ecto)</locus>
                          <desc>Curse on selling or losing the manuscript‎</desc>
                        </item>
                        <item xml:id="a4">
                            <locus target="#29v #31r #31v" facs="032 033 034">Fols. 29v, 31r, 31v</locus>
                           <desc>mention <persName ref="https://betamasaheft.eu/PRS8033Qerellos">Qerǝllos</persName> and <persName ref="https://betamasaheft.eu/PRS7830Petros">Ṗeṭros IV</persName></desc>
                        </item>
                        <item xml:id="a5">
                            <locus target="#33r" facs="035">Fol. 33r</locus>
                          <desc>mentions <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName></desc>
                        </item>
                        <item xml:id="a6">
                          <locus target="#57r" facs="059">Fol. 57r</locus>
                           <desc type="OwnershipNote">note of ownership for <foreign xml:lang="gez">ገብረ፡ ሕይወት፡</foreign>. The name of the scribe is <foreign xml:lang="gez">ተክለ፡ ሥለሴ፡</foreign>, and gives the date of 1925 E.C.</desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#ir(ecto) #iiv(erso) #57v #58r #58v #59r #59v #60r #60v" facs="001 003 060 061 062 063">Fols. ir(ecto), iiv(erso), 57v, 58r, 58v, 59r, 59v, 60r, 60v</locus>

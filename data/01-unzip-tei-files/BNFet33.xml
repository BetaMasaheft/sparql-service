                                <item xml:id="a1">
                                    <locus target="#17v"/>
                                    <desc type="DonationNote">The donation note states that <persName ref="https://betamasaheft.eu/PRS10947LebsaKr">Lǝbsä Krǝstos</persName>, 
                                        to whom the manuscript belonged, donated it to <placeName ref="https://betamasaheft.eu/INS0309KM">Kidāna Mǝḥrat</placeName>.</desc>
                                    <q xml:lang="gez">ዝንቱ፡ ወንግል፡
                                        ዘ<placeName ref="https://betamasaheft.eu/INS0309KM">ታቦተ፡ ኪዳነ፡ ምሕረት</placeName>፡ ዘሀለወት፡
                                        በ<placeName ref="https://betamasaheft.eu/LOC2325DabraM">
                                 <certainty locus="value" match="../@ref" cert="low"/>ደብረ፡ ምስጢር</placeName>።
                  ዘወሀባ፡ <persName ref="https://betamasaheft.eu/PRS10947LebsaKr">ልብሰ፡ ክርስቶስ</persName>፡ ላእከ፡ አሐቲ፡
                                        ሃይመኖት። ዘሰረቃ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                                    </q>
                                </item>
                                

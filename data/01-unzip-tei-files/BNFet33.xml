    </teiHeader><t:text xmlns:t="http://www.tei-c.org/ns/1.0" xml:base="https://betamasaheft.eu/">
        <t:body>
         <t:ab/>
            <t:div type="edition">
                <t:div type="textpart" subtype="book" xml:id="Mt" corresp="https://betamasaheft.eu/BNFet33#ms_i6.1.3">
                    <t:div type="textpart" subtype="chapter" n="1" xml:id="Mt1" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet33#ms_i6.1.3"/>
                    <t:div type="textpart" subtype="chapter" n="2" xml:id="Mt2" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet33#ms_i6.1.3"/>
                    <t:div type="textpart" subtype="chapter" n="19" xml:id="Mt19" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet33#ms_i6.1.3">
                  <t:ab>

                      <t:pb n="42"/>
                    <t:l n="13">ወአምጽኡ፡ ሎቱ፡ ደቀ፡ ከመ፡ ያንብር፡ እዴሁ፡ ላዕሌሆሙ፡ ወይጸሊ፡ ወአርዳእ፡ ይከልእዎሙ፡</t:l>
                    <t:l n="14">ወእግዚእ፡ ኢየሱስ፡ ይቤሎሙ፡ ሕድጉ፡ ደቂቀ፡ ወኢትክልእዎሙ፡ መጺአ፡ ኀቤየ፡ እስመ፡
          ለእለ፡ ከመዝ፡ ይእቲ፡ መንግሥተ፡ ሰማያት።</t:l>
                    <t:l n="15">ወአንበረ፡ እዴሁ፡ ላዕሌሆሙ፡ ወኀለፉ፡ እምህየ።</t:l>
                    ምዕራፍ፡ ፵፫፡
                    <t:l n="16">ወናሁ፡ አሐዱ፡ መጽአ፡ ወይቤሎ፡ ኦሊቅ፡ ምንተኑ፡ ሠናየ፡ እምገበርኩ፡ ሕይወተ፡ ዘለዓለም፡ በዘእወርስ፤</t:l>
                    <t:l n="17">ወይቤሎ፡ ምንተ፡ ትሴአለኒ፡ በእንተ፡ ኄር፡ አልቦ፡ ኄር፡ ዘእንበለ፡ አሐዱ፡ እግዚአብሔር፡ ወእመሰ፡ ትፈቅድ፡
                        ትባእ፡ ውስተ፡ ሕይወት፡ ዕቀብ፡ ትእዛዛተ፡</t:l>
                    <t:l n="18">ወይቤ፡ አያተ። ወይቤ፡ እግዚእ፡ ኢየሱስ፡ ኢትቅትል፤ ኢትትመኀዝ፤ ኢትስርቅ፤ ኢትኩን፡ ስምዓ፡ 
                        በሐሰት።</t:l>
                    <t:l n="19">አክብር፡ አባከ፡ ወእመከ፤ አፍቅር፡ ቢጸከ፡ ከመ፡ ርእስከ።</t:l>
                    <t:l n="20">ወይቤሎ፡ ውእቱ፡ ወሬዛ፡ ዘንተ፡ ኵሎ፡ ዐቀብኩ፡ እምንእስየ፡ ምንተ፡ እንከ፡ ዘተረፈኒ።</t:l>
                    <t:l n="21">ወይቤሎ፡ እግዚእ፡ ኢየሱስ፡ እመ፡ ትፈቅድ፡ ፍጹመ፡ ትኩን፡ ሖር፡ ሢጥ፡ ጥሪተከ፡ ወሀብ፡ ለምስኪን፡
            ወታጠሪ፡ መዝገበ፡ በሰማያት፡ ወነዓ፡ ትልወኒ።</t:l>
                    <t:l n="22">ወሰሚዖ፡ ዘንተ፡ ወሬዛ፡ ኀለፈ፡ ትኩዙ፡ እስመቦ፡ ብዙኀ፡ ጥሬተ።</t:l>
                    <t:l n="23">ወይቤ፡ እግዚእ፡ ኢየሱስ፡ ለአርዳኢሁ፡ አሜን፡ እብለክሙ፡ እምዕፁብ፡ ይበውእ፡ ባዕል፡ መንግሥተ፡
                        ሰማያት።</t:l>
                  </t:ab>
               </t:div>
            </t:div>
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Lu1" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet33#ms_i6.3.3">
                <t:ab>
                    <t:pb n="91"/>
                    <t:l n="1">እስመ፡ ብዙኃን፡ እለ፡ ወጠኑ፡ ይንግሩ፡ ወይምሀሩ፡ በእንተ፡ ግብር፡ ዘአምኑ፡ በላዕሌነ፡</t:l>
                    <t:l n="2">በከመ፡ መሀሩነ፡ እለ፡ ቀደሙነ፡ ርእዮቶ፡ ወተልእክዎ፡ በቃሉ፡</t:l>
                    <t:l n="3">ረትዓኒ፡ ሊተኒ፡ እትልዎ፡ እምጥንቱ፡ ጥዩቀ፡ ኵሎ፡ በበመትልው፡ እጽሕፍ፡ ለከ፡ ዐዚዝ፡ ቴዮፍሊ።  </t:l>
                    <t:l n="4">ከመ፡ ታእምር፡ ጥዩቀ፡ በእንተ፡ ኀይለ፡ ነገር፡ ትምህርት፡ ዘተመሀርከ።</t:l>
                </t:ab>
            </t:div>
            <t:div type="textpart" subtype="chapter" n="8" xml:id="Jo8" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet33#ms_i6.4.3">
                <t:ab>
                    <t:pb n="105"/>
                    <t:l n="3">ወአምጽኡ፡ ጸሐፍት፡ ወፈረሳውያን፡ ብእሲተ፡ እስርተ፡ እንተ፡ ተረክበት፡ በዝሙት። 
          ወአቀምዋ፡  ውሥጠ።</t:l>
                    <t:l n="4"> ወይቤልዎ፡ ኦመምህር፡ ረከብናሃ፡ ለዛቲ፡ ብእሲት፡ በዝሙት፡</t:l>
                    <t:l n="5">ወበሕግነ፡ ሠርዐ፡ ሙሴ፡ ከመ፡ ትትወገር። ወአንተ፡ ምንተ፡ ትብል፡ በእንቲአሃ፡</t:l>
                    <t:l n="6"> ወዘንተ፡ ነገር፡ ዘይቤልዎ፡ እንዘ፡ ያሜክርዎ፡ ከመ፡ ይርከቡ፡ ምክ<t:supplied reason="undefined" resp="PRS10747Zotenbe">ን</t:supplied>ያተ፡ ላዕሌሁ።
           ወእግዚእ፡ ኢየሱስ፡ አትሐተ፡ አዕይንቲሁ፡ ውስተ፡ ምድር፡ እንዘ፡ ይጽሕፍ፡ በአፃብዒሁ፤</t:l>
                    <t:l n="7">ወሶበ፡ ቆሙ፡ ብዙኀ፡ ተስእልዎ፡
            ካዕበ፡ ወነጸረ፡ ኀቤሆሙ።
            ወይቤሎሙ፡ ዘአልቦ፡ ኀጢአተ፡ እምኔክሙ፡ ቀዲሙ፡ ለይገራ፡ በእብን።</t:l>
                    <t:l n="8"> ወዳግመ፡ ካዕበ፡ ደነነ፡ ኀበ፡ ምድር፡ እንዘ፡ ይጽሕፍ።</t:l>
                </t:ab>
            </t:div>
            </t:div>
            <t:div type="apparatus">
                <t:app type="variants" from="#Mt1" loc="18">
                    <t:lem resp="PRS10747Zotenbe" wit="BNFet33">ፅንስት፡</t:lem>
                    <t:rdg resp="PRS10747Zotenbe" wit="BNFet32">እንዘባ፡ ውስተ፡ ማኅፀና፡</t:rdg>

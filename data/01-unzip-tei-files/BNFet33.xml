                    <t:rdg resp="PRS10747Zotenbe" wit="BNFet32">ወይሰምይዎ፡ ሰሞ፡</t:rdg>
                    <t:rdg resp="PRS10747Zotenbe" xml:lang="grc">καὶ καλέσουσιν τὸ ὄνομα αὐτοῦ</t:rdg>
                    

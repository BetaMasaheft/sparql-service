                    <t:rdg resp="PRS10747Zotenbe" wit="BNFet32">ወነቂሆ፡ ዮሴፍ፡</t:rdg>
                    <t:rdg resp="PRS10747Zotenbe" xml:lang="grc">διεγερθεὶς δὲ Ιωσήφ</t:rdg>
                    

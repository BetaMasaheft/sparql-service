               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="8v">1r-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT3952IHA">Unidentified devotional text</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>رأس مالك وعليك تجارك وبه وصولك الى نعيم الأبد في جواز الله تعلي فكل نفس من أنفاسك جوهر لا قية له</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus>ثم قل أعود بالله من الشيطان الرجيم| ثم أقر الفاتحة بتشديداتها أربع تشديدة وأجتهد في الفرق
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="9r" to="120v">9r-120v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>مريم [...] سورة ثمانون وسعوب ايه
بسم الله الرحمن الرحيم

كهيعص
ذِكْرُ رَحْمَةِ رَبِّكَ عَبْدَهُ زَكَرِيَّا
إِذْ نَادَى رَبَّهُ نِدَاء خَفِيًّا
قَالَ رَبِّ إِنِّي وَهَنَ الْعَظْمُ مِنِّي وَاشْتَعَلَ الرَّأْسُ شَيْبًا وَلَمْ أَكُن بِدُعَائِكَ رَبِّ شَقِيًّا<note>Sūra 19 (Maryam), āya 1</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#120v">-120v</locus>بسم الله الرحمن الرحيم
قُلْ أَعُوذُ بِرَبِّ النَّاسِ
مَلِكِ النَّاسِ
إِلَهِ النَّاسِ
مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ
الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ
مِنَ الْجِنَّةِ وَالنَّاسِ

تمت وبالخبر عمت

صدق الله العلي العظيم وبلغ رسوله النبي الكريم والحمد لله رب العالمين ونحنعلى ذلك ممن الشاهدين<note>114:6</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="121r" to="121r">121r-121r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#121r">-121r</locus>دعا حىم القران العطىم بسم الله الرحمن الرحيم اللهم ارحمنا بالقران العظيم وانفعنا بالايت والذكر الحكيم وبارك لنا فى السبع المثاني والقران العظيم

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#121r">-121r</locus>اللهم اشف مرضانا وعاف مبتلانا وارحم موتانا وتمم نعمتك علينا واجعل اجتماعنا ودعانا وتاميتا بركة لنا في ديننا ودنيانا وشفا لنا من كل دا وسقم وفرج عنا من كل هم وغم برحمتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمي صلى الله على سيدنا محمد واله وأصحابه وسلم تسليما

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="121v" to="121v">121v-121v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0754IHA">مدح النبي راق وقتي في الرتبة العليا</title>
                     <incipit xml:lang="ar">
                        <locus target="#121v">-121v</locus>راق وقتي في الرتبة العليا في الاراضى والجوّ ثم السماء| ودأت لى أملاك في كل قطر أتونى تبركا دعاء
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#121v">-121v</locus>أنا في الححشر شافع لمريدي سائر الأوليا تحت اللواء | أنا سلطانهم وشيخي جدّي أوّل الرسل افصح الفصحاء
||

الله الله الله الله هو الله ألف صلو على النبي والسلام
</explicit>
                     <note/>
                     <note/>
                  </msItem>

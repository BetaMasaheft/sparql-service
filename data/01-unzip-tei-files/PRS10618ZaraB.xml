         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዘርአ፡ ቡሩክ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Zarʾa Buruk</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">ዘርአ፡ ብሩክ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Zarʾabruk</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="baptismal">ጸጋ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Ṣaggā Krǝstos</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  <t:residence/>
                  <t:birth notBefore="1630" notAfter="1640"/>
               <t:floruit>He was a saintly figure from <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>, a contemporary of <t:roleName type="title">ʾaṣe </t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS10375Yohanne">Yoḥannǝs I</t:persName> and  <t:roleName type="title">ʾaṣe</t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</t:persName>. Towards the end of his life, <t:persName ref="https://betamasaheft.eu/PRS10618ZaraB">Zarʾa Buruk</t:persName> appears to have been involved in the 
                  Christological controversies of his time. As a result of his disagreeing with <t:roleName type="title">ʾaṣe </t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</t:persName>,  he was imprisoned for five years. 
                  His centre  of veneration is the church dedicated to him, St Michael at <t:placeName ref="https://betamasaheft.eu/LOC3403Gelgal">Gǝš ʾAbbāy</t:placeName>. 
    </t:floruit>
                  <t:death when="1700"/>
               </t:person>  
               
         </t:listPerson>

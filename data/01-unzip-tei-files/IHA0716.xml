               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1v">1r-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1622IHA">دعاء اللهم صل على سيدنا محمد عبدك ورسولك النبي
                    الامي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>اللهم صل على سيدنا محمد عبدك ورسولك النبي الامي وعلى اله وصحبه وسلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>وفتح قريب وفتحت السماء فكانت ابو ابا اذا  جاء نصر الله والفتح</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="3r">1v-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1623IHA">دعاء اللهم صل على سيدنا محمد بحر انوارك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>اللهم صل على سيدنا محمد بحر انوارك ومعدن اسرارك ولسان حجتك وعروس مملكتك </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>ونعم الوكيل ولا حول ولا قوة إلا بالله العلي العظيم وصلى الله على سيدنا محمد وعلى أله وصحبه وسلم فأ</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#130v">Fol. 130v</locus>
                           <desc type="GuestText">A fragment of <title type="incomplete" ref="https://betamasaheft.eu/LIT1367Exodus">Exodus</title> (20:10-11)</desc>
                        </item>
                        <item xml:id="a2">

                           <locus target="#130r">130r, right column, bottom</locus>
                           <desc type="PurchaseNote">A note added at the end of the text of the Genesis states
                  that it had been bought by
                  <persName ref="https://betamasaheft.eu/PRS10794Marqos">Marqos</persName> from the Jews for 300 silver coins</desc>
                           <q xml:lang="gez">ዝመጽሐፍ፡
                  ዘተስ<supplied reason="undefined" resp="PRS10747Zotenbe">ተ</supplied>ሰየጦ፡
                  እምአይሁድ፡ 
                              <persName ref="https://betamasaheft.eu/PRS10794Marqos">
                                 <roleName type="title">አቡነ፡</roleName> መርቆስ፡</persName> በ፫፻፡ ብሩር፡ ወያአምሩ፡ ኵሎሙ፡
                  ነጋድያነ፡ ኢየሩሳሌም፡ ዝክሩኒ፡ በጸሎትክሙ፡ ኢትርሰኡኒ፡ ወትረ፡ ለእመ፡ ነጸርክሙ፡
                  መ<supplied reason="undefined" resp="PRS10747Zotenbe">ጽሐ</supplied>ፈ፡ ኦሪተ።</q>
                        </item>
                        <item xml:id="a3">
                          <locus target="#22v">22v, upper margin</locus>, <locus target="#90v">90v, upper margin</locus>
                           <desc>Short verses of the Bible in Hebrew written in Ethiopic characters</desc>
                           <note>As noted by Sophia Dege-Müller in her forthcoming article (2020)</note>
                        </item>
                        <item xml:id="e1">
                           <locus target="#3r">Fol. 3r</locus>
                           <desc type="StampExlibris"/>
                           <q xml:lang="la">Ex Bibliotheca MSS. Coisliniana, olim Seguieriana, quam Illust.
                              <persName ref="https://betamasaheft.eu/PRS13038Coislin">Henricus du Cambout, Dux de Coislin</persName>, Par Franciae,
                              Episcopus Metensis, &amp;c. <placeName ref="https://betamasaheft.eu/INS0305SGP">Monasterio S. Germani</placeName> à Pratis legavit. An. <date when="1732">M.DCC.XXXII</date>.</q>
                        </item>
                     </list>
                  </additions>



                  <msItem xml:id="ms_i5">
                     <locus from="1r155" to="1r194"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6910MarkFiveWoman">Miracle of Jesus healing the bleeding woman</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ በእንተ፡ ደም፡ ወንጌል፡
                           ዘማርቆስ፡ ወ</hi>መጽአት፡ አሐቲ፡ ብእሲት፡ እንተ፡ ደም፡ ይውኅዛ፡ እም፲ወ፪ ክረምት፡ ወስዕኑ፡ ፈውሶታ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ወይቤላ፡ ወለትየ፡ ሃይማኖተኪ፡ አሕየወተኪ፡ እትዋ፡ በሰላም፡ ወሕየዊ፡ እምደዌኪ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡
                        ከማሃ፡ አድኀና፡ እምሕማመ፡ ውኅዘተ፡ ደም፡ ዘእንበለ፡ ጊዜሁ፡ ወባሕቱ፡ ይኩን፡ ሕፃነ፡ ውስተ፡ ሰሌዳ፡ ማኅፀና፡
                        ለዓመትከ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14947WalattaM">ወለተ፡ ሚካኤል፡</persName> ወእማ፡ 
                           <persName ref="https://betamasaheft.eu/PRS14948WalattaS">ወለተ፡ ሥላሴ፡</persName> ወብእሲሃ፡ <persName ref="https://betamasaheft.eu/PRS14949WaldaS">ወልደ፡ ጻድቅ፡</persName></hi>
                     </explicit>
                  </msItem> 
                  
                  <msItem xml:id="ms_i6">
                     <locus from="1r194" to="1r216"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5920JohnBeg">Beginning of the Gospel of John</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ በእንተ፡ ማዕሠረ፡</hi>
                        አጋንንት፡ ወንጌል፡ ዘዮሐንስ፡ ቀዳሚሁ፡ ቃል፡ ውእቱ፡ ቃል፡ ወውእቱ፡ ቃል፡ ኀበ፡ እግዚአብሔር፡ ሀለወ፡ ወእግዚአብሔር፡
                        ውእቱ፡ ዝንቱ፡ እምቀዲሙ፡ ኀበ፡ እግዚአብሔር፡ ውእቱ፡ ቃል፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ወብርሃንሰ፡ ዘያበርህ፡ በውስተ፡ ጽልመት፡ ወጽልመትኒ፡ ኢያረከባ፡ ወኢይወርባ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ በዝ፡
                        ቃለ፡ ወንጌል፡ ዕቀባ፡ ወአድኀና፡ እምሕማመ፡ በርያ፡ ወሌጌዎን፡ ወኩና፡ ሕይወተ፡ ሥጋ፡ ወነፍስ፡ ለዓመትከ፡ 
                        <persName ref="https://betamasaheft.eu/PRS14947WalattaM">Walatta Mikāʾel<hi rend="rubric">ወለተ፡ ሚካኤል፡</hi></persName> 
                        ወእማ፡ <persName ref="https://betamasaheft.eu/PRS14948WalattaS">Walatta Sǝllāse<hi rend="rubric">ወለተ፡ ሥላሴ፡</hi></persName> 
                        ወብእሲሃ፡ <persName ref="https://betamasaheft.eu/PRS14949WaldaS">Walda Ṣādǝq<hi rend="rubric">ወልደ፡ ቅድጻ፡</hi></persName>
                     </explicit>
                  </msItem> 
                  
                  <msItem xml:id="ms_i7">
                     <locus from="1r216" to="1r252"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT7291PrBaryaPhanuel">LIT7291PrBaryaPhanuel</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ በእንተ፡ ሕ</hi>ማመ፡
                        ዓይነ፡ ባርያ፡ ወሌጌዎን፡ ሰላም፡ ለከ፡ ሰዳዴ፡ አጋንንት፡ ፋኑኤል፡ ለእግዚእብሔር፡ እምጽርሁ፡</incipit>
                     <explicit xml:lang="gez">
                        ሰላም፡ ለከ፡ አድኀኒ፡ ዘልፈ፡ ወኢትኀድግኒ፡ ዮም፡ ፋኑኤል፡ ትጉህ፡ መልአከ፡ ሰላም፡ እስመ፡ በጸሎት፡ ይድኅን፡ <gap reason="illegible"/> ወበፈውስ፡ ይጥኢ፡ ሕሙም፡ መቅደሰ፡ ኦሪት፡ ዘቦእኪ፡ <hi rend="rubric">ማርያም፡ እምነ፡ ወእሙ፡</hi>
                        ለእግዚእነ፡ ወሐፅነ፡ ሐና፡ እምኪ፡ ተማኅፀነ፡ ፈንዊሁ፡ ለፋኑኤል፡ ይዕቀባ፡ ኪያሃ፡ በረምሃ፡ መስቀሉ፡ ሰይጣን፡
                        ኦአምላከ፡ ፋኑኤል፡ ዕቀባ፡ ለዓመትከ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14947WalattaM">ወለተ፡ ሚካሴል፡</persName> ወእማ፡ 
                           <persName ref="https://betamasaheft.eu/PRS14948WalattaS">ወለተ፡ ሥላሴ፡</persName> <persName ref="https://betamasaheft.eu/PRS14949WaldaS">ወልደ፡ ጻድቅ፡</persName> </hi>
                     </explicit>
                  </msItem> 
               

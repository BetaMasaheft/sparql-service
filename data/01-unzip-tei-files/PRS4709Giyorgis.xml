         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ጊዮርጊስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Giyorgis</persName>
               <persName xml:lang="en" xml:id="n2">Giyorgis of Gāsǝč̣č̣ā</persName>
               <persName xml:lang="en" xml:id="n3" type="main">Giyorgis of Saglā</persName>
               <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾabbā</t:roleName>
               </persName>
              <occupation type="ecclesiastic">writer</occupation>
               <floruit notBefore="1380" notAfter="1425">He was one of the most prolific Ethiopian authors of religious texts in Gǝʿǝz, with liturgical and pastoral works as well as doctrinal tracts. 
                  He wrote his principal work <ref type="work" corresp="https://betamasaheft.eu/LIT1952Mashaf">Maṣḥafa mǝśṭir</ref> in <date>1424</date>. 
                  He was a tutor of emperors’ sons and their companions. He was educated in the monastery of  <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos.</placeName>.
               </floruit>
               <t:death xmlns:t="http://www.tei-c.org/ns/1.0" when="1425"/>
            </person>
               
         </listPerson>
                  

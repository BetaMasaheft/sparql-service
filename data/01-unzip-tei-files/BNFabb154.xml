                    <msContents>
                      <msItem xml:id="ms_i1">
                          <locus from="3r" to="68v">6-137</locus>
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT6920CommentJubileesWasan">Amharic commentary on Jubilees by Wasan of Goǧǧām</title>
                          <textLang mainLang="am" otherLangs="gez"/>
                          <note>According to Antoine d'Abbadie, the commentary was dictated by <persName ref="https://betamasaheft.eu/PRS14332Wasan">Wasan</persName>,
                              and d'Abbadie let it be written down. 
                        </note>
                      </msItem>
                          
                          <msItem xml:id="ms_i2">
                              <locus from="73r" to="101v">146-203</locus>
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT1932Mashaf">Maṣḥafa gǝṣṣāwe</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ <gap reason="ellipsis" resp="DN"/></hi>ጽሐፍነ፡ ግጻዌ፡ ግብጽ፡ ዘበዓ<hi rend="rubric">ላት፡ እምዮሐንስ፡ እስከ፡ ዮሐንስ።
                                  ሠ</hi>ረቀ፡ መስከረም፡ ዮሐንስ፡ መጥምቅ፡ ወበርቶሎሜዎስ፡ ሐዋርያ፡ ወጰንጠሌዎን፡ ሰማዕት፡ ወሜሎስ፡ ጳጳስ፡ ወፊስጦስ። ወዮሴዕ፡ ነቢይ። 
                           </incipit>
                              <note>The lectionary stops at <date ref="ethiocal:Teqemt28">28 Ṭǝqǝmt</date>.</note>
                          </msItem>

                        <msItem xml:id="ms_i1.2.2">
                           <locus from="23rb" to="24vb">23rb-24vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle1">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the divine punishment (birds drinking human beings’ brains)</title>
                           <incipit xml:lang="gez">ተአምሪሆሙ፡ ለሰማዕታተ፡
                              ጰራቅሊጦስ፡ ጸሎቶሙ፡ ወበረከቶሙ፡... ወኮነ፡ በቀዳሚ፡ መዋዕል፡ አመ፡ ተምዕዓ፡ እግዚአብሔር፡ መዓተ፡ ዓቢየ፨ ወፈነወ፡
                              አዕዋፈ፡ ዐበይተ፡ እለ፡ ይሴፅሩ፡ ርእሰ፡ <cb/> ሰብእ፡ በአፉሆሙ፡
                              ወይሰትዩ፡ ናላሁ፨...</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.3">
                              <locus from="24vb" to="25vb">24vb-25vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle2">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the jar with holy water that did not break</title>
                              <incipit xml:lang="gez">፪ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ...
                                <pb/> ወካዕበ፡ ነሥአ፡ ውእቱ፡ ብእሴ፡ እግዚኣብሔር፡ ገብረ፡
                                 ቅዱስ፡ ኵስኵስተ፡ ቤተ፡ መቅደስ፡ ከመ፡ ይቅዳሕ፡ ማየ፡ ጸሎት፨ …</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.4">
                           <locus from="25vb" to="29ra">25vb-29ra</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle3">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the healing of Queen ʾƎgziʾ Kǝbrā</title>
                           <incipit xml:lang="gez">፫ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ... ወካዕበ፡ ስምዑ፡
                              አኃውየ፡ ዘገብሩ፡ ላቲ፡ ቅዱሳን፡ ጻድቃን፡ ውሉደ፡ ብርሃን፡ ለእግዚእ፡ ክብራ፡ በእሲተ፡ ንጉሠ፡ ኢትዮጵያ፡</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.5">
                           <locus from="29ra" to="30ra">29ra-30ra</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle4">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the healing of a blind man</title>
                           <incipit xml:lang="gez">ተአምሪሆሙ፡ ለጻድቃን፡ … ወሖረ፡ አሐዱ፡ ብእሲ፡ ዕዉረ፡ ዓይን፡ እንዘ፡
                              ይመርህዎ፡ እምድረ፡ በለስ፨</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.6">
                           <locus from="30ra" to="30vb">30ra-30vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle5">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the holy water of Ṗarāqliṭos extinguishing fire in the King’s palace at ʾAwāgar</title>
                           <incipit xml:lang="gez">፭ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ... ስምዑ፡ አኀውየ፡ ዘከመ፡ ቦአ፡ እሳተ፡ ሰማይ፡ ወስተ፡ ቤተ፡ ንጉሥ፡
                              ዐቢይ፡ ዘምድረ፡ አወገር።</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.7">
                           <locus from="30vb" to="31va">30vb-31va</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle6">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the holy water of Ṗarāqliṭos saving from the pest</title>
                           <incipit xml:lang="gez">፮ተአምሪሆሙ፡ ለሰማዕታተ፡
                              ጰራቅሊጦስ፡ ... ወመጽአ፡ ፩፡ ብእሲ፡ እምድረ፡ ምምሳሕ፡ እንተ፡ ስማ፡ ይብልዋ፡ ጕንያ፡ ጐዲዮ፡ እምፍርሃተ፡ ብድብድ፡</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.8">
                           <locus from="31va" to="34ra">31va-34ra</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle7">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the church bell stolen from Ṗarāqliṭos and restituted</title>
                           <incipit xml:lang="gez">፯ተአምሪሆሙ፡ ለሰማዕታተ፡
                              ጰራ<cb/>ቅሊጦስ፡ ... ወካዕበ፡ ስምዑ፡ ኦአኃውየ፡ ዘገብረ፡
                              ተአምረ፡ ወመንክረ፡ ጰራቅሊጦስ፡ መንፈሰ፡ ሕይወት፤ ወረድኤቶሙ፡ ለሰማዕታት፡ ኅሩያን፡ ለጻድቃን፡ ወቦአ፡ ፩ብእሲ፡
                              በድፍረት፡ ኀበ፡ ቤተ፡ ክርስቲያን፨ ወነሥአ፡ ለዶለ፡ ሐፂን፡</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.9">
                           <locus from="34rb" to="34vb">34rb-34vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle8">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the healing of a blind woman</title>
                           <incipit xml:lang="gez">፰፡ ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ... ወሀለወት፡ አሐቲ፡
                              ብእሲት፡ ዕውርተ፡ ዕይን፡ እምጕንዱይ፡ መዋዕል፨</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.10">
                           <locus from="34rb" to="36vb">34rb-36vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle9">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Miracle of the holy water of Ṗarāqliṭos saving from the pest and men from Mǝsʿǝmā and Hagarāy</title>
                           <incipit xml:lang="gez">፱፡ ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ... <pb/> ስምዑ፡ ካዕበ፡ ኦ፡ አኃውየ፡ ዘከመ፡ ጐዩ፡ ፪ቱ፡ እደው፡ እምፍርሃተ፡
                              ብድብድ፡ ዘቦአ፡ ውስተ፡ ሀገሮሙ፨ ወመጽኡ፡ ኀበ፡ መቃብሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ቅዱሳን፡ ፩እምድረ፡ ምስዕማ፡
                              ወ፩፡ እምድረ፡ ሀገራይ፨</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.11">
                           <locus from="36vb" to="38vb">36vb-38vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle11">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Praise for the church and the martyrs of Ṗarāqliṭos, and list of the provinces from where the faithful come to Ṗarāqliṭos</title>
                           <incipit xml:lang="gez">፲፩፡ ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ... ስምዑኬ፡ አኃውየ፡
                              ከመ፡ ና<pb/>ብጽሕ፡ ለክሙ፡ በዐቅሙ፡ ኵሎ፡ ዘይገብሩ፡ ላዕሌክሙ፡
                              በታሕተ፡ ሰማይ፨</incipit>
                           </msItem>
                        <msItem xml:id="ms_i1.2.12">
                           <locus from="38vb" to="42vb">38vb-42vb</locus>
                              <title ref="https://betamasaheft.eu/LIT5878MiraclesParaqlitos#Miracle12">Taʾāmmǝra samāʿtāta Ṗarāqliṭos, Extensive praise for the church (ʿĀddaqāḥarsi Ṗarāqliṭos), description of the angels surrounding Ṗarāqliṭos etc.</title>
                           <incipit xml:lang="gez">፲፪፡ ተአምሪሆሙ፡ ለሰማዕታተ፡ ጰራቅሊጦስ፡ ...<pb/> ስምዑኬ፡
                              አኀውየ፡ ከመ፡ እንግርክሙ፡ ዘየዐቢ፡ ወዘይኄይስ፡ እምዘሰማዕክሙ ቀዳሚ፨</incipit>
                           </msItem>
                        <note>Miracles 10 and 11 are wrongly numbered as Miracles 11 and 12; the same
                           is in Ms.<ref type="mss" corresp="https://betamasaheft.eu/ESap046">AP-046</ref>.</note>
                        <note>Miracles 1 and 4 are not numbered.</note>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.3">
                        <locus from="44va" to="47ra"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT5879ImageParaqlitos">Malkǝʾa samāʿtāta Ṗarāqliṭos: 32 strophes
                           </title>
                        
                        <textLang xml:lang="gez"/>
                        <note>Malkǝʾa samāʿtāta Ṗarāqliṭos is incomplete, the same as in
                           Ms. <ref type="mss" corresp="https://betamasaheft.eu/ESap046#p1_i1">AP-046</ref>.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="42vb" to="44rb">42vb-44rb</locus>
                        <title ref="https://betamasaheft.eu/LIT1491Gadlas#embeddedcolophon">Gadla Ṣādǝqān za-Ṗarāqliṭos, No item: colophon: embeddedcolophon</title>
                        <colophon xml:id="coloph1" xml:lang="gez">
                           <note>The embedded colophon (same as in <ref type="mss" corresp="https://betamasaheft.eu/ESap046">AP-046</ref>) states that the work was completed in the month of Śane,
                              <origDate when="1523">year of mercy 175 (= 1523 A.D)</origDate>, in the time of <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">King Lǝbna Dǝngǝl (r. 1508-1540)</persName>, 
                              <persName ref="https://betamasaheft.eu/PRS6774Marqos"> Metropolitan Mārqos (d. 1529-30)</persName>, <persName ref="https://betamasaheft.eu/PRS5708JohnXII">Archbishop John XIII of Alexandria (r. 1483-1524)</persName> 
                              and <persName ref="https://betamasaheft.eu/PRS12942Natan">governor of ʿAgāme (śǝyuma ʿagāme) Nātān</persName>.</note>
                           
                        </colophon>
                     </msItem>
                     <note>- This Ms. may be a copy (codex descriptus) of the 16th-cent. Ms.<ref type="mss" corresp="https://betamasaheft.eu/ESap046">AP-046</ref>.</note>
                     <note>The manuscript is probably continued as <ref type="mss" corresp="https://betamasaheft.eu/ESap049a">AP-049a</ref></note>

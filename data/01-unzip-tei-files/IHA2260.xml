               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="3r">1-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT4506IHA">نظم ما دام النور</title>
                     <incipit xml:lang="ar">
                        <locus target="#1">-1</locus>صلاة الله والسلام على النبي الهاشم | ما دام النور يلمع في جنابه الأكرم | حمدا لرب الرحيم على منه الجسين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسلامه العميم الدا مثل الديم؟ | رب هب لنا مننا بجوار العظيم </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3r" to="5v">3r-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4507IHA">نظم اهل النور والمدد</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>اهل النور والمدد اهل الباء والمرشد مدد | نحمد الرب الصمد على الفضل المجرد مدد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5v">-5v</locus>وصلاتى ابدا للرسول المقتد مدد | وءاله والصحب اصل النور والقرب مدد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="5v" to="12r">5v-12r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4508IHA">نظم يا خاتم الرسل سلام عليكم</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>يا خاتم الرسل سلام عليكم | وصلاة الله عمت روحكم | حبيبي سيد بحر جودكم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>حمد لربنا على توفيقه | بالنبي القريش مسك مختم | وصل ابدا على مرقده | وروحه الكريم فضل ونعيم </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="12r" to="21v">12r-21v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4509IHA">نظم لو نكرر ذكرا عليها</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>لو نكرر؟ ذكرا عليها ولا نحصى بعددها | نعمة التي خص بارينا | كم اكرمنا وكم خصنا لكن لم ؟ نقدر ثناء له | هو ربنا وشاهدنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#21v">-21v</locus>ونشهدك نحن مؤمنون نحن البرئ من المشركين | ثم اعترفنا على ظلمنا | عشق دعك؟ في كل الأحوال ونشز؟ لك ثناء الجمال | حيث رءينا بما صدقنا </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="21v" to="26v">21v-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4510IHA">نظم سبحان الجلال والجمال</title>
                     <incipit xml:lang="ar">
                        <locus target="#21v-22r">-21v-22r</locus>والصلاة على ساداتى | والسلام على عمدتى | والله انتم جنتى | والله انتم جنتى | ساكن روض الطيبة | سبحان الجلال والجمال والصلاة علم الهدى | ساداتى في مدينة | طلع الشمس في الغيب ساكن في طي اللب | لم يزل مثل الجنة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>على من قطب العالمين شراب كل المرسلين | ما جالوا للمودة | يا مولى يا نعم النصير وارزقنا من عين البصير | نسأل حسن المنتهة؟ </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="26v" to="32r">26v-32r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4511IHA">نظم في بابكم قد عكفت</title>
                     <incipit xml:lang="ar">
                        <locus target="#26v-27r">-26v-27r</locus>مولى صل وسلم | على الصادق الأمين | محمد خير الورى | ذي الاخلاق المكمل | في بابكم قد عكفت فى أمور وتحيرت؟ | للجواب إنتظرت فى زمن المتقبل | إن سرى قد كتمت لغيركم ما افشيت؟ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#32r">-32r</locus>يا خالق المكونا والعجاب البدائعات | نسألك عند الأجل بالإيمان المكمل</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="32v" to="35r">32v-35r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4400IHA">نظم الحمد لله الحي القيوم</title>
                     <incipit xml:lang="ar">
                        <locus target="#32v">-32v</locus>صلى الله وسلم على | صل الله على وسلم على | طه صاحب المقام العلا | الحمد لله الحي القيوم لتخصيصنا بزين العالم | تحت بابه سيد الولا | إنى سائل متن ... يا رسول الله أبا بتولا | تا من نوره اعلى وسفلى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35r">-35r</locus>جعلنا غريق قى دين الءسلام في دار السلام ومن تغسن؟ | ومن يموت متهللا</explicit>
                     <note/>
                     <note/>
                  </msItem>

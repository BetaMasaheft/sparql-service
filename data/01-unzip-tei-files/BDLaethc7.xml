               <physDesc>
                  <objectDesc form="Codex"> 
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">158</measure> 
                           <measure unit="folio" type="blank">1</measure>
                           <locus target="#156v">Fol. 156v</locus>
                           <dimensions type="outer" unit="in">
                              <height>13.25</height>
                              <width>11.5</width>
                           </dimensions>
                        </extent>
                        <foliation>The actual foliation runs only to 156, as 32 and 141 were each erroneously 
                        repeated in the numeration.</foliation>
                        <condition key="deficient">The manuscript is incomplete at the beginning and
                           illegible at the end.</condition>
                     </supportDesc>
                     
                     <layoutDesc>
                        <layout columns="2" writtenLines="22"/>
                     </layoutDesc>
                  </objectDesc>
                  
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <date notBefore="1700" notAfter="1750" cert="low"/>
                        <seg type="script">Written in a fine hand, probably early <date>18th century</date>. </seg>
                     </handNote>
                  </handDesc>
                  
                  <decoDesc>
                     
                     <summary>All drawings, with the exception of <ref target="#d6"/>,
                     which is in colour, were no doubt intended to receive colour later on.
                     </summary>
                     
                     <decoNote type="drawing" xml:id="d1">
                        <locus target="#1v">Fol. 1v</locus>
                        <desc>Black and white drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> 
                           <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> with the Child;
                        full page.</desc>
                     </decoNote>
                     
                     <decoNote type="drawing" xml:id="d2">
                        <locus target="#14v">Fol. 14v</locus>
                        <desc>Drawing extending over half-page; black and white; <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName>
                        giving a blessing.</desc>
                     </decoNote>
                     
                     <decoNote type="drawing" xml:id="d3">
                        <locus target="#35v">Fol. 35v</locus>
                        <desc>Half-page drawing; black and white; <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> 
                           <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> with 
                        Child in manger, ox and ass.</desc>
                     </decoNote>
                     
                     <decoNote type="drawing" xml:id="d4">
                        <locus target="#74v">Fol. 74v</locus>
                        <desc>Half-page drawing; black and white;  <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                           <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>
                        weeping, with Child. Two Roman soldiers shown in profile with only one eye visible,
                        which is the Ethiopian way of picturing evil people.</desc>
                     </decoNote>
                     
                     <decoNote type="drawing" xml:id="d5">
                        <locus target="#102v">Fol. 102v</locus>
                        <desc>Full-page drawing; black and white; the <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> Crucifixion.
                        <q xml:lang="gez">ዝንቱ፡ ዘተሰቅለ፡ እግዚእነ፡ ኢየሱስ፡ አምላክ፡ 
                        ወልደ፡ አምላክ፡</q>
                        </desc>
                     </decoNote>
                     
                     <decoNote type="miniature" xml:id="d6">
                        <locus target="#125v">Fol. 125v</locus>
                        <desc>Full-page picture in colours. <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> 
                           <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and Child.</desc>
                     </decoNote>
                  </decoDesc>
                  
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1r">Fol. 1r</locus>
                           <desc type="MagicFormula">List of magic names, omitted by <persName ref="https://betamasaheft.eu/PRS9622Ullendor">Edward Ullendorff</persName> in the catalogue. The text breaks off at the end.</desc> 
                           
                           <q xml:lang="gez">ወበል፡ በትሑት፡ ቃል፡ እሎንተ፡ አስማት፡ 
                              <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/>
                              እሙንቱ፡ አስማት፡ ክቡራት፡ ወልዑላት። ኦአምላክ፡ ሚካኤል፡ ዕቀቦ፡ ወአድኅኖ፡ ለአቡነ፡ <persName ref="https://betamasaheft.eu/PRS11435GabraMaryam">ገብረ፡ ማርያም፡</persName>
                           </q>
                        </item>
                        
                        <item xml:id="a2">
                           <locus target="#155v">Fol. 155v</locus>
                           <desc type="OwnershipNote"/>
                           <q xml:lang="gez">ዝመጽሐፍ፡ ዘአለቃ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS11435GabraMaryam">ገብረ፡ ማርያም፡ ካሳ።</persName>
                           </q>
                        </item>
                        
                        <item xml:id="e1">
                           <desc>Names of owners and scribes are generally erased in this manuscript.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        
                        <item xml:id="e2">
                           <locus target="#15r">The name is mentioned on f. 15r at line 9.</locus>
                           <desc>
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11436Cyriacus">
                                 <certainty locus="value" match="../@role" assertedValue="other" cert="low"/>
                              </persName> given here is probably the name of
                              one of the owners of this manuscript.</desc>
                           <q xml:lang="gez"/>
                        </item>
                     </list>
                  </additions>
                  
                  <bindingDesc>
                     <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Ethiopian binding, wooden boards covered with leather.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                     </binding>
                  </bindingDesc>

                          <msItem xml:id="ms_i2">
                             <locus from="163ra" to="172ra"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT4841Discourse">Discourse of Dionysius on the Martyrdom of Sts Peter and Paul</title>
                             <incipit xml:lang="gez">
                               <hi rend="rubric">በስመ: አብ፡ ወወልድ፡</hi><gap reason="ellipsis" resp="DN"/>
                               <hi rend="rubric">ድርሳን፡ ፍናወ፡ መ</hi>ልእክት፡ ዘቅዱስ፡ ወክቡር፡ <hi rend="rubric">ድዮስያኖስ፡ አርዮስ፡ ፋጎስ፡</hi> ኀበ፡ ቅዱስ፡
                                 ጢሞቴዎስ፡ ፍንወ፡ ረድኡ፡ ለጳውሎስ፡ ሕሩይ፡ በእንተ፡ ፍጻሜ፡ ስምዖሙ፡ ለጴጥሮስ፡ ወጳውሎስ፡ ፍንዋን፡ ላእካን፡ ንጹሐን፡ በሀገረ፡ ሮምያ፡
                                 አመ፡ ለወርኃ፡ <hi rend="rubric">፭</hi>ሐምሌ፡ እግዚእነ፡ አሜን፨፨ ሰላም፡ ለረድእ፡ አምላካዊ፡ ወለእውልድ፡ መንፈሳዊ፨ ወልብ፡ ንቁሕ፡ ቀዋሚ፡ ረዓየ፡
                                 መርዔተ፡ ለአምላኩ፡
                               </incipit>
                               <explicit xml:lang="gez">ተፈጸመ፡ በዝየ፡ ፍናወ፡ መልእክት፡ ድርሳን፡ ዘአባ፡ ድዮናስዮስ፡
                                 ቅዱስ፡ በኑዛዜ፡ ወበላሕ፡ ለአባ፡ ጢሞቴዎስ፡ በረድኤተ፡ ክርስቶስ፡ ኢየሱስ፡ አምላከነ፡ ለዓለመ፡ ዓለም፡ አሜን፨
                                 ዘ<sic resp="DN">አስተትነ፡</sic> በቃለ፡ ዝንቱ፡ መጽሐፍ፡ አብ፡ ክቡር፡ መንፈሳዊ፡ ንጹሕ፡ ወሕሩይ፡ አቡነ፡ ማርቆስ፡ በደብረ፡
                                 <gap reason="lost" unit="chars" quantity="3"/>
                                  ለአኃው፡ ኢትዮጵያውያን፡ መንፈሳዊያን፡ መነኮሳት፡
                                 ወእኁነ፡ ክርስቶስ፡<gap reason="ellipsis" resp="DN"/>
                               </explicit>
                               <note>The explicit mentions
                                 <persName ref="https://betamasaheft.eu/PRS13524Marqos">ʾabuna Mārqos</persName> who is said to have
                               facilitated translation or composition of the work (?) at a place
                               whose name is partly erased (but probably it was <placeName ref="https://betamasaheft.eu/LOC7359DabraSebra">Dabra Sǝbrā</placeName>).
                               </note>

                             <colophon xml:id="coloph1">
                               <locus from="172ra" to="172rb"/>
                               በአኰቴተ፡ አብ፡ ወወልደ፡ ወመንፈስ፡ ቅዱስ፨
                               ተፈጸመ፡ ገድል፡ ወስምዕ፡ ዘ፲ወ፪ሐዋርያት፡
                               ዘጸሐፍከዋ፡ አነ፡ ኃጥዕ፡ ወአባሲ፨ <hi rend="rubric"><persName role="scribe" ref="https://betamasaheft.eu/PRS13889Galawdewos">ገላውዴዎስ፡</persName></hi> ወዘአጽሐፉኒ፡ <gap reason="ellipsis" resp="DN"/>
                               <hi rend="rubric">ማርያም፡</hi> መፍቀርያነ፡ እግዚአብሔር፡ ወፍቁራኒሃ፡ ለቤተ፡ ክርስቲያን፡ ወ<cb n="b"/>መፍቀርያኒሆሙ፡ ለሐዋርያት፨
                                  <gap reason="ellipsis" resp="DN"/>
                                 </colophon>

                                 <colophon xml:id="coloph2">
                                    <locus target="#1v"/>
                                   ተፈጸመ፡ በዝየ፡ ገድል፡  ዘ፲ወ፪ሐዋርያት፡ ወ፸ወ፪አርድእት፡ ጸለዩ፡ ወይቤሉ፡
                                   ንሕነ፡ ጻመውነ፡ ወተቀሰፍነ፡ በእንተ፡ ስምከ፨ ምንተ፡ ዐሰብነ፡ በሰማያት፡
                                   ወይቤሎሙ፡ እግዚእነ፡ በደኃሪት፡ ዕለት፡ ሐልፉ፡ በግህደት፨ ወይቤሉ፡ ዘይተአመን፡ በጸሎት፡ ወይገብር፡ ተዝካረነ፡ ወዘአጽሐፈ፡
                                   መጽሐፈ፡ ገድልነ፡ ምንት፡ ዐሰቡ፡ ተአስዮ፡ እግዚኦ፨<gap reason="ellipsis" resp="DN"/>
                                     </colophon>
                               </msItem>


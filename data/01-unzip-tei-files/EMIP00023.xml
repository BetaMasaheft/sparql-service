               <msContents>
                  <summary>Gospel of John, <foreign xml:lang="gez">ወንጌል፡ ዘዮሐንስ፡</foreign>
                  </summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="96v" facs="001">Fols 1r–96v</locus>
                    <title>Gospel of John, with introduction, conclusion, ar'ǝst, and arranged for the days of the week</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" facs="001">Fols 1r and following</locus>

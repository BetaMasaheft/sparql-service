               <t:placeName xml:id="n1" xml:lang="gez">አገርህሴ፡ አቡነ፡ ማማስ፡</t:placeName>
               <t:placeName corresp="#n1" xml:lang="gez" type="normalized">ʾAgarhǝse ʾAbuna Māmās</t:placeName>
               <t:placeName type="alt" xml:lang="gez" xml:id="n2">ደብረ፡ ቅዱሳን፡ አቡነ፡ ማማስ፡ አገርህሴ፡</t:placeName>
               <t:placeName type="normalized" xml:lang="gez" corresp="#n2">Dabra Qǝddusān ʾAbuna Māmās ʾAgarhǝse</t:placeName>


               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>

               <t:settlement type="warada" when="2011-11-19" ref="https://betamasaheft.eu/LOC3640GuloMa">Gulo Maḵadā</t:settlement>

               <t:settlement when="2011-11-16" type="tabiya" ref="https://betamasaheft.eu/LOC6962Sawit">Šawit Lamlam</t:settlement>

               <t:settlement when="2011-11-16" type="qushat" ref="https://betamasaheft.eu/LOC7158Agarhese">ʾAgarhǝse</t:settlement>


               <t:location>
                  <t:geo>14.44875 39.342167</t:geo>
                  <t:height unit="m">2312.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1300" notAfter="1400">1300-1400</t:date>
                  <t:desc type="foundation">The foundation date mentioned by the local oral tradition is <t:date>1295 year of mercy</t:date>, but it is linked to
                  the time of <t:persName ref="https://betamasaheft.eu/PRS3429DawitII">ʾaṣe Dāwit</t:persName>.
                  According to the same tradition, the
                     founder was ʾabuna <t:persName ref="https://betamasaheft.eu/PRS13452Mamas">Māmās</t:persName> (from the time of King <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName>, r.
                     <t:date>1344-1371</t:date> and his successor <t:persName ref="https://betamasaheft.eu/PRS3429DawitII">Dāwit II</t:persName>).</t:desc>

                  <t:ab type="history">Gatar, formerly gadām. According to the <t:ref type="work" corresp="https://betamasaheft.eu/LIT1428GadlaB">Vita of saint Baṣalota

                     Mikāʾel of Dabra Gol</t:ref> (ʾAmhārā), Baṣalota Mikāʾel was exiled to <t:placeName ref="https://betamasaheft.eu/LOC3640GuloMa">Gulo Makadā</t:placeName> and died at <t:placeName ref="https://betamasaheft.eu/LOC3703Gwegwe">Gʷǝdgʷǝde</t:placeName>,
                     which seems to have been a name of the area around ʾAgarhǝse. Local tradition remembers him and confirms that his
                     burial place is in the vicinity.
                   </t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/AQM.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>
                     25 Mss.; 10 Mss. photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm001">AQM-001</t:ref> "Vita of Mamas"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm002">AQM-002</t:ref> "Vita of Mamas"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm003">AQM-003</t:ref> "Four Gospels"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm004">AQM-004</t:ref> "The Book of the Baptismal Rite"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm005">AQM-005</t:ref> "Miracles of Jesus"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm006">AQM-006</t:ref> "Miracles of Mary"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm007">AQM-007</t:ref> "Miracles of Jesus"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm008">AQM-008</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm009">AQM-009</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESaqm010">AQM-010</t:ref> "The Book of the Funeral Rite"
                   </t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="4"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>,
                     <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS13452Mamas">Māmās</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS8083Raphael">Raphael</t:persName>
                     The main feast is that of <t:persName ref="https://betamasaheft.eu/PRS13452Mamas">Māmās</t:persName> on <t:date>30 Tāḫśāś</t:date>.</t:ab>
               </t:note>
            </t:place>
            

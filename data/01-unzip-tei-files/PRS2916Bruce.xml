               <t:persName>
                  
                  <t:forename>James</t:forename>
                  <t:surname>Bruce</t:surname>
               </t:persName>
               
           
               
      
       
               <t:occupation type="academic">traveller</t:occupation>
                  <t:nationality type="Scotland"/>
                  <t:faith type="notSpecified"/>
                  <t:birth/>
               <t:residence>He was in Gondar from <t:date>1769</t:date>to <t:date>1772</t:date>. </t:residence>
               <t:floruit notBefore="1769" notAfter="1772">He arrived in Ethiopia motivated by the ambition 
                  to discover the source of Blue Nile in <t:date> September 1769</t:date>. 
                     He was the most important foreigner to visit Ethiopia  between the expulsion of the Jesuits in <t:date>1632</t:date> and 
                     the visit of <t:persName ref="https://betamasaheft.eu/PRS8442Salt">Henry Salt</t:persName> in<t:date> 1810</t:date>. 
               </t:floruit>
                  <t:death when="1794-04-26"/>
               </t:person>
               

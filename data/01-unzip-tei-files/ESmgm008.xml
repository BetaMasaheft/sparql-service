                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">mediocre</seg>
                        <seg type="ink">Black; red (vivid vermilion; dark vermilion on <locus target="#13rb">13rb</locus>)</seg>
                        <date>1550-1650</date>
                        <seg type="rubrication">Nomina sacra; 
 name of the donor;
 numbers
                           and incipits of miracles; 
 elements of the punctuation signs; 
                           Ethiopic numerals or their elements;
 three groups of red lines
                           alternating with black lines on the incipit page (vol. 1r)</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: fols. 1-24, 31-92,
                        114-117</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="25" to="30">25-30</locus>, 93-113,
                        118-119</handNote>
                     <handNote xml:id="h4" script="Ethiopic"> Hand a: the shape of letters is broad,
                        the lines are thick; the loops of the fifth order are mostly
                        closed</handNote>
                     <handNote xml:id="h5" script="Ethiopic"> Hand b: the letters are more narrow,
                        the lines are thinner than in the hand a; the loops of the fifth order are
                        mostly
                        closed</handNote>
                  </handDesc>

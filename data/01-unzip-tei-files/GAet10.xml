                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus target="#1r">Fol. 1r</locus>
                              <desc>Unclear note written in a recent hand in violet ink. The note is in Amharic.</desc>
                              <q xml:lang="am">ቦሸት፡ ቅርፊት፡ ቅኆነ፡ አውጽተሕ፡ አጠጣ፡ ያተርፋ፡ አመማሮ፡ ዴጥ፡ አዳም፡ ይጀበራ፡ ልብ፡ አጠ፡ ናዶሮ፡</q>
                            </item>
                            <item xml:id="a2">
                              <locus from="1v" to="2r">Fols 1v–2r</locus>
                              <desc>Unclear note written in a recent hand in blue pencil. The note is in Amharic and is dated 18 Taḫśaś 1901 E.C., corresponding to 27 December 1908.</desc>
                              <q xml:lang="am">፲፱፻፩ዓመተ፡ ምሕረት፡ ታሕሣሥ፡ ፲፱ቀን፡ ጨረቃዋ፡ ደም፡ ለብሰ፡ አደረች፡ ገረብ፡ ጽድቅ፡ ሚካኤል፡</q>
                            </item>
                            
                            <item xml:id="e1">
                              <locus target="#77v">Fol. 77v</locus>
                              <desc>Pen trials.</desc>
                            </item>
                          </list>
                        </additions>

                        <bindingDesc>
                          <binding contemporary="true" xml:id="binding">
                            <decoNote xml:id="b1">Link-stitch sewing linked to uncovered wooden boards.</decoNote>
                            <decoNote xml:id="b2" type="Boards">
                              The boards are decorated with drawings depicting equal-armed crosses. On the left board the cross is drawn in pencil and enclosed in a rectangular frame.
                              On the right board the cross is drawn in blue or violet ink.
                            </decoNote>
                            <decoNote xml:id="b3" type="EndLeaves">
                              The first quire is a protective quire on which additional notes were added later.
                            </decoNote>
                            <decoNote xml:id="b4" type="SewingStations">4</decoNote>
                            <decoNote xml:id="b5">
                              The sewing is a chain-stitch on four sewing stations (two pairs). The sewing pattern is a variation of the <term key="patternA3" ana="#patternA3">pattern A3</term> by Bozzacchi.
                              Along the fold of the first quire, for each pair of sewing station, there is one long stitch without knots.
                              The thread used to sew the book is of <term key="animalThread" ana="#animalThread">animal origin.</term>
                            </decoNote>
                            <decoNote xml:id="b6" type="Spine">
                              Small holes are visible in the centre fold of the quires, close to the tail and the head of the codex.
                            </decoNote>
                          </binding>
                        </bindingDesc>

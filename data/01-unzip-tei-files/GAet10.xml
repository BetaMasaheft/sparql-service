                        <decoDesc>
                            <decoNote type="band" xml:id="d1">
                              <locus target="#1r">Fol. 1r</locus>
                              <desc>Ornamental band formed by a geometric <term key="interlace" ana="#interlace">interlace</term> in black ink.</desc>

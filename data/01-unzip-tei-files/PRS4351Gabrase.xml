      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ገብረ፡ ሥላሴ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gabra Śǝllāse</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾǝč̣č̣age</t:roleName>
               </t:persName>
               <t:occupation type="ecclesiastic">abbot</t:occupation>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
           
       
               <t:floruit notBefore="1889" notAfter="1906">He was a native of <t:placeName ref="https://betamasaheft.eu/LOC3764Hamase">Ḥamāsen</t:placeName>, 
                  took his monastic vow in a monastery in 
<t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName>, and received his theological education and honorific title 
                  <t:persName ref="https://betamasaheft.eu/PRS4351Gabrase">
                     <t:roleName type="title">mamhǝr</t:roleName> 
                  </t:persName> 
                  probably at <t:placeName ref="https://betamasaheft.eu/LOC1311AksumS">ʾAksum Ṣǝyon</t:placeName>. 
                  He joined 
                  <t:persName ref="https://betamasaheft.eu/PRS8388SalamaI">
                     <t:roleName type="title">ʾabuna</t:roleName> 
                  </t:persName> in <t:date>1841</t:date>
                     who remained as his spiritual son in his retinue at <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>
                  during the rest of Zamana Masāfǝnt. 
                  During the reign of <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName>, he was also with
                  <t:persName ref="https://betamasaheft.eu/PRS8388SalamaI">
                     <t:roleName type="title">ʾabuna</t:roleName> 
                  </t:persName>
                  and followed him to the place of his detention at the royal fortress of 
                  <t:placeName ref="https://betamasaheft.eu/LOC4547Maqdal">Maqdalā</t:placeName> in <t:date>1867</t:date>. 
                  Following the death of <t:persName ref="https://betamasaheft.eu/PRS8388SalamaI">
                     <t:roleName type="title">ʾabuna</t:roleName> 
                  </t:persName>
                   in <t:date>1867</t:date>, 
                  he joined to the court of <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</t:persName>, 
                  where he became the father confessor of both <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</t:persName> 
                     and his wife <t:persName ref="https://betamasaheft.eu/PRS2342Bafana">Bafäna</t:persName>. 
                  In <t:date>1889</t:date>, <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</t:persName> dismissed <t:persName ref="https://betamasaheft.eu/PRS9451Tewoflos">Tewoflos</t:persName> 
                        and appointed in his place <t:persName ref="https://betamasaheft.eu/PRS4351Gabrase">Gabra Śǝllāse</t:persName> 
                  who was solemnly blessed as <t:persName ref="https://betamasaheft.eu/PRS4351Gabrase">
                     <t:roleName type="title">ʾǝč̣č̣age</t:roleName> 
                  </t:persName>
                   
                        by 
                  <t:persName ref="https://betamasaheft.eu/PRS6876Matewos">
                     <t:roleName type="title">ʾabuna</t:roleName>  
                  </t:persName>. 
                     
              
                     
          </t:floruit>
               <t:death when="1906">He died while still in the office of 
                  <t:persName ref="https://betamasaheft.eu/PRS4351Gabrase">
                     <t:roleName type="title">ʾǝč̣č̣age</t:roleName>  
                  </t:persName>
                  and was buried in 
                  <t:placeName ref="https://betamasaheft.eu/INS0346DL">Dabra Libānos</t:placeName>. </t:death>
            </t:person>
            
         </t:listPerson>
         

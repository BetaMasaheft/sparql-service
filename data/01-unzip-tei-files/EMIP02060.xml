                            Identified in the insurance hand list as Case F4
                            </desc>
                        </item>
                        <item xml:id="e5">
                          <locus target="#16v" facs="018">Fol. 16v</locus>
                           <desc>
                            words of text are written interlinearly
                            </desc>
                        </item>
                     </list>
                  </additions>

               <t:placeName>Qāḥen ʾƎndā Ṣādǝqān</t:placeName>
               <t:placeName type="alt">Qāḥen Dabra Ṣādǝqān</t:placeName>
               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>
               
               <t:settlement type="province" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</t:settlement>
               <t:settlement type="warada" from="2012-11-06" to="2012-11-07" ref="https://betamasaheft.eu/LOC4047Kelett">Kǝlǝtta ʾAwlāʿlo</t:settlement>
               <t:settlement type="tabiya" from="2012-11-06" to="2012-11-07" ref="https://betamasaheft.eu/LOC7264Qahen">Qāḥen</t:settlement>
               <t:settlement from="2012-11-06" to="2012-11-07" type="qushat" ref="https://betamasaheft.eu/LOC7265Qahen">Qāḥen</t:settlement>
               
               <t:location>
                  <t:geo>13.652017 39.543733</t:geo>
                  <t:height unit="m">2092.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1300" notAfter="1400">1300-1400</t:date>
                  
                  <t:ab type="history">Dabr. A new church is being built at the rock near the old rock-hewn church, with the burial of the local <t:persName ref="https://betamasaheft.eu/PRS12540SadeqanQahen">Ṣādǝqān</t:persName>. 
                     A recent church above on the plain is dedicated to <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</t:persName>.  
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/QES.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>16 Mss. and 4 scroll photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes001">QES-001</t:ref> “Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes002">QES-002</t:ref> “Vita of  George; Miracles of George”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes003">QES-003</t:ref> “Vita of the Righteous Ones”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes004">QES-004</t:ref> “Prayer of Incense and other texts”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes005">QES-005</t:ref> “Homiliary for the feasts St. Michael Miracles of St. Mikaʾel”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes006">QES-006</t:ref> “Vita of Righeous ones;               Miracles of the Righteous ones”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes007">QES-007</t:ref> “Vita of  ʾEwostatewos; Miracles of  ʾEwostatewos; Image of  ʾEwostatewos”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes008">QES-008</t:ref> “Book of the Marriage Ritual”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes009">QES-009</t:ref> “Book of the Covenant of the Righteous ones; Vita of the Righteous ones”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes010">QES-010</t:ref> “Bǝsratä Yoḥannǝs (fols. 3r-82r); Bǝsratä Marqos (<t:ref type="mss" corresp="https://betamasaheft.eu/ES83r122">83r-122</t:ref>vb); Fǝkare ʾIyäsus (1<t:ref type="mss" corresp="https://betamasaheft.eu/ES23ra132">23ra-132</t:ref>vb); Tǝnbitä Sabela (1<t:ref type="mss" corresp="https://betamasaheft.eu/ES33ra147">33ra-147</t:ref>); Dǝrsan Zä- Yohannǝs ʾAfäwärq (read on the feast of Rufaʾel ) (fols. 1<t:ref type="mss" corresp="https://betamasaheft.eu/ES41ra161">41ra-161</t:ref>rb); Täʾamrä Rufaʾel (1<t:ref type="mss" corresp="https://betamasaheft.eu/ES61rb192">61rb-192</t:ref>rb)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes011">QES-011</t:ref> “Book of the Funeral Rite”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes012">QES-012</t:ref> “Bandlet of Righteousness”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes013">QES-013</t:ref> “Excerpts from Dǝqqwa”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes014">QES-014</t:ref> “Book of Hymns”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes015">QES-015</t:ref> “1Rite of the passion Week; Doctrina Arcanorum; Other texts for passion week ”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESqes016">QES-016</t:ref> “Bandlet of Righteousness”.</t:ab>
  
                  <t:ab type="tabot">
                     <t:measure quantity="3"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus</t:persName> and <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName> in the old church, 
                     <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</t:persName> in the upper church.</t:ab>
               </t:note>
            </t:place>

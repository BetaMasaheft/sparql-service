                     <msItem xml:id="ms_i1.2">
                        <locus from="46v">Fols 46v and following</locus>
                        <title ref="https://betamasaheft.eu/LIT1931Mashaf#Deacons">Maṣḥafa
                                                  gǝnzat, Readings and prayers over deceased
                                                  deacons</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በግንዘተ፡ ዲያቆናት፡ ጸሎታተ፡ ትብል፡ ዘሀሎ፡ ኀበ፡ ግንዘተ፡ ቀሳውስት። ወዓዲ፡ መዝሙር፡ ዘበሃሌ<supplied reason="undefined" resp="PRS10747Zotenbe">ሉ</supplied>ያ፡ 
                  ወዓዲ፡ ዘንተ፡ ቅድሓ፡ መዝሙር፡ ፫፡</incipit>
                     </msItem>
              
                     <msItem xml:id="ms_i1.3">
                        <locus from="50r">Fols 50r and following</locus>
                        <title cert="low" xml:lang="gez" ref="https://betamasaheft.eu/LIT1931Mashaf#Men">ዝውእቱ፡ ዘይትነበብ፡ ላዕለ፡ ዕደው፡ ወራዙት፡ እለ፡ ኖሙ።</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ወትብል፡ ጸሎታተ፡ ዘሀሎ፡ ኀበ፡ ግንዘተ፡ ቀሳውስት፡ ወዘንተ፡ ቅዳሐ፡ መዝሙር፡ ዘ፻፵፰፡</incipit>
                     </msItem>
              
                     <msItem xml:id="ms_i1.4">
                        <locus from="53r">Fols 53r and following</locus>
                        <title xml:lang="gez" ref="https://betamasaheft.eu/LIT1931Mashaf#Children">አርእስተ፡ ምንባባት፡ በሕፃናት።</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በል፡ ዘተጽሕፈ፡ በእግሩ፡ ወዘንተ፡ ቅዳሐ፡ ዳዊት። ረዳኢ፡ ኵነኒ፡</incipit>
                     </msItem>
              
                     <msItem xml:id="ms_i1.5">
                        <locus from="57v">Fols 57v and following</locus>
                        <title ref="https://betamasaheft.eu/LIT1931Mashaf#Women">Maṣḥafa
                                                  gǝnzat, Readings and prayers over deceased adult
                                                  women</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በግንዘተ፡ ዐበይት፡ አንስት፡ ወትብል፡ ጸሎታተ፡ ዘተጽሕፈ፡ በእግሩ፡ ወዳዊት፡ በሃሌ፡ ሉያ። ትባርኮ፡ ነፍስየ፡ ለእግዚአብሔር፡</incipit>
                     </msItem>
              
                     <msItem xml:id="ms_i1.6">
                        <locus from="62r">Fols 62r and following</locus>
                        <title ref="https://betamasaheft.eu/LIT1931Mashaf#YoungGirls">Maṣḥafa
                                                  gǝnzat, Readings and prayers over deceased young
                                                  girls</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በግንዘተ፡ አዋልድ፡ ንኡሳት፡ ትብል፡ ዘከመ፡ ተጽሕፈ፡ በእግሩ፡ ጸሎታተ፡ ወዘንተ፡
                  መዝሙረ፡ ቅዳሕ፡ ሃሌ፡ ሉያ፡ በ፫። ወአንበሩኒ፡ ውስተ፡ ጽልመት፡ ታሕተ።</incipit>
                     </msItem>
              
                     <msItem xml:id="ms_i1.7">

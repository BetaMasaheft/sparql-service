<msItem xml:id="ms_i1">
<locus from="3r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT1451GadlaG">Life of Gabra Manfas Qǝddus</title>
<incipit xml:lang="gez">በስመ፡ አብ፡ ንወጥን፡ ገድሎ፡ ለቅዱስ፡ ወብፁዕ፡ ወጽሙድ፡ መስተጋድል፡ ኮከበ፡ ገዳም፡ ዘዝኩር፡ ወክቡር፡ ርእሳኑ፡ ጻድቅ፡ ወኄር፡ አባ፡ ገብረ፡ መንፈስ፡ ቅዱስ፡ ገዳማዊ፡
ዘሠረቀ፡ እምሀገረ፡ ንሒሳ፡ እምደወለ፡ መትሕተ፡ ምድር፡ እምደቡበ፡ ግብጽ፡ ወነበረ፡ ገዳመ፡ ፫፻ዓመተ፡ ወወጺኦ፡ እምህየ፡ ዔለ፡ ገዳማተ፡ ኢትዮጵያ፡ ወነበረ፡ በዝቋላ፡ ኀበ፡ ምድረ፡ ከብድ፡
፪፻፷ወ፪ዓመት፡ ዕራቁ፡ ማየ፡ እንዘ፡ ኢይሰቲ፡ ወእክለሂ፡ እንዘ፡ ኢይበልዕ። አኮ፡ ከመ፡ ሰብእ፡ ዘነበረ። አላ፡ ከመ፡ መላእክት፡ በዲበ፡ ምድር፡ ወፈጸመ፡ ገድሎ፡ አመ፡ ፭ለመጋቢት፡ በዕለተ፡
እኁድ፡ በበዓሎሙ፡ ለጴጥሮስ፡ ወጳውሎስ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2">
<locus from="29r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT3977Taammer">Miracles of Gabra Manfas Qǝddus, 12 in number</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3">
<locus from="40r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT1850Malkea">Gubāʾe malkǝʾ</title>
<textLang mainLang="gez"/>

<msItem xml:id="ms_i3.1">
<locus from="40r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2881RepCh162">To Gabra Manfas Qǝddus</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሆህያቲሁ፡ ቅሩጽ። ኀበ፡ አምደ፡ ወርቅ፡ ሥርግው፡ ወአኮ፡ ዘዕፅ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.2">
<locus from="42v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">To Takla Hāymānot</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ እምከርሥ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.3">
<locus from="46v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2956RepCh237">To Eustathius</title>
<incipit xml:lang="gez">ቀዳሚሁሰ፡ ለዘየአምን፡ በረድኤትከ፡ ዘኃይል።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.4">
<locus from="50v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279">To St John the Baptist</title>
<incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ እሳት፡ በሐቅለ፡ ሕሊና፡ ነዳዲ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.5">
<locus from="53r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2906RepCh187">To St Peter and Paul</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘአልባስጥሮስ፡ አፈው።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.6">
<locus from="56r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT6445LetusWeep">To our Lord and the blessed Virgin Mary</title>
<incipit xml:lang="gez"><gap reason="omitted"/>ድ፡ ለባሕቲቱ። እንዘ፡ አሐዱ፡ ሠለስ<gap reason="omitted"/>ሉያ፡ ሃ፡ ሃ፡ ንዑ፡
ንብኪ፡ ኢይሜንነነ፤ ውእቱ፡ አቡነ፡ ወእምነ። </incipit>
<note>The rubrics have been left unfilled.</note>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.7">
<locus from="59r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3067RepCh347">To the Holy Trinity</title>
<incipit xml:lang="gez">እስመ፡ ብዙኃን፡ እሙንቱ፡ እለ፡ አኃዙ፡ ይጽሐፉ። ሃይማኖተ፡ ቅድስተ፡ ሥላሴ፡ እንተ፡ ተሳተፉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.8">
<locus from="63r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">ማኅበረ፡ ምእመናን፡</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.9">
<locus from="64v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">To our Lord</title>
<incipit xml:lang="gez">ስብሐት፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይሄሱ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.10">
<locus from="68v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2842RepCh125">To our Lord</title>
<incipit xml:lang="gez">ስብሐት፡ ለዝክረ፡ ስምከ፡ በመጽሔተ፡ መስቀል፡ ዘተለክዓ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.11">
<locus from="71r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2741RepCh25">To our Lord</title>
<incipit xml:lang="gez">ስብሐት፡ ለሕማምከ፡ ቤተ፡ አይሁድ፡ ዘአንደደ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.12">
<locus from="75v"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">ጠቢበ፡ ጠቢባን፡</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.13">
<locus from="83r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.14">
<locus from="87v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT4274AkkonuB">አኮኑ፡ ብእሲ፡</title>
<incipit xml:lang="gez">አኮኑ፡ ብእሲ፡ ሶበ፡ ሐኒጸ፡ ቤት፡ አፍተዎ። ኵሎ፡ ፃፃዖ፡ ያቀድም፡ አስተዳልዎ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.15">
<locus from="89v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2937RepCh218">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለኵሎን፡ መልክዕኪ፡ እመ፡ እግዚአብሔር፡ እምየ፡ እግዝእትየ፡ ማርያም።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.16">
<locus from="92r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2285Saqoqa">Lament of the blessed Virgin</title>
<incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ሕፀተ፡ ግፃዌ፡ ዘአልቦ። ሰቆቃወ፡ ድንግል፡ እጽሐፍ፡ በቀለመ፡ አንብዕ፡ ወአንጠብጥቦ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.17">
<locus from="96v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3082RepCh362">Hymn to the blessed Virgin</title>
<incipit xml:lang="gez">እግዚአብሔር፡ አብ፡ ወሀቤ፡ ብርሃን፡ ዘይሤለስ፡ በአካሉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.18">
<locus from="100r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2932RepCh213">On the assumption of Mary</title>
<incipit xml:lang="gez">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ ምስለ፡ ነፍስኪ፡ ኢመዋቲ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.19">
<locus from="101r"/>
    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1865Malkea">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">ጽጌ፡ አስተርአየ፡ ሠሪጾ፡ እምዓፅሙ። ለዘአምኃኪ፡ ጽጌ፡ ለገብርኤል፡ ምስለ፡ ሰላሙ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.20">
<locus from="112r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">ይዌድስዋ፡ መላእክት፡ በአርያም፡ በውስተ፡ ውሣጤ፡ መንጦላዕት።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.21">
<locus from="113r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2962RepCh243">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">በሐኪ፡ ማርያም፡ እምነ፡ እግዝእትነ፡ ትምክህቶሙ፡ አንቲ፡ ለዘመድነ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.22">
<locus from="115v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT4998MiracleJewJerusalem">Miracle of the blessed Virgin</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.23">
<locus from="116v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3064RepCh344">To the blessed Virgin Mary</title>
<incipit xml:lang="gez">እሴብሕ፡ ጸጋኪ፡ ኦምልእተ፡ ጸጋ፡ ወይትጋነይ፡ ለኪ፡ ኦምልእተ፡ ውዳሴ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.24">
<locus from="117r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">To St Michael</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.25">
<locus from="120v"/>
<title xml:lang="en" type="complete">To the angel Gabriel</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዓ፡ ቀዲሙ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.26">
<locus from="123v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">To St George</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3.27">
<locus from="127r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3089RepCh369">Hymn</title>
<incipit xml:lang="gez">ኦሰማዕተ፡ አልፋ፡ ለስዕለትየ፡ ጸሐፋ፡ ወኢትግድፋ። ጊዮርጊስ፡ ወልታየ፡ ኩነኒ፡ ከመ፡ ሐገፋ።</incipit>
<textLang mainLang="gez"/>
</msItem>

</msItem>

<msItem xml:id="ms_i4">
<locus from="128r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT1325egziab">ʾƎgzer nagś beginning with the month of Maskaram</title>
<textLang mainLang="gez"/>
</msItem>


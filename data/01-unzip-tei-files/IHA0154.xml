                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#4r">-4r</locus>
                           <desc>Magic squares (wafq)</desc>
                           <q>Two awqāf: the first reporting some God's Names; the second with separate letters, surrounded by numbers.</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#9v">-9v</locus>
                           <desc>Prayer on the Prophet</desc>
                           <q>The name Muḥammad is written in big characters, with a simple prayer below, in smaller letters.</q>
                           <note/>
                        </item>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="202r">1r-202r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus> بَعَثْنَاهُمْ لِنَعْلَمَ أَيُّ الْحِزْبَيْنِ أَحْصَى لِمَا لَبِثُوا أَمَدًا <note>Sūrat al-Kahf (18:11)</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#202r">-202r</locus>قلْ أَعُوذُ بِرَبِّ النَّاسِ

مَلِكِ النَّاسِ

إِلَهِ النَّاسِ

مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ

الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ

مِنَ الْجِنَّةِ وَالنَّاسِ<note>Sūrat al-Nās (114)</note>
                     </explicit>
                     <note>From 18:11 to the end. Vocalized. The words aren't divided. </note>
                     <note/>
                  </msItem>

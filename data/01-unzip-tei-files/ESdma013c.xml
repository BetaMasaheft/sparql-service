               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">8.0</measure> folios, of which <measure unit="leaf" type="blank"/> blank 1r, 8r, in <measure unit="quire">1.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">97</height>
                              <width unit="mm">69</width>
                              <depth unit="mm">4</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">8</dim>
                                 <locus from="1r" to="8v"/>I(8/fols. 1r-8v).</item>
                           </list>
                        </collation>
                        <condition key="good">The Ms. is a separate quire (possibly never part of a
                           text block), with leaves crudely sewn with a vegetal thread. 
 The
                           edges of some leaves are damaged by rodents.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" writtenLines="16">
                           <dimensions unit="mm">
                              <height>75</height>
                              <width>51</width>

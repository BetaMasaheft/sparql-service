                           </dimensions>
                           <note>All data are for <locus target="#2r">2r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible. </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are partly visible. </ab>
                           <ab type="pricking"> Ruling pricks are visible. </ab>
                           <ab type="ruling"> The upper line is written above the ruling. </ab>
                           <ab type="ruling"> The bottom line is written above the ruling.  The bottom ruled line was not used by the scribe on <locus from="3r" to="4r">3r-4r</locus>.</ab>
                        </layout>
                        
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, careless</seg>
                        <seg type="ink">Black, red</seg>
                        <date>First half of the 20th cent. (?)</date>
                        <list type="abbreviations">
                           <item>ቅን፡ for ቅንዋት፡</item>
                           <item>እስ፡ ለዓ፡/እስ፡ ለዓለ፡ for እስመ፡ ለዓለም፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of antiphons and/or their
                           incipit; elements of the punctuation signs; Ethiopic numerals or their
                           elements.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1v">f. 1v</locus>
                           <desc>: Excerpt from Mazmur za-sǝbkät, Antiphon for the Sunday in the
                              Time of the Preaching.</desc>
                           <quote xml:lang="gez">
                              <locus target="#1v">1v</locus>: በ፯፡ ዘሙሴ፡ ሰበከ፡ ለነ፡ ዜናሁ፡ ዘሙሴ…</quote>
                           <quote xml:lang="en"/>
                           <note> The note, probably a writing exercise, is written in a crude hand.
                           </note>
                        </item>
                        <item xml:id="e1">- An omitted word is written in the upper margin of <locus target="#6r">6r</locus>. 
 - Pen trial: <locus target="#4v">4v</locus>. 
 - Writing exercises: <locus target="#1r">1r</locus>, 8v.</item>
                     </list>
                  </additions>
                  <bindingDesc>

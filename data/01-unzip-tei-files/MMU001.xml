               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">36</measure>
                        <measure unit="quire">4</measure>
                           <dimensions type="outer" unit="mm">
                              <height>161</height>
                              <width>138</width>
                              <depth>36</depth>
                           </dimensions>
                        </extent>
                          <foliation>In the middle of the lower margin, in pencil.</foliation>
                        <collation>
                          <list>
                            <item xml:id="q1" n="1">
                               <dim unit="leaf">9</dim>
                               <locus from="1" to="9"/>
                               8, stub after 1
                          </item>
                          <item xml:id="q2" n="2">
                             <dim unit="leaf">8</dim>
                             <locus from="10" to="17"/>
                        </item>
                        <item xml:id="q3" n="3">
                           <dim unit="leaf">9</dim>
                           <locus from="18" to="26"/>
                           20, stub after 24
                      </item>
                      <item xml:id="q4" n="4">
                         <dim unit="leaf">10</dim>
                         <locus from="27" to="36"/>
                    </item>
                          </list>
                        </collation>
                        <condition key="good">Stains of dirt throughout the
                        manuscript, sporadic stains of dye; lower right corners of
                        <locus target="#1 #2 #3"/> are torn down. The stains apparently
                        indicate an extensive use of the manuscript in the past. The quires have
                      been repaired with a modern thread.</condition>
                         </supportDesc>
                         <layoutDesc>
                               <layout columns="2" writtenLines="25">
                                 <locus from="1r"/>
                               </layout>
                         </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script"/>
                        <seg type="ink">Black.</seg>
                        <desc>Irregular hand.</desc>
                        <date notBefore="1700" notAfter="2000"/>
                     </handNote>
                  </handDesc>

                  <decoDesc>
                    <summary>Some text is partially visible at the rands of miniatures.
                      Apparently, the miniatures have been executed over the text at a later stage, probably in order
                    to increase a market value of the manuscript.</summary>
                    <decoNote type="miniature" xml:id="d1">
                      <locus target="#2v"/>
                      <desc>Miniature
                        of <ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref>,
                      namely of<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George</persName>,
                   the <term key="dragon" ana="#dragon">dragon</term>, and the <term key="angel" ana="#angel"/>.</desc>
                    </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                      <locus target="#6r"/>
                      <desc>
                      Miniature of <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>,
                      and two
                      <term key="angel" ana="#angel">angels</term> with <term key="sword" ana="#sword">swords</term>.</desc>
                    </decoNote>
                    <decoNote xml:id="d3" type="miniature">
                      <locus target="#27r"/>
                      <desc>Miniature of
                        <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, depicting
                      also <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and
                    <persName ref="https://betamasaheft.eu/PRS5695John">John</persName>.</desc>
                    </decoNote>
                    <decoNote xml:id="d4" type="miniature">
                      <locus target="#35r"/>
                      <desc>Miniature of the <ref type="authFile" corresp="https://betamasaheft.eu/AT1050ApparitionResur">Post-Resurrection Appearance of Jesus</ref>.</desc>
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1">
                        <locus target="#16v #17v"/>
                        <desc>Crude note or addition to the text in pen.</desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true" xml:id="binding">
                        <decoNote xml:id="b1">Two wooden boards covered with brown blind-tooled leather.</decoNote>
                        <decoNote xml:id="b2" type="Boards">Inlays of reused parchment with unidentified texts. The inlay
                        of the back board has stains of pink and violet color.</decoNote>
                        <decoNote xml:id="b3" type="bindingMaterial">
                          <material key="wood"/>
                          <material key="leather"/>
                          <material key="parchment"/>
                        </decoNote>
                        <decoNote xml:id="b4" type="SewingStations">4</decoNote>
                        <decoNote xml:id="b5">Two pairs of sewing stations.</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>

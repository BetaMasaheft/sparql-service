      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0489</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዝክረ፡ መንፈስ፡ ቅዱስ፡ ሕይወት፨</l>
                  <l n="2">እንተ፡ ባረኮ፡ ይትረዓይ፡ በዐይነ፡ ኵሉ፡ ፍጥረት፨</l>
                  <l n="3">ፍቅርተ፡ ክርስቶስ፡ ኤዶም፡ ዘመዐዛኪ፡ ረድኤት፨</l>
                  <l n="4">ሥቅይዋ፡ ለለ፡ ጊዜሁ፡ ለሰብእናየ፡ ገነት፨</l>
                  <l n="5">ኤፌሶን፡ ቀኖና፡ ሕግ፡ ወግዮን፡ ጸሎት፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስኪ፡ እለ፡ ተቀብኣ፡ ቅብአ፡ አሚን፨</l>
                  <l n="2">ህየንተ፡ ሣራ፡ ወርብቃ፡ በእደ፡ ፈጣሪ፡ መድኅን፨</l>
                  <l n="3">ፍቅርተ፡ ክርስቶስ፡ ፀሓይ፡ ዘሥርጋዌኪ፡ ብርሃን፨</l>
                  <l n="4">ኢክህሉ፡ ቀሪቦተኪ፡ ካህናተ፡ ሐሰት፡ አብዳን፨</l>
                  <l n="5">ወኢረከበኪ፡ ጸላኢ፡ ሰይጣን፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለመቃብርኪ፡ እምጽርሐ፡ አርያም፡ እለ፡ ወረዱ፨</l>
                  <l n="2">ለዐቂቦቱ፡ መላእክት፡ ክብረ፡ ዚአሁ፡ አግሀዱ፨</l>
                  <l n="3">ፍቅርተ፡ ክርስቶስ፡ ብፅዕት፡ ለእግዚአብሔር፡ በፈቃዱ፨</l>
                  <l n="4">ኢክህሉ፡ ቀረቦተኪ፡ እስመ፡ ናፈቁ፡ ወክሕዱ፨</l>
                  <l n="5">በግብረ፡ እበዱ፡ ለንስጥሮስ፡ እኩያን፡ ውሉዱ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላምኪ፡ ኢይትርፍ፡ ጻማሁ፡ ለነባቤ፡ ዝንቱ፡ ድርሳን፨</l>
                  <l n="2">እስመ፡ ኑኀ፡ ዕድሜ፡ ይትዌከፍ፡ እምእግዚአብሔር፡ መድኅን፨</l>
                  <l n="3">ፍቅርተ፡ ክርስቶስ፡ ቅድስት፡ በስእለትኪ፡ ኪዳን፨</l>
                  <l n="4">ወይድኀን፡ ጊዜ፡ ሐተታ፡ እምጻዕረ፡ ኵነኔ፡ ወደይን፨</l>
                  <l n="5">እስመ፡ ጸላኤሁ፡ እኩይ፡ ረቂቅ፡ ሰይጣን፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለኪ፡ ፍቅርተ፡ ክርስቶስ፡ ፌበን፡ በሰረገላ፡ ኀዘን፡ ዘተጽዕኑ፨</l>
                  <l n="2">ማኅበራንኪ፡ እለ፡ የኀዝኑ፨</l>
                  <l n="3">በጊዜ፡ ሞትኪ፡ እለ፡ መነኑ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለኪ፡ ፍቅርተ፡ ክርስቶስ፡ እምነ፡ በልቡናኪ፡ ቤት፡ እንተ፡ ኢቦአ፡ ናፍቆ፨</l>
                  <l n="2">ቃለ፡ ፈጣሪ፡ ድምፀ፡ መሰንቆ፨</l>
                  <l n="3">ዘትሰምዒ፡ ዘልፈ፡ በአድለቅልቆ፨</l>
                  <l n="4">ጸግውኒ፡ ሊተ፡ ለልብየ፡ ጻህቆ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለኪ፡ ፍቅርተ፡ ክርስቶስ፡ ቅድስት፡ ሶበ፡ ጸዋዕኩኪ፡ በተአምኖ፨</l>
                  <l n="2">ለማእበለ፡ ኀዝን፡ ዘታዝኅኖ፨</l>
                  <l n="3">አውፅእኒ፡ ሊተ፡ እምተኮንኖ፨</l>
                  <l n="4">በእንተ፡ ቃለ፡ አብ፡ ዘመጽአ፡ ሰብአ፡ ከዊኖ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="6r">1r-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1154IHA">al-Risāla al-maymūna al-zakiyya</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله ذى النعمة الظاهرة والالاء الغامرة والصلاة والسلام على سيدنا محمد شفيع العصاة اذا اهم بالساهرة وعلى آله وصحبه السادات البررة وبعد فاعلم يا اخى انك ان كنت تطلب الخلاص لنفسك فعليك بطلب العلم النافع اولا فانه القطب وعليه المدار والخير كله فى طلب العلم النافع والعمل به والعلم النافع هو معرفة خالقك

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>ولكن لا يوجدون الا فردا عن فرد فعليك بالذى نحن فى جنبه السراج المنير رضى الله عنه وأرضاهم قبل الفرصة بالفوات وصلى الله على سيدنا ومولانا محمد وعلى اله وصحبه وسلم اجمعين والحمد لله رب العالمين امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6v" to="23v">6v-23v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT1153IHA">انفع الرسائل باهم المسائل</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus>بسم الله الرحمن الرحيم الحمد لله الذى جعل قلوب العارفين اوعية اسراره وبروزهم رحمة لعامة خلقه وهدايتهم اليه والصلاة والسلام على سيدنا محمد [...] وبعد فهذ رسالة جمعت فيها بعض وصياة شيخنا فى رسائل متعددة لبعض الاولاد والاخوان تقريبا للفائدة ولما كانت الوصية اخرى متفرقة باوقات مختلفة لاشخاص معتددة تكرر ما فى وصية فى وصية أخرى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23v">-23v</locus>قال العلامة المناوى فى شرحه اى بملاينتهم والرفق بهم ليدخل من يدخل فى الدين برفق ويتقى المؤمن شر من قدر عليه الشفاء انتهى فإذا علمت ذلك فليعامل كل احد بما هو الانسب له وليجتنب الموفق من جعل الامر كلية بل يميز بالقرائن والمحكم هذ والسلام والحمد لله رب العالمين أمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="24v" to="43v">24v-43v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1149IHA">Kitāb Laṭā’if al-išārāt al-munšiṭa al-muʿziǧa</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>بسم الله الرحمن الرحيم الحمد لله الملك الحق المبين الحليم الغفار الكريم الجواد الذى سحائب فضله بوابل جوده على الكون مدرار القدوس الذى قدس اقواما واصطفاهم لحضرة قدسه وخلص ارواحهم عن مضاجعة الاغيار وحلله عن علوم الغيب ايزار الاستار [...] وابعد قوما وأقصاهم فى سجن القطيعة ومنعهم عن طاعته بواسطة هذه الامارة الظلومة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43v">-43v</locus>كما ان الولد سر الوالد كما ورد وبعد الغمام جهام هذا او ان الختام ختم الله لنا بحسن الختام بحرمة سيدنا محمد وآله وصحبه الكرام الحمد لله او لا وآخر او صلى الله على سيدنا محمد واله وصحبه ووسلم تم تم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="45r" to="52v">45r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1201IHA">هداية الاذكياء الى طريق الاولياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#45v">-45v</locus>بسم الله الرحمن الرحيم.
الحمد لله الموفق للعلى| حمدا يوافى بره المتكاملا| ثم الصلاة على الرسول المصطفى | والآل مع صحب واتباع ولا| تقوى الاله مدار كل سعادة| وتباع أهوى رأس شرحا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>هذا الذى أوصى الشيوخ الكمل| الله وقنا له متفضلا| والحمد للباقى الرؤف مصليا | أعلى الصلاة على الرسول محوقلا.  تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>

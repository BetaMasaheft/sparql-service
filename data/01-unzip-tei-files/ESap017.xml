                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre. Many letters letters (esp. horizontal
                           elements of መ and በ) are extended by hairlines from the left
                           side.</seg>
                        <seg type="ink">Black, red (strong red, strong rose, deep redish
                           brown)</seg>
                        <date>20th century</date>
                        <seg type="rubrication">Divine names; name of the protagonist; the second
                           component of the names of the donors; a few lines on the incipit page of
                           the Text; elements of the punctuation signs; elements of Ethiopic
                           numerals. 
 ff. 3r-36v are rubricated in deep redish brown.
 ff.
                           37r-40r and the second component of the names of the donors on fol. 3r
                           are rubricated in strong rose.
 1st, 2nd, 6th and 7th line, column a,
                           on the incipit page of the Vita is rubricated in strong red.</seg>
                     </handNote>
                     
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1"><desc>Omitted letters are added in blue pen, perhaps in a secondary hand: fols. 3rb, 4rb, 4va, 5ra, 10va, 11ra, 22ra, 25va.</desc></item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards covered with dark brown tooled
                           leather.
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two pairs of endband stitches at the
                           spine cover.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the dark brown leather cover
                           (at least 5 tools were used: double line fillet, single circle, x-form,
                           wave form, criss-cross).</decoNote>
                     </binding>
                  </bindingDesc>

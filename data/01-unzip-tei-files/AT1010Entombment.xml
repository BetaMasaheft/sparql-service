            <t:creation/>
            <t:abstract>
              <t:p> A representation of the burial or entombment of <t:persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus</t:persName>, typically featuring
                <t:term ana="#">Joseph</t:term> and <t:term ana="#">Nicodemus</t:term>, as described in
                 <t:ref cRef="urn:cts:greekLit:tlg0031.tlg001.perseus-grc1:27.57">Matthew 27, 57-61</t:ref>;
                 <t:ref cRef="urn:cts:greekLit:tlg0031.tlg002.perseus-grc1:15.42"> Mark 15, 42-47</t:ref>;
                 <t:ref cRef="urn:cts:greekLit:tlg0031.tlg003.perseus-grc1:23.50">Luke 23, 50-56</t:ref>;
                 <t:ref cRef="urn:cts:greekLit:tlg0031.tlg004.perseus-grc1:19.38">Luke 19, 38-42</t:ref>).
              </t:p>
            </t:abstract>

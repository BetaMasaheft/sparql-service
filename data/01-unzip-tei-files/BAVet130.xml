                    <msContents>      
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="5r" to="69v"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1297Dersan">Dǝrsāna Rufāʾel</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="5r" to="25v"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7214HomilyJCRuf">Homily by John Chrysostom on the archangel Raphael</title>
                                <incipit xml:lang="gez">
                                    በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>ድርሳን፡ ዘይቤ፡ አብ፡ ብፁዕ፡ አባ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ ቍስጥንጥንያ፡
                                    ዘይትነበብ፡ በበዓለ፡ ሊቀ፡ መላእክት፡ <space reason="rubrication"/> ትንብልናሁ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ <space reason="owner"/> ምስለ፡ ኵለ፡ ሰማያውያን፡ ለዓለመ፡ ዓ<supplied reason="explanation">ለም</supplied>፡
                                    አ<supplied reason="explanation">ሜ</supplied>ን፨ 
                                    ይቤ፡ <sic>ዝንቱ፡ ድርሳን፡</sic> በውስተ፡ ሀገረ፡ ሮሜ፡ በትእዛዘ፡ እግዚአብሔር፡ ልዑል፡ ሎቱ፡ ስብሐት፡ ወበትእዛዘ፡ ፪ነገሥት፡ መፍቀርያነ፡ እግዚአብሔር፡ አኖርዮስ፡ ወአርቃድዮስ፡ ወልዱ፡
                                    ለንጉሥ፡ መፍቀሬ፡ እግዚአብሔር፡ ቴዎዶስዮስ፨ አመ፡ <sic>፫ለወርኃ</sic>፡ ንዑስ፡ ዘውእቱ፡ <sic>ጳጉሜን፡</sic> ቡሩክ፡ ተዝካሩ፡ ለመልአክ፡ ዓቢይ፡ ሩፋኤል፡ ሊቀ፡ መላእክት፡ በሰማይ፡ ወበምድር፡
                                </incipit>
                                <explicit xml:lang="gez">
                                    ወሶበ፡ ረከቡ፡ ዘንተ፡ ለአኩ፡ ኀበ፡ ንጉሥ፡ ወነገርዎ፡ ወአይድዕዎ፡ ዘኮነ፨ ወ<supplied reason="omitted">ተ</supplied>ንሥአ፡ ንጉሥ፡ <sic>በፍሥሐ፡</sic> ወበሐሤት፡ ምስለ፡ ሠራዊቱ፡ ብዙኅ፨ ወበጽሐ፡
                                    ኀበ፡ ይእቲ፡ <supplied reason="omitted">መካን፡</supplied> ዘከረዩ፨ ወሶበ፡ ርእየ፡ ውእተ፡ ወርቀ፡ ዘገብሩ፡ ዓብዳን፡ ሕዝብ፡ አንከረ፡ ንጉሥ፡ ወሰብሖ፡ 
                                    ለእግዚአብሔር፨ ሎቱ፡ ስብሐት፡ ወልዕልና፡ ወክብር፡ ለዓለመ<supplied reason="omitted">፡</supplied> ዓለም፡ ዓሜን፨ 
                                </explicit>
                                <textLang mainLang="gez"/>
                            </msItem>                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="25v" to="54v"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1297Dersan#Miracles">Miracles of Raphael</title>
                                <textLang mainLang="gez"/>                                
                                <msItem xml:id="ms_i1.2.1">
                                    <locus from="25v" to="28r"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1297Dersan#MiracleImage">On creating a large image of Raphael</title>
                                    <incipit xml:lang="gez">
                                        በእንተ፡ ተአምራቲሁ፡ ወመንክራቲሁ። <supplied reason="omitted">ለ</supplied>ዘከሠተ፡ ኅቡአቲሁ፡ በትንብልናሁ፡ ለሊቀ፡ መላእክት፡ ሩፋኤል፡ 
                                        ወኮነ፡ ዓቢይ፡ ፍሥሓ፡ ወአዘዘ፡ ንጉሥ፡ ያጸርይዎ፡
                                        ለውእቱ፡ ወርቅ፡ በእሳት፡ እስከ፡ ይትነጠፍ፡ እምርስሕቱ። ወበጊዜሃ፡ ገብሩ፡ ሥዕለ፡ ዓቢየ፡ ዘወርቅ። ንጡፍ፡ በዓምሳለ፡ ሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied>
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ወኦክኑ፡ ይትጋብኡ፡ ኵሉ፡ ሰብእ፡ ሃቤሃ፡ ዘርሑቅ፡ ወቅሩብ፨ ወይጼልዩ፡ ውስቴታ፡ ከመ፡ <sic>ይትነበል፡</sic> ሊቀ፡ መላእክት፡ ወይገብር፡ ሎሙ፡ ዘሰአልዎ<del rend="expunctuated">ሙ</del>፡
                                        መጠነ፡ ፈቀደ፡ እስመ፡ መልአከ፡ ሣህል፡ ወምሕረት፡ ውእቱ፨ ወገባሬ፡ ሥምረቱ፡ ለእግዚአብሔር፡ ልዑል፡ ስእለቱ፡ ወትንብልናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                    <textLang mainLang="gez"/>
                                </msItem>                                
                                <msItem xml:id="ms_i1.2.2">                                    
                                    <locus from="28r" to="33v"/>                                    
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1297Dersan#MiracleSeaMonster">On a keeper of a church, who was carried away by a sea monster</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">
                                        <choice><sic>አጠይቀክሙ፡</sic><corr resp="bm:GrebTiss1935Codices">አጤይቀክሙ፡</corr></choice> ኦአኃውየ፡ ዕፁበ፡ ወመንክረ፡ 
                                        ካልዓ፡ ዘገብረ፡ ተአምረ፡ ሊቀ፡ መላእክት፡ ጸሎቱ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ስምዑ፡ እንግርክሙ፡ ኦጉባኤ፡ ማኅበራ፡ ለቤተ፡ ክርስቲያን፡
                                        ቅድስት፨ ሀሎ፡ ፩ዓቃቤ፡ ቤተ፡ ክርስቲያን፡ ወበአሐቲ፡ ዕለት፡ ቦአ፡ ከመ፡ ያብርህ፡ ማኅቶተ፡ ቅድመ፡ <sic>ሥዕል፡</sic> ክቡር፡ ሩፋኤል<supplied reason="omitted">፡</supplied>
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ወየሀቦ፡ ኃይለ፡ ወመዊዓ፡ ላእለ፡ ኵሉ፡ ጸላእቱ፨ ወፍጡነ፡ <sic>ያወድቆሙ፡</sic> ታሕተ፡ እገሩሁ፨ ወይረስዮሙ፡ ከመ፡ ጸበል፡ ዘቅድመ፡ ገጸ፡ ነፋስ፨ ወይትወከፍ፡
                                        እግዚአብሔር፡ ጾሞ፡ ወጸሎቶ፡ ዕጣኖ፡ ወመሥዋዕቶ፡ ወምጽዋቶ፨ <sic>ወይሬሲ፡</sic> ምስለ፡ <sic>ቆስጠንጢኖስ፡</sic> ንጉሥ፡ ክፍሎ፨ በረድኤቱ፡ ለእግዚእነ፡
                                        <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>                        
                                </msItem>                                
                                <msItem xml:id="ms_i1.2.3">
                                    <locus from="33v" to="34v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1297Dersan#MiracleConstantine">On how Raphael appeared to emperor Constantine</title>      
                                    <textLang mainLang="gez"/>                                    
                                    <incipit xml:lang="gez">
                                        ናሁ፡ ንጽሕፍ፡ ለክሙ፡ ኦአኃውየ፡ ፍቁራን፡ ኃይለ፡ ዘገብረ፡ ቅዱስ፡ ሊቀ፡ መላእክት፡ ሩፋኤል፡ አመ፡ ተፈነወ፡ ውስተ፡ ቤተ፡ ቈስጠንጢኖስ፡
                                        ንጉሥ፡ ዘተመስሎ፡ ለአብርሃም፡ በሠዊዓ፡ ወልዱ፡ ወምንተ፡ ገብረ፡ ዝንቱ፡ መልአክ፡ ሩፋኤል፡ ወሶበ፡ ረከቦ፡ <supplied reason="omitted">ለ</supplied>ንዑሠ፡ 
                                        መዋዕል፡ ወልዱ፡ ለቈስጠንጢኖስ፡
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ዘኢተውህቦ፡ <sic>ለካልአኒሁ፡</sic> መልአክ፨ ከመ፡ ይፍታሕ፡ ማሕፀንተ፡ መካናት፡ ዘሰብእ፡ ወእንስሳ፨ ሶበሰ፡ ኢተውህቦ፡ ሥልጣን፡ እምእግዚአብሔር፨ 
                                        እምኮነ፡ ዝንቱ፡ ዘእንበለ፡ ውሉድ፨ ጻድቃን፡ እምኃጥኣን፨
                                    </explicit>                             
                                </msItem>                                
                                <msItem xml:id="ms_i1.2.4">
                                    <locus from="34v" to="54v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1297Dersan#MiracleTobias">On Tobias</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">
                                        ሣልስኒ፡ ተአምሪሁ፡ ለዝንቱ<supplied reason="omitted">፡</supplied> መልአክ፡ ነበረ፡ ፩ብእሲ፡ በዘመነ፡ አበዊነ፡ ቀደምት። 
                                        <choice><sic>ዘልሙ</sic><corr resp="bm:GrebTiss1935Codices">ዘስሙ፡</corr></choice> ጦቢት፡ ወስመ፡ ወልዱ፡ ጦብያ። ወሠናይ፡ ውእቱ፡ 
                                        ብእሲሁ፡ ወያፈቅሮ፡ ለእግዚአብሔር፨ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወበእንተ፡ ዝንቱ፡ ተጽሕፈ፡ ምስለ፡ ዜና፡ 
                                        መልአክ፡ ሩፋኤል፡ መጽሐፈ፡ ነገሩ፡ ለጦቢት፡ ወልደ፡ ጦብያ፤ ወልደ፡ ገባል፡ ዘእምነ፡ አሳሔል፤ ዘእምነገደ፡ ንፍታሌም፤ 
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ወሰምዓ፡ ዘእንበለ፡ ይሙት፡ ምስናሃ፡ ለነነዌ፨ ወናቡከደነፆር፨ ወ<del rend="expunctuated">ኦ</del>ሳዊሮስ፡ ወሰምዑ፡ ሙስናሃ፡ ለነነዌ፡ ወተፈሥሑ፡ 
                                        እስከ፡ ለዓለም፤ አሜን፨ ተፈጸመ፡ ነገረ፡ <del rend="expunctuated">ወ</del>ጦቢት፡ ወጦብያ፡ ወልዱ፡ ጸሎቶሙ፡ ወበረከቶሙ<supplied reason="omitted">፡</supplied> 
                                        የሀሉ፡ ምስለ፡ ፍቁሮሙ፡ <space reason="owner"/> ለዓለመ፡ ዓለም፡ አሜን፨
                                    </explicit>
                                </msItem>                                
                            </msItem>
                            
                            <msItem xml:id="ms_i3">
                                <locus from="55r" to="63v"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2387Taamme">Taʾammǝra Rufāʾel</title>
                                <note>This is another collection of miracles of Raphael, to be read on the 3rd of Ṗagʷǝmen</note>
                                <textLang mainLang="gez"/>                                
                                <msItem xml:id="ms_i3.1">
                                    <locus from="55r" to="56v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7167MRHealing">On Raphael's power to heal the sick</title>
                                    <incipit xml:lang="gez">
                                        ፩ ተአምሪሁ፡ ለሊቀ፡ መላእክት፡ ዓቢይ፡ ክቡር፡ ሩፋኤል፡ ዘይትነበብ፡ አመ፡ ፫ለጳጕሜን፨ ትንብል<supplied reason="omitted">ና</supplied>ሁ፡ 
                                        <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ዘከመ፡ <sic>ይፈውሶሙ፡</sic> ለድውያን፨ ወያጥዕዮሙ፡ ለሕሙማን፡ ውእቱ፡ 
                                        ሩፋኤል<supplied reason="omitted">፡</supplied> መልአክ፡ ፩እምእለ፡ ይተግሁ፡ ቅ<del rend="expunctuated">ሀ</del>ዱሳን፡ <sic>መላእክተ፡</sic>
                                        ርእዮ፡ ወልደ፡ ያሬድ፡ ሄኖክ፨ ወወሀቦ፡ ዕበየ፡ እግዚአብሔር፡ እንዘ፡ ይበውእ፡ ወይወጽእ፡ እምቤቱ፡ ለልዑል፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ዝውእቱ፡ ሩፋኤል<supplied reason="omitted">፡</supplied> ዘዲበ፡ ሕማም፡ ወቍስል፡ ዘ<del rend="expunctuated">ይ</del><surplus>ት</surplus>ፈትኖ፡ 
                                        ከመ፡ ይፈውሶሙ፤ ለነፍሳተ፡  <choice><sic>እሉ፡</sic><corr resp="bm:GrebTiss1935Codices">እለ፡</corr></choice> ቈስሉ፤ በኃጢአት፡ 
                                        ወቍሰለ፡ ሥጋኒ፡ እለ፡ ቈስሉ፤ በደዌ፡ ትንብልናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.2">
                                    <locus from="56v" to="60r"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7162MRTheophilus">How the patriarch Tewoflos remained buried for three days</title>
                                    <incipit xml:lang="gez">
                                        ፪ ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወሀሎ፡ ፩ብእሲ፡ ኄር፡ ሊቀ፡ <sic>ጳጳስ፡</sic> ዘስሙ፡ ቴዎፍሎስ፨ 
                                        ዘተወድየ፡ ውስተ፡ ሣፁን፡ <choice><sic>ወደፈነኒ፡</sic><corr resp="bm:GrebTiss1935Codices">ወደፈኑኒ፡</corr></choice> ከመ፡ መቃብር፨ 
                                        <choice><sic>ውነበርኩ፡</sic><corr resp="bm:GrebTiss1935Codices">ወነበርኩ፡</corr></choice> ውስተ፡ ልበ፡ ምድር፡ ሠሉሰ፡ መዋዕለ፨ 
                                        ወሠሉሰ፡ ለያልየ፨ ወአመ፡ ራብዕት፡ ዕለት፡ ነዋ፡ አስተርአየኒ፡ ጽሚተ፨ ሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied> ወመጽአ፡ 
                                        ኀቤየ፡ እንዘ፡ ሀሎኩ፡ ውስተ፡ ሣፁን፡ ኀበ፡ ወደዩኒ፡ ወደፈኑኒ፡ ከመ፡ መቃብር፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        አነ፤ ውእቱ፡ ዘአብጻሕኩከ፡ እስከ፡ ዝየ፡ <sic>በደኅና፡</sic> ወበሰላም፨ ወባላሕኩከ፡ እምአኅጕሎተ፡ ዓርዌ፨ ዘይመስጥ፡ ተመን፡ ዕኩይ፡ ዘሀሎ፡ ውስተ፡ ባሕር፨ 
                                        <choice><sic>ጼሕከ፡</sic><corr resp="bm:GrebTiss1935Codices">ጼሕኩ፡</corr></choice> ፍኖተከ፡ በከመ፡ አበዊከ፡ ቀደምት፨ ወዘንተ፡ ብሂሎ፡
                                        ሊቀ፡ መላእክት፡ ተኃብአ፡ እምኔሁ፡ ትን<surplus>ት</surplus>ብልናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.3">
                                    <locus from="60r" to="60v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7163MRKidnapping">On a boy who was snatched away by a wild animal</title>
                                    <incipit xml:lang="gez">
                                        ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወሀሎ<supplied reason="omitted">፡</supplied> ፩ሕፃን፡ ውስተ፡ ቤተ፡ 
                                        ክርስቲያኑ፡ ለሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied> ወበአሐቲ፡ ዕለት፡ 
                                        <choice><sic>ወጽአ፡</sic><corr resp="bm:GrebTiss1935Codices">መጽአ፡</corr></choice> አርዌ፡ በአር<supplied reason="omitted">አ</supplied>ያ፡
                                        ነጌ፨ ውእቱ፡ <sic>ኅርማዝ፡</sic> ወነዊህ፨ ክሳዱ፡ ከመ፡ ክሣደ፡ ገመል፨ ወመሰጦ፡ ለሕፃን፡ በማእከለ፡ እድ፨ ወሕዝብ፡ እለ፡ <sic>ሀለው፡</sic> 
                                        ጉቡዓን፡ ውስተ፡ <sic>ገብዋቲሃ፡</sic> ለቤተ፡ ክርስቲያን፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        እሙሰ፡ ለሕፃን፡ ኢ<del rend="erasure">ያ</del>እመረት፡ እምከመ፡ መሠጦ፡ አርዌ፡ ለወልዳ፨ ወሶበ፡ ርእየቶ፡ አእመረቶ፡ ወጠየቀቶ፨ ውእቱ፡ አሚረ፡ 
                                        ተፈስሐት፡ ፈድፋደ፨ ወስብሐቶ፡ ለእግዚአብሔር፨ ወወደሰቶ፡ ለሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied> ዘአድኃኖ፡ ለወልዳ፡
                                        እምነ፡ አርዌ፡ ጸዋጋ፡ ትንብል<surplus>ል</surplus>ናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.4">
                                    <locus from="60v" to="61r"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7164MRWhale">On a king attacked by a sea monster</title>
                                    <incipit xml:lang="gez">
                                        ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወበአሐቲ፡ ዕለት፡ እንዘ፡ ሀሎ፡ ንጉሥ፡ ቀዊሞ፡ ውስተ፡ ሐይቅ፡ ባሕር። 
                                        <sic>መጽአ፡</sic> አንበሪ፡ ከመ፡ ይምስጦ፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ውእቱኒ፡ ፈቀደ፡ ከመ፡ ይሕንጽ፡ ቤተ፡ ክርስቲያነ፨ ወሐነጸ፡ በስሙ፡ ለሊቀ፡ መላእክት፡ ሩፋኤል፡ መልአከ፡ ሣህል፡ 
                                        ት<add place="inline">ን</add>ብል<supplied reason="omitted">ና</supplied>ሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.5">
                                    <locus from="61r" to="62r"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7165MRThief">On treasures hidden in a church</title>
                                    <incipit xml:lang="gez">
                                        ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወበአሐቲ፡ ዕለት፡ <sic>መጽኡ፡</sic> ሰብአ፡ ቍዝ፨ ሶበ፡ ሰምዑ፡ ዜና፡ ይእቲ፡
                                        ቤተ፡ ክርስቲያን፨ ወብዙኅ፡ መዛግብት፡ ዝጉብ፡ ውስቴታ፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ወይእዜኒ፡ ተገኃሡ፡ ኀበ፡ ተግባርክሙ፨ ወሑሩ፡ ኀበ፡ ፍናዊክሙ፨ ወዘንተ፡ ብሂሎ፡ ተሠወረ፡ መልአክ፡ <surplus>፩</surplus> እምኔሆሙ፡ 
                                        ትንብልናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.6">
                                    <locus from="62r" to="62v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7166MRDeacon">Miracle of Raphael: Of a deacon thrown into the sea</title>
                                    <incipit xml:lang="gez">
                                        ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወሀሎ፡ ፩ ብእሲ፡ <sic>ዲያቆን።</sic> ኄር፡ ዘይነብር፡ እንዘ፡ 
                                        ያነ<surplus>፡</surplus>ብብ፡ መጽሐፈ፡ ቀለምሲስ፨ ወአስተዋደየቶ፡ ብርክልያ፨ ከመ፡ ይወር<supplied reason="omitted">ው</supplied>ዎ፡ ውስተ፡ 
                                        ባሕር፡ ለውእቱ፡ ዲያቆን፨
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ወአወፈዮ፡ ኅብስተ፡ ወማየ፡ ወኢሰሰለ፡ ሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied> እምኔሁ፡ እንዘ፡ ያርእዮ፡ ኂሩቶ፤ ወሠናይቶ፡ 
                                        ትንብልናሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                
                                <msItem xml:id="ms_i3.7">
                                    <locus from="62v" to="63v"/>
                                    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7169MRChurch">Miracle of Raphael: On the construction of the church of St Raphael</title>
                                    <incipit xml:lang="gez">
                                        ተአምሪሁ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ስምዑ፡ አበውየ፡ ወአኃውየ፨ ፍቁራንየ፡ ዜና፡ <sic>ዕፀብ</sic> 
                                        ወመድምመ፡ ዘገብረ፡ ሊቀ፡ መላእክት፡ ሩፋኤል<supplied reason="omitted">፡</supplied> <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                        አስተናስኦሙ፡ መንፈስ፡ ቅዱስ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ከመ፡ ይሕንፁ፡ በስሙ፡ 
                                        <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ቤተ፡
                                    </incipit>
                                    <explicit xml:lang="gez">
                                        ውእቱ፡ ዕፅ፡ ዘተመትረ፡ ለዓምድ፡ ወእምአበየ፡ <choice><sic>ተአምረሁ፡</sic><corr resp="bm:GrebTiss1935Codices">ተአምሪሁ፡</corr></choice>
                                        ለመልአክ፡ ክቡር፡ ሩፋኤል፡ ሊቀ፡ መላእክት፡ ብዙኅ፡ ውእቱ፡ ተአምሪሁ፡ ዘገብሮ፡ በእዴሁ፡ ለነኒ፡ ይክድነነ፡ ታሕተ፡ ክነፊሁ፨ 
                                        ጸሎቱ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    </explicit>
                                </msItem>                                
                            </msItem>
                            
                            <msItem xml:id="ms_i4">
                                <locus from="64v" to="65v"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7215HistoryRuf">History of the consecration of the church of Raphael on an island near Alexandria</title>                                
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                    በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> አመ፡ ፫ <sic>ለጳጉሜን፡</sic> በዛቲ፡ ዕለት፡ ኮነ፡ ተዝካሩ፡ ለመልአክ፡ ክቡር፡ 
                                    ሩፋኤል<supplied reason="omitted">፡</supplied> ሊቀ፡ መላእክት፨  ወዝንቱ፡ ሣልሳይ፡ እምሊቃነ፡ መላእክት፡ ትጉሃን፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i5">
                                <locus from="65v" to="69r"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT7216HistoryJCRuf">History of how John Chrysostom visited the church of Raphael on an island</title>                          
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                    ዜና፡ ዘንተ፡ <sic>ዘተነገረ፡</sic> አባ፡ ዮሐስን፡ ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ ቍስጥንጥንያ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i6">
                                <locus target="#69r"/>
                                <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT6633SalRufMastafessehe"><foreign xml:lang="gez">Salām</foreign>-hymn to Raphael</title>
                                <textLang mainLang="gez"/>

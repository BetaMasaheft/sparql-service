                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="145v">1r-145v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0049IHA#s38IHA">قران, First half (ǧuz’ 1-15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم الم ذلك الكتب لا ريب فيه هدى للمتقين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#145v">-145v</locus>ولم يكن له شريك في الملك ولم يكن له ولي من الذل وكبره تكبيرا</explicit>
                     <note>Contains sūras 2-17. Words divided into two lines. Vocalized.</note>
                     <note/>
                  </msItem>
               </msContents>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">[The beginning of the text is lost.]</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለጕርዔከ፡ ወለክሳድከ፡ ምጡቅ፨</l>
                  <l n="2">በንብረ፡ አሐዱ፡ መልክእ፡ እስመ፡ ከመ፡ መልአክ፡ ረቂቅ፨</l>
                  <l n="3">ዘወልደ፡ ማርያም፡ ዜናዊ፡ መምህረ፡ የዋሃን፡ ደቂቅ፨</l>
                  <l n="4">ታሰግድ፡ በጸሎትከ፡ አራዊተ፡ ገዳም፡ ርኁቅ፨</l>
                  <l n="5">ወአናብስተ፡ ትጼዐን፡ በጽድቅ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለመትከፍትከ፡ አነዳ፡ ዘተዐጽፈ፨</l>
                  <l n="2">ወለዘባንከ፡ ሰላም፡ በአምሳለ፡ ክርስቶስ፡ ተቀሥፈ፨</l>
                  <l n="3">ዘወልደ፡ ማርያም፡ መጥምቅ፡ ከመ፡ ዮሐንስ፡ አእላፈ፨</l>
                  <l n="4">ግድፍ፡ ሐሜለተከ፡ በዘኮንከነ፡ ሐዳፈ፨</l>
                  <l n="5">ከመ፡ ሐሜለቶ፡ ኤልያስ፡ ለኤልሳዕ፡ ገደፈ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለሰኰናከ፡ በፍኖተ፡ ወንጌል፡ ረዋጺ፨</l>
                  <l n="2">ወለመከየድከ፡ ሰላም፡ ድውያነ፡ ሥጋ፡ ሐዋጺ፨</l>
                  <l n="3">ዘወልደ፡ ማርያም፡ ለቤተ፡ ክርስቲያን፡ ተሐነጺ፨</l>
                  <l n="4">ወኢይግድፍ፡ አናቅጸኪ፡ ነፋሰ፡ ልዮን፡ ዐማፂ፨</l>
                  <l n="5">ወነፋሰ፡ ምክሩ፡ ለልዮን፡ ገሣጼ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለቆምከ፡ ዘነዊኅ፡ አካሉ፨</l>
                  <l n="2">ዓዲ፡ ሰላም፡ ለመልክእከ፡ ኵሉ፨</l>
                  <l n="3">ለኀረገ፡ ወይን፡ ተክለ፡ አልፋ፡ ዘወልደ፡ ማርያም፡ አስካሉ፨</l>
                  <l n="4">አባ፡ አባ፡ ለውሉደ፡ ጸጋከ፡ እሉ፨</l>
                  <l n="5">እንበለ፡ ተፈልጦ፡ ኅቡረ፡ ምስሌሆሙ፡ ሀሉ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ህየንተ፡ ጸሪቅ፡ ዘነፍስ፡ መበለት፡ አጽደቀ፨</l>
                  <l n="2">እንበለ፡ ትሁብ፡ ሰላመ፡ አምኃ፡ ሰላምከ፡ ወርቀ፨</l>
                  <l n="3">ዘወልደ፡ ማርያም፡ ተወከፍ፡ እንዘ፡ ኢትጐነዲ፡ ጥቀ፨</l>
                  <l n="4">ክርስቶስኒ፡ እንበለ፡ ኢይበል፡ ሕቀ፨</l>
                  <l n="5">እምእደ፡ መበለት፡ ተወክፈ፡ ወነሥአ፡ ጸሪቀ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ኦዘትትዐጸፍ፡ ብሉየ፡ አነዳ፨</l>
                  <l n="2">በከመ፡ ቀዳሚ፡ ተዐጽፈ፡ ክርስቶስ፡ ከለሜዳ፨</l>
                  <l n="3">ዘወልደ፡ ማርያም፡ አብርሃም፡ ተወካፌ፡ ምጽዋት፡ እንግዳ፨</l>
                  <l n="4">አዝናም፡ መና፡ ሩጸት፡ በአምሳለ፡ ወይጠል፡ ተቅዳ፨</l>
                  <l n="5">ለእግረ፡ መጻጕዕ፡ ብንያም፡ ወሐንካስ፡ ይሁዳ፨</l>
               </lg>
            </div>
         </div>
      </body>

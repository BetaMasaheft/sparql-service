                                    <locus from="2r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura#Psalms">Mazmura Dǝngǝl: : Psalms</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                            
                            
                            <msItem xml:id="ms_i1.1.3">
                                <locus from="121r"/>
                                <title type="complete">Prayers</title>
                                <textLang mainLang="gez"/>
                                
                                    <msItem xml:id="ms_i1.1.3.1">
                                        <locus from="121r"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2248salota">Ṣalota ʾakkʷatet za-Bāsǝlyos</title>
                                        <textLang mainLang="gez"/>
                                        <incipit xml:lang="gez">ጸሎተ፡ አኰቴት። ነአኵቶ፡ ለገባሬ፡ ሠናያት፡ ላዕሌነ፡ እግዚአብሔር፡ መሓሪ፡</incipit>
                                    </msItem>
                                    
                                    <msItem xml:id="ms_i1.1.3.2">
                                        <locus from="121v"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT5851Prayer">Naʾakkʷǝtaka ʾǝgziʾo wa-nǝsebbǝḥaka</title>
                                        <textLang mainLang="gez"/>
                                        <incipit xml:lang="gez">ነአኵተከ፡ እግዚኦ፡ ወንሴብሐከ፡ ንባርከከ፡ እግዚኦ፡ ወንትአመነከ።</incipit>
                                    </msItem>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.4">
                                    <locus from="122r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura#Canticles">Mazmura Dǝngǝl: t:div Canticles</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.5">
                                    <locus from="135v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura#SongOfSongs">Mazmura Dǝngǝl: t:div SongOfSongs</title>
                                    <incipit xml:lang="gez">ጸሎተ፡ አኰቴት። ነአኵቶ፡ ለገባሬ፡ ሠናያት፡ ላዕሌነ፡ እግዚአብሔር፡ መሓሪ፡</incipit>

               <msPart xml:id="p2">
                  <msIdentifier>
                     <idno/>
                  </msIdentifier>
                  <msContents>
                     <msItem xml:id="p2_i1">
                        <locus from="109ra" to="109rb" facs="0133"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT4292Salam">Malkǝʾ-hymn to the martyrs</title>
                        <incipit xml:lang="gez">ሰላም፡ ለክሙ፡ ሰማዕታተ፡ ክርስቶስ፡ ኬንያ። ዘዘዚአሁ፡ አርአያ፡ ዘተኰነንክሙ፡ በአንጾክያ፡ በግብጽ፡ ወበሮምያ፨</incipit>
                        <explicit xml:lang="gez">ዘተቀጸልክሙ፡ በእደ፡ ሱራፊ<supplied reason="omitted">ል</supplied>፡ ሰርጐ፡ ወርቅ፡ አ</explicit>
                        <note>The end is missing.</note>
                     </msItem>
                     <msItem xml:id="p2_i2">
                        <locus from="109va" facs="0134"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4293Salam">Malkǝʾ-hymn to the martyr Baʾǝda Mikāʾel</title>
                        <incipit xml:lang="gez">በእደ፡ ሚካኤል፡ ነሣእከ፡ አስኬማ። 
                              <sic>አንተ፡</sic>
                            ስርጉት፡ በግርማ፡</incipit>
                        <explicit xml:lang="gez">ሴጠ፡ ደመ፡ ስምእከ፡ እምድር፡ <supplied reason="omitted">ወ</supplied>እምሰማይ፡ ሀሎ፡ ይርፍቁ፡ 
                              <sic>እሊያ፡</sic>
                            
                           ይቤሎ፨ = ፨</explicit>
                     </msItem>
                     <msItem xml:id="p2_i3">
                        <locus from="110r" facs="0134"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4294Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                        <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ እክል። ሰላም፡ ለኪ። 
                              <sic>መጽንኤተ፡</sic>
                            ባኅል፡</incipit>
                        <explicit xml:lang="gez">ሰላም፡ ለኪ፡ አክሊልኪ፡ ቤዘ፡ 
                              <sic>ጽብሕ።</sic>
                            ሰላም፡ ለኪ፡ ደመና፡ ዝናም፡ 
                              <sic>ንጸሕት።</sic>
                           
                        </explicit>
                     </msItem>
                     <msItem xml:id="p2_i4">
                        <locus from="110v" facs="0135"/>
                        <title type="incomplete">Malkǝʾ-hymn to the martyrs</title>
                        
                        <note>The beginning is missing.</note>
                        <incipit xml:lang="gez">ሰበ፡ ሃላፌ፨ ሰላም፡ ለክሙ፡ እማየ፡ መአት፡ ብዙኅ፡ ዘአልቦ፡ ወሰነ፡</incipit>
                     </msItem>
                     <msItem xml:id="p2_i5">
                        <locus from="110v" facs="0135"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4295Salam">Malkǝʾ-hymn to the Paraclete</title>
                        <incipit xml:lang="gez">ሰላም፡ ለኅዝብከ፡ ዘእምሀቤከ፡ 
                              <sic>ይደሉ፡</sic>
                            መንፈሰ፡ አብ፡ ወቃሉ፡ ጰራቅሊጦስ፡ 
                              <sic>ማኅያዌ፡</sic>
                            ኵሉ።</incipit>
                        <explicit xml:lang="gez">ሰላም፡ ለከ። በከመ፡ ሜጥከ፡ ይኩን፡ ለኅብስተ፡ ስርናይ፡ ወወይን፡ ሥጋ፡ በግዑ፡ 
                              <sic>ዘለቁርባን።</sic>
                            እምኢያእምሮ፡ ውስተ፡ አእምሮ፡ አማን፡ ይሚጠነ፡ ኀይልከ፡ ብርሃን።</explicit>
                     </msItem>
                  </msContents>

               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="181v" facs="001">Fols 1r–181v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                     <msItem xml:id="ms_i1.1">
                       <locus from="1r" to="141r" facs="001">Fols 1r–141r</locus>
                       <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                       <note>starts with Psalm 3</note>
                       <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                       <locus from="141r" to="156r" facs="141">Fols 141r–156r</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                       <locus from="156r" to="165v" facs="156">Fols 156r–165v</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                       <locus from="166r" to="176v" facs="166">Fols 166r–176v</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     </msItem>

                     <msItem xml:id="ms_i1.5">
                       <locus from="177r" to="181v" facs="177">Fols 177r–181v</locus>
                       <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                     </msItem>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">181</measure>
                           <dimensions type="outer" unit="mm">
                              <height>171</height>
                              <width>164</width>
                              <depth>75</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Most of the original binding for Marwick codex 37 has been removed or is worn and broken. The codex has been rebound with the ubiquitous use of the stab stitch. The resultant state makes quire analysis impossible.</note>
                          <note>Navigation system: blue yarn is sewn into the fore edge of <locus target="#113 #123" facs="113 123">fols. 113, 123</locus> to mark content.</note>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">25</dim>
                              <dim type="bottom">32</dim>
                              <dim type="right">26</dim>
                              <dim type="left">15</dim>
                           </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="17 19">
                           <locus from="1r" to="165v" facs="001">Fols 1r–165v</locus>
                       </layout>
                       <layout columns="2" writtenLines="17 19">
                           <locus from="166r" to="181v" facs="166">Fols 166r–181v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  <note>The word God is not rubricated in the first three works of the Psalter</note>
                  </seg>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#156r" facs="156">fols. 156r, </locus> (a line of alternating red and black dots);
                      <locus target="#165v" facs="166">165v, </locus> (lines of full stops, alternating red and black dots, and red ink);
                      <locus target="#177r" facs="177">177r</locus> (lines of red and black dots)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="a1">
                      <desc type="OwnershipNote">
                      <locus target="#165r" facs="165">Fol. 165r</locus>, fore edge margin: Note of ownership, names erased
                      </desc>
                      </item>
                      <item xml:id="e1">
                        <locus target="#173v" facs="174">Fol. 173v</locus>
                        <desc>words of text are written interlinearly</desc>
                        </item>
                      <item xml:id="e2">
                        <locus target="#87r" facs="087">Fol. 87r</locus>
                        <desc>and lines of text are written interlinearly</desc>
                        </item>
                      <item xml:id="e3">
                        <locus target="#124r #150r" facs="124 150">Fols. 124r, 150r</locus>
                        <desc>, e.g., text has been removed</desc>
                      </item>
                      <item xml:id="e4">
                        <locus target="#149r" facs="149">Fol. 149r</locus>
                      <desc>e.g., this scribe has avoided the problem of lines of text too long to fit on one line by adopting an aspect ratio that leaves ample room for the
                      width of most lines. On a few occasions, the line would have been too long and the scribe finishes the end of the line with words written smaller
                      so as to avoid leftover text
                      </desc>
                      </item>
                      <item xml:id="e5">
                        <locus target="#124r #133v" facs="124 134">Fols. 124r, 133v</locus>
                        <desc>e.g., occasionally a line is still too long and has to be completed above or below the end of the line</desc>
                      </item>

                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                        <decoNote xml:id="b1">Parchment, 171 x 164 x 75 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1750" notAfter="1799">late-eighteenth century</origDate>
                  </origin>
               </history>
            </msDesc>

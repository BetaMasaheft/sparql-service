                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                  <foreign xml:lang="gez">ዮሐንስ</foreign>
                  </seg>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1039Magi">The Three Magi</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d5"><locus target="#41r" facs="043">Fol. 41r</locus><desc>A saint holding the arm of <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d6"><locus target="#41v" facs="044">Fol. 41v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John stand beside the cross</desc></decoNote>
                  <decoNote type="miniature" xml:id="d7"><locus target="#101r" facs="103">Fol. 101r</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> holding books</desc></decoNote>
                  <decoNote type="miniature" xml:id="d8"><locus target="#101v" facs="104">Fol. 101v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1010Entombment">Entombment of Jesus</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d9"><locus target="#102r" facs="104">Fol. 102r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                  <decoNote type="miniature" xml:id="d10"><locus target="#102v" facs="105">Fol. 102v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/> flanked by leopards and tigers</desc></decoNote>
                  <decoNote type="frame" xml:id="d11">
                  Decorative designs:
                  <locus target="#47r #78r #97r" facs="049 080 099">folss. 47r, 78r, 97r, </locus> (multiple full stops and lines of alternating red and black dots);
                  <locus target="#88v #100v" facs="091 103">88v, 100v</locus> (line of alternating red and black dots)
                  </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc type="OwnershipNote">
                    <locus target="#77v" facs="080"> f. 77v and passim</locus>
                    mention the owners Hǝlawe Krǝstos (<foreign xml:lang="gez">ህላዌ፡ ክርስቶስ፡</foreign>) and Qǝrbǝtä Krǝstos (<foreign xml:lang="gez">ቅርብተ፡ ክርስቶስ፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="OwnershipNote">
                    <locus target="#78r" facs="080">Fol. 78r</locus>
                    secondary owner is mentioned, Ḫaylä Giyorgis (ኃይለ፡ ጊዮርጊስ፡)
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="OwnershipNote">
                    <locus target="#100v" facs="103">Fol. 100v</locus>
                    mentions the owners Hǝlawe Krǝstos (<foreign xml:lang="gez">ህላዌ፡ ክርስቶስ፡</foreign>) and Qǝrbǝtä Krǝstos (<foreign xml:lang="gez">ቅርብተ፡ ክርስቶስ፡</foreign>) and ʿhis fatherʾ Tǝrsitä Wäld (<foreign xml:lang="gez">ትርሲተ፡ ወልድ፡</foreign>; presumably, the father of Hǝlawe Krǝstos)
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Red paper strip with number 12 inside
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#1 #25 #47 #97 #100" facs="003 027 049 099 102">Fols. 1, 25, 47, 97, 100</locus>
                    red fabric stitched into the fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                      words of text are written interlinearly (<locus target="#10v #24r #24v #27v #88r" facs="013 026 027 030 090">folss. 10v, 24r, 24v, 27v, 88r, </locus>);
                      text has been removed (<locus target="#1r #6r #7v #9r #12v" facs="003 008 010 011 015">1r, 6r, 7v, 9r, 12v</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
               </physDesc>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="11v">1r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT3351IHA">علم المنطق الحديث والقديمعلى النظام الصحيح والنظم
                    القويم</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>وحدد من بنى الانسان ه هو سقراط !! مع ان سؤاليه (من هو المؤمن من هو الكافر) بل بقية أسئلته تدل بلا مرية على سبق من دعا الناس الى الاىمان وترك الكفر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>صحيفة ١٠٠ من هذا الكتاب : فلم يفت الاقدمين الالمام به كما زعموه . أجل . فاتهم هم تطبيق نظريتهم وادراك رمزهم . فقالوا في حقهم ما قالوا 
هدان الله جميعا لما فيه السداد ، وسلك بنا سبيل الرشاد حسبنا الله وكفى وسلام على عباده الذي اصطفى </explicit>
                     <note>The manuscript contains excerpts from the text.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="40">p. 1-40</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3355IHA">ايضاح المبهم من معاني السلم في المنطق</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>
                        <listBibl type="secondary">

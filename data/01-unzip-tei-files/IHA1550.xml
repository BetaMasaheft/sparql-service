                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/MYV2E78S"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook738"/><title level="m">Īḍāḥ al-mubham min maʻānī al-Sullam fī al-manṭiq - wa yalīhi šarḥ al-ʻallāmā al-Aḫḍarī ʻalā Sullamihi al-maḏkūr</title><author><name>al-Damhanūrī, Aḥmad</name></author><author><name>al-Aḫḍarī</name></author><pubPlace>al-Qāhira</pubPlace><publisher>al-Maṭbaʻa al-Maymaniyya - Muṣṭafā al-Bābī al-Ḥalabī wa aḫawayhi Bakrī wa ʻĪsā</publisher><date>1324</date><note type="tags"><note type="tag">bm:IHABook738</note></note><note type="tag">bm:IHABook738</note></bibl>

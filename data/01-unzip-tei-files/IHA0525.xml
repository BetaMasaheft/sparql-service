               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="6r">1v-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1162IHA">خطبة المولد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين وأفضل الصلاة والتسليم على النبى الكريم [...] وبعد فان أفضل العبادات اجتناب المنهيات وخصوصا حال التلبس فى الطاعات فان خلط المنكرات فى الطاعات من شيم المنافقين [...] خصوصا فى حال الاجتماعات كالمواليد ومجالس العلم والذكر والدعوات وسياتى قريبا التنبيه عليه بكلمات قليلات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>هناك ما هو اغرب مما لو شرع فى ذكره ذاكر غرق واغترب كما اشاروا لذلك فى بعض مواليدهم وستاتى الاشارات الى ذلك فى هذه الكلمات الاتية ان شاء الله تعالى والحمد لله اولا و ءاخرا وصلى الله على خير الورى و على ءاله وصحبه الكبرى وعلى اتباعه فى الدنيا والاخرى آمين وسلام على المرسلين والحمد لله رب العالمين ولا حول ولا قوة الى بالله العلى العظيم تمت</explicit>
                     <note>Words divided into two lines.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6v" to="54r">6v-54r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0173IHA">مختصر الحلية لمن في المختصرات بغية</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v-7r">-6v-7r</locus>بسم الله الرحمن الرحيم \ الحمد لله الكريم المنان الذي أبرز الاكوان من نور سيد الانس والجان والصلاة والسلام الاكملان على أسعد الخلق سيدنا وسيد ولد عدنان</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53v-54r">-53v-54r</locus>صلى الله وسلم عليه وعليهم وعلينا معهم أجمعين امين وسلام على المرسلين والحمد لله رب العلمين سبحان ربك رب العزت عما يصفون وسلام على المرسلين والحمد لله رب العالمين ا م ن</explicit>
                     <note>Vocalized, except for the title information on f. 12v.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="56v" to="56v">56v-56v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1164IHA">دعاء اللهم انى اسألك بذاتك</title>
                     <incipit xml:lang="ar">
                        <locus target="#56v">-56v</locus>اللهم انى اسئلك بذاتك العليه وصفاتك السيه ان تصلى وسلم على سيدنا محمد وعلى آل محمد وان ترضى شيخنا ومشايخهم واهل بيتهم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#56v">-56v</locus>ويختم لهم الشيخ والمقدم فالمفتح بقوله برحمتك يا ارحم الراحمين والحمد لله رب العالمين للهم صل وسلم على سيدنا م جمد سبحان ربك</explicit>
                     <note>Loose folio.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="57v" to="56r">57v-56r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1166IHA">تلقين الميت</title>
                     <incipit xml:lang="ar">
                        <locus target="#57v">-57v</locus>انت وحدك لا شريك لك وءن محمد عبدك ورسولك اربعا ثم الاول الصبح فهى [استغفر] الله العظيم الذى لا ءله الا هو الحي القيوم وءتوب اليه عشر مرات لا ءله الا الله وحده</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#56r">-56r</locus>وان محمد عبدك ورسولك اربعا ثم اللهم ما ء صبح من نعمة او باحد من خلقك فمنك وحدك لا شريك لك ولك الحمد ولك الشكر <note>The text starting from the first "/" is an addition and it is written with a blue ball-point pen.</note>
                     </explicit>
                     <note>Consists of two loose folios. The text begins on fol. 57v and ends on fol. 56r. The colophon is an addition written with a blue ball-point pen.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="58r" to="59v">58r-59v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1167IHA">مصطلح الحديث</title>
                     <incipit xml:lang="ar">
                        <locus target="#58r">-58r</locus>تنبيه دارت الفاظ بين المحدثين ينبغي الوقوف على معانيها وهي الحديث والخبر والاثر والسنة والمتن والسند والاسناد والمسند بفتح النون والمسند بكسرها والمحدث والحافظ والحجة والحاكم والحديث </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#59v">-59v</locus>قال الزركشي فى النكت ادخال المقطوع فى انواع الحديث فيه تسامح كبير فان اقوال التابعين ومذهبهم لا مدخل  لها فى الحديث فكيف تكون نوعا منه انتهى وكذا يقال فى الموقوف اه ه ه من مصطلح الحديث</explicit>
                     <note/>
                     <note/>
                  </msItem>

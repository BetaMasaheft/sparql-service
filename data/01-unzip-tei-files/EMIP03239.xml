         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Weiner</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3239/" n="154" corresp="https://betamasaheft.eu/api/iiif/EMIP03239/manifest">Weiner Codex 467</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1"><locus from="3r" to="146v" facs="003">Fols 3r–146v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                    <msItem xml:id="ms_i1.1"><locus from="3r" to="112v" facs="003">Fols 3r–112v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title></msItem>
                  <msItem xml:id="ms_i1.2"><locus from="112v" to="124v" facs="113">Fols 112v–124v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref>, is <q>the Prayer of Hana, mother of Samuel, prophet</q></note>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="124v" to="131r" facs="125">Fols 124v–131r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title><note>common edition</note></msItem>
                  <msItem xml:id="ms_i1.4"><locus from="131v" to="141v" facs="132">Fols 131v–141v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title><note>arranged for the days of the week, laid out beginning on Monday and culminating on Sunday</note></msItem>
                  <msItem xml:id="ms_i1.5"><locus from="141v" to="146v" facs="142">Fols 141v–146v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title></msItem>

                <colophon xml:id="coloph1">
                <locus target="#146v" facs="147"> f. 146v, col. 1, bottom</locus>
                <q>This book belongs to <foreign xml:lang="gez">ወይዘሮ፡ ታፈሰጭ፡ ሰበይቲ፡ ባራባራስ፡ ሀጎስ፡</foreign></q>,
                mentioning her children,  <foreign xml:lang="gez">ደስታ፡ ወለተ ማርያም፡,  ራያ፡ ገብረ፡ ማርያም፡,  ውብነኽ፡ ገብረ፡ ሥላሴ፡</foreign>, her father, <foreign xml:lang="gez">ግራዝማች፡ ፋሪስ፡</foreign>,
                and her brothers, <foreign xml:lang="gez">ግራዝማች፡ አባይ፡</foreign> , and <foreign xml:lang="gez">ልጅ አብ[ር]ሃ፡</foreign>, whose baptismal name is <foreign xml:lang="gez">ገብረ፡ ክርስቶስ፡</foreign>.
                The name of the scribe is mentioned, <foreign xml:lang="gez">አለቃ፡ መሸ፡ ዘየጁ</foreign> (from Yajju),
                baptismal name <foreign xml:lang="gez">ገብረ ማርያም</foreign>, <q>“who deserves two mules,”</q> the payment for the book, from (<foreign xml:lang="gez">ባራባራስ፡) ሀጎስ፡</foreign>
              </colophon>


              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">147</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>
                              <width/>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="24">
                         <locus from="1v" to="131r" facs="002">Fols 1v–131r</locus>
                       </layout>
                       <layout columns="2" writtenLines="24">
                         <locus from="131v" to="147r" facs="132">Fols 131v–147r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <desc><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps148">Psalms of
                                                  David, Psalmus 148</title> and <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps50">Psalms of
                                                  David, Psalmus 50</title> and the tenth biblical canticle employ columetric rubrication of text</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc>Crude drawings</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#147v" facs="148">Fol. 147v</locus><desc>(including an <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with drawn <term key="sword" ana="#sword"/>, drawn in black and red ink)</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1v #2r" facs="002"> f. 1v-2r, top</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT3509Epistle">First Epistle of
                                                  John</title>, written in a different hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#147r" facs="147">Fol. 147r</locus>
                      <desc type="Asmat">
                      Asmat prayer to Archangel Rufa’el for safety in childbirth, <foreign xml:lang="gez">ጸሎት፡ ሶበ፡ ትወልድ፡ ብእሲት፡</foreign>
                      </desc>
                    </item>
                    <item xml:id="e1">
                      <locus target="#1r" facs="001">Fol. 1r</locus>
                      <desc>
                      Despite the label, the Weiner collection number should be 467 and not 464
                      </desc>
                    </item>
                    <item xml:id="e2">
                      <locus target="#Inside front cover" facs="001">Fols. Inside,, </locus>
                      <desc>
                      Note: mirror niche in inside front cover. Mirror intact
                      </desc>
                    </item>
                    <item xml:id="e3">
                      <locus target="#Back cover" facs="148">Fols. Back, </locus>
                      <desc>
                      Colorful cloth is visible between the paste downs of the back cover
                      </desc>
                    </item>
                    <item xml:id="a3">
                      <locus target="#2r" facs="002"> f. 2r, bottom</locus>
                      <desc>
                      Copy of letter, in Amharic, from <foreign xml:lang="am">ከሜቴ፡ ወይዘሮ፡ ታፈሰች፡ ፋሩስ፡ to ለመርጄታ ገብረ ሚካኤል፡</foreign> asking for prayer and (financial?) support
                      </desc>
                    </item>
                    <item xml:id="a4">
                      <locus target="#2r" facs="002"> f. 2r, bottom two lines</locus>
                      <desc type="OwnershipNote">
                      note of secondary ownership, written in a different hand: <foreign xml:lang="gez">ፊታውራሪ፡ ውብነህ</foreign>
                      </desc>
                    </item>
                    <item xml:id="a5">
                      <locus target="#2v" facs="003"> f. 2v, top</locus>
                      <desc>
                      Writing exercise, copying the introductory prayer to the <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</ref> on <locus target="#3r" facs="003">fol. 3r</locus>
                      </desc>
                    </item>
                    <item xml:id="a6">
                      <locus target="#2v" facs="003"> f. 2v, middle</locus>
                      <desc>
                      Scribal note of commencing the writing of a letter for several persons: <foreign xml:lang="gez">ልጅ ውብነህ፡</foreign>, <foreign xml:lang="gez">ግራዝማች፡ አባይ፡</foreign>, and <foreign xml:lang="gez">ፊታውራሪ፡ አብርሃ፡</foreign>
                      </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#2v" facs="003"> f. 2v, bottom</locus>
                      <desc type="Genealogy">
                      Genealogical note about three generations: <foreign xml:lang="gez">ደጃዝማች፡ ኪሮስ፡, ግራዝማች፡ ፋሩስ፡</foreign>, and <foreign xml:lang="gez">ደጃዝማች፡ ደበብ፡</foreign>.  The writer of the note is <foreign xml:lang="gez">ልጅ ነጋሽ.</foreign>
                      </desc>
                    </item>
                    <item xml:id="a8">
                    <locus from="131r" facs="131"> f. 131r, bottom five lines</locus>
                    <locus to="131v" facs="132"/>
                    <desc type="OwnershipNote">
                      Scribal doxology mentioning original owner, <foreign xml:lang="gez">ተክለ ሃይማኖት</foreign>, and his wife, <foreign xml:lang="gez">ወለተ መድኃን</foreign>, his children, <foreign xml:lang="gez">ገብረ ማርያም, ገብረ ሥላሴ, ወለተ ማርያም</foreign>,  his father, <foreign xml:lang="gez">ስይፈ ሚክኤል</foreign>, and his mother, <foreign xml:lang="gez">ትውክልተ ሚካኤል</foreign>, and his brother, <foreign xml:lang="gez">ዛማርያም</foreign>
                    </desc>
                    </item>
                    <item xml:id="a9">
                    <locus target="#146v" facs="147">Fol. 146v</locus>
                    <desc>
                    Scribal comment: <q>Man began, God will finish</q>
                    </desc>
                    </item>
                    <item xml:id="a12">
                    <locus target="#147r" facs="147"> f. 147r, col. 2, last seven lines</locus>
                    <desc>
                    Beginning of a letter from <foreign xml:lang="gez">ወይዘሮ፡ደስታ፡</foreign>
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1850" notAfter="1950">Late-nineteenth/early-twentieth century</origDate>
                  </origin>
               </history>
            </msDesc>
         </sourceDesc>

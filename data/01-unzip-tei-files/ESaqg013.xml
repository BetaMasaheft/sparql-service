                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, but careful.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Middle or second half of the 19th century.</date>
                        <seg type="rubrication">Nomina sacra; incipits and headings of the texts,
                           numbers of the chapter and the word mǝʿrāf; elements of the punctuation
                           signs, chapter dividers and numbers; In the incipit page of the Gospel, a
                           few lines are rubricated (in groups of two lines, alternating with black
                           lines).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#97vb">f. 97vb</locus>
                           <desc>: salām to St Theodore Stratelates.</desc>
                           <quote xml:lang="gez">
                              <locus target="#97vb">97vb</locus>, l.1: ሰላም፡ ለቅዳሴ፡ ቤትካ፡ ቴዎድሮስ፡ ሊቀ፡
                              ሠራዊት፡ ...</quote>
                           <quote xml:lang="en"/>
                           <note> </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#98r">f. 98r</locus>
                           <desc>: Calendaric note on fasting periods (crudely drawn table).</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#98v">f. 98v</locus>
                           <desc>: Magic prayer against the storm and hail.</desc>
                           <quote xml:lang="gez">
                              <locus target="#98v">98v</locus>, l.1: ምድግምያስ፯ጊዜ፡ ዘይጼውዖ፡ ለመብረቅ፡ ዘይፌኑ፡
                              በረዶ፡ ለስሣን፡ አግዮስ፡ መጽአ፡ ሚሎስ፡ ዘያቈሮሮ፡ ወያርዕዶ፡ ወይመውዖ፡ ለዝንቱ፡ በረድ፡ ወለኃይለ፡
                              ነፋሳት፡ ማያት፡ ኤልያስ፡ ዘከመ፡ ለጐመ፡ ሰማየ፡ ከመ፡ ኢይዝንም፡ ዝናም፡ ፫አመተ፡ ወ፮ተ፡ አውራኃ፡ ከማሁ፡
                              አነ፡ ሀተምኩካ፡ ወለጐምኩካ፡ በህተመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ምርምር[ዑ?]ን፡ መጥርትም፡
                              ኢታውርድ፡ በረዶ፡ ዘእንበለ፡ ጽሩይ፡ ማይ።</quote>
                           <quote xml:lang="en"/>
                           <note> </note>
                        </item>
                     </list>
                  </additions>

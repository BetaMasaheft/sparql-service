        <body>       
            <listBibl type="editions">
                <bibl corresp="http://zotero.org/groups/358366/items/E264UBRS"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1983satanique"/><title level="a">Un poème satanique éthiopien</title><title level="m">Guirlande pour Abba Jérome: travaux offerts à Abba Jérôme Gabra Musé par ses élèves et ses amis réunis par Joseph Tubiana</title><author><forename>Stefane</forename><surname>Strelcyn</surname></author><pubPlace>Paris</pubPlace><publisher>Le Mois en Afrique</publisher><date>1983</date><biblScope unit="page">83–115</biblScope><note type="tags"><note type="tag">bm:Strelcyn1983satanique</note></note><note type="tag">bm:Strelcyn1983satanique</note><citedRange unit="page">92-110</citedRange></bibl>
                <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
            <div type="edition" xml:lang="gez">
                <note>Quoted as provided by Augustine Dickinson  <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" subtype="stanza" n="1">
                    <lg><l n="1">ሰላም፡ ለፅንሰትከ፡ ውስተ፡ ከርሠ፡ መካን፡ ኤልሳቤጥ፨</l>
                        <l n="2"> ለመልአከ፡ ዜና፡ ገብርኤል፡ በብስራተ፡ ቃሉ፡ ጽዑጥ፨</l>
                        <l n="3"> በኵረ፡ ቅድሳት፡ ዮሐንስ፡ እንዘ፡ ሕፃን፡ ቅጥቁጥ፨</l>
                        <l n="4">እፎ፡ ተክህልከ፡ አስተብርኮ፡ ለፅንሰ፡ መለኮት፡ ሥሉጥ፨</l>
                        <l n="5">ቅድመ፡ ትፍታሕ፡ ማሕፀነ፡ ወትፃእ፡ እምውስጥ፨</l></lg>
                </div>
                <div type="textpart" subtype="stanza" n="2">
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለልደትከ፡ ስዱሰ፡ ወርኀ፡ ዘቀደሞ፨</l>
                        <l n="2">ለልደተ፡ አምላክ፡ ሕያው፡ እማርያም፡ ጼና፡ አበሞ፨</l>
                        <l n="3">ዮሐንስ፡ ኤልያስ፡ ነቢየ፡ ቅንዓት፡ ወተቃውሞ፨</l>
                        <l n="4">ከመ፡ ይክዐው፡ ውስተ፡ ዓለም፡ ለውዳሴከ፡ ዝናሞ፨</l>
                        <l n="5">ሰማየ፡ ልሳንየ፡ አርኁ፡ ወክልእ፡ ልጓሞ፨</l>
                    </lg>
                </div>
                <div type="textpart" subtype="stanza" n="3">
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሳብእ፡ ውጣኔሁ፨</l>
                        <l n="2">ወሳድስ፡ ፍጻሜሁ፨</l>
                        <l n="3">ቃለ፡ አዋዲ፡ ዮሐንስ፡ ለክርስቶስ፡ ሐዋርያሁ፨</l>
                        <l n="4">ይሰወጥ፡ ውስተ፡ እዝንየ፡ ለመንፈስከ፡ ጽራሁ፨</l>
                        <l n="5">መንግሥተ፡ ሰማይ፡ ቀርበት፡ ዘይቤ፡ ነሥሑ፨</l>
                    </lg>
                    
                </div>
                <div type="textpart" subtype="stanza" n="4">
                    <lg type="stanza" n="4">
                        <l n="1">ሰላም፡ ለሥዕርትከ፡ እለ፡ ኮናሁ፡ አክናፈ፨</l>
                        <l n="2">ለርእስከ፡ በመጥባሕት፡ እንተ፡ ተሰየፈ፨</l>
                        <l n="3">ኮከበ፡ ጽባሕ፡ ዮሐንስ፡ ዘታስተጋውህ፡ አጽናፈ፨</l>
                        <l n="4">ጊዜ፡ ስርቀትከ፡ ክረምተ፡ ኀጢኣት፡ ኀለፈ፨</l>
                        <l n="5">ወጽጌ፡ ጽድቅከ፡ ኵለሄ፡ ሰፈፈ፨</l>
                    </lg>
                    
                    
                </div>

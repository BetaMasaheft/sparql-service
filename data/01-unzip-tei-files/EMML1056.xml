                  <decoDesc>
                     <decoNote xml:id="d1">Diagram of the directions of sunrise and sunset, fol. 5v; Diagram of the fraction of the eucharistic bread, fol. 25v; Diagram of the tabernacle of the covenant, fol. 28r; Table of shadows, fol. 28v-29r; Table of the motions of the sun and moon, fol. 31r; Perpetual calendar for Easter and other important dates, fol. 31v-32r; Perpetual calendar, fol. 32v-34r; Unidentified tables, ffol. 34r; Perpetual calendar for the 532 year cycle, fol. 34v-48r; Tables of the moon phases, fol. 48v-49v; Eusebian canons, fol. 65v-74v
                        
                     </decoNote>
                  </decoDesc>
                  <additions><list><item xml:id="a1">Dated the 13th year of Emperor Iyoʼas, fol. 29v; Calendar calculations, fol. 1r, 2r
                     
                  </item></list></additions>

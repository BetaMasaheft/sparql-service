               <msContents>
                  <summary>Computus, Abušahǝr, አቡሻኽር፡ <term key="Chronography" ana="#Chronography"/></summary>
                  <msItem xml:id="ms_i1">
                     <title>fol. 7r-10v and 3r-4v                 Commentary on Revelation, the Last Supper, and the saying "The heart of a hermit is like a paradise of delight"</title>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <title>fol. 11r-49v	Bāḥra ḥassāb</title>
                     <textLang xml:lang="gez"/>
                     <incipit xml:lang="gez">ናሁ፡ ንጽሕፍ፡ በረድኤተ፡ እግዚአብሔር፡ ዜና፡ አርእስተ፡ ሐሳብ፡ ዘእምፍጥረተ፡ ዓለም፡ እስከ፡ ተፍጻሜተ፡ ዓመተ፡ ዓለም።
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <title>fol. 51r-75r	Introduction to the Gospels</title>
                     <textLang xml:lang="gez"/>
                     <note>Introduction to the four gospels and the ten canons, fol. 51r-60v; Letter of Eusebius to Carpianus, fol. 61rv; Synoptic presentation concerning the agreement of the four Gospels, fol. 62rv; Introduction to Matthew, fol. 62v-63v; Introduction to Mark, fol. 63v-64r; Introduction to Luke, fol. 64rv; Introduction to John, fol. 64v-65v; Eusebian Canons, fol. 65v-74v; Commentary on Gospel passages, fol. 74v-75r
                        
                     </note>
                     <note>Accompanied by margin notation</note>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <title>fol. 75r-91v 	Revelation</title>
                     <note>Accompanied by margin notation</note>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <title>fol. 92r-116r 	1 Ezra</title>
                     <note>Accompanied by margin notation</note>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <title> fol. 116v-146v Faith of the fathers. Selections</title>
                     <note>Introduction to the Haymanota Abaw</note>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <title> fol. 146v-147v Account of the believers and heretics</title>
                     <incipit xml:lang="gez">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ዜና፡ ምእመናን፡ ወዓላውያን። ሰባልዮስ፡ ይቤ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ገጽ።</incipit>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <title> fol. 147v-160v History of the first five ecumenical councils</title>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <title> fol. 161r-162r List of the patriarchs of Alexandria from Saint Mark to Gabriel V</title>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <title> fol. 162r-171v  Commentary on the ordinary of the mass and the anaphoras</title>
                     <textLang xml:lang="am"/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <title> fol. 171v-174r Glossary of Turkish and Arabic words</title>
                     <textLang xml:lang="ar"/>
                  </msItem>
               </msContents>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="189v">2v-189v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>سورة مريم بسم الله الرحمن الرحيم [.؟.] مكية كهيعص ذكر رحمت ربك عبده زكريا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#189v">-189v</locus>الذي يوسوس في صدور الناس من الجنة والناس</explicit>
                     <note>The text contains suras 19-114. Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="189v" to="190r">189v-190r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4124IHA">دعاء ختم القران ربنا تقبل منا انك انت السميع</title>
                     <incipit xml:lang="ar">
                        <locus target="#189v">-189v</locus>صدق الله العلى العظيم وصدق رسوله النبي الكريم ونحن على ذلك من الشاهدين والحمد لله رب العالمين ربنا تقبل منا انك انت السميع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#190r">-190r</locus>وارزقنا الاداء بالتلب واللسان وهب لنا الخيرات والسعادة والشهادة والبشارة من الايمان وصلى الله على خير خلقه سيدنا ومولانا محمد واله وصحبه وسلم تسليما كثيرا برحمتك يا [ارحم] الراحمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

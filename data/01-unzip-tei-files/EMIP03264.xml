               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="151v" facs="002">Fols 2r–151v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="2r" to="120r" facs="002">Fols 2r–120r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Employs the <q>“I am the Lord”</q> system for <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> contains two of the plusses that make up the longer version: <foreign xml:lang="gez">ወአድኃኒ፡</foreign>, and <foreign xml:lang="gez">ልጎልያድ፡</foreign> (no <foreign xml:lang="gez">ርኩሳን፡</foreign>, no longer plus)</note>
                  </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="120r" to="131v" facs="120">Fols 120r–131v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>The fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>“Prayer of Hana, mother of Samuel.”</q></note>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="132r" to="138r" facs="132">Fols 132r–138r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Common edition</note>
                  </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="138r" to="149r" facs="138">Fols 138r–149r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Arranged for the days of the week, beginning with Monday and culminating on Sunday</note>
                  </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="149r" to="151v" facs="149">Fols 149r–151v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
              </msItem>
               </msContents>

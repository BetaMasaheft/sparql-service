         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ለዘወጠንኩ፡ ወልድከ፡ በቃለ፡ በቋዒ፡ ሰላም፨</l>
                  <l n="2">ሰላመ፡ መልክእከ፡ ኣንብብ፡ ዘሥነ፡ መልክኡ፡ አዳም፨</l>
                  <l n="3">አቡየ፡ ዮናስ፡ ወአበ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="4">አብጽሐኒ፡ እስከ፡ እክል፡ ፈጽሞ፡ በረድኤትከ፡ ግሩም፨</l>
                  <l n="5">ውሂበ፡ ዐሥብየ፡ ሥመር፡ በዓለም፡ ዳግም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ከመ፡ ስመ፡ አምላክ፡ ክቡር፨</l>
                  <l n="2">ዘይገብር፡ ኀይለ፡ ውስተ፡ ገጸ፡ የብስ፡ ወባሕር፨</l>
                  <l n="3">ነቢየ፡ ደብረ፡ ሣህል፡ ዮናስ፡ ወዘደብረ፡ ሰላም፡ መምህር፨</l>
                  <l n="4">አመ፡ በዓልከ፡ በዓለ፡ ሰላም፡ ወፍቅር፨</l>
                  <l n="5">ተፈሥሑ፡ ሰማያት፡ ወተኀሤት፡ ምድር፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ በንፍሐተ፡ ቀርን፡ ሠላስ፨</l>
                  <l n="2">አመ፡ ይትነሥኡ፡ ሙውታን፡ በአካለ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="3">ቢጸ፡ ሱራፌል፡ ዮናስ፡ ካህነ፡ አርያም፡ መቅደስ፨</l>
                  <l n="4">አዕዱ፡ ደቂቀከ፡ እምባሕረ፡ ኵነኔ፡ ተጽናስ፨</l>
                  <l n="5">በገነተ፡ ተድላ፡ ይንበሩ፡ በዓለም፡ ሐዳስ፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ለዘሐለየ፡ ወልድከ፡ ጥዑመ፡ ማሕሌት፡ ሠናየ፨</l>
                  <l n="2">በኍልቈ፡ መልክእከ፡ ኵሉ፡ ዘተሠርገወ፡ ዕበየ፨</l>
                  <l n="3">ኀሤተ፡ ሥጋየ፡ ዮናስ፡ ወትፍሥሕተ፡ ኃጥእት፡ ነፍስየ፨</l>
                  <l n="4">በለኒ፡ በሰማያት፡ ክብረ፡ ሰማያዊ፡ አቡየ፨</l>
                  <l n="5">እሁበከ፡ አነ፡ ኢትፍራህ፡ ወልድየ፨</l>
               </lg>
            </div>
         </div>
      </body>

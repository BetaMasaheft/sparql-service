                            <msItem xml:id="ms_i1.8">
                                <locus from="178ra" to="190rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#PrayerIncense">Prayers, mostly prayers of incense (<foreign xml:lang="gez">ṣalota ʿǝṭān</foreign>)</title>
                                
                            <msItem xml:id="ms_i1.8.1">
                                <locus from="178ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Basalam">No item: LIT1960Mashaf, could not check for Basalam</title>
                                <incipit>
                                    <hi rend="rubric">ሰላም፡ እምኀበ፡ <surplus>እምኀበ፡</surplus> እግዚአ</hi>ብሔር፡ አብ፡ ወልደ፡ ዋሕድ፡ 
                                    ዘተፈነወ፡ ወኃደረ፡ ውስተ፡ ማኅፀና፡ <hi rend="rubric">ለማርያም፡</hi> ድንግል፡
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8.2">
                                <locus from="178vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Tawakkafetan">Prayer of incense</title>
                                <incipit>
                                    ተወከፍ፡ እግዚኦ፡ ዕጣነነ፡ በከመ፡ ተወከፍከ፡ ዕጣነ፡ አሮን፡ 
                                    ካህን<hi rend="rubric" rendition="#partialRubric">፨</hi>
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8.3">
                                <locus from="179rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Nesel">Prayer of incense</title>
                                <incipit>
                                    <locus from="179rb" to="179va"/>
                                    ንስእለከ፡ ወናስተበቍዕ፡ ኂሩተ፡ ሠናያቲከ፡ እግዚኦ፡ አምላክነ፡ አኀዜ፡ 
                                    ኵሉ<hi rend="rubric" rendition="#partialRubric">፤</hi> አቡሁ፡ ለእግዚእነ፡ 
                                    ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ከመ፡ ትትወከፍ፡ እምአግብርቲከ፡ ዘንተ፡ ዕጣነ፡ 
                                    ከመ፡ ተወከፍከ፡ ዘመበለት፡ ክል<pb n="179va"/>ኤ፡ ጸራይቀ፡ ወዘአቤል፡
                                    አምሓ<hi rend="rubric" rendition="#partialRubric">፨</hi>
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8.4">
                                <locus from="180va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Neselakka">No item: LIT1960Mashaf, could not check for Neselakka</title>
                                <incipit>
                                    <locus from="180vb"/>
                                    ንስእለከ፡ ወናስተበቍዓከ፡ እግዚኦ፡ አምላክነ፡ በከመ፡ ሠመርከ፡ ቍርባነ፡ አቤል፡ 
                                    ፍቁርከ፡ ወመሥዋዕተ፡ ሄኖክ፡ ወኖኅ፡ ወአብርሃም፡ ወዕጣነ፡ አሮን፡ ወሳሙኤል፡ 
                                    ወዘካርያስ<hi rend="rubric" rendition="#partialRubric">፤</hi>
                                </incipit>
                                <note>
                                    Supplications for <persName ref="https://betamasaheft.eu/PRS5711JohnXVI">John XVI</persName> (1676–1718),
                                    <persName ref="https://betamasaheft.eu/PRS8870Sinoda">Sinodā</persName> (1671–1692), and
                                    <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</persName> (1682–1706).
                                </note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8.5">
                                <locus from="182rv"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Nesebhaka">No item: LIT1960Mashaf, could not check for Nesebhaka</title>
                                <incipit>

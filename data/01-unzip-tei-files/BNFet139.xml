                    <msItem xml:id="ms_i1.3">
                        <locus from="12r"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3963Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ድርሳን፡ ዘቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት። ነገር፡ <sic resp="PRS10747Zotenbe">ዘበእንተ፡</sic>
                        ዮሐንስ፡ ጳጳስ፡ ዘብሔረ፡ ኢትዮጵያ፡ ዘመጽአ፡ እምድኅረ፡
                        አቡነ፡ ይስሐቅ፡ ጳጳስ። ነገር፡ ዘበእንተ፡ ኀይል፡ ወገድል፡ ዘሊቃነ፡ መላእክት፡ ሚካኤል፡ አመ፡ ፲ወ፪፡ ለጥር፡ በበዐሉ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ወኮነ፡ በመዋዕለ፡ አርቃዴዎስ፡ ንጉሥ፡ ወልዱ፡ ለቴዎዶስዮስ፡ ንጉሥ፡ ርቱዐ፡ ሃይማኖት፡ በቍስጥንጥንያ፡
                      በመዋዕለ፡ ሊቀ፡ ጳጳሳት፡ ዝውእቱ፡ ዮሕንስ፡ አፈ፡ ወርቅ። ወሀለወት፡ በውእቱ፡ መዋዕል፡ ብእሲቱ፡ ለአርቃዴዎስ፡ ንጉሥ፡
                      ታፈቅር፡ ንዋየ፡ ወርቅ፡ ወብሩር፡ በኀይል፡ ወበትእግልት፡</incipit>
                        <note>The homily about Yoḥannǝs the Metropolitan of <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</placeName>   
                           who came after Yǝsḥāq, for <date ref="ethiocal:Terr12">12 Ṭǝrr</date>.</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.4">
                        <locus from="13v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3964Homily">በስመ፡
                      <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ድርሳን፡ ዘቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ ዘደረሰ፡ ዮሐንስ፡ ጳጳስ፡ ዘአክሱም፡ ቀዳሚ፡ ለአብያተ፡ ክርስቲያናት፡
                        ዘሚካኤል፡ ወያፈቅርዎ፡ ለሚካኤል፡ ብዙኀ።
                      </title>
                        <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ወበውእቱ፡ ሀገር፡ ሀሎ፡ መኵንን፡ ወርቱዕ፡ ሃይማኖቱ፡ ዘስሙ፡ አስተርናቆስ፡ ዘቂልቅያ፡ ወብእሲቱ፡
                      አፎምያ፡ ወ፪ሆሙ፡ ብዙኀ፡ ያፈቅርዎ። ወአመ፡ ፲ወ፪፡ ለለወርኁ፡ ይገብሩ፡ በዐሎ፡</incipit>
                        <note>Homily by Yoḥannǝs, the bishop of ʾAksum.</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.5">
                        <locus from="19v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3960Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ወኮነ፡ እምድኅረ፡ ዝንቱ፡ <supplied reason="undefined" resp="PRS10747Zotenbe">ነ</supplied>ገር፡ ሀመ፡ ፩፡ ብእሲ፡ ነዳይ፡ ውስተ፡ ውእቱ፡ ብሔር። 
                      ወይጼሊ፡ ወይስእል፡ መዐልተ፡ ወሌሊተ፡ ወይብል፡ ሚካኤል፡ ተሠሃለኒ፡</title>
                        <textLang mainLang="gez"/>
                       <note>Miracle</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.6">
                        <locus from="22v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT7176MiracleMichaelTalason">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ነገር፡ ዘዮሐንስ፡ ጳጳስ።
                      </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ወሀሎ፡ ፩፡ ብእሲ፡ ዐቢይ፡ ውስተ፡ አሐቲ፡ ሀገር፡ ወልቡ፡ ጸዋግ፡ ከመ፡ ፈርኦን።
                      ወአልቦ፡ ላዕሌሁ፡ ጾም፡ ወጸሎት። ወሀሎ፡ ፩፡ ብእሲ፡ ነዳይ፡ ይነብር፡ ጎረ፡ ቤቱ፡ ምስለ፡ ብእሲቱ፡</incipit>
                        <note>Homily by the Metropolitan Yoḥannǝs</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.7">
                        <locus from="26v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3961Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                      ድርሳን፡ አመ፡ ፲ወ፪፡ ለግንቦት፡ ዘደረሰ፡ ሊቀ፡ ጳጳሳት፡ ዘአንጾኪያ፡ በእንተ፡ ሊቀ፡ መላእክት፡ ሚካኤል፡ ወአፍቅሮቱ፡
                      ሰብአ። ቅድስት፡ እስመ፡ ኀበረ፡ በዐለ፡ ሚካኤል፡ በይእቲ፡ ዓመት፡ ምስለ፡ ዕለተ፡ ሰንበት። ወካዕበ፡ ተናገረ፡ በእንተ፡ ማቴዎስ፡
                      ነግድ፡ ብእሲቱ፡ ወውልዱ፤ ዘከመ፡ አምኑ፡ በስእለተ፡ ሚካኤል፡ ሊቀ፡ መላእክት። እስመ፡ ይቤ፡ ዛቲ፡ ድርሳን፡ አመ፡ ፲ወ፪፡
                      ለኅዳር፡ እንዘ፡ ጉቡኣን፡ ሕዝብ፡ በቤተ፡ ክርስቲያን፡ ዘቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ ይገብሩ፡ በዐለ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ስምዖ፡ ለመዘምር፡ ቅዱስ፡ ዳዊት፡ ዘነገረ፡ ኅብረተ፡ ዝንቱ፡ በዐል፡ ዮም፡ ይትፌሣሕ፡</incipit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.8">
                        <locus from="42r"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3966Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ዛቲ፡ መጽሐፍ፡ ዘወጽአት፡ እምኢየሩሳሌም፡ ከመ፡ <supplied resp="PRS10747Zotenbe" reason="undefined">ይትነገር፡</supplied>
                        ዕበዮ፡ ወክብሮ፡ ወሢመቶ፤ ወትፍሥሕቶሙ፡ 
                      ወሕይወቶሙ፡ ለሚካኤል፡ ወለገብርኤል፡ ወለ፬፡ እንስሳ፡ ወለ፳፡ ወአርባዕቱ፡ ካህናተ፡ ሰማይ።</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ዘእምአርም፡ ስብሐት፡ በመንፈስ፡ ፍጹም፡ ሥርዓት፡ ወአቃብያነ፡ ሃይማኖት፡ ዘሕገ፡ አእምሮ፡
                      ብሩሃን፡ ወንጹሓነ፡ ልብ፡</incipit>
                        <note>The homily is divided in two parts,
                        the translation is not the same as in <ref type="mss" corresp="https://betamasaheft.eu/BNFet133#p2_i5">Paris, Bibliothèque nationale de France, BnF Éthiopien 133: Homily on the Archangel Michael by Timothy of Alexandria
          (Ḫǝdār) (in p2_i5)</ref>.</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.9">
                        <locus from="51r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3959Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ድርሳን፡ ዘርቱዓ፡ ሃይማኖት፡ ኤጲፋንዮስ፡ ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ቆጵሮስ። 
                      </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሥሉስ፡ ዘኢይትሌለይ፡  ወዕሩይ፡ ዘኢይሰደቅ፡ ታሉት፡ ዘኢ<gap reason="lost" extent="unknown" resp="PRS10747Zotenbe"/>ድ። ርድአኒ፡ ከመ፡ 
                      እንግር፡ ዕበዮ፡ ለሚካኤል፡ መልአከ፡ ኀይል፡</incipit>
                        <note>Homily by Epiphanius of Cyprus</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.10">
                        <locus from="54r"/>
                        <title type="incomplete">Unidentified miracle of St Michael
                      </title>
                        <textLang mainLang="gez"/>
                        <note>The beginning is missing.</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.11">
                        <locus from="59v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3962Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ድርሳን፡ ዘርቱዓ፡ ሃይማኖት፡ ዘደረሰ፡ በእንተ፡ ብፁዕ፡ ወቅ<supplied reason="undefined" resp="PRS10747Zotenbe">ዱ</supplied>ስ፡ ሚካኤል፡ ሊቀ፡ መላእክት።
                      </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">መፍትው፡ አኀዊነ፡ ንዘከር፡ ዕበየ፡ ዘአብ፡ ወኂሩተ፡ ዘወልድ፡ ወክብረ፡
                      ወዓቅመ፡ ዘመንፈስ፡ ቅዱስ። እስመ፡ በሕብረተ፡ ሥላሴ፡ ተገብረ፡ ኵሉ፡ ፍጥረት፡ ዘበሰማይ፡</incipit>
                        <note>Homily by Rǝtuʿā Hāymānot</note>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.12">
                        <locus from="63v"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3967Homily">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ድርሳን፡ በእንተ፡ ቅዱስ፡ ሚካኤል፡ ሊቀ፡ ሰራዊት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ወይቤ፡ ይደነግፁ፡ ወይቤ፡ እግዚአብሔር፡ ኢታምልኩ፡ ባዕዳነ፡ አማልክተ፡ ዘእንበሌየ፤
                      ወዘእንበለ፡ ሰማዕት፡ ወጻድቃን፡ ወነቢያት፡ ወሐዋርያት፤ ወምድረ፡ ዘሳረርኩ፡ በእዴየ፡ ኵሎ፡ ፍጥረተ፡ ዘፈጠርኩ፡
                      ባሕቲትየ።</incipit>

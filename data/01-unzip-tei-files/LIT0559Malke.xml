      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0559</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለምጽአትክሙ፡ በመንግሥተ፡ አብርሃ፡ ወአጽብሃ፨</l>
                  <l n="2">ወለጉባኤክሙ፡ ሰላም፡ ዘምስለ፡ ብዙኅ፡ አምኃ፨</l>
                  <l n="3">አእላፈ፡ ጻድቃን፡ እለ፡ ተሠርገውክሙ፡ ንጽሐ፨</l>
                  <l n="4">ጸልዩ፡ በእንቲአየ፡ እስመ፡ ኃጢአትየ፡ በዝኀ፨</l>
                  <l n="5">ከመ፡ ይምሐረኒ፡ አምላክክሙ፡ ሰማየ፡ ዘሰፍሐ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘኃንባር፡ ጉድባ፡ ጻድቃን፨</l>
                  <l n="2">ወለኅንብርትክሙ፡ ሰላም፡ በዐጸደ፡ ዛቲ፡ መካን፨</l>
                  <l n="3">አእላፍ፡ አንትሙ፡ አርአያ፡ አእላፍ፡ ኄራን፨</l>
                  <l n="4">ጸልዩ፡ በእንቲአየ፡ ለለ፡ ሠርቀ፡ ኵሉ፡ ዘመን፨</l>
                  <l n="5">ከመ፡ ያድኅነኒ፡ እመንሱት፡ ለብእሲ፡ ምኑን፨</l>
               </lg>
               <lg type="stanza" n="37">
                  <l n="1">ሰላም፡ ለመልክእክሙ፡ ዘተኀርየ፡ እምዕንቈ፡ ሶም፨</l>
                  <l n="2">ወእምሠርጐ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="3">እስእለክሙ፡ ጻድቃን፡ በኀይለ፡ ኢየሱስ፡ ግሩም፨</l>
                  <l n="4">ከመ፡ ትጸግዉኒ፡ መጠነ፡ ሰብዓ፡ አክራም፨</l>
                  <l n="5">አምጣነ፡ ምኑን፡ አነ፡ ወብእሲ፡ ድኩም፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ተወከፉ፡ አኃውየ፡ ዘንተ፡ ስብሐተ፡ ወውዳሴ፨</l>
                  <l n="2">አርአያ፡ ክርስቶስ፡ ተወክፈ፡ መሥዋዕተ፡ አሮን፡ ወሙሴ፨</l>
                  <l n="3">ዘትጸውሩ፡ ጻድቃን፡ አስማተ፡ ቅድስት፡ ሥላሴ፨</l>
                  <l n="4">ከመ፡ ትባልሑ፡ ኃጥእ፡ ብእሴ፨</l>
                  <l n="5">ወታድኅኑ፡ እመንሱት፡ ወብዙኅ፡ ድምሳሴ፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ይባረክ፡ አብ፡ በአፈ፡ ኵሉ፡ ነፍስ፨</l>
                  <l n="2">ወይትባረክ፡ ወልድ፡ እስከ፡ ቀላያት፡ ወየብስ፨</l>
                  <l n="3">መንፈስ፡ ቅዱስ፡ ይትባረክ፡ ሕይወተ፡ ሥዹስ፡ ቅዱስ፨</l>
                  <l n="4">ዘነበብክሙ፡ ምሴተ፡ በነገር፡ ሐዲስ፨</l>
                  <l n="5">እንዘ፡ ኃጥእ፡ አነ፡ ወብእሲ፡ ዕቡስ፨</l>
               </lg>
            </div>
         </div>
      </body>

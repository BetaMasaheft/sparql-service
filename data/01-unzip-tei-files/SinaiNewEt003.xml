                      <measure unit="leaf" quantity="22">22</measure>
                      <measure unit="quire" quantity="4">4</measure>
                      <dimensions type="outer" unit="mm">
                        <height>180</height>
                        <width>15</width>
                      </dimensions>
                    </extent>
                    <foliation>Foliation in the upper outer corner.</foliation>
              <collation>
                      <list>
                        <item xml:id="q1" n="1">
                          <dim unit="leaf">4</dim>
                          <locus from="1r" to="4v"/>
                        </item>
                        <item xml:id="q2" n="2">
                          <dim unit="leaf">8</dim>
                          <locus from="5r" to="12v"/>
                        </item>
                        <item xml:id="q3" n="3">

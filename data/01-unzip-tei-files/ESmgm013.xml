                           <material key="textile"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Traces of blind tooled ornament are
                           visible on the outer part of the back cover.</decoNote>
                        <decoNote xml:id="b5">none</decoNote>
                     </binding>
                  </bindingDesc>

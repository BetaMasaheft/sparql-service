               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1ra" to="89vb"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2342serata">The Order of the Monastic Profession</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ <gap reason="ellipsis" resp="DN"/></hi> ዝንቱ፡ ሥርዓተ፡ መንኵስና፡ ዘሠርዓ፡ አቡነ፡ ቅዱስ፡ <hi rend="rubric">አባ፡ ያዕቆን፡ ዘስሩግ። ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስ</hi>ለ፡ ፍቁሩ፡ <persName ref="https://betamasaheft.eu/PRS14540HendaKrestos">ሕንፃ፡ ክርስቶስ፡</persName> ለዓለመ፡ ዓለም፨ ይደሉ፡ ለዘይፈቀድ፡
                        ይኩን፡ መነኮስ፡ ከመ፡ ይንበር፡ ዓመተ፡ ይትመሀር፡ ውሳንያተ፡ መንኵስና፡ ወይትገሠጽ፡ እመጻሕፍተ፡ ገነት፡ ዘአባዊነ፡
                     </incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="90ra" to="91vb"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4498Pilgrims">Antiphon of Pilgrims</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"><hi rend="rubric">መዝሙር፡ ዘመነኮሳት፡ ወፈለስያ</hi>ን፨ በ፫ወቅኑታን፡ ሐቌሆሙ፡ በጽድ<hi rend="rubric">ቅ፡ 
                        ጠለ፡ ገዳም፡ ይሴሰዩ፡ ምስለ፡ እንስ</hi>ሳ፡ ገዳም፡ ይነብሩ፡ </incipit>
                     <notatedMusic>
                        <desc>Musical notation throughout the text.</desc>
                     </notatedMusic>
                  </msItem>


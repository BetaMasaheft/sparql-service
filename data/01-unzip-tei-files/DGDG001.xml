                    <msContents>
                        <summary/>
                          <msItem xml:id="ms_i1">
                              <locus from="4r" to="50v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾtǝna Māryām ba-Dabra Golgotā</title>
                                  <incipit xml:lang="gez">
                              በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡ እሙ፡ ለብርሃን፡ ጸሎታ፡ ወበረከታ፡
                              የሃሉ፡ ምስለ፡ ገብራ፡ ወልደ፡ መድኅን፡ ለዓለመ፡ ዓለም፡ አሜን፨
                                  </incipit>
                                    <explicit xml:lang="gez">
                                      ቡሩክ፡ አንተ፡ እግዚኦ፡ ይትአኮት፡ ስምከ፡ ወይትባረክ፡ ስመ፡ መንግሥትከ፡
                                          ወምስለ፡ ቅዱስ፡ መንፈስ፡ ስብሐት፡ ወእኂዝ፡ ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን።
                                    </explicit>
                          </msItem>
                                  <msItem xml:id="ms_i2">
                                      <locus from="51r" to="62v"/>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT6510PrayerEstenfasa"/>
                                      <note>Incomplete at the end.</note>
                            <incipit xml:lang="gez">
                        በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ ወአስተብቁዖት፡ ኀበ፡ እግዚአብሔር፡ ዘትበቁዕ፡ ለነፍስ፡ ወሥጋ፡ ሕያዋን፡
                        ሶበ፡ ይጼልዩ፡ ባቲ፡ ያወጽኡ፡ እምሲኦል፡ አበዊሆሙ፡ ወእማቲሆሙ፡ ወአዝማዲሆሙ፡ ወፍቁራኒሆሙ፡ እስከ፡ ፼ ነፍስ፡ በአሐቲ፡ ጊዜ። </incipit>
                            <explicit xml:lang="gez">
                              አሜን። አቡነ ዘበሰማያት በል።
                            </explicit>
                            <colophon xml:lang="gez" xml:id="coloph1">
                                <locus target="#60v"/>ሐምሌ፡ ፫ ቀን፡ ፪ሽ፡ ፭ ዓመተ፡ ምሕረት፡ ተፈጸመ፨
                                ወጸሐፊሁኒ፡ ቄስ፡ አበዛ፡ እስዚያ። ወስመ፡ ጥምቀቱ፡ ገብረ፡ ሥላሴ።
                            </colophon>

         <listPerson>
            <person sex="1">
                     <persName xml:lang="gez" xml:id="n1" type="birth">ሲኖዳ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Sinodā</persName>
                     <persName>
                  <roleName type="title">ʾabuna</roleName>
               </persName>
                     <occupation type="ecclesiastic">metropolitan</occupation>
                     <nationality type="Egypt"/>
                     <faith type="Coptic"/>
                   
               <residence>He was at <placeName ref="https://betamasaheft.eu/LOC6376Yebaba">Yǝbābā</placeName>
               </residence>
                     
               <floruit notBefore="1671" notAfter="1692">He was a metropolitan of the Ethiopian Orthodox 
                  Church, consecrated by Coptic Patriarch 
                  <persName ref="https://betamasaheft.eu/PRS6906Matthew">Matthew (Mātewos) IV</persName> to replace 
               
                  <persName ref="https://betamasaheft.eu/PRS6071Krestodo">   
                     <roleName type="title">ʾAbuna</roleName> Krǝstodolu [II]</persName> in <date>1671</date>, who was imprisoned due to religious controversy.
                  He was a loyal ally to the king in power until the end of his tenure in <date>1692</date>. 
               
                             
                     </floruit>
                     <death when="1699"> He died in <date>1699</date>. 
               </death>
                  </person>
                  
         </listPerson>
      
         
         

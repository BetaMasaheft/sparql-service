                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura">Mazmura Dǝngǝl</title>
                                
                                

                        <msItem xml:id="ms_i3">
                            <locus from="210r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa malāʾǝkt la-Māryām</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ይዌድስዋ፡ መላእክት፡ ለማርያም፡ በውስተ፡ ውሣጤ፡ መንጦላዕት፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus target="#211r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2811RepCh95">Malkǝʾ-hymn to Our Lady Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለኪ፡ እንዘ፡ ንሰግድ፡ ንብለኪ። እግዝእትነ፡ ማርያም፡ ናስተበቍዓኪ። እምአርዌ፡ ነዓዊ፡ ተማኅፀነ፡ ብኪ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="211r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkəʾa Māryām</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ። እምነ፡ ከልበኔ፡ ወቍስጥ፡ ወእምነ፡ ሰንበልት፡ ምዑዝ፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="216v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2730RepCh14">Hymn to Our Lady Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ማርያም፡ ስብሕት፡ ቀስተ፡ መሐላሁ፡ ለኖኅ። ዲበ፡ ገጸ፡ ምድር፡ ዳግመ፡ እምደመና፡ ላህ። ኢያንጠብጥብ፡ ዝናመ፡ አይኅ። ሰላም፡ ለኪ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i7">
                            <locus from="218r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3990Prayer">Prayer by Philoxenus of Mabbug</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">እሴብሐከ፡ ኦእግዚእየ፡ ወአምላኪየ፡ ኢየሱሰ፡ ክርስቶስ፡ በስብሐተ፡ ማር፡ ፈለስኪኖሰ፡ ጳጳስ፡ ዘሀገረ፡ ምንቡዠ። 
                                <seg type="supplication">ጸሎቱ፡ ወበረከቱ፡ ወሀብተ፡ ረድኤቱ፡ የሀሉ፡ 
                                    ምስለ፡ ፍቁሩ፡ <persName ref="https://betamasaheft.eu/PRS13080Isayeyyas">ኢሳይያስ፡</persName> ወፍቅርቱ፡ <persName ref="https://betamasaheft.eu/PRS13081WalattaH">ወለተ፡ ሃይማኖት፡</persName>
                                    <persName ref="https://betamasaheft.eu/PRS13079HellaweK"><add place="overstrike">ህላዌ፡</add> ክርስቶስ፡</persName> እስከ፡ ለዓለመ፡ ዓለም፡ አሜን።</seg> ስብሐት፡ ለከ፡ ኦእግዚአብሔር፡ አብ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i8">
                            <locus from="223r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6104MadhanitaN">Ṣalot wa-sǝʾlat baʾǝnta madḫānita nafs wa-śǝgā</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><seg type="inscriptio">ጸሎት፡ ወስእለት፡ በእንተ፡ መድኃኒተ፡ ነፍስ፡ ወሥጋ፡</seg> 
                                ኦእግዚእየ፡ ወአምላኪየ፡ ወመድኃኒየ፡ ኢየሱስ፡ ክርስቶስ።
                                ወይትከዐው፡ ሞገደ፡ ምሕረትከ፡ ላዕሌየ፤ ከመ፡ ያስጥሞ፡ ለመጽሐፈ፡ ዕዳየ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i9">
                            <locus from="224r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6105EgzioA">ʾƎgziʾo ʾadḫǝnanni za-ʾadḫānko la-ʾElyās ʾǝm-ʾǝda ʾElzābel
          nǝgǝśt...</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">እግዚኦ፡ አድኅነኒ፡ ዘአድኃንኮ፡ ለኤልያስ፡ እምእደ፡ ኤልዛቤል፡ ንግሥት።</incipit>
                        </msItem>
                        
                    </msContents>
                    

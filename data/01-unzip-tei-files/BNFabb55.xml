                             <msItem xml:id="ms_i3.1">
                                <locus from="26ra" to="33rb"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3927Messale">Mǝssālǝyāta Salomon</title>
                              <incipit><hi rend="rubric">ምሳልያተ፡ ሰሎሞን፡ ወ</hi>ልደ፡ ዳዊት፡ ዘነግሠ፡ ለእ<hi rend="rubric">
                              ስራኤል፡ ለአእምሮ፡ ጥበብ፡</hi> ወተግሣጽ፨</incipit>
                                <note>Proverbs.</note>
                                 </msItem>

                                 <msItem xml:id="ms_i3.2">
                                 <locus from="33rb" to="34vc"/>
                                 <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2396Tagsas">Tagśāṣa Salomon</title>
                                   <incipit xml:lang="gez"><hi rend="rubric">ዝተግሣጸ፡ ሰሎሞን፡ ዘእንበ</hi>ለ፡ ኑፋቄ፡ ዘጸሐፉ፡ አዕርክቲሁ፡ <hi rend="rubric">ለሕዝቅያስ፡ ንጉሠ፡ ይሁዳ፡ </hi>ክብረ፡ እግዚአብሔር፡ የኅብእ፡<hi rend="rubric"> ነገረ፡</hi></incipit>
                                 <note>Admonition of Salomon.</note>
                                 </msItem>

                                 <msItem xml:id="ms_i3.3">
                                    <locus from="34vc" to="38ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1320Eccles">Ecclesiastes</title>
                                    <incipit xml:lang="gez"><hi rend="rubric">ቃለ፡ መክብብ፡ ወልደ፡ ዳዊት፡ ንጉ</hi>ሠ፡
                                       እስራኤል፡ በኢየሩሳሌም። ከን<hi rend="rubric">ቱ፡ ከንቱ፡  ኵሉ፡ ከንቱ፡ ይቤ፡ መ</hi>ክብብ፡
                                       ከንቱ፡ ከንቱ፡  ምንት፡ ፈድ<hi rend="rubric">ፋዱ፡ ለሰብእ።</hi></incipit>
                                       <explicit xml:lang="gez">እመ፡ ሠናይ፡ ወእመ፡ እኩይ፨
                                       </explicit>
                                    <note>Ecclesiastes.</note>
                                   </msItem>


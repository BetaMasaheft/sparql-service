               <msContents>
                  <summary>Folio i is blank.</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="15v">1v-15v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s37IHA">قران, Thirtieth ǧuz’ (30/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة النبا وهى احدى وارىعون اية مكيه \ بسم الله الرحمن الرحيم \ عم يتسالون عن النبا العظيم الذي هم فيه مختلفون</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15v">-15v</locus>الذى يوسوس فى صدور الناس , من الجنة والناس</explicit>
                     <note>78:1-114:6. Triple dots as verse markers. In the margins, the word ǧuz' in red (fol. 1v) and ḥizb in black (fol. 7v).</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="16r" to="16v">16r-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4490IHA">دعاء اللهم اغفر لنا ولوالدينا ولمشائخنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>بسم الله الرحمن الرحيم \ اللهم اغفر لنا ولوالدينا ولمشائخنا ولجميع المسلمين والمسلمات والمؤمنين والمؤمنات الله اصلح امور امة محمد صلى الله عليه وسلم واغفر ذنوبهم واستر عيوبهم واقض ديونهم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>وخراب دولة الكافرين فى زماننا هذا واىرنا وافرحنا وارحنا بذلك [وأورث] المسلمين ارضهم وديارهم واموالهم [عاجلا] غير اجل برحمتك يا أرحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم تسليما امين امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="17r" to="17v">17r-17v</locus>
                     <title ref="https://betamasaheft.eu/LIT0955IHA">دعاء ختم القران اللهم تقبل منا ختم القران العظيم</title>
                     <incipit xml:lang="ar">
                        <locus target="#17r">-17r</locus>بسم الله الرحمن الرحيم  \ اللهم تقبّل منا ختم القران العظيم وتجاوز عنا فى ما كان فى تلاوته من خطا او نسيان

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17v">-17v</locus>واغفر لنا ما ضيعنا من حقوقهم واغفر لهم ما ضيعوا من حقوقك برحمتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين

</explicit>
                     <note/>
                     <note/>
                  </msItem>

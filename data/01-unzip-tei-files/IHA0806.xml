                        <item xml:id="a0_2893">
                           <locus target="#15v">-15v</locus>
                           <q xml:lang="ar">صدق الله العظيم وبلغ رسوله النبي الكريم والحمد لله رب العالمين \ وصلى الله على سيدنا محمد واله وصحبه وسلم</q>

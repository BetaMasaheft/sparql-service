                        <msItem xml:id="ms_i2">
                            <locus from="2r" to="10vb"/>
                            <textLang mainLang="gez"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2125OntheG">Dǝrsān za-darasa Yoḥannǝs ʾAfa Warq ... baʾǝnta kǝbru
          la-Yoḥannǝs maṭmǝq</title>
                            <incipit xml:lang="gez">
                                <locus target="#2r"/>
                                <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመ</hi>ንፈስ፡ ቅዱስ፡ አሐዱ፡ አም<hi rend="rubric">ላክ፡ ድርሳን፡ ዘደረሰ፡ ቅዱስ፡</hi> ዮሐንስ፡ አፈ፡ ወርቅ፡ ሊቀ፡ <hi rend="rubric">ጳጳሳት፡ ዘሀገረ፡ ቍስጥ</hi>ንጥንያ፡ </incipit>
                            <incipit xml:lang="gez" type="supplication">ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡
                                    <space reason="owner"/>ወምስለ፡ ፍቅርቱ፡ <space reason="owner"/>። ዓለመ፡
                                ዓለም፡ አሜን።</incipit>
                            <incipit xml:lang="gez">ዘተናገረ፡ በእንተ፡ ክብሩ፡ ለዮሐንስ፡ መጥምቅ። በከመ፡ ጽሑፍ፡ በውስተ፡
                                ወንጌለ፡ ማቴዎስ ።</incipit>
                            <explicit xml:lang="gez" type="supplication">
                                <locus from="9vb" to="10ra"/> ወለነኒ፡ ክፍለነ፡ ርስተ፡ ሊተ፡ ለገብርከ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14833Zawangel">ዘወንጌል፡</persName><persName ref="https://betamasaheft.eu/PRS14835AdamS"> አዳም፡
                                        ስና፡</persName></hi> ወለዓመትከ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14836SablaW">ሰብለ፡ ወንጌል፡</persName></hi>
                            </explicit>
                            <explicit xml:lang="gez">ወመክፈልተ፡ ሠናየ፡ ዘወሀብኮ፡ ለዮሐንስ፡ ፍቁርከ። ወኵሉ፡ ዘይገብር፡
                                ተዝካሮ፡ በዲበ፡ ምድር፡ ወበእንተ፡ አፍቅሮቱ፡ ወምሕረቱ፡ ለሰብእ፡ በእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡
                                ክርስቶስ። ዘሎቱ፡ ክብር፡ ወሰብሐት፡ ወስጊድ፡ ይደሉ፡ ምስለ፡ አቡሁ፡ ወመንፈስ፡ ቅዱስ፡ ማኅየዊ፡ ይእዜኒ፡
                                ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን። ወአሜን፡ ለይኩን፡ ለይኩን። </explicit>
                            <colophon xml:lang="gez" xml:id="coloph1">
                                <locus from="10rb" to="10va"/> ወተጽሕፈ፡ ዝንቱ፡ ገድለ፡ ዮሐንስ፡ ድንግል፡ ወሰማዕት፡
                                ወገድለ፡ መብአ፡ ጽዮን፡ መፍቀሬ፡ ፀባኦት፡ በ<del rend="strikethrough">ኰወ፪
                                </del>ዓመተ፡ ምሕረት፡ በመዋዕለ፡ ማርቆስ፡ ዕፀ፡ ገነት፡ በዕብሬተ፡ ንግሡ፡ ለናዖድ፡ ዘይት፡ በረከተ፡
                                ነቢያት፡ ወሐዋርያት፡ በረከተ፡ ጻድቃን፡ ወሰማዕት፡ ወበረከተ፡ እግዚእትነ፡<hi rend="rubric">ማርያም፡</hi> ቅድስት፡ በረከተ፡ አዕሩግ፡ ወሕፃናት። ለይረድ፡ ላዕለ፡ ፍቁራኒሁ፡ <space reason="rubrication" unit="chars" quantity="16"/>ከመ፡ ዝናመ፡ ክረምት።
                                ወያእሙ፡ በትፍሥሕት፡ ኀበ፡ ተርኅወ፡ ገነት፡ ወኀበ፡ ተነጽፈ፡ ዕረፍት፡ ውስተ፡ ኢየሩሳሌም፡ ሰማያዊት፡
                                ወይዕቀበነ፡ ከመ፡ ዓይነ፡ ብንት፡ እመሥገርተ፡ ዓርዌ፡ መስሕት፡ በኵሉ፡ ጊዜ፡ ወበኵሉ፡ ሰዓት፡ ለዓለመ፡
                                ዓለም፡ አሜን። ወአሜን፡ ለይኩን፡ ለይኩን። ። ። ። </colophon>
                            <note>According to <bibl corresp="http://zotero.org/groups/358366/items/MZC4PZ7D"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1914Notice"/><title level="m">Notice sur les manuscrits éthiopiens de la Collection d’Abbadie</title><title level="s">Extrait du Journal Asiatique</title><author><forename>Carlo</forename><surname>Conti Rossini</surname></author><pubPlace>Paris</pubPlace><publisher>Imprimerie nationale</publisher><date>1914</date><series><title level="s">Extrait du Journal Asiatique</title></series><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note><citedRange unit="page">179-180</citedRange></bibl>, this
                                colophon belongs to <ref type="work" corresp="https://betamasaheft.eu/LIT2125OntheG">Dǝrsān za-darasa Yoḥannǝs ʾAfa Warq ... baʾǝnta kǝbru
          la-Yoḥannǝs maṭmǝq</ref>,
                                signaling that the current text was copied from an antigraph dated
                                to the time of King <ref type="pers" corresp="https://betamasaheft.eu/PRS7481NaodA">Nāʿod</ref>.</note>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="11r" to="27vb"/>
                            <textLang mainLang="gez"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1450GadlaG">Gadla Gabra Krǝstos</title>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመ</hi>ንፈስ፡
                                ቅዱስ፡ ፩አምላክ፡ ድር <hi rend="rubric">ሳን፡ ወገድል፡ ዘብፁዕ፡ ወቅ</hi>ዱስ፡ ንጹሕ፡
                                ወጽሩይ፡ ብእሴ፡ እግዚአብሔር፡ ገብረ፡ ክርስቶስ፡ ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቅሩ፡ <space reason="owner" unit="chars" quantity="9"/> ምስለ፡ ፍቅርቱ፡ <space reason="owner" unit="chars" quantity="7"/> ለዓለመ፡ ዓለም፡ አሜን። ገድለ፡
                                ኂሩቱ፡ ለብፁዕ፡ ብእሴ፡ እግዚአብሔር፡ ዝውእቱ፡ ገብረ፡ ክርስቶስ፡ ወልደ፡ ቴዎደስዮስ፡ ንጉሠ፡ ቍስጥንጥያ።
                                ወቴዎዶስዮስሰ፡ መፍቀሬ፡ እግዚአብሔር፡ ውእቱ፡ ወመፍቀሬ፡ እንግዳ፡</incipit>
                            <explicit xml:lang="gez">ወወረደ፡ ብርሃን፡ ኀበ፡ መቃብሩ፡ ዘየሐዩ፡ ኵሎ፡ ድዉያነ፡
                                ወሕሙማነ።</explicit>
                            <explicit xml:lang="gez" type="supplication">ጸሎቱ፡ ወበረከቱ፡ ወትጋሃ፡ ጸማሁ፡
                                ለብእሴ፡ እግዚአብሔር፡ <hi rend="rubric">ገብረ፡ ክርስቶስ፡</hi> የሀሉ፡ ምስለ፡ አግብርቱ፡
                                    <space reason="owner" unit="chars" quantity="15"/>
                                <del rend="effaced" unit="chars" quantity="10"/>
                                <space reason="owner" unit="chars" quantity="15"/> ለዓለመ፡ ዓለም፡ አሜን።
                                ወአረፈ፡ አመ፡ ፲ወ፬ በወርኃ፡ ጥቅምት፡ በዕለተ፡ እሑድ፡ ጊዜ፡ ፫ሰዓት፡ ለዘጸሐፎ፡ ወለዘአጽሐፎ፡
                                ወለዘአንበቦ፡ ወለዘሰምዓ፡ ቃላቲሁ፡ ኅቡረ፡ ይምሐረነ፡ እግዚአብሔር፡ አሜን።</explicit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="28ra" to="50ra"/>
                            <textLang mainLang="gez"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1959Mashaf">Maṣḥafa qedar</title>
                            <incipit xml:lang="gez"><hi rend="rubrication">በስመ፡ አብ፡ ወወልድ፡</hi>
                                ወመንፈስ፡ ቅዱስ፡ ፩አም<hi rend="rubric">ላከ፡ ቀኖና፡ መጽሐፈ፡ ቄ</hi>ድር፡ ዘአንበሩ፡
                                    መምህራ<hi rend="rubrication">ን፡ በእንተ፡ ዘክህደ፡ ሃይ</hi>ማኖቶ። አው፡ ዘአርኰሰ፡
                                ሥጋሁ፡ ምስለ፡ ኢምእመናን። አው፡ ተባዕተ፡ አው፡ አንስተ።</incipit>
                            <explicit xml:lang="gez">ወዘንተ፡ ሕዝብ፡ ዘዐለወ፡ ጽኑሕ፡ ሎቱ፡ ደይን፡ ወበዛቲ፡ ሕግ፡ ዘሖረ፡
                                ድኁን፡ እምኵነኔ፡ እወ፡ አሜን። ወአሜን፡ </explicit>
                            <explicit xml:lang="gez" type="supplication">ከማሁ፡ ያድኅኖሙ፡ ለአግብርተ፡
                                እግዚአብሔር፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14837HadaraK">ሐደራ፡
                                        ክርስቶስ፡</persName>
                                    <persName ref="https://betamasaheft.eu/PRS14833Zawangel">ዘወንጌል።</persName></hi> ወለአእማተ፡
                                እግዚአብሔር፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS14836SablaW">ሰብለ፡ ወንጌል፡ </persName>
                                    <persName ref="https://betamasaheft.eu/PRS14835AdamS">አዳም፡ ስና፡</persName></hi>
                                <space reason="rubrication"/> እስከ፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን። </explicit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="51ra" to="87rb"/>
                            <textLang mainLang="gez"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4072GadlaKiLo">Gadla Kiros</title>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ እግዚአብሔር፡ ግሩመ፡</hi> ግርማ፡
                                መንክረ፡ ሥላሴ፡ ንጉሠ፡ <hi rend="rubric">ራማ፡ ወውእቱኬ፡ ዘሐረያ፡ ለቅድ</hi>ስት፡
                                ወንጽሕት፡ ወጽሪት፡ ወኅ<hi rend="rubric">ሪት፡ ማርያም፡ ድንግል፡ እምቅ</hi>ድመ፡ ይትፈጠር፡

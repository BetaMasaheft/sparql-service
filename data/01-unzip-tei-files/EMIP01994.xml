                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                           <desc>The word God is rubricated in the first three works; the word Mary is rubricated in the final two works. Occasionally, the word God is written in alternating red and black ink (e.g., <locus target="#58v">fol. 58v</locus>)</desc>
                           <desc>Columetric layout of text: <locus target="#15v" facs="018">fols. 15v, </locus> (Ps. 28r); <locus target="#90v" facs="093">90v, </locus> (Ps. 148); <locus target="#91v" facs="094">91v, </locus> (Ps. 150); <locus target="#99v #100r" facs="102">99v, 100r</locus> (tenth Biblical Canticle)</desc>
                        </seg>
                     </handNote>
                  </handDesc>

                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                        <desc>Crude drawing of a Roman cross</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc><persName ref="https://betamasaheft.eu/PRS8472Samuel">Samuel</persName> anointing the head of <persName ref="https://betamasaheft.eu/PRS3417David">David</persName> with caption <q>“How Samuel, the prophet, anointed David with the anointing of the throne.”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#60r" facs="062">Fol. 60r</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#60v" facs="063">Fol. 60v</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d5">
                    Decorative designs:
                    <locus target="#1r #11v #17v #30r #34v #41v #49r #55r #61r #70r #79r #81v #92r #103r #108v" facs="003 014 020 032 037 044 051 057 063 072 081 084 094 105 111">folss. 1r, 11v, 17v, 30r, 34v, 41v, 49r, 55r, 61r, 70r, 79r, 81v, 92r, 103r, 108v, </locus> (haräg);
                    <locus target="#1r #6r #24v #102v" facs="003 008 027 105">1r, 6r, 24v, 102v, </locus> (line of alternating red and black dots);
                    <locus target="#108r #119v" facs="110 122">108r, 119v</locus> (multiple full stops and lines of alternating red and black dots).
                    </decoNote>
                  </decoDesc>

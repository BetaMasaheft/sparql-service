                          <locus target="#15v" facs="018"> f. 15v, line 24</locus>
                          <locus target="#16r" facs="018"> f. 16r, line 6</locus>
                          <locus target="#18r" facs="020"> f. 18r, line 22</locus>
                          <locus target="#20r" facs="022"> f. 20r, lines 7 and 24</locus>
                          <locus target="#25r" facs="027"> f. 25r, line 16</locus>
                          <locus target="#26v" facs="029"> f. 26v, line 19</locus>
                          <desc>etc., lines of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted</desc>
                          </item>
                        <item xml:id="e9">
                          <locus target="#15v" facs="018">Fol. 15v</locus>
                          <desc>etc., erasure markings are visible</desc>
                          </item>
                        <item xml:id="e10">
                          <locus target="#14r #15v #19v #21v #22v" facs="016 018 022 024 025">Fols. 14r, 15v, 19v, 21v, 22v</locus>
                          <desc>etc., text has been removed</desc>

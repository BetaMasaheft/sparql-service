               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="4v">1v-4v</locus>
                     <textLang xml:lang="am">Amharic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0731IHA">Poem in ʻaǧamī Amharic (7)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>يأحدن خبر تقت لالسمايشه| أيناشه [...] يلقت جوار اوشه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>عمرن لمفجو هلن اياباظي حضر اول اي كوم يا قلب دندالي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="11v">5r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0975IHA">فقه على المذاهب الأربعة</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>لنقصانهما وسادسها الصحة فلا تجب على المريض وسابعها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>شرايط وجوب الزكاة فيها اي الاثمان خمسة اشيا او ؟ الاسلام وثانيها الحرية وثالثها الملك التام ورابعها ال؟وخا</explicit>
                     <note>Fiqh
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="12r" to="35v">12r-35v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#12r">-12r</locus>بِالْعَذَابِ وَإِنَّ جَهَنَّمَ لَمُحِيطَةٌ بِالْكَافِرِينَ  يَوْمَ يَغْشَاهُمُ الْعَذَابُ مِن فَوْقِهِمْ وَمِن تَحْتِ أَرْجُلِهِمْ وَيَقُولُ ذُوقُوا مَا كُنتُمْ تَعْمَلُونَ<note>29:53</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35v">-35v</locus>وَلَوِ اتَّبَعَ الْحَقُّ أَهْوَاءهُمْ لَفَسَدَتِ السَّمَاوَاتُ وَالأَرْضُ وَمَن فِيهِنَّ بَلْ أَتَيْنَاهُم بِذِكْرِهِمْ فَهُمْ عَن ذِكْرِهِم مُّعْرِضُونَ<note>23:71</note>
                     </explicit>
                     <note>29:53-23:71. The fol. are bound in a wrong order (pages of several different copies). The words are not divided. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="36r" to="121v">36r-121v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0087IHA">منهج الطلاب</title>
                     <incipit xml:lang="ar">
                        <locus target="#36r">-36r</locus>واخ لابوين ولام باب وجد وفرع [...] واخ لابوين وعم باب وابن وابنه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#121v">-121v</locus>وصيفة وعوض وسيد وشرط فيه [...] معتق وكتابة مريض من ثلث فان خلف مثا</explicit>
                     <note/>
                     <note/>
                  </msItem>

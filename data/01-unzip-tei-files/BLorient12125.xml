                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1v" to="286v"/>
                            <title ref="https://betamasaheft.eu/LIT6924OctateAmharic">Octateuch (Amharic)</title>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The following text parts are described as Old Testament books by S. Strelcyn. However, the number of folios written
                                give the impression, that in several cases they are too few to contain the complete biblical books. Furthermore, the given 
                                incipits with the quotations of the Hebrew name of each book (in Ethiopic script) raises the suspicion, that they may be 
                                abridged versions or paraphrases, or commentaries on the books listed, which could not be verified because of the lack of
                                images available.</t:note>
                        <msItem xml:id="ms_i1.1">
                            <locus from="2ra" to="55vb"/>
                            <title ref="https://betamasaheft.eu/LIT6926GenesiAmharic">Genesis</title>
                            <incipit xml:lang="am">ኦሪት፡ ዘፍጥረት፡ በዕብራይስጥም፡ ብርሺት፡ ይባላል።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered with some errors from 1 to 50.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                            <locus from="56r" to="101va"/>
                            <title ref="https://betamasaheft.eu/LIT6927ExodusAmharic">Exodus</title>
                            <incipit xml:lang="am">ኦሪት፡ ዘፀዓት። በዕብራይስጥም፡ ይባላል፡ ወኤሌ፡ ሸሞች፡</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered with some errors from 1 to 40.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                            <locus from="102ra" to="136vb"/>
                            <title ref="https://betamasaheft.eu/LIT6928LevitiAmharic">Leviticus</title>
                            <incipit xml:lang="am">ኦሪት፡ ዘሌዋውያን። በዕብራይስጥም፡ ወይቅራ፡ ይባላል።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered from 1 to 27.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.4">
                            <locus from="137ra" to="188ra"/>
                            <title ref="https://betamasaheft.eu/LIT6929NumberAmharic">Numbers</title>
                            <incipit xml:lang="am">ኦሪት፡ ዘኍልቍ። ዘዕብራይስጥም፡ ወይዳብር፡ ይባላል።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered from 1 to 36.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.5">
                            <locus from="188va" to="228vb"/>
                            <title ref="https://betamasaheft.eu/LIT6930DeuteroAmharic">Deuteronomy</title>
                            <incipit xml:lang="am">ኦሪት፡ ዘዳግም። በዕብራይስጥም፡ ኤሌ፡ ሐደፈሪም፡ ይባላል።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are not numbered.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.6">
                            <locus from="229ra" to="256rb"/>
                            <title ref="https://betamasaheft.eu/LIT6931JoshuaAmharic">Joshua</title>
                            <incipit xml:lang="am">መጽሐፈ፡ ኢያሱ፡ ወልደ፡ ነዌ። በዕብራይስጥም፡ ይሆሹዓ። ይባላል።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered from 1 to 24.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.7">
                            <locus from="256va" to="282ra"/>
                            <title ref="https://betamasaheft.eu/LIT6932JudgesAmharic">Judges</title>
                            <incipit xml:lang="am">መጽሐፈ፡ መሳፍንት። በዕብራይስጥም፡ ሾፍጢም፡ ይባላል፡</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered from 1 to 21.</t:note>
                        </msItem>
                        <msItem xml:id="ms_i1.8">
                            <locus from="282va" to="286v"/>
                            <title ref="https://betamasaheft.eu/LIT6933RuthAmharic">Ruth</title>
                            <incipit xml:lang="am">መጽሐፈ፡ ሩት፡ ምዓባዊት።</incipit>
                            <t:note xmlns:t="http://www.tei-c.org/ns/1.0">The leaves are numbered from 1 to 4.</t:note>
                        </msItem>
                        </msItem>
                    </msContents>

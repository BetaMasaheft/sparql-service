         <listPlace>
            <place type="monastery" subtype="institution" sameAs="wd:Q2511832">
               <placeName xml:lang="gez" xml:id="n1">ደብረ፡ ሊባኖስ፡</placeName>
               <placeName xml:lang="gez" corresp="#n1" type="normalized">Dabra Libānos</placeName>
               <placeName xml:lang="gez" xml:id="n2" type="alt">ዓስቦ፡</placeName>
               <placeName xml:lang="gez" corresp="#n2" type="normalized">ʿAsbo</placeName>
               <t:state xmlns:t="http://www.tei-c.org/ns/1.0" type="existence" ref="Paks2"/>

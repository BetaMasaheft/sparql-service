         <listPerson>
            <person sex="1">
              <persName xml:lang="gez" xml:id="n1" type="birth">አብዬ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAbbǝyye</persName>
               <persName xml:lang="gez" xml:id="n2" type="alt">ቀዳሜ፡ ቃል፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Qadāme qāl</persName>
               <persName xml:lang="gez" xml:id="n3" type="alt">ቀዳሜ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Qadāme</persName>
               <persName>
                  <roleName type="title">marʿǝd ʾazmāč</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="political">ruler</occupation>

               <floruit notBefore="1719" notAfter="1743">He was the third ruler of the kingdom of
                  <placeName ref="https://betamasaheft.eu/LOC5597Sawa">
                  Šawā </placeName> from about <date>1719</date> to <date>1743</date>,
                  a period of  territorial expansion and administrative consolidation.
                  Like his predecessors, in alliance with the walasma rulers,
                  he continued a campaign against the <persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</persName>
                  of Karrayyu and pushed the border of the principality.
                  It was during his rule  that the typical land tenure system of  <placeName ref="https://betamasaheft.eu/LOC5597Sawa">
                     Šawā </placeName> was developed. He was succeeded by
                  <persName ref="https://betamasaheft.eu/PRS1878AmmehaI">
                     <roleName type="title">marʿǝd ʾazmāč</roleName>
                        ʾAmmǝḫā ʾIyyasus</persName>
               </floruit>


               </person>
               
         </listPerson>

               <msContents>
                  <summary>The hymn, "God Reigns," ascribed to Zär’a Ya‘ǝqob, እግዚአብሔር፡ ነግሠ፡, Three Miracles of Mary, ተአምረ፡ ማርያም፡</summary>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="72v" facs="003">Fols 1r–72v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1325egziab">ʾƎgziʾabǝḥer nagśa
                                                  (General record)</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="73r" to="79r" facs="075">Fols 73r–79r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                     <note>Three Miracles of Mary</note>
                    <msItem xml:id="ms_i2.1">
                        <locus from="73r" to="75r" facs="075">Fols 73r–75r</locus>
                        <title ref="https://betamasaheft.eu/LIT3900Miracle">Miracle of Mary:
                                                  How the Virgin Mary smote a satan who was trying
                                                  to corrupt a monk</title>
                      </msItem>
                    <msItem xml:id="ms_i2.2">
                        <locus from="75r" to="78r" facs="077">Fols 75r–78r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3866Miracle">Miracle of Mary:
                                                  How Nicodemus the Persian knight became a
                                                  Christian</title>
                        <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእነ፡ ቅድቅድስት፡ ድንግል፡ ማርያም፡<gap reason="omitted"/>ወሀሎ፡ ፩መስተፅዕነ፡ ፈረስ፡ ኃጥእ፡ በኵሉ፡ ፍናዊሁ፡ ዓለማዊ። ወባሕቱ፡ ጸጋ፡ እግዚአብሔር፡<gap reason="omitted"/></incipit>
                    </msItem>
                    <msItem xml:id="ms_i2.3">
                        <locus from="78r" to="79r" facs="080">Fols 78r–79r</locus>
                        <title ref="https://betamasaheft.eu/LIT3597Miracle">Miracle of Mary:
                                                  Miracle of Juliana and Barbara from
                                                  Bethlehem</title>
                    </msItem>
                  </msItem>
               </msContents>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="4r" to="13v">4r-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT1482IHA">شرح الورقات للمحلي</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الله الرحمن الرحيم هذه ورقات قليلة تشتمل على معرفة فصول من اصول الفقه ينتفع بها المبتدى وغيره وذلك اي لفظ اصول الفقه مولف من جزئين مفردين احدهما الاصول والاخر الفقه من الافراد مقابل التركيب الجمع والمولف يعرف بمعرفة ما الف منه فالاصل اي الذى هو المفرد الجزى الاول</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ومن اجتهد فاخطا فله اجر واحد ووجه الدليل ان النبي صلى الله عليه وسلم خطا المجتهد تارة وصوبه اخرى والحديث رواه الشيخان ولفظ البخاري اذا اجتهد الحاكم فاصاب فله اجران واذا حكم فاخطا فله اجر واحد والله اعلم تم الكتاب بعون الملك الوهاب واليه المرجع والماب وصلى الله على سيدنا محمد وعلى ءاله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="14v" to="64r">14v-64r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1483IHA">فتاوى مختلفة</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>بسم الله الرحمن الرحيم \ الحمد لله الذى ارتضى لنا الاسلام دينا اختاره لنفسه وارسل به خير خلقه  [...] وبعد فقد وردت علي اسئلة من بعض من اظن فيه الخير والرشد والصلام عن المسائل التى هي علي غويصات ارهقنى بها عسرا لكونها حادثة ما وقعت الا فى هذه الناحية ناحية الكفر والضلال والجهل والبدعة والطغيان ولا ارى دليلا من كتاب وسنة فى غينها ولا قولا لامام من ائمة هذه الامة في كثير منها مع عدم تاهلى لرد الفرع الى اصله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#64r">-64r</locus>وفى فتاوى بعضهم انه يجوز الجمع بين كل محرم فى الجنة ما سوى الام والبنت هذا والسلام وليكن هذا اخر ما اردت من اجوبة المسائل وكاختمنا كلامنا بذكر ما فى الجنة ختم الله لنا بحسن الخاتمة وجعل ماوانا الجنة بفضله ومنه امين وانا نستغفر الله من جميع الزلات والهفوات ومما زلت القدم وطغى به القلم واللسان ويعاملنا بلطفه ولا يجعل ما تكلمنا به او سطرناه فى السطور وبالا علينا انه البر الرحيم الحنان المنان وصلى الله على سيدنا محمد واله وصحبه اجمعين الحمد لله رب العالمين امين امين امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

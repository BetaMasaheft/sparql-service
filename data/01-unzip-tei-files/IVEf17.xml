                    <msItem xml:id="ms_i1.5">
                      <locus from="129r" to="134v"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                      <textLang mainLang="gez"/>
                      </msItem>

                    <msItem xml:id="ms_i1.6">
                      <locus from="137v" to="142v" cert="low"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our Lady Mary</title>
                      <textLang mainLang="gez"/>
                      <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡ መዓዛ፡ አፍኪ፡ ኮል፡ እንተ፡ ትጸንዊ፡
                      በገዳም፡ ወሐቅል፡ ወልታ፡ ረዲኦትየ፡ በውስተ፡ ቀትል፡</incipit>
                      <note>Excerpts from the
                       <ref type="work" corresp="https://betamasaheft.eu/LIT1961Mashaf">Maṣḥafa saʿātāt</ref>
                       (salām-praises for the Saviour and
                       St Mary for the 1st, 3rd and 9th hours).</note>
                    </msItem>



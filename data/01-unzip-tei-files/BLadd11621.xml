                                <item xml:id="a3">
                                    <desc type="OwnershipNote"/>
                                    <locus target="#160v"/>
                                    <q xml:lang="gez">ዛቲ፡ መጽሐፍ፡ ዘንዋየ፡ ሥሉስ፡ ዘአጠረያ፡ በንዋዮ፡ ከመ፡ ትኵኖ፡ ተዝካረ፡ ወዝክረ፡ ለአቡሁ፡ ወለእሙ፡ ወለአኀዊሁ።</q>
                                    <q xml:lang="en">"This book belongs to Nǝwāya Śǝllus, who purchased it with his own money, so that his memory and that of his father, his 
                                        mother and his brothers shall be commemorated".</q>
                                    <note>The note states that the book belongs to <persName role="owner" ref="https://betamasaheft.eu/PRS10767NewayaS">Nǝwāya Śǝllus</persName>.</note>
                                </item>
                                <item xml:id="a4">
                                    <desc type="ProtectivePrayer"/>
                                    <locus target="#160v"/>
                                    <q xml:lang="gez">ጸሎት፡ በእንተ፡ ስደተ፡ አጋንንት።</q>
                                    <note>Protective prayer against the demons, only the beginning.</note>
                                </item>
                            </list>
                        </additions>

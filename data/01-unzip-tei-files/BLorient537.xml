                          <msItem xml:id="p1_i1">
                              <locus from="1r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                              <textLang mainLang="gez"/>
                              
                              <note>This manuscript contains in continuous form the text of the <ref type="work" corresp="https://betamasaheft.eu/LIT2701Dawit">Psalter</ref>
                                  together with the <ref type="work" corresp="https://betamasaheft.eu/LIT2003Mazmur">Mazmura Krǝstos</ref> and the
                                  <ref type="work" corresp="https://betamasaheft.eu/LIT3985Mazmura">Mazmura Dǝngǝl</ref>.
                                  The single prayers of <ref type="work" corresp="https://betamasaheft.eu/LIT4691Prayer">Prayer for the weekdays</ref> occur at the beginning and after each book of Psalms.</note>
                              
                              <incipit type="supplication" xml:lang="gez">
                                  <locus from="1r"/>
                                  ኦአምላከ፡ ዳዊት። አድኅኖ፡ ለነፍሰ፡ ገብርከ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ።</persName> ወዕቀበኒ፡ እምኵሉ፡ ዘእፈርሆ፡ 
                                 ለ<space/>።
                              </incipit>
                              
                              

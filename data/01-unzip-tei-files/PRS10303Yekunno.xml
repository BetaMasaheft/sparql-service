         <t:listPerson>
            <t:person sameAs="wd:Q56825507" sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ይኩኖ፡ አምላክ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yǝkunno ʾAmlāk</t:persName>
                  <t:persName xml:lang="en" corresp="#n1" type="normalized">There shall be to him sovereignty</t:persName>

                  <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ተስፋ፡ ኢየሱስ፡</t:persName>

                  <t:persName xml:lang="gez" corresp="#n2" type="normalized">Tasfā ʾIyasus</t:persName>

               <t:persName>
                  <t:roleName type="title">ʾaṣe</t:roleName>
               </t:persName>


               <t:occupation type="ruler">Emperor</t:occupation>


               <t:floruit when="1270" evidence="internal">He became the first king of the Solomonic dynasty in<t:date>1270</t:date>.
                  He was supported by two important religious figures of the 13th century, <t:persName ref="https://betamasaheft.eu/PRS5633IyasusM">ʾIyasus Moʾ a</t:persName> and
                  <t:persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</t:persName> to establish the new dynasty, "Solomonic dynasty".</t:floruit>
               <t:death when="1285"/>
            </t:person>
               
         </t:listPerson>


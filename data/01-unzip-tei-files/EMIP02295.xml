               <msContents>
                  <summary/>
                    <msItem xml:id="ms_i1">
                      <locus from="1r" to="14v" facs="002">Fols 1r–14v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa
                                                  Mikāʾel</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ፡</incipit>
                    </msItem>

                    <msItem xml:id="ms_i2">
                      <locus from="15r" to="23v" facs="016">Fols 15r–23v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa
                                                  Gabrǝʾel</title>
                      <incipit xml:lang="gez">በሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአዕረፈ፡</incipit>
                    </msItem>

                    <msItem xml:id="ms_i3">
                      <locus from="23v" to="28r" facs="026">Fols 23v–28r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkǝʾ-hymn to
                                                  Gabra Manfas Qǝddus</title>
                      <incipit xml:lang="gez">ሰላም፡ ለፅንሰትከ፡ መሠረተ፡ ነገር፡ ወውጣኔ፡</incipit>
                    </msItem>

                    <msItem xml:id="ms_i4">
                      <locus from="28v" to="42r" facs="030">Fols 28v–42r</locus>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne
                                                  ʿālam</title>
                      <incipit xml:lang="gez">ሰላም፡ ለ<supplied reason="lost">ዝ</supplied>ክረ፡ ስምከ፡ ዘኢረከቡ፡ ተፍጻሜተ፡ መላእክተ፡ ሰማይ።</incipit>
                      <note>Incomplete at the end because of illumination painted over text</note>
                    </msItem>

                    </msContents>

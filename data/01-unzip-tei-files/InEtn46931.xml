                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ማዕሠረ፡ አጋንንት፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i6">
                    <locus from="1r163" to="1r183">Fols 1r163–1r183</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5691MagicPrayer">Ṣalot baʾǝnta ḥǝmāma budā wa-qumaňňā<certainty locus="value" match="../@ref" cert="medium"/></title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ቡዳ፡ ወ<sic>ቀ</sic>ማኛ፡
                  ወሐብት፡</incipit>
                  </msItem>

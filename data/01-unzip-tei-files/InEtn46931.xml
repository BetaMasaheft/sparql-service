                  <msItem xml:id="ms_i1">
                    <locus from="1r1" to="1r9">Fols 1r1–1r9</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4581MagicPr">ጸሎት፡ በእንተ፡ ማእሠረ፡ አጋንንት፡ እንትሙ፡ እለ፡ ባርያ፡ እለ፡ ሌጌዎን፡<certainty locus="value" match="../@ref" cert="medium"/></title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ማዕሠረ፡
                  አጋንንት፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="1r10" to="1r94">Fols 1r10–1r94</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሕያው፡ ነባቢ፡ ወተናጋሪ፡ ጸሎቱ፡ ወበረከቱ፡ ለቅዱስ፡ ሱስንዮስ፡
                    </incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <locus from="1r95" to="1r101">Fols 1r95–1r101</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4643Salam">Malkǝʾ-hymn to St Susǝnyos</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ሰላም፡ ለሱስንዮስ፡ ወልደ፡ ጴጥሮስ፡ ሱሲ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                    <locus from="1r102" to="1r115">Fols 1r102–1r115</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4578MagicPr">ጸሎት፡ በእንተ፡ ሱስንዮስ፡ ዘያሰስል፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ወበእንተ፡ መጋኛ፡ ወጉሥምት፡<certainty locus="value" match="../@ref" cert="medium"/></title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ኦአምላከ፡ ሱስንዮስ፡ ዕቀባ፡ ወአድኅና፡ እምሕማመ፡ ባርያ፡ ወሌጌዎን፡ ደም፡ ወመጋኛ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i5">
                    <locus from="1r117" n="1r162">Fols 1r117 and following</locus>

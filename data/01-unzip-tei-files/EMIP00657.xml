                  <decoDesc>
                  <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  <locus target="#41r" facs="043">fol. 41r</locus> (haräg);
                  lines of alternating red and black dots are used as section dividers throughout
                  </decoNote>
                </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>
                    <desc type="GuestText">
                    excerpts from <title type="incomplete" ref="https://betamasaheft.eu/LIT2361somade">Ṣoma dǝggʷā</title>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#70v" facs="073">Fol. 70v</locus>
                    <desc type="GuestText">
                    Blessing of Saint Yared, <foreign xml:lang="gez">ቡራኬ፡ ዘቅዱስ፡ ያሬድ፡</foreign>, in a later hand
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    <desc>
                    pen trial and seal of the Capuchin fathers
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                    <desc type="RecordTransaction">
                    Note of transaction, purchase of the manuscript in 29 Yäkkatit 1923 for 22 birr. with names and signatures of seller, buyer and witnesses
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#41v" facs="044">Fol. 41v</locus>
                    <desc type="OwnershipNote">
                    Note of ownership: This book belongs to Ḫabtä Maryam, whose father is Wäldä Arägawi, whose mother is Wälätä Kiros, whose teacher is Wäldä Mika’el, whose parish is Däbrä Däqaqit, bought with his own wealth for 35 bars of salt
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#70v" facs="073">Fol. 70v</locus>
                    <desc type="GuestText">
                    List of sections from <title type="complete" ref="https://betamasaheft.eu/LIT2361somade">Ṣoma dǝggʷā</title>
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#71v" facs="074">Fol. 71v</locus>
                    <desc type="GuestText">
                    Asmat prayer for multiplying the grain in threshing
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#71r" facs="073">Fol. 71r</locus>
                    <desc>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#33r #36r #38r #42v #44v" facs="035 038 040 045 047">Fols. 33r, 36r, 38r, 42v, 44v</locus>
                    <desc>etc., words of text are written interlinearly;
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#5v #6r #23r #48v #50r" facs="008 025 051 052">Fols. 5v, 6r, 23r, 48v, 50r</locus>
                    <desc>etc., lines of text are written interlinearly;
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#4v" facs="007"> f. 4v, col. 2, line 14</locus><locus target="#23v" facs="026"> f. 23v, col. 2, line 1</locus><locus target="#28v" facs="031"> f. 28v, col. 3, line 10</locus><locus target="#32r" facs="034"> f. 32r, col. 3, line 11</locus>
                    <desc>
                    lines of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted;
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#25v" facs="028">Fol. 25v</locus>
                    <desc>
                    erasure markings are visible;
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <locus target="#12v #14r #22r #33v #35r" facs="015 016 024 036 037">Fols. 12v, 14r, 22r, 33v, 35r</locus>
                    <desc>etc., text has been removed
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                    Marginal and interlinear notation is found throughout the codex
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, spine covered with leather.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

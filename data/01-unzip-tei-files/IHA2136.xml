               <msContents>
                  <summary>F. 3v is blank.</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="3v">1r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم | اللهم صل وسلم علي سيدنا ومولانا محمد وعلي ال سيدن [كذا] محمد عدد معلوماتك ومدد كلماتك اللهم صلى سيدنا [كذا] ومولانا محمد وعلى ال سيدنا محمد وأضعاف أضعاف ذالك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1r">-1r</locus>اللهم صل وسلم علي سيدنا ومولانا محمد وعلي ال سيدنا محمد الذي من صلي عليه في يوم خمس مائة مرة هدمت ذنوبه ومهئي سيئته ودام سروره اللهم صل وسلم علي سيدنا ومولانا محمد وعلي ال سيدنا محمد </explicit>
                     <note>Loose folios, order disrupted.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="6r" to="7v">6r-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-un">Unidentified</textLang>
                     <title ref="https://betamasaheft.eu/LIT4164IHA">رسال الى الحاج يونس عبده وحاج حاكم كليف</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v-7v">-6v-7v</locus>الحمد لله وحده والسلاة [كذا] واسلام علي من لا نبي بعده سيدنا محمد وعلي أله وصحبه وسلم إلى حضرة الجناب ؟ الأكرم المكرم المحترم العزيز المحب الخينا في الله والرسول الحاج يونس عبده وحاج حاكم كليف سلمه الله تعالي أمين من بندر هرر إلي بلد دري رو؟ </incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="8r" to="8r">8r-8r</locus>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>بسم الله الرحمن الرحيم | بسم الله الرحمن الرحيم اللهم صل علي سيدنا ومولانا محمد وعلي أل سيدنا محمد اللهم صل وسلم وبارك على سيدنا محمد شجرة الأصل النورانية ولمعة القبدة الرحمانية وأفضل الخليقة الإنسانية</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>

                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_6363">
                           <locus target="#1r">-1r</locus>
                           <q xml:lang="ar">هذه دلائل الخيرات وشوارق الانوار في ذكر الصلوة على على النبي المختار صلى الله عليه وسلم</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_6363">
                           <locus target="#1v">-1v</locus>
                           <q xml:lang="ar">بسم الله الرحمن الرحيم وصلى الله على سيدنا [...] وبعد هذ فالغرض فى هذا  الكتاب ذكر الصلوة على النبي صلى الله عليه ويلم وفضائلها ذكرها مخذوفة الاسانيد يسهلحفظها على القاري وهي مزاهم المهمات لمذ يريد القرب من رب الارباب وسميته بكتاب دلائل الخيرات وشوارق الانوار فى ذكر الصلوة على النبي المختار</q>
                           <desc>Muqaddima</desc>
                           <note/>
                        </item>
                     </t:list>
                  </additions>

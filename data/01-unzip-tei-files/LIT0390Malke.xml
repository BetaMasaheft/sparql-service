      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">ትትመየጥ፡ ሊተ፡ ሀበ፡ ገጸ፡ ገብርከ፡ ዐይንከ፡ መሓሪት፨</l>
                  <l n="2">ዘይኬልላ፡ ብርሃን፡ በመዓልት፡ ወበሌሊት፨</l>
                  <l n="3">ኀይለ፡ ሥላሴ፡ ንጉሥ፡ ተቅዋመ፡ ማኅቶት፡ መንግስት፨</l>
                  <l n="4">አኮኑ፡ ወጠንኩ፡ ለንግሥከ፡ ነገረ፡ ውዳሴ፡ ወማሕሌት፨</l>
                  <l n="5">ልቱተ፡ በዘኮነ፡ አፉየ፡ ልቱት፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጽሕፈ፡ እምጥንቱ፨</l>
                  <l n="2">በእደ፡ ጳጳሳት፡ ባስልዮስ፡ ወጎርጎርዮስ፡ ክልኤቱ፨</l>
                  <l n="3">ኀይለ፡ ሥላሴ፡ ንጉሥ፡ በኵረ፡ ዓለማት፡ ዐሥርቱ፨</l>
                  <l n="4">ኀቤከ፡ ይምጻእ፡ ተዋሕዶ፡ በአእጋሪሁ፡ ክልኤቱ፨</l>
                  <l n="5">ፍና፡ ጳጳሳት፡ ኮነት፡ ዘረትዐት፡ ፍኖቱ፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለመልክእከ፡ ዘሕብረ፡ ፀሓይ፡ ሕብራ፨</l>
                  <l n="2">ሐዋያ፡ ወንጌል፡ ባስልዮስ፡ ሶበ፡ በዐይኑ፡ ነጸራ፨</l>
                  <l n="3">ኀይለ፡ ሥላሴ፡ ንጉሥ፡ ምስዋቀ፡ ንህልት፡ ኤርትራ፨</l>
                  <l n="4">ለጽርሐ፡ ዝኩ፡ ማርቆስ፡ ተደንግሎ፡ በእደዊሁ፡ ሰፈራ፨</l>
                  <l n="5">ባስልዮስ፡ ሐዋርያ፡ ሶበ፡ ርእየ፡ ግብራ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">በአፈ፡ ትጉሃን፡ ባስልዮስ፡ ሐዋርያ፡ ወበቴዎፍሎስ፡ ሊቅ፨</l>
                  <l n="2">ኢየሐልቅ፡ ወትረ፡ ውዳሴ፡ ንጉሥከ፡ ዘጽድቅ፨</l>
                  <l n="3">ኀይለ፡ ሥላሴ፡ ሥንከ፡ ዘሥነ፡ ደመና፡ ረቂቅ፨</l>
                  <l n="4">ኵሉ፡ ይትፌሣሕ፡ በብዝኀ፡ ብዕሉ፡ ዘይትዌዳዕ፡ ወየሐልቅ፨</l>
                  <l n="5">ወለዓለመ፡ ዓለም፡ ውእቱ፡ ዘዘዚአከ፡ አጽቅ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">መኑ፡ ውእቱ፡ ዘየአድዋ፡ ለባሕረ፡ ተከዚ፡ ጥበብ፨</l>
                  <l n="2">እንበለ፡ ዋሕድ፡ ንጉሥ፡ ኀይለ፡ ሥላሴ፡ መክብብ፨</l>
                  <l n="3">ኢትዮጵያ፡ ንግሥት፡ መርዓተ፡ ቤቱ፡ ለአብ፨</l>
                  <l n="4">ወልድኪ፡ ኀይለ፡ ሥላሴ፡ መልአከ፡ አሕዛብ፡ ወሕዝብ፨</l>
                  <l n="5">አምሳሊሁ፡ ዘሰማይ፡ ኮከብ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
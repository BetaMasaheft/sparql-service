                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>First half of the 19th cent.</date>
                        <seg type="rubrication">Nomina sacra; incipits of the chapters; elements of
                           the punctuation signs, element of chapter dividers; elements of Ethiopic
                           numerals. 
 On the incipit page of Text I (fol. 3r), a few lines are
                           rubricated (two red line alternating with black lines).</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#104v">Fol. 104v: </locus>
                        <desc>The Holy Trinity.</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1ra">f. 1ra-2</locus>
                           <desc>vb, 104ra-104va: Ṣalota nǝssǝḥa “Prayer of Penance”.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> Additio 1 mentions Metropolitan Krǝstodolu (in tenure 1720-1735)
                              and King Dāwit III (r. 1716-21), but the text is obviously a late
                              addition written on the protective leaves of the Ms., and the scribe
                              copied the names from the model manuscript. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#103v">ff. 103v</locus>
                           <desc>: List of religious feasts.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> </note>
                        </item>
                        <item xml:id="e1">
                           <desc type="findingAid">- Daily readings are indicated by the names of the
                              days and of the hours, written in the upper margin of some folios
                              (between two decorative chains of red and black dots): ዘሰኑይ: <locus target="#3r">fol. 3r</locus>, 12v. ዘሠሉስ: <locus target="#7v">fol.
                                 7v</locus>, 24r, 35v. ዘእሁድ: <locus target="#9r">fol. 9r</locus>,
                              56v, 85r. ዘቀዳም: <locus target="#19r">fol. 19r</locus>, 42r, 55r. ዘረቡዕ:
                                 <locus target="#48r">fol. 48r</locus>, 50r, 88v. ዘሐሙስ: <locus target="#60v">fol. 60v</locus>. ዘፈጸምነ: <locus target="#73v">fol.
                                 73v</locus>. ዘዓርብ: <locus target="#76r">fol. 76r</locus>. ዘዘወትር:
                                 <locus target="#90v">fol. 90v</locus>. ዘነግህ: <locus target="#92v">fol. 92v</locus>. ዘ፫ሰዓት: <locus target="#94r">fol. 94r</locus>.
                              ዘ፮ሰዓት: <locus target="#95v">fol. 95v</locus>. ዘ፱ሰዓት: <locus target="#97v">fol. 97v</locus>. ዘሠርክ: <locus target="#99r">fol.
                                 99r</locus>. ዘንዋም: <locus target="#101r">fol. 101r</locus>. -
                              Coloured threads are incerted in the upper corner of fols. 9, 12, 18,
                              23, 50, 55, 60, 84.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden board covered by tooled reddish-brown
                           leather; textile inlays. 
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                           <material key="textile"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two pairs of chains of endband stitches
                           at the spine cover.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the brown leather cover (at
                           least 5 tools were used: double circle, double line fillet, criss-cross,
                           double sine wave with dots, x-form).</decoNote>
                     </binding>

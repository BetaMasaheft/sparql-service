         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እግዚአብሔር፡ ወሃቤ፡ ብርሃን፡ ዘይሤለስ፡ በአካሉ፨</l>
                  <l n="2">እንዘ፡ ተዋሕዶ፡ ያጸንዕ፡ በመለኮቱ፡ ወኀይሉ፨</l>
                  <l n="3">ዐይነ፡ ልቡናየ፡ ያብርህ፡ በማኅቶተ፡ ጥበብ፡ ሥነ፡ ጸዳሉ፨</l>
                  <l n="4">ከመ፡ እርአይ፡ ገጸ፡ ነገር፡ ለኪዳንኪ፡ ዘይደሉ፨</l>
                  <l n="5">ማርያም፡ እግዝእተ፡ ኵሉ፡ ዘታሕቱ፡ ወላዕሉ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘአስተማሰልዎ፡ በኮከብ፨</l>
                  <l n="2">ሶበ፡ ብርሃኖ፡ ተከድኑ፡ ጽልሙታነ፡ ራእይ፡ ሕዝብ፨</l>
                  <l n="3">ኪዳነ፡ አምላክ፡ ማርያም፡ ወተስፋ፡ መድኀኒት፡ ዘዐርብ፨</l>
                  <l n="4">ተናዘዘ፡ ብኪ፡ አኮኑ፡ ኅሊና፡ ቀዳማይ፡ አብ፨</l>
                  <l n="5">አመ፡ እምገነቱ፡ ተሰደ፡ በሐዘን፡ ዕጹብ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስኪ፡ ዘፈትለ፡ ሜላት፡ ዘውጋ፨</l>
                  <l n="2">ወምልእት፡ ይእቲ፡ እምጠለ፡ ሠናይት፡ እንበለ፡ ንትጋ፨</l>
                  <l n="3">ለዘተካየድኪ፡ ማርያም፡ ቅድመ፡ ማኅበር፡ ወእንግልጋ፨</l>
                  <l n="4">ሰአልዮ፡ ሕይወተ፡ ነፍስ፡ ይጸግወኒ፡ በጸጋ፨</l>
                  <l n="5">አምሳለ፡ ኤልያስ፡ አኮ፡ ያሐይወኒ፡ በሥጋ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለርእስኪ፡ ዘሀሎ፡ ወይሄሉ፨</l>
                  <l n="2">ዲበ፡ ጠባይዓት፡ ኵሉ፨</l>
                  <l n="3">ተካየድኒ፡ ማርያም፡ ኪዳነ፡ ምሕረት፡ ዘይደሉ፨</l>
                  <l n="4">ምስለ፡ ሞትሰ፡ ተካየድነ፡ ወተማሐልነ፡ ዘይብሉ፨</l>
                  <l n="5">ከንቶ፡ ነበቡ፡ ወነፍሶሙ፡ ሀጕሉ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለገጽኪ፡ ገጸ፡ ቅድስና፡ ስቡሕ፨</l>
                  <l n="2">ዘይበርህ፡ ሥኑ፡ እምጸዳለ፡ ፀሓይ፡ ወወርኅ፨</l>
                  <l n="3">ትእምርተ፡ ኪዳን፡ ማርያም፡ ወቀስተ፡ ደመና፡ ብሩህ፨</l>
                  <l n="4">እምኀበ፡ አምላክ፡ መሓሪ፡ እምአመ፡ ነሥአኪ፡ ኖኅ፨</l>
                  <l n="5">አማስኖታ፡ ለምድር፡ ኢደገመ፡ አይኅ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለቀራንብትኪ፡ ንጻሬ፡ አዕይንት፡ ለዑቃቤ፨</l>
                  <l n="2">እለ፡ ሥዩማት፡ እማንቱ፡ ህየንተ፡ ምስዋር፡ ወግልባቤ፨</l>
                  <l n="3">ማርያም፡ በሊዮ፡ ለዘወለድኪዮ፡ በኢሩካቤ፨</l>
                  <l n="4">አይቴኑ፡ ቃልከ፡ እግዚኦ፡ እምሕር፡ ለከ፡ ዘይቤ፨</l>
                  <l n="5">እመ፡ ኃጥኣን፡ ጸውዑ፡ ስመኪ፡ ነባቤ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለአዕይንትኪ፡ አምሳለ፡ ክልኤቱ፡ ቀናዲል፨</l>
                  <l n="2">እንተ፡ ሰቀሎን፡ ኬንያ፡ በማኅፈደ፡ ሥጋ፡ ልዑል፨</l>
                  <l n="3">ማርያም፡ አንቲ፡ ነቅዐ፡ ተራኅርኆ፡ ወሣህል፨</l>
                  <l n="4">አድኅነኒ፡ በኪዳንኪ፡ ወባልሕኒ፡ እምሀጕል፨</l>
                  <l n="5">እስመ፡ ዘእንበሌኪ፡ አልቦ፡ አድኅኖ፡ ዘይክል፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለአእዛንኪ፡ እለ፡ ተበስራ፡ ኪዳነ፨</l>
                  <l n="2">እምአፈ፡ ፈጣሪ፡ ወልድኪ፡ ዘበባሕርይኪ፡ ተከድነ፨</l>
                  <l n="3">ኣምሕለኪ፡ ማርያም፡ ከመ፡ ኢታርእይኒ፡ ደይነ፨</l>
                  <l n="4">እንበለ፡ ምግባር፡ ባሕቱ፡ ለእመ፡ ኢይጸድቅ፡ አነ፨</l>
                  <l n="5">ቦኑ፡ ለከንቱ፡ ኪዳንኪ፡ ኮነ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለመላትሕኪ፡ ጽጌያተ፡ ሮማን፡ እለ፡ ይመስላ፨</l>
                  <l n="2">ባሕቱ፡ መጽለዋ፡ በእሳተ፡ አንብዕ፡ በነበልባላ፨</l>
                  <l n="3">በኪዳንኪ፡ ማርያም፡ አዕርግኒ፡ ዐጸደ፡ ተድላ፨</l>
                  <l n="4">ወይ፡ ለነ፡ አሌ፡ ለነ፡ አመ፡ ውስተ፡ ደይን፡ ይብላ፨</l>
                  <l n="5">ነፍሳተ፡ ክልኤቲ፡ አኃት፡ ሀሊባ፡ ወሀላ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለአእናፍኪ፡ መሳክወ፡ ሕይወት፡ ምንታዌ፨</l>
                  <l n="2">ዘአስተዋደዶን፡ አምላክ፡ በአጽባዕተ፡ ጥበብ፡ ወልባዌ፨</l>
                  <l n="3">ማርያም፡ ሕጽርኒ፡ በኀይለ፡ ኪዳንኪ፡ እምንሳዌ፨</l>
                  <l n="4">ወቀጥቅጢ፡ ርእሶ፡ በበትረ፡ ሕማም፡ ወደዌ፨</l>
                  <l n="5">ለእመ፡ አፋሁ፡ አብቀወ፡ የኀጠኒ፡ አርዌ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለከናፍርኪ፡ በእንተ፡ ኃጥኣን፡ እለ፡ ሰአላ፨</l>
                  <l n="2">እምኀበ፡ አምላክ፡ መሓሪ፡ ኪዳነ፡ ምሕረት፡ ወመሐላ፨</l>
                  <l n="3">ውስተ፡ ጎልጎታ፡ ማርያም፡ አመ፡ ገይሶትኪ፡ እምገሊላ፨</l>
                  <l n="4">ለጽድቀ፡ ዛቲ፡ ኪዳንኪ፡ ለለ፡ ጊዜ፡ ይከውን፡ በዓላ፨</l>
                  <l n="5">ዲበ፡ ርእሰ፡ ኃጥእ፡ ገብርከ፡ አንብሪ፡ አክሊላ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለአፉኪ፡ አፈ፡ በረከት፡ ትሩፍ፨</l>
                  <l n="2">አንቀጸ፡ ቅዱስ፡ መጽሐፍ፨</l>
                  <l n="3">ተማሕፀንኒ፡ ማርያም፡ በኪዳንኪ፡ ውኩፍ፨</l>
                  <l n="4">ኢይትኀፈር፡ ቅድመ፡ ወልድኪ፡ ወመላእክቲሁ፡ አእላፍ፨</l>
                  <l n="5">አመ፡ ሥርወ፡ ልሳን፡ ይትመተር፡ ወይትኀተም፡ አፍ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለአስናንኪ፡ ከመ፡ መራዕይ፡ እለ፡ ተቀርፃ፨</l>
                  <l n="2">እለ፡ ወፅኣ፡ እምኅፃብ፡ እንዘ፡ ይትባየጻ፨</l>
                  <l n="3">ማርያም፡ ንሥእኒ፡ ኪዳንኪ፡ ህየንተ፡ ሞፃ፨</l>
                  <l n="4">ወለዕድውየ፡ ግብጻዊ፡ ዘፍትወተ፡ ልቡ፡ ዐመፃ፨</l>
                  <l n="5">መዝራዕተ፡ ጸሎትኪ፡ ሙሴ፡ ይድፍኖ፡ በኆጻ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለልሳንኪ፡ ዘአፈድፈደ፡ ቅዳሴ፨</l>
                  <l n="2">እምካህናተ፡ ሰማይ፡ ሱራፌል፡ እለ፡ ይቀውሙ፡ ቅድመ፡ ሥላሴ፨</l>
                  <l n="3">አዘክሪ፡ ሊተ፡ ማርያም፡ ተዝካረ፡ ኪዳንኪ፡ አመ፡ ድምሳሴ፨</l>
                  <l n="4">በእንተ፡ እስራኤል፡ በገዳም፡ ከመ፡ አዘከረ፡ አውሴ፨</l>
                  <l n="5">ኪዳነ፡ አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ ወጽድቆ፡ ለሙሴ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለቃልኪ፡ ተሰጣዌ፡ ቃል፡ ለቃሉ፨</l>
                  <l n="2">ለመልአከ፡ ብስራት፡ ገብርኤል፡ ዘጸዳለ፡ ብርሃን፡ መንዲሉ፨</l>
                  <l n="3">ማርያም፡ ቅድስት፡ ለእግዚአብሔር፡ መካነ፡ ኀይሉ፨</l>
                  <l n="4">እንቋዕ፡ ተውህበኪ፡ ኪዳነ፡ ምሕረቱ፡ ወሣህሉ፨</l>
                  <l n="5">በዘቦቱ፡ ጸዲቀ፡ ኃጥኣን፡ ይክሉ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለእስትንፋስኪ፡ ነፋሰ፡ ጥዒና፡ ፈዋሲ፨</l>
                  <l n="2">ነፍሳተ፡ ብዙኃን፡ ሰብእ፡ እለ፡ ቈስሉ፡ በሕምዘ፡ ከይሲ፨</l>
                  <l n="3">በኪዳንኪ፡ ማርያም፡ ኀጣውእየ፡ ደምስሲ፨</l>
                  <l n="4">እንበለ፡ ኪዳንኪሰ፡ ወመስቀለ፡ ክርስቶስ፡ ወራሲ፨</l>
                  <l n="5">አልቦ፡ እምሲኦል፡ ዘይድኅን፡ ብእሲ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለጕርዔኪ፡ ሠናይ፡ ወአዳም፨</l>
                  <l n="2">እንተ፡ ይትፈለጡ፡ ቦቱ፡ ጸዋትወ፡ መሪር፡ ወጣዕም፨</l>
                  <l n="3">ምንተ፡ እግበር፡ ማርያም፡ እስመ፡ ኀይልየ፡ ድኩም፨</l>
                  <l n="4">ሐጸኒ፡ ግብር፡ እምኵለሄ፡ ወጸበኒ፡ ዓለም፨</l>
                  <l n="5">ባሕቱ፡ በኪዳንኪ፡ ናዝዝኒ፡ እም፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ሰላም፡ ለክሳድኪ፡ ዘማኅፈደ፡ ዳዊት፡ ርእዮታ፨</l>
                  <l n="2">ዲበ፡ ተልፍዮስ፡ ጠቢባን፡ ዘአስተናደፉ፡ መሠረታ፨</l>
                  <l n="3">ማርያም፡ በልዮ፡ ውስተ፡ እዝነ፡ ነፍስየ፡ ለናዝዞታ፨</l>
                  <l n="4">ለምንት፡ ብዙኀ፡ ትሰርሒ፡ ነፍስ፡ ዚአየ፡ ማርታ፨</l>
                  <l n="5">እስመ፡ ኅዳጥ፡ የአክል፡ እምብዙኅ፡ ሐተታ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለመታክፍትኪ፡ ግዕዛነ፡ በረከት፡ እለ፡ ተወክፋ፨</l>
                  <l n="2">ህየንተ፡ መርገም፡ ወዘልፋ፨</l>
                  <l n="3">ማርያም፡ ጹርኒ፡ ለጽድቀ፡ ኪዳንኪ፡ ዲበ፡ መትከፋ፨</l>
                  <l n="4">ወንሥእኒ፡ ዐሥራተ፡ እድ፡ እመሬተ፡ ወልድኪ፡ አልፋ፨</l>
                  <l n="5">እስመ፡ ሃይማኖትየ፡ አንቲ፡ ወዘብየ፡ ተስፋ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ሰላም፡ ለዘባንኪ፡ በወርኀ፡ ተሰዶ፡ ቀዲሙ፨</l>
                  <l n="2">ምዕራፈ፡ አምላክ፡ ዘኮነ፡ ውስተ፡ ፍኖተ፡ ቍስቋም፡ ጊዜ፡ ድካሙ፨</l>
                  <l n="3">ማርያም፡ ስመኪ፡ ለዘጾረ፡ መልዕልተ፡ ስሙ፨</l>
                  <l n="4">በዕለተ፡ ኵነኔ፡ እመ፡ ኢያስለጠ፡ ደሙ፨</l>
                  <l n="5">በዕለተ፡ ኵነኔ፡ እመ፡ ኢያስለጠ፡ ደሙ፨</l>
                  <l n="6">ዐሥራተ፡ ኪዳንኪ፡ ንሥእዮ፡ መሓሪት፡ እሙ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለእንግድኣኪ፡ ወለሕፅንኪ፡ ካልእታ፨</l>
                  <l n="2">ወለአእዳውኪ፡ መንታ፨</l>
                  <l n="3">አምሕለኪ፡ ማርያም፡ በነጸፍጻፈ፡ ደም፡ ዘጎልጎታ፨</l>
                  <l n="4">ለነፍስየ፡ ምስለ፡ ነፍስኪ፡ ታስተዳልዊ፡ መክፈልታ፨</l>
                  <l n="5">አመ፡ መሬታዊት፡ ሥጋየ፡ ትትከደን፡ መሬታ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለመዛርዒኪ፡ ወለኵርናዕኪ፡ ምፅንጋዕ፨</l>
                  <l n="2">ዘሐቀፋሁ፡ ለክርስቶስ፡ ባሕርየ፡ መለኮት፡ ኅቡእ፨</l>
                  <l n="3">ማርያም፡ ኅሪት፡ እመላእክት፡ ወሰብእ፨</l>
                  <l n="4">ተዝካረኪ፡ ለእመ፡ ገብረ፡ በተአምኖ፡ ጽኑዕ፨</l>
                  <l n="5">በመንግሥተ፡ ሰማይ፡ ምስሌኪ፡ ይነግሥ፡ ኃጥእ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ ለእመታትኪ፡ ለቤተ፡ መቅደስ፡ ቀዋሚ፨</l>
                  <l n="2">እለ፡ አሠነያ፡ ወርቀ፡ ፈትለ፡ ሜላት፡ ግብረ፡ አናሚ፨</l>
                  <l n="3">ማርያም፡ ላዕሌየ፡ ኪዳነ፡ ምሕረትኪ፡ ፈጽሚ፨</l>
                  <l n="4">ወቅትሊ፡ ዕድወ፡ ነፍስየ፡ እስመ፡ ውእቱ፡ ረጋሚ፨</l>
                  <l n="5">ከመ፡ በጥበቡ፡ ሰሎሞን፡ ቀተሎ፡ ለሳሚ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለእራሓትኪ፡ ተመጣዌ፡ ኅብስት፡ ወማይ፨</l>
                  <l n="2">ሶበ፡ ያመጽኡ፡ ለኪ፡ መላእክተ፡ ሰማይ፨</l>
                  <l n="3">እንዘ፡ ሀሎኪ፡ ማርያም፡ በመቅደሰ፡ ኦሪት፡ ዐባይ፨</l>
                  <l n="4">ይትወከፍ፡ ሊተ፡ ኪዳንኪ፡ ከመ፡ መሥዋዕተ፡ ሰርክ፡ ኅሩይ፨</l>
                  <l n="5">እመ፡ ሕፍነ፡ ማይ፡ አስተይኩ፡ ለጽሙእ፡ ነዳይ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለአጻብዕኪ፡ ወለአጽፋርኪ፡ ጽዕድው፨</l>
                  <l n="2">ወለአጥባትኪ፡ ክልኤ፡ አንቅዕተ፡ ሐሊብ፡ ፍትው፨</l>
                  <l n="3">ማርያም፡ ጽጌ፡ ዘዘመንኪ፡ መፀው፨</l>
                  <l n="4">ተማሕፀንኩ፡ በአጥባትኪ፡ ወበሥንኪ፡ ምጽልው፨</l>
                  <l n="5">በኀይለ፡ ጸሎትኪ፡ እድኅን፡ እምእሳት፡ ድልው፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለገቦኪ፡ መንፈለ፡ ለፌ፡ ወለፌ፨</l>
                  <l n="2">እለ፡ ተረሰያ፡ ደርገ፡ ሐመልማለ፡ ወርቅ፡ ኢኀላፌ፨</l>
                  <l n="3">ማርያም፡ ምጥቅኒ፡ በገቦ፡ ኪዳንኪ፡ ምስለ፡ ሑቃፌ፨</l>
                  <l n="4">ሶበ፡ ይወርዱ፡ ኃጥኣን፡ ብሔረ፡ ጽልመት፡ ጸናፌ፨</l>
                  <l n="5">እለ፡ በሕይወቶሙ፡ ጸልኡ፡ ዘጻድቃን፡ ሱታፌ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለከርሥኪ፡ ለከርሠ፡ መላእክት፡ ዘውጉ፨</l>
                  <l n="2">ኅብስተ፡ ሰማይ፡ ውትረ፡ ዘይሴሰይ፡ ዐቅመ፡ ምዕራጉ፨</l>
                  <l n="3">ማርያም፡ በጽዮን፡ ለእግዚአብሔር፡ ታቦተ፡ ሕጉ፨</l>
                  <l n="4">ያንጽሐኒ፡ እምፍቅረ፡ ወይን፡ ለማየ፡ ኪዳንኪ፡ ዐይጉ፨</l>
                  <l n="5">እስመ፡ ፍቅረ፡ ወይን፡ ተብህለ፡ ለሰይጣን፡ ዔረጉ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለልብኪ፡ ስንእወ፡ ኵልያት፡ ወኅሊና፨</l>
                  <l n="2">ወለአማዑትኪ፡ ሰላም፡ ምስለ፡ ንዋየ፡ ውስጥኪ፡ በዕሪና፨</l>
                  <l n="3">ውስተ፡ ምድረ፡ ርስት፡ አብእኒ፡ ማርያም፡ ዐምደ፡ ደመና፨</l>
                  <l n="4">በብርሃነ፡ እሳት፡ ኪዳንኪ፡ እንዘ፡ ትመርሐኒ፡ ፍና፨</l>
                  <l n="5">ወትሴስይኒ፡ እምፍቅርኪ፡ መና፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለሕንብርትኪ፡ ምሳሌ፡ ፍሑቅ፡ ማዕከክ፨</l>
                  <l n="2">ወለማሕፀንኪ፡ ንጹሕ፡ ምስለ፡ ሐቌኪ፡ ቡሩክ፨</l>
                  <l n="3">ማርያም፡ ቅድስት፡ ወላዲተ፡ ቅዱስ፡ አምላክ፨</l>
                  <l n="4">ተዐየኒ፡ ዐውደ፡ ነፍስየ፡ እስከ፡ ሣልሳዊ፡ ፈለክ፨</l>
                  <l n="5">አመ፡ ተቃወማ፡ በአየር፡ ቀናኢ፡ መልአክ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለድንግልናኪ፡ መክብበ፡ ሕዋሳት፡ ኀምስ፨</l>
                  <l n="2">ወለአቍያጽኪ፡ ክልኤ፡ አዕማደ፡ ነባቢት፡ መቅደስ፨</l>
                  <l n="3">ማርያም፡ ታቦት፡ ወጽላተ፡ ኪዳን፡ ሐዲስ፨</l>
                  <l n="4">ቅብእኒ፡ ርጢነ፡ ጾም፡ እስከ፡ ሰኰና፡ እግር፡ ወርእስ፨</l>
                  <l n="5">እስመ፡ ጾም፡ ትፌውስ፡ ሕማማ፡ ለነፍስ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለአብራክኪ፡ ጊዜ፡ አስተርእዮ፡ ወተንብሎ፨</l>
                  <l n="2">ምስለ፡ አእጋርኪ፡ ደርገ፡ እለ፡ ይሰግዳ፡ በኢያብጥሎ፨</l>
                  <l n="3">ማርያም፡ በቃልኪ፡ እስመ፡ ተሳተፍኪ፡ ቃሎ፨</l>
                  <l n="4">ሰአልዮ፡ ለወልድኪ፡ ይጸግወኒ፡ ሣህሎ፨</l>
                  <l n="5">አመ፡ ውስተ፡ እሳት፡ ይወዲ፡ ኃጥኣነ፡ ምድር፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለሰኰናኪ፡ ወለመከየድኪ፡ እለ፡ ሖራ፨</l>
                  <l n="2">ውስተ፡ ደብረ፡ ቍስቋም፡ ለደቂቅ፡ አመ፡ ቀተልዎሙ፡ ሐራ፨</l>
                  <l n="3">ለአምላከ፡ ሰማይ፡ በሊዮ፡ ማርያም፡ ወለተ፡ ዕዝራ፨</l>
                  <l n="4">አማንኑ፡ ትኴንና፡ በእንተ፡ ፴ነገራ፨</l>
                  <l n="5">ለዘ፡ ታፈቅረኪ፡ ነፍስ፡ በኵሉ፡ ምግባራ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ሰላም፡ ለአጻብዕኪ፡ አቅርንተ፡ አእጋር፡ ክልኤቲ፨</l>
                  <l n="2">ወለአጽፋሪሆን፡ ለለአሐቲ፨</l>
                  <l n="3">በኪዳንኪ፡ ማርያም፡ ኀጢአትየ፡ ክብቲ፨</l>
                  <l n="4">ሰብእሰ፡ ካልእየ፡ እንዘ፡ ከማየ፡ መዋቲ፨</l>
                  <l n="5">በጽውዐ፡ ልሳን፡ ደምየ፡ ቀዲሖ፡ ይሰቲ፨</l>
               </lg>
               <lg type="stanza" n="34">
                  <l n="1">ሰላም፡ ለቆምኪ፡ አየረ፡ ትሩፋት፡ ዘሐፀኖ፨</l>
                  <l n="2">ወዐውሎ፡ ኀጢአት፡ ዘኢያጽነኖ፨</l>
                  <l n="3">በክንፈ፡ ኪዳንኪ፡ ክድንኒ፡ ማርያም፡ እምተኰንኖ፨</l>
                  <l n="4">ሶበ፡ ኪዳንኪ፡ ምክንያተ፡ ድኂን፡ ኢኮኖ፨</l>
                  <l n="5">ነፍሰ፡ በላዔ፡ ሰብእ፡ መኑ፡ እምክህለ፡ አድኅኖ፨</l>
               </lg>
               <lg type="stanza" n="35">
                  <l n="1">ሰላም፡ ለመልክአ፡ ሐና፡ ወኤልሳቤጥ፨</l>
                  <l n="2">ዘብዑድ፡ ሥኑ፡ ወልምላሜሁ፡ ፍሉጥ፨</l>
                  <l n="3">ማርያም፡ ድንግል፡ ድንግልተ፡ አፍኣ፡ ወውስጥ፨</l>
                  <l n="4">ቤዛ፡ ይኩነኒ፡ ኪዳንኪ፡ በገጸ፡ ፈጣሪ፡ ሥሉጥ፨</l>
                  <l n="5">አመ፡ ወርኀ፡ ንግድ፡ ዮኀልቅ፡ ወይፀራዕ፡ በሤጥ፨</l>
               </lg>
               <lg type="stanza" n="36">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስኪ፡ በነጽሮ፡ ብርሃን፡ ዘየኀቱ፨</l>
                  <l n="2">መልአከ፡ አፍርሆ፡ ጸሊም፡ እንበለ፡ ያደንግፅኪ፡ በጽላሎቱ፨</l>
                  <l n="3">ኣምሕለኪ፡ ማርያም፡ ለእግዚአብሔር፡ በመለኮቱ፨</l>
                  <l n="4">ከመ፡ ያድኅነኒ፡ በኪዳንኪ፡ እመደንግፃን፡ ሠለስቱ፨</l>
                  <l n="5">አመ፡ ይፈልጠኒ፡ ሞት፡ እምሥጋየ፡ ዝንቱ፨</l>
               </lg>
               <lg type="stanza" n="37">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋኪ፡ ዘኢጐንደየ፡ በምስካብ፨</l>
                  <l n="2">እስመ፡ አንሥኦ፡ ፍጡነ፡ መንፈሰ፡ ሕይወቱ፡ ለአብ፨</l>
                  <l n="3">ኢይትነከር፡ ለኪ፡ ማርያም፡ አድኅኖተ፡ ጻድቃን፡ ሕዝብ፨</l>
                  <l n="4">እስመ፡ አድኀንኪ፡ ኃጥኣነ፡ በኪዳንኪ፡ ጥበብ፨</l>
                  <l n="5">ዝኬ፡ መንክር፡ ወዝኬ፡ ዕጹብ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋኪ፡ በመዋጥሐ፡ ክታን፡ ወከርቤ፨</l>
                  <l n="2">ላዕለ፡ እደ፡ ጴጥሮስ፡ ብእሴ፡ ይባቤ፨</l>
                  <l n="3">ተሣሀልኒ፡ ማርያም፡ ወኢትበልኒ፡ አመ፡ ምንዳቤ፨</l>
                  <l n="4">ለምንት፡ ታአኵት፡ ኪዳንየ፡ ወረድኤትየ፡ ዐቃቤ፨</l>
                  <l n="5">ቅብአ፡ ኃጥኣን፡ አኮኑ፡ ኢይትቀባእ፡ እቤ፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ሰላም፡ ለመቃብርኪ፤ እለ፡ ይትጋብኡ፡ ባቲ፨</l>
                  <l n="2">ለአሕዛብ፡ ኵሎሙ፡ እስመ፡ ምክሖሙ፡ አንቲ፨</l>
                  <l n="3">ማርያም፡ ብጽሕኒ፡ ለሰዐተ፡ ሞትየ፡ ለመዋቲ፨</l>
                  <l n="4">እምነፍሰ፡ ክርስቲያን፡ አኮኑ፡ ሶበ፡ ይመውት፡ አሐቲ፨</l>
                  <l n="5">ለናዝዞታ፡ ፍጡነ፡ ትበጽሒ፡ አንቲ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ሰላም፡ ለትንሣኤኪ፡ ለትንሣኤ፡ ክርስቶስ፡ አምሳሊሁ፨</l>
                  <l n="2">አንቀጸ፡ መቃብር፡ ዝጉሐ፡ እንዘ፡ ኢያርኁ፨</l>
                  <l n="3">ማርያም፡ አንቲ፡ ለአዳም፡ ጥንተ፡ ተስፋሁ፨</l>
                  <l n="4">ሶበ፡ አኮ፡ ጸሎትኪ፡ ወኪዳንኪ፡ ምስሌሁ፨</l>
                  <l n="5">ውስተ፡ ዕመቀ፡ ሀጕል፡ እምኮነ፡ በነፍሱ፡ ወሥጋሁ፨</l>
               </lg>
               <lg type="stanza" n="41" xml:id="chaine3">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ ኀበ፡ መካነ፡ ሕይወት፡ ዘተሐደሰ፨</l>
                  <l n="2">እምቅድመ፡ ዝኒ፡ ኀቤሁ፡ ሥጋ፡ ወልድኪ፡ ፈለሰ፨</l>
                  <l n="3">ቤዛዊተ፡ ዓለም፡ ማርያም፡ ኣስተበቍዐኪ፡ አንሰ፨</l>
                  <l n="4">ትቤዝዊ፡ በኪዳንኪ፡ ዘጸላእትየ፡ ነፍሰ፨</l>
                  <l n="5">እስመ፡ በሥራይኪ፡ ለቍስልየ፡ ቀባእክኒ፡ ፈውሰ፨</l>
               </lg>
               <lg type="stanza" n="42">
                  <l n="1">ኣአኵቶ፡ ለእግዚአብሔር፡ ለዘጸውዐኒ፡ ጽዋዔ፨</l>
                  <l n="2">ተዝካረ፡ ኪዳንኪ፡ ንግበር፡ ማእከለ፡ ምንዱባን፡ ጉባኤ፨</l>
                  <l n="3">ተመጠዊዮ፡ ባሕቱ፡ ማርያም፡ አመ፡ ትንሣኤ፨</l>
                  <l n="4">ወአንብሪ፡ በርእሰ፡ ነፍሱ፡ አክሊላተ፡ መንግሥት፡ ሱባዔ፨</l>
                  <l n="5">ለነባቤ፡ ዝንቱ፡ ድርሰት፡ አርብዓ፡ ወክልኤ፨</l>
               </lg>
               <lg type="stanza" n="43">
                  <l n="1">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ አድባር፡ ወአውግር፨</l>
                  <l n="2">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ ዕፀዋት፡ ወሣዕር፨</l>
                  <l n="3">ስብሐት፡ ለኪ፡ ማርያም፡ በኈልቈ፡ ቀላያት፡ ወባሕር፨</l>
                  <l n="4">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ ኵሉ፡ ፍጡር፨</l>
                  <l n="5">ምሉእ፡ ስብሐትኪ፡ በሰማይ፡ ወምድር፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለኪ፡ ኪዳነ፡ ምሕረት፡ ትስፋየ፡ ዘታጸድቂ፡ ኃጥአ፨</l>
                  <l n="2">ወዘተኀሥሢ፡ አሐደ፡ በግዐ፨</l>
                  <l n="3">ዘተገድፈ፡ እምነ፡ ተስዓ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለኪ፡ ኪዳነ፡ ምሕረት፡ ሐውልት፡ ዘተከለኪ፡ እግዚእ፨</l>
                  <l n="2">ትእምርተ፡ አድኅኖ፡ ትኩኒ፡ ለኵሉ፡ ኃጥእ፨</l>
                  <l n="3">ፍቅርኪ፡ ዘያጸንዕ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለኪ፡ ኪዳነ፡ ምሕረት፡ በማይ፡ ዘታጸንኒ፡ መድሎተ፨</l>
                  <l n="2">ተአምኖተኒ፡ ብኪ፡ ረስዪ፡ ሊተ፨</l>
                  <l n="3">ገድልኪ፡ ወትሩፋተ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለኪዳነ፡ ምሕረት፡ ወርቅ፡ ወመዝገበ፡ ኵሉ፡ ንዋይ፨</l>
                  <l n="2">አንቲ፡ ውእቱ፡ ምስካበ፡ ነዳይ፨</l>
                  <l n="3">ወብዕል፡ ዘበሰማይ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለኪ፡ ሶበ፡ ስእንኩ፡ ጸዲቀ፡ በምግባረ፡ ሠናይ፡ ወገድል፨</l>
                  <l n="2">አስመኩ፡ ብኪ፡ ኪዳነ፡ ድንግል፨</l>
                  <l n="3">መድኀኒተ፡ ነፍስየ፡ እምነ፡ ሀጕል፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለኪ፡ ኪዳነ፡ ምሕረት፡ አንቲ፡ አረቦነ፡ መንፈስ፡ ዘላዕሉ፨</l>
                  <l n="2">ዘያፈቅረኪ፡ በተስፋ፡ ይሄሉ፨</l>
                  <l n="3">እስከ፡ አመ፡ ይከውን፡ ትንሣኤ፡ ኵሉ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለኪ፡ በስመ፡ ኪዳንኪ፡ ቤተ፡ ለዘሐነጸ፡ ገብርኪ፨</l>
                  <l n="2">ወለእመ፡ ጸለይነ፡ በስምኪ፨</l>
                  <l n="3">ማርያም፡ ፈትቲ፡ እምበረከትኪ፨</l>
                  <l n="4">ሰአሊ፡ ኀበ፡ ኄር፡ ወልድኪ፨</l>
               </lg>
            </div>
         </div>

      </body>
   </text></TEI>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="14v">1r-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>في مدحه العمر انفده فليس [...]| بمدح من مدحه متلو في [...] واحطن بذلك خور العين في [...] ||وانست الى ذاته <note>The page is broken</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14v">-14v</locus>وأعط سامعها خيرا وحابسها| وجد بالبركات واعمر مجالسها يا وافر الفضل والاحسان والنعم

واله العرو الصحب الذين علوا اهل الوفا والصفا| والجود والكرم| ووالدى وما عفىت من خلقى والمسلمين من العراب والعجم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="16r" to="16r">16r-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1163IHA">نظم الوهم لا يدركه</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>بسم الله الرحمن الرحيم | الوهم لا يدركه |والعجز لا يلحقه|| فهوه الذي نعبده | جل اله هو هو</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus> سواك من أقصده|| يا راحم الشيب أجر | من حر نار تستعر|| [عيلا مكاتاك منكسل] | سواك من مجبره 
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="50r" to="50v">50r-50v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3856IHA">نظم بريق الغور من أكتاف رامه</title>
                     <incipit xml:lang="ar">
                        <locus target="#50r ">-50r </locus>الله الله | بريق الغور من أكتاف رامه شجا قلبى وذكره عرامه | وأجرى كالعقيق دموع عينى فأخجل فيضها فيض الغمامه | 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#50v ">-50v </locus>وبان الحى ما شجعت حمامه | فتلك مواطن الصب المعنى بها | الأرواح صارت مستهامه | على عرب تهامى السلامه | يكون المسك من قلبى خيامه </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="50v " to="52r">50v -52r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4629IHA">دعاء لقد اصبحت من شوقي</title>
                     <incipit xml:lang="ar">
                        <locus target="#50v ">-50v </locus>الله الله لقد اصبحت من شوقي عليلا وما شفيت من ليلا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52r">-52r</locus>انا ملى غضبا اليها واكن ارجوا عفوك وحسن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="52r" to="52v">52r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4630IHA">دعاء ملوك الارض رباب الرعايا</title>
                     <incipit xml:lang="ar">
                        <locus target="#52r ">-52r </locus> الله الله ملوك الارض رباب الرعايا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>فهل حي يصاب على البواري</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="52v" to="53r">52v-53r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4631IHA">دعاء سلوا الرحمن رب العالمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#52v">-52v</locus>الله الله سلوا الرحمن رب العالمين وكانو ابا لاجبا به</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53r">-53r</locus>وعلى اله وصحبه اجمعينا الهي قد جعلت الخير فينا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="53r" to="53v">53r-53v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3754IHA">نظم لا يطعم المر إلا من عشق</title>
                     <incipit xml:lang="ar">
                        <locus target="#53r ">-53r </locus>لا اله الا الله لا اله الا الله

لا يكعم المر الاكل من عشقا | وليس من قال اني عاشق صد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53v">-53v</locus>قلا تردنها يا رب خايبة| فجر جودك يروى كل من يرد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="53v" to="53v">53v-53v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4632IHA">صلاة على النبي يا خاتم الانبياء يا سيد المرسلين</title>
                     <incipit xml:lang="ar">
                        <locus target="#53v">-53v</locus>لا اله الا الله لا اله الا الله ثم ذلك | العلمين يا خاتم الانبيا يا سيد المرسلين| يا صفوة الاصفيا يا ارحم الراحمين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53v">-53v</locus>بكل محبوب وسول| فلم يزل معطيا مجيب للسايلين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="53v" to="55r">53v-55r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4633IHA">دعاء بسمك الله ربي ابتدى في كل خطبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#53v">-53v</locus>لا اله الا الله لا اله الا الله لا اله الا الله محمد رسول الله| باسمك الله ربي ابتدى في كل خطبي |انت مولاي وحسبي نظر منك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#55r">-55r</locus>يا مودن قم فاذن للصلوة والعباد يا منادي قم فنادي نظر منك كفا في</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="55r" to="55r">55r-55r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4634IHA">نظم لاح برق ثهمد في الدجاعيم</title>
                     <incipit xml:lang="ar">
                        <locus target="#55r">-55r</locus>الصلوة على احمد دائما مديم| الدى سكن في حىه| لاح برق ثهمد في الدجاعيم| بت صب معمد ابكي كاليتم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#55r">-55r</locus>كف عن ملامي أيها العزول| مذهبي غرامي عنه لا احول</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="55r" to="55r">55r-55r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4635IHA">دعاء يا من توجه اليه كلمي</title>
                     <incipit xml:lang="ar">
                        <locus target="#55r">-55r</locus>الله الله الله الله قيوم لاقى والكل فامى| يا من توجه اليه كلمي| ومن كان في الموبقات عوني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#55r">-55r</locus>يمح كل ذنبي بالنبي الحبيب| الشفيع في غد للذي عديم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="55v" to="56v">55v-56v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3842IHA">نظم شربت كأسا من المعانى</title>
                     <incipit xml:lang="ar">
                        <locus target="#55v">-55v</locus>الله الله الله الله قيوم باقى وكل قامى| سربت كاسا من المعاني| عاينت منها بلا عيافي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#56v">-56v</locus>الصلاة على النبي والسلام على النبي الشفيع الابطحي والحبيب الغربي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="16v" to="16v">16v-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2983IHA">نص الصلاة والسلام الاتمان الاكملان</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>بسم الله الرحمن الرحيم بسم الله والحمد لله والصلوة والسلام الاتمان الاكملان ونبتدى| ببسم الله ونسوق ميعه المولد اعوذ بالله من الشيطان الرجيم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>وبلغ رسوله النبي الكريم , والحمد لله رب العالمين | ان الله وملئكته يصلون على النبي , يايها الذين امنوا صلوا عليه وسلموا تسليما </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i21">
                     <locus from="56v" to="57r">56v-57r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4637IHA">نظم على ذكركم لذلي مشربوا</title>
                     <incipit xml:lang="ar">
                        <locus target="#56v">-56v</locus>اللهم صل وسلم على حبيبك محمد عليه السلام| على ذكركم لذلي مشربوا| وقتي بكم سادتي طيبوا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57r">-57r</locus>وارضاهم في فراجسه| وعلى المنازل بواهم| فارضاهم بالرضي عنهم وعن ساير الخلق اغناهم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i22">
                     <locus from="57r" to="57v">57r-57v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0411IHA">دعاء الهى الهى اجب سائلا كثير الذنوب قليل العمل</title>
                     <incipit xml:lang="ar">
                        <locus target="#57r">-57r</locus>اللهم صل وسلم على حبيبك محمد عليه السلام | 
الهى الهى اجب سائلا كثير الدنوب قليل العمل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57v">-57v</locus>ابن الرسول| ومآحي جواجر وحد الامين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i23">
                     <locus from="57v" to="58r">57v-58r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4636IHA">نظم غيب ما خلي رغيب عن وصالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#57v">-57v</locus>الله الله الله الله الله الله الله الله الله الله رب الله | [غيب] ما خلي| رغيب عن وصالي| بصبحي وليلي| مقاصي وصالي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#58r">-58r</locus>وعن غير هذا فمهلا فمهلا الا يا حداتي ايخوا جمافي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i24">
                     <locus from="58r" to="58v">58r-58v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3756IHA">دع الأمال يا رجال</title>
                     <incipit xml:lang="ar">
                        <locus target="#58r">-58r</locus>لا اله الا الله لا اله الا الله [...] | دع الامال يا رجل فلا تدري متي الاجل فقدم يا احى عملا ليوم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#58v">-58v</locus>بهم ندعوا الي المولي بطفر غنا الوزري فلا سيما كابرهيم فانه موفر الظهره</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i25">
                     <locus from="58v" to="59v">58v-59v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1030IHA">حزب النصر</title>
                     <incipit xml:lang="ar">
                        <locus target="#58v">-58v</locus>  الله الله الله الله الله الله الله الله لله
 يامصطفى شي الله


ان ابطأت غارت الارحام و ابتعدت فأقرب الشيء منا غارة الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#59v">-59v</locus>
                        <note>Blurred</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="16v" to="17v">16v-17v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0589IHA">سلامات على النبي السلام عليك زين الأنبياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>السلام عليك زين الانبياء السلام عليك| السلام عليك اصفا الاصفياء السلام عليك| السلام عليك احمد يا محمد السلام عليك | السلام عليك طه يا ممجد السلام عليك 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17v">-17v</locus>السلام على علي السامى يقينا السلا عليك |لسلام على اصحابك اجمعين السلام عليك |السلام على الك كلهم والتابعينا
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="17v" to="48r">17v-48r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0706IHA">عنوان الشريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#18r ">-18r </locus>بسم الله الرحمن الرحيم الحمد لله الذى شرف العالمين| بأشرف العالمين |واصطفاه من خلقه أجمعين| ونبأه وءادم بين الماء والطير| ونوه بذكره فى الاخرين والاولين| كما شرف بقدره فى الاخرين| خلق ءادم من سلالة من طين| فما ختمت صدفة جسده الاعلى درة محمد خاتم النبيين 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#48r">-48r</locus>كيف التصبّر والسلوان عن قمر| موافقي في هواه العجم والعرب 
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="46v" to="47v">46v-47v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3785IHA">دعاء ختم المولد الشريف اللهم انا قد حضرنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#46v">-46v</locus>بسم الله الرحمن الرحيم اللهم إنا قد حضرنا قرأة مولد نبيك الكريم فأفض علينا ببركة 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#47v">-47v</locus>اللهم ما قدرت من قضاء وقدر فسلم لنا فيها العقل والدين وافضل الدين وافضل الصلاة والتسليم على اشرف الخلق سيدنا محمد الذي جأ بالحق المبين وأرسلته رحمه للعالمين وعلى اله وصحبه اجمعين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="48v" to="49v">48v-49v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0737IHA">مدح النبي أبتدئ بسم الكريم</title>
                     <incipit xml:lang="ar">
                        <locus target="#48v">-48v</locus>الف صلي الله على احمد |ابتدي باسم الكريم ٬ وبحمد الله ثاني , ثالثا بالصلوات , بالنبي الهادي الشفيع </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#49v">-49v</locus>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="49v" to="49v">49v-49v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3859IHA">نظم نسيم الوصل هب على الندام</title>
                     <incipit xml:lang="ar">
                        <locus target="#49v">-49v</locus>الله الله نسيم الوصل هب على الندا ما فأسكرهم وما شربوا مداما
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#49v">-49v</locus>ينال الوصل من سحر الليالى على الاقدام وألخلة الصياما | فما مقصودهم جنات عدن ولا الحور الحسان ولا خياما | سوى نظر الجليل فهو مناهم فهذا مقصد القوم الكراما
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="49v" to="50r">49v-50r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4012IHA">نظم الاهي قد جعلت الخير فينا</title>
                     <incipit xml:lang="ar">

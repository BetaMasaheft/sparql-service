                  <idno facs="EMIP/Codices/2271/" n="46" corresp="https://betamasaheft.eu/api/iiif/EMIP02271/manifest">Weiner Codex 272</idno>
               </msIdentifier>
               <msContents>
                  <summary>Bandlet of Righteousness</summary>
                <msItem xml:id="ms_i1">
                  <locus from="1r" to="23r" facs="002">Fols 1r–23r</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">i + 28 panels</measure>
                           <dimensions type="outer" unit="mm">
                              <height>85</height>
                              <width>55</width>
                              <depth>16</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="9 10"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  <foreign xml:lang="gez">ሚካኤል፡</foreign>
                  <foreign xml:lang="gez">ገብርኤል፡</foreign>
                  </seg>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="frame" xml:id="d1">
                    Decorative designs:
                    <locus target="#23r" facs="024">fol. 23r</locus> multiple full stops
                  </decoNote>
                </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto) #iv(erso) #14r #25v #26v" facs="001 002 015 027 028">Fols. ir(ecto), iv(erso), 14r, 25v, 26v</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#6v" facs="008"> f. 6v and passim</locus>
                    space for the name of the owner has been left blank
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#10v" facs="012">Fol. 10v</locus>
                    the name of the owner has been erased
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#14v" facs="016">Fol. 14v</locus>
                    pentrials
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#23v" facs="025">Fol. 23v</locus>
                    incomplete Trinitarian formula
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#24r #26r" facs="025 027">Fols. 24r, 26r</locus>
                    several words in an untrained hand
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <locus target="#24v #25r" facs="026">Fols. 24v, 25r</locus>
                    several lines of text mentioning Tǝrsitä Bǝrhan (<foreign xml:lang="gez">ትርሲተ፡ ብርሃን፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#27r" facs="028">Fol. 27r</locus>
                    Faded secondary text written in pencil
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#27v #28r" facs="029">Fols. 27v, 28r</locus>
                    several lines of text written in pen and pencil
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Accordion-fold codex attached to rough-hewn boards of the traditional wood, three strips of parchment.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1999">Twentieth century</origDate>
                  </origin>
               </history>

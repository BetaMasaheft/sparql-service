                    <msContents>
                        <summary/>

                        <msItem xml:id="ms_i1">
                            <locus from="3r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3854KingList">King list B</title>
                            <textLang mainLang="gez"/>
                            <note>The list end with
                              <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas I</persName>, the son of
                              <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>.</note>
                      </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="5r"/>
                            <title type="complete" xml:lang="gez">History of
                            <persName ref="https://betamasaheft.eu/PRS7091Mikael">Mikāʾel Sǝḥul</persName>, especially of his
                          struggle with daǧǧāzmāčč Waldu.</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                          <locus from="6r"/>
                          <title type="complete" xml:lang="en">Account of the reign of
                          <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>.</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                          <locus from="7r"/>
                          <title type="complete" xml:lang="en">Account of the reign of
                          <persName ref="https://betamasaheft.eu/PRS4015Fasilada">Fāsiladas</persName>.</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>


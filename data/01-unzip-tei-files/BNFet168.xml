               <msContents>
                  <summary/>
              
                  <msItem xml:id="ms_i1">
                    <title type="complete" ref="https://betamasaheft.eu/LIT1546Genesi">Amharic Genesis</title> 
                    <textLang mainLang="am"/>
                    <note>This is the translation by <persName role="translator" ref="https://betamasaheft.eu/PRS1356AbuRumi">Abu Rumi</persName>.</note> 
                     
                    <note>This exemplar shows some variants and divergences in its use of <foreign xml:lang="am">ኸ</foreign> / <foreign xml:lang="am">ኀ</foreign> / <foreign xml:lang="am">ሐ</foreign> and 
                      <foreign xml:lang="am">ጠ</foreign> / <foreign xml:lang="am">ጸ</foreign> / <foreign xml:lang="am">ፀ</foreign>. For example:
                      <p>
                           <foreign xml:lang="am">መሐከልም፡</foreign> for <foreign xml:lang="am">መኻከልም፡</foreign>  (Gen 1:7);</p>
                        <p>
                           <foreign xml:lang="am">ይገለጽ፡</foreign> for <foreign xml:lang="am">ይገለጥ፡</foreign> (Gen 1:9);</p>
                        <p>
                           <foreign xml:lang="am">አወፃች፡</foreign> for <foreign xml:lang="am">አወጣች፡</foreign>  (Gen 1:12);</p>
                        <p>
                           <foreign xml:lang="am">ማሐልም፡</foreign>  (Gen 1:18);</p>
                        <p>
                           <foreign xml:lang="am">ውሐይቱ፡ ታውፃ፡</foreign>  (Gen 1:20);</p>
                        <p>etc.</p>
                     </note>
                  </msItem>
              
               </msContents>
          

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" facs="003">Fols 1r and following</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest">ʾAmmǝstu ʾaʿǝmāda
                                                  mǝśṭir</title>
                    <textLang mainLang="am">Amharic</textLang>
                    <msItem xml:id="ms_i1.1">
                      <locus from="1r" to="5r" facs="003">Fols 1r–5r</locus>
                        <title>Introduction</title>
                        <incipit xml:lang="am"><gap reason="omitted"/>
                        በአብም፡ በወልድም፡ በመንፈስ፡ ቅዱስም፡ ሶስት፡ አካል፡ አንድ፡ አምላክ፡ በሚሆን፡ እታመናለሁ፡ ይላል፡ ክርስቲያናዊ፡ ሰው፡ የክርስቶስ፡ ወገን፡ የሆነ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="5r" to="25r" facs="007">Fols 5r–25r</locus>
                        <title>The Mystery of the Trinity</title>
                        <incipit xml:lang="am">
                          ማን፡ ፈጠረህ፡ እግዚአብሔር፡ እግዚአብሔር፡ ስንትነው፡ ሶስትም፡ ነው፡ አንድም፡ ነው፡ ሶስትነቱ፡ በምን፡ ነው፡ በአካል፡ በስም፡ በግብር፡ አካል፡ ማለት፡ ምን፡ ማለት፡ ነው፡ የእጊዝአብሔር፡ ቁመቱ፡
                          እንደ፡ ሰውን፡ አጭር፡ ነው፡ ግዙፍነው፡ የተወነን፡ ነው፡ አይዶለውም፡ እንዴት፡ ነዋ፡ ምሉዕ፡ ነው፡ ረቂቅ፡ ነው፡<gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="25r" to="54v" facs="027">Fols 25r–54v</locus>
                        <title>The Mystery of the Incarnation</title>
                        <incipit xml:lang="am">
                          ከሦስቱ፡ አካላት፡ ማን፡ ሥጋ፡ ለበሰ፡ አካለ፡ ወልድም፡ ነው፡ አንሶን፡ ዕፃ፡ ወፅቶ፡ የበተን፡ አንሶም፡ ዕፃ፡ ወዕቶበትም፡ አይደለወም፡ አብ፡ ሥጋ፡
                          ቢለብስ፡ አብም፡ ወልድም፡ ይባል፡ መንፈስ፡ ቅዱስ፡ ሥጋ፡ ቢለብስ፡ መንፈስ፡ ቅዱስም፡ ወልድም፡ ይባል፡ ወልድ፡ ግን፡ በጥንት፡ ስሙ፡ መጸራት፡ በተለየ፡ አካሉ፡ ሥጋ፡ ለበሰ፡<gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.4">
                        <locus from="54v" to="55r" facs="057">Fols 54v–55r</locus>
                        <title>The Mystery of Baptism</title>
                        <incipit xml:lang="am">ይህ፡ የምንጠመቀመው፡ ጥምቀት፡ ምንድር፡ ነው፡ ተጎድኑ፡ የወፃ፡ ወሀ፡ ነው፡ ተጐድኑ፡ የወፃ፡ ወሀ፡ ለምን፡ ይሆናል፡ ይኸሳ፡ ዛሬ፡ ቄስ፡ በሥልጣኑ፡
                          ስንዴንና፡ ወይንን፡ በባረከ፡ ጊዜ፡ ፍጹም፡ ሥጋ፡ መለኮት፡ ይሆናል፡ ወሀንም፡ እንድያ፡<gap reason="omitted"/></incipit>
                        <note>This section is unusually short in this manuscript</note>
                      </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus from="55r" to="57v" facs="057">Fols 55r–57v</locus>
                        <title>Mystery of communion, <foreign xml:lang="am">ምሥጢረ፡ ቍርባን፡</foreign></title>
                        <incipit xml:lang="am">
                          የማንን፡ ሥጋ፡ ትበላለህ፡ የወልድን፡ አብና፡ መንፈስ፡ ቅዱስ፡ ሥጋ፡ ለበሱ፡ ሥጋ፡ የለበሰ፡ ወልድ፡ እንጂ፤ ነው፡ የወልድን፡ ሥጋ፡ እበላለሁ፡ ወልድን፡ ዓረገ፡ አልህሳ፡ ሥጋውንት፡ ጥሎ፡ ዓረገ፡ ዳግምን፡ ይመጻል፡ አይደለውም፡ እንዴት፡
                          ነዋ፡ ቀድሞ፡ የጸሎት፡ ሐሙስ፡ ዕለት፡ ስንዴውንና፡ ወይኑን፡ አክብሮ፡<gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.6">
                        <locus from="57v" to="60v" facs="060">Fols 57v–60v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Resurrection">ʾAmmǝstu ʾaʿǝmāda mǝśṭir, Mystery ofthe
                                                  Resurrection (ምሥጢረ፡ ትንሣኤ፡)</title>
                        <incipit xml:lang="am"><gap reason="omitted"/>
                        እንዴት ትነሣለህ፡ ከፈረስህ፡ ከበሰበስህ፡ በኋላ፡ እንዴት፡ ትነሣለህ፡ ይኽሳ፡ እኽል፡ ስንኳን፡ ቢዘሩት፡ ፈርሶ፡ በስብሶ፡ አካል፡ ገዝቶ፡ የጥንቱ፡ ልብሱን፡ ለብሶ፡ ይነሣል፡ ከህልን፡ እብስ፡ እኔም፡ እንዲያ፡
                        እነሣለሁ፡ እንዴት፡ ባለ፡ ስራ፡ ትነሣለህ፡ በጎ፡ ምግባር፡ ብሰራ፡ እንደ፡ ምሆ፡ ረቂቄ፡ እንደ፡ ቢረሌ፡ ጸርቼ፡ ብርሃን፡ ለብሼ፡ ብርሃን፡ ተጐናጽፌ፡<gap reason="omitted"/></incipit>
                      </msItem>
                    </msItem>
                    <msItem xml:id="ms_i2">
                      <locus from="60v" to="66v" facs="063">Fols 60v–66v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5628CommCreed">Commentary on the
                                                  Nicene Creed</title>
                      <incipit xml:lang="am">(ጸሎተ፡) ሃይማኖት፡ ዘ፫፻ በማን፡ ታምናለህ፡ በእግዚአብሔር፡ እግዚአብሔር፡ ስንት፡ ነው፡ አንድም፡ ነው፡ ሶስትም፡ ነው፡ ሶስትነቱ፡ በማነው፡ በአካል፡</incipit>
                    </msItem>
                    <msItem xml:id="ms_i3">
                      <locus from="67r" to="67v" facs="069">Fols 67r–67v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3056RepCh336">Hymn to Our Lady
                                                  Mary</title>
                      <incipit xml:lang="gez">እሰግድ፡ ለኪ፡ ኦእግዝእትየ፡ ማርያም፡ ድንግል ለፀሐየ፡ ጽድቅ፡ ሰረገላ፡ …</incipit>
                    </msItem>
                    <msItem xml:id="ms_i4">
                      <locus from="68r" to="104r" facs="070">Fols 68r–104r</locus>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT3308Nicene">Nicene Creed</title>
                      <incipit xml:lang="gez">
                      <gap reason="omitted"/>በስመ፡ ኃዳሪ፡ ይጼዋዕ፡ ብሔር፡ ወብስመ፡ ብሔር፡ ይጼዋእ፡ ኃዳሪ፡ ይላል፡ ሃይማኖተ፡ አበው፡ <gap reason="omitted"/>
                      ምሁረ፡ መጽሐፍነቱን፡ ግን፡ ቢያውቁበት፡ በሥጋው፡ ሞት፡ በነፍሱ፡ ገሃነመ፡ እሳት፡ አስፈረዱበት፡ ምን፡ ቢል፡ ያልኽ፡ እንደሆነ፡ እግዚአብሔር፡ አብ፡ ዓለምን፡ ይፈጥር፡ ቢወድ፡ ወልድን፡ ፈጠረ፡<gap reason="omitted"/></incipit>
                      <note>incomplete at the beginning</note>
                    </msItem>
                    <msItem xml:id="ms_i5">
                      <locus from="105r" to="116r" facs="107">Fols 105r–116r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">Malkǝʾa
                                                  Śǝllāse</title>
                      <incipit xml:lang="gez">ሰላም፡ ለህላዌክሙ፡ ዘይመውዕ፡ ህላውያተ፡ <gap reason="omitted"/></incipit>
                    </msItem>
                    <msItem xml:id="ms_i6">
                      <locus from="116r" to="119v" facs="118">Fols 116r–119v</locus>
                      <title ref="https://betamasaheft.eu/LIT6467Heresies">List of Heretics</title>
                      <incipit xml:lang="gez">ናሁ፡ ንጽሕፍ፡ አስማቲሆሙ፡ ለመናፍቃን፡ ሰባልዮስ፡ ይቤ፤ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ገጽ፡ ናሁ፡ ንቤ፡ ፫ቱ፡ ገጽ፡ ፩ራዕይ፡ ፫ቱ፡ አካል፡ <gap reason="omitted"/></incipit>
                    </msItem>
               </msContents>

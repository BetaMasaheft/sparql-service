               <msPart xml:id="p1">
                  <msIdentifier/>
                  <msContents>
                     <summary>I) Gadla Gabra Manfas Qǝddus (fols. 1ra-25vb, 36ra-55vb, 65ra-75rb),
                        possibly incomplete, some fols. are misplaced 
 II) Taʾammǝra Gabra Manfas
                        Qǝddus: 13 miracles (fols. 26ra-35vb, 56ra-66vb)
 
 Additiones
                        1-4.</summary>
                     <msItem xml:id="p1_i1">
                        <title ref="https://betamasaheft.eu/LIT1119DossierQMQ">Hagiographic Dossier of St Gabra Manfas Qǝddus</title>
                        <textLang xml:lang="gez"/>
                        <msItem xml:id="p1_i1.1">
                        <locus from="1ra" to="25vb"/>
                        <locus from="36ra" to="55vb"/>



                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1451GadlaG">Gadla Gabra Manfas Qǝddus (general record)</title>
                        <note>possibly incomplete, some fols. are misplaced, continues in the <ref target="#p2">second unit</ref>
                        </note>
                     </msItem>

                     <msItem xml:id="p1_i1.2">
                        <locus from="26ra" to="35vb"/>
                        <locus from="56ra" to="66vb"/>


                        <title type="incomplete" ref="https://betamasaheft.eu/LIT3977Taammer">Taʾammǝra Gabra Manfas Qǝddus</title>
                        <note>13 miracles</note>
                     </msItem></msItem>
                  </msContents>

                  <physDesc>
                     <handDesc>
                        <handNote xml:id="h1" script="Ethiopic">
                           <locus from="1r" to="66v">1r-66v</locus>
                           <seg type="script">Both mediocre; angular.</seg>
                           <seg type="ink">Black; red.</seg>
                           <date>18th century</date>
                           <persName role="scribe" ref="https://betamasaheft.eu/PRS12073WaldaTaklaH">Walda Takla
                              Hāymānot</persName> is mentioned as the scribe in the supplication
                           formulas: <locus target="#32vb #36rb, 55vb">32vb, 36rb, 55vb</locus>.
                              <seg type="rubrication">Nomina sacra; name of the protagonist and
                              other saints; names of the donors; name of the scribe; incipit of Text
                              I and its sections; groups of lines (alternating with black lines) on
                              the incipit page of Text II; incipits of the miracles; elements of the
                              punctuation signs; elements of Ethiopic numerals.</seg>
                        </handNote>


                     </handDesc>
                     <decoDesc>

                        <decoNote type="drawing" xml:id="d1">
                           <locus target="#36r">f. 36r: </locus>
                           <desc>Two crosses.</desc>
                        </decoNote>
                        <decoNote type="band" xml:id="d2">- <locus target="#33va">33va</locus>:
                           Narrow and simple uncoloured horizontal ornamental band.</decoNote>
                        <decoNote type="band" xml:id="d3">- <locus target="#71rb">71rb</locus>:
                           Narrow coloured (black, red) horizontal ornamental band
                           (interlaces).</decoNote>
                     </decoDesc>
                     <additions>
                        <list>
                           <item xml:id="a1">
                              <locus target="#32vb">f. 32vb</locus>l. 8: <desc type="DonationNote">Donation note.<q xml:lang="gez"> ለዘቲ፡ መጽሐፍ፡ ዘወሀቦ፡ ለቅዱስ፡ [ዮሐን]ስ፡
                                    መጥምቅ፡ ዘ&lt;...&gt;፡ ወልደ፡ ኪዳን፡ ወብእሲቱ፡ አመተ፡ ሚካኤል፡ ዘስረቆ፡ ወዘፈሐቶ፡
                                    በሥልጣነ፡ ጴጥሮስ፡ ወጳውሎስ፡ በአፈ፡ ፫፻፲ወ፰፡ ርቱአነ፡ ሃይማኖት፡ በሥል{ጣነ}፡ አብ፡ ወወልድ፡
                                    ወመንፈስ፡ ቅዱስ፡ ውጉዛ፡ ለይኩን፡ ውስተ፡ ተአምረሃ፡ ሊታብጥሉ፡ ካህናቲሁ፡ ለዮሐንስ፡ ለዓለመ፡
                                    ዓለም፡ አሜን።</q> Mention of the names of donors, <persName role="donor" ref="https://betamasaheft.eu/PRS12064WaldaKidan">Walda Kidān</persName> and
                                 his wife <persName ref="https://betamasaheft.eu/PRS12065AmataMikael">ʾAmata
                                    Mikāʾel</persName>. Mention also of the name of the tābot (or
                                 original place?) to which the Ms. was donated: Yoḥannǝs
                                 Maṭmǝq.</desc>
                           </item>
                           <item xml:id="a2">
                              <locus target="#33ra #33rb">f. 33ra-rb</locus>: <desc type="Record">Record concerning calendaric calculation: estimation of waning
                                 moon and full moon periods of months.<quote xml:lang="gez"/>
                                 <quote xml:lang="en"/>
                              </desc>
                           </item>
                           <item xml:id="e1">
                              <desc type="findingAid">- Notes in the upper margin of some fols.
                                 (possibly in the same hand) indicate the monthly readings from the
                                 Vita of Gabra Manfas Qǝddus as follows: <locus target="#9v">Fol.
                                    9v</locus>: Ḥamle; <locus target="#14v">Fol. 14v</locus>:
                                 Naḫāśe; <locus target="#20v">Fol. 20v</locus>: Maskaram; <locus target="#27v">Fol. 27v</locus>: Ḫǝdār; <locus target="#30r">Fol.
                                    30r</locus>: Maggābit; <locus target="#33v">Fol. 33v</locus>:
                                 Yakkātit; <locus target="#36r">Fol. 36r</locus>: Tāḫśāś; <locus target="#41v">Fol. 41v</locus>: Ṭǝrr; <locus target="#45r">Fol.
                                    45r</locus>: Gǝnbot; <locus target="#51v">Fol. 51v</locus>:
                                 Sane; <locus target="#52v">Fol. 52v</locus>: Ṭǝrr; <locus target="#60r">Fol. 60r</locus>: Miyāzyā; <locus target="#71r">Fol. 71r</locus>: Ṗāqʷǝmen.</desc>
                           </item>
                        </list>
                     </additions>
                  </physDesc>
               </msPart>

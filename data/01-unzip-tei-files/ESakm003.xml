                  <bindingDesc>
                     <binding contemporary="false">
                        <decoNote xml:id="b1">Two wooden boards (the back board is missing).
                           Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Originally, the binding consisted of
                           animal threads (traces in <locus from="64v" to="65r">64v-65r</locus>,
                           70v-71r) in two pairs of sewing stations (holes visible on the folds of
                           the quires). But it was destroyed and the Ms. was rebounded with
                           vegetal threads in two sewing stations (e.g. <locus from="55v" to="56r">55v-56r</locus>). Later (?), the board attachment was repaired with
                           synthetic threads.</decoNote>
                        <decoNote xml:id="b5">None</decoNote>
                     </binding>

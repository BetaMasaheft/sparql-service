         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ስመ፡ ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ አቀድም፡ ጸውዖ፨</l>
                  <l n="2">ለሰይጣን፡ ፀርየ፡ በዘእመውኦ፨</l>
                  <l n="3">ናሁ፡ እወጥን፡ ለስብስትያኖስ፡ መልክኦ፨</l>
                  <l n="4">ለዘአንበቦ፡ በጽሒቅ፡ ወለብእሲ፡ ዘሰምዖ፨</l>
                  <l n="5">እመዕይንተ፡ ሞት፡ ወትረ፡ ሣህሉ፡ ይኅብኦ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ናሁ፡ እወጥን፡ በእንቲአከ፡ ማሕሌተ፨</l>
                  <l n="2">ዘያስተፌሥሕ፡ ሕሊና፡ ወዘይጼጉ፡ ሕይወተ፨</l>
                  <l n="3">ስብስትያኖስ፡ ትጋህ፡ በዘትትራድአኒ፡ ሊተ፨</l>
                  <l n="4">ከመ፡ ይተግህ፡ ብእሲ፡ እንዘ፡ ይገብር፡ ሠናይተ፨</l>
                  <l n="5">እለ፡ ይሣርሩ፡ ቦቱ፡ ወየሐንጹ፡ ቤተ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ጊዜ፡ እነብብ፡ ስብሐቲከ፡ በልሳንየ፡ ነባቢ፨</l>
                  <l n="2">ስብስትያኖስ፡ ዘጽርዕ፡ ወአኮ፡ ዘብሔረ፡ ዐረቢ፨</l>
                  <l n="3">አሠንዮ፡ አንተ፡ በጥበብከ፡ መጥበቢ፨</l>
                  <l n="4">ከመ፡ ያሠንዮ፡ ለወርቅ፡ ነሃቢ፨</l>
                  <l n="5">ወለዕፅኒ፡ ብእሲ፡ ጸራቢ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሆህያቲሁ፡ ኀምስ፡ ወክልኤቱ፨</l>
                  <l n="2">አምሳለ፡ ነጐድጓድ፡ ሰባዕቱ፨</l>
                  <l n="3">ስብስትያኖስ፡ ሥመር፡ ለቃለ፡ ውዳሴከ፡ ዝንቱ፨</l>
                  <l n="4">ወዝክረ፡ ስምየ፡ ከመ፡ ኢይጥፋዕ፡ በከንቱ፨</l>
                  <l n="5">በሰሌዳ፡ ሕይወት፡ ጸሐፎ፡ ወልክኦ፡ ሎቱ፨</l>
               </lg>
               <lg type="stanza" n="60">
                  <l n="1">ኅድግሰ፡ ስብስትያኖስ፡ እለ፡ እምኔየ፡ ተወልዱ፨</l>
                  <l n="2">እምነ፡ አዕርክትየ፡ ጸላኢ፡ ከመ፡ ኢያሙት፡ አሐዱ፨</l>
                  <l n="3">አኮኑ፡ ይቤሉ፡ እግዚኦ፡ ለእለ፡ ተፋቅሮ፡ ለመዱ፨</l>
                  <l n="4">ፍቁረ፡ ለፍቁር፡ ማእከለ፡ ባሕር፡ የዐዱ፨</l>
                  <l n="5">ለእመ፡ ምስሌሁ፡ ኅቡረ፡ በፍኖት፡ ነግዱ፨</l>
               </lg>
            </div>
         </div>
      </body>

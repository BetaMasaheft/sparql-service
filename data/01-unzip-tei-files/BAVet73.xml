               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1" to="132v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano">ʾArgānona wǝddāse</title>
                     <note>
                        Six miracles of Mary are inserted between the readings for the weekdays.
                     </note>
                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="23v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Monday">ʾArgānona wǝddāse, for Monday</title>
                        <note/>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus target="#23v"/>
                        <title type="complete" cert="unknown" ref="https://betamasaheft.eu/LIT3908Miracle">Miracle of the apparition of Our Lady Mary to the pious child</title>
                        <incipit xml:lang="gez">ተብህለ፡ ከመ፡ ሀሎ፡ ፩ሕፃን፡ ንዑስ፡ ዘያፈቅራ፡ ለእግ<supplied reason="explanation">ዝእትነ፡</supplied>
                        </incipit>
                        <explicit xml:lang="gez">ወውእቱሰ፡ ሕፃን፡ ኮነ፡ ኅጽወ፡ ለመንግሥተ፡ ሰማያት፡ በረከተ፡ ጸሎታ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="24r" to="45r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Tuesday">ʾArgānona wǝddāse, for Tuesday</title>
                        <note>The text includes a short introduction and a long conclusive blessing.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="45v" to="67v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Wednesday">ʾArgānona wǝddāse, for Wednesday</title>
                        <note>The text includes a short introduction and a long conclusive blessing.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus target="#67v"/>
                        <title type="complete" cert="unknown" ref="https://betamasaheft.eu/LIT3599Miracle">Miracle of the church destroyed in Jericho</title>
                        <note/>
                        <incipit xml:lang="gez">ተአምሪሃ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ስምዑ፡ ዘኮነ፡ በሀገረ፡ ጽርእ፡
                        ወሀሎ፡ ደብር፡ በጽንፈ፡ ባሕር፡ ዘኢያሪኮ፡</incipit>
                        
                        <explicit xml:lang="gez">ወወረ<supplied reason="omitted">ደ</supplied>ት፡ ታሕተ፡ ጽንፈ፡ ኢያሪኮ፡ 
                              <sic>ወጽንዓ፡</sic>
                            በኃይለ፡
                           እግዚአብሔር።</explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="68r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Thursday">ʾArgānona wǝddāse, for Thursday</title>
                        <note>The text includes a short introduction and a long blessing after the explicit.</note>
                        <explicit xml:lang="gez">
                           ይቤ፡ በመልእክቱ፡ ለብሔረ፡ ሮሜ፨ ጳውሎስ፡ ገብሩ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተሰምየ፡ ሐዋርያሁ፡ ወተፈልጠ፡ ለትምህርተ፡ እግዚአብሔር፡ ዘአቅደመ፡ ነጊረ፡ በአፈ፡ ነቢያቲሁ፡ ቅዱሳን፡ በእንተ፡
                           ወልዱ፡ ዘተወልደ፡ ወመጽአ፡ እምዘርአ፡ ዳዊት፡ በሥጋ፡ ሰብእ፨ስ
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus target="#90r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3865Miracle">Miracle of Our Lady Mary on the man who was washing his clothes</title>
                        <incipit xml:lang="gez">ተአ<supplied reason="explanation">ምረ፡</supplied> በል፡ ወሀሎ፡ ፩ብእሲ፡ እንዘ፡ የሐጽብ፡ አልባሲሁ፡ ወመጽአ፡ ካልዕ፡ ብእሲ፡</incipit>
                        <explicit xml:lang="gez">ወካዕበ፡ ተመይጠ፡ ማይ፡ ኀበ፡ ዘቀዳሚ፡ ምህዋሩ፡ በፈቃደ፡ እግዚአብሔር፡ <add place="margin">የሃሉ፡</add> ስብሐት፡ ለወላዲቱ፡
                           ቅ<supplied reason="explanation">ድስት፡</supplied> ድ<supplied reason="explanation">ንግል፡</supplied> በ፪፡
                           ማ<supplied reason="explanation">ርያም፡</supplied> ገባሪተ፡ ተአምራት፡ ወመንክራት፡</explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus from="90v" to="110v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Friday">ʾArgānona wǝddāse, for Friday</title>
                        <note>The text includes a short introduction before the incipit and a long blessing.</note>
                        <incipit xml:lang="gez">ኦእግዝእትየ፡ ቅድስት፡ ድንግል፡ በክልኤ፡ ማርያም፡ ዘበዕብራይስጢ፡ ማሪሃም፡ ንዒ፡ ዝየ፡ ምስለ፡ ኵሎሙ፡ ማኅበረ፡ ነቢያት፡ ከመ፡ 
                              <sic>ታለበወኒ፡</sic>
                           
                           ኃይለ፡ ቃል፡ ዘወጽአ፡ እምኔሆሙ፡ ለስብሐተ፡ ዚአኪ፨</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus target="#110v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3597Miracle">Miracle of Our Lady Mary on the women Juliana and Barbara and the thief who lost his teeth</title>
                        <incipit xml:lang="gez">ተአምሪሃ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወሐለዋ፡ ክልኤ፡ አምስት፡
                        እንዘ፡ የሐውራ፡ ውስተ፡ ቤተ፡ ክርስቲያና፡ ለእግዝእትነ፡ ማርያም፡</incipit>
                        <explicit xml:lang="gez">ወዝንቱ፡ ኵሉ፡ ኮነ፡ በስዕለታ፡ ለእግዝእትነ፡ ማርያም፡ ዘበዕብራይስጢ፡ ማሪሃም፡ ጸሎታ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="111r" to="122r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Saturday">ʾArgānona wǝddāse, for Saturday</title>
                        <note>The text includes a short introduction and two blessings.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="122r" to="122v"/>
                        <title type="complete" cert="high" ref="https://betamasaheft.eu/LIT3907Miracle">Miracle of the sick monks in the desert of Scete</title>
                        <incipit xml:lang="gez">
                           
                              <sic>ወሀለው፡</sic>
                            በገዳመ፡ አስቄጥስ፡ ሕሙማን፡ እምአበው፡ ቅዱሳን፡ ወአዕረፉ፡ እለ፡ አልቦሙ፡ 
                              <sic>ኁልቍ፡</sic>
                           
                        በውስተ፡ ደብር፡</incipit>
                        <explicit xml:lang="gez">
                           ወሶበ፡ ርእዩ፡ ቅዱሳን፡ ዘንተ፡ መንክረ፡ ራእየ፡ ተፈሥሑ፡ ዐቢየ፡ ፍስሐ፡ ወሰብሕዎ፡ ለእግዚአብሔር፡ ስቡሕ፡ 
                              <sic>ወአእኵትዋ፡</sic>
                           
                           ለእ<supplied reason="explanation">ግዝእትነ</supplied>፡ ቅ<supplied reason="explanation">ድስት</supplied>፡
                           ድ<supplied reason="explanation">ንግል</supplied>፡ በ፪፡ ወላ<supplied reason="explanation">ዲተ</supplied>፡
                           አ<supplied reason="explanation">ምላክ</supplied>፡ ጸሎታ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="123r" to="132v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Sunday">ʾArgānona wǝddāse, for Sunday</title>
                        <note>The blessing is separated from the invocation to Our Lady Mary.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.13">
                        <locus from="133v" to="134r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3633Miracle">Conversation of Jesus Christ and Our Lady Mary on the Five Pains</title>
                        <note/>
                        <incipit xml:lang="gez">ተአምሪሃ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወአሐተ፡ ዕለተ፡ ይቤላ፡
                        እግዚእ፡ ኢየሱስ፡ ክርስቶስ፡ ዓይኑ፡ የዓቢ፡ እምነ፡ ኃዘናት፡ ዘረከበኪ፡ በእንቲአየ፡</incipit>
                        <explicit xml:lang="gez">አነ፡ እመጽእ፡ እምቅድመ፡ 
                              <sic>ትጸእ፡</sic>
                           
                           
                              <sic>ነፍሱ፡</sic>
                            በ፫ዕለት፡ ለናዝዞቱ፡
                           ምስሌኪ፡ ኦወላዲትየ፡ ወእንዘ፡ ዘንተ፡ ይትናገራ፡ ሶበ፡ ሰምዓ፡ ደቅስዮስ፡ ጸሐፈ፡ ከመ፡ ያንብብዎ፡ ምዕመናን፡ ጸሎታ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                  </msItem>
               </msContents>


                  <msItem xml:id="ms_i1">
                    <locus from="3r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6395Consecration">Consecration Ritual</title>
                     <textLang mainLang="gez"/>

                     <msItem xml:id="ms_i1.1">
                       <locus from="3r" to="6r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT6395Consecration#Reader"><span xmlns="" class="w3-tag w3-red">No item: LIT6395Consecration, could not check for Reader</span></title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡
                       ጸሎት፡ በእንተ፡ ሢመተ፡ አናጉንስጢስ፡ ወሶበ፡ መጽአ፡ ፩፡ ከመ፡ ይሠየም፡
                     አናጉንስጢስ፡ እንዘ፡ ኢይትከደን፡ አልባሰ፡ ከሢቶ፡ ርእሶ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                       <locus from="6v" to="10v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT6395Consecration#SubDeacon"><span xmlns="" class="w3-tag w3-red">No item: LIT6395Consecration, could not check for SubDeacon</span></title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በእንተ፡ ሢመተ፡ <add place="above">መ</add>ንፈቀ፡ ዲያቆን፡
                       ሶበ፡ ከመ፡ ይሠየም፡ ዘእንበለ፡ ይትከደን።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                       <locus from="10v"/>

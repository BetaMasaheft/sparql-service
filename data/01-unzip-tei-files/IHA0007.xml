               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="273v">2r-273v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0009IHA">حاشية الزيادي على فتح الوهاب</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus> بسم الله الرحمن الرحيم قوله وتجل حفاظه اي يصيرهم اجلا لفهمهم معَانيه فهوَ بالجيم المعجمَة لا بالحا المهملة قوله وهو العلو فهو من الاسما المحذوفة الاعجاز كيد ودم بنيت او ايلها على السكون وادخل عليها همزة الوصل لتعذير الابتدا بالساكن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#273r">-273r</locus>قوله ومتله غيره مما يمكن ضعيف فرع افتى القاضي فيمن اقر بولادة امته فادعت انها اسقطت منه ما تصير به ام ولد بانها تصدق ان امكن ذلك بيمينها وحكي ابن القطان فيه وجهين ورجح الاذرعي منهما تصديقه وان اعترف بالحمل ما لم يمض مدة لا يبقي الحمل فيها حجتنا وهذا هو المعتمد</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

                        <msItem xml:id="ms_i3">
                          <locus from="8r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6459AstronomicalTreatise">A short, chiefly astronomical,
                          treatise</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            እምጥንተ፡ ዓለም፡ እሑድ። ምድር፡ መሠረታ፡ ለዓለም፡ ይከውን፡ ኑኃ፡ ፸፻ወ፫፻ መርኅብ። ወኁላቈ፡
                            መርኅብኒ፡ በመስፈርተ፡ ምዕራፍ፡ አው፡ በፈረሰኽ፡ አልቦ፡ ዘነአምር፡ ወባሕቱ፡ ይትአመር፡ ስመ፡
                            መርኅብ፡ ስፉሕ፡ ሜዳ፡ ውእቱ፡ ምስለ፡ ክበቡ፤ ወግዝፉሂ፡ ፳፻ወ፱ መርኅብ።
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                          <locus from="12r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5048Hassabat#Stars">ሐሳበ፡ ከዋክብት፡</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ወከመዝ፡ ከመ፡ ታእምር፡ ሐሳበ፡ ከዋክብት፡ እስመ፡ ሥርጋዌሁ፡ ለሰማይ፡ ክብሮሙ፡ ለከዋክብት፡
                            ወመንክር፡ ሥራቱ፡ ለትዕይንተ፡ ሰማይ፡ በቃለ፡ ቅዱሳቲሁ፡ የሐውሩ፡ ወዛቲ፡ ሥርዓቶሙ፡ ለእሉ፡
                            በበመካናቲሆሙ፡ የአርቡ።
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                          <locus from="14r" to="15v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/NAR0003tables">Calendaric tables</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i6">
                          <locus from="16r" to="17r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/NAR0003tables">Lunar tables</title>
                          <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i6.1">
                              <locus from="17v" to="19v"/>
                              <title type="complete" xml:lang="gez">A short explanatory treatise to the
                              lunar tables</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ከመዝ። ሥርዓቱ፡ ለኬክሮስ፡ በ፩ ሥርዓቱ፡ ፭ ኬክሮስ፡ በ፩ ዕለት፡ በ፩ ሰዓት፡ በ፱ ኬክሮስ፡ ትትወለድ፡
                                ወርኅ፡ በ፪ ዕለት፡ በ፪ ሰዓት፡ በ፫ ኬክሮስ፡ ወኮነ፡ ኬክሮስ፡ ፳።
                              </incipit>
                            </msItem>
                            </msItem>
                            <msItem xml:id="ms_i7">
                              <locus from="20r" to="26v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT6043Hassab">Computus from the beginning till the end of the World</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">ምሥጢረ፡ አቅማራት፡ ወግብረ፡ ዓመታት፡ ወክፍለ፡
                              ሰንበታት፡ ወሱባኤያቲሆሙ፡ ወተባርዮ፡ ዕለታቲሆሙ፡ ዘ፩ ቀመር።</incipit>
                            </msItem>
                            <msItem xml:id="ms_i8">
                              <locus from="26v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT5798ListKingsIsrael">List of the Kings of Israel</title>
                              <textLang mainLang="gez"/>

                              <msItem xml:id="ms_i8.1">
                                <locus from="26v"/>
                                <title type="complete" xml:lang="en">List of the king of Judah</title>
                                <textLang mainLang="gez"/>
                              </msItem>
                              <msItem xml:id="ms_i8.2">
                                <locus from="27v" to="29r"/>
                                <title type="complete" xml:lang="en">List of the kings of Israel</title>
                                <textLang mainLang="gez"/>
                                <note>Starting with <persName ref="https://betamasaheft.eu/PRS11373Nebuc">Nǝḇūḵaḏneṣṣar</persName>,
                              and ending with <persName ref="https://betamasaheft.eu/PRS5294Heracliu">Heraclius</persName>,
                            after whom is mentioned <persName ref="https://betamasaheft.eu/PRS1894Amrb">ʿAmr b. al-ʿĀṣ</persName> in
                          Egypt.</note>
                              </msItem>
                              <msItem xml:id="ms_i8.3">
                                <locus from="29r"/>
                                <title type="complete" xml:lang="gez">On the names of the nations in
                                the book of Enoch</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                  ዝንቱ፡ ውእቱ፡ አስማቲሆሙ፡ ለአሕዛብ፡ ዘሰመዮሙ፡ ሄኖክ። ለአማሌቅ፡ ሰመዮሙ፡ አንስርት። ወለግብጽ፡
                                  አዘዕብት።
                                </incipit>
                              </msItem>
                              <msItem xml:id="ms_i8.4">
                                <locus from="29r"/>
                                <title type="complete" xml:lang="en">On the idols of different nations</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                  ወዝውእቱ፡ አምልኮቶሙ፡ ለአሕዛብ፤ አማልክተ፡ ብና፡ ያመልኩ፡ ዘይሰመይ፡ ቀብው፤ ለውልንድዩኒ፡ ያመልኩ፡
                                  አንበሳ፡ አብጺርያ፡ ያመ፡ ላህም፡ ዘብርት። ንጥሩኒስ፡ ወአትሪብ፡ ያመ፡ ላህመ፡ ዘዕብን። ሰኂን፡ ያመ፡ ሰግላ፡
                                  አልፍብና፡ ያመ፡ ጣዖተ፡ ዘዕብን። ኑቂዩስ፡ ያመ፡ ጣዖተ፡ ብእሲ፡ ዘዕብን። ወጣዕዋ፡ ያመ፡ ሐራውያ፡ ዘዕብን፡
                                </incipit>
                              </msItem>
                            </msItem>
                            <msItem xml:id="ms_i9">
                              <locus from="30r"/>
                              <title type="complete" ref="https://betamasaheft.eu/NAR0003tables">Tables for determining Easter</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i10">
                              <locus from="37v"/>
                              <title type="complete" ref="https://betamasaheft.eu/NAR0003tables">Calendaric tables</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i11">
                              <locus from="38v"/>
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/NAR0003tables">ዓውደ፡ ዕለት፡</title>
                              <textLang mainLang="gez"/>
                              <msItem xml:id="ms_i11.1">
                                <locus target="#38v"/>
                                <title type="complete" xml:lang="gez">ዘአሐዱ፡ ዓመት፡</title>
                                <textLang mainLang="gez"/>
                              </msItem>
                              <msItem xml:id="ms_i11.2">
                                <locus target="#38v"/>
                                <title type="complete" xml:lang="gez">ዘአሠርቱ፡ ዓመት፡</title>
                                <textLang mainLang="gez"/>
                              </msItem>
                              <msItem xml:id="ms_i11.3">
                                <locus target="#38v"/>
                                <title type="complete" xml:lang="gez">ዘ፸፻፡ ዓመት፡</title>
                                <textLang mainLang="gez"/>
                              </msItem>
                            </msItem>
                            <msItem xml:id="ms_i12">
                              <locus from="39v" to="40r"/>
                              <title type="complete" xml:lang="gen" ref="https://betamasaheft.eu/NAR0003tables">Tables for
                              Roman (Greek) and Armenian calendars,
                              <foreign xml:lang="gez">ካልእ፡ ሐሳብ፡ ዘሮም፡ ወአርማንያ።</foreign></title>
                              <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i13">
                          <locus target="#41r"/>
                          <title type="complete" xml:lang="en">The Hebrew or Syriac alphabet</title>
                          <textLang mainLang="gez"/>
                          <note>The names of the letters are <foreign xml:lang="gez">
                          አሌፍ፡ ቤት፡ ጋሜል፡ ዳሌጥ፡ ሄ፡ ዋው፡ ዛይ፡ ሔት፡ ጤት፡ ዮድ፡ ካፍ፡ ላሜድ፡ ሜም፡
                        ኖን፡ ሳምኬት፡ ዔ፡ ፌ፡ ጻዴ፡ ቆፍ፡ ሬስ፡ ሳን፡ ታው።</foreign></note>

                        <msItem xml:id="ms_i13.1">
                          <locus from="41r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6460Letters">A short tract on the various
                            significations of the 22 letters of the alphabet</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ትርጓሜ፡ በእንተ፡ ፳ወ፪ ፊደላት፡ እሙንቱ፡ ይሰካተዩ፡ ፳ወ፪ ፍጥረታት፡ ዘፈጠሮሙ፡ እግዚአብሔር፡
                              ውስተ፡ ዝንቱ፡ ዓለም። ቅድመ፡ ፈጠራ፡ ለሰማይ፡ ቀዳሚት። ካዕበ፡ ፈጠራ፡ ለምድር፡ ዘታሕተ፡ ዕመቅ፡
                              <gap reason="ellipsis"/> ወካዕበ፡ ፳ወ፪ ምግባራት፡ ዘገብሮሙ፡ እግዚአብሔር፡
                              ውስተ፡ ገዳም፡ ቅድመ። ወቀፀበ፡ ለነ፡ በዝኩ፡ ምስጢር፡ ምግባራት፡ ዘኢየሱስ፡ ክርስቶስ፡ መድኅን፡
                            </incipit>
                        </msItem>

                        </msItem>
                        <msItem xml:id="ms_i14">
                          <locus from="43r"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/NAR0003tables">ስፍረ፡ ሰዓታት፡</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i14.1">
                            <locus from="43v"/>
                            <title type="complete" xml:lang="en">Explanatory tract</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ወይእዜኒ፡ ንግባዕ፡ ወንንግር፡ በእንተ፡ ሐሳበ፡ ሰዓታት፡ ዘከመ፡ የዓውድ፡ ለለወርኁ፡ ቀቂመከ፡ ርቱዓ፡
                              ትኔጽር፡ ጽላሎተ፡ ርእስከ፡ ወትትኤመር፡ ኀበ፡ በጽሐ፡ ወትሄልቍ፡ ለአእምሮ፡ ሰዓታት፡ እምቀዳሚ፡
                              ሰዓተ፡ መዓልት፡ እስከ፡ ሠርክ፡ ፲ወ፪ ሰዓት፡
                            </incipit>
                          </msItem>
                        </msItem>
                        <msItem xml:id="ms_i15">
                          <locus target="#45r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT4052Hours">On the twelve hours of the night and the twelve hours of the
          day</title>
                          <incipit xml:lang="gez">
                            በቀዳሚ፡ ሰዓተ፡ መዓልት፡ <sic>ያዖርጉ፡</sic> ጸሎተ፡ ቅዱሳን።
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i16">
                          <locus from="45v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6461Distances">Geographical notices</title>
                          <incipit xml:lang="gez">ኅልቊ፡ አህጉራት፡ ወኊልቍ፡ ፍኖት፡ ዘዉስቴቶን፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i17">
                          <locus from="48r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT6462TractOnPsalm">Tract on the text of Ps. 90.4</title>
                          <incipit xml:lang="gez">
                            በስመ፡ እግዚአብሔር፡ ግሩም፡ ርእሰ፡ ጥበብ፡ ወአእምሮ፡ <gap reason="ellipsis"/>
                            ነጽር፡ ኦላባዊ፡ ዘተኃሥሥ፡ ጥበበ፡ ወአእምሮ፡ በአዕይንተ፡ ልቡና፡ ወሐሳበ፡ በጥይቅና፡ ወኀሥሥ፡ በአስተጋብኦ፡
                            ሕሊና፡ ዘጸሐፍኩ፡ ለከ፡ ሐሳበ፡ ሰዓት፡ እላንቱ፡ እግዚአብሔር፡ በዘዚአሁ፡ ሥልጣን፡ ወምልክና። ፲ወ፪ ሰዓታት፡
                            ዘ፲፻፡ ዓመታት፡ በከመ፡ ይቤ፡ ዳዊት፡ ነቢይ፡ እስመ፡ ፲፻ ዓመት፡ <sic>በቅድሜየ፡</sic> ከመ፡ ዕለት፡
                            እንተ፡ ትማልም፡ ሐለፈት፡ እማንቱ።
                          </incipit>
                        </msItem>


                    </msContents>


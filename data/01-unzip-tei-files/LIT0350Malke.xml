      <body>
         
         
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ በሰሌዳ፡ ሰማይ፡ ጥብጡብ፨</l>
                  <l n="2">ዘሆህያቲሁ፡ ታስዕ፡ ወካዕበተ፡ ካዕብ፨</l>
                  <l n="3">አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ አንቅዕተ፡ ጥበብ፨</l>
                  <l n="4">አኅልፉኒ፡ በተንብሎ፡ እምነ፡ ፍኖት፡ መጽብብ፨</l>
                  <l n="5">ምስሌክሙ፡ ለሀልዎ፡ ውስተ፡ ምድር፡ ርኂብ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርትክሙ፡ ወለአርእስቲክሙ፡ ክሉላነ፡ ጌራ፨</l>
                  <l n="2">ለፍጽምክሙ፡ ሰላም፡ ወለገጽክሙ፡ ኅብረ፡ ነከራ፨</l>
                  <l n="3">አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ አዕማደ፡ ሴድራ፨</l>
                  <l n="4">እምዐላውያን፡ ነገሥት፡ ከመ፡ ተባልሐት፡ ሳራ፨</l>
                  <l n="5">ባልሑኒ፡ ሊተ፡ እምኵሉ፡ መከራ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">በከመ፡ ተወክፈ፡ እግዚአብሔር፡ መሥዋዕተክሙ፡ ንጹሐ፨</l>
                  <l n="2">በበ፡ ዘመንክሙ፡ ለለ፡ አሐዱ፡ ጊዜ፡ አዕረግክሙ፡ ጽንሐሐ፨</l>
                  <l n="3">አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ ለእመ፡ አምላክ፡ አበዊሃ፨</l>
                  <l n="4">ተወኪፈክሙ፡ በኢመንኖ፡ እንዘ፡ አቅረብኩ፡ አምኃ፨</l>
                  <l n="5">ዕሥዩኒ፡ ጥቀ፡ ዕሤተ፡ ብዙኀ፨</l>
               </lg>
            </div>
         </div>

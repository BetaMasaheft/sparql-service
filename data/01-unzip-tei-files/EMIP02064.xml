               <msContents>
                  <summary>Praises of Mary, ውዳሴ፡ ማርያም፡; Gate of Light, አንቀጸ፡ ብርሃን፡; Angels Praise Her, ይዌድስዋ፡ መላእክት፡ ለማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="34v" facs="001">Fols 1r–34v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="35r" to="50v" facs="035">Fols 35r–50v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="50v" to="55r" facs="051">Fols 50v–55r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
               </msContents>

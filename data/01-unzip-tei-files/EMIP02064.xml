                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  <locus target="#1r" facs="001">fols. 1r, </locus> (haräg);
                  <locus target="#27r" facs="027">27r, </locus> (multiple full stops);
                  <locus target="#50v #55r" facs="051 055">50v, 55r</locus> (multiple full stops and a line of alternating red and black dots)
                  </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#55r" facs="055">Fol. 55r</locus>
                           <desc type="OwnershipNote">an owner’s name is written in a later ink, <foreign xml:lang="gez">ወልደ፡ ተክለ፡ ሃይማኖት፡</foreign>. The original scribe is mentioned, <foreign xml:lang="gez">ወልደ፡ ስማዕት፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="e1">
                        <locus target="#55v" facs="056">Fol. 55v</locus>
                        <desc>
                        Note, “The seal of the Emperor came to me on the 10th of Taḫśaś,” in a different hand
                        </desc>
                        </item>
                        <item xml:id="e2">
                        <locus target="#56r" facs="056">Fol. 56r</locus>
                        <desc>
                          Note regarding property, in a different hand
                        </desc>
                        </item>
                        <item xml:id="a2">
                        <locus target="#56v" facs="057">Fol. 56v</locus>
                        <desc>
                          Medicinal instruction, in a different, later hand
                        </desc>
                        </item>
                        <item xml:id="e4">
                           <desc>
                            Identified in the insurance hand list as Marian Works 7
                            </desc>
                        </item>
                        <item xml:id="e5">
                          <locus target="#4 #22" facs="004 022">Fols. 4, 22</locus>
                           <desc>
                            purple yarn is sewn into the fore edge as navigation system
                          </desc>
                       </item>
                       <item xml:id="e6">
                        <locus target="#9 #27 #31" facs="009 027 031">Fols. 9, 27, 31</locus>
                        <desc>
                          blue yarn is sewn into the fore edge as navigation system
                        </desc>
                        </item>
                        <item xml:id="e7">
                        <locus target="#35" facs="035">Fol. 35</locus>
                        <desc>
                          yellow and blue yarn is sewn into the fore edge as navigation system
                        </desc>
                        </item>
                        <item xml:id="e8">
                        <locus target="#40" facs="040">Fol. 40</locus><desc>
                        red yarn is sewn into the fore edge as navigation system
                        </desc>
                        </item>
                        <item xml:id="e9">
                        <locus target="#3r #5v #8v #14r #20v" facs="003 006 009 014 021">Fols. 3r, 5v, 8v, 14r, 20v</locus>
                        <desc>
                          etc., words of text are written interlinearly
                        </desc>
                        </item>
                        <item xml:id="e10">
                        <locus target="#18v #47v #53v" facs="019 048 054">Fols. 18v, 47v, 53v</locus>
                        <desc>
                          lines of text are written interlinearly with a symbol (+) marking the location where the text is to be inserted (18v),
                          and in another case where the symbol (┬) is used (47v, line 9; 53v, line 2)
                        </desc>
                        </item>
                        <item xml:id="e11">
                        <locus target="#34v" facs="035">Fol. 34v</locus>
                        <desc>
                          erasure markings are visible
                        </desc>
                        </item>
                        <item xml:id="e12">
                        <locus target="#7r #19r #22r #23v #32v" facs="007 019 022 024 033">Fols. 7r, 19r, 22r, 23v, 32v</locus>
                        <desc>
                          etc., text has been removed
                        </desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, the front cover is missing.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

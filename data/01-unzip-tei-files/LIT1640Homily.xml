      <t:body>
         <t:ab/>
         
         <t:listBibl type="secondary">
            <t:bibl corresp="http://zotero.org/groups/358366/items/M7NA79KV"><seg type="encyclopediaArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Getachew2010RetuaHaymanot"/><title level="a">Rǝtuʿa Haymanot</title><title type="short">EAe</title><title level="m">Encyclopaedia Aethiopica</title><author><name>Getatchew Haile</name></author><editor><forename>Siegbert</forename><surname>Uhlig</surname></editor><editor><forename>Alessandro</forename><surname>Bausi</surname></editor><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>2010</date><biblScope unit="volume">IV</biblScope><biblScope unit="page">382b-383b</biblScope><note type="tags"><note type="tag">bm:Getachew2010RetuaHaymanot</note></note><note type="tag">bm:Getachew2010RetuaHaymanot</note><t:citedRange unit="page">383a</t:citedRange></t:bibl>
         </t:listBibl>
         <t:div type="edition">
           <t:note>The incipit is taken from <t:ref type="mss" corresp="https://betamasaheft.eu/EMML2375">ʾAnkobar, ʾAnkobar Mikāʾel, MS EMML no. 2375</t:ref></t:note>
           <t:div type="textpart" subtype="incipit">
             <t:ab xml:lang="gez">ድርሳን፡ ዘማርያም፡ ወላዲተ፡ አምላክ። ድርሳን፡ ዘማርያም፡ ወላዲተ፡ እግዚአብሔር። ድርሳን፡ ዘማርያም፡ ወላዲተ፡ ብርሃን፡ ወላዲተ፡ መድኅን። ወላዲተ፡ ሕይወት፡ ወላዲተ፡
             መንፈስ። ወላዲተ፡ ክርስቶስ፡ ወላዲተ፡ ኢየሱስ። ወላዲተ፡ አማኑኤል። ወላዲተ፡ የማን። ወላዲተ፡ ጽድቅ። ወላዲተ፡ መዓልት። ዘንተ። ወዘይመስሎ፡ ኵሎ፡ ይሰመይ፡ ወልዳ፡ ዋህድ፡ ቃለ፡ አብ፡ ቀዳማዊ።</t:ab>
            </t:div>
            <t:div type="textpart" subtype="explicit">
             <t:ab xml:lang="gez">ቡራኬ፡ ለመንፈስ፡ ቅዱስ፡ ዘረሰያ፡ መንጦላእተ፡ ለምስዋረ፡ መሢሑ። ሎቱ፡ ስብሐት፡ ለ፩፡ አምላክ፡ ወለእሌኒ፡ ይኵን፡ ምኅረቱ። ወበረኮታ፡ ለወላዲቱ፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን።</t:ab>
            </t:div>
        </t:div>
      </t:body>

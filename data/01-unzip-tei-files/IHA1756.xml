                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a9_5685">
                           <locus target="#17r">-17r</locus>
                           <q xml:lang="ar">فَإن خِفْتًمْ أَلاَّ يًقِيمَا حًدًودَ اللهِ</q>
                           <desc>Maginalia</desc>

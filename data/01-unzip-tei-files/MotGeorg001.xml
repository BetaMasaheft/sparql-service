                  <msItem xml:id="ms_i1">
                      <msItem xml:id="ms_i1.1">
                        <incipit xml:lang="gez">
                    በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ሥላሴ፡ ዋሕድ፡ ዕሩይ፡ ዘኢይሰደቅ፡ ታሉት፡ ዘኢይነፍድ። ዘሀሎ፡ እምቅድም፡ እምክዋኔሁ፡ እንዘ፡ ኢይትበዓድ፨                       </incipit>
                          <explicit xml:lang="gez">
                           <title/>
                        </explicit>

               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="16v">Fols 1r–16v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <textLang mainLang="gez"/> 
                     
                     <note>This fragment contains Psalms 40:9-65:6, with the exception of some 20 verses missing of Psalm 49. 
                        The text breaks off on <locus target="#16v">fol. 16v</locus>.</note>
                     <note>
                        <locus target="#7">Fols. 7, </locus> and <locus target="#8">8, </locus> are correctly bound but wrongly numbered, 
                        <locus target="#8">8, </locus> preceding  <locus target="#7">7</locus>.</note>
                     <note>One folio containing Psalm 49:2-21 is missing.</note>
                     <note>
                       <p> 
                           <locus from="1r">Fols 1r and following</locus>: from 40:9;</p>
                        <p>
                           <locus from="6">Fols 6 and following</locus>: from 49:1;</p>
                        <p> 
                           <locus target="#7r">Fol. 7r</locus>: from 49:22;</p>
                        <p>  
                           <locus target="#7v">Fol. 7v</locus>: up to the end of 50;</p>
                        <p> 
                           <locus target="#8r">Fol. 8r</locus>: 51:1;</p>
                        <p>  
                           <locus target="#8v">Fol. 8v</locus>: from 53:3;</p>
                        <p>
                           <locus from="9r">Fols 9r and following</locus>: from 53:3 (continued).</p>
                     </note>
                     </msItem>
               
                  </msContents>
                     

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘስብሐት፡ ሎቱ፨</l>
                  <l n="2">እዌጥን፡ በረድኤቱ፨</l>
                  <l n="3">ውዳሴ፡ ስምክሙ፡ እጽሕፍ፡ ወመልክእክሙ፡ ዝንቱ፨</l>
                  <l n="4">አከም፡ ለፍጻሜ፡ ተራድኡኒ፡ ባሕቱ፨</l>
                  <l n="5">መላእክት፡ አእላፍ፡ ወነገድ፡ ተስዓቱ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘተዐውቀ፡ በእሑድ፨</l>
                  <l n="2">ቅድመ፡ ይኩን፡ ጠፈር፡ ማእከለ፡ ማያት፡ ዘሞገድ፨</l>
                  <l n="3">መላእክት፡ ጽዱላን፡ ዘሕብርክሙ፡ መረግድ፨</l>
                  <l n="4">ለገጸ፡ ሥንክሙ፡ ብዙኅ፡ ዘኢይትፌጸም፡ በፍቅድ፨</l>
                  <l n="5">ኮከብ፡ ሕፁፅ፡ ወኆፃ፡ ውሑድ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ነገረ፡ ዝንቱ፡ ስብሐትክሙ፡ ዘዘፍሉጥ፡ መልክኡ፨</l>
                  <l n="2">ውስተ፡ ሰሌዳክሙ፡ መብረቅ፡ መላእክተ፡ ብርሃን፡ ልክኡ፨</l>
                  <l n="3">በዝየኒ፡ ለለ፡ ዕለቱ፡ ወለለ፡ ሳዑ፨</l>
                  <l n="4">ይትበፅዑ፡ ዘአእመርዎ፡ ወቃላቲሁ፡ ዘሰምዑ፨</l>
                  <l n="5">ከመ፡ ቃለ፡ መምህር፡ ዮሐንስ፡ ዘአህጉር፡ ሰብኡ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለክሙ፡ በኍልቈ፡ እስትንፋስ፡ ዘአእናፍ፨</l>
                  <l n="2">ወበኍልቈ፡ ቃል፡ ዘይወፅእ፡ እምነ፡ ከናፍር፡ ወአፍ፨</l>
                  <l n="3">እንዘ፡ ትረውጹ፡ ፍጡነ፡ ከመ፡ እብነ፡ ዐቢይ፡ ሞጸፍ፨</l>
                  <l n="4">መንፈቅክሙ፡ ምስለ፡ ኲናት፡ ወመንፈክመ፡ ምስለ፡ ሰይፍ፨</l>
                  <l n="5">ለጸቢአ፡ ፀርየ፡ ነዑ፡ መላእክት፡ አእላፍ፨</l>
               </lg>
            </div>
         </div>

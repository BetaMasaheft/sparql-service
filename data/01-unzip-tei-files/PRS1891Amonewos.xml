         <listPerson>
            <person sex="1">
          
                  <persName xml:lang="gez" xml:id="n1" type="birth">አሞኔዎስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAmonewos</persName>
               <persName xml:lang="gez" xml:id="n2" type="alt">አሞንዮስ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAmonyos</persName>
             
                  <persName>
                  <roleName type="title">grāzmāč, qaññāzmāč</roleName>
               </persName>
                  
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="political">officer</occupation>
                 <floruit notBefore="1680" notAfter="1703">He was a favourite officer of 
                    
                    <persName ref="https://betamasaheft.eu/PRS5616IyasuI"> 
                     <roleName type="title">ʾaṣe </roleName> ʾIyāsu I</persName>.  
                    He was active in the <date>1680</date>s as a 
                    <persName ref="https://betamasaheft.eu/PRS1891Amonewos">
                     <roleName type="title">grāzmāč</roleName> 
                  </persName> in the royal army and 
                    in the later <date>1690</date>s as <persName ref="https://betamasaheft.eu/PRS1891Amonewos">
                     <roleName type="title">blatten getā</roleName>  
                       
                    </persName>at the court.
                        Three years later, in <date>1700</date>,
                    he was appointed <persName ref="https://betamasaheft.eu/PRS1891Amonewos">
                     <roleName type="title">baǧǝrond</roleName>
                  </persName> of the throne hall. 
                  </floruit>
               <death when="1703"> He died of poison. </death>
                  
                  
                  
               </person>  
               
         </listPerson>

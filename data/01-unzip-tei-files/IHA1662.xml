                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/MBMRLEXI"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook811"/><title level="m">al-Maǧālis al-saniyya fī al-kalām ʻalā al-arbaʻīn al-nawawiyya ... wa-bi-hāmišihi kitāb al-Sabʻiyyāt fī mawāʻiẓ al-bariyyāt</title><author><name>al-Fašnī, Aḥmad b. Ḥiǧāzī</name></author><author><name>ʻAyn al-Quḍāt, Muḥammad b. ʻAbd al-Raḥmān al-Hamaḏānī</name></author><pubPlace>Miṣr</pubPlace><publisher>Maṭbaʻat al-Taqaddum al-ʻilmiyya</publisher><date>1326</date><note type="tags"><note type="tag">bm:IHABook811</note></note><note type="tag">bm:IHABook811</note></bibl>

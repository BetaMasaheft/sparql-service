                        <item xml:id="a0_4950">
                           <locus target="#112r">-112r</locus>
                           <q xml:lang="ar">تمت فى ١٠ صفر من سنه ١٣٧٢ ه</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_4949">
                           <locus target="#68r">-68r</locus>
                           <q xml:lang="ar">فقد تم الرقم بيد العبد الفقير الى مولاه الغني محمد سعيد بن محمد امين يوم الخامس من ربيع الثانى وقت العصر الحادي عشر من بدئه من شهور سىه ١٣٧٢ ه غفر الله له ولوالديه ومشايخه ومؤلفه واحبائه ومحبيه امين وسلام على المرسلين والحمد لله رب العلمين</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_4948">
                           <locus target="#1r">-1r</locus>
                           <q xml:lang="ar">Cartella "AQUILA" /
Mod. 0</q>

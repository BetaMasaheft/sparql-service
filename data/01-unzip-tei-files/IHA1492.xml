                           <note>
                              <q xml:lang="it"/>
                              <q>Script: Latin</q>
                           </note>
                        </item>
                        <item xml:id="a1_4948">
                           <locus target="#23v">-23v</locus>
                           <q xml:lang="ar">[.?.] / AGGARO</q>
                           <desc>Stamp / Signature</desc>
                           <note>Purple stamp. The First line is faint and partly torn off.</note>
                           <note>: <placeName ref="https://betamasaheft.eu/LOC0060IHA">Agaro / Aggārō</placeName>

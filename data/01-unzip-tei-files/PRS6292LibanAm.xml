      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሊበን፡ አመዴ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Liban ʾAmade</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ ጂሩ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbāā Ǧirru</t:persName>
     
               
               <t:persName>
                  <t:roleName type="title">imām</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="Islam"/>
               <t:occupation type="political">ruler</t:occupation>
               <t:birth when="1785">He was born in <t:placeName ref="https://betamasaheft.eu/LOC1713Bagemd">Bagemdǝr</t:placeName>
               </t:birth>
               <t:residence> 
                  <t:placeName ref="https://betamasaheft.eu/LOC6242WarraH">Warra Himano</t:placeName>
               </t:residence>
            
               <t:floruit notBefore="1803" notAfter="1825">He was a ruler of 
                  <t:placeName ref="https://betamasaheft.eu/LOC6242WarraH">Warra Himano</t:placeName> between <t:date>1803-1825</t:date>.
                  During his child hood, <t:persName ref="https://betamasaheft.eu/PRS6292LibanAm">Liban ʾAmade</t:persName> 
                  received Christian education, when he was about 15 years. 
                  Afterwards he converted to Islam under the influence of his father, whom he appointed him governorship of <t:placeName ref="https://betamasaheft.eu/LOC6132Wadla">Wādlā</t:placeName>, 
                  <t:placeName ref="https://betamasaheft.eu/LOC2586Dawent">Dāwǝnt</t:placeName> and <t:placeName ref="https://betamasaheft.eu/LOC2449Dalant">Dalāntā</t:placeName>. 
                  His reign is characterized by a state of latent warfare against the neigbouring Christian rulers. He married at least three women including Christians. </t:floruit>
            
               <t:death when="1825">He died of an intestinal hernia complicated by intensive horse riding.</t:death>
            </t:person>
            
         </t:listPerson>
         
         

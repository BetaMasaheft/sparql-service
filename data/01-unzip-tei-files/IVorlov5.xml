                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                         <date notBefore="1700" notAfter="1800"/>
                         <seg type="ink">Black, red</seg>
                        <desc>
                           <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> describes
                        the handwriting as "good", datable to the 18th century.
                        The name of the scribe, <persName role="scribe" ref="https://betamasaheft.eu/PRS12656MasoraDengel">
                          Maṣora Dǝngǝl</persName> is mentioned on some
                        folios.</desc>
                     </handNote>
                  </handDesc>


                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2r"/>
                            <desc type="MagicText"/>
                           <note>Prayer for the fertility of women.</note>
                        </item>

                        <item xml:id="a2">
                           <locus target="#1r"/>
                           <desc type="MagicText"/>
                           <note>Prayer for the salvation from Hades,
                           referring to some biblical accounts, such as
                         salvation of <persName ref="https://betamasaheft.eu/PRS7594Noah"> Noah </persName> from the Flood,
                         <persName ref="https://betamasaheft.eu/PRS3721Elijah"> Elijah </persName> from Ahab, etc.</note>
                        </item>

                        <item xml:id="a3">
                             <locus target="#1r"/>
                           <desc type="GuestText">
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5678CommemorationRoch">Commemorative note and hymn for St Roch
          (Roqo)</title></desc>
                           <note>Commemoration entry and salām-hymn dedicated to <persName ref="https://betamasaheft.eu/PRS12657Roch">St Roch (Roqo)</persName> who saves from plague.
                           </note>
                        </item>
                     </list>
                  </additions>


                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">
                  Wooden boards, leather quarter-cover.
                  Possibly one pair of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="bindingMaterial">

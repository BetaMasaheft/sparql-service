                           <material key="leather"/>
                        </decoNote>
                     </binding>
                  </bindingDesc>

               </physDesc>



               <history>
                   <origin>
                       <origDate notBefore="1700" notAfter="1800">
                       </origDate>
                   </origin>
                   <provenance>The commissioners mentioned in the manuscript up to <locus target="#104r"/>
                      are <persName role="patron" ref="https://betamasaheft.eu/PRS12660BatraMaryam">Batra Māryām</persName> and
                   "his beloved"<persName role="patron" ref="https://betamasaheft.eu/PRS12661WaldaHanna">
                      Walda Ḥannā</persName>, with the scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS12656MasoraDengel">Maṣora
                 Dǝngǝl</persName>.
                 On <locus target="#104v"/> "the children of <persName role="patron" ref="https://betamasaheft.eu/PRS12662Zaparaqlitos">Zaṗārāqliṭos</persName>" are mentioned.
                      On <locus target="#109r"/> <persName role="patron" ref="https://betamasaheft.eu/PRS12663GabraMaryam">Gabra Māryām</persName>, <persName role="scribe" ref="https://betamasaheft.eu/PRS12656MasoraDengel">Maṣora
                         Dǝngǝl</persName> and <persName role="patron" ref="https://betamasaheft.eu/PRS12664AmdaGiyorgis">ʿĀmda Giyorgis</persName> are
                 mentioned (the last name written over an erasure). The manuscript was bought by the Russian diplomat
                     <persName role="owner" ref="https://betamasaheft.eu/PRS7674Orlov">Alexander Orlov</persName>.
                 </provenance>
                 <acquisition>
                       The manuscript was
                    acquired by the Asian Museum on <date>10 September 1903</date>
                  </acquisition>
               </history>



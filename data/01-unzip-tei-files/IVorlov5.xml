               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="106v"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas">
                      ጸሎታተ፡ እንተ፡ ሰብዕቱ፡ ዕለታት</title>
                     <textLang mainLang="gez"/>
                     <note>According to <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName>, there are two versions of the
                     work, the text in the manuscript is close to the version
                     contained in <ref type="mss" corresp="https://betamasaheft.eu/BNFet90">BNFet90</ref>.</note>

                     <msItem xml:id="ms_i1.1">
                        <locus from="3r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Monday">No item: LIT2505Weddas, could not check for Monday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer of <persName ref="https://betamasaheft.eu/PRS2546Basilth">Basil the Great</persName>.</note>

                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="14r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Tuesday">No item: LIT2505Weddas, could not check for Tuesday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer of <persName ref="https://betamasaheft.eu/PRS3827Ephrem">Ephrem the
                           Syrian</persName>.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="31r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Wednesday">No item: LIT2505Weddas, could not check for Wednesday</title>
                        <textLang mainLang="gez"/>
                        <note>
                           <persName ref="https://betamasaheft.eu/PRS3827Ephrem">Ephrem the
                           Syrian</persName>.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="45r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Thursday">No item: LIT2505Weddas, could not check for Thursday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer from <ref type="work" corresp="https://betamasaheft.eu/LIT3989Aragawi">Spiritual Elder</ref>.
                      </note>
                     </msItem>

                     <msItem xml:id="ms_i1.5">
                        <locus from="64r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Friday">No item: LIT2505Weddas, could not check for Friday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer of <persName ref="https://betamasaheft.eu/PRS8823Shenute">Shenute</persName>
                        with insertion of a text by
                        <persName ref="https://betamasaheft.eu/PRS7696Pachomiu">Pachomius</persName>.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.6">
                        <locus from="78r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Saturday">No item: LIT2505Weddas, could not check for Saturday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer gathered from Egyptian chants by
                          <persName ref="https://betamasaheft.eu/PRS2209Athanasi">Athanasius of Alexandria</persName>.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.7">
                        <locus from="104v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Sunday">No item: LIT2505Weddas, could not check for Sunday</title>
                        <textLang mainLang="gez"/>
                        <note>Prayer of <persName ref="https://betamasaheft.eu/PRS3255CyrilI">Cyril
                            of Alexandria</persName>
                        </note>
                     </msItem>

                     <msItem xml:id="ms_i1.8">
                        <locus from="104v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Monday2">No item: LIT2505Weddas, could not check for Monday2</title>
                        <textLang mainLang="gez"/>
                        <note>A short addedprayer to "God of Basil" and "God of Ephrem"; according to
                        <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> similar texts for other days of the week are
                      placed after the "respective long prayers".</note>
                    </msItem>
                  </msItem>
               </msContents>


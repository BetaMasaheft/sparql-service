                    <decoNote type="miniature" xml:id="d1"><locus target="#ivv(erso)" facs="005">Fol. ivv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#31r" facs="035">Fol. 31r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>

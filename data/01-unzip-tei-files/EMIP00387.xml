                    <decoNote type="miniature" xml:id="d4"><locus target="#156r" facs="160">Fol. 156r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising Adam and Eve</desc></decoNote>
                    <decoNote type="frame" xml:id="d5">
                    Decorative designs:
                    <locus target="#1r #14v #30v #31v #54r #65v #74r #79v #92v #105r #108r #114r #120v #132v #150r" facs="005 019 035 036 058 070 078 084 097 109 112 118 125 137 154">folss. 1r, 14v, 30v, 31v, 54r, 65v, 74r, 79v, 92v, 105r, 108r, 114r, 120v, 132v, 150r, </locus> (haräg);
                    <locus target="#1r #45r #139v #141v #148v" facs="005 049 144 146 153">1r, 45r, 139v, 141v, 148v, </locus> (line of black dots);
                    <locus target="#7v #149v" facs="012 154">7v, 149v, </locus> (lines of alternating red and black dots);
                    <locus target="#21v #154v" facs="026 159">21v, 154v, </locus> (full stops between lines of alternating red and black dots);
                    <locus target="#143v #147v" facs="148 152">143v, 147v</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>

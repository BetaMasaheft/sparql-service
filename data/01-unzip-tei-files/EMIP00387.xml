                    <locus target="#ir(ecto) #iv(erso) #iir(ecto) #iiv(erso) #iiir(ecto) #156v" facs="001 002 003 161">Fols. ir(ecto), iv(erso), iir(ecto), iiv(erso), iiir(ecto), 156v</locus>

                    <msContents>
                        <summary/>  
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="35v"/>
                            <title ref="https://betamasaheft.eu/LIT3052RepCh332">Hymn to David</title>
                            <incipit xml:lang="gez">እምሥርወ፡ ዕሤይ፡ እስመ፡ ሠረፅከ፡ ወእማኅፀና፡ ለሩት።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="35v"/>
                            <title ref="https://betamasaheft.eu/LIT7002PrayerSmiths">Prayer against buda and smiths</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/>ጸሎት፡ በእንተ፡ ሕማመ፡ ቡዳ፡ ወጠቢብ፡ ሕማመ፡ ቡዳ፡ ሐሮፓሮስ፡ ፯ጊዜ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="38v"/>
                            <title ref="https://betamasaheft.eu/LIT7003PPMagicians">Prayer against buda and magicians by the virtue of secret
          names uttered by the Virgin Mary</title>
                            <incipit xml:lang="gez">ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ዘጸለየት፡ ባቲ፡ <gap reason="ellipsis"/>እንዘ፡ ትብል፡ ቴምኒ፡ ድብድራስ፡ 
                                <gap reason="ellipsis"/> አድኅነኒ፡ እምሠገርተ፡ ቡዳ፡ ወቁመኛ፡ ለገብርከ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="40v"/>
                            <title ref="https://betamasaheft.eu/LIT7005PPCharms">Prayer against charms by the virtue of secret names uttered
          by the Virgin Mary</title>
                            <incipit xml:lang="gez">ወትቤ፡ ማርያም፡ ፊሳላምዮዮስ፡ ቍራስብያኤል፡ <gap reason="ellipsis"/>ይእትት፡ እምኔክሙ፡ መንፈሰ፡ ሥራይ፡</incipit>
                        </msItem>
                    </msContents>

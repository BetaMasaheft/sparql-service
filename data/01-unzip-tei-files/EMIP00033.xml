                      <incipit xml:lang="gez">
                        እግዚብሔር፡ ጥበበ፡ ጠቢባን።ሐሓሊ። እስከ፡ ለዓለም፡ እምጥንት፡ እንት፡ ኢትበሊ፡<gap reason="omitted"/>
                      </incipit>
                      </msItem>
                    <msItem xml:id="ms_i7">
                     <locus from="64r" to="76v" facs="065">Fols 64r–76v</locus>
                      <title>Booklet of prayer that came down from heaven for a nobleman in the land of the Afrǝgi</title>
                      <incipit xml:lang="gez">
                        በስመ፡ አብ፡<gap reason="omitted"/>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡ ለገብርከ፡ ሎቱ፡ ስብሐት፡ በእንተ፡ ዘኃደርከ፡ በከርሠ፡ ማርያም፡<gap reason="omitted"/>ዝንቱ፡ መጽሐፍ፡ ከመዝ፡ ምጽአታ፡ እስመ፡ ነገረ፡ ፩፡ መኰንን፡ በሀገረ፡ አፍርንጊ፡<gap reason="omitted"/>
                      </incipit>
                      </msItem>
                    <msItem xml:id="ms_i8">
                     <locus from="76v" to="90r" facs="078">Fols 76v–90r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh">Maṣḥafa
                                                  ʾardǝʾt</title>
                      <incipit xml:lang="gez">
                        በስመ፡ አብ፡<gap reason="omitted"/>ጸሎተ፡ ዘ፲ወ፪አርድእት፡ ዘወሀቦሙ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ አመ፡ የዓርግ፡ ሰማየ፡ በዘይድኅኑ፡ እምኃጢአት፡ ወእምኵሉ፡
                        ሕማመ፡ ሥጋ፡ ወበፍስ፡ ወእምኵሉ፡ ፀራዊ፡ ወሕምዘ፡ አርዌ፡ ምድር፡ ወእምኵሉ፡ ዘቦቱ፡ ሕምዝ፡ ዘይቀትል፡ ወእምኵሉ፡ ሕማም፡ ወድካም፡<gap reason="omitted"/>
                        በኢያሄ፡ ስምከ፡ ግሩም፡ በሱራሄ፡ ስምከ፡ ዓቢት፡<gap reason="omitted"/>
                      </incipit>
                      </msItem>
                    <msItem xml:id="ms_i9">
                     <locus from="90r" to="93r" facs="091">Fols 90r–93r</locus>
                      <title>Prayer of the Disciples for forgiveness of sin, <foreign xml:lang="gez">ጸሎት፡ ስርየተ፡ ኃጢአት፡</foreign>
                     </title>
                      <incipit xml:lang="gez">
                        ጸሎት፡ ስርየተ፡ ኃቲአት፡ ዘሰአሉ፡ ሐዋርያ፤ ኦእግዚኦ፡ እግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ መሐሪ፡ ወመስተሣህል፡<gap reason="omitted"/>ስረይ፡ ኃጢአትየ፡<gap reason="omitted"/>በሴቃ፡ ወበጼቃ፡ ስምከ፡ እግዚኦ፡ ርድአኒ፡<gap reason="omitted"/>ዛቲ፡ መጽሐፍ፡ ኢተጽሕፈት፡ በእደ፡ ሰብእ፡ አላ፡ ለሊሁ፡ መድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘጸሐፋ፡ በእዴሁ።<gap reason="omitted"/>
                      </incipit>
                      </msItem>
                    <msItem xml:id="ms_i10">
                     <locus from="93r" to="96v" facs="094">Fols 93r–96v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2295Sayfam">Sayfa malakot</title>
                      <incipit xml:lang="gez">
                        በስመ፡ እግዚአብሔር፡ ቀዳማዊ፡ እንበለ፡ ትማልም፡ ወወማዕከላዊ፡ ዘእንበለ፡ ዮም፡ ወደኃራዊ፡ ዘእንበለ፡ ጌሠም፡ ብሉየ፡ መዋዕል፡<gap reason="omitted"/>
                        ነአ፡ ኀቤየ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ወወልደ፡ ማርያም፡ ሥግው፡<gap reason="omitted"/>
                      </incipit>
                      </msItem>
                    <msItem xml:id="ms_i11">
                     <locus from="96v" to="103r" facs="098">Fols 96v–103r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  </msItem>
                    <msItem xml:id="ms_i12">
                     <locus from="103r" to="107r" facs="104">Fols 103r–107r</locus>
                      <title>The prayer, “God of the luminaries,” <foreign xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡</foreign>
                     </title>
                      <note>MG 59, pp. 38ff; MQ 51, pp. 199–200; Daoud-Mersie, Liturgy, pp. 244–45; Sebastian Euringer, “Die Äthiopische Anaphora des hl. Epiphanius Bischofs der Insel Cypern,” Oriens Christianus, third ser., vol. I (1926), pp. 126–28</note>
                      </msItem>
                    <msItem xml:id="ms_i13">
                     <locus from="107r" to="117v" facs="108">Fols 107r–117v</locus>
                      <title>The prayer, “I take refuge,” <foreign xml:lang="gez">ጸሎተ፡ ተማኅፀንኩ፡</foreign>
                     </title>
                      </msItem>
               </msContents>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <title>Dǝggwā</title>
                     <textLang xml:lang="gez"/>
                     
                     <colophon xml:id="coloph1" xml:lang="gez">…. ዝንቱ መጽሐፍ ዘአባ ደስታ ዘአጥረወዮ…. በዘመነ አጸባ በአባ መድኅነት በአበጋዝ አስፋው ዳኝነት የወጣ ነው፡፡ (f.167)</colophon>
                     <note>Used in the school of Zema</note></msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf"> 167</measure>
                           <dimensions type="outer">
                              <height unit="mm">285</height>
                              <width unit="mm">255</width>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <condition key="good"/>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="3" writtenLines="41 44"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        Gabra Heywat (colophon, f. 90a)
                     </handNote>
                     
                  </handDesc>                  
                  <decoDesc>
                     <decoNote xml:id="d1">
                        <desc>Ornamental designs, ff. 58a, 64b, and 145a, plus many small designs in the text.</desc>
                     </decoNote>
                  </decoDesc>
                  <additions><list><item xml:id="a1"><locus target="#167"/><desc type="OwnershipNote"><q xml:lang="gez">ዓይነ ኩሉየተማረ ያስተማረ ፩፩ አቡነ ዘበሰማያት ወልደ ኢየሱስ፡፡ </q></desc></item><item xml:id="e1">Stamp of the Church of the Savior of the World, f. 112b. F. 3ab: blank, except for a few pencilled words that are illegible. Ff. 161b-162a: not filmed.</item></list></additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>
               <history>

                         <msItem xml:id="ms_i1.5">
                           <locus from="24r" to="27r"/>
                           <title type="complete">Fourth section</title>
                           <textLang mainLang="gez"/>
                           <note>The text contains the first part of the fourth section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">73 l. 2-74 l. 24</citedRange></bibl>.</note>  
                         </msItem>
                         <msItem xml:id="ms_i1.6">
                           <locus from="27r" to="29r"/>
                           <title type="complete">First prayer for the heavenly journey</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez">
                             በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ዘመንገደ፡ ሰማይ፡ ሚካኤል፡ ወገብርኤል፡ ሱራፌል፡ ወኪሩቤል፡ 
                             ወሱርያል፡ ኡሪአኤል፡ ወፋኑኤል፡ ወኢያኤል፡ ሊቃነ፡ መላእክት፡ ሰአሉ፡ በእንቲአ<add place="above">ነ</add>፡
                             </incipit>
                           <explicit xml:lang="gez">
                             በ፳ወ፬ ካህናተ፡ ሰማይ፡ በ፸ወ፪ አርድእት፡ በ፭፻ ቢጽ፡ በ፫፻፲ወ፰ ርቱዓነ፡ ሃይማኖት፡ መሐረኒ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> 
                             በበአስማቲሆሙ፡ <choice><sic>ተመኅፀንኩ፡</sic><corr resp="bm:GrebTiss1935Codices">ተማኅፀንኩ፡</corr></choice> ከመ፡ ትስአሉ፡ በእንቲአነ፡ 
                             በደኃሪ፡ መዋዕል፡ ኀበ፡ ገባሬ፡ መላእክት፡ አበ፡ ኵሉ፡ ለዓለመ፡ ዓለም፡ አሜን፡
                           </explicit>                         
                         </msItem>
                         <msItem xml:id="ms_i1.7">
                           <locus from="29v" to="30v"/>
                           <title type="complete">Second prayer</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez">
                             በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ዘመንገደ<supplied reason="omitted">፡</supplied> ሰማይ፡ ዕቀበኒ፡
                             ክርስቶስ፡ ኢያዕቅፍዋ፡ ለነፍስየ፡ መላእክተ፡ ጽልመት<supplied reason="omitted">፡</supplied> ውስተ፡ ጸባብ፡ አንቀጸ፡ እስእለከ፡ እብል፡ ስረት፡ ሊተ፡ ኵሎ፡
                             ጊዜ፡ <choice><sic>ጊጋይይ፡</sic><corr resp="bm:GrebTiss1935Codices">ጌጋይየ፡</corr></choice> በሐዳሳተ፡ ሰማይ፡ 
                             ወበሐዳ<supplied reason="omitted">ሳ</supplied>ተ፡ ምድር፡
                           </incipit>
                           <explicit xml:lang="gez">
                           ከመ፡ ኢያእምርዋ፡ ለነፍስየ፡ መላእክት፡ ጸዋጋን፡ ወኢይነጽርዋ፡ በመዓት፡ ወዕቀብ፡ ዘንተ፡ ቃለ፡ ከመ፡ ይዕቀብከ፡ ለዓለመ፡ ዓለም፡ አሜን።
                           </explicit>                         
                         </msItem>
                         <msItem xml:id="ms_i1.8">
                           <locus from="30v" to="31v"/>
                           <title type="complete">Third prayer</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez">
                             በስመ፡ አብ<supplied reason="omitted">፡</supplied> <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ዘመንገደ፡ ሰማይ፡ በቆቤ፡
                             <choice><sic>ስም፡</sic><corr resp="bm:GrebTiss1935Codices">ስመ፡</corr></choice> ኃይልከ፡ ወበድቅኤል፡ ስመ፡ ጥምቀትከ፡ 
                             <choice><sic>በዘአጥመ<add place="above">ቀ</add>ኒ፡</sic><corr resp="bm:GrebTiss1935Codices">በዘአጥመቀከ፡</corr></choice> 
                             <sic>ዮሓንስ፡</sic>
                           </incipit>
                           <explicit xml:lang="gez">
                             በቀ<add place="above">ተ</add>ናዊ፡ ስምከ፡ ወበሰተናዊ፡ ስምከ፡ ተማኅፀንኩ፡ ስመ፡ ትምሐረኒ፡ ለአመትከ፡ ወለተ፡ ሚካኤል፡
                           </explicit>                        
                         </msItem>
                         <msItem xml:id="ms_i1.9">
                           <locus from="31v" to="33v"/>
                           <title type="complete">Fourth prayer</title>
                           <textLang mainLang="gez"/>
                           <note>The text corresponds to the fifth section of E.A.W. Budge's edition: <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">76 ll. 1-23</citedRange></bibl>.</note> 
                         </msItem>
                         <msItem xml:id="ms_i1.10">
                           <locus from="33v" to="36r"/>
                           <title type="complete">Fifth prayer</title>
                           <textLang mainLang="gez"/>
                           <note>The text corresponds to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">76 l. 24-77 l. 24</citedRange></bibl>.</note> 
                         </msItem>
                         <msItem xml:id="ms_i1.11">
                           <locus from="36r" to="37v"/>
                           <title type="complete">Sixth prayer</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez">
                             በስመ፡ <supplied reason="omitted">አብ፡</supplied> <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ዘመንገደ፡ ሰማይ፡ 
                             ዕቀበኒ፡ ክርስቶስ፡ ከመ፡ ኢያዕቅፍዋ፡ ለነፍስየ፡ መላእክተ፡ ጽልመት፡ እስእለከ፡ ወአስ<add place="above">ተ</add>በቍዓከ፡ ወአኃሥሥ፡ እምነ፡ ኂሩትከ፡
                           </incipit>
                           <explicit xml:lang="gez">
                             አነሂ፡ እስእለከ፡ ወአኃሥሥ፡ እምነ፡ ኂሩትከ፡ በዝየኒ፡ ወበከሃከኒ፡ ከመ፡ ትምሐረኒ፡ ወትሣሃለኒ፡ ለአመትከ፡ ወለተ፡ ሚካኤል፡
                           </explicit>                         
                         </msItem>
                         <msItem xml:id="ms_i1.12">
                           <locus from="33v" to="38v"/>
                           <title type="complete">Seventh prayer</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez">
                             በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡<gap reason="omitted" resp="bm:GrebTiss1935Codices"/> 
                             ዕቀበኒ፡
                           </incipit>
                           <explicit xml:lang="gez">
                             አስማተ፡ ቅንዋተ፡ መስቀሉ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ<supplied reason="omitted">፡</supplied> ሳዶር፡ አላዶር፡ ዳናት፡ እዴራ፡ ሮዳስ፡ በዴናኤል፡ ኩነኒ፡ 
                             ረዳኤ፡ ወስረት፡ ኃጢአትየ፡ ለአመትከ፡ ወለተ፡ ሚካኤ<add place="above">ል</add> ለዓለመ፡ ዓለም፡ አሜን፡
                           </explicit>                         
                         </msItem>
                     </msItem>
                    </msContents>
                  

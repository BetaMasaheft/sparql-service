                    <desc type="OwnershipNote">
                    Title of another book, <foreign xml:lang="gez">አርድዕት፡ ቱላዳን፡</foreign>, and the name of a secondary owner, Taddäsä Bäyänä, written in blue ink
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#5r" facs="009"> f. 5r and passim</locus>
                    <desc type="OwnershipNote">
                    the owner’s name is Wälätä Giyorgis
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#iv(erso) #iir(ecto) #iiv(erso) #iiir(ecto) #iiiv(erso) #ivr(ecto) #ivv(erso)" facs="002 003 004 005">Fols. iv(erso), iir(ecto), iiv(erso), iiir(ecto), iiiv(erso), ivr(ecto), ivv(erso)</locus>
                    <desc type="GuestText">
                      Image of Rufa’el, Mälk‘a Rufa’el, <foreign xml:lang="gez">መልክአ፡ ሩፋኤል፡</foreign>
                      Incipit: <foreign xml:lang="gez">ሰላም፡ ለተፈጥሮትከ፡ በዕለተ፡ ሰንበት፡ እኁድ፡</foreign>
                      Doesn't appear to match either <ref type="work" corresp="https://betamasaheft.eu/LIT2849RepCh131">Malkǝʾ-hymn to
                                                  Raphael</ref> and <ref type="work" corresp="https://betamasaheft.eu/LIT2934RepCh215">Malkǝʾ-hymn to
                                                  Raphael</ref>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#28r" facs="032"> f. 28r and passim</locus>
                    <desc>
                    mentions the scribe, Täklä Ṣǝyon
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#93v #94r" facs="098">Fols. 93v, 94r</locus>
                    <desc type="Supplication">
                    Concluding prayer of the scribe, including the line, <q>“My lady, as I have fulfilled your will, may the mother of God encourage you to fulfill my will.”</q>
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#95v" facs="100">Fol. 95v</locus>
                    <desc type="OwnershipNote">
                    Note of secondary ownership and purchase of the book for 30 birr, written in blue ink
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#68r #68v #96r #96v" facs="072 073 100 101">Fols. 68r, 68v, 96r, 96v</locus>
                    <desc>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#1 #28 #50" facs="005 032 054">Fols. 1, 28, 50</locus>
                    <desc>
                    black yarn is sewn into the fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#9 #34 #60" facs="013 038 064">Fols. 9, 34, 60</locus>
                    <desc>
                    red yarn is sewn into the fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    Numbered quires: quires 2–5
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#4v #11r #17r #24r #25r" facs="009 015 021 028 029">Fols. 4v, 11r, 17r, 24r, 25r</locus>
                    <desc>etc., words of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#2r #49r #59r" facs="006 053 063">Fols. 2r, 49r, 59r</locus>
                    <desc>
                    lines of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <locus target="#49r" facs="053"> f. 49r, line 5</locus>
                    <desc>
                    lines of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <locus target="#18r #23v #42r #44r #53v" facs="022 028 046 048 058">Fols. 18r, 23v, 42r, 44r, 53v</locus>
                    <desc>etc., erasure markings are visible
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <locus target="#18v #28v #54v #55r #57v" facs="023 033 059 062">Fols. 18v, 28v, 54v, 55r, 57v</locus>
                    <desc>etc., text has been removed
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

                      <decoDesc>
                          <decoNote xml:id="d1" type="miniature">
                              <locus target="#134r"/>
                              <desc/> <note>It contains the portraits of <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>, <persName ref="https://betamasaheft.eu/PRS2682BerhanM#n3">Walatta Giyorgis</persName>, 
                                  <persName ref="https://betamasaheft.eu/PRS2038Arkalade"><roleName type="title">ብላቴን፡ ጌታ፡ </roleName>አርከለዲስ፡ </persName>, 
                                  <persName ref="https://betamasaheft.eu/PRS2266Ayente"><roleName type="title">መምሕሬ፡</roleName> አይንቴ፡ </persName>, <persName ref="https://betamasaheft.eu/PRS9931WaldaLe"><roleName type="title">ራስ፡</roleName> ወልደ፡ ልዑል፡</persName>, 
                                  <persName ref="https://betamasaheft.eu/PRS3813enkoyye"><roleName type="title">ወይዘሮ፡</roleName>እንኰዬ፡</persName>, and
                                  <persName ref="https://betamasaheft.eu/PRS2093Asayo"><roleName type="title">ብላቴን፡ ጌታ፡</roleName> አሳዮ፡</persName></note>
                          </decoNote>
                          
                          
                      </decoDesc>
                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#5r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ገድለ፡ ጊዮርጊስ፡  ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                                    </q>
                                </item>
                                <item xml:id="e1">
                           
                                    <desc> The manuscript was written for one  <persName role="owner" ref="https://betamasaheft.eu/PRS12758Zamikael">Zamikāʾel</persName>, but for his name and those of his wife and mother, 
                                        the name of King <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName> and his mother <persName ref="https://betamasaheft.eu/PRS2682BerhanM#n3">Walatta Giyorgis</persName>, have usually been substituted.</desc>
                                    
                                    
                                </item>
                                
                            </list>
                            
                        </additions>
                        <bindingDesc>
                            <binding contemporary="true" xml:id="binding">
                                <decoNote xml:id="b1">In the original boards, covered with blind-tooled leather and lined with red silk.</decoNote>
                                <decoNote xml:id="b2" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                    <material key="silk"/>
                                    
                                </decoNote>
                            </binding>
                        </bindingDesc>
                        
                        

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                         <msItem xml:id="ms_i1.1">
                                
                         <locus from="5r" to="12v"/>
                            <title ref="https://betamasaheft.eu/LIT1287Dersan">Homily by Theodotus of Ancyra on the commemoration of St George, for
                                the 23th of Miyāzyā</title>
                            <textLang mainLang="gez"/>
                            
                        </msItem>
                      
                        
                        <msItem xml:id="ms_i1.2">
                            
                            
                            <locus from="12v" to="73r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1455GadlaG">Gadla Giyorgis (Lydda)</title>
                            <textLang mainLang="gez"/>
                            <colophon xml:id="coloph2" corresp="LIT1455GadlaG#coloph1 BLorient712#coloph1 BLorient713#coloph2">
                                <locus target="#71v"/>አመ፡ ከረመ፡ በምድረ፡ ዕንዘዞ። 
                                <note>The copied colophon gives the precise date of translation into Ethiopic.</note>
                                
                            </colophon>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                            
                            
                            <locus from="73r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4006Taamme">The miracles of George, 41 in number</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                        
                        </msItem>  

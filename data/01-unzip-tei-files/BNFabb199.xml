                            <item xml:id="a1">
                               <locus target="#1r"/>
                               <desc type="OwnershipNote"/>The note states that the manuscript was owned by
                               <persName ref="https://betamasaheft.eu/PRS9683Urbino">Giusto da Urbino</persName>.
                                 <q xml:lang="gez">መጽሐፍ፡ ዘ<persName ref="https://betamasaheft.eu/PRS9683Urbino">አባ፡ ዮስጦስ።</persName>
                                   </q>
                                   </item>

                            <item xml:id="a2">
                               <locus target="#67ra"/>
                                <desc type="PurchaseNote">Purchase note in the hand of
                                  <persName ref="https://betamasaheft.eu/PRS9683Urbino">Giusto da Urbino</persName>, stating that he
                                  bought the manuscript for the price of one <foreign xml:lang="am">Bǝrr</foreign> from disciples of <persName ref="https://betamasaheft.eu/PRS13840Yamesrac">ʾabbā Yamǝsrāč</persName> of <placeName ref="https://betamasaheft.eu/LOC5843Tadbab">Tadbāba Māryām</placeName>.
                                  The era that was used for the date is not indicated; it appears that the writer
                                  meant the Ethiopian calendar and thus the date is
                                  <date>1 October 1849 CE</date>.
                             </desc>
                             <q xml:lang="gez">ዘንተ፡ መጽሐፈ፡ ተሣየጦ፡ አባ፡ ዮስጦስ፡ ሮማዊ፡ እምኀበ፡ አርዳኢሁ፡

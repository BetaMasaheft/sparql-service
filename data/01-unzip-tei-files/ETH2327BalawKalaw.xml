         <listPerson>
            <personGrp role="ethnic">
               <persName xml:id="n1" xml:lang="ti">በለው፡ ከለው፡</persName>
               <persName corresp="#n1" xml:lang="ti" type="normalized">Balaw Kalaw</persName>
               <persName xml:id="n2" xml:lang="ti">ከለው፡ በለው፡ </persName>
               <persName corresp="#n2" xml:lang="ti" type="normalized">Kalaw Balaw</persName>
               <persName xml:id="n3" xml:lang="ti">በለውን፡ ከለውን፡</persName>
               <persName corresp="#n3" xml:lang="ti" type="normalized">Balaw Kalaw</persName>
               <note>Balaw Kalaw is a legendary ancestral people (most probably
                  related to the historical ethnic group <persName ref="https://betamasaheft.eu/ETH1194Balaw">Balaw</persName>) believed to have populated, in a very remote time,
                  in particular the vicinity of <placeName ref="https://betamasaheft.eu/LOC4639Matara">Maṭarā</placeName>, which is sometimes also 
                  referred to as Balaw Kalaw. The traditions about Balaw Kalaw have been circulating especially in 
                  <placeName ref="https://betamasaheft.eu/LOC3764Hamase">Ḥamāsen</placeName>, <placeName ref="https://betamasaheft.eu/LOC5575Saraye">Sarāye</placeName> and <placeName ref="https://betamasaheft.eu/LOC1298Akkala">Akkälä Guzay</placeName>.</note>
            </personGrp>
         </listPerson>

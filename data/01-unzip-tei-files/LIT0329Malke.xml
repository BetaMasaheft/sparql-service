         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ምስለ፡ ርእሱ፨</l>
                  <l n="2">ለገጽከ፡ ወቀራንብቲከ፡ እስከ፡ ብርሃናዊ፡ ሞገሱ፨</l>
                  <l n="3">አበ፡ ብዙኃን፡ አቢብ፡ ለእንጦንዮስ፡ ምዋርሱ፨</l>
                  <l n="4">ፈጽም፡ ሊተ፡ እግዚኦ፡ ለኅሊናየ፡ ማኅሠሡ፨</l>
                  <l n="5">በሀገረ፡ ተስፋ፡ ነፍስ፡ ምስሌከ፡ ታንሶሱ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለአእዛኒከ፡ ምስለ፡ መላትሕ፡ ኅቡረ፨</l>
                  <l n="2">ለአእናፊከ፡ ወለከናፍሪከ፡ ወለአፉከ፡ ድኅረ፨</l>
                  <l n="3">አቢብ፡ ፍቁሩ፡ ለዘኵሎ፡ ፈጠረ፨</l>
                  <l n="4">ተወከፍ፡ ጸሎትየ፡ ኵሎ፡ አሚረ፨</l>
                  <l n="5">ወእምአባላትየ፡ ስድድ፡ አበሳ፡ ወነውረ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለቆምከ፡ ፍትው፡ ወለመልክእከ፡ አዳም፨</l>
                  <l n="2">ለፀአተ፡ ነፍስከኒ፡ ወለበድነ፡ ሥጋከ፡ ሰላም፨</l>
                  <l n="3">አቢብ፡ አቡየ፡ ኮከበ፡ ገዳም፨</l>
                  <l n="4">ጸሊ፡ ሊተ፡ እግዚኦ፡ ወጸሎትከ፡ ግጹም፨</l>
                  <l n="5">ከመ፡ ታዕርፈኒ፡ እምስራህ፡ ለዛቲ፡ ዓለም፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለቆብዕከ፡ ወለአፅፍከ፡ ዘምስለ፡ አስኬማ፨</l>
                  <l n="2">ዘተረሰይከ፡ ቦሙ፡ አምሳለ፡ በዝግና፡ ቃማ፨</l>
                  <l n="3">አቢብ፡ ሥጋዊ፡ ወመልአከ፡ ሰማይ፡ ዘራማ፨</l>
                  <l n="4">በዐይነ፡ ረድኤትከ፡ ነጽር፡ ለሰብእናየ፡ ድካማ፨</l>
                  <l n="5">እስመ፡ ያረስእ፡ ሰይጣን፡ ለብዙኅ፡ ጻማ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ይጽውኡ፡ ስምከ፡ ዮም፡ እለ፡ ተጋባእነ፡ ሕዝብ፨</l>
                  <l n="2">አስተጋብአነ፡ ለዕለተ፡ ከብካብ፨</l>
                  <l n="3">ወዓዲ፡ ይእዜ፡ ቅዱስ፡ አቢብ፨</l>
                  <l n="4">አጥብበኒ፡ ለደቂቅከ፡ በዘዚአከ፡ ጥበብ፨</l>
                  <l n="5">ወበየማንከ፡ ባርከኒ፡ አብ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ማሕፀን፡ በሕማምከ፡ ሶበ፡ ነጸረከ፡ ሕማሞ፨</l>
                  <l n="2">በመልዕልተ፡ ቅዱስ፡ መስቀል፡ እንተ፡ አንጸፍጸፈ፡ ደሞ፨</l>
                  <l n="3">ለኢየሱስ፡ ክርስቶስ፡ ሕሩመ፡ በቀል፡ ወተቀይሞ፨</l>
                  <l n="4">አባ፡ አቢብ፡ ዕቀበኒ፡ እምባሕረ፡ ሲኦል፡ ተሰጥሞ፨</l>
                  <l n="5">እስመ፡ ኵሉ፡ ድኅን፡ ዘጸውዐ፡ ስሞ፨</l>
               </lg>
            </div>
         </div>
      </body>

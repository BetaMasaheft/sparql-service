                        <list type="abbreviations">
                           <item>
                              <abbr>ይ፡ ካ፡</abbr> for <expan>ይበል፡ ካሕን፡ </expan> (e.g., <locus target="#20rb">20rb</locus>, 21vb, 23ra)</item>

                    <desc>
                    words of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted;
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#30r #36r #75v #78v" facs="030 036 076 079">Fols. 30r, 36r, 75v, 78v</locus>

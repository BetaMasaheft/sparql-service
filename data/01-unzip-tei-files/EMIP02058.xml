                         <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> with <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#3v" facs="005">Fol. 3v</locus>
                        <desc type="Asmat">Chart with text of asmat prayer against the enemy, arranged in three directions</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#4v" facs="006">Fol. 4v</locus>
                        <desc>Two snakes, devouring one another, arranged in a circle, with the text of an asmat prayer against disease in the center</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#6v" facs="008">Fol. 6v</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> in the clouds with <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#7r" facs="008">Fol. 7r</locus>
                        <desc>Two intertwined snakes on either side of the folio, with the text of an asmat prayer against the enemy between</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#7v" facs="009">Fol. 7v</locus>
                        <desc type="Asmat">Chart with text of asmat prayer against the enemy, arranged in three directions</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#11v" facs="013">Fol. 11v</locus>
                        <desc type="Asmat">Chart with text of asmat prayer against the enemy, arranged in three directions</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d8">
                        <locus target="#12r" facs="013">Fol. 12r</locus>
                        <desc>Two green snakes, devouring one another, arranged in a circle, with the text of an asmat prayer against disease and warfare in the center</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d9">
                        <locus target="#15r" facs="016">Fol. 15r</locus>
                        <desc>two sets of intertwined snakes, each set containing one pink and one green snake; no text stands between</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d10">
                        <locus target="#17r" facs="018">Fol. 17r</locus>
                        <desc>two snakes surrounding a lamb with a processional <term key="cross" ana="#cross"/>
                        </desc>

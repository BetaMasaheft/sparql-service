                    <decoNote type="miniature" xml:id="d11">
                        <locus target="#17v" facs="019">Fol. 17v</locus>
                        <desc>
                        <ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d12">
                        <locus target="#18r" facs="019">Fol. 18r</locus>
                        <desc>
                          <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> holding a banner chart with text of asmat prayer to the angels, arranged in three directions</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d13">
                        <locus target="#22r" facs="023">Fol. 22r</locus>
                        <desc>Two snakes, one green and one pink, devouring one another, arranged in a circle, with the text of an asmat prayer to <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> in the center</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d14">
                        <locus target="#22v" facs="024">Fol. 22v</locus>
                        <desc type="Asmat">Chart with text of asmat prayer against the enemy, arranged in three directions</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d15">
                        <locus target="#24r" facs="025">Fol. 24r</locus>
                        <desc>Two snakes, one green and one pink, devouring one another, arranged in a circle, with the text of an asmat prayer to <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> in the center</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d16">
                        <locus target="#24v" facs="026">Fol. 24v</locus>
                        <desc>two snakes surrounding a lamb with a processional <term key="cross" ana="#cross"/>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d17">
                        <locus target="#26v" facs="028">Fol. 26v</locus>
                        <desc type="Asmat">Chart with text of asmat prayer against the enemy and epilepsy, demons, the evil eye, and thieves</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d18">
                        <locus target="#27v" facs="029">Fol. 27v</locus>
                        <desc> A faded illumination of a <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> (with <term key="halo" ana="#halo"/>)</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d19">
                        <locus target="#28v" facs="030">Fol. 28v</locus>
                        <desc>A faded illumination of a goat seated on an altar</desc>

          <msContents>
            <summary/>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="86v" facs="005"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <note>The text is arranged for the days of the week</note>
              <colophon xml:id="coloph1">
                <locus target="#86v" facs="091"/>
                <seg xml:lang="gez" type="supplication"> ኦ፡ አቡየ፡ ቀሲስ፡ ወመነኮስ። <lb/> ዘተሰመይከ፡ገብረ፡ ሥላሴ፡
                  ቅዱስ። <lb/> ኢትርሥአኒ፡ ለፍቁርከ፡ ተክለ፡ ማርያም፡ ሐዲስ። <lb/> በይነ፡ ዘጸሐፍኩ፡ ለከ፡ ቃለ፡ ወንጌሉ፡ ለክርስቶስ።
                  <lb/> ኁልቈ፡ ፩ዱ፡ አቡነ፡ ዘበሰማያት፡ ለእንተ፡ ኢትመውት፡ ነፍስ። <lb/> ወበዝ፡ ዓለም፡ ለዕቅበተ፡ ሥጋየ፡ ንኡስ።
                </seg> ይትባረክ፡፡እግዚአብሔር፡ ዘአፈጸመኒ፡ በዳኅና፡ ወበሰላም። በ፲ወ፱፻፴፫ዓ፡ ም፡ ዘወረቆ፡ ውጉዝ፡ </colophon>

            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="89r" to="102v" facs="093"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"/>መጽሐፈ፡ ሕይወት፡ ልፋፈ፡ ጽድቅ፡
                ጸሎተ፡ መድኃኒት፡ ዘጸሐፈ፡ አብ፡ በእደዊሁ፡ ቅዱሳት፡<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i3">
              <locus from="117r" to="128v" facs="121"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> which Jesus gave to the
                disciples</title>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"/>ጸሎት፡ ዘተስእልዎ፡ አርዳኢሁ፡
                ለኢየሱስ፡ ክርስቶስ፡ ወይቤልዎ፡ ክሥት፡ ለነ፡ እግዚኦ፡ ዘንተ፡ ስመከ፡ ኅቡዓ፡<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i4">
              <locus from="129r" to="135v" facs="133"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT1873Mangad">Mangada samāy</title>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"/>ጸሎተ፡ መንገደ፡ ሰማይ፡ ዕቀበኒ፡
                ክርስቶስ፡ ከመ፡ ኢያዕቅፍዋ፡ ለነፍስየ፡ መላእክተ፡ ጽልመት፡<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i5">
              <locus from="135v" to="145r" facs="140"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> spoken to Andrew</title>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ…፡ ጸሎት፡ ዘተናገሮ፡ ለእንድርያስ፡ ሐዋርያ፡ ጸሎቱ<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i6">
              <locus from="145r" to="149v" facs="149"/>
              <title>Table blessing, “We beseech you,” Sä’alnakä, <foreign xml:lang="gez">ሰአልናከ</foreign></title>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"/> ሰአልናከ፡ መሐሪ፡ ሰአልናከ፡ ፈጣሪ፡
                ሰአልናከ፡ ከሃሊ፡ ዘሰአሉከ፡ ትሁብ<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i7">
              <locus from="102r" to="109r" facs="106"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat za-wald</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"/> ጸሎተ፡ ፍትሐት፡ ዘወልድ፡ እግዚእ፡
                እግዚኦ፡ ኢየሱስ፡ ክርስቶስ፡ ወልድ፡ ዋህድ፡ ቃለ፡ እግዚአብሔር፡ አብ፡ ዘበተከ፡ እምኔነ<gap reason="omitted"/></incipit>
            </msItem>
            <msItem xml:id="ms_i8">
              <locus from="109v" to="113r" facs="114"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
              <incipit xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡ እግዚአብሔር፡ ዘሥልጣናት፡ እግዚአብሔር፡ ዘአርእስተ፡ መላእክት<gap reason="omitted"/></incipit>
            </msItem>

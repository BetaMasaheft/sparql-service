                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">iv + 152</measure>
                           <dimensions type="outer" unit="mm">
                              <height>178</height>
                              <width>175</width>
                              <depth>87</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Codex has been extensively rebound, and the original construction of the manuscript is no longer discernible.</note>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">18</dim>

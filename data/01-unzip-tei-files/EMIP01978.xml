               <msContents>
                  <summary>Psalter, ዳዊት።, rebound in the late-twentieth century</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="148v">Fols 1r–148v</locus>
                     <title type="complete" facs="005" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters</note>
                  </msItem>
               </msContents>
               <physDesc>

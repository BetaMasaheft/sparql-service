                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                           <desc>The word God is not rubricated in the first three works; the word Mary is rubricated in the final two works</desc>
                        </seg>
                        <desc>There is no columetric layout of text</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                       Decorative designs:
                       <locus target="#8r #16r #24r #34r #42r #48v #58v #70r #79v #85v #97r #106v #114v #120r #131v #137v #138v #139v #141r #142v #144r #144v #145 #148v" facs="012 020 028 038 046 053 063 074 084 090 101 111 119 124 136 142 143 144 145 147 148 149 018 153">fols. 8r, 16r, 24r, 34r, 42r, 48v, 58v, 70r, 79v, 85v, 97r, 106v, 114v, 120r, 131v, 137v, 138v, 139v, 141r, 142v, 144r, 144v, 145, 148v</locus> (line of alternating red and black dots)
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                          <locus target="#ir(ecto) #iv(erso) #iir(recto) #iiv(erso) #iiir(ecto) #iiiv(erso) #ivr(ecto) #ivv(erso) #149r #149v #150r #150v #151r #151v #152r #152v" facs="001 002 002 003 003 004 004 005 153 154 154 155 155 156 156 019">Fols. ir(ecto), iv(erso), iir(recto), iiv(erso), iiir(ecto), iiiv(erso), ivr(ecto), ivv(erso), 149r, 149v, 150r, 150v, 151r, 151v, 152r, 152v</locus>
                           <desc>blank</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#65r" facs="069">Fol. 65r</locus>
                           <desc>mid-point of the Psalter is marked with a symbol of one vertical line and three horizontal lines with circles at both ends of the horizontal lines</desc>
                        </item>
                        <item xml:id="e3">
                          <locus target="#145v" facs="150">f. 145v, upper margin</locus>
                           <desc type="OwnershipNote">Note of secondary ownership</desc>
                        </item>
                        <item xml:id="e4">
                           <desc>Identified in the insurance hand list as Psalter 13</desc>
                        </item>
                        <item xml:id="e5">
                           <desc>Rebound and trimmed in the late-twentieth century; stab stitch holes in the upper gutter are visible from an earlier repair</desc>
                        </item>
                        <item xml:id="e6">
                          <locus target="#1v" facs="006">Fol. 1v</locus>
                           <desc>Words of text are written interlinearly</desc>
                           </item>
                        <item xml:id="e7">
                          <locus target="#53v" facs="058">Fol. 53v</locus>
                          <desc>Erasure markings are visible</desc>
                          </item>
                        <item xml:id="e8">
                          <locus target="#56r #58r" facs="060 062">Fols. 56r, 58r</locus>)
                          <desc>Text has been removed</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding xml:id="binding" contemporary="false">
                        <decoNote xml:id="b1">Parchment, 178 x 175 x 87 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with tooled leather, headband and tailband. Rebound in the late-twentieth century.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">

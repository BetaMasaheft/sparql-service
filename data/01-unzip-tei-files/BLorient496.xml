                        <additions>
                            <list> 
                                                             
                                
                                
                                <item xml:id="a1">
                                    <locus target="#3r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                    </desc>
                                    <q xml:lang="gez">ኢዮብ፡ ዘቅ' ፡ መ' ፡ ዓለም።</q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#2v"/>
                                    <desc type="PurchaseNote">a note, stating that this Ms. 
                                        belonged by purchase to one <persName role="owner" ref="https://betamasaheft.eu/PRS11391WaldaA">Walda ʾAmlāk</persName>
                                    </desc>
                                    <q xml:lang="gez">ዝመጽሐፍ፡ ዘወልደ፡ አምላክ፡ ዘአጥረዮ፡ በንዋዩ፡ ከመ፡ ይኵኖ፡ 
                                        ለመድኃኒተ፡ ነፍሱ፡ ወሥጋሁ፡ ዘሠረቆ፡ ወዘፈሐቆ፡ 
                                        በሥልጣነ፡ ዼጥሮስ፡ ወጳውሎስ፡ ውጉዘ፡ ይኩን፡ ከመ፡ አርዮስ፡ ለዓለመ፡ ዓለም። አሜን።</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#193v"/>
                                    <desc type="GuestText">A short history of Prophet Daniel 
                                    </desc>
                                    <q xml:lang="gez">ዳንኤል፡ ነቢይ፡ እምነገደ፡ ይሁዳ፡ ወእምዘመደ፡ ነገሥት፡ ውእቱ ፤ 
                                        ወኮነ፡ ስመ፡ አቡሁ፡ ሴምዩ፡ ወስመ፡ እሙ፡ ሚላናስ፡ etc.</q>
                                </item>
                               
                                
                            </list>
                        </additions>
                        

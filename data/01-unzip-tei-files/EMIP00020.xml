                        <locus from="33v" to="34r" facs="034"/>
                        <title>Greeting to Abib</title>
                        <incipit xml:lang="gez">ሰላም፡ ለከ፡ አቢብ፡ ኅሩይ፡ ዘተከለልከ፡ ሞገስ። እስመ፡ ምስለ፡ ዐቢይ፡ ንጉሥ፡ ዐረይከ፡ ነጊሠ።</incipit>

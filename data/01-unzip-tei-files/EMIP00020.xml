                     <msItem xml:id="ms_i1.7">
                        <locus from="38r" to="44r" facs="038"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">Māḫbara mǝʾmanān</title>
                        <incipit xml:lang="gez">መኅበረ፡ ምእመናን፡ ወምእምናት፡ እለ፡ ኪያከ፡ ተአመኑ። ለነሢአ፡ ሥጋከ፡ ወትረ፡ ኀበ፡ ተዓየኑ።</incipit>

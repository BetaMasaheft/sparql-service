                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Monday
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#22r" facs="022">Fol. 22r</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Saturday
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#27r" facs="027">Fol. 27r</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Tuesday
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#36v" facs="037">Fol. 36v</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Wednesday
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#45v" facs="046">Fol. 45v</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Thursday
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#56r" facs="056">Fol. 56r</locus>
                    <desc type="GuestText">
                    <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Friday
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#65r" facs="065">Fol. 65r</locus>
                    <desc type="GuestText">
                    <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>: Sunday
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <locus target="#1r #1v #2r" facs="001 002">Fols. 1r, 1v, 2r</locus>
                    <desc>
                    scribal exercise, excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>, written in strophes
                    </desc>
                    </item>
                    <item xml:id="a9">
                    <locus target="#85v #86r" facs="086">Fols. 85v, 86r</locus>
                    <desc>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>, about the crying icon and a child who grew to become a monk
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#2r" facs="002">Fol. 2r</locus>
                    <desc>
                    notes and scrawls
                    </desc>
                    </item>
                    <item xml:id="a10">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc type="OwnershipNote">
                    Note of ownership mentioning father, wife, brothers, mother, several of which names are effaced
                    </desc>
                    </item>
                    <item xml:id="a11">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc type="OwnershipNote">
                    Mentions the name of the original patron, <foreign xml:lang="gez">አቡነ፡ ወልደ፡ ማርያም፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a12">
                    <locus target="#70r #85r" facs="070 085">Fols. 70r, 85r</locus>
                    <desc>
                    Final prayers for “<foreign xml:lang="gez">ክንፈ፡ ሚካኤል፡</foreign>, Kenfe Mika’el, with my father <foreign xml:lang="gez">ወልደ፡ ተክለ፡ ሃይማኖት፡</foreign>, Walda Takla Haymanot.”
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    Where one would expect prayers for Bishops and Kings in peaceful Holy Things, there are left spaces for names which are not filled in
                    </desc>
                    </item>
                    <item xml:id="a13">
                    <locus target="#85v" facs="086"> f. 85v, column 1</locus>
                    <desc>
                    Record of reconciliation between two people, with names of mediators and witnesses
                    </desc>
                    </item>
                    <item xml:id="a14">
                    <locus target="#86r" facs="086"> f. 86r, column 2</locus>
                    <desc type="Record">
                    Record: List of the feast of the Apostles
                    </desc>
                    </item>
                    <item xml:id="a15">
                    <locus target="#86v" facs="087">Fol. 86v</locus>
                    <desc>
                    Writing exercise of the first two letters (in all seven orders) of the Ge’ez syllabary, written in pencil
                    </desc>
                    </item>
                    <item xml:id="a16">
                    <desc>
                    Purchased by Dr. Sobania in Aksum in 2012 from the scribe, Qes Aragawi Teklahaimanot
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    The manuscript has been donated to Hope College, Holland Michigan, where it as assigned the accession number 2018.25.43
                    </desc>
                    </item>
                  </list>

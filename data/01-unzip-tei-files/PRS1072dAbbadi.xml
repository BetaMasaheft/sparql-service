      <body>
         <listPerson>
            <person sex="1" sameAs="wd:Q2477471">
                     <persName>
                        <forename> Arnauld [Michel]</forename>
                        <surname>d’Abbadie [d’Arrast]</surname>
                     </persName>
                     <occupation type="academic">traveller</occupation>
                     <nationality type="France"/>
                     <faith type="Catholicism"/>
                     <birth when="1815"/>
                     <residence>Dublin</residence>
                     <floruit when="1837" evidence="internal">He arrived in Ethiopia together with his elder brother <persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d’Abbadie [d’Arrast]</persName> in
                        <date>1837</date>. He was very close to <persName ref="https://betamasaheft.eu/PRS4779GossuZa">Goššu Zawde</persName> 
                        during his stay in Ethiopia and he secured also the research activities of his elder brother <persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d’Abbadie [d’Arrast]</persName>. 
                        He was the commissioner of the collection of royal chronicles preserved in <placeName ref="https://betamasaheft.eu/INS0303BNF">Bibliothèque nationale de France</placeName> 
                       
                     </floruit>
                     <death when="1893"/>
                  </person>
                  
         </listPerson>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
          
                  
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">በትረ፡ ማርያም፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Batra Māryām</t:persName>
                  
                  <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
               <t:floruit notBefore="1300" notAfter="1399">He was a 14th century saintly monk. 
                  He was born in <t:placeName ref="https://betamasaheft.eu/LOC4892Mugar">Mugār</t:placeName>
                  and he entered in the monastery belonging to the community of <t:persName ref="https://betamasaheft.eu/PRS9162TaklaHa">
                     Takla Hāymānot</t:persName> where he received monkhood. 
                  After he had been ordained deacon, then priest, he became the administrator of the monastery of 
                  <t:placeName ref="https://betamasaheft.eu/LOC2341DabraS">Dabra Sablā</t:placeName>. 
                  After he was attacked by the <t:persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/PRS2540BatraMa">Batra Māryām</t:persName> was forced to flee  
                  through <t:placeName ref="https://betamasaheft.eu/LOC2488Damot">Dāmot</t:placeName>, <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName> and 
                  <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName>. 
                  Finally, he settled at the island of <t:placeName ref="https://betamasaheft.eu/LOC6411Zage">Zage</t:placeName> 
                  where he established a community that cultivated the soil and built a church dedicated to <t:persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</t:persName>.</t:floruit>
                  
               </t:person>
               
         </t:listPerson>

                  <msItem xml:id="ms_i4">
                     <locus from="71" to="82"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4691Prayer">Prayers for the weekdays</title>
                     <msItem xml:id="ms_i4.1">
                        <locus from="71r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Monday">Prayer for the weekdays, Prayer for Monday</title>
                        <incipit xml:lang="gez">
                           እግዚአብሔር፡ አምላክ፡ ዓቢይ፡ ወግሩም፡ ዘአልቦ፡ ጥንት፡ ወኢተፍጻሜት፡ ወይሄሉ፡ <supplied reason="lost">እስከ፡ ለዓለ</supplied>ም፡ እስእለ<supplied reason="lost">ከ፡ 
                              ወኣስተበቍ</supplied>ዓከ፡ ከመ፡ ትርድአኒ፡ ወትባልሐኒ፡ ወታድኅነኒ፡ እምኵሉ፡ ዘእፈርህ፡ ወእትዓቀብ፨ ወአእትት፡ እምኔየ፡ እከዮ፡ ለሰይጣን፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ኦእግዚኦ፡ አድኅነኒ" እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገብርከ፡ ናትናኤል፡ የብ<gap reason="illegible" unit="chars" quantity="2"/>፨
                        </explicit>
                        <note>The name of <persName ref="https://betamasaheft.eu/PRS11695Natnael">Nātnāʾel</persName> is mentioned in the supplication formula at the end of the text.</note>
                     </msItem>                       
                     <msItem xml:id="ms_i4.2">
                        <locus from="72" to="74"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Tuesday">Prayer for the weekdays, Prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           አርእየኒ፡ እግዚኦ፡ በ<gap reason="illegible" unit="chars" quantity="3"/> ዛቲ፡ ዕለት፡ <choice>
                              <sic>ሠናይት፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ሠናይተ፡</corr>
                           </choice> 
                           <supplied reason="lost">ስ</supplied>ማዕ፡ ጸሎትየ፡ ወተወከፍ፡ ስእለትየ፤ ወሥረይ፡ ሊተ፡ ኃጢአትየ፡ ወኢትመጥወኒ፡ ውስተ፡ 
                              <sic>እዳ፡</sic>
                            
                           ዘይሔይለኒ፤ ወአሰስል፡ እምኔየ፡ እከዮ፡ ለሰይጣን፡ ወመዓቶሙኒ፡ ለሥዩማን፤
                        </incipit>
                        <explicit xml:lang="gez">
                           ወደምረነ፡ ኅቡረ፡ ውስተ፡ መንግሥትከ፡ ምስለ፡ ኄራን፡ አግብርቲከ፡ እስመ፡ ለከ፡ ይእቲ፡ መንግሥት፡ ኃይል፡ 
                              <sic>ወክብስት፡</sic>
                            ለዓለመ፡ ዓለም፤ ሚጥ፡ ገጸከ፡ 
                           እምኃጢአትየ፡ ወኢታርኅቅ፡ ሠናይተከ፡ እምኔየ፨ ኦሰማዔ፡ ኵሎሙ፡ እለ፡ ይጼውዕዎ፡ በጽድቅ፡ ስማዕ፡ ጸሎትየ፡ ወተወከፍ፡ ስእለትየ፡ በሣህልከ፡ ወምሕረትከ፡ እስመ፡ አኰቴት፡ ለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i4.3">
                        <locus from="74" to="76"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Wednesday">Prayer for the weekdays, Prayer for Wednesday</title>
                        <incipit xml:lang="gez">
                           ይትባረክ፡ እግዚአብሔር፡ አቡሁ፡ ለእግዚእነ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                              <sic>ነአኵቶ፡</sic>
                            
                           በኵሉ፡ ሰዓት፡ በእንተ፡ ጸጋ፡ ዘወሀበነ፡ ኅቡአ፤ ወክሡተ፡ እስእለከ፡ እግዚኦ፡ በዕበይከ፡ ወግርማከ፡ ወኃይልከ፡ ወመለኮትከ፨ ከመ፡ ትረሲ፡ ዛተ፡ ዕለተ፡ ሠናይተ፡ ወቡርክት፨ 
                        </incipit>
                        <explicit xml:lang="gez">
                           ረስየኒ፡ አፍቀር፡ ገቢረ፡ ሠናይ፡ ወእጽላዕ፡ እኩየ፡ በሣህልከ፡ ወምሕረትከ፡ እስመ፡ አንተ፡ መሐሪ፡ ወመስተሣህል፡ ለከ፡ ይደሉ፡ ክብር፡ ወስብሐት፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨ ፨ ኦእግዚእየ፡ አድኅነኒ፡ 
                           እመንሱት፡ ለገብርከ፡ ናትናኤል።
                        </explicit>
                        <note>The name of <persName ref="https://betamasaheft.eu/PRS11695Natnael">Nātnāʾel</persName> is mentioned in the supplication formula at the end of the text.</note>
                     </msItem>                       
                     <msItem xml:id="ms_i4.4">
                        <locus from="76" to="78v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Thursday">Prayer for the weekdays, Prayer for Thursday</title>
                        <incipit xml:lang="gez">
                           እሴብሖ፡ ለእግዚ<del rend="effaced">አብሔር፡</del> በእንተ፡ ጸጋ፡ ዘወሀበኒ፡ ወአፈድፈደ፡ ላዕሌየ፡ ሠናይቶ፡ ወበረከታቲሁ፡ ዘአልቦ፡ ኍልቍ፨ ተወከልኩ፡ ላዕሌከ፡ እግዚኦ፡ ዕቀበኒ፡ ወኢትግድፈኒ፡ 
                           እስመ፡ 
                              <sic>ኢትመንኖሙ፡</sic>
                            
                           <choice>
                              <sic>ላዕለ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ለእለ፡</corr>
                           </choice> 
                           ይሴፈዉ፡ ኪያከ፡ ነጽር፡ ድካምየ፡ ወትሕትናየ፤ ወስረይ፡ ሊተ፡ አበሳየ፡ ወኃጢአትየ፡                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ኢትሚጥ፡ ገጸከ፡ እምኔየ፡ ወኢታርኅቅ፡ ሣህለከ፡ እምላዕሌየ፡ አድኅነኒ፡ እግዚኦ፡ እምእሳተ፡ ገሃነም፤ ስረይ፡ ሎሙ፡ እግዚኦ፡ ለአቡየ፡ ወለእምየ፡ ወሥመር፡ ቦሙ፡ በከመ፡ ሠመርኮሙ፡ ለቅዱሳኒከ፤ እስመ፡ 
                           ኵሉ፡ ይትከሀለከ፡ ስብሐት፡ ወአኰቴት፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨ ፨ ኦእግዚእ፡ አድኅነኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገብርከ፡ ናትናኤል፡ የ<gap reason="illegible" unit="chars" quantity="3"/>
                        </explicit>
                        <note>The name of <persName ref="https://betamasaheft.eu/PRS11695Natnael">Nātnāʾel</persName> is mentioned in the supplication formula at the end of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i4.5">
                        <locus from="79" to="80v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Saturday">Prayer for the weekdays, Prayer for Saturday</title>
                        <incipit xml:lang="gez">
                           ይትባረክ፡ እግዚአብሔር፡ ዘፈጠረ፡ ሰማየ፡ ወ<supplied reason="lost">ምድረ፡</supplied> ወኵሎ፡ ዘውስቴቶሙ፡ ከሀሊ፡ ወመዋኢ፡ ወሀቢ፡ ወመሐሪ፡ የዋህ፡ ዘእምትካት፡ 
                           <add place="interlinear">ወ</add>ይነብር፡ እስከ፡ ለዓለመ፡ ዓለም፤ 
                              <sic>የአምር፡</sic>
                            ኵሎ፡ ወአልቦ፡ ዘየሰአኖ፡ እስእለከ፡ በዕበይከ፡ ወግርማከ፡ 
                           በኃይልከ፡ ወመንግሥትከ፡ ከመ፡ ትሥረይ፡ ኃጢአትየ፤ ወጌጋይየ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           አርኅቅ፡ እምኔየ፡ ሰይጣነ፡ ወሠራዊቶ፨ ወአድኅነኒ፡ እመዓተ፡ ንጉሥ፡ በዕበይከ፤ ሀበኒ፡ እግዚኦ፡ ፍቅረ፡ አኃው፡ ወርድአኒ፡ በዕለተ፡ ምንዳቤየ፤ እስመ፡ ኪያከ፡ ተሰፈውኩ፡ ወብከ፡ ተአመንኩ፡ ወላዕሌከ፡ 
                           ተወከልኩ፡ ለከ፡ ስብሐት፡ ለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i4.6">
                        <locus from="80v" to="82"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT4691Prayer#Sunday">Prayer for the weekdays, Prayer for Sunday</title>
                        <incipit xml:lang="gez">
                           እስእለከ፡ 
                              <sic>ስእላተ፡</sic>
                            
                           <supplied reason="lost">በእንተ፡ ተ</supplied>አምኖ፡ 
                           ኃጣው<supplied reason="omitted">እ</supplied>
                           <supplied reason="lost">የ፡ ወተ</supplied>ዓልዎትየ፡ ከመ፡ ትኅድግ፡ አበሳየ፡ ዘኃለፈ፡ ዘይከውን፡ ባቲ፡ ስምዓ፡ 
                           ተዓቅቦትከ፡ ወይኌልቍዎ፡ መላእክቲከ፤ ወዘይሌብዋ፡ <supplied reason="omitted">ለ</supplied>አእምሮትከ፡ ወይፈትና፡ <supplied reason="omitted">ለ</supplied>አፍቅሮትከ፡ 
                           ለእለ፡ ያፈቅሩከ፤ ወተአዘዙ፡ ለትእዛዝከ፡ ወእለ፡ አምኑ፡ በስምከ፡ ዘውእቶሙ፡ ሴት፡ ወሄኖክ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           በሥልጣነ፡ ኤልሳዕ፡ ወልደ፡ ሴሎማዊት፡ ዘአንሥአ፡ አሐደ፡ ምውተ፡ በሕይወቱ፤ ወአሕየወ፡ ዓዲ፡ ድኅረ፡ ሞቱ፡ ምውተ፡ ሶበ፡ ለከፈት፡ አዕፅምቲሁ፤ ወበጸሎተ፡ ሕዝቅያስ፡ ንጉሥ፡ ዘአስተኃፈርኮ፡ ቦቱ፡ 
                           ለሰናክሬም፡ ወአድኃ
                        </explicit>
                        <note>The text is incomplete; it terminates abruptly.</note>
                     </msItem>

                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="11v"/>
                     <title>Praises to God</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="3r"/>
                        <title>Praises</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ፩አምላክ፡ ስቡሕ፡ ወውዱስ፡ ዘሣረረ፡ ኵሎ፡ ዓለመ፡ በአሐቲ፡ ቃል፨ 
                           ቅዱስ፡ ቅዱስ፡ ቅዱስ፤ እግዚአብሔር፡ አምላከ፡ አማልክት፡ ዘሀሎ፡ ወይሄሉ፤ ኦእግዚኦ፡ መሐረነ፡ ኦእግዚኦ፡ ተሣሃለነ፤ ኦእግዚኦ፡ ባርከነ፨ ሃሌ፡ ሉ<supplied reason="lost">ያ፡</supplied> 
                           ለአብ፤ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ስብሐት፡ ለአብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           ቅዱስ፤ ቅዱስ፤ ቅዱስ፤ እግዚአብሔር፡ ጸባዖት፡ ፍጹም፡ ምሉእ፡ ሰማያተ፡ ወምድረ፡ ቅድሳተ፡ ስብሐቲከ፨ እሰግድ፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እንዘ፡ ሠለስቱ፡ አሐዱ፤ ወእንዘ፡ አሐዱ፡ ሠለስቱ፨ 
                           <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> እሰግድ፡ ለመስቀለ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተሰቅለ፡ በእንቲአነ፡ 
                           ለቤዛ፡ ኵሉ፡ ዓለም፨ እሰግድ፡ ለንጽሐ፡ ሥጋሃ፡ ለእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፨
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="5r" to="7v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2248salota">Prayer of Thanksgiving by St Basil</title>
                        <incipit xml:lang="gez">
                           ጸሎተ፡ አኰቴት፡ ዘቅዱስ፡ ባስልዮስ። 
                              <sic>ነአኵቶ፡</sic>
                            ለገባሬ፡ ሠናያት፡ ላዕሌነ፡ እግዚአብሔር፡ መሓሪ፡ አቡሁ፡ ለእግዚእነ፡ 
                           <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> እስመ፡ ሠወረነ፡ ወረድአነ፡ ዓቀበነ፡ ወአቅረበነ፡ ወተወክፈነ፡ ኀቤሁ፡ 
                           ወተማኅፀነነ፡ ወአጽንዓነ፡ ወአብጽሐነ፡ እስከ፡ ዛቲ፡ ሰዓት፨
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps50">Mazmura Dāwit, Psalmus 50</title>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="10v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2811RepCh95">Malkǝʾ-hymn to Our Lady Mary</title>
                        <incipit xml:lang="gez">
                       ሰላም፡ ለኪ፡ እንዘ፡ ንሰግድ፡ ንብለኪ፤ ማርያም፡ እምነ፡ ናስተ<supplied reason="omitted">በ</supplied>ቍዓኪ፤
                        </incipit>

          <div type="edition" xml:id="bav">
            <note>The incipits for the stanzas are taken from <bibl corresp="http://zotero.org/groups/358366/items/QZH8VYBF"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:GrebTiss1935Codices"/><title level="m">Bybliothecae apostolicae Vaticanae codices manu scripti recensiti iussu Pii XI Pontificis maximi. Codices Aethiopici Vaticani et Borgiani, Barberinianus orientalis 2, Rossianus 865&lt;hi rend="italics"&gt;, I:&lt;/hi&gt; Enarratio codicum</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sylvain</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Grébaut</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Eugène</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Tisserant</t:surname></author><pubPlace>Città del Vaticano</pubPlace><publisher>In Bybliotheca Vaticana</publisher><date>1935</date><citedRange unit="page">799-800</citedRange></bibl>, which describes <ref type="mss" corresp="https://betamasaheft.eu/BAVborget9">Vatican City, Biblioteca Apostolica Vaticana, Vat. Borg. et. 9</ref>.</note>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza1">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>እምብዙኅ፡ ተአምሪከ፡ ዕዜኑ፡ አሐተ፡ ኤዎስጣቴዎስ፡ ዘትገብር፨ ዓበይተ፡ ኃይላተ፡ መኰንን፡ ዝኁር፨ ሶበ፡ ፈቀደ፡ ነሢተ፡ መቃብሪከ፡ ክብርተ፨</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza2">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ካልዕ፡ ተአምሪከ፡ ኤዎስጣቴዎስ፡ ድንግል፡ አመ፡ ውስተ፡ ባሕር፡ ተሰጥመ፨ እንዘ፡ ይጐይይ፡ እምቀትል፤</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza3">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ሣልስ፡ ተአምሪከ፡ ዝውእቱ፤ ከመ፡ አድኃንኮሙ፡ አባ፡ ለኃብተ፡ እግዚእ፡ ወለወለቱ፨ እመቅሠፍተ፡ ሥራይ፡ ኅሱም፡</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza4">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ራብዕ፡ ተአምሪከ፡ ኤዎስጣቴዎስ፡ አቡየ፡ ለብእሲት፡ አሐቲ፨ ዘአልቦ፡ ሲሳየ፤</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza5">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ሓምስ፡ ተአምሪከ፡ ኤዎስጣቴዎስ፡ ሕይወት። ከመ፡ መሰጥካ፡ በኃይል፡ እመልአከ፡ ሞት፨ ለብእሲት፡ አሐቲ፡</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza6">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ሳድስ፡ ተአምሪከ፡ ኤዎስጣቴዎስ፡ ስቡሕ፤ ለብእሲ፡ አሐዱ፡ ኃጣውኢሁ፡ ብዙኅ፨ ዘከመ፡ አድኃንኮ፡</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza7">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ነያ፡ ሳብዕ፡ ለተአምሪከ፡ ፍቅዳ፨ ኤዎስጣቴዎስ፡ መገሥጽ፡ ከመ፡ ተግሣጸ፡ እም፡ ላዕለ፡ ውሉዳ፨</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza8">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ሣምን፡ ተአምሪከ፡ ኤዎስጣቴዎስ፡ አዳም፨ ከመ፡ ሠወርከ፡ በገዳም፨ እሞገደ፡ ብዙዝ፡ ዓክራም፨</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza9">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ታሥዕ፡ አአምሪከ፡ እዜኑ፡ ዜና፨ ኤዎስጣቴዎስ፡ አቡየ፡ ምሉዓ፡ ጥበብ፡ ወልቡና፨</ab>
              </div>
            </div>

            <div type="textpart" subtype="stanza" xml:lang="gez" xml:id="Stanza10">
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>ኣስር፡ ተአምሪከ፡ በኍልቈ፡ ቃላት፡ ኤዎስጣቴዎስ፡ ኃያል፡ ወገባሬ፡ ኵሉ፡ መንክር፨</ab>
              </div>
            </div>

         </div>
      
      <div type="edition" xml:lang="gez" xml:id="mg" corresp="https://betamasaheft.eu/LIT6200Hymn"><bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
        <div type="textpart" xml:id="masgabiya">
          <lg type="stanza" n="1">
            <l n="1">መንክራቲከ፡ ሰማዕነ፡ እንዘ፡ ትነብር፡ አርማንያ፡ መካነ፨</l>
            <l n="2">ኤዎስጣቴዎስ፡ ተኣምር፡ በኢትዮጵያ፡ ዘኮነ፨</l>
            <l n="3">መርበብቶ፡ ኢይስፋሕ፡ ውስተ፡ ማኅበርነ፨</l>
            <l n="4">ትትበአስ፡ መስተቃርነ፡ ብጽሐነ፡ ፍጡነ፨</l>
            <l n="5">ዘተሠርኀከ፡ ሥነ፡ ጳዝዮን፡ አቡነ፨</l>
          </lg>
        </div>
        <div type="textpart" xml:id="malke">
          <lg type="stanza" n="1">
            <l n="1">እምብዙኅ፡ ተኣምሪከ፡ ኣቀድም፡ አሐተ፨</l>
            <l n="2">ኤዎስጣቴዎስ፡ ዘትገብር፡ ዐበይተ፡ ኀይላተ፨</l>
            <l n="3">መኰንን፡ ዝኁር፡ ሶበ፡ ፈቀደ፡ ነሢተ፨</l>
            <l n="4">መቃብሪከ፡ ክብርተ፡ በአእባነ፡ ባሕርይ፡ ሕንፅተ፨</l>
            <l n="5">ምስለ፡ ሠራዊቱ፡ ብዙኅ፡ ረሰይኮ፡ ሐውልተ፨</l>
          </lg>
          <lg type="stanza" n="2">
            <l n="1">ካልእ፡ ተኣምሪከ፡ ኤዎስጣቴዎስ፡ ድንግል፨</l>
            <l n="2">አመ፡ ውስተ፡ ባሕር፡ ተሠጥመ፡ እንዘ፡ ይጐይይ፡ እምቀትል፨</l>
            <l n="3">በከመ፡ አድኀንኮ፡ ለብርሃነ፡ መስቀል፨</l>
            <l n="4">በዐጽፈ፡ ዚአከ፡ እምትንሣኤ፡ ግሩም፡ ማዕበል፨</l>
            <l n="5">መኑ፡ ከማከ፡ ገቢረ፡ ዘይክል፨</l>
          </lg>
          <lg type="stanza" n="10">
            <l n="1">ዐሥር፡ ተኣምሪከ፡ በኍልቈ፡ ቃላት፡ ዐሥር፨</l>
            <l n="2">ኤዎስጣቴዎስ፡ ኀያል፡ ገባሬ፡ ተኣምር፨</l>
            <l n="3">ከመ፡ ታዘንም፡ ሎሙ፡ ለሰብአ፡ አሐቲ፡ ሀገር፨</l>
            <l n="4">በሐሩር፡ ወቍር፡ ወበብዙኀ፡ ዐባር፨</l>
            <l n="5">እንዘ፡ ኵላ፡ ትውዒ፡ ምድር፨</l>
          </lg>
          <lg type="stanza" n="11">
            <l n="1">አናኅኩ፡ ነፍስየ፡ ወከሠትኩ፡ አፈ፨</l>
            <l n="2">ኤዎስጣቴዎስ፡ እዜኑ፡ ተኣምሪከ፡ ትሩፈ፨</l>
            <l n="3">አናብስተ፡ ግርዳም፡ መፍርሃን፡ እንዘ፡ ይትለአኩከ፡ ዘልፈ፨</l>
            <l n="4">አሐዱ፡ ዘይጸውር፡ ዐጽፈ፨</l>
            <l n="5">ወካልኡ፡ ክልኤተ፡ መንጸፈ፨</l>
          </lg>
          <lg type="stanza" n="12">
            <l n="1">ለዝንቱ፡ አበ፡ መንፈስነ፡ ዕበየ፡ ገድሉ፡ አምጽኡ፨</l>
            <l n="2">ዘሰበከ፡ ለነ፡ ተክለ፡ ሃይማኖት፡ ረድኡ፨</l>
            <l n="3">ነጸርክዎ፡ ይቤ፡ ቅድመ፡ መንበረ፡ አብ፡ ወበግዑ፨</l>
            <l n="4">እንዘ፡ ይቀውም፡ በግርማ፡ ምስለ፡ ሊቃናት፡ ሰብዑ፨</l>
            <l n="5">እሙንኬ፡ ወጽድቅ፡ ስምዑ፨</l>
          </lg>
          <lg type="stanza" n="13">
            <l n="1">ኵሉሰ፡ ተኣምሪሁ፡ ሶበ፡ ተጽሕፈ፡ በበ፡ አሐዱ፨</l>
            <l n="2">እመ፡ ኢተገምረ፡ ኍልቈ፡ ወእመ፡ ኢተክህለ፡ ፍቅዱ፨</l>
            <l n="3">ለኤዎስጣቴዎስ፡ አብ፡ ዘገቢረ፡ ምሕረት፡ ልማዱ፨</l>
            <l n="4">ባሕረ፡ ውዳሴሁ፡ አመ፡ ፈቀድኩ፡ እእዱ፨</l>
            <l n="5">ዕፅበት፡ ንስቲተ፡ ከልአኒ፡ ሞገዱ፨</l>
          </lg>
        </div>
      </div>
      
         
      </body>
   </text></TEI>
               <t:label>Salutation from the righteous</t:label>
            </t:div>
            <t:div type="textpart" subtype="chapter" xml:id="Monks">
               <t:label>Salutation from the monks</t:label>
            </t:div>
            <t:div type="textpart" subtype="chapter" xml:id="Virgins">
               <t:label>Salutation from the chaste virgins</t:label>
            </t:div>

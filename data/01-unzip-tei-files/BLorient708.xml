                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="5r" to="91r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1893Martyr">The Acts of Fāsiladas</title>
                            <textLang mainLang="gez"/>
                            
                            
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2">
                            <locus from="91r" to="95v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1893Martyr#Taamer">The Miracle of Fāsiladas</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ኃይለ፡ ተአምር፡ ዘገብረ፡ ቅዱስ፡ ፋሲለደስ፡ በደሴት፡ እንተ፡ ትሰመይ፡ ምጽሌ።</incipit>
                            
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                            <locus from="95v" to="101v"/>
                            <locus from="1v" to="4r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3004RepCh284">Malkǝʾa Fāsiladas</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ፀባዖት፡ ዘይትወሐድ፡ በመለኮት። እንዘ፡ ይሤለስ፡ በገጻት፡ ወበአካላት። ውዳሴ፡ መልዕከ፡ እጽሐፍ፡ 
                                ፋሲለደስ፡ ሰማዕት።</incipit>
                            <note>Ff. 95v-101v contain stanzas 1-39 plus the first line of stanza 40. The remaining lines and stanzas 41-52 are continued on ff. 1v-4r.</note>
                        </msItem>
                        
                        
                    </msContents>
                    
                    
                    
                    
                    
                    

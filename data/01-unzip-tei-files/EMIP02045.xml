                  <additions>
                     <list>
                        <item xml:id="e1">
                          <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc>
                              A name, written in purple ink
                            </desc>
                        </item>
                        <item xml:id="a1">
                          <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                           <desc>
                              The birthplace of Wayzäro Abäraš Gäzahañ and list of dates of the deaths of various family members, written in pencil and light black ink. “The Lords family is twelve apostles, 76 disciples, 36 holy women.”
                            </desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#iir(eco) #iiiv(erso) #ivv(erso) #111r #111v #112r #112v #113r #113v #114r #115v" facs="002 004 005 115 116 116 117 117 118 118 120">Fols. iir(eco), iiiv(erso), ivv(erso), 111r, 111v, 112r, 112v, 113r, 113v, 114r, 115v</locus>
                           <desc>
                              blank
                            </desc>
                        </item>

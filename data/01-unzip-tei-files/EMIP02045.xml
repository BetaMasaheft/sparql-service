                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc>
                          A man standing holding a handkerchief in his right hand and with left hand outstretched, and attendant with a rifle with caption <q>“How Fitawrari [name erased] interceded.”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with caption <q>“Mika’el” “with her beloved son,” “Gabri’el"</q>
                        </desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d3">
                      Decorative designs:
                      <locus target="#1r #36v #49r #60r #66r #85v" facs="005 041 053 064 070 090">folss. 1r, 36v, 49r, 60r, 66r, 85v, </locus> (haräg);
                      <locus target="#33v #48v #59v #65v #85r #105r #110r" facs="038 053 064 070 089 109 114">33v, 48v, 59v, 65v, 85r, 105r, 110r</locus> (multiple full stops)
                    </decoNote>

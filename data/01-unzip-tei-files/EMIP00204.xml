                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ገብረ፡ መንፈስ፡ ቅዱስ፡</foreign>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#41r #44r #53v #54v #58r" facs="042 045 055 056 059">folss. 41r, 44r, 53v, 54v, 58r, </locus> (multiple full stops);
                      <locus target="#58r #85v" facs="059 087">58r, 85v</locus> (lines of alternating red and black dots)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1">
                      <desc>
                      <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus> Alphabet, first four letters
                      </desc>
                      </item>
                      <item xml:id="e2">
                      <desc>
                      <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus> scrawls
                      </desc>
                      </item>
                      <item xml:id="a1">
                      <desc type="ScribalSignature">
                      <locus target="#58r" facs="059">Fol. 58r</locus> scribe, Gäbrä Mänfäs Qǝddus
                      </desc>
                      </item>
                      <item xml:id="a2">
                      <desc type="OwnershipNote">
                      <locus target="#58r" facs="059">Fol. 58r</locus> and passim: <q>“This book belongs to Mika’el, his brother is Kokäb.”</q> A second owner is listed: Amdä Mäsqäl
                      </desc>
                      </item>
                      <item xml:id="e3">
                      <desc>
                      <locus target="#58v" facs="060">Fol. 58v</locus> blank
                      </desc>
                      </item>
                      <item xml:id="e4">
                      <desc>
                      words of text are written interlinearly (<locus target="#26r #85v" facs="027 087">folss. 26r, 85v, </locus>);
                      text has been removed (e.g., <locus target="#44r #53v #85r" facs="045 055 086">44r, 53v, 85r</locus>)
                      </desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 194 x 175 x 53 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

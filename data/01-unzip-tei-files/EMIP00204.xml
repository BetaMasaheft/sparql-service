                                 <dim unit="leaf">8</dim>
                                 <locus from="40" to="47" facs="041">Fols 40–47</locus>
                              Quire 5
                            </item>
                              <item xml:id="q7" n="6">
                                 <dim unit="leaf">12</dim>
                                 <locus from="48" to="59" facs="049">Fols 48–59</locus>
                                 <note>
                                    <locus target="#48 #49 #50 #59" facs="049 050 051 060">Fols. 48, 49, 50, 59</locus> are single folios that are attached using a stab stitch.</note>

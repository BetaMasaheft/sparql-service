                                 <dim unit="leaf">10</dim>
                                 <locus from="20" to="29" facs="021">Fols 20–29</locus>
                                 <note>
                                    <locus target="#20 #29" facs="021 030">Fols. 20, 29</locus> are single folios that are attached using a stab stitch. These folios appear to have been part of this quire and were subsequently repaired.</note>
                              Quire 3:
                              1 added
                              10 added
                            </item>
                              <item xml:id="q5" n="4">
                                 <dim unit="leaf">10</dim>
                                 <locus from="30" to="39" facs="031">Fols 30–39</locus>

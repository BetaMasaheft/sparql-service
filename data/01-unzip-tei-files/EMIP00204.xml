                              Protection Sheet:
                              1, stub after 1
                            </item>
                              <item xml:id="q2" n="1">
                                 <dim unit="leaf">9</dim>
                                 <locus from="1" to="9" facs="002">Fols 1–9</locus>
                                 <note>
                                    <locus target="#1" facs="002">Fol. 1</locus> is a single folio that is attached using a stab stitch.</note>
                              Quire 1:
                              1 added
                            </item>
                              <item xml:id="q3" n="2">
                                 <dim unit="leaf">10</dim>
                                 <locus from="10" to="19" facs="011">Fols 10–19</locus>

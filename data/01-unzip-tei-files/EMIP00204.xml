                          <note>Quire descriptions: quires 2, 4–5 and 7–9 balanced; protection sheet adjusted balanced; quires 1, 3 and 6 unbalanced.</note>
                          <list>
                              <item xml:id="q1" n="a">
                                 <dim unit="leaf">1</dim>
                                 <locus target="#i" facs="001">Fol. i</locus>

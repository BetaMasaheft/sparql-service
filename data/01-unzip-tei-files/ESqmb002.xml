                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Very regular and neat</seg>
                        <seg type="ink">Black, red</seg>
                        <date>18th century (?)</date>
                        <list type="abbreviations">
                           <item>throughout Additio 3:</item>
                           <item>ሰላ፡ for ሰላም፡</item>
                           <item>ሚ(ካ)፡ for ሚካኤል፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the archangels Michael and
                           Gabriel; names of the donors; groups of lines on the incipit page; a few
                           lines in the incipit of all sections; incipit of subsections and their
                           numbers; elements of the punctuation signs and of the text dividers;
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The handwriting remains uniform
                        throughout the Ms. and is characterized by finely shaped, slender, tall and
                        upright
                        letters.</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#1v">Fol. 1v: </locus>
                        <desc>St. Michael, a prone male figure below (donor?).</desc>Painted on the
                        unruled protective leaf.</decoNote>
                     <decoNote type="miniature" xml:id="d2">
                        <locus target="#8r">Fol. 8r: </locus>
                        <desc>St. Michael and the Three Youths in the Fiery Furnace.</desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d3">
                        <locus target="#30v">Fol. 30v: </locus>
                        <desc>Annunciation.</desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d4">
                        <locus target="#59r">Fol. 59r: </locus>
                        <desc>St. Mary and St. Michael, the latter weighs the deeds of the soul of
                           the cannibal of Qǝmǝr (bälaʾe säbʾ).</desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d5">
                        <locus target="#67v">Fol. 67v: </locus>
                        <desc>St. Michael subdues the Devil.</desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d6">
                        <locus target="#88v">Fol. 88v: </locus>
                        <desc>St. Michael with a sword and King Sennacherib.</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#105ra">f. 105ra-vb</locus>
                           <desc type="CommemorativeNote">Commemorative notice for St Sebastian (Sǝbǝstyanos) to be read
                              on 25th of Ṭərr</desc>
                           <q xml:lang="gez"/>
                           
                           <note> Śahlä Rufaʿel is mentioned in the supplication. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#106ra">ff. 106ra-109vb</locus>
                           <desc type="Poem">Malkǝʾa ŚahläRufaʿel "Image of ŚahläRufaʿel", followed by a
                              <term key="Qene" ana="#Qene">qǝne</term>-poem for him. </desc>
                           <q xml:lang="gez"/>
                           
                           <note> The poem is written by Wädä Māryām of Baso, Goğğam. It is the same
                              hand as Additio 1. </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#110ra">ff. 110ra-113rb</locus>
                           <desc> Malkǝʾa Mikāʾel "Image of Michael".</desc>
                           <q xml:lang="gez"/>
                           
                           <note> The scribe disregarded the ruled lines after the first folio and
                              wrote in a small, tight and uneven script. </note>
                        </item>
                        <item xml:id="a4">
                           <locus target="#113rb">f. 113rb</locus>
                           <desc>: Prayer to St Michael. </desc>
                           <q xml:lang="gez"> ኦሚካኤል፡ ኦሚካኤል፡ ኦሚካኤል፡ ኦመተንብል፡

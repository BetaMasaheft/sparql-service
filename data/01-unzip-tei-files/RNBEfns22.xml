                     <explicit xml:lang="gez">
                        <lb/>ለዝንቱ፡ መጽሐፍ፡ ዘአጽሐፎ፡ <persName role="donor" ref="https://betamasaheft.eu/PRS7006Menilek">ዳግማዊ፡
  <lb/>ምኒልክ፡ ንጉሠ፡ ነገሥት፡ ዘኢትዮጵያ፡ </persName>
                        <lb/>መፍቀሬ፡ እግዚአብሔር፡ ወሰብእ፡
  <lb/>ዘግብጽ፡ ወሮምያ፡
  <lb/>እምደለዋ፡ ለትዕይንቱ፡
  <lb/>ትሰመይ፡ ኒክያ፡
  <lb/>ወመቅደሰ፡ <persName ref="https://betamasaheft.eu/PRS8065Raguel">መልአከ፡ ራጉኤል፡</persName>
                        <lb/>ወመቅደሰ፡ <persName ref="https://betamasaheft.eu/PRS8925Solomon">ሰሎሞን፡</persName> ነያ፡
  <lb/>ኵሉ፡ ዘሰምዓ፡ ወዘርእያ፡
  <lb/>ይትሬስሓ፡ አድባረ፡ ጽዮን፡
  <lb/>ወአዋልደ፡ ይሁዳ፡ ይትኃስያ፡
  <lb/>ወመዋዕለ፡ መንግሥቱ፡ ለትኩን፡
  <lb/>ሰማንያ፡
  <lb/>ወይትባረክ፡ እግዚአብሔር፡ ዘእፈጸመኒ፡
  <lb/>በደኅና፡ ለጸሐሬሁ፡ ድኩም፡ ወምስኪን፡
  <lb/>
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS12507Kasa">አለቃ፡ ካሳ፡</persName> 
                        <ref type="place" corresp="https://betamasaheft.eu/LOC4432Mahdar">ዘማኅደረ፡ ማርያን፡</ref>
                        <lb/>ሰማርያ፡
  <lb/>ለዓለመ፡ ዓለም። አሜን፡
</explicit>
                     <colophon xml:id="coloph1" xml:lang="gez">
                        <locus target="#291v"/>
                        <lb/>ወትጽሕፎቱ፡ ለዝንቱ፡ መጽሐፍ፡
  <lb/>እምአመ፡ ነግሠ፡ <persName ref="https://betamasaheft.eu/PRS7006Menilek">ዳግማዊ፡ ምኒልክ፡</persName>
                        <lb/>ንጉሠ፡ ነገሥት፡ ዘኢትዮጵያ፡
  <lb/>በ፴ ዓመት፡
  <lb/>
                        <date>ወእምልደቱ፡ ለእግዚአብሔር፡ ኢየሱስ፡ ክርስቶስ፡
  <lb/>በ፲ወ፰፻፹ወ፯ ዓመት፡</date>
                        <lb/>ስብሐት፡ ለእግዚአብሔር፡ ለዘአብጽሐኒ፡
  <lb/>እስከ፡ ዛቲ፡ ሰዓት፡
  <lb/>ወለወላዲቱ፡ ድንግል፡ ማርያም፡
  <lb/>ቅድስት፡
  <lb/>ወላዕሌነ፡ ይኩን፡ ሣህል፡ ወምሕረት፡
  <lb/>ለዓለመ፡ ዓለም። አሜን፡
</colophon>

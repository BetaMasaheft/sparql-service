                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ሚካኤል፡</foreign>
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#1r #4r #9v #15r #21v #26r #29v #33v #47r #59r" facs="002 005 011 016 023 027 031 035 048 060">folss. 1r, 4r, 9v, 15r, 21v, 26r, 29v, 33v, 47r, 59r, </locus> (haräg);
                      <locus target="#25v #46v" facs="027 048">25v, 46v</locus> (multiple full stops);
                    </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc>
                             Several of the characteristics of this book make it clear that it was produced in or near the government scriptorium: two-toned head and tail bands, tooled Moroccan leather, the distinctive harags, etc
                           </desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#ir(ecto) #iv(erso) #67r #67v #68r #68v" facs="001 002 068 069 069 070">Fols. ir(ecto), iv(erso), 67r, 67v, 68r, 68v</locus>
                           <desc>
                              blank
                            </desc>
                        </item>
                        <item xml:id="a1">
                          <locus target="#66v" facs="068">Fol. 66v</locus>
                           <desc type="OwnershipNote">
                              owner’s name is Habtä Wäld
                            </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>
                             Identified in the insurance hand list as Liturgical 10
                           </desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#34 #47 #59" facs="035 048 060">Fols. 34, 47, 59</locus>
                           <desc>
                             blue string is sewn into the fore edge as navigation system
                           </desc>
                        </item>
                        <item xml:id="e5">
                           <desc>
                             Numbered quires: quires 2–7
                           </desc>
                        </item>
                        <item xml:id="e6">
                          <locus target="#16v #22v #55v" facs="018 024 057">Fols. 16v, 22v, 55v</locus>
                           <desc>
                             words of text are written interlinearly
                           </desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with tooled leather, headband and tailband.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

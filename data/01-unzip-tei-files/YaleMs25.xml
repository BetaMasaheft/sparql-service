                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1"><locus target="#iiv(erso)" facs="003"/><desc>An illustration of the first of the miracles of <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> contained in the book. Mary
                           sits on throne (left) and holds out a cloth in her left hand to a man
                           seated before her (right) and who is copying a book. Above right an <term key="angel" ana="#angel"/> hovers. And on the far left, behind Mary, stands another
                              <term key="angel" ana="#angel"/></desc></decoNote>
                     <decoNote type="miniature" xml:id="d2"><locus target="#iiir(ecto)" facs="003"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> armed with two
                              <term key="spear" ana="#spear"/>s stands (left) before a man who has fallen on his
                           back, with feet in the air (right)</desc></decoNote>
                     <decoNote type="miniature" xml:id="d3"><locus target="#47v" facs="052"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref></desc></decoNote>
                     <decoNote type="miniature" xml:id="d4"><locus target="#68v" facs="073"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref></desc></decoNote>
                     <decoNote type="miniature" xml:id="d5"><locus target="#107v" facs="112"/><desc>The Weighing of Souls (Mary on the left; Satan(?) on the
                           right</desc></decoNote>
                     <decoNote type="miniature" xml:id="d6"><locus target="#116r" facs="120"/><desc>Our Lady <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> with the
                           Body of <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName>, flanked by two <term key="angel" ana="#angel"/>s</desc></decoNote>
                     <decoNote type="miniature" xml:id="d7"><locus target="#127v" facs="132"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> kneels at left
                           before a crucifix; a king sits enthroned on the right with several pen
                           looking on</desc></decoNote>
                     <decoNote type="miniature" xml:id="d8"><locus target="#140v" facs="144"/><desc>The burial of Mary <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref>,
                           where King <persName ref="https://betamasaheft.eu/PRS3417David">David</persName> plays the harp to
                        her</desc></decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#ivr(ecto) #ivv(erso)" facs="004 005"/>
                           <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT3056RepCh336">Hymn to Our Lady Mary</title>
                           </desc>
                        </item>
                        <item xml:id="a2">
                           <locus target="#5r" facs="009"> f. 5r and passim</locus>
                           <desc> mentions, Emperor Menilek (1868–1913), one <foreign xml:lang="gez">ገብረ ሚካኤል, ወለተ መድኀን</foreign>, and the scribe, <foreign xml:lang="gez">ገብረ እግዚአብሔር</foreign>
                           </desc>
                        </item>
                        <item xml:id="a3">
                           <locus target="#193v #194r #194v #195r #195v" facs="198 199 200"/>
                           <desc> The last of the miracles is written in a different hand and dated
                              in the time of “Our King Mika’el,” i.e., Ras Mikael of Wollo,
                              1850–1918 </desc>
                        </item>
                        <item xml:id="e1">
                           <locus target="#Inside cover" facs="001"/>
                           <desc> cover contains the ownership plate of Yale University Library,
                              Gift of Laurence and Cora Witten </desc>
                        </item>
                        <item xml:id="e2">
                           <locus target="#ir(ecto)" facs="001"/>
                           <desc> written in the upper left corner [12210] </desc>
                        </item>
                        <item xml:id="e3">
                           <locus target="#iv(erso) #iir(ecto) #iiiv(erso) #69r" facs="002 004 073"/>
                           <desc> Blank </desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment. Wooden boards, with four chain stitches.
                           Leather bound. Fine cloth is visible between the turndowns on the inside
                           back cover.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                           <material key="leather"/>
                           <material key="textile"/>
                        </decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1850" notAfter="1918">Late-nineteenth/early-twentieth
                        century (the last miracle is written in a different hand the late-ninteenth
                        century and mentions Ras Mikael of Wollo, 1850–1918 [<locus target="#195v" facs="199"/>]. The harags also speak of the Menilek
                        scriptorium).</origDate>
                  </origin>
               </history>

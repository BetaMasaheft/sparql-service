               <msContents>
                  <summary>Miracles of Mary, ተአምረ፡ ማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="3v" facs="005"/>
                     <title>Introduction to the Miracles of Mary, መቅድመ: ተአምረ: ማርያም: ዘሙዓልቃ:, to be
                        read on Sundays, explaining the feast days of Mary</title>
                     <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3v" to="5r" facs="008"/>
                     <title>Second, shorter Introduction to the Miracles of Mary, ስምዑ እነግረክሙ, to be
                        read Monday through Saturday</title>
                     <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="5r" to="193r" facs="009"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</title>
                     <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     <note>One Hundred Fifty Two Miracles of Mary</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>

         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="monastic">ኢሳይያስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾIsāyǝyyās</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">abbot</occupation>
               <birth when="1485"> He was born at <placeName ref="https://betamasaheft.eu/LOC1236Agama">ʿAgama</placeName> in <date>1485</date>. </birth>
                  <residence>
                  <placeName ref="https://betamasaheft.eu/INS0005Gund">Gunda Gunde</placeName>
               </residence>
               <floruit when="1555">He was  the sixth abbot of the monastery of <placeName ref="https://betamasaheft.eu/INS0005Gund">Gunda Gunde</placeName>
                  and became an abbot  in <date>1555</date> succeeding ʾabbā 
                  <persName ref="https://betamasaheft.eu/PRS9192TaklaNa">Takla Nabiyāt</persName>. 
                  He was a relative of  
                  <persName ref="https://betamasaheft.eu/PRS3894estifano">
                     <roleName type="title">ʾabbā </roleName> ʾƎsṭifānos</persName>, the first leader of <persName ref="https://betamasaheft.eu/PRS11211Stephanites">Stephanites</persName>.
                  He took the monastic habit at the age of 15 from the hands of <persName ref="https://betamasaheft.eu/PRS4322GabraMa">Gabra Maśiḥ</persName>. He was represented in the community as an interpreter of the Scriptures.
                  </floruit>
                  <death> He died in <date>1572</date>
               </death>
               </person>  
               
         </listPerson>

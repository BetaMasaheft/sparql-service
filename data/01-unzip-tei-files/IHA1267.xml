               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="272">p. 1-272</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT0353IHA#s513IHA">قوت القلوب في معاملة المحبوب, al-Ǧuz'
                    al-awwal</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>الجزء الأول من كتاب قوت القلوب في معامله المحبوب ووصف طريق المريد الى مقام التوحيد لسيدنا ومولانا الشيخ الامام العالم المحقق أبى طالب محمد بن أبى الحسن على ابن عباس المكى تغمد الله برحمته وأسكنه فسيح جنته آمين<note>Title page; the beginning is missing.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 271">-p. 271</locus>وقال عثمان بن عمارة كان يقال الورع يبلغ بالعبد الى الزهد والزهد يبلغ به حب الله تعالى فهذان الحالان غاية الطالبين الحب للجليل والانس باللطيف فمن لم يتحقق بالزهد لم يبلغ مقام الحب ولم يدرك حال الانس ثم ان سرائر الغيوب في مقام الحب والخلة عفى حال الانس والقربة وفقنا الله واياكم لما يحب وبلغنا ما نؤمل بفضله ورحمته ولا حول ولا قوة الا بالله العلى العظيم وهذا آخر كتاب الزهد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="272">*p. 1-272</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT2873IHA">سراج القلوب وعلاج الذنوب</title>
                     <incipit xml:lang="ar">
                        <locus target="#*p. 1">-*p. 1</locus>وبهامشه كتابان جليلان أولهما كتاب سراج القلوب وعلاج الذنوب للشيخ أبى على زين الدين على المعيرى</incipit>
                     <explicit xml:lang="ar"/>
                     <note>The explicit of the work is not present among the images. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="1" to="272">**p. 1-**272</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT2875IHA">حياة القلوب في كيفية الوصول الى المحبوب</title>
                     <incipit xml:lang="ar">
                        <locus target="#**p. 1">-**p. 1</locus>والثانى حياة القلوب في كيفية الوصول الى المحبوب لعماد الدين الاموى رحم الله الجميع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#**p. 271">-**p. 271</locus>...يحتاج فيه الى موقف ودليل يأخذ به ليسلم من الحيرة والفتنة فان لم يكن معه سيره من يعرفه كيفية ... الهلال لبعضهم ان فلانا قد رجع فقال ما أرا ه رجع الا من وحشة الطريق وقلة سالك به<note>Torn page, part of the text is unreadable.</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>

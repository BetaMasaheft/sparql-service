                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title ref="https://betamasaheft.eu/LIT5196MagicPrayer">Ṣalot baʾǝnta gǝrmā mogas</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎተ፡ ግርማ፡ ሞገስ፡ ዘወረደ፡ ላዕለ፡ ሐዋርያት፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title ref="https://betamasaheft.eu/LIT7057Fever">Ṣalota ferā wa-nǝdād za-qǝddus Mikāʾel</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎተ፡ ፌራ፡ ወንዳድ፡ ዘቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ <gap reason="ellipsis"/>
                                ሌኬ፡ ኤንካ፡ ጌሌ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title ref="https://betamasaheft.eu/LIT7059Shimdan">Ṣalot baʾǝnta ḥǝmāma ʿaynat šimdān šimdān šimdān</title>

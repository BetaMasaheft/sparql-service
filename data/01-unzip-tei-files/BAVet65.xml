                  <msContents>
                     <msItem xml:id="p4_i1">
                        <locus from="23" to="27v"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT4556Praise">Praises to Our Lord Jesus Christ, 39 in number</title>
                        <incipit xml:lang="gez">
                           ፮ሐሊናሁ፡ ለአብ፡ ዘኢይትረከብ፡ ውእቱ፡ ጥበቡ፡ ለአብ። ውእቱ፡ ኀይሉ፡ ውእቱ፡ 
                              <sic>ይማኑ፡</sic>
                            ውእቱ፡ ምክሩ፡ ውእቱ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ፴፰፡ ዘይቤ፡ ከመ፡ የሀበነ፡ ዘዓይን፡ ኢርእየ፡ ወእዝን፡ ኢሰምዓ፡ ወውስተ፡ ልበ፡ ሰብእ፡ ዘኢዓርግ፡ ዘአስተዳ<supplied reason="omitted">ለ</supplied>ወ፡ እግዚአብሔር፡ ላዕለ፡ ያፈቅርዎ። 
                           ፴፱፡ በከመ፡ ይቤ፡ ሙሴ፡ ወባዕዳንሂ፡ ነቢያት፡ ንሕነኒ፡ ቦቱ፡ ተወኪለነ፡ ሎቱ፡ ነሀብ፡ 
                              <sic>ስብሐት፡</sic>
                            ዘሎቱ፡ ስብሐት፡ ወጽንዕ፡ ለዓለመ፡ ዓለም፡ ወይብል፡ ኵሉ፡ ሕዝብ፡ 
                           አሜን። = ።
                        </explicit>

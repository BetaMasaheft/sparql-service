               <t:persName xml:lang="gez" xml:id="n1" type="birth">ያዕቆብ፡</t:persName>
                     <t:persName xml:lang="gez" type="normalized" corresp="#n1">
                  <t:roleName type="title">ʾaṣe</t:roleName> Yāʿqob</t:persName>
                     <t:persName xml:lang="en" corresp="#n1">Jacob</t:persName>
                  <t:persName xml:lang="gez" type="regnal" xml:id="n2">መልክአ፡ ሰገድ፡</t:persName>
                  <t:persName xml:lang="gez" type="normalized" corresp="#n2">Malkǝʾa Sagad</t:persName>


               <t:occupation type="ruler">Emperor</t:occupation>
               <t:birth when="1587"/>
               <t:floruit notBefore="1597" notAfter="1607">
                  He succeeded his father <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                     Śarḍa Dǝngǝl</t:persName> in <t:date>1597</t:date> .
                  He was overthrown in <t:date> 1603</t:date> and was again enthroned two years later in<t:date>1605</t:date>. </t:floruit>
               <t:death when="1607" evidence="internal">He died in battle
                  fighting against his power rival <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                      Susǝnyos</t:persName>,  in <t:date>10 March 1607</t:date>. </t:death>
            </t:person>
            

                  <additions>
                    <list>
                      <item xml:id="e1">
                        <desc><locus target="#1r">Fol. 1r</locus> mentions <foreign xml:lang="gez">አፀደ፡ ማርያም</foreign></desc>.
                      </item>
                      <item xml:id="e2">
                        <desc><locus target="#5v">Fol. 5v</locus> mentions <foreign xml:lang="gez">ገ/አፅበሃ፡</foreign> and <foreign xml:lang="gez">ገ/ሚካኤል፡</foreign> and <foreign xml:lang="gez">ወ/ብርሃን፡</foreign></desc>
                      </item>
                      <item xml:id="e3">
                        <desc><locus target="#7r">Fol. 7r</locus> mentions <foreign xml:lang="gez">አመተ፡ ማርያም፡</foreign>, <foreign xml:lang="gez">ወ/ጊዮርጊስ፡</foreign>, and <foreign xml:lang="gez">ገብረ፡ ሚካኤል፡</foreign></desc>.
                      </item>
                      <item xml:id="e4">
                        <desc><locus target="#18r">Fol. 18r</locus> mentions <foreign xml:lang="gez">አቡነ፡ ሃ/ማርያም፡</foreign></desc>
                      </item>
                      <item xml:id="e5">
                        <desc><locus target="#23r">Fol. 23r</locus> mentions <foreign xml:lang="gez">ገብረ፡ ተ/ሃይማኖት፡</foreign></desc>
                      </item>
                      <item xml:id="a1">
                        <desc type="OwnershipNote">
                          <locus target="#37r">Fol. 37r</locus> has a note of ownership:
                          <q>"This Actos of Abuna Yasay belongs to <foreign xml:lang="gez">ወይዘሮ፡ ሙሉ፡ አረፈ፡</foreign>.
                          She gave it to the Church (<foreign xml:lang="gez">ለኩሐ፡ ቅድስት፡ ማርያም፡ ደብረ፡ ተዋህዶ፡</foreign>) to lead her soul to paradise.</q>
                          Dated <date calendar="ethiopian" when-custom="2001">Ṭǝqǝmt 2, 2001 EC</date>
                          Then follows a list of departed souls, five men and five women.
                          </desc>
                      </item>
                    </list>
                    </additions>


                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT3958IHA">دعاء على النبي اللهم صل وسلم على سيدنا محمد بعدد الجن
                    والانس</title>
                     <incipit xml:lang="ar">
                        <locus target="#21">-21</locus>اللهم صل وسلم على سيدنا محمد بعدد [...] اللهم صل وسلم على   سيدنا محمد بعدد الجن والانس</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22">-22</locus>اللهم بجاهه وقربه عندك توفنا مسلم[...]عثنا</explicit>
                     <note/>
                     <note/>
                  </msItem>

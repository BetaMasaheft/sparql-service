              <t:bibl corresp="http://zotero.org/groups/358366/items/Z22SPIBX"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Zuurmond1989EvangeliumMarc"/><title level="m">Novum Testamentum Aethiopice: The Synoptic Gospels&lt;hi rend="italics"&gt;, I:&lt;/hi&gt; General Introduction&lt;hi rend="italics"&gt;; II:&lt;/hi&gt; Edition of the Gospel of Mark</title><title level="s">Äthiopistische Forschungen</title><author><forename>Rochus</forename><surname>Zuurmond</surname></author><pubPlace>Stuttgart</pubPlace><publisher>Franz Steiner</publisher><date>1989</date><series><title level="s">Äthiopistische Forschungen</title><biblScope unit="volume">27</biblScope></series><biblScope unit="volume">27</biblScope><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Philology</note><note type="tag">bm:Zuurmond1989EvangeliumMarc</note></note><note type="tag">Ethiopic</note><note type="tag">Philology</note><note type="tag">bm:Zuurmond1989EvangeliumMarc</note><t:citedRange unit="page">14-15</t:citedRange></t:bibl>

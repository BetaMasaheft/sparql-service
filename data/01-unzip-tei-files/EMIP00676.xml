                      <msItem xml:id="ms_i2.1.1">
                        <locus from="1r" facs="005">Fols 1r and following</locus>
                        <title>Introduction to the Psalms</title>
                        <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                        <incipit xml:lang="gez">መዝሙረ፡ ዳዊት፡ ትመስል፡ ገነተ።
                          ወታስተጋብእ፡ ኵሎ፡ ጽጌያተ።
                          ትመስል፡ ፍርያተ፡ ወታመጽእ፡ በረከተ።
                          ትሰድድ፡ አጋንንተ፡ ወታቀርብ፡ መላእክተ።</incipit>
                        </msItem>
                      </msItem>

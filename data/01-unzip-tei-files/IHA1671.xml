               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="5v">1r-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0208IHA">مقدمة الجزرية قي التجويد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم \ يقول راجى عفو رب سامع , محمد بن الجزرى الشافعى \ الحمد لله وصلى الله , على نبيه ومصطفاه \ محمد واله وصحبه , ومقرئ القرءان مع محبه \ وبعد إن هذه مقدمة , فيما على قرائه ان يعلمه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r-5v">-5r-5v</locus>وقد تقضى نظمى المقدمة \ منى لقارئ القرءان تقدمت \ والحمد لله لها ختام \ ثم الصلاة بعد والسلام \ على النبى المصطفى واله \ وصحبه وتابعين منواله \ ابياتها قال وزاى فى العدد \ من يحسن التجويد يظفر بالرشد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6v" to="7r">6v-7r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3529IHA">دواء الكبد</title>
                     <incipit xml:lang="ar">
                        <locus target="#7r">-7r</locus>هذ دواء الكبد \ فصل فى الادوية المفتحة لسدد الكبد والطحال الانيسون نافع من سدد الكبد ايضا الزعفران يفتح السدد واذ شرب المصطكى مسحوقا الو لعق بغره فتح السدد </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>واكل فتح السدد من الكبد الكراث يفتح السدد من الكبد الكائن من البلغم اللبان ينفع من وجع الحاصرة ويفتح سدد الكبد</explicit>
                     <note>Written upside down.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="8r" to="9r">8r-9r</locus>
                     <textLang xml:lang="am">Amharic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3530IHA">نظم باب في ذكر مولد احمد خير الورى</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>باب فى ذكر مولد احمد خير الورا \ ثَامِنَاتْ هُوْد وَطُّو تَهُو نُو طَهَارَا \ مَنَڛَّا زَرَّفُ أَمِنَةُ الزَّهْرَا \ تَهُودًوا يَوَطّا نُورْ يَنُورْ أَذْمَرا وَدَاجُنْ يَمَّيَا شَرْبَادُّنيَامْ بَاخِرَا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>يچتسوش جميد فحمود [.؟.] \ محمد الرسول امجد  الامجد يچتىوش يا ابا القالسم جند </explicit>
                     <note/>
                     <note/>
                  </msItem>

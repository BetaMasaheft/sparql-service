<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">The gathering of the faithful</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.7">
<locus from="37r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">መልክአ፡ ልሳን፡</title>
<incipit xml:lang="gez">ናሁ፡ ተማኅፀንኩ፡ በኆኅያተ፡ ስምከ፡ ካፍ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.8">
<locus from="37r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">ጥበበ፡ ጠቢባን፡</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.9">
<locus from="48v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3067RepCh347">Hymn to the Holy Trinity</title>
<incipit xml:lang="gez">እስመ፡ ብዙኃን፡ እሙንቱ፡ እለ፡ አኃዙ፡ ይጽሐፍ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.10">
<locus from="55v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2872RepCh153">To the Four Beasts</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘተለዓለ፡ ዕበዩ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.11">
<locus from="60v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2909RepCh190">To the 24 Elders <foreign xml:lang="gez">ካህናተ፡ ሰማይ፡</foreign></title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘያሜንን፡ ጸቃውዓ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.12">
<locus from="65r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2991RepCh272">To the guardian angel</title>
<incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ስቡሕ፡ ዘጸገወከ፡ ሥርዓት።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.13">
<locus from="70r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2847RepCh129b">To the angel Raphael</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ውስተ፡ አፈ፡ ኵሉ፡ ጥዑም።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.14">
<locus from="75r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279">To St John the Evangelist</title>
<incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ እሳት፡ በሐቅለ፡ ሕሊና፡ ነዳዲ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.15">
<locus from="77v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT6192Saqoqa">Hymn</title>
<incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘነበበ። በነቢያት፡ ቅድመ፡ ወበሐዋርያት፡ ካዕበ። እዌጥን፡ አንሰ፡ ሰቆቃቅወ፡ ነፍስ፡ ዕፁበ፤
ኵሎ፡ ሌሊተ፡ በአንብዕ፡ እንዘ፡ አርኅስ፡ ምስካአበ። ከመ፡ በአንብዑ፡ ዳዊት፡ ዓራቶ፡ ሐፀበ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.16">
<locus from="86r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2816RepCh100">To the 12 Apostles</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ለለ፩ዱ። ዓሥሩ፡ ወክልኤ፡ ዘይከውን፡ መጠነ፡ ፍቅዱ። </incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.17">
<locus from="89r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2906RepCh187">To St Peter and Paul</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘአልባስጥሮስ፡ አፈው።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.18">
<locus from="93r"/>
    <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">To the archangel Michael</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ፡</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.19">
<locus from="99r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3081RepCh361">To the same as above</title>
<incipit xml:lang="gez">እግዚአብሔር፡ እግዚእ፡ አመ፡ ፈጠረ፡ ብርሃነ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.20">
<locus from="104r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2875RepCh156">To the angel Gabriel</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዓ፡ ቀዲሙ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.21">
<locus from="111r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">To St George</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.22">
<locus from="117r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3004RepCh284">To Fasiladas</title>
<incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ጸባዖት፡ ዘይትወሀብ፡ በመለኮት።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.23">
<locus from="123v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3035RepCh315">To Claudius</title>
<incipit xml:lang="gez">ናሁ፡ ተወጥነ፡ ለመልክእከ፡ ሰላም።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.24">
<locus from="130v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2879RepCh160">To Theodore</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘትእምርተ፡ መስቀል፡ ጥንተ፡ ፊደሉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.25">
<locus from="135v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3095RepCh375">To Quiricus or Cyriacus</title>
<incipit xml:lang="gez">ኦክርስቶስ፡ ናዝራዊ፡ ዘተ<supplied reason="omitted">ወ</supplied>ከፍከ፡ ሕማመ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.26">
<locus from="142r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2726RepCh10">To Victor</title>
<incipit xml:lang="gez">መንክራቲከ፡ ብዙኃ፡ ወገድላቲከ፡ ይሰብኩ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.27">
<locus from="149v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT1864Malkea">To the Blessed Virgin Mary</title>
<incipit xml:lang="gez">ሰላም፡ ለስዕልኪ፡ ዘየዕዔድም፡ ንጻሬ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.28">
<locus from="151r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2972RepCh253">To St Stephen</title>
<incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ እግዚአብሔር፡ አሐዱ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.29">
<locus from="157v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3075RepCh355">To Sebastian</title>
<incipit xml:lang="gez">እንዘ፡ እፈቅድ፡ ፈቂደ፡ ወእትሜነይ፡ ተምኔተ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.30">
<locus from="161r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2924RepCh205">To St Bartholomew for the 1st of Maskaram</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ እንበለ፡ ያእምሩ፡ አዝማዲከ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.31">
<locus from="163v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2921RepCh202">To St Matthew for the 1st of Ṭǝqǝmt</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ በዕለተ፡ ቡርክት።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.32">
<locus from="166r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2922RepCh203">To St Luke for the 22nd of Ṭǝqǝmt</title>
<incipit xml:lang="gez"> ለፅንሠትከ፡ በዕለት፡ ዓባይ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.33">
<locus from="168v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2855RepCh137">To St Philip for the 18th of Ḫǝdar</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለስእርትከ፡ ሠርጐ፡ ርእስ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.34">
<locus from="170v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2929RepCh210">To St Andrew for the 4th of Tāḫśāś</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ እማኅፀን።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.35">
<locus from="173r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2928RepCh209">To St John the Evangelist</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ እማኅፀን።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.36">
<locus from="177r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2918RepCh199">To St Jacob son of Alpheus</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ በሥርዓተ፡ ሰብሳብ፡ ዘተጽሐፈ።</incipit>
<note><date ref="ethiocal:Yakkatit10">For the 10th of Yakkātit</date></note>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.37">
<locus from="179v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2916RepCh197">To St Matthias(<foreign xml:lang="gez">ማትያስ፡</foreign>) for the 8th of Magābit</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ምስለ፡ ልደትከ፡ ቅዱስ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.38">
<locus from="181v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2931RepCh212">To St James, the Son of Zebedee, for the 17th of Miyāzyā</title>
<incipit>ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ ሰላም።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.39">
<locus from="184r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2917RepCh198">To St Mark for the 30th of Miyāzyā</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ በሀገረ፡ ዓባይ፡ ገሊላ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.40">
<locus from="186r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2920RepCh201">To St Thomas for the 27th of Gǝnbot</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ በእምርት፡ ዕለት።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.41">
<locus from="188v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2829RepCh113">To St Thaddeus for the 2nd of Ḥamle</title>
<incipit xml:lang="gez">ሰላም፡ ለዕለተ፡ ፅንስከ፡ እግዚአብሔር፡ ዘባረከ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.42">
<locus from="191r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2828RepCh112">To St Peter and Paul</title>
<incipit xml:lang="gez">ሰላም፡ ለዕለተ፡ ፅንስከ፡ ድኅረ፡ ዕለታት፡ ኃለፋ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.43">
<locus from="193v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2828RepCh112">To Nathaniel for the 10th of Ḥamle</title>
<incipit xml:lang="gez">ሰላም፡ ለዕለተ፡ ፅንስከ፡ ኃሤት፡ ትኩዝ፡ አቡከ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.44">
<locus from="196r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2828RepCh112">To St James for the 18th of Ḥamle</title>
<incipit xml:lang="gez">ሰላም፡ ለጊዜ፡ ፅንሰትከ፡ ኀበ፡ ጊዜ፡ ወንጌል፡ ቅሩብ።</incipit>
<note>For the <date ref="ethiocal:Hamle10">10th of Ḥamle</date></note>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.45">
<locus from="199r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2783RepCh67">To the 12 Apostles</title>
<incipit xml:lang="gez">ሰላም፡ ለከ፡ ኰኵሐ፡ ሃይማኖት፡ ጴጥሮስ፡ ለቤተ፡ ክርቲያን፡<sic/> ድዳ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.46">
<locus from="200r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2868RepCh149">To Antony</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘቀለመ፡ አሌፍ፡ ፊደሉ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.47">
<locus from="201v"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT3007RepCh287">To ʾAbib</title>
<incipit xml:lang="gez">በእንተ፡ አቡከ፡ አብርሃም፡ ወበንተ፡ ወላዲትከ፡ ሐሪክ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.48">
<locus from="204r"/>
    <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2851RepCh133">To Cyrus</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስመከ፡ ኀበ፡ ዓምደ፡ ወርቅ፡ ዘተጽሐፈ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.49">
<locus from="206v"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2844RepCh127">To Gabra Krǝstos</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በስመ፡ ወልደ፡ አምላክ፡ ዘተጸውዓ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.50">
<locus from="208v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2881RepCh162">To Gabra Manfas Qǝddus</title>
<incipit xml:lang="gez">ስላም፡ ለዝክረ፡ ስምከ፡ ዘኆኅያቲሁ፡ ቅሩጽ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.51">
<locus from="214r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">To Takla Hāymānot</title>
<incipit xml:lang="gez">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ እምከርሣ፡</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.52">
<locus from="221r"/>
<title xml:lang="en" type="complete">To Eustathius</title>
<incipit xml:lang="gez">ቀዳሚሁሰ፡ ለዘየአምን፡ በረድኤትከ፡ በኃይል።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.53">
<locus from="232r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3042RepCh322">To Samuel</title>
<incipit xml:lang="gez">አኀዝኩ፡ አንሰ፡ ለልብየ፡ እምሐኬቱ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.54">
<locus from="235v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3029RepCh309">The hymn <foreign xml:lang="gez">ኢየሱስ፡ ሞአ፡</foreign></title>

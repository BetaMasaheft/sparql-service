<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Hymn</title>
<incipit xml:lang="gez">ሰላም፡ ለሕማምከ፡ ቤተ፡ አይሁድ፡ ዘአንደደ፡ ወረሰዮሙ፡ ሐመደ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.4">
<locus from="23r"/>
<title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2842RepCh125">መልክአ፡ መስቀል፡</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በመጽሔተ፡ መስቀል፡ ዘተለክዓ።</incipit>

</msItem>

<msItem xml:id="ms_i1.5">
<locus from="26v"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3096RepCh376">Hymn</title>
<incipit xml:lang="gez">ኦክርስቶስ፡ እንግዳ፡ ዘኢተወልፉከ፡ ሰብአ፡ ግብጽ።</incipit>
<textLang mainLang="gez"/>
</msItem>


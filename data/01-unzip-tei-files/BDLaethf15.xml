               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="3r">Fols 3r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                     <textLang mainLang="gez"/>


                     <msItem xml:id="ms_i1.1">
                        <locus from="3r">Fols 3r and following</locus>
                        <title type="complete" cert="low" evidence="conjecture" ref="https://betamasaheft.eu/LIT2509Weddas#Monday">Wǝddāse Māryām for Monday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="6r">Fols 6r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Tuesday">Wǝddāse Māryām for Tuesday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="12r">Fols 12r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Wednesday">Wǝddāse Māryām for Wednesday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="18r">Fols 18r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Thursday">Wǝddāse Māryām for Thursday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.5">
                        <locus from="24v">Fols 24v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Friday">Wǝddāse Māryām for Friday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.6">
                        <locus from="29r">Fols 29r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Saturday">Wǝddāse Māryām for Saturday</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.7">
                        <locus from="32v">Fols 32v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Sunday">Wǝddāse Māryām, Hymn to Our Lady Mary</title>
                        <textLang mainLang="gez"/>
                        <note>
                           <locus target="#35">Fol. 35</locus> is so badly mutilated that only a small corner is
                           left.</note>
                     </msItem>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="36v">Fols 36v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2959RepCh240">Hymn to Our Lady Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ቅድስት፡ ወበፅዕት፡ ስብሕት፡ ወቡርክት፡ ክብርት፡ ወልዕልት፡</incipit>
                     <note>The name of the owner mentioned here is <persName role="owner" ref="https://betamasaheft.eu/PRS11444GabraMi">ʾabbā Gabra Mikāʾel</persName>.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="52r">Fols 52r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa malāʾǝkt la-Māryām</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ይዌድስዋ፡ መላእክት፡ ለማርያም፡ በውስተ፡ ውሤጤ፡ መንጦላዕት፡</incipit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="54r">Fols 54r and following</locus>
                     <title type="complete">Hymn to <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The refrain is <foreign xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡</foreign>
                     </note>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="56v">Fols 56v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkǝʾa Māryām</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ።</incipit>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="73r">Fols 73r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይሔሱ።</incipit>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <locus target="#88r">Fol. 88r</locus>
                     <textLang mainLang="gez"/>
                     <colophon xml:id="coloph1">ዝመጽሐፍ፡ ዘ<persName role="owner" ref="https://betamasaheft.eu/PRS11444GabraMi">
                           <roleName type="title">አባ፡</roleName> ገብረ፡ ሚካኤል፡</persName>
                        ዘብሔረ፡ <placeName ref="https://betamasaheft.eu/LOC5597Sawa">ሼዋ፡</placeName> ወጸሐፌሁኒ፡ በኢድልወቱ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS11445HaylaS">
                           <roleName type="title">አባ፡</roleName>
                           ኃይለ፡ ሥላሴ፡</persName> ዘ<placeName ref="https://betamasaheft.eu/INS0354DB">ደብረ፡ ቢዘን።</placeName>
                        ተጽሕፈ፡ በ<date calendar="ethiopian" when="1888" when-custom="1881" evidence="internal">፲ወ፰፻፹ወ፩ ዓመት፡ ምሕረት፡</date>
                        <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/> በዘመነ፡ መንግሥቱ፡
                        ለመፍቀሬ፡ አምላክ፡ <persName ref="https://betamasaheft.eu/PRS10378Yohanne">ዮሐንስ፡</persName> ንጉሠ፡ ነገሥት።
                     </colophon>
                  </msItem>
               </msContents>


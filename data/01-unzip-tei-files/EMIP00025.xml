                     <decoNote type="miniature" xml:id="d2">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc>Painting of a holy man (Jesus?) looking and pointing up <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                        </desc>
                     </decoNote>

                     <decoNote type="miniature" xml:id="d3">
                        <locus target="#8v" facs="011">Fol. 8v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc>
                     </decoNote>


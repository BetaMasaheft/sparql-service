                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                        <desc>Painting of <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> being fed by a bird</desc>

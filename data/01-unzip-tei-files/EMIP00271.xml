            <decoDesc>
              <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                  <name ref="PRS4306GabraMa"/></desc></decoNote>
              <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc>Two panels: top, <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>,
                  followed by his disciples, heals a man in a crowd; bottom, Jesus and another saint
                  talk to a kneeling man and a crowd</desc></decoNote>
              <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc>Two panels, mostly effaced but containing scenes of <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>’ ministry</desc></decoNote>
              <decoNote type="miniature" xml:id="d4"><locus target="#84v" facs="087">Fol. 84v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> takes a man by the hand (The partial
                  margin artist?)</desc></decoNote>
              <decoNote type="miniature" xml:id="d5"><locus target="#141r" facs="143">Fol. 141r</locus><desc>Man
                  standing (The partial margin artist?)</desc></decoNote>
              <decoNote type="miniature" xml:id="d6"><locus target="#141v" facs="144">Fol. 141v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref> spearing an enemy through the head
                  (The “red box artist”)</desc></decoNote>
              <decoNote type="miniature" xml:id="d7"><locus target="#142r" facs="144">Fol. 142r</locus><desc>Two
                    <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> standing (The “red box
                  artist”)</desc></decoNote>
              <decoNote type="frame" xml:id="d8"> Decorative designs: <locus target="#1r #32r #35r #58v #61r #66v #78v #85r #91r" facs="003 034 037 061 069 081 087 093">folss. 1r, 32r, 35r, 58v, 61r, 66v, 78v, 85r, 91r, </locus> (ḥaräg); <locus target="#67r #68r #68v #69r #69v #70r #94v #98r #102r #105r" facs="069 070 071 072 097 100 104 107">67r, 68r, 68v, 69r, 69v, 70r, 94v, 98r, 102r, 105r, </locus> (geometric patterns as section dividers);
                  <locus target="#135v #137v #138v #139r #140r" facs="137 140 141 142">135v, 137v, 138v, 139r, 140r, </locus> (arc of red
                and black dots); <locus target="#140v" facs="143">140v</locus> (multiple full stops)
              </decoNote>

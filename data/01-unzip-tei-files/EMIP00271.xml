                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>

              <msItem xml:id="ms_i1.4">
                <locus from="66v" to="78v" facs="069">Fols 66v–78v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1714Kestat">Kǝśtat
                                                  za-ʾaryām</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>

              <msItem xml:id="ms_i1.5">
                <locus from="78v" to="79v" facs="081">Fols 78v–79v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT5441ApostolicCreed">ʾAmaknəyo
                                                  za-ḥawāryāt</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                <colophon xml:id="coloph1">
                  <locus target="#79v" facs="082">f. 79v, column 2, top</locus> Note on the cost of
                  copying the book (91 birr) and statement of the will  </colophon>
              </msItem>
            </msItem>

            <msItem xml:id="ms_i2">
              <locus from="80r" to="84v" facs="082">Fols 80r–84v</locus>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>

            <msItem xml:id="ms_i3">
              <locus from="85r" to="141r" facs="087">Fols 85r–141r</locus>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT3186Meeraf">Mǝʿrāf</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <note>Continuation of Mǝ‘raf, for fasting period</note>
              <notatedMusic>
                <desc>with musical notation</desc>
              </notatedMusic>
              <colophon xml:id="coloph2">
                <locus target="#141r" facs="143"> f. 141r, col. 2</locus>
                <q>“Finished the Book of Mǝ‘raf of the Fasting Period with the peace of God on
                  twentieth of Mäskäräm, in the year of Matthew the Evangelist, 1957 E.C.” </q>,
                  <date when-custom="1957" calendar="ethiopian">1957 EC</date>
              </colophon>
            </msItem>
          </msContents>

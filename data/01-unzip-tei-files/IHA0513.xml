                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_1433">
                           <locus target="#24r">-24r</locus>
                           <q xml:lang="ar">بافتحة مقدرة على لاخر منع من ظهورها اشتغال المحل بحركة المناسبة المقدرة منع من ظهور ما اشتغال المحل بافتحة للخفة</q>
                           <desc>Marginalia</desc>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                           </note>
                        </item>
                        <item xml:id="a1_1418">
                           <locus target="#26v">-26v</locus>
                           <q xml:lang="ar">النحو يصلح من لسان الألكن| والمرء تعظمه اذا لم يلحن</q>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                              <p>
                                 Author
                              : <persName ref="https://betamasaheft.eu/PRS0831IHA">اسحاق بن
               خلف البهراني</persName>
                              </p>
                           </note>
                        </item>
                        <item xml:id="a2_1418">
                           <locus target="#59v">-59v</locus>
                           <q xml:lang="ar">وباالخير عمت وقع فراغي يوم السبت في الثمانة يوم الثانى من الاول بيد من صغير الاصغر الفقير الحقير الاذلى ذليل المذنب نحاطع ضعيف الراج عفوا ربه القادر اعنى بذالك من كان عدد اولى اسمه ؟؟؟ واخره ؟؟؟؟ من ريت هذا لاتنساه بدعائك المستجاب عليك ثم عليك سنة غشفج هج 
لا اله الا الله الله محمد رسول الله</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1418">
                           <locus target="#26r">-26r</locus>
                           <q xml:lang="ar">مناد مضاف منصوب وعلامة نصبه فتحة مقدرة على الأخر منع من طهوها</q>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                           </note>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#59v">-59v</locus>
                           <desc>Waqf</desc>
                           <q>وقفت هذا الكتاب المسمى باالآجروميه على جميع المسلمين وجعلت ناظر نفسى مدة حياتى وبعده من اهل بيتى من كان اهل للعلمى في الحضرا</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#47v">-47v</locus>
                           <desc>Ownership</desc>
                           <q>زبي مولا</q>
                           <note/>
                        </item>
                        <item xml:id="a3">
                           <locus target="#1r">-1r</locus>
                           <q>اذ انت مع شخص جلست ولم تجد| حضورك ينمو فاجتنبه وفارق</q>
                           <note/>
                        </item>
                        <item xml:id="a4">
                           <locus target="#1r">-1r</locus>
                           <q>ابجد هوز حطي كلمن سعفص قرشت ثخذ</q>
                           <note>Abǧad</note>
                        </item>
                     </t:list>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="16v">1v-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0136IHA">ملحة الاعراب</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>أقول من بعد افتتاح القول بحمد ذى الطول شديد الحول وبعده فافضل السلام على النبي سيد الانام </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>فارفعه اذ يعرب فهو الفاعل نحو جرى الماء وجارا العامل. ووحد الفعل مع الجماعة. كقولهم سار الى جال ساعه وان تشأ فزد عليه التاعا. نحو اشتكت عراتنا الشتاء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="17r" to="18v">17r-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#17r">-17r</locus>وهب من وعلى وإلى وعن وعلى وفى ورب والياء والكاف واللام وحروف القسم وهى الواو والباء والتاء والفعل يعرف</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17v">-17v</locus>معه دليل الا اسم ولا دليل فعل فعد باب الاعراب الاعراب هو تغير أو اخر الكلام لاختلاف العوامل الدخلة عليها</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="18r" to="18v">18r-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#18r">-18r</locus>قال الشيخ الامام النحوي اللغوي ابو عبد الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#18v">-18v</locus>عونك يا كريم وصلى الله على سيدن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="19r" to="23r">19r-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#19r">-19r</locus>فى الفعل المضارع اذا اتصل به ضمير تنية أو ضمير جميع او ضمير المؤثنية</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>وما اليا فتكون علامة للخفض فى ثلاث موضع فى الاسماء الخمسة فى تنبيه والجمع </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="24r" to="25v">24r-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>يا كريم وصلى الله على سيدنا محمد وله وصحبه وسلم اجمعين قال شيخ الامام النحوى النحوى اللغوي ابو عبد الله محمد ابن داود الضهاجى الشهير ببن اجروم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>وفعل وحرف جاء لمنعنى فالاسم باالخفض يتعرف وتنوين ودخول الالف ولا هى وحروف الخفض</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="26r" to="59v">26r-59v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r-27v-28r-28v">-27r, 27v, 28r, 28v</locus>يسرو لا تعسر وبه نستعين عونك يا كريم وصلى الله على سيدنا محمد وآاله وصحبه وسلم  جمعين
 قال الشيخ الامام النحوي اللغوي ابو عبد الله محمد ابن داود الضهاجي الشهير بابن آجروم الكلام هو اللفظ المركب المفيد بالوضع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#59v">-59v</locus>نحو علام زيد واللذى يقدر بمن نحو ثوب خز وباب ساج وخاتم حديد وما اشبه ذالك والله اعلم تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>

               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="101v" facs="001">Fols 1r–101v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1.1">
                      <locus from="1r" to="72r" facs="001">Fols 1r–72r</locus>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note>beginning at Psalm 43</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                    </msItem>

                    <msItem xml:id="ms_i1.2">
                      <locus from="72r" to="82v" facs="072">Fols 72r–82v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    </msItem>

                    <msItem xml:id="ms_i1.3">
                      <locus from="82v" to="89r" facs="083">Fols 82v–89r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <colophon xml:id="coloph1">
                        <locus target="#89r" facs="089">Fol. 89r</locus>
                        Concluding prayer of the Psalms, including a colophon:
                        <foreign xml:lang="gez">ተፈጸመ፡ በወርኃ፡ ጥቅምት፡ በዘመነ፡ ዮሐንስ፡ በ፲፱፻፬ አመተ፡ ምሕረት፡ በዕለተ፡ ዐርብ፡ በ፳፱ሌሊት፡ በ፲፮፡ መዓልት፡</foreign>
                        Translation: “Finished in the month of Ṭǝqǝmt, in the year of John the Evangelist, 1904 EC, on Friday, the 29th night [of the lunar cycle] and the 16th day [of the solar cycle].”
                      </colophon>
                    </msItem>

                  <msItem xml:id="ms_i1.4">
                    <locus from="89v" to="96r" facs="090">Fols 89v–96r</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>

                    <msItem xml:id="ms_i1.4.1"><locus from="89v" facs="090">Fols 89v and following</locus><title>Monday</title>
                      <note>incomplete at the end</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.2"><locus from="90r" facs="090">Fols 90r and following</locus><title>Friday</title>
                      <note>incomplete at the beginning and at the end</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.3"><locus from="91r" facs="091">Fols 91r and following</locus><title>Wednesday</title>
                      <note>incomplete at the beginning and the end</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.4"><locus from="92r" facs="092">Fols 92r and following</locus><title>Thursday</title>
                      <note>incomplete at the beginning</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.5"><locus from="92v" facs="093">Fols 92v and following</locus><title>Friday</title>
                      <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                      </msItem>
                    <msItem xml:id="ms_i1.4.6"><locus from="93r" facs="093">Fols 93r and following</locus><title>Tuesday</title>
                      <note>incomplete at the beginning</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.7"><locus from="93r" facs="093">Fols 93r and following</locus><title>Wednesday</title>
                      <note>incomplete at the end</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.8"><locus from="94r" facs="094">Fols 94r and following</locus><title>Saturday</title>
                      <note>incomplete at the beginning</note>
                      </msItem>
                    <msItem xml:id="ms_i1.4.9"><locus from="94r" facs="094">Fols 94r and following</locus><title>Sunday</title>
                      </msItem>

                </msItem>

                  <msItem xml:id="ms_i1.5"><locus from="96r" to="101v" facs="096">Fols 96r–101v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  </msItem>
                </msItem>


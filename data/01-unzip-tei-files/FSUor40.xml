                                <msItem xml:id="ms_i1.1">
                                    <locus target="#1a"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#Preface">No item: LIT6936TarWaAmidBeta, could not check for Preface</title>
                                    
                                    <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡</hi>ነ አሚን፡ ቦቱ፡ እትረዳእ፡ ወእዌጥን። ጽሕፈተ፡ ታሪክ፡ ዘውእቱ፡ ዜናሆሙ፡ ለአበው፡ ቀደምት።</incipit>
                                    <explicit xml:lang="gez">ወሰላመ፡ እግዚአብሔር። የሀሉ፡ ላዕለ፡ ገብረ፡ እግዚአብሔር<del rend="erasure"/>ለዓለመ፡ ዓለም፡ አሜን።</explicit>
                                </msItem>
                            
                                <msItem xml:id="ms_i1.2">
                                    <locus from="1a" to="3b"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#Introduction">No item: LIT6936TarWaAmidBeta, could not check for Introduction</title>
                                    <incipit xml:lang="gez">ስብሐት፡ ለእግዚአብሔር፡ ቀዳሚ፡ ዘእንበለ፡ ጥንት።</incipit>
                                    <explicit xml:lang="gez">እስመ፡ ሐሳብ፡ ይፈቅድ፡ ኪያሆሙ፡ እስመ፡ ውእቱ፡ ንዱቅ፡ ላዕሌሆሙ።</explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3">
                                    <locus from="3b" to="5a"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#KawinaAlam">No item: LIT6936TarWaAmidBeta, could not check for KawinaAlam</title>
                                    <incipit xml:lang="gez"><hi rend="rubric">ነገር፡ በእንተ፡ ዓለም፡ ተጋአዙ፡ በእንተ፡ ፍጥረተ፡ ዓለም፡</hi></incipit>
                                    <explicit xml:lang="gez">ወረድኤትነሰ፡ እም<pb n="3ra"/>ኀበ፡ እግዚአብሔር።</explicit>
                                </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="5a" to="5b"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#TeyyaqeAzman">No item: LIT6936TarWaAmidBeta, could not check for TeyyaqeAzman</title>
                                <incipit xml:lang="gez"><hi rend="rubric">ነገር፡ በእንተ፡ ጥያቄ፡ አዝማን፡</hi></incipit>
                                <explicit xml:lang="gez">ወመዓልት፡ ለ፲ወ፪ክፍል፡ እንተ፡ ይእቲ፡ ሰዓታት።</explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.5">
                                <locus from="5b" to="6a"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#MatanaAzman">No item: LIT6936TarWaAmidBeta, could not check for MatanaAzman</title>
                                <incipit xml:lang="gez"><hi rend="rubric">ነገር፡ በእንተ፡ መጠነ፡ አዝማን፡</hi></incipit>
                                <explicit xml:lang="gez"><sic>ወብጸነ፡</sic> ለእመ፡ ሠምረ፡ እግዚአብሔር።</explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <locus from="6a" to="7b"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#TentaFetrat">No item: LIT6936TarWaAmidBeta, could not check for TentaFetrat</title>
                                <incipit xml:lang="gez"><hi rend="rubric">ነገር፡ በእንተ፡ ጥንተ፡ ፍጥረት፡</hi></incipit>
                                <explicit xml:lang="gez">ይቤ፡ መጽሐፍ፡ ወአዕረፈ፡ እግዚአብሔር፡ እምኵሉ፡ ግብሩ፡ በዕለት፡ ሰብዕ፡ ወዐረካ፡ ወቀደሳ።</explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.7">
                                <locus from="7b12" to="174a"/>
                                <note>Running until Emperor Marcus Aurelius, who is called <foreign xml:lang="gez">አራልያኖስ፡</foreign>.</note>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#preislamichistory">No item: LIT6936TarWaAmidBeta, could not check for preislamichistory</title>
                                <incipit xml:lang="gez">ወይቤ፡ ለእግዚአብሔር፡ አምላክ፡ ገነት፡ ውስተ፡ <sic>ኤዶም፡</sic> ዘመንገለ፡ ጽባሕ፡</incipit>
                                <explicit xml:lang="gez">ወአራልያኖስሰ፡ ቄ<sic>ሰ</sic>ር፡ ንጉሥ፡ ሞተ፡ በፍጻሜ፡ ፶፻ወ፯፻፹ወ፩ ዓመት፡ ወመንፈቅ፡ እምፍጥረተ፡ ዓለም። ። ።</explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8">
                                <locus from="174a" to="190a"/>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT6936TarWaAmidBeta#Patriarchs">No item: LIT6936TarWaAmidBeta, could not check for Patriarchs</title>
                                <note>Despite the announcement in the incipit, the enumeration of Patriarchs contains more than 50 representatives of
                                    the Alexandrian see, running infact from Mark the Evangelist until a Patriarch with the name
                                    <foreign xml:lang="gez">ቆዝሞስ፡</foreign> on <locus target="#93rb"/>, continued by another pen 
                                    with <foreign xml:lang="gez">ፊለታኦስ፡</foreign>, who was given no. 65, while the last representatives from 
                                    <foreign xml:lang="gez">ጴጥሮስ፡</foreign> (no. 83) to <foreign xml:lang="gez">ማርቆስ፡</foreign> (no. 99) are 
                                    offered in the form of a short list on <ref target="95rb"/>. Another abbreviated list of the later patriarchs was written 
                                    with smaller script but possibly by the same hand at the bottom margin of <locus from="94v" to="95v"/> ranging from 
                                    <foreign xml:lang="gez">ዘካርያስ፡</foreign> (no. 64) to <foreign xml:lang="gez">ብንያም፡</foreign> (no. 102).</note>
                                <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈሰ፡ ቅዱስ፡ ፩ አ</hi>ምላክ፡ ፶ አንቀጽ፡ በእንተ፡ አእምሮ፡ ስመ፡
                                    ሊቃነ፡ ጳጳሳት፡ ዘግብጽ፡ ወምስር፡ እለ፡ ተሰይሙ፡ በእለእስክንድርያ። እምአብ፡ ሐዋርያ፡ ማርቆስ፡ ወንጌላዊ፤ ወእስከ፡ አብ፡ አትናስየስ።</incipit>
                                <explicit xml:lang="gez">ወኵሉ፡ ድሙር፡ ዓመታት፡ እምፍጥረተ፡ ዓለም፡ እስከ፡ ፫ ዓመተ፡ መንግሥቱ፡ ለዓፄ፡ ሱስንዮስ፡ ፸፻፡ ወ፩፻ወ፪ ዓመተ፡ ውእቱ።
                                        </explicit>
                            </msItem>
                        </msItem>
                            
                        <msItem xml:id="ms_i2">
                                <locus from="190a" to="191b22"/>
                                <title type="complete">List of Egyptian Kings</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ነገስታት፡ ግብጽ፡</incipit>
                                <explicit xml:lang="gez">ዘበእንቲአሃ፡ ይቤ፡ ንግሥተ፡ ሰብእ፤ ወንግሥተ፤ አዜብ። ።</explicit>
                            </msItem>
    
                                <msItem xml:id="ms_i3">
                                    <locus from="191b22" to="203b"/>
                                    <title>List of Ethiopian Kings from ʾArwe to Bazen</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ዝውእቱ፡ አስማቲሆሙ። ለነገሥተ፡ ኢትዮጵያ፡ 
                                        እመን<supplied reason="omitted" resp="CH">ግ</supplied>ሥተ፡ 
                                        አር<choice resp="CH"><t:corr xmlns:t="http://www.tei-c.org/ns/1.0">ዌ</t:corr><sic>ዊ</sic></choice>፡ እስከ፡ በዜን፡</incipit>
                                    <explicit xml:lang="gez">ወእምዝ፡ ሖረ፤ ዮምኒ፡ ይብልዎ፡ ለንጉሥ፡ ዳንዞ፡ እንዘ፡ ይጽርሑ፤ ኀቤሁ፡ ሰብአ፡ ቤቱ፤ ደረባ፡ ቤት። ። ።</explicit>
                                </msItem>
                                
                                <msItem xml:id="ms_i4">
                                    <locus from="203b" to="204b"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT4983ListDabra">List of the abbots of Dabra Libānos</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez"><hi rend="rubric">ኍልቈ፡ መምህራን፡ ዘደብረ፡ <add place="above">ሊባኖስ፡ </add></hi>
                                        ፩ አቡነ፡ ተክለ፡ ሃይማኖት፡
                                        ፪ ኢልሳዕ፤
                                        ፫ ፊልጶስ።</incipit>
                                    <explicit xml:lang="gez">፵፬ ፊልጶስ፡ ዘአምሓራ።
                                        ፵፭ ገብረ፡ ሥላሴ፡ ዘጎረፍ፤</explicit>
                                </msItem>
                            
                            <msItem xml:id="ms_i5">
                                <locus from="206b" to="221a"/>
                                <title ref="https://betamasaheft.eu/LIT2341serata">Śǝrʿāta mangǝśt (general record)</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez"><hi rend="rubric">ሕግ፡ ወሥርዓተ፡ መንግሥት፡</hi> ዘወፅአ፡ እምኢየሩሳለም፡
                                    <hi rend="rubric">ምስለ፡ እብነ፡ ሐኪም፡ ወል</hi>ደ፡ ሰሎሞን፡ ዘውእቱ፡ ምኒልክ፡ ወምስሌሁ፡ ዘወፅኡ፡ ፲ወ፪ በዓለ፡ ሕግ፡</incipit>
                                <explicit xml:lang="gez">ወ<pb n="221a"/>ድኅሬሁ፡ ይ፡ ብላቲንጌታ<add place="above">ኒ</add>፡ ወራስ፡ በላዕሌሁ፡ ወበላዕሌሆሙ፡ 
                                    ይመክሩ፡ ንጉሥ። ። <add place="above">ኀለቀ፡ ወምቱረ፡</add></explicit>
                            </msItem>
                            
                                <msItem xml:id="ms_i6">
                                    <locus target="#221a"/>
                                    <title ref="https://betamasaheft.eu/LIT2341serata">Record on tributes of the kingdom (?)</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez"><choice resp="CH"><sic>ወግ፡</sic><t:corr xmlns:t="http://www.tei-c.org/ns/1.0">ሕግ፡</t:corr></choice> ወሥርዓት፡ ዘቀኝ፡ ወዘግራ፡
                                        አዛዞች፡ ዘራስ፡ ፲ ወቄት፡</incipit>

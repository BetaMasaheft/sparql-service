                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus><desc> Crude drawings of five faces and two ornate crosses</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref> with caption <q> “It is David, King of Israel.”</q></desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#123r" facs="125">Fol. 123r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                  <decoNote type="frame" xml:id="d4">
                  Decorative designs:
                  <locus target="#11r #29r #38r #44v #84v #95r #99r #102v" facs="013 031 040 047 087 097 101 105">folss. 11r, 29r, 38r, 44v, 84v, 95r, 99r, 102v, </locus> (haräg);
                  <locus target="#1r #21v #44r #49r #56r #64v #71r #75r" facs="003 024 046 051 058 067 073 077">1r, 21v, 44r, 49r, 56r, 64v, 71r, 75r, </locus> (line of alternating red and black dots);
                  <locus target="#93r #109v #122v" facs="095 112 125">93r, 109v, 122v, </locus> (full stops between lines of alternating red and black dots);
                  <locus target="#112v" facs="115">112v, </locus> (line of full stops);
                  <locus target="#87r #87v #88r #88v" facs="089 090 091">87r, 87v, 88r, 88v</locus>multiple full stops used at the beginning of a psalm in many locations
                  </decoNote>
                  </decoDesc>

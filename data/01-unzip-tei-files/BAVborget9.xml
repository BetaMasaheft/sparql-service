                        <item xml:id="a2">
                          <locus from="2r" to="3r"/>
                          <desc type="GuestText">
                            <title type="complete">Prayers in the form of a litany</title>
                          </desc>
                          <q xml:lang="gez">
                            <seg part="I">በእንተ፡ ሥላሴከ፨ እግዚኦ፡ ተሣሃለነ፨ በእንተ፡ ማርያም፡ እምከ፨ እግዚኦ፡ ተሣሃለነ፨ በእንተ፡ ማኅፀና፡ ዘጾ<choice><sic>ራ</sic><corr>ረ</corr></choice>ከ፨ እግዚኦ፡ ተሣሃለነ፨ በእንተ፡ ትስብእትከ፡ እግዚኦ፡ ተሣሃለነ፨</seg>
                            <seg part="F">በእንተ፡ ትንሣኤከ፡ እግዚኦ፡ ተሣሃለነ። በ<sic>፡</sic>እንተ፡ <choice><sic>ፅ</sic><corr>ዕ</corr></choice>ርገትከ፡ እግዚኦ፡ ተሣሃለነ። በእንተ፡ ምጽዓትከ፡ እግዚኦ፡ ተሣሃለነ። በእንተ፡ ሥጋከ<supplied reason="omitted">፡</supplied> ወደምከ፡ እግዚኦ፡ ተሣሃለነ።</seg>
                          </q>
                        </item>


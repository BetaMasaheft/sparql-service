               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="3r" to="3v">3r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1130IHA">تذكير المذاهب مستغنيا بواهب المواهب</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>ولا يجوزون ارسال الطلاق الثلاث بلفظ واحد ولا يرون تعجيل الافطار ووضع اليمنى على يسرى فى الصلاة سنة واما المسائل التى اختلفوا فيها فالعلوية قالوا ان عليا نبى فلا تفنى الدنيا وما فيها ا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>الباب الحامس فى اسامى القدرية احمدية تنوية كسائيه شيطانية شريكية وهمية رويدية ناكسية مسرية قاسطية نظامية منزلية اعلم ان المسائل التى اختلفوا</explicit>
                     <note>The folio is turned around: the text begins on fol. 3v and continues on fol. 3r.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="4v">4r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0019IHA">قاموس المحيط</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>والشرطان محركة نجمان من الحمل وهما قرناه وإلى جانب الشمالى كوكب صغير ومنهم من يعده معهما فيقظ هذه المنزل ثلاثة كواكب ويسميها الأشراط</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>فزع المؤخر بطن الحوت| وسموه الرشا بسكر يأتى

|والحمد لله على التمام| صلى وسلم على بدر التمام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="37r" to="37v">37r-37v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0026IHA">مختصر ﺍبي شجاﻉ على مذﻫب ﺍلشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#37r">-37r</locus>الذي حلت فيه نجاسة وهو دون القلتين او كان قلتين كثير فتغير والقلتان خمس  مائة رطل بالبعد ادي تقريبا في الاصح </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#37v">-37v</locus>يشرك فيها الرجل ولناء وهي [...] الموت وثلاثة؟؟؟<note>Disrupted</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="38r" to="42v">38r-42v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1128IHA">نظم جلا بنوره ظلمة الضلال</title>
                     <incipit xml:lang="ar">
                        <locus target="#39r">-39r</locus>جلا بنوره ظلمة الضلال| رقى بعزمه دزوة الكمال| تدكدكت له حجب الجلال| واستدلت منه اصحاب الدلال قوت ارواح الله يا الاقوياء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#42v">-42v</locus>نور كل شير من بعرس نوره | قسمه الله الى مخلوقه | سماه نبيا قبل بروزه| انزل عليه خير تنزله اعطاه شفاعة فى يوم اللواء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="43r" to="43v">43r-43v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1135IHA">صلاة مدحك أنسى سهم</title>
                     <incipit xml:lang="ar">
                        <locus target="#43r">-43r</locus>مدحك أنسى سهم وترس درع وبسى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43v">-43v</locus>شمس ءينا عيزاب فيوض الاسرار وكأس المدام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="45r" to="45v">45r-45v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1136IHA">قصيدة وعين أعيان العالم نقطة الباء المطلسم</title>
                     <incipit xml:lang="ar">
                        <locus target="#45r">-45r</locus>وعين أعيان العالم نقطة الباء المطلسم| مجتبى بيت الكمال| شفيع كافة الامم سيد العرب والعجم| ترياق الداء العضال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#45v">-45v</locus>جرحتم قلب المحب بسهم لحطه الحب| فى يوم ذاك الخيال| صلاة مع السلام دائما بلانصرام| سر مدا على التوال</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="46r" to="48r">46r-48r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1129IHA">قصيدة على النبى المصطفى المكرم</title>
                     <incipit xml:lang="ar">
                        <locus target="#46r">-46r</locus>صلى الله وسلم صلى الله على النبى مصطفى المكرم|

محمد مولانا على ما ءولانا|بمن به تشرف العالم| محمد الامين نور الله المبين | سر التكوين لحوى وادم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#48r">-48r</locus>والفاروق الاكبر وعثمان| الابر وعلى الحيدر لاسد الضرغم | ما طاب التدانى لذوى العرفان| وما عنى الغانى بلذيذ النغم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="48r" to="49v">48r-49v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1137IHA">نظم شي لله اهل الولاس سكان زب مولا</title>
                     <incipit xml:lang="ar">
                        <locus target="#48r">-48r</locus>شي لله اهل الولاس سكان زب مولا اعنى شيخين الزبي والقاقي

بدأت يا البسملا ثانيا با الحمد لا وشاكر اشاملا لنعمه الكاملا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#49v">-49v</locus>فاوصلنا ذاك القرب ويا رب فيارب واسقنا كاس الحب واردنا حوض الولا| زب صلى وسلم على النور المعظم وصحبه المكرم وكذا على الا؟ تمت
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="50r" to="52r">50r-52r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1138IHA">نظم سادتنا اغيثونا فبالله سامحونا وصلنا ذاك المنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#50r">-50r</locus>سادتنا اغيتونا فبالله سامحونا وصلنا ذاك المنا.
بسم الله قد بدءنا| تبركا ما سمد نظمنا| يجيب سؤالنا| ولعل أن يرضانا رب الوراى خالقنا بسبب زبينا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52r">-52r</locus>سلم على نبينا| واله وصحبنا | نصرتنا حماتنا| انجحنا بدورنا قدوتنا شموسنا ؟؟ اوصل ذاك المنا. تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="52v" to="54v">52v-54v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <incipit xml:lang="ar">
                        <locus target="#52v">-52v</locus>جمال العالم صلى الله عليه وسلم جمال العالم صلى الله عليه وسلم.

جمال بدمن جارى قبا| هيجه لروح حركا قلبا| بطالعته سبا قلوبا| لك حبا من اهل الغرام

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#54v">-54v</locus>طاوس ءقطاب لزمان عروس حضرة الجنان| من قد فضله لرحمان من قبل سائر الأمم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="55v" to="63v">55v-63v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1140IHA">صلاة على النبي طلع بدر الوجود من شرق السماء</title>
                     <incipit xml:lang="ar">
                        <locus target="#55v">-55v</locus>الصلاة كل لحمة والسلام والتحية على نبي الرحمة. طلع بدر الوجود من شرق سماء المجد اي سماء الحضرة| فيه فى الكون نور افغيه سره سرى وجرى باالاحاطة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#63v">-63v</locus>ادخلنا معه الجنة وفقنا النهج والستة قونا على الطاعة| واغفر لى ولا حب بى ولا مرو ابى واهلى وزيتى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="68r" to="71v">68r-71v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1141IHA">نظم انت يا سيدى مناك مرام</title>
                     <incipit xml:lang="ar">
                        <locus target="#68r">-68r</locus>انت يا سيدى مناك مرام| غايه مطلبي طب وومرهم| ملجق مهرى فى يوم الزحام| ذخرتكم ذاذ بااليوم القيام إذ ذاك سواك فليس يغنينى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71v">-71v</locus>مرأت رونق حجلا الملكوت| مشكات زجاج حضرة الجبروت| صفاء سحاء ميادن للهوت| مجلى محاسن عالم الوح؟وت بشرى معاشر ارباب الايقان</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5r" to="8r">5r-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1009IHA">عروس السمر في منازل القمر بشرح نسيمة السحر</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين وصلى الله على سيدنا محمد رسول الله وعلى إله وصحبه وسلم هذه قصيدة يعرف بها ما يطلع به الفجر من منازل القمر في جميع ايام السنة مرتبا على شهور القبط وبمعروفة ذلك يعلم اذ انظرت فيها ليلا متى يطلع الفجر  وشهور القبط او له توت والثنى بابه والثالث هتور والرابع هذه قصيدة بعر ذكيهك والخامس طوبه والسادس أمشيبر والسابع برهمات والثامن يرمودة والتاسع مسرى وتوت خمسة أيام لاتعد مع واحد منهما تسمى ايام النسئ وسياتى ذكرها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>ما اختيالى وما مقالى وما لى| عمل ارتضيه فى ميزان|| رب هب توبة وسامح بعفو| لعلى يا دائم الاحسان</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i20">
                     <locus from="74r" to="74v">74r-74v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3931IHA">حاشية الاجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#74r">-74r</locus>بسم الله الرحمن الرحيم .
الباء حرف جرمبنى على الكسر اسم مجرور بالباء وعلامة جره كسرة ظاهره فى اخره</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#74v">-74v</locus>التعلم وخبره محذوف جواز تقديره مؤلف به مؤلف خبر مرفوع وعلامة رفعه ضمة ظاهره فى اخره الباء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i21">
                     <locus from="75r" to="77r">75r-77r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1143IHA">خلاصة ما علينا الله تعالى</title>
                     <incipit xml:lang="ar">
                        <locus target="#75r">-75r</locus>خلاصة ما علينا الله تعلى ملازمة ذكره سواء كان ذلك باللسان او باالقلب او بالروح او باالسر او باالجملة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#77r">-77r</locus>وسبب وفاية العبيد من عذاب الدنيا ونجاتهم من عذاب الاخرة ان كان مع الندم واستعار قبح الدنوب والفرج من كل ضيق ومخرج من كل هم واقله جدا مائة اوثلاثمائة الى الف وخامسها ملازمة الدعاء وقراءت الاحزاب وملازمة الاوراد لطلب لذة المنجات والموانسات لا غير لانه الائق بهذ الذمان لمبارك قطعا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i22">
                     <locus from="78r" to="80v">78r-80v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0030IHA">تحفة المحتاج بشرح المنهاج</title>
                     <incipit xml:lang="ar">
                        <locus target="#78r">-78r</locus>والقلتان فى المربع ذراع وربع طولا وعرضا وعمقا بذراع الادمى المعتدل وهو شبران تقريبا فتكون الارباع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#80v">-80v</locus>فاالوجب نعجة او عنز بقيمة ثلاثة ارباع نعجة وربع عنزوهم فى المنال المذكور دينار وثلاثة ارباع دينار ولو كانت ما شيته صغارا اخذت صغيرة باالنسبة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i23">
                     <locus from="81r" to="83v">81r-83v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0020IHA">منهاج الطالبين</title>
                     <incipit xml:lang="ar">
                        <locus target="#82v">-82v</locus>الفقه لغة الفهم واصطلاحا العلم باالاحكام الشرعية العلمية المكتسب من ادلتها التفصلية</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#83r">-83r</locus>فى الركوع الاول قدر مأة من البقرة وفى لثانى ثمانين وفى الثالث سبعين والرابع خمسين تقريبا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="10r" to="11v">10r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0983IHA">خلاصة مختصر تحرير الاصول والاوراد في ذكر تراجم
                    اشياخنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>منهم خلاف ذلك فان من كان بينهم على نقص فى محبته وامتثال امره فقد خسر واستوجب الحرمان والانحطاط عن رتبته  كما اشتهر ذلك فيهم ايضا ومن ذلك ما ذكره العارف بالله سيدى ومولاى الشيخ محمد كرم رحمه الله الرحمة الواسعة بقوله وكان مع شيخنا قدوة المحققين وقبلة العارفين سيدى كمال الدين الزبى غلام من تلامذته وكان يحبه كثيرا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>والحقيقة اياما ثم سأله الشنكىّ رحمه الله الرحمة الواسعة ما يرومه فأخيره بأنّ قصده التعلم فعند ذلك اشار اليه أ يتعلم عنده فتشاور</explicit>
                     <note>I am not sure about the text. It could be a draft of this work.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="12r" to="14v">12r-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1133IHA">قصيدة على النبي رفرف اصحاب السير</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>رفرف اصحاب السير مرأة شهود البارى مادة الخير والرشدى منحة حضرة الصمد ترياق اللب والجسدى نبعة الجود والمدد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12r">-12r</locus>نبي جميل الذات مرأة تلط الحضرة ى|
نبي يساط الأنس مجراب حضرة القدس ه ى|
نبي سقير البارى غذا روح الأخيارى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="15r" to="30v">15r-30v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1131IHA">فضائل على التعلم</title>
                     <incipit xml:lang="ar">
                        <locus target="#15r">-15r</locus>فى سفر حجه فصول اليه واخذ الطريقة الاحمدية منه ثم اشتغل بوردها عنده كثيرا حتى فتح الله له الفتح المبين واجلسه على سرير التمكين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30v">-30v</locus>ولا طلبن عثرته وان زل قبلت معذرته وعليك ان توقره وتعظمه المه تعالى ما دام يحفظ امر الله تعالى ولا تجلس امامه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="31r" to="31v">31r-31v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1132IHA">دعاء سائر المؤمنين ملحوظة إليها يارب العالمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#31r">-31r</locus>سائر المؤمنين ملحوظة إليها يارب العالمين وأسئلك النفع بها ياحنان يامنان ياارحم الراحمين اللهم إني اسئلك المفواتح الخير وخواتمه وجوامعه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#31v">-31v</locus>اللهم إني أطعتك فى أحب الأشياء إليك وهو التوحيد ولم أعصك فى أبغض للاشياء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="32r" to="32r">32r-32r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0481IHA">فتح مفرج الكروب</title>
                     <incipit xml:lang="ar">
                        <locus target="#32r">-32r</locus>لبر كان جميلا طويل اللحية حسن الوجه وقال فى موضع اخر كان رئعة حسن الوجه رقيق البشرة عظسم اللحية اه 
أثمر اللون كان يصفر لحبته بالورس وشد اسنانه بالذهب وعلى الامام ابى حسن على ابن ابي طالب فى العلم إذا وافى بسحائبه جمع سحاب الخلج بفتح الخاء واللام جمع خلوج السحاب 
المتفرق وقام الاجماع على غزارة علمه والحمد لله والصلاة والسلام على اشرف الخلق سيدنا محمد وعلى اله وصحبه وسلم سنة ١٣٢٠</incipit>
                     <explicit xml:lang="ar"/>
                     <note>A small fragment: only the ending of the text remains. The whole fragment is given in Incipit. The text is copied by the same hand as the next part.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="32r" to="32v">32r-32v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1130IHA">تذكير المذاهب مستغنيا بواهب المواهب</title>
                     <incipit xml:lang="ar">
                        <locus target="#32r-32v">-32r, 32v</locus>بسم الله الرحمن الرحيم وبه نستعين الحمد لله الهادى للمتقين الحافظ عن طريق الضالين والصلاة والسلام على رسوله خاتم النبيين وعلى اله واصحابه ما حى بدع المبتدعين
اما بعد ان الله تعلى قد فرض علينا طيب طريق الحق الذى عليه السنة والجماعة والحذر عن طريق الفرق [...] وسميته بتذكير المذاهب مستغينا بواهب المواهب وجمعته على سبعة ابواب </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#32v">-32v</locus>اعلم بان المسائل التى اتفقوا عليها فيها قالوا بان الجماعة  أليست بسنة والمسح على الخفين غير جائز ويلعنون ابا بكر وعمر ويعزون بعلى ويقولون التراويح ليس بسنته و \ لا ىجوز<note>The last two words are the catchword. The continuation of the text is on fol. 3v.</note>
                     </explicit>
                     <note>
                        <note>
        Manuscript item  1416 relates to manuscript item 1410</note>
                     </note>
                     <note>The text is copied by the same hand as the preceding fragment in the top part of fol. 32r. The fragment is dated 1320 H and must apply to the present text as well.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="33r" to="36r">33r-36r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0088IHA">احياء علوم الدين</title>
                     <incipit xml:lang="ar">
                        <locus target="#33r">-33r</locus>ولا تحصل المعرفة الا بدوام ذكر الله تعالى والانس به ولا تتيسر المواظبة والانس به الا بانقلاع حب الدنيا من القلب ولا ينقلع ذلك الا بترك لذات الدنيا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35v">-35v</locus>ويكون ورده وردا واحدا وهو لباب الاوراد وثمراتها اعنى ملازمة القلب بذكر الله تعالى بعد الخلوص عن ذكر غيره اذ ليس للمحب شىء اشرف</explicit>
                     <note/>
                     <note/>
                  </msItem>

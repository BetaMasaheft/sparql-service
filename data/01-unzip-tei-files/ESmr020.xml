                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Poor</seg>
                        <seg type="ink">Black, red</seg>
                        Scribe: Walda Ṣādǝq. Walda Ṣādǝq
                           (<locus target="#52va">52va</locus>) for the text in quires
                           I-VII.<date>19th century</date>
                        <seg type="rubrication">Nomina sacra; names of the donors; incipits and
                           headings of the texts; names of sections of Text III followed by feast
                           names and initial words (e.g, zǝmmāre za-Qirqos); elements of the
                           punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: quires I-VII, crude, with
                        angular
                        letters.</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: quire VIII, somewhat better
                        trained.</handNote>
                  </handDesc>

                    <msPart xml:id="p1">
                        <msIdentifier/>
                        <msContents>
                            <summary/>
                            
                            <msItem xml:id="p1_i1">
                                <locus from="1ra" to="64vb"/>
                                <locus from="100ra" to="104rb"/>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT1850Malkea">Malkǝʾa gubāʾe</title>
                                <textLang mainLang="gez"/>
                                <note>The beginning is missing.</note>
                                
                                <msItem xml:id="p1_i1.1">
                                    <locus from="1ra" to="1rb"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT3088RepCh368">ʾO-rǝḫrǝḫta ḫǝllinā</title>
                                    <textLang mainLang="gez"/>
                                    <note>The beginning is missing.</note>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.2">
                                    <locus from="1rb" to="8ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3082RepCh362">Malkǝʾa kidāna mǝḥrat</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">እግዚአብሔር፡ ወሀቤ፡ ብርሃን፡ ዘይሴለስ፡ በአካሉ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.3">
                                    <locus from="8rb" to="10vc"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2932RepCh213">Malkǝʾa fǝlsatā</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ ምስለ፡ ነፍስኪ፡ ኢመዋቲ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.4">
                                    <locus from="11ra" to="19rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3035RepCh315">Malkəʾa Galāwdewos</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ናሁ፡ ወጠንኩ፡ ለመልክዕከ፡ ሰላሙ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.5">
                                    <locus from="19rb" to="35vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba ṭabibān</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.6">
                                    <locus from="36ra" to="40va"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2870RepCh151">Malkəʾa Yoḥannǝs</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘበመጽሐፈ፡ ሕግ፡ ተሐትመ።</incipit>
                                    <note><foreign xml:lang="gez">አጼ፡ ዮሐንስ፡</foreign> is written in the margin by the main hand, 
                                        supporting the attribution of this hymn to <persName ref="https://betamasaheft.eu/PRS10375Yohanne">Yoḥannǝs I</persName>.</note>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.7">
                                    <locus from="40vb" to="48rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">Lǝssāna sabʾ</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ናሁ፡ ተማኅፀንኩ፡ በኆኅያተ፡ ስምከ፡ ካፍ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.8">
                                    <locus from="48rb" to="57va"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2741RepCh25">Malkǝʾa ḥǝmāmāta masqal</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለሕማምከ፡ ቤተ፡ አይሁድ፡ ዘአንደደ፡ ወረሰዮሙ፡ ሐመደ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.9">
                                    <locus from="57va" to="62vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2842RepCh125">Malkǝʾa masqal</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በመጽሔተ፡ መስቀል፡ ዘተልክዓ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.10">
                                    <locus from="63ra" to="64vb"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                                    <textLang mainLang="gez"/>
                                    <note>The text breaks off with the end of <locus target="#64vb"/>; the end is missing.</note>
                                    <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis"/> ንጽሕፍ፡ በረድኤተ፡ እግዚአብሔር፡ መጽሐፈ፡ ሕይወት፡ ልፋፈ፡ ጽድቅ፡ ጸሎተ፡
                                    መድኃኒት፡ ዘጸሐፋ፡ አብ፡ በእዴሁ፡ እምቅድመ፡ ይትወለድ፡ እማርያም፡ ድንግል፡ እንተ፡ ታበውእ፡ ውስተ፡ ጸባብ፡ አንቀጽ፡ ወታበጽሕ፡ ውስተ፡ መንግሥተ፡ ሰማያት፡
                                    መርሐ፡ ለጽድቅ፡ ወዘንተ፡ ነገራ፡ ክርስቶስ፡ ለማርያም፡ እሙ፡ እምድኅረ፡ ተወልደ፡ እምኔሃ፡ አመ፡ ፳ወ፬ ለወርኃ፡ መጋቢት።</incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="p1_i1.11">
                                <locus from="100ra" to="104rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2849RepCh131">Malkǝʾ-hymn to Raphael</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ተጸውዖ፡ ዘቀደመ፡ በአፈ፡ አምላክ፡ አዳመ፡ እንበለ፡ ይሰመይ፡ ስመ።</incipit>
                            </msItem>
                            
                    </msContents>
                    
                    

                                    <title type="complete" ref="https://betamasaheft.eu/LIT3115RepCh395">Malkǝʾa Ṗarāqliṭos</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ጰራቅሊጦስ፡ ዓምደ፡ ደመና፡ ዘመራሕኮሙ፡ ለአበው።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p2_i1.2">
                                    <locus from="73ra" to="80vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2842RepCh125">Malkǝʾa masqal</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በመጽሔተ፡ መስቀል፡ <sic>ዘተክዓ</sic>።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p2_i1.3">
                                    <locus from="81ra" to="84ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2960RepCh241">Malkǝʾa ʾanqaṣa bǝrhān</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ቅድስት፡ ወብፅዕት፡ በልሳነ፡ ኵሉ፡ ዘነፍስ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p2_i1.4">
                                    <locus from="84rb" to="90rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT3055RepCh335">ʾƎsaggǝd la-malakotǝka</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">እሰግድ፡ ለመለኮትከ፡ እንተ፡ ፈጠረከ፡ ጸልመተ።</incipit>
                                    <note>The text is divided into the days of the weeks, which are indicated within the main body of the text.</note>

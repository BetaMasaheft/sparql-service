            <t:div type="edition" xml:lang="gez">
                <t:div type="textpart" subtype="incipit" xml:id="Incipit">
                    
                    <t:ab> ሰላም፡ ለኪ፡
                        <t:app><t:lem wit="W2 W3 W4"/>
                            <t:rdg wit="W1">ማርያም።</t:rdg>
                        </t:app>
                        ኆኅተ፡ ምሥራቅ፡</t:ab></t:div>
                
                <t:div type="textpart">
                    <t:ab>
                ዘወልደ፡
                            <t:app>
                    <t:lem wit="W2 W3 W4">ኖሬ፡</t:lem>
                            <t:rdg wit="W1"><t:gap reason="illegible" unit="chars" quantity="2"/>፡</t:rdg>                        
                        </t:app>
                        
                        ሰላም፡ ለኪ፡<t:app>
                            <t:lem wit="W3 W4 W1">ዓፀድ፡</t:lem>
                            <t:rdg wit="W2">ጽድልት፡</t:rdg>
                        </t:app>
                        <t:app>
                            <t:lem wit="W1">ዘእሰከደሬ፡</t:lem>
                            <t:rdg wit="W2"/>
                            <t:rdg wit="W3">ዘኤስኬድራ፡</t:rdg>
                            <t:rdg wit="W4">ዘእስከደሬ፡ ሰለኪ፡ ስርጉት፡ በወራውሬ፡ ሰለኪ፡ ፅድልተ፡ ንጻሬ፡</t:rdg>
                        </t:app>
                        <t:app>
                            <t:lem wit="W2 W4 W1"/>
                            <t:rdg wit="W3">ሰላም፡ ለኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W4 W1"/>
                            <t:rdg wit="W3">እስመ፡ ወልድኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W4 W1"/>
                            <t:rdg wit="W3">ፈጣሬ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W1"/>
                            <t:rdg wit="W3">ሰላ፡</t:rdg>
                            <t:rdg wit="W4">ሰላ፡</t:rdg>
                        </t:app>
                        <t:app>
                            <t:lem wit="W2 W4 W1"/>
                            <t:rdg wit="W3">ለኪ፡ ጽድልተ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W1"/>
                            <t:rdg wit="W3 W4">ንጸሬ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W3 W1">ሰላም፡</t:lem>
                            <t:rdg wit="W2"/>
                            <t:rdg wit="W4">ሰላኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1">ለኪ፡ ጽድልተ፡</t:lem>
                            <t:rdg wit="W2 W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W1">ንፂሬ፡</t:lem>
                            <t:rdg wit="W2 W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W1">ሥርጉት፡</t:lem>
                            <t:rdg wit="W2 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W2 W1">በወራውሬ፡</t:lem>
                            <t:rdg wit="W3">በወራውረ፡ ሰ፡</t:rdg>
                            <t:rdg wit="W4"/>
                        </t:app><t:app>
                            <t:lem wit="W2 W1">ሰላም፡</t:lem>
                            <t:rdg wit="W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W2 W1">ለኪ፡</t:lem>                                                 
                            <t:rdg wit="W2">ወጽዕድውት፡ ዘምስለ፡ ንዳሬ፡</t:rdg>
                            
                        </t:app>
                        <t:app>
                            <t:lem wit="W1 W2">ሰላም፡ ለኪ፡</t:lem>
                            <t:rdg wit="W3">ሰላኪ፡</t:rdg>
                            <t:rdg wit="W4">ሰ፡</t:rdg>                            
                        </t:app>
                                       
                        <t:app>
                            <t:lem wit="W2 W3 W1">በትረ፡ አሮን፡ ጸዋሪተ፡ ፍሬ፡ </t:lem>
                            <t:rdg wit="W4">በትረ፡ አሮን፡ ጸዋሪተ፡ ፍሬ፡ ሰ፡</t:rdg>                        
                        </t:app>
                        <t:app>
                            <t:lem wit="W1">ሰላም፡ ለኪ።</t:lem>
                            <t:rdg wit="W2 W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W2 W3 W1"/>
                            <t:rdg wit="W4">ሰላኪ፡ እንተ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1"/>
                            <t:rdg wit="W2">ሰላም፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1"/>
                            <t:rdg wit="W2">ኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W1">አንተ፡</t:lem>
                            <t:rdg wit="W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W4 W1">ወለድኪ፡</t:lem>
                            <t:rdg wit="W2">ወለድኪ፡ ፈጣሬ፡</t:rdg>
                            <t:rdg wit="W3"/>
                        </t:app><t:app>
                            <t:lem wit="W4 W1">ፈጣሬ፡</t:lem>
                            <t:rdg wit="W2 W3"/>
                        </t:app><t:app>
                            <t:lem wit="W1">ሰላም፡</t:lem>
                            <t:rdg wit="W2 W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W1"/>
                            <t:rdg wit="W2 W3 W4">ዘምስለ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W3 W1"/>
                            <t:rdg wit="W4">ዝማረ፡ እስግድ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W4 W1"/>
                            <t:rdg wit="W2 W3">ዝማሬ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W3 W1"/>
                            <t:rdg wit="W4">ለኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W4 W1"/>
                            <t:rdg wit="W2">እስግድ፡</t:rdg>
                            <t:rdg wit="W3">ንሰግድ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W1">ለኪ።</t:lem>
                            <t:rdg wit="W3"/>
                            <t:rdg wit="W4">ለስይትን በብ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1">ዘምስለ፡ ዝማሬ፡</t:lem>
                            <t:rdg wit="W2 W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1"/>
                            <t:rdg wit="W2">መጽሐፈ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1">ንሰማድ፡</t:lem>
                            <t:rdg wit="W2">ተአምርኪ፡</t:rdg>
                            <t:rdg wit="W3 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W1">ለኪ፡ ሶበ፡</t:lem>
                            <t:rdg wit="W2 W4"/>
                        </t:app><t:app>
                            <t:lem wit="W2 W3 W1">ይትነበብ፡</t:lem>
                            <t:rdg wit="W4"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1">መጽሐፈ፡</t:lem>
                            <t:rdg wit="W2"/>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1"/>
                            <t:rdg wit="W2">ለለወትረ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1">ተአምርኪ።</t:lem>
                            <t:rdg wit="W2"/>
                            <t:rdg wit="W3 W4">ተአምርኪ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W3 W4 W1">በሰላም፡</t:lem>
                            <t:rdg wit="W2"/>
                        </t:app><t:app>
                            <t:lem wit="W1"/>
                            <t:rdg wit="W2 W3 W4">ኪያነ፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1"/>
                            <t:rdg wit="W2">ባርኪ፡ ሰላመ፡ ባርኪ፡</t:rdg>
                            <t:rdg wit="W3 W4">ባርኪ።</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W2 W1">ኪያነ፡</t:lem>
                            <t:rdg wit="W3"/>
                            <t:rdg wit="W4">ወኢትርስእኒ፡ ለገብርኪ፡ ኃጥእ፡ ወአባሴ፡ ዘወልደ፡ ማርያሞ፡ ጭማር፡ አቡነ፡ ትክለ፡
                                ሃይማሮት፡ ወልደሙ፡ ለአቡነ፡ ዘገብርኤል፡ ለዓለመ፡ ንለም፡ አሜን፡ ወአሜን፡</t:rdg>
                        </t:app><t:app>
                            <t:lem wit="W1">በርኪ። ወላዲተ፡ አምላክ፡ ማርያም፡ እንበለ፡ ሰብሳብ፡ ወሩካቤ፡ በይነ፡ ዘዓቀ
                                <t:gap reason="illegible" unit="chars" quantity="2"/>ብኩ፡ ለኪ፡
                                ንስቲተ፡ ቃለ፡ ይባቤ፡ ፈትዊ፡ እሙ፡ በረከተ፡ አፉኪ፡ ሙሐዘ፡ ከርቤ። ለነዳይ፡ ብእሲ፡ ወለዘረከቦ፡
                                ምንደቤ፡ ኅብስተከ፡ ፈትት፡ ኢሳይያስ፡ ይቤ።</t:lem>
                            <t:rdg wit="W2">ኅቡረ።</t:rdg>
                            <t:rdg wit="W3 W4"/>
                        </t:app>
                    </t:ab>
                </t:div>

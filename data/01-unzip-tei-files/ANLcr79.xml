                    <msContents>
                        <summary/>
                        
                        
                        
                        <msItem xml:id="ms_i1">
                            <locus from="4r" to="65r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5354Mashaf">Maṣḥafa ʾahagʷǝlota ḥasat</title>
                            <textLang mainLang="am"/>
                            <incipit type="inscriptio" xml:lang="am">መጽሐፈ፡ አኅጕሎተ፡ 
                                ሐሰት፡ ዘተጽሕፈ፡ በእደ፡ አባ፡ ተክለ፡ ሃይማኖት፡ ወልደ፡ ተክለ፡ እግዚእ፡ ካቶሊካዊ፡ ዘማርያም፡ ሰዊቶ።
                            </incipit>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="4r" to="11v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT5354Mashaf#PartOne">Maṣḥafa ʾahagʷǝlota ḥasat, Part 1</title>
                                <incipit xml:lang="am">
                                    እኔ፡ እግዚአብሔር፡ በጽድቅ፡ ጸራሁህ፡ እጀህንም፡ ያዝሁህ፡ ጠበቅሁህም፡ ለሕዝብም፡ ኪዳን፡ አደረግሁህ፡ ለአህዛብም፡ 
                                    ብርሃን። የዕውርን፡ ዓይን፡ ትከፍት፡ ዘንድ፤ የተጋዘውንም፡ ትከፍት፡ ዘንድ፡ የተጋዘውንም፡ ከግዞት፡ ቤት፡ ታወጣ፡ ዘንድ፡ 
                                    ከግዞት፡ ቤት፡ ጨለማ፡ ቤት፡ የተቀመጡት፡
                                </incipit>
                                
                            </msItem>
                            

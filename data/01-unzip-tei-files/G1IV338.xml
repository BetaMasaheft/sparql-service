                    <msContents>
                        <summary>Amharic commentary to the Book of Psalms. The left-hand column is
                            the Ge'ez text, the right-hand column is the commentary to it in
                            Amharic. This type of commentary is called andemta. Images no.
                            014-108.On the right-hand folio on the image no. 108 starts another text
                            i.e. Wǝddase Maryam ("The praise of Mary"). It finishes at image no.
                            113</summary>
                        <msItem xml:id="ms_i1">
                            <title ref="https://betamasaheft.eu/LIT6368PsaltComm">Amharic commentary to the Book of Psalms, Canticles and Song of Songs</title>
                            <textLang xml:lang="gez"/>
                            <textLang xml:lang="am"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title>Wǝddase Maryam</title>
                            <textLang xml:lang="gez"/>
                        </msItem>
                    </msContents>

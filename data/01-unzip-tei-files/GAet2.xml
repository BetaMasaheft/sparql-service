                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="18v">Fols 1r–18v</locus>
                            <title ref="https://betamasaheft.eu/LIT2835RepCh119">Image of Michael the Archangel</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ፡ ወልደ፡ ያሬድ፡ ሄኖክ፡ በከመ፡ ጸሐፈ፡ ሶበ፡ እጼውዕ፡ ስመከ፡ ከሲትየ፡ አፈ፡ ረዳኤ፡ ምንዱባን፡ ሚካኤል፡ በከመ፡ ታለምድ፡ ዘልፈ፡ ለረዲኦትየ፡ ነዓ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="19r" to="28v">Fols 19r–28v</locus>
                            <title ref="https://betamasaheft.eu/LIT2965RepCh246">Image of Gabriel the Archangel</title>
                            <incipit xml:lang="gez">ሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአእረፈ፡ ከመ፡ እዜኑ፡ ሕዳጠ፡ ወአኮ፡ ትሩፈ፡ እግዚአብሔር፡ ሀበኒ። ሲሳየ፡ ልቡና፡ መጽሐፈ፡ ወአፉየ፡ ሙሴ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="29r" to="35r">Fols 29r–35r</locus>
                            <title ref="https://betamasaheft.eu/LIT2927RepCh208">Image of St. George </title>
                            <incipit xml:lang="gez">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ ቡሩክ፡ በላዕለ፡ ድንግል፡ ቅድስት፡ ወመስቀሉ፡ [ለ]ክርስቶስ፡ አምላክ፡ ገባሬ፡ መንክራት፡ ጊዮርጊስ፡ በዓውደ፡ ዱድያኖስ፡ ምዑክ፡ አጽራርየ፡ እለ፡ ተንሥኡ፡ በነገረ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="35v" to="47v">Fols 35v–47v</locus>
                            <title ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                            <incipit xml:lang="gez">በእንተ፡ ትኅምረተ፡ (sic) ኅቡአት፡ ቅድመ፡ ዘትትነገር፡ እምጵርስ፡ ፎራ፡ ለምእመናን፡ ኅቡአት፡ ትእምርተ፡ (sic) ኅቡአትሰ፡ ከመዝ፡ ንግር፡ ዘቅድመ፡ ሀሎ፡ ወይሄሉ፡ ዘመጽአ፡ ዘሐመ፡ ወሞተ፡ ወተቀብረ።</incipit>
                        </msItem>
                    </msContents>


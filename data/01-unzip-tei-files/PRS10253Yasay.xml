         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ያሳይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yāsāy</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">ይሳይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Yǝsāy</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="birth">አሳይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">ʾAsāy</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
              
               <t:floruit notBefore="1300" notAfter="1399">He was a saintly monk and contemporary of <t:persName ref="https://betamasaheft.eu/PRS1854Amdase">ʿAmda Ṣǝyon I</t:persName>. 
                  He is considered to have been the founder of the monastery of
                  <t:placeName ref="https://betamasaheft.eu/LOC4518Mandab">Mandābbā Madḫāne ʾAlam</t:placeName>.
                  He was one of the seven disciples of  
                  <t:persName ref="https://betamasaheft.eu/PRS6445Madhanin">
                     <t:roleName type="title">ʾabuna</t:roleName> Madḫānina ʾƎgziʾ</t:persName>.
                  He was the spritual father of <t:persName ref="https://betamasaheft.eu/PRS7598Nob">Nob</t:persName>, <t:persName ref="https://betamasaheft.eu/PRS3895estifano">ʾƎsṭifanos of Maqdasa Māryām</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/PRS8752senana">Ṣǝnʿana Krǝstos of Dabra Zayt</t:persName> and some others.</t:floruit>
             
               </t:person>  
               
         </t:listPerson>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እወጥን፡ አንሰ፡ መልክአ፡ ውዳሴከ፡ ወማሕሌተከ፡ አሐሊ፨</l>
                  <l n="2">ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በረድኤቶሙ፡ ከሃሊ፨</l>
                  <l n="3">በርተሎሜዎስ፡ ጻድቅ፡ ወመትልወ፡ ኢዮብ፡ ተጋዳሊ፨</l>
                  <l n="4">እመ፡ ይፈቅድ፡ ፀር፡ ይጽብአኒ፡ ወአህጕሎትየ፡ ይሔሊ፨</l>
                  <l n="5">በእንቲአየ፡ አስተምሕር፡ ወጸሊ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምከ፡ ቅዱስ፨</l>
                  <l n="2">ዘተጸውዐ፡ ቀዳሚ፡ በአፈ፡ ነባቢ፡ መንፈስ፨</l>
                  <l n="3">በርተሎሜዎስ፡ ኅሩይ፡ እምነ፡ ማሕፀን፡ ወከርሥ፨</l>
                  <l n="4">አመ፡ ቆምከ፡ ጊዜ፡ ጸሎት፡ ለአርእዮ፡ ትእምርት፡ ሐዲስ፨</l>
                  <l n="5">ሐሊበ፡ ልቡና፡ አንቃዕከ፡ እምኰኵሕ፡ ይቡስ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ዘያገኒ፡ ኵሎ፨</l>
                  <l n="2">እንዘ፡ መንገሌሁ፡ ይስሕብ፡ ወያረውጽ፡ በተሣህሎ፨</l>
                  <l n="3">በርተሎሜዎስ፡ ወልድከ፡ እስመ፡ እጼው፡ በተወክሎ፨</l>
                  <l n="4">ጸሐፍ፡ በስምከ፡ ስመ፡ ዚአየ፡ በመትሎ፨</l>
                  <l n="5">በሰሌዳ፡ ንጹሕ፡ ጽሑፍ፡ ዘሀሎ፨</l>
               </lg>
            </div>
         </div>

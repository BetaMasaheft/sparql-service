                                <msItem xml:id="p1_i1">
                            <locus from="1r"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/NAR0005calend">Calendar of saint commemorations</title>
                            <textLang mainLang="gez"/>
                                    <note>The prefatory hymn is incomplete at the beginning, and 
                                        the end is missing, the text ends abruptly on 16th Ḥamle.</note>
                                    <incipit xml:lang="gez"><locus from="2r"/><hi rend="rubric">በምሕረቱ፡ ለአምላከ፡</hi> ሰላም፡
                                        <hi rend="rubric"><date ref="ethiocal:Maskaram1">ሠረቀ፡ መስከረም። አመ፡ ፩።</date></hi> ኦአምላከ፡
                                        <hi rend="rubric">ዮሐንስ፡ መጥምቅ፡</hi> ወሜልዮስ፡ ጳጳስ፤ ወበርተሎሜዎስ፡ ሐዋርያ፡ ወኢዮብ፡ ዕጉሥ፤
                                        ወራጉኤል፡ መልአክ፡ ወሄኖክ፡ ነቢይ፡ ወመልኪ። <date ref="ethiocal:Maskaram2"><hi rend="rubric">አመ፡</hi> ፪። </date>
                                    ኦአምላከ፡ ደስያ፡ ሰማዕት፤ ዲድሞስ፡ ወመሪና፤ ወዲዮስ፡ ቆሮስ። ወዮልዮስ።</incipit>

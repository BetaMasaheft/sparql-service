                                <item xml:id="a2">
                                    <locus from="151ra" to="151rb"/>
                                    <desc type="GuestText"/>
                                    <q xml:lang="gez">
                                        <seg part="I">በአክናፈ፡ መላእክቲሁ፡ ብሩሃን፡ ይከልለነ፡ እግዚአብሔር   ፡ <add place="above">አ</add>፨ በሐፁረ፡ መስቀሉ፡ ቅዱስ፡ ይኅፅረነ፡ እ<hi rend="ligature">ግዚ</hi>አብሔር፡ አ፨</seg> 
                                        <seg part="F">ወለለ ፩፩ ፍኖቶ፡ ይሠርኅ፡ ወያሤ<cb n="b"/>ኒ፡ እግዚአብሔር፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፡ ለይኵን፡ </seg> 
                                    </q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#2vc"/>
                                    <desc type="OwnershipNote"/>
                                    <q xml:lang="gez">
                                        ዝመጽሐፍ፡ ዘ<persName ref="https://betamasaheft.eu/PRS13826TaklaM">አልፋስክድ፡ ተክለ፡ ማርያም፡</persName> ዘአጥረዮ፡ በንዋዩ፡
                                    </q>
                                </item>
                                
                                <item xml:id="a4">
                                    <locus target="#147vc"/>
                                    <desc type="OwnershipNote"/>
                                    <q xml:lang="gez">
                                        ዝመጽሐፍ፡ ዘአልፋስክድ፡ ዘውእቱ፡ <persName ref="https://betamasaheft.eu/PRS13826TaklaM">ተክለ፡ ማርያም፡</persName> ወአቡሁ፡ <persName ref="https://betamasaheft.eu/PRS13828Nacco">ነጮ፡ ግብረ፡ አምላክ፡</persName>
                                        ወእሙ፡ <persName ref="https://betamasaheft.eu/PRS13829Webit">ዉቢት፡ ታዕካ፡ ድንግል፡</persName> ወአኃዊሁ፡ እሸቴ፡ ንዝሕተ፡ ደም፡ ጥዱ፡ ጅሩ፡ ዘአጥረዮ፡ በንዋዩ፡ ዘሰረቆ፡ ወዘፈሐቆ፡ ውጉዘ፡ ይኩን።
                                    </q>
                                </item>
                            </list>
                            

                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">         
                     </handNote>
                  </handDesc>
               </physDesc>
               <history>
                   
                  <provenance>This manuscript is part of a small collection of Islamic manuscripts held at Eton College Library, which are not part of the separate ‘Pote Collection’. 
                     (The Pote Collection was given in 1788 by Edward Ephraim Pote to Eton College and King’s College, Cambridge and is now held on loan at the Cambridge University Library).
                  </provenance>
                  
               </history>
               <additional>
                  <adminInfo>

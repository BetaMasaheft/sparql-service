               <msContents>
                  <summary>
                     1 copy of an Ethiopian hymn to the Virgin Mary in Geez, on vellum.
                  </summary>
                  <msItem xml:id="ms_i1"> 

                     <title>Mahleta sege - Canticle of the Flowers</title>
                     <textLang mainLang="gez">Geez</textLang>  
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc defer="parchment">                        

               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                        <locus from="3r" to="48r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                        <textLang mainLang="gez"/> 
                     <note>
                        <locus target="#3"/> is written in a hand different from that of the remainder of the manuscript,
                        <ref type="hand" target="#h2"/>.
                        Only the upper part of <locus target="#3v"/> is written on.</note>
                     <note>The chapter division is often different from that in printed texts, e.g. beginning of chapter 4 on
                     <locus target="#8r"/> coincides with 3:22 in printed versions.</note>
                     <note>The Gospel of John is preceded by 5 lines of blessings for the owner, <persName role="owner" ref="https://betamasaheft.eu/PRS11700Fileppos">Filǝṗṗos</persName>.</note>
                     </msItem>
               
                  </msContents>
                     

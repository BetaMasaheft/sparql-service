                            <incipit xml:lang="gez">
                                <locus from="1ra" to="1rb"/>
                                <hi rend="rubric">በስመ፡ እግዚአብሔር፡፡ ሥሉስ፡ ዘእን</hi>በለ፡ 
                                ፍልጠት፡ ወአሐዱ፡ በጽምረት፡ ኅቡረ፡ 
                                <hi rend="rubric">ህላዌ፡ ዕሩየ፡ መለኮት፡ ዘአሐተ፡ ይሰገድ፡</hi>

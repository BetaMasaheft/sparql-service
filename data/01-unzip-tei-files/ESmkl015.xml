                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine</seg>
                        <seg type="ink">Black, red</seg>
                        Scribe: Za-Walda Māryām. The Ms. is
                        written in the same hand as MKL-016 (with the name of the scribe mentioned),
                        QSM-001 and QSM-007.<date>First half of the 18th century</date>
                        <seg type="rubrication">Nomina sacra; name of the protagonist; name of the
                           donor; two initial lines on the incipit page of Texts I and II-1; incipit
                           of Text III and sections; elements of the punctuation signs and of the
                           text dividers; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#3v">Fol. 3v: </locus>
                        <desc>Heavenly Priests (four figures).</desc>Legend: ካሕናተ፡ ሰማይ፡ "Priests of
                        Heaven". 
 Painted on unruled leaf.
 The miniature is protected by a
                        textile curtain.</decoNote>
                     <decoNote type="miniature" xml:id="d2">
                        <locus target="#">Fol.4r: </locus>
                        <desc>Christ in Majesty.</desc>Legends: ገጸ፡ ሰብእ፡ "Face of a man". እግዚአብሔር፡
                        "Lord". ገጸ፡ ንስር "Face of an eagle". ገጸ፡ አንብሳ "Face of a lion". ገጸ፡ ላሕም "Face
                        of an ox".
 Painted on unruled leaf.
 The miniature is protected by
                        a textile curtain.</decoNote>
                     <decoNote type="miniature" xml:id="d3">
                        <locus target="#14v">Fol. 14v: </locus>
                        <desc>St. Michael.</desc>Legend: ቅዱስ፡ ሚካኤል፡ "Saint Michael". 
 A note,
                        written in the right upper margin, states that Diyonasyos has commissioned
                        the miniature.
 All three miniatures have been executed by the same
                        painter as the miniatures in Ms. MKL-016, fols. 126v-127r.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">Monthly readings are indicated by the names of the
                              feast and months, written in red ink, in the upper margin: በ፬፡ እንስሳ፡
                              ምንባብ: <locus target="#5ra">fol. 5ra</locus>b በኀዳር፡ ምንባብ: <locus target="#15ra">fol. 15ra</locus>b በሰኔ፡ ምንባብ: <locus target="#19vb">fol. 19vb</locus> በነሐሴ፡ ምንባብ: <locus target="#26rb">fol.
                                 26rb</locus>.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Erasures are marked with thin lines: fols. 6rb, 8vab, 9rb, 12vab, 14ra, 19rb, 22rb, 25ra. - Omissions were inserted interlineally: fols. 7ra, 12vb, 24ra, 27rb.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards.
 Two pairs of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes and tears are visible in the
                           centre fold of the quires, close to the head and the tail of the
                           codex.
 Quires A and B are reinforced with a parchment
                           guard.</decoNote>
                     </binding>
                  </bindingDesc>

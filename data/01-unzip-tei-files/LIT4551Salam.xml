            <div type="bibliography">
                
                <listBibl type="editions">
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>            
            </div>
                
        <div type="edition">
            <div type="textpart" subtype="incipit" xml:lang="gez">
                <note>The following incipit follows <ref type="mss" corresp="https://betamasaheft.eu/BDLaethe4">Oxford, Bodleian Library, Bodleian Aeth. e. 4</ref>.</note>
                <ab>
                    አዚዝ፡ ላሊበላ፡ ዓለመ፡ ዘትቀኒ።
                    ሰላም፡ ለዝክረ፡ ስምከ፡ ከመ፡ ቃለ፡ ማዕነቅ፡ ድምፅ።
                </ab>
            </div>
        </div>
            <div type="edition" xml:lang="gez"><note>After <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">እስመ፡ ብዙኃን፡ አኃው፡ እለ፡ እሙንቲ፡ ቀደሙኒ፨</l>
                        <l n="2">አኀዙ፡ ይንግሩ፡ ዝክረ፡ ስምከ፡ ዝስይሤኒ፨</l>
                        <l n="3">አነኒ፡ ማሕሌተ፡ መልክእከ፡ ይእዜኒ፨</l>
                        <l n="4">ከመ፡ እጽሐፍ፡ በበ፡ ምትልው፡ ሊተኒ፡ ረትአኒ፨</l>
                        <l n="5">ዐዚዝ፡ ላሊበላ፡ ዓለመ፡ ዘትቀኒ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ከመ፡ ቃለ፡ ማዕነቅ፡ ድሙጽ፨</l>
                        <l n="2">በአህጉር፡ ወዓፅ፨</l>
                        <l n="3">ላሊበላ፡ ፍቅርከ፡ ውስተ፡ ልብየ፡ ሕኑጽ፨</l>
                        <l n="4">ይሱቀኒ፡ አድኅኖትከ፡ እምነ፡ ትንታኔ፡ ወዳኀፅ፨</l>
                        <l n="5">ወይሂጶ፡ ለፀርየ፡ ጸሎትከ፡ ሐጽ፨</l>
                    </lg>
                    <lg type="stanza" n="45">
                        <l n="1">ሰላም፡ ለመቃብሪከ፡ በዐጸደ፡ ቅድስት፡ ጎልጎታ፨</l>
                        <l n="2">ለመቃብረ፡ ክርስቶስ፡ ካልእታ፨</l>
                        <l n="3">ላሊበላ፡ በለዝ፡ ለጥበብ፡ ዐምደ፡ ቤታ፨</l>
                        <l n="4">እሞተ፡ ጌጋይ፡ ከመ፡ ትትነሣእ፡ ሕያውታ፨</l>
                        <l n="5">ለነፍስየ፡ በላ፡ ተንሥኢ፡ ጣቢታ፨</l>
                    </lg>
                    <lg type="stanza" n="46">
                        <l n="1">እምትራፈ፡ ገድልከ፡ ንስቲተ፡ ፍተ፡ ጻማከ፡ እዜኑ፨</l>
                        <l n="2">ውዱሰ፡ ምግባር፡ ላሊበላ፡ ለእግዚአብሔር፡ ዐርከ፡ ምእመኑ፨</l>
                        <l n="3">በምጽዋት፡ ፈጸምከ፡ ንዋየ፡ ለእግርከ፡ እስከ፡ አሣዕኑ፨</l>
                        <l n="4">እንዘ፡ ንጉሥ፡ በሥልጣኑ፡ ወመስፍን፡ በምኵናኑ፨</l>
                        <l n="5">ዘኢያትረፈ፡ ልብሰ፡ ለበድኑ፡ ከማከ፡ መኑ፨</l>
                    </lg>
                </div>
            </div>
        </body>

        <body>
            <div type="bibliography">
                <bibl corresp="http://zotero.org/groups/358366/items/KSUKVXHQ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1949PriereFalacha"/><title level="a">Sur une prière 'falacha' publiée par c. conti rossini dans les appunti di storia e letteratura falascià</title><title level="j">Rassegna di Studi Etiopici</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Stefan</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Strelcyn</t:surname></author><date>1949</date><biblScope unit="volume">8</biblScope><biblScope unit="page">63-82</biblScope><note type="url">http://www.jstor.org/stable/41460245</note><citedRange unit="page">64-75</citedRange></bibl>
            </div>
            <div type="bibliography">
                
            </div>
            <div type="edition">
                <note>Incipits and order of the prayers are taken from <ref type="mss" corresp="https://betamasaheft.eu/BLorient12859">BLorient12859</ref></note> 
                <div type="textpart" xml:id="Moses">
                    <label>Prayer of Moses</label>
                    <note>Thematically related to <ref type="work" corresp="https://betamasaheft.eu/LIT2277salotu">The Prayer of Moses</ref>, <ref type="work" corresp="https://betamasaheft.eu/LIT2278salota">Second Prayer of Moses</ref> 
                        and <ref type="work" corresp="https://betamasaheft.eu/LIT2703salota">The Third Prayer of Moses</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ሙሴ፡ ገበርከ፡ እንዘ፡ ይብል፡ ጋዲን፡ ፈሊዖ፡ <gap reason="ellipsis"/></q>
                </div>
                <div type="textpart" xml:id="Joshua">
                    <label>Prayer of Joshua</label>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ኢያሱ፡ ወልደ፡ ነዌ፡ ውስተ፡ ሀገረ፡ ገባዖን፡ እንዘ፡ ይብል፡ ደርታን፡</q>
                </div>
                <div type="textpart" xml:id="Elijah">
                    <label>Prayer of Elijah</label>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ኤልያስ፡ ስመከ፡ እንዘ፡ ይብል፡ አቅርያኖስ፡</q>
                </div>
                <div type="textpart" xml:id="Daniel">
                    <label>Prayer of Daniel</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT2250salota">Ṣalota Dānǝʾel nabiy sǝbḥat za-ʾǝm-ʾAzāryā</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ <supplied reason="omitted" resp="PRS8999Strelcyn">ጸርሐ፡ </supplied>ዳንኤል፡ ስመከ፡ እንዘ፡ ይብል፡ 
                        ዝራኤል፡</q>
                </div>
                <div type="textpart" xml:id="Manasseh">
                    <label>Prayer of Manasseh</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT2265salota">The Prayer of Manasseh</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ምናሴ፡ ስመከ፡ እንዘ፡ ይብል፡ ቀለኤል፡</q>
                </div>
                <div type="textpart" xml:id="ThreeChildren">
                    <label>Prayer of the Three Holy Children in the Furnace (ʾĀnānyā, ʾĀzāryā and Misāʾel)</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT2250salota">Ṣalota Dānǝʾel nabiy sǝbḥat za-ʾǝm-ʾAzāryā</ref>, <ref type="work" corresp="https://betamasaheft.eu/LIT2271salota">Ṣalota śalastu daqiq</ref> or
                        <ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa">Third Song of the Three Youths in the Furnace</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሑ፡ አናንያ፡ ወአዛርያ፡ ወሚሳኤል፡ እንዘ፡ ይብሉ፡ ዳፋኤል፡</q>
                </div>
                <div type="textpart" xml:id="David">
                    <label>Prayer of David</label>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ስመከ፡ ዳዊት፡ እንዘ፡ ይብል፡ በለማዊፒሲል፡</q>
                </div>
                <div type="textpart" xml:id="Hezekiah">
                    <label>Prayer of Hezekiah</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT2258salota">The Prayer of Hezekiah, King of Judah</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ሕዝቅያስ፡ ስመከ፡ እንዘ፡ ይብል፡ ወገላውዮስ፡</q>
                </div>
                <div type="textpart" xml:id="Jonah">
                    <label>Prayer of Jonah</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT2274salota">The Prayer of Jonah</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ስመከ፡ <sic>ዳዊት፡</sic> ዮናስ፡ እንዘ፡ ይብል፡ ዳላዊ፡</q>
                </div>
                <div type="textpart" xml:id="Jeremiah">
                    <label>Prayer of Jeremiah</label>
                    <note>Thematically possibly related to <ref type="work" corresp="https://betamasaheft.eu/LIT1753Lament">Lamentations</ref>.</note>
                    <q xml:lang="gez">ወሶበ፡ ጸርሐ፡ ኤርምያስ፡ ስመከ፡ እንዘ፡ ይብል፡ <gap reason="ellipsis"/> ገደላፊል፡</q>
                </div>
            </div>
        </body>
    </text></TEI>
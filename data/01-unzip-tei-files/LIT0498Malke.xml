      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0498</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በጽዋዐ፡ ጥበብ፡ እሳተ፡ ከመ፡ ራጉኤል፡ አስተዮ፨</l>
                  <l n="2">ለዘተሳተፈ፡ ዕዝራ፡ ከመ፡ ሱቱኤል፡ ተሰምዮ፨</l>
                  <l n="3">ነበልባለ፡ እሳት፡ ሴት፡ ድርሳነ፡ መልክእከ፡ ለአሠንዮ፨</l>
                  <l n="4">እሳትየኒ፡ ወይነ፡ ሰማይ፡ ለምሥጢረ፡ ነድ፡ እርአዮ፨</l>
                  <l n="5">ወሀሊበ፡ መዝሙር፡ ጽዕድወ፡ ዘዳዊት፡ ሐለዮ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ፀሓየ፡ ፍሥሓ፡ ስቁል፨</l>
                  <l n="2">በኍልቈ፡ ፊደላት፡ ክልኤ፡ አየራተ፡ ስሙ፡ ለቃል፨</l>
                  <l n="3">ለክብረ፡ በአዓልከ፡ ሴት፡ በአተ፡ ማርያም፡ ድንግል፨</l>
                  <l n="4">ናሁ፡ ትዜምር፡ ምስለ፡ ወልዳ፡ አርአያ፡ ሱራፌል፡ ወኪሩቤል፨</l>
                  <l n="5">እንዘ፡ ትብል፡ ሃሌ፡ ህሉያ፡ በዜማ፡ ልዑል፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ውስተ፡ ሰማያት፡ ሀገር፨</l>
                  <l n="2">አመ፡ ዕሥራ፡ ወረቡዑ፡ ለወርኀ፡ ኅዳር፨</l>
                  <l n="3">ካህናተ፡ ሰማይ፡ ቡሩካን፡ አጠንተ፡ ግሩም፡ መንበር፨</l>
                  <l n="4">ተበሀሉ፡ ሴት፡ ቢዜ፡ ሞትከ፡ በብሂለ፡ ዘዳዊት፡ መዝሙር፨</l>
                  <l n="5">አማን፡ ሞተ፡ ጻድቅ፡ ከመዝ፡ ክቡር፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ዘይስእሉ፡ ኀቤሃ፨</l>
                  <l n="2">ሕሙማነ፡ ነፍስ፡ ሕይወተ፡ ወትኩዛነ፡ ልብ፡ ፍሥሓ፨</l>
                  <l n="3">ሴት፡ ጴጥሮስ፡ ለመንግሥተ፡ ሰማይ፡ ዴዴሃ፨</l>
                  <l n="4">ንሥሓ፡ ሀበኒ፡ ወጸግወኒ፡ ዕድሜ፡ መዋዕል፡ ብዙኀ፨</l>
                  <l n="5">እስመ፡ ድኅረ፡ ሞቱ፡ ለሰብእ፡ አልቦቱ፡ ንሥሓ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ካህናተ፡ ሰማይ፡ ሰብሑ፡ ወሰመዩ፡ በመለኮተ፨</l>
                  <l n="2">ኢብሂለ፡ ቀትር፡ ወሌሊት፡ እንበለ፡ ያዕርፉ፡ ምንተ፨</l>
                  <l n="3">ሠሚረከ፡ ሴት፡ አምኃ፡ ከናፍርየ፡ ስብሐተ፨</l>
                  <l n="4">በከንቱ፡ ተወከፍ፡ ወአዕርግ፡ ሰማያተ፨</l>
                  <l n="5">በቀለመ፡ ብሩር፡ ወወርቅ፡ ጽሒፈከ፡ ዘንተ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary>Miracles of Mary</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="38r" facs="003">Fols 1r–38r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="1r" to="8v" facs="003">Fols 1r–8v</locus><title>Introduction to the Miracles of Mary, <foreign xml:lang="gez">መቅድመ ተአምረ ማርያም ዘሙዓልቃ</foreign></title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="9r" to="38r" facs="011">Fols 9r–38r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Thirteen Miracles of Mary</note>
                </msItem>
              </msItem>
                  <msItem xml:id="ms_i2"><locus from="39r" to="52v" facs="041">Fols 39r–52v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3035RepCh315">Hymn to
                                                  Galāwdewos</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>beginning: <foreign xml:lang="gez">ናሁ ተወጥነ ለመረካዕከ ሰላሙ</foreign></note>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="55r" to="63v" facs="057">Fols 55r–63v</locus><title>Prayer to Saint Mary imploring her to bless the speaker in the various ways in which she has blessed others like Ephrem the Syrian, a priest from Rome</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i4"><locus from="65r" to="70r" facs="067">Fols 65r–70r</locus><title>Shorter Introduction to the Miracles of Mary, <foreign xml:lang="gez">ስምዑ እነግረክሙ</foreign></title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i5"><locus from="70v" to="75r" facs="073">Fols 70v–75r</locus><title>Prayer to Saint Mary on behalf of those who wrote the Miracles of Mary</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i6"><locus from="75r" facs="077"> f. 75r, bottom of second column</locus><title>Chant to be recited after the reading of the Miracles of Jesus</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i7"><locus from="75v" to="84v" facs="078">Fols 75v–84v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Two Miracles of Jesus Christ (beginning at 73v and 83v)</note>
                </msItem>
                  <msItem xml:id="ms_i8"><locus from="88r" to="88v" facs="090">Fols 88r–88v</locus><title>Chant to be recited before the reading of the miracle of Jesus</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>

      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0478</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትክሙ፡ ወለልደትክሙ፡ እማሕፀን፨</l>
                  <l n="2">በሕገ፡ ሩካቤ፡ ሥሩዕ፡ ወበግዕዘ፡ ንኡስ፡ ሕፃን፨</l>
                  <l n="3">ደቂቀ፡ እንድርያስ፡ ሰማዕት፡ ጽዱላነ፡ ምግባር፡ ወሥን፨</l>
                  <l n="4">አብርሁ፡ አዕይንተ፡ ልብየ፡ በአእምሮ፡ መንፈስ፡ ብርሃን፨</l>
                  <l n="5">እምዜና፡ ዝክርክሙ፡ ኅዳጠ፡ እትናገር፡ በልሳን፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ እምጸቃውዐ፡ መዐር፡ ጥዑም፨</l>
                  <l n="2">ወለሥዕርትክሙ፡ ሰላም፡ ዘሥነ፡ ራእዩ፡ አዳም፨</l>
                  <l n="3">ጥቡዓነ፡ ልብ፡ ሰማዕት፡ ዘፍናዊክሙ፡ ሰላም፨</l>
                  <l n="4">ሶበ፡ ሰማዕክሙ፡ ዜና፡ ጽድቁ፡ ለመምህረ፡ ቀኖና፡ ወጾም፨</l>
                  <l n="5">ከመ፡ ትንበሩ፡ ህየ፡ ወፃእክሙ፡ እምዓለም፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለመቃብሪክሙ፡ ለደብረ፡ ጽጌ፡ በዐጸዳ፨</l>
                  <l n="2">እንተ፡ በላዕሌሃ፡ ወረደ፡ እክለ፡ አርያም፡ ጸዐዳ፨</l>
                  <l n="3">ዓዲ፡ ይውሕዝ፡ ፈለገ፡ ዮርዳኖስ፡ በዐውዳ፨</l>
                  <l n="4">ተሐበዩኒ፡ ሰማዕት፡ አመ፡ ዕለተ፡ በቀል፡ ወፍዳ፨</l>
                  <l n="5">ወአመ፡ ኢታድኅን፡ እም፡ ዘወለደት፡ ወልዳ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">በዓሥር፡ ዕለት፡ አርእስቲክሙ፡ ሶበ፡ ተወቅየ፨</l>
                  <l n="2">እንድርያስ፡ ብፁዕ፡ በከመ፡ ተነበየ፨</l>
                  <l n="3">መስፍነ፡ ሀገር፡ መጽአ፡ ሰሚዖ፡ በህየ፨</l>
                  <l n="4">አብድንተ፡ ሥጋክሙ፡ ሰማዕተ፡ ውስተ፡ ከርሠ፡ ምድር፡ ወደየ፨</l>
                  <l n="5">ወመቃብሪክሙኒ፡ አሥረጸ፡ መክርየ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">አምኃ፡ ማሕሌት፡ አቅረብኩ፡ ለመልክእክሙ፡ በጽዋዔ፨</l>
                  <l n="2">ኀይለ፡ እግዝእትየ፡ ድንግል፡ እንዘ፡ ይከውነኒ፡ ረዳኤ፨</l>
                  <l n="3">ተወከፉኒ፡ ሰማዕት፡ ምስለ፡ ያዕቆብ፡ ቀርነ፡ ጉባኤ፨</l>
                  <l n="4">ወአሠርግዉኒ፡ ልብሰ፡ ከብካብ፡ ጊዜ፡ ይከውን፡ ውዋዔ፨</l>
                  <l n="5">ከመ፡ ዕራቅየ፡ ኢይቁም፡ በሐዳስ፡ ትንሣኤ፨</l>
               </lg>
            </div>
         </div>
      </body>

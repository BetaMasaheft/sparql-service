                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="2" to="143"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1295Dersan">ድርሳነ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡</title>
                            <colophon xml:lang="gez" xml:id="coloph1">
                                <locus target="#1"/>
                                <note>The colophon states that the manuscript was written in Tāḫśāś <date calendar="ethiopian">1833 CE</date>, in <placeName ref="https://betamasaheft.eu/LOC1465Ankoba">Ankobär</placeName>, during the reign of 
                                    king <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śāhla Śǝllāse</persName>
                        </note>
                            </colophon>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="2" to="11"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1637Homily">Homily by Timothy of Alexandria for Ḫǝdār</title>
                                <incipit xml:lang="gez">
                                    <locus target="#2"/>
                                    ዝንቱ፡ ድርሳን፡ ዘደረሰ፡ አባ፡ ደማቴዎስ፡ ሊቀ፡ ጳጳሳት፡ ዘለእስክንድርያ፡ ዘይትነበብ፡ በበዓሉ፡ ለሊቀ፡ መላእክት፡ ወክቡር፡ ቅዱስ፡ ሚካኤል፡ አመ፡ ፲ወ፪ለወርኀ፡ ኅዳር፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="11" to="19"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3958Homily">Homily for Tāḫśāś</title>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="19" to="32"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3959Homily">Homily by Epiphanius of Cyprus for Ṭǝrr</title>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="32" to="38"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3960Homily">Homily for Yakkātit</title>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="38" to="63"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3961Homily">Homily by a patriarch of Antiochia for Maggābit</title>
                                <incipit xml:lang="gez">
                                    <locus target="#38"/>
                                    ድርሳን፡ ዘደረሰ፡ ሊቀ፡ ጳጳሳት፡ ዘአንጾኪያ፡ በዕለተ፡ ቅዱስ፡ ሚካኤል።
                                </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.6">
                                <locus from="63v" to="74"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3962Homily">Homily by Yoḥannǝs the Orthodox for Miyāzyā</title>
                            </msItem>
                            <msItem xml:id="ms_i1.7">
                                <locus from="74" to="80"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3963Homily">Homily by Yoḥannǝs Metropolitan of Ethiopia for Gǝnbot</title>
                                <incipit xml:lang="gez">
                                    <locus target="#74"/>
                                    ድርሳን፡ ዘነገረ፡ ዮሐንስ፡ ጳጳስ፡ ዘብሔረ፡ ኢትዮጵያ፡ ዘመጽአ፡ እምድኅረ፡ አቡነ፡ ይስሐቅ፡ ጳጳስ፡ ነገረ፡ በእንተ፡ ኀይል፡ ወገድል፡ ዘሊቀ፡ መላእክት፡ ሚካኤል፡ አመ፡ ፲ወ፪ለወርኀ፡ ግንቦት።
                                </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.8">
                                <locus from="80" to="95"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3964Homily">Homily by Yoḥannǝs Bishop of ʾAksum for Sane</title>
                                <incipit xml:lang="gez">
                                    <locus target="#80"/>
                                    ድርሳን፡ ዘይትነበብ፡ በወርኀ፡ ሰኔ፡ ዘደረሰ፡ ዮሐንስ፡ ጳጳስ፡ 
                              <sic>ዘአኵስም፡ ቀዳማዊ፡</sic>
                            አብያተ፡ ክርስቲያናት፡ ቤተ፡ ሚካኤል፡ ወያፈቅሮ፡ ሚካኤል፡ ለውእቱ፡ ሀገር።
                                 </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.9">
                                <locus from="95v" to="107"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3965Homily">Homily by Yoḥannǝs Bishop of ʾAksum for Ḥamle</title>
                            </msItem>
                            <msItem xml:id="ms_i1.10">
                                <locus from="107v" to="126"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3966Homily">Homily for Naḥase</title>
                                <incipit xml:lang="gez">
                                    <locus target="#107v"/>
                                    ድርሳን፡ ዘቅዱስ፡ ሚካኤል፡ አመ፡ ፲ወ፪ለነሐሴ፡ ዘ፳ወ፬ካህናተ፡ ሰማይ፡ ዘወጽአት፡ ዛቲ፡ መጽሐፍ፡ እምኢየሩሳሌም፡ ከመ፡ ይትነገር፡ ክብሮሙ፡ ወዕበዮሙ፡ ወሢመቶሙ፡ ለሚካኤል፡ ወገብርኤል፡ ወ፳ወ፬ካህናተ፡ ሰማይ፡ ወ፬እንስሳ።                                      
                                </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.11">
                                <locus from="126" to="134"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3967Homily">Homily for Maskaram</title>
                            </msItem>
                            <msItem xml:id="ms_i1.12">
                                <locus from="134v" to="143"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3968Homily">Homily for Ṭǝqǝmt</title>
                            </msItem>
                    </msItem>
                    </msContents>
                    

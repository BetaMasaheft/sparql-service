                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#ivv(erso)" facs="005">Fol. ivv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#ivr(ecto)" facs="004">Fol. ivr(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#35v" facs="041">Fol. 35v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#36r" facs="041">Fol. 36r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName> standing for prayer</desc></decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs: <locus target="#1r" facs="006">fols. 1r, </locus> (haräg); <locus target="#41v #42r" facs="047">41v, 42r</locus> (lines of black dots)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="a1">
                        <desc type="Asmat">
                          <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>
                          Asmat prayer against demons
                          <foreign xml:lang="gez">
                            በስመ፡ አብ፡ ወወልድ፡<gap reason="omitted"/>አርፍቃኤል፡ አዘቅታኤል፡ ሕዝቅናኤል፡ ምርሜል፡ መግሦስ፡ ሚላትሮ፡ <gap reason="omitted"/>
                            (iir) ተንብል፡ ሊተ፡ ኦሊቀ፡ መላእክት፡ ቅዱስ፡ ሚካኤል፡ ከመ፡ ታድኅነኒ፡ እምአጋንንት፡<gap reason="omitted"/>
                          </foreign>
                        </desc>
                      </item>
                      <item xml:id="a2">
                        <desc type="Asmat">
                        <locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus>, Asmat prayer, from a rejected leaf from another book
                        </desc>
                      </item>
                      <item xml:id="e1">
                        <desc>
                           <locus target="#ir(ecto) #44v #45r" facs="001 050">Fols. ir(ecto), 44v, 45r</locus>: pen trial
                        </desc>
                        </item>
                      <item xml:id="a3">
                        <desc type="ScribalSignature">
                          <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>, last two lines: name of scribe, <foreign xml:lang="gez">ጸጋ፡ ሥላሴ፡</foreign>
                        </desc>
                        </item>
                      <item xml:id="a4">
                        <desc type="OwnershipNote">
                          <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>,  last two lines  owner, <foreign xml:lang="gez">አኅተ፡ ማርያም፡</foreign>
                        </desc>
                        </item>
                      <item xml:id="e2">
                        <desc>
                          Scribal intervention: words of text are written interlinearly (<locus target="#40r" facs="045">fol. 40r</locus>)
                        </desc>
                      </item>
                      <item xml:id="e3">
                        <desc>
                          <locus target="#iiv(erso) #iiir(ecto) #35r #36v" facs="003 040 042">Fols. iiv(erso), iiir(ecto), 35r, 36v</locus>: blank
                        </desc>
                      </item>
                      <item xml:id="e4">
                        <desc>
                          Numbered quires: quires 2–5
                        </desc>
                      </item>
                      </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">

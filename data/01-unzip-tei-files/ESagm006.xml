                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre but regular</seg>
                        <seg type="ink">Black (a different hue in fol. 7), red</seg>
                        <date>19th century</date>
                        <seg type="rubrication">Nomina sacra; name of the owner; three lines on the
                           incipit page alternating with black lines; the initial line of each
                           prayer; elements of the punctuation signs; elements of Ethiopic
                           numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The hand on fol. 7 is probably
                        different from the main hand. It is less regular; letters are distinguished
                        by conspicous
                        hairlines.</handNote>
                  </handDesc>

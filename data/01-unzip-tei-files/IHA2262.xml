               <msContents>
                  <summary>This microfilm includes images of four different manuscripts, belonging to different collections. Each manuscript includes a page, written by Drewes, where he locates the manuscript. This location has been reported as Previous Shelfmark for each part.</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="2r">1-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4512IHA">مدح شيخ ابادر ذري الأمال واسع الى الابادر</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>ايا يابادر شيخ ابادر فسامحنا وداركنا ابادر | ذري الأمال واسع الى ابادر فكل الخير عند الشيخ حاضر</incipit>
                     <explicit xml:lang="ar">وصلى الله زيكل وقت على المختار من بين الأكابر | وال ثم أصحاب كرام أولى الأحسان ما انعقد الجوهر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="3r">2v-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0752IHA">توسل بابادر عمر الرضى توسلت بشيخ الابادر</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>صلوة وتسليم وازكى تحية على احمد طه المفاخر | توسلت بالشيخ الأبادر انه لما يطلب الأنسان فيه يبادر | فبادر فعجلة فيا عمر الردى لأنك ملحوظ اليه وناظر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>وأصحابه ذوي المكارم والتقى فلاتهم؟ شمس الهدي والجواهر | وتباعه والداخلين جوااره مدى الدهر ما دامت منى والجواهر</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 12.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="19r" to="20v">19r-20v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4521IHA">Poem in Old Hararī "bi-Ism Allāh al-aʻẓam"</title>
                     <incipit xml:lang="ar">
                        <locus target="#19r">-19r</locus>بسم الله الرحمن الرحيم بسم الله بسم الله الأعظموا صلوة | الوسطوا واذا جيني غفار الذنوب ستا | والعيوب علام الغيوب إليك اتوب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20v">-20v</locus>داوشو ننزوا محمود كل حايم خالي حمدي | لجا فزا والي خير يفل؟ د الله حمد حبوت وجبنى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="20v" to="21r">20v-21r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4522IHA">توسل باولياء هرر</title>
                     <incipit xml:lang="ar">
                        <locus target="#20v">-20v</locus>بسم الله الرحمن الرحيم توسل الى المولى بخير الوسائل محمد الهادي تقربا الوسائل | وبالانبيا ثم الملئك جملة وبالآل والصحب الكرام الافاضل </incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="22" to="32">22-32</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4523IHA">ذكر هرري</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>Reproduction of part of a manuscript, with pages reproduced more times.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3v" to="4r">3v-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4277IHA">دعاء الله الله يا خالق النون</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>الله الله الله يا خالق النون يا جامع الأمر بين الخاف والنون | الحمد لله ربي خالق النون حمد نقول به دنيا وفي الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>وال احمد واصحابه ما جراى ما دعت؟ سيحون وحيحون | الله الله الله يا خالق النون يا جامع الأمر بين الكاف والنون</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 12.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="4v" to="5r">4v-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4514IHA">نظم بشرى كي حليم</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بشر ... حليم بدرة اليتيم طوبى كي حليم بدرة اليتيم | يا مرضعت محمد المصطفى ... بين الثنا المؤبد و... الكريما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>القلب فيه العاني وحبه كفاني يا صاحب المعاني اشواقنا قديمة | محمد المكرم السيد العظم ابن الصفا والزمزم والخيف والحطيمه</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 12.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="5r" to="5r">5r-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4515IHA">نظم الله الله لطيف خبير</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>الله الله لطيف خبير نعم المولى وانت نعم النصير | رب يا عالم السرائر يا ... هو لا غيره اللطيف الخبير</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>قد توسلت بالنبي وحسبي إنه المصطفى البشير النذير | فعليه يا رب صل وسلم ما اماطت غياهب وستور</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 12.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="5v" to="7r">5v-7r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4516IHA">نظم لا إله إلا الله نبيوا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله الرحمن الرحيم | لا اله الا الله نبيوا محمد نب رسول الله الحمد لله رب العالمين | الله إله واحد حي عالموا قادروا سميع البصير سبحان الحي الحليم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7r">-7r</locus>ايتها النفس المطمئنة الجعي الى ربك راضية مرضية | فادخلي فى عبادي وادخلي جنتي ولا حول ولا قوة الا بالله العلي العظيم</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 12.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="7v" to="11r">7v-11r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4384IHA">اسماء الشجر والعروق (٢)</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>هندبا البر الشبت وطوكى قطيط خردل فلفل منبه كراث فجل ياسمين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>العدس اللوبيا دفلا سوس كشوث فوزبج مدر يجوش كباث برفع اسل الفرسك قطونا ملوخا لسان الجمل</explicit>
                     <note>: <placeName ref="https://betamasaheft.eu/INS0030IHA">Abdel Muhaymin</placeName>
                     </note>
                     <note>This part belongs to the Abdel Muhaymin collection, ms. 20.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="11r" to="17r">11r-17r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4520IHA">باب اسماء الشجر والعروق ٣</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>باب اسمآ الشجر والعروق حرف الالف ارب افستين اسخل انجدان ارز اقثيمون</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17r">-17r</locus>يزبوع يمام يوار يعسوب بحمور يوشا ياعرة يحموم  يامور يرفا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="18" to="18v">18-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar">
                        <locus target="#18v">-18v</locus>لا تشترون بآيات الله ثمنا قليلا اولايك لهم اجرهم عند ربهم [...] حسبنا الله ونعم الوكيل ولا حول ولا قوة الا بالله العلي العظيم سبع مرات ان الله وملئكته يصلون على النبي يا أيها الذين آمنوا صلوا عليه وسلموا تسليما ثلاث مرات اللهم صل افضل صلوة الى آخره ثلاث مرات سبحن الله ونحمده عدد خلقه ورضى نفسه وزنة عرشه ومداد كلمات ثلاث مرات سبحن الله والحمد لله ولا حول ولا قوة الا بالله العلي العظيم وصلى الله على سيدنا محمد واله وصحبه وسلم ا م م م </explicit>
                     <note>The microfilm preserves only the last page of the text, which was not identified. This part belongs to the ms 17 of the ʻAbdel Muhaymin collection.</note>
                     <note/>
                  </msItem>
               </msContents>

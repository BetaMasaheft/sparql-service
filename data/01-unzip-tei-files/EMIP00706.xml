                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#48v" facs="052">Fol. 48v</locus>
                    <desc>
                    Note of transaction, sale of this book for 2 birr
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#iv(erso) #49r" facs="002 052">Fols. iv(erso), 49r</locus>
                    <desc>
                    blank
                    </desc>
                    </item>

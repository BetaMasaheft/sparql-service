               <msContents>
                  <summary>Thirty-Two Miracles of Mary, ተአምረ፡ ማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="56r" facs="003">Fols 1r–56r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="4r" facs="003">Fols 1r–4r</locus>
                    <title>Extended version of Introductory Rite from Mu‘allaqa</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="5r" to="56r" facs="007">Fols 5r–56r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Thirty-Three Miracles of Mary (rebound in disorder)</note>

                  <msItem xml:id="ms_i1.2.1">
                    <locus from="5r" facs="007">Fols 5r and following</locus>
                    <title>How the Virgin Mary accepted the Book of Miracles compiled by Saint Däqsǝyos and how she punished a bishop who usurped the garment and chair of Däqsǝyos</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.2">
                    <locus from="7r" facs="009">Fols 7r and following</locus>
                    <title>How a certain righteous governor was falsely accused, and the authorities attempted to injure him, but the Virgin Mary prevented the injury and also sustained his life when they attempted to hang him</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.3">
                    <locus from="9r" facs="011">Fols 9r and following</locus>
                    <title>How, because of his devotion to her, the Virgin Mary saved the soul of a wicked monastic leader from hell when he died; and how he appeared to his disciple in a dream and told him how the Virgin Mary saved him from damnation</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.4">
                    <locus from="10r" facs="012">Fols 10r and following</locus>
                    <title>How the Virgin Mary saved from a sinking ship a certain devoted person who cried out to Mary, who then came and covered him with her wings (other accounts say garment)</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.5">
                    <locus from="12v" facs="015">Fols 12v and following</locus>
                    <title>How the painted figures of the Virgin Mary and Christ on an icon bled when a Jew cast the board into a pit, and how the magistrate had the Jew burnt alive</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.6">
                    <locus from="13v" facs="016">Fols 13v and following</locus>
                    <title>How the Virgin Mary appeared to a monk when he couldn’t walk and his friends carried him to church; how she appeared to him and took him to Paradise; and how a certain monk saw this in his dream</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.7">
                    <locus from="15r" facs="017">Fols 15r and following</locus>
                    <title>How the Virgin Mary saved a young widow from the wiles of a certain knight, who forthwith became a monk and retired to the desert</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.8">
                    <locus from="18v" facs="021">Fols 18v and following</locus>
                    <title>A story about a bell ringer and faithful priest. The exact identification is not possible due to the disorder of the folios</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.9">
                    <locus from="19r" facs="021">Fols 19r and following</locus>
                    <title>How the Virgin Mary revealed to a certain man the truth of the prophecy of Isaiah about the birth of the messiah by a virgin; and how she allowed him to kiss her feet and cheek. Not known in other collections</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.10">
                    <locus from="30r" to="20r" facs="032">Fols 30r–20r</locus>
                    <title>How the icon of the Virgin Mary helped a young impoverished man and how the church keeper saw this miracle and how he gave his daughter to the young man in marriage. Ending f. 20r, beginning ff. 30rv</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.11">
                    <locus from="21r" facs="023">Fols 21r and following</locus>
                    <title>How the Virgin Mary commanded the bishop to bury in the believers’ burial the body of a hanged thief who had been devoted to Mary; and how a tree with healing powers grew up from his grave</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.12">
                    <locus from="23v" facs="026">Fols 23v and following</locus>
                    <title>How the Virgin Mary spoke from her picture to a devout worshipper and said to him, “Blessed art thou among men.”</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.13">
                    <locus from="24v" facs="027">Fols 24v and following</locus>
                    <title>How the Virgin Mary raised up a dead knight, who had been buried in the cemetery of a convent, to fight against an enemy of the church called Gǝldǝyanos. (continued on ff. 27rv)</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.14">
                    <locus from="26r" facs="028">Fols 26r and following</locus>
                    <title>How the Virgin Mary appeared to a certain priest inside the church at the time of prayer; How the Abbott of the church had beaten the priest because he had not participated in prayer. Incomplete at the beginning and end</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.15">
                    <locus from="37r" to="28r" facs="039">Fols 37r–28r</locus>
                    <title>How the Virgin Mary received the gift of a certain woman who was forbidden to fast by her husband, incomplete at the beginning. 15.	Concluded on f. 28r, beginning f. 37r</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.16">
                    <locus from="28r" to="31r" facs="030">Fols 28r–31r</locus>
                    <title>How the Virgin Mary saved the drunken monk from a lion and a savage dog. Beginning f. 28r, continued 31rv</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.17">
                    <locus from="40v" to="29r" facs="043">Fols 40v–29r</locus>
                    <title>How the Virgin Mary saved a certain painter when he fell from his scaffolding, incomplete at the beginning. Concluded on f. 29r, beginning on f. 40v</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.18">
                    <locus from="29v" to="54r" facs="032">Fols 29v–54r</locus>
                    <title>How the Virgin Mary appeared to a jeweler to forbid him from making an icon for certain arrogant people; and how she showed an icon of her which had been made by the angels to Abba Basiliyos. Beginning f. 29v; ending ff. 54r–55v</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.19">
                    <locus from="31v" facs="034">Fols 31v and following</locus>
                    <title>How the Virgin Mary saved the people on a certain ship on the sea when they were caught in a powerful storm</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.20">
                    <locus from="33v" facs="036">Fols 33v and following</locus>
                    <title>How the Virgin Mary healed the sick deacon who recited her sälam song by anointing him with her breast milk</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.21">
                    <locus from="35r" facs="037">Fols 35r and following</locus>
                    <title>How the Virgin Mary protected a sinful man from his attackers until he had confessed his sin to the priest; and how she received his soul after he was executed; and how the people saw this and repented of their sins</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.22">
                    <locus from="36r" facs="038">Fols 36r and following</locus>
                    <title>How two traveling women [elsewhere called Juliana and Barbara] were attacked by robbers who stole their provisions; and how, when the head of the bandits tried to eat the stolen food, the Virgin Mary turned the bread into stones upon which he broke his teeth; and how the thieves repented from their evil</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.23">
                    <locus from="36v" to="47r" facs="039">Fols 36v–47r</locus>
                    <title>How the Virgin Mary commanded a deacon to dig up and rebury in consecrated ground the body of an adulterous deacon from the island of Jericho in the city of Gärisat who was killed by the people. Beginning f. 36v, continuing ff. 41rv, and ending 47r</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.24">
                    <locus from="46r" to="38r" facs="048">Fols 46r–38r</locus>
                    <title>How the Virgin Mary healed a certain sinful woman when she swallowed a scorpion because she was depressed about her sin and how a voice from the icon led her to a certain priest for repentance and healing. Ending f. 38r and beginning 46rv</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.25">
                    <locus from="38v" to="39v" facs="041">Fols 38v–39v</locus>
                    <title>How the Virgin Mary appeared to a wise monk who had criticized his fellow monks about the food they were eating and how she chided him, incomplete at the end</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.26">
                    <locus from="52r" to="40r" facs="054">Fols 52r–40r</locus>
                    <title>How a certain Jew of Constantinople threw into the water [other accounts say to the ground] a picture of the Virgin Mary and when it was restored it exuded oil that healed many, incomplete at the beginning. 26.	Ending f. 40r; beginning 52rv</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.27">
                    <locus from="42r" to="43r" facs="044">Fols 42r–43r</locus>
                    <title>How a monk from Alexandria [other versions say an aged Jew of Akhmim], who had spent his whole life in ministering in a church of the Virgin Mary, became old and could not walk [other versions say that he fell down one day during the service and broke his back], and how the Virgin Mary touched his backbone and made it whole, and made him to stand by her on the right-hand side of the altar</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.28">
                    <locus from="43r" to="44v" facs="045">Fols 43r–44v</locus>
                    <title>How a scribe [some versions name him as Damianus] used to write the name of the Virgin Mary in gold and colored paints, and how the Virgin appeared to him when dying, and took his soul to Paradise and showed him his name inscribed upon a pillar of gold</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.29">
                    <locus from="44v" to="46r" facs="047">Fols 44v–46r</locus>
                    <title>How the Virgin Mary appeared to reassure an ascetic woman about the purity of her friends, other ascetic women held with her in prison</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.30">
                    <locus from="47r" to="49v" facs="049">Fols 47r–49v</locus>
                    <title>How a certain woman prayed to Mary to hold Jesus as the Virgin Mary had held her; how Jesus Christ appeared to the woman as a small child; and how the woman did not recognize him and sent him away</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.31">
                    <locus from="49v" to="51r" facs="052">Fols 49v–51r</locus>
                    <title>How a certain witch advised a man to bring communion for the purpose of attracting bees; how the man brought the communion elements in his mouth and put them in the beehive; how light shown in the beehive and how the Virgin Mary with her Beloved Son appeared in the beehive; and how the priest and the believers took the beehive to the church, received the communion elements and how they killed the man</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.32">
                    <locus from="51r" to="52r" facs="053">Fols 51r–52r</locus>
                    <title>How the Virgin Mary saved the soul of a certain rich person who had stolen the land and grain of the people, but was devoted to the Virgin Mary; how the demons tried to take his soul; how the demons and the angels put his deeds in the balances; and how the Virgin Mary interceded to save his soul</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2.33">
                    <locus from="52r" to="56r" facs="054">Fols 52r–56r</locus>
                    <title>How the Virgin Mary removed a Monastery [called in some versions the monastery Akona or Sikona] near Jericho from the site on which it had been built in the desert to the side of a running stream; and how the removal was effected by night whilst the monks were sleeping. 52r–53r, ending f. 56r</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                </msItem>
              </msItem>

               </msContents>

               <msContents>
                  <summary>I) Malʾǝkta Ṗāwlos ḫaba säbʾa Rome "Epistle of Paul to the Romans" [Rom.]
                     (incipit: fol. 1va; explicit: fol. 11ra), incomplete 
 II) Malʾǝkta Ṗāwlos
                     qadāmāwi ḫaba säbʾa Qorontos "First Epistle of Paul to the Corinthians" [1
                     Cor.] (incipit: fol. 11ra; explicit: fol. 60ra)
 III) Malʾǝkta Ṗāwlos
                     dāgǝmāwi ḫaba säbʾa Qorontos "Second Epistle of Paul to the Corinthians" [2
                     Cor.] (fols. 60ra-70ra) 
 IV) Malʾǝkta Ṗāwlos ḫaba säbʾa Gälatya "Epistle
                     of Paul to the Galatians" [Gal.] (incipit: fol. 70ra; explicit: fol. 74ra)
                     V) Malʾǝkta Ṗāwlos ḫaba säbʾa ʾEfeson "Epistle of Paul to the Ephesians" [Eph.]
                     (fols. 74ra-78va) 
 VI) Malʾǝkta Ṗāwlos ḫaba säbʾa Filṗǝsyos "Epistle of
                     Paul to the Philippians" [Phil.] (incipit: fol. 78va; explicit: fol. 40ra)
                     VII) Malʾǝkta Ṗāwlos ḫaba säbʾa Qʷälasyǝs "Epistle of Paul to the Colossians"
                     [Col.] (incipit: fol. 40ra; explicit: fol. 47va) 
 VIII) Malʾǝkta Ṗāwlos
                     qadāmāwi ḫaba säbʾa Täsälonqe "First Epistle of Paul to the Thessalonians" [1
                     Thes.] (fols. 47va-50vb)
 IX) Malʾǝkta Ṗāwlos dāgǝmāwi ḫaba säbʾa Täsälonqe
                     "Second Epistle of Paul to the Thessalonians" [2 Thes.] (fols. 50vb-52va)
                     X) Malʾǝkta Ṗāwlos qadāmāwi ḫaba Ṭimotewos "First Epistle of Paul to Timothy"
                     [1 Tim.] (incipit: fol. 52va; explicit: fol. 34va)
 XI) Malʾǝkta Ṗāwlos
                     dāgǝmāwi ḫaba Ṭimotewos "Second Epistle of Paul to Timothy" [2 Tim.] (fols.
                     34va-37ra)
 XII) Malʾǝkta Ṗāwlos ḫaba Tito "Epistle of Paul to Titus"
                     [Tit.] (fols. 37ra-38vb)
 XIII) Malʾǝkta Ṗāwlos ḫaba Filmona "Epistle of
                     Paul to Philemon" [Phlm.] (fols. 38vb-39va)
 XIV) Malʾǝkta Ṗāwlos ḫaba
                     säbʾa ʿǝbrawǝyan "Epistle of Paul to the Hebrews" [Heb.] (incipit: fol. 39va),
                     incomplete</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>The correct order of fols. containing Texts I, II, IV, VI, VII, X, XIV is
                        as follows:</note>
                     <note>- Rom.</note>
                     <note>1:32-4:3 (<locus from="1va" to="3vb">1va-3vb</locus>); 4:4-4:23 (<locus target="#14ra">14ra-</locus>vb); 4:24-5:17 (<locus target="#17ra">17ra-</locus>vb); 5:17-8:11 (<locus from="4ra" to="6vb">4ra-6vb</locus>); 8:11-8:23 (<locus target="#22v">22v</locus>); 8:23-8:34
                           (<locus target="#22r">22r</locus>); 8:34-9:21 (<locus target="#8ra">8ra-</locus>vb); 9:21-10:12 (<locus target="#15ra">15ra-</locus>vb);
                        10:12-11:14 (<locus target="#9ra">9ra-</locus>vb); 11:14-13:7 (<locus from="12ra" to="13vb">12ra-13vb</locus>); 13:7-15:16 (<locus from="12ra" to="13vb">12ra-13vb</locus>); 15:16-16:7 (<locus target="#10ra">10ra-</locus>vb); 16:7-16:25 (<locus target="#16ra">16ra-</locus>vb);
                        16:25-16:27 (<locus target="#11ra">11ra</locus>)</note>
                     <note>- 1 Cor.</note>
                     <note>1:1-1:19 (<locus target="#11ra">11ra-</locus>vb); 1:19-2:7 (<locus target="#23ra">23ra-</locus>vb); 2:7-4:9 (<locus from="20ra" to="21vb">20ra-21vb</locus>); 4:10-10:9 (<locus from="25ra" to="30vb">25ra-30vb</locus>); 10:9-11:11 (<locus target="#24ra">24ra-</locus>vb);
                        11:11-16:24 (<locus from="54ra" to="60ra">54ra-60ra</locus>)</note>
                     <note>- Gal.</note>
                     <note>1:1-5:4 (<locus from="70ra" to="73vb">70ra-73vb</locus>); 5:5-6:15
                           (<locus target="#41ra">41ra-</locus>vb); 6:15-6:18 (<locus target="#74ra">74ra</locus>)</note>
                     <note>- Phil.</note>
                     <note>1:1-4:17 (<locus from="78va" to="81vb">78va-81vb</locus>); 4:17-4:23
                           (<locus target="#40ra">40ra</locus>)</note>
                     <note>Col.</note>
                     <note>1:1-1:20 (<locus target="#40ra">40ra-</locus>vb); 1:20-4:18 (<locus from="45ra" to="47va">45ra-47va</locus>)</note>
                     <note>- 1 Tim.</note>
                     <note>1:1-3:8 (<locus from="52va" to="53vb">52va-53vb</locus>); 3:8-5:5 (<locus target="#43ra">43ra-</locus>vb); 5:5-6:21 (<locus from="33ra" to="34va">33ra-34va</locus>)</note>
                     <note>- Heb.</note>
                     <note>1:1-1:9 (<locus target="#39va">39va-</locus>b); 1:9-3:6 (<locus target="#7ra">7ra-</locus>vb); 3:6-5:2 (<locus target="#44ra">44ra-</locus>vb); 5:2-7:2 (<locus target="#42ra">42ra-</locus>vb);
                        7:2-9:6 (<locus from="31ra" to="32rb">31ra-32rb</locus>).</note>
                     <note>Most of the texts are followed by a note on stichometry.</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">81.0</measure> folios, in <measure unit="quire"/> quires . <dimensions type="outer">
                              <height unit="mm">170</height>
                              <width unit="mm">145</width>
                              <depth unit="mm">50</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">The quire structure cannot be established due to the
                                 poor condition of the Ms.</item>
                           </list>
                        </collation>
                        <condition key="deficient">Both boards are missing.
 The sewing is
                           damaged (for the most part missing) and crudely repaired (e.g., <locus target="#4r">4r</locus>, 27r, 59r, 69r). 
 Many fols. are missing,
                           many are misplaced. 
 Many fols. are affected by humidity, partly
                           with the loss of text (e.g., <locus target="#1r">1r</locus>, 32v, 40-41,
                           43). 
 Larger portion of the text are difficult to read because the
                           ink faded away or has been abraded (e.g., <locus target="#2r">2r</locus>,
                           11v, 22v).</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="22">
                           <dimensions unit="mm">
                              <height>123</height>
                              <width>123</width>
                              <dim type="intercolumn">6</dim>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">5</dim>
                              <dim type="bottom">38</dim>
                              <dim type="right">14</dim>
                              <dim type="left">5</dim>
                              <dim type="intercolumn">6</dim>
                           </dimensions>
                           <note>All data are for <locus target="#2r">2r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible. </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A-1A1A/0-0/0-0/C. </ab>
                           <ab type="pricking"> Primary pricks are partly visible. </ab>
                           <ab type="pricking"> Ruling pricks are partly visible. </ab>
                           <ab type="ruling"> The upper line is written above the ruling. </ab>
                           <ab type="ruling"> The bottom line is written above the ruling.  The scribe sometimes did not use the bottom ruled line (e.g., <locus target="#16v">16v</locus>, 20r, 22v).</ab>
                        </layout>
                        
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Mid 18th - early 19th century</date>
                        <list type="abbreviations">
                           <item>Throughout the Ms.:</item>
                           <item>
                              <abbr>ክ፡</abbr> for <expan>ክፍል፡ </expan> (e.g., <locus target="#18rb">18rb</locus>, 29ra)</item>
                           <item>
                              <abbr>ክፍ፡</abbr> for <expan>ክፍል፡ </expan> (e.g., <locus target="#12vb">12vb</locus>, 19ra, 46vb)</item>
                           <item>
                              <abbr>አን፡</abbr> for <expan>አንቀጽ፡ </expan> (e.g., <locus target="#29va">29va</locus>)</item>
                           <item>
                              <abbr>አንቀ፡</abbr> for <expan>አንቀጽ፡ </expan> (e.g., <locus target="#21va">21va</locus>, 24vb, 46va)</item>
                        </list>
                        <seg type="rubrication">Incipits of all texts; the words for "section" kǝfl
                           and ʾanqäṣ, resp. their abbreviations; elements of the punctuation signs;
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The handwriting appears irregular and
                        angular in
                        shape.</handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">A few omissions were inserted interlineally: e.g., fols. 2va, 38va (in red), 52ra, 57va.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Boards are missing. 
 Two pairs of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial"/>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible on the spine fold
                           of the quires, close to the head and the tail of the codex.</decoNote>
                     </binding>
                  </bindingDesc>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="2r" to="6v">Fols 2r–6v</locus>
                    <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1195Bahrah">ባሕረ፡ ሐሳብ፡</title>
                    <textLang mainLang="am"/>
                    <incipit xml:lang="am">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                    ፩ አምላክ፡ ንዌጥን፡ በረደኤተ፡ እግዚአብሔር፡ ለጽሒፈ፡ ሐሳበ፡ ቁጥር፡ ለዓለመ፡
                  ዓለም፡ አሜን። ባሕረ፡ ሐሳብ፡ ማለት፡ ቁጥር፡ ዘመን፡ ያለው፡ ነው፡ ሐሳበ፡
                ባሕር፡ ያለ፡ እንደሆነ፡ የዘመን፡ ቁጥር፡ ይህ፡ ነው። </incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="11r" to="39r">Fols 11r–39r</locus>
                    <title type="incomplete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1834Mahlet">ማኅሌተ፡ ጽጌ፡</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ጽጌ፡ አስተርአየ፡ ሠሪፆ፡ እምዓለም። ለዘአምኃኪ፡
                    ጽጌ፡ ለገብርኤል፡ ምስለ፡ ሰላሙ። ወበእንተዝ፡ ማርያም፡ ሶበ፡ ሐወዘኒ፡ መዓዛ፡ ጣዕሙ።</incipit>
                    <explicit>ሰብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ነቢያት፡ ቅዱሳን፡ ሰብሐት፡ ለኪ፡ ማርያም፡ በጽጌል ሐዋርያት፡ ፍንዋን። ሰብሐት፡ ለኪ፡
              ማርያም፡ በጽጌ፡ ሰማዕት፡ ወጻድቃን። ሰብሐት፡ ለኪ፡ ማርያም፡ ለማኅሌተ፡ ጽጌኪ፡ ወይን። እስመ፡ በጽጌኪ፡ ወይን፡ ይትፌሣህ፡ ኅዙን።
          ኦእግዚእትየ፡ ማርያም፡ ዕቀብኒ፡ ወአድኀንኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገብርኪ፡ <space/> ለዓለመ፡ ዓለም፡ አሜን።</explicit>
                    <note>The text is distributed according to the days of the week.</note>
                    <note>The text seems to be incomplete.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                    <locus from="39r" to="49r">Fols 39r–49r</locus>
                    <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2285Saqoqa">ሰቆቃወ፡ ድንግል፡</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ሕጸት፡ ግፃዌ፡
                    ዘአልቦ፡ ሰቆቃወ፡ ድንግል፡ እጽሕፍ፡ በቀለመ፡ አንብዕ፡ ወአንጠብጥቦ።</incipit>
                    <explicit xml:lang="gez">ሰብሐት፡ ለኪ፡ ማርያም፡
                    በሰብሓተ፡ መንፈስ፡ ቅዱስ፡ ማኅየዊ። ቃለ፡ ለዕለትየ፡ በአዕዛነ፡ መንፈስ፡ ጽልዊ።
                  ወዲበ፡ ዛቲ፡ ጸሎት፡ ሰላመ፡ ከዓዊ።</explicit>
                    <note>The text is distributed according to the days of the week.</note>
                  </msItem>

                  <msItem xml:id="ms_i4">
                    <locus from="49r" to="63r">Fols 49r–63r</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1099Anapho">አኰቴተ፡ ቁርባን፡ ዘእግዝእትነ፡ ማርያም፡ ዘደረሰ፡ አባ፡ ሕርያቆስ፡ በሀገረ፡ ብሕንሳ፡</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፡ ወይእዜኒ፡ ዘረሰየነ፡ ንንብብ፡ ወንፈጽም፡
                    በሠምረቱ፡ ሎቱ፡ ስብሐት፡ ወውእቱ፡ ጠቢብ፡ እስከ፡ ለዓለመ፡ አሜን።</incipit>
                  </msItem>


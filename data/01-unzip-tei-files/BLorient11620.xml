                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7334Nahabt">Ṣalot baʾǝnta nahabt ʾasmāta Salomon</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ጸሎት፡ በእንተ፡ ነሀብት፡ አስማተ፡ ሰሎሞን፡ ዘረበቦሙ፡ ለአጋንንት፡ ከመ፡ መርበብ፡ ዘዓሣ፡
                                ዘባሕር፡ እንዘ፡ ይብል፡ ሰደቃኤል፡ ጸደቃታኤል፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT6609ProtectPrayer">Protective Prayer (general record)</title>
                            <note>Prayer against demons and about the healing of a man possessed with a demon, containing verses from 
                                <ref type="work" corresp="https://betamasaheft.eu/LIT1560Gospel">Mt. 9:32-4</ref>.</note>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4620Prayer">Ṣalot baʾǝnta ḥǝmāma nahabt wa-ʾagānǝnt ʾAlāhumā
          Wayānurā</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ጸሎት፡ በእንተ፡ አላሁማ፡ ወያኑራሽም፡ ዲጂ፡ <gap reason="omitted"/>
                                በኃይለ፡ ዝንቱ፡ አስማቲከ፡ ዘረበቦሙ፡ ለአጋንንት፡ ከመ፡ መርበብተ፡ ዓሣ፡ ዘባሕር፡ ወይቤ፡ ሰሎሞን፡ ሎፍሐም፡ ሎፍሐም፡ ሎፍሐም፡ <gap reason="omitted"/>
                                በኃይለ፡ ዝንቱ፡ አስማቲከ፡ አድኅኖ፡ እምሕማመ፡ ነሀብት፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7276MarkOne">Mark 1:23-27</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7335BahaylaAsm">Ba-ḫāyla zǝntu ʾasmātika fǝtāh śǝrāyomu la-maśaryān</title>
                            <incipit xml:lang="gez">አኽያ፡ ሹራህያ፡ አልሻዳይ፡ <gap reason="omitted"/> በኃይለ፡ ዝንቱ፡ አስማቲከ፡ ፍታህ፡ ሥራዮሙ፡ 
                                ለመሠርያ<supplied reason="undefined" resp="PRS8999Strelcyn">ን</supplied>፡ እምላዕለ፡ ለ<gap reason="illegible"/>
                                <gap reason="omitted"/> በከመ፡ ፈታህኮሙ፡ ለጴጥሮስ፡ ወለጳውሎስ፡ ወፈታህከ፡ ውስተ፡ ቴርም፡ ሥራየ፡ ቆጵርያኖስ፡ ከማሁ፡ ፍታህ፡ ሥራየ፡ ብእሲት፡
                                ወብእሲት፡ ሥራየ፡ ባርያ፡ ወአጋንንት፡ አቅጥናኤል፡ ክፍትናኤል፡ <gap reason="omitted"/> በኃይለ፡ <sic>ዝንቱዝ፡</sic>
                                አስማቲከ፡ ዘርዝር፡ ወርጽሽጅ፡ ዝንቱ፡ <sic resp="PRS8999Strelcyn">ሥራይ፡</sic> በእሲ፡ ወብእሲት፡ ሥራየ፡ ማሪ፡ ወማሪት፡</incipit>
                            <explicit xml:lang="gez"/>
                            <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>

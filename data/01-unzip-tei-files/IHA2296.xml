                        </item>
                        <item xml:id="a0_7573">
                           <locus target="#28v">-28v</locus>
                           <q xml:lang="ar">تمت بالخير والحمد لله رب العالمين أمين [.؟.] رمضان ليلة الأرباء</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_7570">

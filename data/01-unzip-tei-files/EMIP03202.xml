               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="1r" to="56r" facs="001">Fols 1r–56r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan">, arranged with the homilies in front and the miracles in the back</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">56</measure>

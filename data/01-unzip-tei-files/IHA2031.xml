                  <msItem xml:id="ms_i0">
                     <locus from="4v" to="140v">4v-140v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0030IHA#s649IHA">تحفة المحتاج بشرح المنهاج, From the beginning of
                    Kitāb al-ṣadāq to the end of Kitāb al-nafaqāt fi al-nikāḥ</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>كتاب الصداق هو بفتح الصاد ويجوز كسرها وجمعه قلة اصدقة وكثرة صدق ويقال صدقه بفتح فتثليث وبضم او فتح فسكون وتضمهما وجمعه صدقات ما وجب بعقد نكاح وياتي ان الفرض فى التفويض وان كان الوجوب به مبتدء العقد هو الاصل فيه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#140v">-140v</locus>وصح ان الرجول [ليوجز] في نفقته كلها الا في هذا التراب اي ما لم يقصد بالانفاق فى البناء به مقصدا صالحا كما هو معلوم والله سبحانه وتع اعلم </explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

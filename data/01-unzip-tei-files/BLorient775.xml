                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በእንተ፡ ክብራ፡ ለድንግል፡ ንጽሕት፡ ማርያም፡ ወብካያ፡ ወላሀ፡ በእንተ።

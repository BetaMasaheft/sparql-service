                    <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> (facing right), flanked by an <term key="angel" ana="#angel"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#133r" facs="135">Fol. 133r</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1106HolyWomen">Holy Women</ref> facing one another</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#133v" facs="136">Fol. 133v</locus><desc>The Holy Family</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#134r" facs="136">Fol. 134r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> disputing with <persName ref="https://betamasaheft.eu/PRS11330Devil">Devil</persName></desc></decoNote>
                    <decoNote type="frame" xml:id="d7">
                    Decorative designs:
                    <locus target="#1r #33v #77r #102v #108v" facs="003 036 079 105 111">folss. 1r, 33v, 77r, 102v, 108v, </locus> (ornamental band);
                    <locus target="#68r #90v #108r" facs="070 093 110">68r, 90v, 108r</locus> (multiple full stops)
                    </decoNote>

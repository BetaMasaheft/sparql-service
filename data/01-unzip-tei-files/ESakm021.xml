                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic"> Hand a: <locus from="3r" to="27r">3r-27r</locus>
                        <seg type="script"> mediocre, irregular hand, characterized by big broadly
                           spaced letters; the hand writing is upright or slightly
                           left-sloping.</seg>
                        <seg type="ink">Black, red (strong red).</seg>
                        <date>19th century</date>
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS12554SaggaZaAb">Ṣaggā za-ʾAb</persName> and
                           <persName role="scribe" ref="https://betamasaheft.eu/PRS12555GabraSadeq">Gabra Ṣādǝq</persName>
                        are simultaneously mentioned as scribes in the supplication formula (<locus target="#34r">34r</locus>). <list type="abbreviations">
                           <item>
                              <abbr>ሰላ፡</abbr> for <expan>ሰላም፡ </expan> (e.g., <locus target="#3r">3r</locus>, <locus target="#4r">4r</locus>, <locus target="#5r">5r</locus>).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; elements of the punctuation signs;
                           elements of Ethiopic numerals; some words like salām (e.g., 10r, 12v,
                           15r), ba-zǝntu qāla (fol. 18r), sǝbḥat laki (fol. 18v), ʾǝm-mǝsraq (fol.
                           32v).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand b: <locus from="27v" to="34r">27v-34r</locus>
                        <seg type="script"> mediocre, irregular hand, characterized by smaller,
                           round letters. </seg>
                        <seg type="ink">Black, red (strong red).</seg>
                        <date>19th century</date>
                     </handNote>


                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1r">f. 1r</locus>
                           <desc>: Record on the arrival of Gabra Madhǝn [and] Gabra Māryām.</desc>
                           <q xml:lang="am">
                              <locus target="#1r">1r</locus>: ገብረ፡ መድህን፡ ገብረ፡ ማርያም፡ በታህሳ[ስ]፡ ፲ቀን፡
                              በሰላም፡ ደርሰዋል፡ ለቄስ፡ ብርሐነ፡ [vac] ቄስ፡ ገብረ፡ መድን፡ </q>
                           <note> crude note in Amharic. The note mentions the safe arrival of
                                 <persName ref="https://betamasaheft.eu/PRS12549GabraMadhen">Gabra Madhǝn</persName> [and]
                              Gabra Māryām on 19 December. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#34r">f. 34r</locus>
                           <desc type="AcquisitionNote">: Purchase note.</desc>
                           <q xml:lang="gez">
                              <locus target="#34r">34r</locus>: ዝንቱ፡ መጽሐ[ፍ]፡ ዘተሣየጦ፡ በሁለት፡ ብር፡
                              ዘኢትዮጵያ፡ ሃለቃ፡ ይሕደጎ፡ ሐደራ፡፡ ወንድማሞቼ፡ በሁለት፡ ብር፡ እንድ፡ ትገዙ፡ ዝንቱ፡ ብራና፡ ዘይከውን፡
                              ለትውልደ፡</q>
                           <note> The note mentions <persName role="owner" ref="https://betamasaheft.eu/PRS12556Yehdagwa">halaqā Yǝḥdagwa Ḥādarā</persName> as the buyer of the codex for 2
                              Ethiopian Birr. </note>
                        </item>
                        <item xml:id="e1">- Immediate correction marked by thin lines above and
                           below the word: <locus target="#10r">10r</locus>
                        </item>
                        <item xml:id="e2">- Corrections written interlineally: <locus target="#10v">10v</locus>, 11r, 14v, 15r, 15v, 23v.
 </item>
                        <item xml:id="e3"> - Words or passages erased: <locus target="#32r">32r</locus>.
 </item>
                        <item xml:id="e4"> - Pen trial: <locus target="#2r">2r</locus>.
 </item>
                        <item xml:id="e5"> - Writing exercises: <locus target="#2r">2r</locus>.
 </item>
                        <item xml:id="e6"> - Crude note: <locus target="#1r">1r</locus>.</item>
                     </list>
                  </additions>

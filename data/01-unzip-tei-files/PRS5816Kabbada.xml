      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ከበደ፡ ተሰማ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Kabbada Tasammā</t:persName>
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč </t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               
               <t:occupation type="academic">writer, statesman</t:occupation>
               
               <t:birth when="1902">He was born at <t:placeName ref="https://betamasaheft.eu/LOC2794Efrata">ʾƎfrātā</t:placeName>.</t:birth>
               
               
               
               <t:floruit notBefore="1916" notAfter="1974">He was a courtier of <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</t:persName>. He started his career in the court of 
                  <t:persName ref="https://betamasaheft.eu/PRS10671Zawditu">Zawditu</t:persName> as a scribe in the Ministry of Pen. In <t:date>1925</t:date>, 
                  he was promoted to head of the pages in the Imperial court with the title 
                  <t:persName ref="https://betamasaheft.eu/PRS5816Kabbada">
                     <t:roleName type="title">āzzāž</t:roleName>
                  </t:persName>. 
                  During the Italian occupation (1936-1941), he was in exile in <t:placeName ref="https://www.wikidata.org/entity/Q1218">Jerusalem</t:placeName>. 
                        After liberation, he served in various important government posts until the revolution, in<t:date>1974</t:date>. 
               </t:floruit>
               <t:death when="1985">He died at <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> in <t:date>1985</t:date>.</t:death>
               
               
            </t:person>
            
         </t:listPerson>
         
         
         

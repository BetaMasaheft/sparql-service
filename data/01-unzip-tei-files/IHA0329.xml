               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="9v">1r-9v</locus>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>السَلَام عَلَيْكُمْ الَلَأمْ عَلَيْكُمْ رَسُوْلَ اَلله \ الحَمْدُ لِلهِ رَبُ السَمَاوَاتِ كَنْ نُڠُوڎِ ڟِۏْرأ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus> اَسِتِّ ڟَ بَتَامَيْ ڠَرْسِ اِخْوَانَا \ دَوَإِيْ نَفْسَيْڟَاهَبَلِي شَيطَانَ \ لَفَا نَمَ كَاسَا اَكُمُ اَذَانَا \ تمت باالخيرِ</explicit>
                     <note>Subject of the text: preaching
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="10r" to="10v">10r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>يا رسول خلْقِي رَبَرَيْدَا كَكَسَان أَرْڠَمُوْ \ يا رسول اِسْمَانِ فَايَمَ اَبُوْنَا أَدَامُوْيا رسول عَزَلِ بَافَمِي اَدْمَدْ مُكَلَ مُوْ
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>شَذْسَيِدَا مَتَا اِبْادَاتِ اَكَنَ بَئَنِي سَيِدُ السَا \ داتِ شبهَا نَمَا ڠَيْسَاڠَرَحَرَا مَاتِ</explicit>
                     <note>Subject of the text: praise of the Prophet
</note>
                  </msItem>
                  <msItem xml:id="ms_i2">

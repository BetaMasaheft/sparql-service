               <msContents>
                  <summary>I) Maftǝḥe śǝrāy “Undoing of Charms”: 21 protective prayers (fols.
                     1r-24r).</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="24r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1824Mafteh">Maftǝḥe śǝrāy “Undoing of Charms”:
                        15 protective prayers</title>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">24.0</measure> folios, of which
                              <measure unit="leaf" type="blank"/> blank 24v, in <measure unit="quire">1.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">130</height>
                              <width unit="mm">110</width>
                              <depth unit="mm">15</depth>
                           </dimensions>
                        </extent>
                        <foliation>Foliated by the Ethio-SPaRe team</foliation>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">22</dim>
                                 I(22+2/fols. 1r-24v).</item>
                              <item xml:id="q2">
                                 <dim unit="leaf">2</dim>
                                 The bifolio
                                 made of fols. 18 and 19 is an eccentric insertion.</item>
                           </list>
                        </collation>
                        <condition key="deficient">The sewing is damaged.
 The ink is abraded,
                           parts of the text are illegible.
 The leather cover is damaged and
                           stained with white paint.
 The parchment is of poor quality; the size
                           of the fols. varies greatly.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" writtenLines="15">
                           <dimensions unit="mm">
                              <height>105</height>
                              <width>70</width>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">5</dim>
                              <dim type="bottom">10</dim>
                              <dim type="right">7</dim>
                              <dim type="left">18</dim>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <note>All data for <locus target="#2r">2r</locus>. The size and layout of
                              the fols. differ throughout the Ms.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Ruling and pricking are visible.</ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are visible.</ab>
                           <ab type="pricking"> Ruling pricks are visible.</ab>
                           <ab type="ruling"> The upper line is written above the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careless, crude. Ligatures, peculiar feature of writing
                           the letter ዝ; the loops of መ are separated in all vowel
                           orders.</seg>
                        <seg type="ink">Black, red (vivid scarlet).</seg>
                        <date>19 th century.</date>
                        <seg type="rubrication">Divine names; several lines on the incipit of each
                           prayer; elements of the punctuation signs; elements of Ethiopic
                           numerals.</seg>
                     </handNote>
                     
                  </handDesc>
                  <decoDesc>

                     <decoNote type="drawing" xml:id="d1">
                        <locus target="#4r">f. 4r: </locus>
                        <desc>“Seal of Solomon”, angelic script.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d2">
                        <locus target="#5v">f. 5v: </locus>
                        <desc>Angel.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d3">
                        <locus target="#">f.14v: </locus>
                        <desc>Geometric motifs.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d4">
                        <locus target="#15v">f. 15v: </locus>
                        <desc>Cross, “magic” letters.</desc>
                     </decoNote>
                     <decoNote type="drawing" xml:id="d5">
                        <locus target="#17">f. 17: </locus>
                        <desc>Two persons and two angels surrounding a cross.</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1"><desc>- Space for the rubricated name of the owner is left unfilled throughout the Ms.</desc></item>

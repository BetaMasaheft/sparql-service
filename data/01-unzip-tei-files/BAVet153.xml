                    <msContents>
                      <summary/>
                      
                      <msItem xml:id="ms_i1">
                        <locus from="3r" to="54r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1975Mashaf">Maṣḥafa ṭǝmqat</title>
                        <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">
                         <locus target="#3r"/>
                         በስመ፡ አብ፡ <gap reason="ellipsis"/> ንቀድም፡ በረድኤተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ጽሒፈ፡ መጽሐፈ፡ ጥምቀት። 
                         ቀዳሚሁ፡ ለውእቱ፡ ይቀውሙ፡ ሕፃናት፡ ውስተ፡ ቤተ፡ ክርስቲያን፡ ወትብል፡ <sic>መዝሙር፡</sic>
                         ዘ፶<supplied reason="omitted">፡</supplied>
                         ወጸሎተ፡ አኰቴት፨ ወጸሎተ፡ ዕጣን። እግዚአብሔር፡ ዘተወከፍከ፡ ቍርባነ፡ አቤል፡ <sic>ጸድቅ፨</sic> ወመሥዋዕተ፡ ኖኅ፡ 
                         ወአብርሃም፡ ወዕጣነ፡ አሮን፡
                         ወዘካርያስ፨ ተወ<add place="above">ከ</add>ፍ፡ ኀቤከ፡ ዘንተ፡ ቍርባነ፡ እምእዴነ፨
                       </incipit>
                        <explicit xml:lang="gez">
                          <locus target="#54r"/>
                          ተዘከር፡ እግዚኦ፡ ኵሎ<supplied reason="omitted">ሙ</supplied>፡ ሊቃነ፡ ጳጳሳት፡ ወኤጲስ፡ ቆጶሳት፡
                          ቀሳውስት፡ ወዲያቆናት፡ አናጕንስጢስ፡ ወመዘምራን፡ ደናግል፡ ወመነኮሳት፡ እድ፡ ወአንስት፡ አዕሩግ፡ ወሕፃናት፡ ወኵሎሙ፡ ሕዝበ፡ 
                          ክርስቲያን፡ አጽንዖሙ፡ በሃይማኖተ፡ ክርስቶስ፡ ተዘከሮሙ፡ እግዚኦ፡ ወፍትሖሙ፡ ለኵሎሙ፡ ለዓለመ፡ ዓለም፡ አሜን፨
                          ወአሜን፡ ለይኩን፨ ለይኩን፨ <seg type="supplication">ዕቀበኒ፡ ለገብርከ፡
                            <persName role="owner" ref="https://betamasaheft.eu/PRS14406NewayaM">ንዋየ፡ ማርያም።</persName></seg>
                        </explicit>
                        <colophon xml:id="coloph1" xml:lang="gez">
                          <locus target="#54r"/>
                          ዝንቱ፡ መጽሐፍ፡ <lb/> ተጽሕፈ፡ 
                          በ<date when="1924" when-custom="1916" calendar="ethiopian">፲፻ወ<lb/>በ፱፻፲፮ቱ፡ ዓመ<lb/>ተ፡ ምሕረት፡</date> 
                          በእደ፡ ገብሩ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS14407WaldaM">ወልደ፡ <lb/>መስቀል።</persName> 
                          <date calendar="evangelists">በዘ<lb/>መነ፡ <del rend="effaced"/> ዮሐንስ፡ ወንጌላ<lb/>ዊ፡</date>
                          ለዓለመ፡ ዓለም፡ አሜን።
                        </colophon>
                      </msItem>

                 <persName xml:lang="gez" xml:id="n1" type="birth">አፈወርቅ፡ ወልደ፡ ማርያም፡</persName>
                 <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAfawarq Walda Māryām</persName>
                  <persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ መንዝር፡</persName>
                  <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbā Manzǝr</persName>
               
                <nationality type="Ethiopia"/>
               <occupation type="political"> civil servant</occupation>
               <birth when="1868">He was born at <placeName ref="https://betamasaheft.eu/LOC2008Bulga">Bulga</placeName> in <date>1868</date>. </birth>
               <floruit notBefore="1909" notAfter="1955">Having received a church education, he began his career as a palace clerk.
               In <date>1913</date> he was appointed as "Minister of the Pen". He lost his post as a consequence of civil
             uprisings in <date>1918</date>. In <date>1922</date> he was appointed Minister of Post, Telephone and Telegraph and
             Minister of Agriculture. In the <date>1930s</date> he became President of the House of Deputies. During the Fascist
             invasion in <date>1935-1936</date> he fought at the northern front. After two years of imprisonment in Italy,
             he was appointed to senate.
        </floruit>
         <death when="1955"/>
            </person>

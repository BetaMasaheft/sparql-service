      <t:body>
         <t:listPerson>
            <t:person sex="1">

                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ቆዝሞስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Qozmos</t:persName>

                  <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="Judaism"/>
                  <t:occupation type="ecclesiastic">monk</t:occupation>
               <t:floruit notBefore="1300" notAfter="1399">He was a monk of the 14th century who came from
                  <t:placeName ref="https://betamasaheft.eu/LOC1310Aksum">ʾAksum</t:placeName>
                  to the monastery called <t:placeName ref="https://betamasaheft.eu/LOC6457Zazo">Zāzo</t:placeName>.
                  <t:persName ref="https://betamasaheft.eu/PRS8041Qozmos">Qozmos</t:persName>
                  was an extreme ascetic who lived in a separate cell and refused all cooked food, as well as the Eucharist.
                  He was highly accepted by those who practiced the religion of Jews in <t:placeName ref="https://betamasaheft.eu/LOC5671Semen">Semen</t:placeName>
                  and <t:placeName ref="https://betamasaheft.eu/LOC5498Sallam">Ṣallamt</t:placeName> who viewed him as a semi-divine. He was the enemy of
                  <t:persName ref="https://betamasaheft.eu/PRS3429DawitII">Dāwit II</t:persName>. Qozmos is known from the <t:ref type="work" corresp="https://betamasaheft.eu/LIT1511GadlaY">Gadla Yāfqǝranna ʾƎgziʾ</t:ref>. </t:floruit>

               </t:person>
               
         </t:listPerson>


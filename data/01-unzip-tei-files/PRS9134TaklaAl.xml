      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ተክለ፡ አልፋ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Takla ʾAlfā</t:persName>

               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">እንድርያስ፡</t:persName>

               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾƎndrǝyās</t:persName>
            
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
         
         
               <t:floruit notBefore="1500" notAfter="1550">He was a saintly monk from 
                  <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName> who was the abbot of  monastery of
                  <t:placeName ref="https://betamasaheft.eu/LOC2687DimaGi">Dimā Giyorgis</t:placeName>. 
                  When he was 30 years old, <t:persName ref="https://betamasaheft.eu/PRS9134TaklaAl">Takla ʾAlfā</t:persName> 
                  was appointed as abbot of <t:placeName ref="https://betamasaheft.eu/LOC2687DimaGi">
                     Dimā Giyorgis</t:placeName> by 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>
                  at the suggestion of 
                  <t:persName ref="https://betamasaheft.eu/PRS6774Marqos">
                     <t:roleName type="title">ʾabuna</t:roleName> Mārqos [I]</t:persName>, the then metropolitan. 
                  Thus, he headed the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2687DimaGi">Dimā Giyorgis</t:placeName> during the turbulent periods of the wars of 
                  <t:persName ref="https://betamasaheft.eu/PRS1500Ahmad">ʾAḥmad</t:persName>. </t:floruit>
               <t:death>He died at the age of 80 and was buried in the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2687DimaGi">Dimā Giyorgis</t:placeName>
               </t:death>
            </t:person>  
            
         </t:listPerson>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ተወጥነ፡ ለመልክእከ፡ ሰላሙ፨</l>
                  <l n="2">እንዘ፡ መንፈስ፡ ቅዱስ፡ ይረድእ፡ ወያበጽሕ፡ እስከ፡ ተፍጸሙ፨</l>
                  <l n="3">ገላውዴዎስ፡ ባርክ፡ መንግሥተ፡ ገላውዴዎስ፡ ለለጌሠሙ፨</l>
                  <l n="4">ምስለ፡ መንግሥትከ፡ ንግሡ፡ ወምስለ፡ ስምከ፡ ስሙ፨</l>
                  <l n="5">እስመ፡ ተሳተፈ፡ እምፀሐይ፡ ቀዲሙ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝከረ፡ ስምከ፡ ውስተ፡ አፈ፡ ኵሎሙ፡ መሃይምናን፨</l>
                  <l n="2">ዘጥዑም፡ ፈድፋደ፡ እምዘትረ፡ ጸቃውዕ፡ ወወይን፨</l>
                  <l n="3">ገላውዴዎስ፡ መሥዋዕት፡ ወመዓዛ፡ ቀዱስ፡ ቍርባን፨</l>
                  <l n="4">እስከ፡ እሤልጥ፡ ቃለ፡ ሰላም፡ ዘመልክእከ፡ ኵሎን፨</l>
                  <l n="5">ውስተ፡ እዝነ፡ ልብየ፡ ይድምፅ፡ ረድኤትከ፡ ቀርን፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ እንተ፡ በዲቤሁ፡ ነፍነፈ፨</l>
                  <l n="2">ጠለ፡ መንፈስ፡ ቅዱስ፡ ቀዳሲ፡ ከመ፡ ሰሎሞን፡ ጸሐፈ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ ዘተጋደልከ፡ ትሩፈ፨</l>
                  <l n="4">ኦወሬዛ፡ ትዕግሥተ፡ ገድልከ፡ ዘልፈ፨</l>
                  <l n="5">ጽጌ፡ ብሩር፡ ይመስል፡ ወወርቀ፡ ንጡፈ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለርእስከ፡ ዘቅብዓ፡ መስኮት፡ አጥለሎ፨</l>
                  <l n="2">በአከሊለ፡ ሞገስ፡ ወክብር፡ አምሳለ፡ ወልታ፡ ጽድቅ፡ ዘይኬልሎ፨</l>
                  <l n="3">ገላውድዎስ፡ ሥርግው፡ በትርሲተ፡ ንጽሕ፡ ወተደንግሎ፨</l>
                  <l n="4">ዘይገዝም፡ ጕንደ፡ ወእም፡ አበሳየ፡ ኵሎ፨</l>
                  <l n="5">ጕድበ፡ ምሕረት፡ ይሩጽ፡ በእዴከ፡ ዘዘሎ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለገጽከ፡ ብርሃነ፡ ቅድስት፡ ሥላሴ፨</l>
                  <l n="2">ዘተሠውጠ፡ ቦቱ፡ ከመ፡ ገጸ፡ ነቢይ፡ ሙሴ፨</l>
                  <l n="3">ገላውዴዎስ፡ ፀሐይ፡ ወንጉሠ፡ ሌሊት፡ ብናሴ፨</l>
                  <l n="4">በዓፀደ፡ ተድላ፡ አመ፡ ትከውን፡ ነጋሤ፨</l>
                  <l n="5">ረስየኒ፡ ግብረ፡ ወምእመነ፡ ብእሲ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ሰላም፡ ለቀራንብቲከ፡ መንታ፨</l>
                  <l n="2">ነገረ፡ ጥበብ፡ ሥውረ፡ እንተ፡ ለዘልፍ፡ የሐታ፨</l>
                  <l n="3">ገላውዴዎስ፡ ኃያል፡ ተወልታዊ፡ መስቀል፡ ዘጎልጎታ፨</l>
                  <l n="4">ሴስየኒ፡ እከለ፡ መንፈስ፡ ስለ፡ ይጸብሕ፡ ሳኒታ፨</l>
                  <l n="5">ሰብሐተ፡ ከብርከ፡ እንብብ፡ በብዙኅ፡ ጾታ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለአዕይንቲከ፡ እለ፡ ኢኮና፡ ሐማሜ፨</l>
                  <l n="2">እመ፡ ተደለወ፡ ለገባአት፡ ዲናረ፡ ዐስበ፡ ጽድቅ፡ ዲድርክሜ፨</l>
                  <l n="3">ገላውዴዎስ፡ ኅሩይ፡ እምሳለ፡ ጳውሎስ፡ ዘብሔረ፡ ሮሜ፨</l>
                  <l n="4">አይድዐኒ፡ ምክረ፡ ጥበብ፡ ወነገረ፡ ሕይወት፡ ቀጥሜ፨</l>
                  <l n="5">እምገነተ፡ ስምከ፡ እኩን፡ አፈወ፡ ቀሳሜ፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለአእዛኒከ፡ ዘያጸምኣ፡ ስእለቶ፨</l>
                  <l n="2">ለነዳይ፡ ብእሲ፡ ዘጥቅመ፡ ምንዳቤ፡ ዓገቶ፨</l>
                  <l n="3">ገላውዴዎስ፡ ነዓ፡ ሶበ፡ ጸዋዕኩከ፡ በተሐግርቶ፨</l>
                  <l n="4">ከመ፡ ትምርሐኒ፡ ወታርአየኒ፡ ፍኖቶ፨</l>
                  <l n="5">ለዘብእሲ፡ ጥበብ፡ ሐነጸ፡ ዲበ፡ ኰነሕ፡ ቤቶ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለመላትሒከ፡ ከመ፡ ቃለ፡ መጽሐፍ፡ ዚነወ፨</l>
                  <l n="2">ዘርኄ፡ ወረዳ፡ እለ፡ ይፈርያ፡ አፈወ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ እንተ፡ ደምከ፡ ተክዕወ፨</l>
                  <l n="4">በላህበ፡ ጌጋይ፡ አመ፡ ፈድፋደ፡ መጽለወ፨</l>
                  <l n="5">ላዕለ፡ መላትሕየ፡ ንዛን፡ ላህየከ፡ ቅድወ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ በአእናፊከ፡ ዕፍረተ፡ ስምዓ፡ ጽድቅ፡ ወገድል፨</l>
                  <l n="2">ዘአፄነዋ፡ ፈድፋደ፡ አምሳለ፡ አበሜ፡ ወኮል፨</l>
                  <l n="3">ገላውዴዎስ፡ ፍሡሕ፡ ወወሬዛ፡ መንግሥት፡ ኃያል፨</l>
                  <l n="4">ናዝዘኒ፡ በፍሥሓከ፡ እምብካየ፡ ብዙ፡ ኃጕል፨</l>
                  <l n="5">አመ፡ ለቃለ፡ አብ፡ ይሰፋሕ፡ ሞጣሕቱ፡ በቀል፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለከናፍሪከ፡ እለ፡ ያፈቅራ፡ ነቢበ፨</l>
                  <l n="2">ነገረ፡ የውሃት፡ ዘርግብ፡ ወዘአርዌ፡ ምድር፡ ጥበበ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ ዘተጋደልከ፡ ዕፁበ፨</l>
                  <l n="4">ምስለ፡ አብያጺከ፡ ጊዜ፡ ትገብር፡ ከብካበ፨</l>
                  <l n="5">ፍርፋየ፡ ስብሐቲከ፡ አጽግብ፡ ከርሥየ፡ ርኁበ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለአፉከ፡ ዘጣዖታተ፡ ዝሰፈ፨</l>
                  <l n="2">እለ፡ ኢይነቡ፡ ሕቀ፡ እንዘ፡ ቦሙ፡ አፈ፨</l>
                  <l n="3">ገላውዴዎስ፡ ባሕርይ፡ ዘኢትትከደን፡ ሰይፈ፨</l>
                  <l n="4">ነኰርኳርከ፡ ዝዋካ፡ አመ፡ ምድረ፡ ጽልመት፡ ኃለፈ፨</l>
                  <l n="5">ብርሃነ፡ ሕይወት፡ በሴድራ፡ ተርፈ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለአስናኒከ፡ በኆኅተ፡ ሥጋከ፡ ሕንጻ፨</l>
                  <l n="2">ማዕዎ፡ ጽድቀ፡ ቃል፡ ዝኮና፡ እምነቢበ፡ ኵሉ፡ ዓመፃ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ ወትሩፈ፡ ገድል፡ አምኆፃ፨</l>
                  <l n="4">ኵነኒ፡ ቀስተ፡ መዊዕ፡ ወዘረድኤት፡ አሕዋ፨</l>
                  <l n="5">አምነ፡ ልሳን፡ ቀታሊት፡ ዘግሩም፡ ድምፃ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰባም፡ ለልሳንከ፡ ድኅረ፡ እምሕሊና፡ ሠረፀ፨</l>
                  <l n="2">ዘቃለ፡ ሐሤት፡ ይወልድ፡ ወመስተፍሥሔ፡ ልብ፡ ድምፀ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ አንተ፡ ሠለጥከ፡ ምርዋፀ፨</l>
                  <l n="4">ላዕሌየ፡ ሲዘቈጸሩ፡ ምስለ፡ አማዑቶሙ፡ ገጸ፨</l>
                  <l n="5">በክሳደ፡ ነፍሶሙ፡ ስቅል፡ ዘአድግ፡ ማኅረፀ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለቃልከ፡ ዘጣዕመ፡ ድምፁ፡ ነከራ፨</l>
                  <l n="2">ዘይኄይስ፡ እምድምፀ፡ አርጋኖን፡ ወእንዚራ፨</l>
                  <l n="3">ገላውዴዎስ፡ መክብብ፡ ዘሰማዕታተ፡ ጽድቅ፡ እለ፡ መርቆራ፨</l>
                  <l n="4">እንዘ፡ ያነክሩ፡ ዘተዓግሥከ፡ መከራ፨</l>
                  <l n="5">በዓለ፡ ስምከ፡ በሰማይ፡ ይገብሩ፡ ሐራ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለእስትንፋስከ፡ እንተ፡ ይነፍሕ፡ መዓዛ፨</l>
                  <l n="2">መሳከወ፡ ልብከ፡ ቅቡዕ፡ በደመ፡ መስኮት፡ ከመ፡ ራግዛ፨</l>
                  <l n="3">ገላውዴዎስ፡ ኃያል፡ በአርማኃ፡ በቀል፡ ተረጊዛ፨</l>
                  <l n="4">እምጽንዕከ፡ ወእምትብዕከ፡ መዋዒ፡ ወሬዛ፨</l>
                  <l n="5">አድያመ፡ ቍዝ፡ ቀትረ፡ ተበርበረት፡ ጋዛ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለጕርዔከ፡ ዘዝክሩ፡ መዓርዒር፨</l>
                  <l n="2">እምዝክረ፡ ወይን፡ ሥሙር፨</l>
                  <l n="3">ገላውዴዎስ፡ ፌማ፡ ፍጹመ፡ አእምሮ፡ ወምክር፨</l>
                  <l n="4">እንዘ፡ አንተ፡ ወልደ፡ ንጉሥ፡ ወዘመደ፡ ፍጥረት፡ ክቡር፨</l>
                  <l n="5">እፎኑ፡ ተዳደቀከ፡ ምናኔ፡ ኀሡር፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ሰላም፡ ለክሳድከ፡ ዘአርማስቆስ፡ አምሳሉ፨</l>
                  <l n="2">በዝግና፡ ባሕርይ፡ ከቡረ፡ ዘተሠርገወ፡ እምላዕሉ፨</l>
                  <l n="3">ገላውዴዎስ፡ ፍቁር፡ ሰልበ፡ ፍጥረታት፡ ኵሉ፨</l>
                  <l n="4">አምረኒ፡ ፍኖተ፡ ጽድቅ፡ እንዘ፡ ታቀድም፡ ወታተሉ፨</l>
                  <l n="5">አመ፡ መሠገርተ፡ ሞት፡ ቅድሜየ፡ ተከሉ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለመትከፍትከ፡ እንተ፡ ተፅዕነ፡ ዲቤሁ፨</l>
                  <l n="2">አርዑተ፡ ኢየሱስ፡ ሠናይ፡ ወቀሊል፡ ጾረ፡ ዚአሁ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሐሊ፡ ሲሳየ፡ መፍቅድየ፡ ለለጽባሑ፨</l>
                  <l n="4">ሀካይስ፡ እንተ፡ ኃዋፈ፡ እዴሁ፨</l>
                  <l n="5">ደሞ፡ ይሰቲ፡ ወይበልዕ፡ ሥጋሁ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ሰላም፡ ለዘባንከ፡ እንተ፡ አፍቀረ፡ ተመይጦ፨</l>
                  <l n="2">እምኅራመ፡ ጣዖት፡ ዘወርቅ፡ ዘእደ፡ ነሀቢ፡ ዘበጦ፨</l>
                  <l n="3">ገላውዴዎስ፡ ፍንው፡ መልእከተ፡ ክርስቶስ፡ ለአሥልጦ፨</l>
                  <l n="4">ከመ፡ እኩን፡ ገብረ፡ ዚአከ፡ እንዘ፡ አልብየ፡ ተፈልጦ፨</l>
                  <l n="5">ለደመ፡ ስምዕከ፡ ረስየኒ፡ ሤጦ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለእንግድዓከ፡ ምዕላደ፡ ልቡና፡ ዘኮነ፨</l>
                  <l n="2">ወረሰየ፡ ዓዲ፡ ሎግ፡ ምክር፡ ከዳነ፨</l>
                  <l n="3">ገላውዴዎስ፡ ዕፍረት፡ አንተ፡ ትምዕዝ፡ ዕጣነ፨</l>
                  <l n="4">አድኅነኒ፡ እምአፈ፡ ፀር፡ እንተ፡ የሐቂ፡ አስናነ፨</l>
                  <l n="5">አመ፡ ላዕሌየ፡ አንሥአ፡ ዓቢየ፡ ተስናነ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለሕፅንከ፡ ምርፋቀ፡ ጥበብ፡ ኅሪት፨</l>
                  <l n="2">ዘሕገጊሃ፡ ወንጌል፡ ወሥርዓታቲሃ፡ ኦሪት፨</l>
                  <l n="3">ገላውዴዎስ፡ ግሥ፡ እምአፍቅሮ፡ ጥሪት፨</l>
                  <l n="4">ውስተ፡ ዓፀድከ፡ ወግነትከ፡ መፍሪት፨</l>
                  <l n="5">ትምርሐኒ፡ ለበዊአ፡ ልብከ፡ ጽሪት፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ ለአእዳዊከ፡ እለ፡ ሠረዋ፡ አፅራረ፨</l>
                  <l n="2">ንጉሡ፡ አረሚ፡ ዘቍዝ፡ አመ፡ ማዕሌተ፡ ገብረ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሠርዌ፡ ወርእሰ፡ አእላፍ፡ ወትረ፨</l>
                  <l n="4">ጊዜ፡ ቀተሉከ፡ ምስለ፡ ፊቅጦር፡ ኅቡረ፨</l>
                  <l n="5">ሰብአ፡ አንጾኪያ፡ ወግብጽ፡ በከዩ፡ መሪረ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለመዛርዒከ፡ በሥምረተ፡ ክርስቶስ፡ ሊቅ፨</l>
                  <l n="2">እምአጕናደ፡ አባል፡ ዘዓርጋ፡ አምሳለ፡ ሠናያን፡ አዕጹቅ፨</l>
                  <l n="3">ገላውዴዎስ፡ ጽጌ፡ ወሕንባበ፡ ዛ ረዳ፡ ዘሐይቅ፨</l>
                  <l n="4">ይኄይሰኒ፡ ለገብርከ፡ ሕግ፡ አፉከ፡ ዘጽድቅ፨</l>
                  <l n="5">እምነ፡ አእላፍ፡ ብሩር፡ ወቀይሕ፡ ወርቅ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ሰላም፡ ለዘዚአከ፡ ኲርናዕ፨</l>
                  <l n="2">አመ፡ ዕለተ፡ ዐብዕ፡ ዘጸንዓ፡ አምሳለ፡ አርዌ፡ ብርት፡ ጽኑዕ፨</l>
                  <l n="3">ገላውዴዎስ፡ ፍሡሕ፡ ወያርብታዊ፡ ተባዕ፨</l>
                  <l n="4">ይኩነኒ፡ ማየ፡ ጥምቀት፡ ለብእሲ፡ ኃጥእ፨</l>
                  <l n="5">ነ፡ እምዓይነ፡ በቅጥር፡ እኁከ፡ ዘውኅዘ፡ አንብዕ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለእመትከ፡ ከመ፡ አዘዘ፡ ክርስቶስ፨</l>
                  <l n="2">እንተ፡ አምጣኒሃ፡ ሠፈረ፡ ለኢየሩሳሌም፡ መቅደስ፨</l>
                  <l n="3">ገላውዴዎስ፡ ንጉሥ፡ በዕለተ፡ ኵነኔ፡ መብዕስ፨</l>
                  <l n="4">ጸግወኒ፡ ሐመረ፡ ተድላ፡ ዘኢየሀውኮ፡ ነፋስ፨</l>
                  <l n="5">ምስሌከ፡ ለኃዲር፡ ኀበ፡ ዘዓን፡ ወመርስ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለእራኃቲከ፡ እለ፡ ይሰፍሓ፡ ለዘልፍ፨</l>
                  <l n="2">ለውሂበ፡ ሀብታት፡ ብዙኅ፡ ወጸግዎ፡ ጸጋ፡ ትሩፍ፨</l>
                  <l n="3">ገላውዴዎስ፡ መልአክ፡ ወዘውግ፡ ትጉሃን፡ አእላፍ፨</l>
                  <l n="4">ዘአስተርኢ፡ ቅድመ፡ ገጽየ፡ እንዘ፡ ትሠርር፡ በክንፍ፨</l>
                  <l n="5">አመ፡ ቀርነ፡ ጽራሕ፡ ይነፍሕ፡ ሚካኤል፡ ዖፍ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለአጻብኢከ፡ ዘኍላቌሆን፡ ዓሥር፨</l>
                  <l n="2">እለ፡ ሥርግዋት፡ እማንቱ፡ በኅልቀተ፡ ሰላም፡ ወፍቅር፨</l>
                  <l n="3">ገላውዴዎስ፡ አዚዝ፡ መኰንነ፡ ዕበይ፡ ወክብር፨</l>
                  <l n="4">እስመ፡ አሥጠመኒ፡ ፈለግ፡ ኃጢአት፡ ወነውር፨</l>
                  <l n="5">በሰሪቦቱ፡ ትርድአኒ፡ ምድር፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለአጽፋረ፡ እዴከ፡ ዘኑባሬሆን፡ ሉዓሌ፨</l>
                  <l n="2">በከተማ፡ አጽባዕት፡ ዓሥር፡ እንዘ፡ ያበርሃ፡ ከመ፡ ቢረሌ፨</l>
                  <l n="3">ገላውዴዎስ፡ ተቅዋም፡ ወወጾረ፡ ትእዛዝ፡ ጽሌ፨</l>
                  <l n="4">እንዘ፡ ይትአመኑ፡ አድኅኖተከ፡ ከሀሌ፨</l>
                  <l n="5">ሙሴ፡ ወአሮን፡ ጸሐፉ፡ ኩፋሌ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለገቦከ፡ ዘተዓገሠ፡ ርግዘተ፨</l>
                  <l n="2">በአፈ፡ ኲናት፡ በሊሕ፡ እስከ፡ ሠለጥከ፡ መዊተ፨</l>
                  <l n="3">ገላውዴዎስ፡ ንጹሕ፡ ዘኢተአምር፡ ርስሐተ፨</l>
                  <l n="4">ርእዮሙ፡ ጸላእትነ፡ ከመ፡ ይትኃፈሩ፡ ግብተ፨</l>
                  <l n="5">ግበር፡ ላዕሌነ፡ ሠናየ፡ ትእምርተ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለከርሥከ፡ መብልዓ፡ ጣዖታት፡ ዘከደ፨</l>
                  <l n="2">ረኃበ፡ ኵነኔ፡ ማሕምም፡ እንዘ፡ ይገብር፡ ማዕደ፨</l>
                  <l n="3">ፀባኢተ፡ አርማን፡ ወቍዝ፡ አመ፡ አንሥኡ፡ መራደ፨</l>
                  <l n="4">ገላውዴዎስ፡ ጽንዓ፡ ኃይልከ፡ ጊዜ፡ ከመ፡ እሳት፡ ነደ፨</l>
                  <l n="5">አምሳለ፡ ትንታጋት፡ ጤሱ፡ ወኮኑ፡ ሐመደ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለልብከ፡ ዘተመሰለ፡ በአብ፨</l>
                  <l n="2">ሕሊና፡ አእምሮ፡ ዘይወልድ፡ ወምክረ፡ ጥበብ፨</l>
                  <l n="3">ገላውዴዎስ፡ ጸልል፡ በአክናፊከ፡ ዘላህብ፨</l>
                  <l n="4">መልዕልተ፡ ርእስየ፡ እምሐሩረ፡ ጌጋይ፡ ዕፁብ፨</l>
                  <l n="5">እስመ፡ መልአከ፡ ምክር፡ እንተ፡ ዘስሙ፡ ኪሩብ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ሰላም፡ ለኵልያቲከ፡ ከመ፡ መዘምራን፡ ነበቡ፨</l>
                  <l n="2">እንተ፡ ፈተኖን፡ ልዑል፡ በማኅቶተ፡ ፅዱል፡ ጥበቡ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሙሴ፡ ለእግዚአብሔር፡ መጋቤ፡ ሕዝቡ፨</l>
                  <l n="4">ገዳማት፡ በእንቲአከ፡ ጠላተ፡ በረከት፡ ጸግቡ፨</l>
                  <l n="5">ዕንጐታትኒ፡ መዓዛ፡ ወሀቡ፨</l>
               </lg>
               <lg type="stanza" n="34">
                  <l n="1">ሰላም፡ ለሕሊናከ፡ እምሥርወ፡ ልብ፡ ዘዓርገ፨</l>
                  <l n="2">ምሕረተ፡ ነዳያን፡ የሐሊ፡ ወፍትሐ፡ ምስኪናን፡ ደርገ፨</l>
                  <l n="3">ገላውዴዎስ፡ አንግፍ፡ እምከሳዴ፡ ነፍስየ፡ ጋገ፨</l>
                  <l n="4">ሶበ፡ አክበደ፡ ላዕሌየ፡ አርዑተ፡ ቅኔሁ፡ ጸዋግ፨</l>
                  <l n="5">አርዌ፡ ሕማም፡ ጸዋግ፡ ዘይልሕስ፡ ምስሐገ፨</l>
               </lg>
               <lg type="stanza" n="35">
                  <l n="1">ሰላም፡ ለአማዑቲከ፡ ቅድመ፡ ገጸ፡ ኵሉ፡ ተዓይን፨</l>
                  <l n="2">በእሳተ፡ ሃይማኖት፡ ዘነደ፡ ከመ፡ ደርሳይን፨</l>
                  <l n="3">ገላውዴዎስ፡ ጽጌ፡ ወአስካለ፡ ተድላ፡ ዘወይን፨</l>
                  <l n="4">ጊዜ፡ ቀሰሙከ፡ ባ ወዓልተ፡ ኵነኔ፡ ወደይን፨</l>
                  <l n="5">መላእክተ፡ ሰማይ፡ አውኃዙ፡ አንብዓ፡ እምዓይን፨</l>
               </lg>
               <lg type="stanza" n="36">
                  <l n="1">ሰላም፡ ለንዋየ፡ ውሥጥከ፡ ዘኑባሬሆን፡ አንግዳ፨</l>
                  <l n="2">ከመ፡ ቀርነ፡ ነጌ፡ ሐዋዝ፡ ውስተ፡ ከርሥከ፡ ሰሌዳ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሥርግው፡ በአክሊለ፡ ሞገስ፡ ፀዓዳ፨</l>
                  <l n="4">ኢትትሐየይ፡ ሐወዖትየ፡ ምስለ፡ ጊዮርጊስ፡ ዘልዳ፨</l>
                  <l n="5">እመእደ፡ ጸላኢ፡ ወፀር፡ ለነፍስየ፡ ሮዳ፨</l>
               </lg>
               <lg type="stanza" n="37">
                  <l n="1">ሰላም፡ ለዓንብርትከ፡ አምሳለ፡ ማዕከከ፡ ፍሑቅ፨</l>
                  <l n="2">ወአርአያ፡ ማኅተም፡ ኅርው፡ እንተ፡ ተግበረ፡ እምወርቅ፨</l>
                  <l n="3">ገላውዴዎስ፡ አብላ፡ ወብርሃነ፡ ሰማይ፡ ምጡቅ፨</l>
                  <l n="4">ይደምሰሱ፡ ቅድመ፡ ገጽየ፡ በጸዳልከ፡ መብረቅ፨</l>
                  <l n="5">አጋንንተ፡ ጽልመት፡ ዘቀትር፡ ወጸዋግ፡ ድድቅ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለሐቌከ፡ እንዘ፡ ይቀንት፡ መዊአ፨</l>
                  <l n="2">ውስተ፡ ከብካበ፡ ወልድ፡ መርዓዊ፡ ምስለ፡ ሥነ፡ ብርሃን፡ ዘቦአ፨</l>
                  <l n="3">ገላውዴዎስ፡ ቅቱል፡ እምድረ፡ ሙላድከ፡ አፍአ፨</l>
                  <l n="4">ጽድቅከ፡ ወኂሩትከ፡ አመ፡ ርኅበ፡ ዓለም፡ መልአ፨</l>
                  <l n="5">አምዐይነ፡ ሞት፡ ወሲኦል፡ ፍሥሓ፡ ተኀብአ፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ሰላም፡ ለአቍያጺከ፡ ዘተመሰላ፡ ድንባዘ፨</l>
                  <l n="2">ታቦተ፡ ሥጋ፡ ይጹራ፡ አንዘ፡ የዓቅባ፡ ትአዛዘ፨</l>
                  <l n="3">ገላውዴዎስ፡ ቅቡዕ፡ ዕፍረተ፡ ቅዳሴ፡ ምዑዘ፨</l>
                  <l n="4">ኲናተ፡ ሕማም፡ ጊዜ፡ ሥጋከ፡ ረገዘ፨</l>
                  <l n="5">አንብዐ፡ መላእከት፡ ወሰብእ፡ ከመ፡ ማይ፡ ውኅዘ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ሰላም፡ ለአብራኪከ፡ ዘኢፈቀዳ፡ አስተብርኮ፨</l>
                  <l n="2">ለምስል፡ ዘወርቅ፡ ዘእደ፡ ነሀቢ፡ ሰበኮ፨</l>
                  <l n="3">ገላውዴዎስ፡ ሰማዕት፡ ለአምላከ፡ ሰማይ፡ ዘታመልኮ፨</l>
                  <l n="4">ባርከኒ፡ ለጽሙድከ፡ አመ፡ ጊዜ፡ ንጹሕ፡ ተልእኮ፨</l>
                  <l n="5">ከመ፡ ለወልዱ፡ ይሁዳ፡ ያዕቆብ፡ ባረኮ፨</l>
               </lg>
               <lg type="stanza" n="41">
                  <l n="1">ሰላም፡ ለአእጋሪከ፡ ከመ፡ ሩጸተ፡ ዖፍ፡ ወሐፅ፨</l>
                  <l n="2">ውስተ፡ ዓውደ፡ ስምዕ፡ ይሥርራ፡ ዘአስተፋጠና፡ ሰረዊጽ፨</l>
                  <l n="3">ገላውዴዎስ፡ እኩት፡ ውስተ፡ አናቅጽ፨</l>
                  <l n="4">ሶበ፡ ይቀርቡኒ፡ መላእክተ፡ ላኳ፡ ወድንጽ፨</l>
                  <l n="5">መድኃኔ፡ ገጽየ፡ ይኰን፡ ዘዚአከ፡ ገጽ፨</l>
               </lg>
               <lg type="stanza" n="42">
                  <l n="1">ሰላም፡ ለሰኰናከ፡ ዘስዒሞቱ፡ ከሠተ፨</l>
                  <l n="2">ለብእሲት፡ አሐቲ፡ ዘኣዕይንቲሃ፡ ዑረተ፨</l>
                  <l n="3">ገላውዎዴስ፡ ጸጉ፡ ዘጌጋይዳ፡ ስርየተ፨</l>
                  <l n="4">ለጸድቃንሰ፡ አመ፡ ሰአልከ፡ ምሕረተ፨</l>
                  <l n="5">ጸሎትከ፡ በቋዒት፡ ኢኮነት፡ መንክርተ፨</l>
               </lg>
               <lg type="stanza" n="43">
                  <l n="1">ሰላም፡ ለመከየድከ፡ መከየደ፡ ብሩር፡ ጽሩይ፨</l>
                  <l n="2">ዘመልዕልቴሆን፡ ተተከላ፡ አዕማደ፡ ጠባይዕ፡ ሰኑይ፨</l>
                  <l n="3">ገላውዴዎስ፡ መስፍን፡ ወሠርዐ፡ መንግሥት፡ ኅሩይ፨</l>
                  <l n="4">ተብህል፡ በእንቲአከ፡ በአፈ፡ ሆሴዕ፡ ራአይ፨</l>
                  <l n="5">ለኢይዝራኤል፡ ዕለቱ፡ ዐባይ፨</l>
               </lg>
               <lg type="stanza" n="44">
                  <l n="1">ሰላም፡ ለአፃብዓ፡ እግርከ፡ እንዘ፡ ይትወሀቦን፡ አካል፨</l>
                  <l n="2">እምድረ፡ መከየድ፡ ዘዓርጋ፡ አምሳለ፡ ሰዊት፡ ወሰብል፨</l>
                  <l n="3">ገላውዎዴስ፡ ሰማዕት፡ ሰባኬ፡ ቅዱስ፡ ወንጌል፨</l>
                  <l n="4">ይስቅየኒ፡ ጠለ፡ ሣህልከ፡ አሥር፡ ዘይት፡ ዘይክል፨</l>
                  <l n="5">ለአውልዓ፡ ገዳም፡ መሪር፡ ወይቡስ፡ ተከል፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለአጽፋረ፡ እግርከ፡ እምርእሰ፡ አፃብዕ፡ ዘዐርጋ፨</l>
                  <l n="2">ፅዕዳዊ፡ በረድ፡ ወስን፡ እንዘ፡ ይዛወጋ፨</l>
                  <l n="3">ገላውዴዎስ፡ ውዱስ፡ ማእከለ፡ ብዙኃን፡ አንግልጋ፨</l>
                  <l n="4">ያስተበፅዑከ፡ ትዝምደ፡ ኵሉ፡ ዘሥጋ፨</l>
                  <l n="5">በረድኤትከ፡ ረኪቦሙ፡ ጸጋ፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">ሰላም፡ ለቆምከ፡ ዘይመስል፡ አርዘ፨</l>
                  <l n="2">ዘሠምራተ፡ ምድር፡ ለብሰ፡ ወዘዓየራት፡ ሐዋዘ፨</l>
                  <l n="3">ገላውዴዎስ፡ ፀሐይ፡ እንተ፡ ትኳንን፡ አብያዘ፨</l>
                  <l n="4">በሐብለ፡ ፍቅርከ፡ ዘኢሕሊናሁ፡ ተእኅዘ፨</l>
                  <l n="5">በአፈ፡ ኬፋ፡ ወሳውል፡ ለይኩን፡ ውጉዘ፨</l>
               </lg>
               <lg type="stanza" n="47">
                  <l n="1">ሰላም፡ ለመልከዕከ፡ ድኅረ፡ በናት፡ ተቀትለ፨</l>
                  <l n="2">ኅብረ፡ አርአያ፡ ወርቅ፡ ዘይመስል፡ ወዕንቈ፡ ቢረሌ፡ ዕዱለ፨</l>
                  <l n="3">ገላውዴዎስ፡ ክቡር፡ እስእለከ፡ ስኢለ፨</l>
                  <l n="4">እስመ፡ ተዘርወ፡ በድነ፡ ሥጋየ፡ ወኮነ፡ ወበለ፨</l>
                  <l n="5">ስብሐተ፡ ትንሣኤ፡ ምልኦ፡ ወጸግዎ፡ ኀይለ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለአተ፡ ነፍስከ፡ በዕለት፡ ዛቲ፨</l>
                  <l n="2">ቅዱሳነ፡ ሰማይ፡ ወምድር፡ እንተ፡ ይትፌሥሑ፡ ባቲ፨</l>
                  <l n="3">ገላውዴዎስ፡ መልአከ፡ ዑቃቤ፡ ሕይወት፡ ለመዋቲ፨</l>
                  <l n="4">አምሕለከ፡ እግዚኦ፡ በዕበይከ፡ እንታከቲ፨</l>
                  <l n="5">ጊዜ፡ ተወፅአ፡ ነፍስየ፡ ኢትመንና፡ ላቲ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋከ፡ ዘጥቀ፡ የሐቱ፨</l>
                  <l n="2">የሐውዕዎ፡ መላእከት፡ ዘያፈትዎሙ፡ ሥነ፡ ርእየቱ፨</l>
                  <l n="3">ገላውዴዎስ፡ ቡሩክ፡ ለእግዚአብሔር፡ መከፈልተ፡ ርስቱ፨</l>
                  <l n="4">ሚጠኒ፡ በምሕረትከ፡ እምፍኖተ፡ ጌጋይ፡ ዝንቱ፨</l>
                  <l n="5">አሥዋከ፡ ደዌ፡ ወሞት፡ ዘተሐፅረ፡ ቦቱ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ ዘእደ፡ ምእመናን፡ ገንዞ፨</l>
                  <l n="2">በልብሰ፡ ቅዳሴ፡ ንጹሕ፡ ድኅረ፡ አፈ፡ ኲናት፡ ረገዞ፨</l>
                  <l n="3">ገላውዴዎስ፡ ስቡሕ፡ ሕገ፡ ጽድቅ፡ ወተአዝዞ፨</l>
                  <l n="4">ሠውረኒ፡ በምሕረትክ፡ ወናዝዘኒ፡ ናዝዞ፨</l>
                  <l n="5">እምብካየ፡ ወይሴ፡ መሥጥም፡ ወዓቢይ፡ ተከዞ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ መካነ፡ ገቦ፡ ደብር፡ ልዑል፨</l>
                  <l n="2">ድኅረ፡ ሠሰጥከ፡ መዊተ፡ በናተ፡ ሕማም፡ ስሑል፨</l>
                  <l n="3">ገላውዴዎስ፡ ተባዕ፡ ወወሬዛ፡ መንግሥት፡ አዛል፨</l>
                  <l n="4">ትበክየከ፡ አንጾኪያ፡ እንዘ፡ ትኬልሕ፡ ወትብል፨</l>
                  <l n="5">እፎኑ፡ ታሕተ፡ ከፈር፡ ተኃብአ፡ ጸዳል፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ናሁ፡ ተግህደ፡ ዘመልክእክ፡ ፍጻሜ፨</l>
                  <l n="2">እንተ፡ ያረውፅ፡ ፈድፋደ፡ ፄና፡ መዓዛሁ፡ አበሜ፨</l>
                  <l n="3">ገላውዴዎስ፡ ነፍኒፍ፡ በርእሰ፡ ገላውዴዎስ፡ አምሳለ፡ ጊሜ፨</l>
                  <l n="4">ጽባሐ፡ በረከተ፡ ወሰዓተ፡ ምሴት፡ ሱላሜ፨</l>
                  <l n="5">ዘይዌስከ፡ መዋዕለ፡ ወያነውን፡ ዕድሜ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ዓፀደ፡ መልክእከ፡ እግዚኦ፡ እንዘ፡ አኃሥሥ፡ ተግባረ፨</l>
                  <l n="2">ጊዜ፡ ፍና፡ ምሴት፡ ወነግህ፡ እስመ፡ እግረ፡ ልብየ፡ ሖረ፨</l>
                  <l n="3">ገላውዴዎስ፡ ምክር፡ ወአስተሐይፅ፡ ነገረ፨</l>
                  <l n="4">ከመ፡ ትጸግወኒ፡ ዕሤተ፡ ተስፋ፡ ጽድቅ፡ ወትረ፨</l>
                  <l n="5">ምስለ፡ ብእሴ፡ ቅንየት፡ ለዕለት፡ ከበዳ፡ ዘጾረ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ አሐዱ፡ ሰማዕት፡ መዋዒ፡ እምነ፡ ኅሩያን፡ አእላፍ፨</l>
                  <l n="2">አንታዔ፡ ፲፻፡ ወሰዳዴ፡ እልፍ፨</l>
                  <l n="3">ዘገብርኤል፡ ጸዋሬ፡ ሰይፍ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ውእቱ፡ ሰይፍከ፡ ለሰብእ፡ ቍዝ፡ አምሰትየ፡ ደሞሙ፡ ሰክረ፨</l>
                  <l n="2">ወእግረ፡ ፈረስከ፡ ኬደ፡ ርእሶ፡ ምቱረ፨</l>
                  <l n="3">በዜናከ፡ ከመ፡ ተነግረ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ደምሰስክሙ፡ እንተ፡ እምነ፡ አርማን፡ ለእለ፡ ተጋብኡ፡ ፀር፨</l>
                  <l n="2">በብሔር፡ ዘስሙ፡ ፈለገ፡ ከቦር፨</l>
                  <l n="3">ገላውዴዎስ፡ ጥዑመ፡ ዝክር፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ መንግሥተ፡ ምድር፡ መነንከ፡ ዘኖላዌ፡ ጠሲ፡ ወረሶ፨</l>
                  <l n="2">መንግሥተ፡ ሰማያት፡ ትርከብ፡ በተጸንሶ፨</l>
                  <l n="3">ገላውዴዎስ፡ ከናፍረ፡ ፍሕሶ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለእኅትከ፡ ተፋስየ፡ ነበልባለ፡ ኃዘን፡ አውዐያ፨</l>
                  <l n="2">አመ፡ ንግደትከ፡ እምአንጾኪያ፨</l>
                  <l n="3">ገላውዴዎስ፡ ምክሀ፡ ሮምያ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ከመ፡ አምላክከ፡ ኄር፡ ወጻድቅ፡ በዓመፃ፡ ዘአልቦ፨</l>
                  <l n="2">በአፈ፡ ኲናት፡ ክላሌ፡ አንተቦ፨</l>
                  <l n="3">ገላውዴዎስ፡ ርጉዘ፡ ገቦ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ እስመ፡ እፈቱ፡ ርእየ፡ ስነ፡ ገጽከ፡ ልሑየ፨</l>
                  <l n="2">ምስለ፡ እኁከ፡ ፊቅጦር፡ እግዚእየ፨</l>
                  <l n="3">ገላውዴዎስ፡ ነዓ፡ በስዓ፡ ሞትየ፨</l>
                  <l n="4">ትንብብ፡ ሰላመከ፡ ለኃጥአት፡ ነፍስየ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
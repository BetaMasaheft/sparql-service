      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0510</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እምጾታ፡ ሥላሴ፡ ዋሕድ፡ እንዘ፡ ኢይትፈለጥ፡ ምክረ፨</l>
                  <l n="2">አመ፡ በሐልዮ፡ ፈጸመ፡ ዓለመ፡ ሱባዔ፡ ገቢረ፨</l>
                  <l n="3">ከመ፡ ቃልከ፡ ሳሙኤል፡ ዜናሁ፡ ለኢሳይያስ፡ ፈከረ፨</l>
                  <l n="4">በመንክር፡ ዕበየ፡ ግርማ፡ ኀበ፡ ማርያም፡ ዘኀደረ፨</l>
                  <l n="5">መለኮቶ፡ ወልድ፡ ውስተ፡ ሥጋሃ፡ ደመረ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ አካለ፡ ቅዳሴ፡ ዘአቀመ፨</l>
                  <l n="2">ወለልደትከ፡ መዋኢ፡ መርድአ፡ ሴሩህ፡ ዓለመ፨</l>
                  <l n="3">ድሙፀ፡ ፍካሬ፡ ሳሙኤል፡ ዘታድለቀልቅ፡ ገዳመ፨</l>
                  <l n="4">እጽሕፍ፡ በበ፡ አምሳሉ፡ እንዘ፡ እሬሲ፡ ቀለመ፨</l>
                  <l n="5">ለዘበእንቲአከ፡ ዜና፡ ይነግር፡ ሰላመ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዐ፡ ቀዲሙ፨</l>
                  <l n="2">አድባረ፡ ምድር፡ እምነ፡ ድኁኃን፡ ቅድመ፡ በሥርዓት፡ ይቁሙ፨</l>
                  <l n="3">መጽሐፈ፡ ሕይወትከ፡ ሳሙኤል፡ ዘኢይትፈታሕ፡ ማሕተሙ፨</l>
                  <l n="4">አምክረኒ፡ ምክረ፡ ድኂን፡ እመፅራርየ፡ ኵሎሙ፨</l>
                  <l n="5">ከመ፡ ለእስራኤል፡ ያዕቆብ፡ አፍቀረቶ፡ እሙ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ምድረ፡ ደብተራ፡ ሣህል፡ ታዕካ፨</l>
                  <l n="2">ታቦተ፡ ማርያም፡ ጽዮን፡ ኀበ፡ አስተርአየት፡ ዋካ፨</l>
                  <l n="3">ስምዐ፡ ትንሣኤሁ፡ ሳሙኤል፡ ለአማኑኤል፡ ፋሲካ፨</l>
                  <l n="4">እደዊነ፡ አንስት፡ ዜና፡ ግዕዛነ፡ በረከት፡ ይስብካ፨</l>
                  <l n="5">ውስተ፡ ሀገርነ፡ ዘትመስል፡ ፔካ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ሰላም፡ ለአስኬማከ፡ ቅዱስ፨</l>
                  <l n="2">ዘተውህበ፡ ለከ፡ እምእንጦንዮስ፡ ቀሲስ፨</l>
                  <l n="3">ጽንዐ፡ ሕገ፡ ኦሪት፡ ሳሙኤል፡ መሠረተ፡ ቃላት፡ ሐዲስ፨</l>
                  <l n="4">መሐረኒ፡ ወንጌለ፡ ጸጋ፡ ሕይወተ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="5">ዘተናግሮ፡ ገሀደ፡ ኢየሱስ፡ ክርስቶስ፨</l>
               </lg>
               <lg type="stanza" n="37">
                  <l n="1">በቃለ፡ አምላኮ፡ ስብሐት፡ ለባሕርየ፡ አብ፡ ይደሉ፨</l>
                  <l n="2">ሰጊድ፡ ካዕበ፡ ለባሕርየ፡ ዋሕድ፡ ቃሉ፨</l>
                  <l n="3">ወለመንፈስ፡ ቅዱስ፡ ባርኮ፡ ዘይመስል፡ ባሕርየ፡ እሉ፨</l>
                  <l n="4">አባ፡ ሳሙኤል፡ ባሕቱ፡ ኢትግድፈነ፡ በኵሉ፨</l>
                  <l n="5">ወበረከትከ፡ ምስሌነ፡ የሀሉ፨</l>
               </lg>
            </div>
         </div>
      </body>

      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0449</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ዝክረ፡ ስምከ፡ በኍልቈ፡ መጻሕፍት፡ ሥላሴ፨</l>
                  <l n="2">እግዚአብሔር፡ ዘኀረዮ፡ ለምድረ፡ ተስፋ፡ ጽድቅ፡ ወራሴ፨</l>
                  <l n="3">መዋኤ፡ ጽልመት፡ አቢብ፡ ዘውገ፡ ኦርያሬስ፡ ወቢጸ፡ ብናሴ፨</l>
                  <l n="4">አብርህ፡ ዐይነ፡ ልብየ፡ ለስመ፡ ዚአከ፡ ውዳሴ፨</l>
                  <l n="5">ከመ፡ እንብብ፡ በትፍሥሕት፡ ከይድየ፡ ከይሴ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርትከ፡ በክሳደ፡ ርእስ፡ ዘተናውኃ፨</l>
                  <l n="2">እንዘ፡ ይሰቀይ፡ ዘልፈ፡ ፈለገ፡ ደም፡ ቀይሐ፨</l>
                  <l n="3">ብፁዕ፡ አቢብ፡ ዘተኰነንከ፡ ብዙኀ፨</l>
                  <l n="4">እንዘ፡ ትዘከር፡ በልቡና፡ ሕማማተ፡ ክርስቶስ፡ ዘአሜሃ፨</l>
                  <l n="5">በዐውደ፡ ጲላጦስ፡ ዘቆመ፡ አእዳዎ፡ ስፉሐ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ እደ፡ ወልደ፡ አምላክ፡ ዘሠዐላ፨</l>
                  <l n="2">ወአዕረጋ፡ በክብር፡ እንበለ፡ ሕማም፡ አርያመ፡ ተድላ፨</l>
                  <l n="3">ወልደ፡ አብርሃም፡ አቢብ፡ ለኃሪክ፡ ፍሬ፡ አስካላ፨</l>
                  <l n="4">አስትየኒ፡ ለበግዕከ፡ ፈለገ፡ ጸበልከ፡ ገብላ፨</l>
                  <l n="5">ወኖላዊኪ፡ አነ፡ ለነፍስየ፡ _ላ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለክብረ፡ ዜናከ፡ እምዜና፡ ቅዱሳን፡ ብዑድ፨</l>
                  <l n="2">ወእምሰማዕታት፡ ዓዲ፡ ጻማ፡ ገድልከ፡ ፍድፉድ፨</l>
                  <l n="3">ኮለ፡ ሮቤል፡ አቢብ፡ በሰይፈ፡ ሐራዊ፡ ግሙድ፨</l>
                  <l n="4">ባርከኒ፡ ለጸማድከ፡ ከመ፡ ባረከከ፡ ወልድ፨</l>
                  <l n="5">በረከተ፡ ኪዳን፡ ታትርፍ፡ ለዘለከ፡ ጸማድ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ናሁ፡ ፈጸምኩ፡ ውዳሴ፡ መልክእከ፡ በልሳንየ፡ ድኩም፨</l>
                  <l n="2">እንዘ፡ እትአመን፡ አንሰ፡ በረድኤትከ፡ ቃውም፨</l>
                  <l n="3">ብፁዕ፡ አቢብ፡ አስተበቍዐከ፡ ዮም፨</l>
                  <l n="4">ከመ፡ ትዕሥየኒ፡ ዐስበ፡ ጻማየ፡</l>
                  <l n="5">[The remainder of the text is lost.]</l>
               </lg>
            </div>
         </div>
      </body>

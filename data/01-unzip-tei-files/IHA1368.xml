               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="4r">1v-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0508IHA">تخميس نظم ما ارسل الرحمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>عواذ لي ها انني مقبل| على الذ أهوى فلا تعذ لوا| واستمعو منى الهدى واقبلوا| ما أرسل الرحمان أويرسل من رحمة تصعد أو تنزل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>واجعلنا فى حرزك يا سيد اراه فى دار البقا يرفل|| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="6v">4r-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2883IHA">قصيدة بروق الحمى ابرقي يا بروق</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>الله الله الله يا معين الله الله الله يا متين

إرحم من يدعوك قلبه فزين

بريق الحما أبرقي يا بريق| عسى الله يسقي بكى المخدبين|| عسى اغصاتا ذاوية تنقشي| وتشهر مع جملة المشهرين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>أصأت به الظلما واتخر إلورا| طراز جمال للمحاس جامع|| وصل وكل يوم وليلة| على المحتبا فهو الحبيب المشفع|| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="16r" to="16v">16r-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0024IHA">عقد الجوهر في مولد النبي الازهر</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>أشرف البدر علينا| واختفت منه البدور</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v ">-16v </locus> ليس ازكى منك اصلا| قط يا جدّ الحسين || فعليك الله صلى | دائما طول الدهور ||تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="17v" to="91r">17v-91r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0707IHA">مولد شرف العالمين</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="17v" to="42r">17v-42r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#17v">-17v</locus>ما بال قلبك ذا ألم | مذبان اهل الحما البان والعلم | وانهل مدمعك القانى بمنسجم |أمن تذكر جيران بذي سلم مزجت دمعا جرى من مقلة بدم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#41r">-41r</locus>على نبي الهداد انزله ولهم |لاه ولأل والصحب ثم التابعين لهم أهل التقى والنقى والجو دو الكرم|| تمت </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="42v" to="43v">42v-43v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2898IHA">نظم اشرق شمس الهدايا</title>
                     <incipit xml:lang="ar">
                        <locus target="#42v ">-42v </locus>اشرق شمس الهدايا | في مشارق الصفاء | ابصرت عين البرايا || في طراىق الهداء | نعم ذالك الحبيب| وبذكره نطيب| فهو الشافع الخطيب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43v">-43v</locus>ايها البدر المعلا | في سما بدر تجلا| فعليك الله صلى | دائما بلا انتهاء || تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="43v" to="46r">43v-46r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2881IHA">نظم بذات علي على جده</title>
                     <incipit xml:lang="ar">
                        <locus target="#43v">-43v</locus>بذات علي على جده | بسر خفي سرا سرى ه | وعبد صفي صفا سره|| وعبد زكي زكى خيره | فحقق لديك الذي نأمل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#46r">-46r</locus>وصلّ وسلّم على من سما | بذات ووصف ومعنى كما | اقرت جميعا به العلما ||وال وصحب كلما| توالت باحكامها العلل|| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="46v" to="47v">46v-47v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2899IHA">نظم اسمعوا وفقتمو من اخ ينصحكمو</title>
                     <incipit xml:lang="ar">
                        <locus target="#46v">-46v</locus>بسم الله| الرحمن الرحيم || امسعوا وفّقتمو | من أخ ينصحكموا || قدموا أعمالكم | قبل ما لم تندموا || ليس ينفع الندم | بعد ما جفّ القلم

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#47v">-47v</locus>النفوس والنصارا والمجوس| أسلمو على يديه| الحسن والحسين|| للنبي تفاحتين | نورهم كا الشمعتين| جدهم صلوا عليه|| تمت تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="48v" to="89v">48v-89v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0706IHA">عنوان الشريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#51r">-51r</locus>بسم الله الرحمن الرحيم  الحمد لله الذى شرف العالمين| بأشرف العالمين |واصطفاه من خلقه أجمعين| ونبأه وءادم بين الماء والطير| ونوه بذكره فى الاخرين والاولين| كما شرف بقدره فى الاخرين| خلق ءادم من سلالة من طين| فما ختمت صدفة جسده الاعلى درة محمد خاتم النبيين

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#89v">-89v</locus>كيف التصبّر والسلوان عن قمر موافقي في هواه العجم والعرب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="90r" to="91r">90r-91r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3785IHA">دعاء ختم المولد الشريف اللهم انا قد حضرنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#90r">-90r</locus>دعا ختم المولد الشريف | بسم الله الرحمن الرحيم| اللهم انّا قد حضرنا قراءة مولد نبيك الكريم فأفض علينا ببركته خلع القبول</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#91r">-91r</locus>وافضل الصلاة والتسليم على أشرف الخلق سيدنا محمد الذي جاء با الحق المبين وأسلته رحمة للعلمين وعلى إله وصحبه أجمعين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين.
تم الكتاب بحمد رب العلمين اه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="6v" to="8r">6v-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2884IHA">نظم الهي باياتك البينات</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus>الهى با إياتك البيات| وبالصحف والذكر بالمنجيات|| باءسمك من أنت أكتته| بمزهو مفز ومحي الزفات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>وما أحمد دين الحلي شذا| إلهى بأنواك الامعات</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="8r" to="8v">8r-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2889IHA">نظم هبوا لي من فضلكم هبوا لي</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>الهى الهى ذ الجلال| تفضل علينا بالقبول

هبو لي من فضلكم هبو لي | وجودوا للعبد بالقبول || منائي وبغيتي رضاكم| وانتم قصدي وكل سؤلي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus>والأل والأصحاب جميعا| فهم أهل الفضل والنوال</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="8v" to="9r">8v-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2890IHA">نظم الهي اغفر لنا ذنوبا</title>
                     <incipit xml:lang="ar">
                        <locus target="#8v">-8v</locus>الهى الهى ذا الحلال | سلمنا عدواة الجهال:

الحمد لله ذى الجلال | والصلاة على خير الرسول || إلهى فاغفر لنا ذنوبا | أجرنا من عذابك الويل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>بحق سيدنا محمد | اجعلنا من زمرة الرسول||أدخلنا في جنات النعيم| بحق سيدنا الرسول
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="9r" to="10r">9r-10r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0737IHA">مدح النبي أبتدئ بسم الكريم</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>الف صلى الله عليك يا محمد صلوات الله عليك احمد محمد
  أبتدي باسم الكريم | وبحمد الله ثاني || ثالثا باالصلوات | بالنبى الهادي الشفيع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>فاغفر عن فتح اجترامي| يا ملاذي واعتصامي|| فعلى خير الأنام| صلواتي وسلامي| كل أصحاب وءال|| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="10r" to="11v">10r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2802IHA">نظم اسمعوا يا كرام</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>نبى سلام على نبى سلام على | محمد نبينا صلى الله على:

إسمعو يا كرام| يا معشرالإسلام| نبي خير الأنام|| معارن الشفا|  مراتب الوفا| فى جبر المصطفى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v ">-11v </locus>واغفر ذنوبنا| وستر عيوبنا| بجاه نبينا|| تمت تمت تمت تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="12v" to="13v">12v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1222IHA">نظم طلع البدر علينا</title>
                     <incipit xml:lang="ar">
                        <locus target="#12v">-12v</locus>طلع البدر علينا | من ثنيات الوداع | وجب الشكر علينا || ما دعا لله داع | ايها المبعوث فينا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>صلى يا رب عليه ما سعى لله ساع| وعلى الال والصحب| بل وأتباعى التاعي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="13v" to="13v">13v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2894IHA">نظم ابتدئ مدح احمد بعون الله الصمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ابتدى مدح احمد | بعون الله الصمد | ملتمسا بعونه || حتى ابلغ مقصدي | وثم صلاة لله| على المجتب احمد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ولد النبي احمد | ملئكة سألت بتربيته السيد | وكذا وحش وطير || إلا شيطان المارد | فأباهم ربنا  إلا حليمة| السعد || تمت

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="14r" to="15r">14r-15r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2896IHA">نظم بسم الله فى النظم ابتدئ</title>
                     <incipit xml:lang="ar">
                        <locus target="#14r">-14r</locus>بسم الله الرحمن الرحيم

بسم الله النظم أبتد| ثانيا الله نحمد|| ثالثا لما نظمنا| باالصوة على أحمد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus> يا رب ارحم شريف علي |يا رب ارحم شريف علي</explicit>
                     <note/>
                     <note/>
                  </msItem>

                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1ra" to="31vb"/> 
                            <title ref="https://betamasaheft.eu/LIT1512GadlaY">Collection of hagiographic texts in honour of St Yāred</title>
                            <note>With many variations to <bibl corresp="http://zotero.org/groups/358366/items/SWYGN7PD"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1904YaredPantalewonT"/><title level="m">Vitae Sanctorum Antiquiorum, I: Gadla Yārēd seu Acta Sancti Yārēd, II: Gadla Panṭalēwon seu Acta Sancti Pantaleonis. Textus</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Carlo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Conti Rossini</t:surname></author><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Carlo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Conti Rossini</t:surname></editor><pubPlace>Romae, Parisiis, Lipsiae</pubPlace><publisher>Excudebat Karolus de Luigi, Carolus Poussielgue Bibliopola, Otto Harrassowitz</publisher><date>1904</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Corpus Scriptorum Christianorum Orientalium</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">Scriptores Aethiopici, Series Altera, 17</t:biblScope></series><biblScope unit="volume">Scriptores Aethiopici, Series Altera, 17</biblScope><note type="url">https://archive.org/details/vitaesanctoruman00cont</note></bibl>.</note>
                            <msItem xml:id="ms_i1.1">
                                <locus from="1ra"/>
                                <title ref="https://betamasaheft.eu/LIT1303Dersan">Dǝrsān wa-gadl za-Yāred</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ድርሳን፡ ዘቅዱስ፡ ያሬድ፡ ቀርነ፡ ቤተ፡ ክርስቲያን፡ ዘይጼውዖሙ፡ 
                                    <sic resp="CH">ለሃይማናን፡</sic> ከመ፡ ይሴብሕዎ፡ ለእግዚአብሔር፡ በክላህ፡ ወበዐቢይ፡ ቃል፡ ከመ፡ ሱራፌል፤ ድርሳን፡ ዘያሬድ፡ ካህን፡ </incipit>    
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="18vb"/>
                                <title ref="https://betamasaheft.eu/LIT7019MiraclesYared">Miracles of St Yared</title>
                                <msItem xml:id="ms_i1.2.1">
                                    <locus from="18vb"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT7019MiraclesYared#Satan">Miracles of St Yared: Miracle of overcoming of Satan by Yāred</title>
                                    <note>The beginning is missing</note>
                                    <incipit xml:lang="gez">ወእምድኅረ፡ አዕረፈ፡ <persName ref="https://betamasaheft.eu/PRS10245Yared">ያሬድ፡</persName> ካህን፡ ፈጺሞ፡ 
                                        ገድሉ፡ ወመዊዖ፡ ሰይጣነ፡</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2.2">
                                    <locus from="22rb"/>
                                    <title ref="https://betamasaheft.eu/LIT7019MiraclesYared#Decoration">Miracles of St Yared: The miracle of Yāred, when decoration of the church was hidden from him</title>
                                                   <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ነገር፡ በእንተ፡ ሰዋሬሁ፡ ለያሬድ፡ ካህን፡ ሠርጐ፡ ቤተ፡ ክርስቲያን፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2.3">
                                    <locus from="24vb"/>
                                    <title ref="https://betamasaheft.eu/LIT7019MiraclesYared#Gift">Miracles of St Yared: The miracle of Yāred, when a gift dedicated to him was hidden from him</title>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ነገር፡ በእንተ፡ ሰዋሬሁ፡ ለያሬድ፡ ካህን፡ ዘተወህቦ፡ ጸጋ፡ </incipit>
                                </msItem>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="27ra" to="31vb"/>
                                <title ref="https://betamasaheft.eu/LIT2989RepCh270">Malkǝʾ of Yāred</title>
                                <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘበሰማያት፡ አቡነ።</incipit>
                            </msItem>
                        </msItem> 

                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="OwnershipNote">
                    <locus target="#136r" facs="138"/>
                    Four lines of text including the name of the later owner, all erased
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Binding is original and intact
                    </desc>
                    </item>
                    <item xml:id="e2">

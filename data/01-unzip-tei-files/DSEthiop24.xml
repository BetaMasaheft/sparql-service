                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="2v">Fols 1r–2v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara
                    Bǝhnǝsā</title>
                        <textLang mainLang="gez"/>
                     <note>
                       A part of the Anaphora corresponding to
                       <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">110-112</citedRange><citedRange unit="paragraph">24-40</citedRange></bibl>
                   (cp. <bibl corresp="http://zotero.org/groups/358366/items/UV8BMXC4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Euringer1937AnaphMaria"/><title level="a">Die äthiopische Anaphora unserer Herrin Maria</title><title level="j">Oriens christianus</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sebastian</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Euringer</t:surname></author><date>1937</date><biblScope unit="volume">12</biblScope><biblScope unit="page">63-102, 248-262</biblScope><citedRange unit="number">28-43γ</citedRange></bibl>).
                   The text immediately precedes the part of the Anaphora in
                        <ref type="mss" corresp="https://betamasaheft.eu/DSEthiop17"><hi rendition="simple:smallcaps">MS</hi> DS Ethiop. 17</ref>.</note>
                     <incipit xml:lang="gez">
                        <locus target="#1r">Fol. 1r</locus>
                        ዘከመኪ፡ ወሠምረ፡ መአዛ፡ ዚአኪ፡ ወአፍቀረ፡ ስነኪ፡ ፈነወ፡ ሀቤኪ፡ ወልደ፡ ዘያፈቅር፡ <sic resp="DN">ይበ፡</sic> ዲያቆን፡ ውስተ፡ ጽባህ፡ ነጽሩ፡ ንኔጽር፡
                        ቅዱስ፡ <hi rend="rubric">እግዚአብሔር፡ አብ፡ ዘሠምረ፡ ኪያኪ፡ ቅዱስ፡ ወልድ፡ ዋህድ፡ ዘኃደረ፡ ውስተ፡ ከርሥኪ።</hi>
                        ቅዱስ፡ ወልድ፡ ዋህድ፡ ጳራቅሎጦስ። መንፈሰ፡ ጽድቅ፡ ዘቀደሰኪ፡ ወአጽንአኪ፡ <sic resp="DN">ይበ፡</sic> ዲ፡ አውሥኡ፡
                        <sic resp="DN">ይበ፡</sic> ሕዝብ፡ ቅቅቅ፡
                        <sic resp="DN">ይበ፡</sic> ካህን፡ <hi rend="rubric">ኦድንግል፡ ምል<add place="above">ዕተ</add>፡ ውዳሴ።</hi>
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#2v">Fol. 2v</locus>
                        ምእልተ፡ ወሌሊተ፡ ኦድንግል፡ አኮ፡ <sic resp="DR">በፏትወተ፡</sic> ደነሰ፡ ዘተፀነስኪ፡ አላ፡ በሩካቤ፡ ዘባህግ፡ እምሐና፡ ወኢያቄም። ተወለድኪ፡
                        ኦድንግል፡ አኮ፡ በተላህዎ፡ ዘልሕቅኪ፡ ከመ፡ አዋልደ፡ እብራውያን፡ እለገዝፉ<supplied reason="omitted" resp="DR">፡</supplied>
                        ክሳዶን፡ አላ፡ በቅድስና፡ ወበንጽሕ። ውስተ፡ ቤተ፡ መቅድስ፡ ነበርኪ፡ ኦድን<supplied reason="omitted" resp="DR">ግ</supplied>ል፡
                        <sic resp="DR">ኃብስተ፡</sic> ምድራዊ፡ <add place="above">ዘ</add>ተሴስይኪ፡ አላ፡ ኅብስተ፡
                     </explicit>
                  </msItem>



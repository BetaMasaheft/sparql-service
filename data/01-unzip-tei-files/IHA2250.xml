               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="2v">1-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4354IHA">نظم اسمعوا يا مسلمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#1">-1</locus>له السنايا كالدرر نور نور القمر عن راه افتخر صلوات الله عليه | النبي خير الانام فالغواثم الغوا من جلس وسط الظلام نوره يضيء اليه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>وانت شافع المقبول غداة الحشر عند الله وانت الصادق المصدوق كريم الأصل احب الله | صلاة الله والتسليم على المختار صلى الله واله ثم الاصحاب على كل سلام الله </explicit>
                     <note>The part is the continuation of DWL00024-3A3; part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="5r">2v-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT3901IHA">مدح النبي بسم الله إبتداء ثانيا الصلاة على الهادي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم | بسم الله ابتدا ثانيا الصلوة على الهادى لارشادى | نب نغم المجيبا ورعجيبا انخ نالخ بقلبا يا حبيبا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>نب جيزوا انبوردي الله فونل أول نارش عئوم نسخ أنلوا | عليه صلاتى دائما ما جن حمام في وكيره</explicit>
                     <note>Part of the text written in vertical in the margin.
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="22r" to="24r">22r-24r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4467IHA">Poem in Old Harari (19)</title>
                     <incipit xml:lang="ar">
                        <locus target="#22r">-22r</locus>بسم اللها لرحمن الرحيم | بان سلاما أن ل ولما ذيلخ سلامى باي ولما | نلخ سلامى تاسلامى ايل ايمان زيلخ مان نبوا الله لمحيوا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>عرشت كر سب ذاكرينا حجاب احجيج مومنينا | نبيوا سطين الوا حمدي ايمان سطين الوا حمدى | الموسين الوا حمدي </explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="24r" to="25v">24r-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4468IHA">Poem in Old Harari (20)</title>
                     <incipit xml:lang="ar">
                        <locus target="#24r">-24r</locus>بسم الله الرحمن الرحيم نوروا سلامي نور سلامي | ابدا القول ببسم الله ثم اثنى الحمد الله | اللوا كفتلن رحمت برأي الوا كفتلن فاتح برأى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>سخي صغي الله تعثمان خ رضي الله تعلى خوا | حبيب الله محمدوا نبيوا سطينا الله حمدي | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="25v" to="29v">25v-29v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4469IHA">نظم ببسم الله قد منا الرحمن</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>بسم الله الرحمن الرحيم | ببسم الله قد منا الرحمن خير فرد لنا | ببسم الله قد منا الرحمن شر سدد لنا | ببسم الله قد منا الرحمن واي اتد يجبنا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29v">-29v</locus>تعثمان ح سلامي نب تعلى خ سلامي تحسر خ سلامي | نب تحسين خ سلامي خالق جاف حنو تلى الحمد لله رب العالمين | تمت عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="30r" to="34r">30r-34r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4470IHA">نظم بسم الله ننشأ</title>
                     <incipit xml:lang="ar">
                        <locus target="#30r">-30r</locus>بسم الله الرحمن الرحيم | بسم الله ننشا تنشئا بسم الله ذلنسأ واى نساء | بسم الله نبداء دين نقد احا | بسم الله بارأ بارإيا نب عبد الباأ بارإيا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34r">-34r</locus>زرف حال يتحذف زال دد سطنا محمد حال يتويرث زال دد سطنا | راج حال يتويرث زال دد سطنا تمت والخير عمت</explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="34r" to="35v ">34r-35v </locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4471IHA">Poem in Old Harari (21)</title>
                     <incipit xml:lang="ar">
                        <locus target="#34r">-34r</locus>بسم الله الرحمن الرحيم | سمز عزيز دوانما دواخاني سمز عزيز حرز نماحر زخانى | سمز عزيز كنز نما كنز خانى سمز عزيز عيناتوا فايدان خانى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35v">-35v</locus>سر زجج ليووا او حسينوا حياتخ كشلبييا او حسينوا | الله نرخبييا او حسينوا حمد حلاخياروا اذنان خانا </explicit>
                     <note>Part of the text written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="35v" to="36v">35v-36v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4472IHA">Poem in Old Harari (22)</title>
                     <incipit xml:lang="ar">
                        <locus target="#35v">-35v</locus>بسم الله الرحمن الرحيم | بل فرجي ودا جوا بحياتي جمط بلى وداجوا بحياتي | رب يستر ولابا تعسيرا يسيرا يخنلاوي نب بايتوا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#36v">-36v</locus>سم رحمات زخاخن بركاتي دش نبات زخاخن بركاتي ذلام جعوت زخاخن بركات معجزاتخ رسولوا ان البوردا </explicit>
                     <note>F. 36v written upside down; part of the text written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="37r" to="39r">37r-39r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4284IHA">نظم اولوا بسم الله اخر حمد نبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#37r">-37r</locus>بسم الله الرحمن الرحيم | اولوا بسم الله اخر حمد نبى احمدوا بسم الله امنت بالله رسول الله | احمدوا بسم الله توكلت بالله رسول الله احمدوا بسم الله ترزقت بالله رسول الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#39r">-39r</locus>نورهم كالشمعتين جدهم صلوا عليه فاطمي بنت الرسول | وعلي زوج البتول ذوا الفقار وسيف المسلول صلوات الله عليه | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5r" to="7v">5r-7v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4450IHA">Poem in Old Harari (16)</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v ">-5v </locus>بسم الله حصن نانما زالله عدولى حمديو دجان نانما نند فاني | قل هو الله خندق نانما ورشا تلى يسينوا وطاف نانما كميد يجلى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7v">-7v</locus>اللوا حمدوي حمدي اللوا حمدي فاطم خان رخابا اللوا حمدو وصلى الله على سيدنا محمد وعلى ال سيدنا محمد واله وصحبه وسلم تسليما امين</explicit>
                     <note>Part of the text written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="8r" to="9r">8r-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4451IHA">نظم اسماء الحسنى زالله</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>بسم الله الرحمن الرحيم | وبه نستعين وهو حسبي ونعم الوكيل ولا حول ولا قوة الا بالله العلي العظيم | اسمأ الحسنى سم زالله تسعا وتسعين رويناه | فادعوه بها باي الله لها دعوناك فاستجبت ياه | </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>وتباعه والداخلين جواره مد الدهر ما دامت منا والمشاعر | صلاة وتسليم وازكى تحية على احمد المختار طه المفاخر</explicit>
                     <note>Part of the text is written in vertical in the margins.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="9v" to="10r">9v-10r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4049IHA">دعاء يا رب اهدنا وارزقنا علما</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>بسم الله الرحمن الرحيم | يا رب يا رب اهدنا وارزقنا علما ولاستعماله وفقنا | والحفظ للقرأن والتأدبا به وفهما فيه والتهذبا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>ومن سواهم من سواد المسلمين والحمد للاله رب العالمين | وصل يا رب وسلم ابدا على النبي الهاشمي احمدا | نور الوجود صفوة الاله من جملة الكون الوظيم الجاه</explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="10r" to="10v">10r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0753IHA">قصيدة طف بحالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>طف بحانى سبعا وقف بزمامى وتجرد لزورتى كل عامي | أنا سر الأسرار من سر سرى كعبتي راحتى بسطى؟ مدامى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>واجعلنى يا مولاي ممن يراك في جنات النعيم ذ الاكرام | فهو قصدى وبغيتى ومناى واسكنى في جار خير الانام | فالحمد للمحي الحليم الكريم العليم القدير يرمحيى؟ الوظام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="10v" to="10v">10v-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4455IHA">نظم المطر</title>
                     <incipit xml:lang="ar">
                        <locus target="#10v">-10v</locus>فيا رب طهرنا وطهر بلادنا وامطر علينا رحمة المتماطر | واعرر لنا الأمطار في كل بقعة واعن جميع الخلق بالخير سارر | وفرج علينا عاجلا غير اجل فقد ضاقت الأحوال عجل وببسر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>وقد قلت في الشهر المعظم بذي الحجة بيوم الثلاث تسع عسر يفكر | بتأريخ الف والثمانين والمائة وخمس من الأعوام جبر لكاسر | وصل وسلم كل حين وساعة علي المصطفي المختار طه المطهر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="11r" to="12v">11r-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0725IHA">قصيدة البكرية الحضرمية</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>بسم الله الرحمن الرحيم | أ يا سائلي عن مدح من جل في الذكر | وما حل في وصف الإمام أبى بكر | تسمع هداك الله إن كنت لا تدرى | فيا ليت شعرى ما مديح وما فكرى لقد جأ في القرأن مدح النبى أبا بكر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>لك الحمد أولا لك الحمد اخرا | لك الحمد ظاهرا كل الحمد باطنا | لك الحمد سيدى على كل نعمتى | ومن جملة النعمإ إلهي لك الحمد </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="13r" to="15v">13r-15v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4458IHA">Poem in old Harari (17)</title>
                     <incipit xml:lang="ar">
                        <locus target="#13r">-13r</locus>بسم الله الرحمن الرحيم | أواي عربوا السلام محمد عربوا عرب يان عربوا | زعرب ولديوا عرب ذولدوا حبش ذواد ديوا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15v">-15v</locus>صلاة نبوا بشرحن يليا صديق التحيات عمر البركات عثمان الصلوات علي الطيبات لك الحمد ودود | اله الاحدا لك الشكر معبود الفرد الصمد الف الف سلام الف كم جر سلام بقل كم جر سلام تمت</explicit>
                     <note>Part of the text written in vertical in the margin; part of the text erased and rewritten.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="16r" to="22r">16r-22r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4461IHA">Poem in Old Harari (18)</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>بسم الله الرحمن الرحيم | بسم الله بان نخلشالي بسم الله بان نفر الى | بسم الله بان رخبنانى بسم الله بان سلطنانى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>عالم يفسر ان إذ كثرا عالم ورزوب ان احورب | نب سطين اللوا احمدي ايمان سطين الوا حمدي </explicit>
                     <note/>
                     <note/>
                  </msItem>

                                <textLang mainLang="gez"/>
                            </msItem>                            
                            <msItem xml:id="ms_i1.7">
                                <locus from="113r" to="121v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Sunday">ʾArgānona wǝddāse, for Sunday</title>
                                <textLang mainLang="gez"/>
                                <explicit xml:lang="gez">
                                    ወሰርሕኒ፡ ከመ፡ ያዕርፍ፡ ላዕሌየ፡ በረከተ፡ አዳም፡ ወአቤል፡ ወሴት፡ ወኵሎሙ፡ አበው፨ ኄራን፨ በረከተ፡ ሄኖክ፡ ወኖኅ፡ ወሴም፡ ወኵሎሙ፡ ኅሩያን፨ 
                                    <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                    ወበረከተ፡ ፳ወ፬ካህናት፡ ሰማያውያን፡ ወኵሎሙ፡ መላእክት፨ ኦእግዝእትየ፡ ቅድስት፡ ድንግል፡ በክልኤ፡ ማርያም፡ ዘበዕብራይስጢ፡ ማሪሃም፡ በረከትኪ፨ 
                                    ወበረከተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅጉስ፡
                                    ይኩን፡ ምስለ፡ ኃጥእ፡ ገብርኪ፡ <del rend="erasure"/> ወምስለ፡ ጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS14618SenaKr">ስነ፡ ክርስቶስ፡</persName> 
                                    ጊጉይ፡ ዘአልቦ፡ ከማሁ፡ በውስተ፡ ዓለም፨ ለዓለመ፡ ዓለም፨
                                </explicit>                            
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="121v" to="123v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6738Malke">Malkǝʾ-hymn to St George</title>
                            <incipit xml:lang="gez">
                                ሰላም፡ ለዝክረ፡ ስምከ፡ እንተ፡ የዐውዶን፡ መዐዛ። ወለስእርትከ፡ ጽሁድ፡ ዘርእስከ፡ አክሊለ፡ ቤዛ።
                            </incipit>
                            <explicit xml:lang="gez">
                                ከመ፡ እስራኤል፡ ድኅኑ፡ እመልአከ፡ ሞት፡ በደመ፡ ጠሊ፨ አድኅነኒ፡ ወባልሐኒ፡ ጊዜ፡ ተንሥኦ፡ ቀታሊ፨ በደመ፡ ስምዕከ፡ ዘተክዕወ፡
                                ጊዮርጊስ፡ ከሐሊ፨ ስብሐት፡ ለእግዚአብሔር፡ ለወሀቤ፡ ልቡና፡ ወትረ፡ እስከ፡ ለዓለም።
                            </explicit>                          
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="124r" to="131v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1570habeka">Anaphora of St John, Son of Thunder</title>
                            <explicit xml:lang="gez">
                                ንሥአተ፡ ዘቅዱስከ፡ ምሥጢር፡ ኢለርስሐት፡ ወኢለኵነኔ። አላ፡ ለኅድገተ፡ ኃጢአት፡ ወለሕይወት፡ ዘለዓለም፨ ወለአእምሮ፡ አማን፨ ጸግወነ፡ አንተ፡ ወበከመ፡
                                ከፈልከነ፡ በዝ፡ ዓለም፡ ንሥአተ፡ ዘቅዱስከ፡ ምሥጢር፨ ከማሁ፡ ለዘ፡ ሀሎ፡ ትንሣኤ፡ ሙታን፡ ምስለ፡ ቅዱሳን፡ ንቁም፡ ክፍለነ፨ በእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ዘቦቱ፡
                                ለከ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ለዓለመ፡ ዓለም፡ አሜን።
                            </explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus target="#131v"/>
                            <title ref="https://betamasaheft.eu/LIT3852KingList">Short list of Ethiopian kings</title>
                            <note>
                                This is a short list of Ethiopian kings from <persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</persName> to <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>.</note>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ዘርአ፡ ያዕቆብ፡ ነግሠ፡ ፴ወ፬ዓመተ፡ በዕደ፡ ማርያም፡ 
                                ነግሠ<supplied reason="omitted">፡</supplied> ፲ዓመተ፨ እስክንድር፡ ምስለ፡ ዓምደ፡ ጽዮን፡ ወልዱ፡ ነግሠ፡ ፲ወ፯ዓመተ፨ ናዖድ፡ ነግሠ፡ 
                                ፲ወ፯ዓ<supplied reason="explanation">መተ</supplied>። ወእምድኅሬሁ፡ ነግሠ፡ ወልዱ፡ ልብነ፡ ድንግል፡ ፳ወ፩ዓመተ፨ በትፍሥሕት፨
                            </incipit>
                        </msItem>

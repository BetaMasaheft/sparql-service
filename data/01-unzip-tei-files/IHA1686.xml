               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="88v">2r-88v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT0114IHA">فواكه الجنية على متممة الآجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم \ احمد الله على نعمه واشكره على مزيد فضله وكرمه [...] وبعد فهذا تعليق لطيف وصعته على المقدمة الموضوعه في علم العبربيه تاليف سيدنا وصاحبنا العالم الورع الزاهد شمس الدين محمد بن الشيخ محمد الرعينى الشيهر بالحطاب المكى المالكى تغمده الله برحمته قصدت فيه تقرير معانيها وتحرير متانيها مع فوائد رحمة وزوائد مهمة وسميته الفواكه الجنية على متممت الاجروميه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#88v">-88v</locus>وقد قرا به بعذ السبعة فى قوله تعالى ارحمة الله قريب من المحسنين واليكن هذا اخر ما تيسر جمعه على هذه المقدمة جعله الله خالصا لوجهه الكريم وموجيبا للفوز العظيم بنجات النعيم بمنه وكرمه وفضله الجسيم اشكر نعمتك التى انعمت على وعلى والدى واه عمل صالحا وترضاه وادخلنى فى [عبادك] الصالحين والحمد لله رب العلمين امين امين ام ام </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="89r" to="91r">89r-91r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1208IHA">حدود النحوية</title>
                     <incipit xml:lang="ar">
                        <locus target="#89r">-89r</locus>البسم الله الرحمن الرحيم \ الحمد
 لله الذى اعطى من رفع قدره مكانا عليا وشرفه باللغة العربية [...] وبعد فقد سالنى من لا تسعنى مخالفته ان اجمع له الحدود المختارة فى علم النحو وما ضم اليه فأجبته  الى سواله وشرعت فيه مقتصا على ذكر الحدود فاقول مستمدا من الله التوفيق</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#91r">-91r</locus>حد الخط تصوير اللفظ المقصود وتصويره برسم حروف هجائية بتقدير الابتداء بها والوقف عليها وليكن هذا اخر ما اردنا ايراده من الحدود النحوية تمت وصلى الله على سيدنا ومولانا محمد وصحبه وسلم امين

</explicit>
                     <note/>
                     <note/>
                  </msItem>

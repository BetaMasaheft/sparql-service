                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, irregular</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Late 19th – early 20th century</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                           <item>እማ፡ for እማሬ፡</item>
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; several letters in nomina sacra on
                           fols. 60va-61rb; name of the king, bishop and patriarch; groups of red
                           lines alternating with black in the incipit page of Text I; incipits of
                           the texts and their sections; directives for the ministers; some other
                           words, e.g. ጸሎት, ጽዋዕ, ከመ, ካዕበ; elements of the punctuation signs;
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hastily executed, conspicuously right
                        sloping.
                        </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Smaller letters on <locus from="75r" to="77r">75r-77r</locus>.</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#3r">3r</locus> (incipit page of Text I): ornamental band,
                        geometric motifs.</decoNote>
                     <decoNote type="frame" xml:id="d2">
                        <locus target="#36vb">36vb</locus> (incipit page Texyt II): colored (red and
                        black) ornamental band, geometric motifs.</decoNote>
                  </decoDesc>
                  <additions>

         <listPerson>
            <person sex="1">
              
              
              
               <persName xml:lang="gez" xml:id="n1" type="birth">ሜናስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Menās</persName>
               <persName xml:lang="gez" xml:id="n2" type="alt">ሚናስ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Minās</persName>
              
                  <persName>
                  <roleName type="title">ʾabbā </roleName>
               </persName>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
                  <birth/>
                  <residence/>
                  
                     <floruit>He was  a saint  and martyr venerated in the <placeName ref="https://betamasaheft.eu/LOC2056Byzant">Byzantine empire </placeName> and all over the Christian Orient, especially in 
                        <placeName ref="https://betamasaheft.eu/LOC2804Egypt">Egypt</placeName>. He was supposedly martyred during the <persName ref="https://betamasaheft.eu/PRS3581Diocleti">Diocletian</persName>
                        persecution of Christians  in <placeName ref="https://betamasaheft.eu/LOC4151Kotyai">Kotyaion</placeName>. <persName ref="https://betamasaheft.eu/PRS7000MenasM">Minās</persName> seems to have been a popular saint in 
                        <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</placeName> to which both his frequent representations in art as well as the name of <date>16th century</date> 
               
                        <persName ref="https://betamasaheft.eu/PRS7102Minas">   
                     <roleName type="title">ʾaṣe</roleName>Minās</persName>, named after him, testify.
                     </floruit>
                  <death/>
               </person>
               
         </listPerson>

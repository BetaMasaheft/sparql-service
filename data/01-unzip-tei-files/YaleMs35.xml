          <msContents>
            <summary/>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="41r" facs="003">Fols 1r–41r</locus>
              <title>The story of Mary and Ephrem and the composition of the Praises of Mary,
                arranged for the days of the week</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <msItem xml:id="ms_i1.1">
                <locus from="1r" to="6r" facs="003">Fols 1r–6r</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Monday, which
                  he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.2">
                <locus from="6v" to="12v" facs="009">Fols 6v–12v</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Tuesday,
                  which he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.3">
                <locus from="13r" to="19r" facs="015">Fols 13r–19r</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Wednesday,
                  which he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.4">
                <locus from="19v" to="27r" facs="022">Fols 19v–27r</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Thursday,
                  which he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="27r" to="32r" facs="029">Fols 27r–32r</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Friday, which
                  he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.6">
                <locus from="32r" to="36v" facs="034">Fols 32r–36v</locus>
                <title>How the Virgin Mary instructed Ephrem in the Praise of Mary for Saturday,
                  which he then recites</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.7">
                <locus from="36v" to="42r" facs="039">Fols 36v–42r</locus>
                <title/>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i2">
                <locus from="42v" to="58r" facs="045">Fols 42v–58r</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i3">
                <locus from="59r" to="91v" facs="061">Fols 59r–91v</locus>
                <title>The Book of Mohammad Graññ, <foreign xml:lang="gez">መጽሐፈ ግራኝ</foreign>. The
                  story of the invasion of Mohammad Graññ and the list of the martyrs killed by
                  him</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i4">
                <locus from="92r" to="109v" facs="094">Fols 92r–109v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾ-hymn to St
                                                  George</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                <incipit xml:lang="gez">ሰላም ለዝክረ ስምከ ዘሰሌዳ ሞገስ መጽሐፉ</incipit>
              </msItem>
            </msItem>
          </msContents>
          <physDesc>
            <objectDesc form="Codex">
              <supportDesc>
                <support>
                  <material key="paper"/>
                </support>
                <extent>
                  <measure unit="leaf">ii + 110</measure>
                  <dimensions type="outer" unit="mm">
                    <height>120</height>
                    <width>80</width>
                    <depth/>
                  </dimensions>
                </extent>
              </supportDesc>
              <layoutDesc>
                <layout columns="1" writtenLines="15 16"/>
              </layoutDesc>
            </objectDesc>
            <additions>
              <list>
                <item xml:id="a1">
                  <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                  <desc> Prescription and instructions for prayer, involving the recitation of
                    prayers (<foreign xml:lang="gez">ጸሎት እግዝእትነ ማርያም</foreign> and <foreign xml:lang="gez">ጸሎተ ሃይማኖት</foreign>) seven times, eating seven seeds of the
                      <foreign xml:lang="gez">ጠበለል</foreign> tree with honey, presumably in order to
                    gain knowledge or wisdom </desc>
                </item>
                <item xml:id="a2">
                  <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                  <desc> A prayer of blessing for the scribe </desc>
                </item>
                <item xml:id="a3">
                  <locus target="#110r" facs="112">Fol. 110r</locus>
                  <desc type="GuestText"> Excerpt from the beginning of <title type="incomplete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>, Yǝwedǝssǝwa Mäla’ǝkt, <foreign xml:lang="gez">ይዌድስዋ
                      መላእክት ለማርያም</foreign>
                  </desc>
                </item>
                <item xml:id="a4">
                  <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                  <desc> A list of names of a leading judge and priest of the region of <foreign xml:lang="gez">ዐፎሊ ምድር</foreign>. There follows at least three more names of
                    people. The names appear to be of Oromo people </desc>
                </item>
                <item xml:id="a5">
                  <locus target="#6r #12v" facs="008 015"> f. 6r, 12v and passim</locus>
                  <desc type="OwnershipNote"> mention an owner <foreign xml:lang="gez">ቅብዓ
                      ሥላሲ</foreign>. <locus target="#58r" facs="060">Fol. 58r</locus> mentions another owner(?),
                      <foreign xml:lang="gez">ወልደ ማርያም</foreign>
                  </desc>
                </item>
                <item xml:id="a6">
                  <locus target="#19r">Fol. 19r</locus>
                  <desc> mentions the scribe, <foreign xml:lang="gez">ገብረ ኪዳን</foreign>
                  </desc>
                </item>
                <item xml:id="a7">
                  <locus target="#109v" facs="112">Fol. 109v</locus>
                  <desc type="OwnershipNote"> mention later owners(?) or family members, written in
                    a later hand: <foreign xml:lang="gez">ገብረ ማርያም, ወልደ ማርያም, ወልዳ ኢየሱስ</foreign>
                  </desc>
                </item>
                <item xml:id="a8">
                  <locus target="#Inside front cover">Fols. Inside,, </locus>
                  <desc> Donation plate from Thomas Ewart Marston </desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="true">
                <decoNote xml:id="b1" type="bindingMaterial">
                  <material key="parchment"/>
                  <material key="wood"/>
                </decoNote>
              </binding>
            </bindingDesc>
          </physDesc>
          <history>
            <origin>
              <origDate notBefore="1700" notAfter="1899">Eighteenth or nineteenth century</origDate>
            </origin>
          </history>

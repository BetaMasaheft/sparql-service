                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Blank; red (vivid red).</seg>
                        <date>Early 20th century (?)</date>
                        <list type="abbreviations">
                           <item>ለዓለ/ለዓ፡ ዓለ፡ አሜን፡ (e.g., <locus target="#12va">12va</locus>, 68ra,
                              103ra).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the protagonists (Qirqos and
                           ʾIyäluṭa); names of the donors; a group of lines alternating with black
                           lines in the incipit page of Texts I and II; the initial lines of each
                           section (for the monthly readings) and subsection in Text I; the initial
                           lines of each miracle in Text II; 
 some corrections interlineally;
                           elements of Ethiopian numerals and of punctuation signs.</seg>
                     </handNote>
                  </handDesc>
                  <additions>

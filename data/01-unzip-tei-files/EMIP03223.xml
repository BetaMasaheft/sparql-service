                  <idno facs="EMIP/Codices/3223/" n="210" corresp="https://betamasaheft.eu/api/iiif/EMIP03223/manifest">Sobania 2</idno>
               </msIdentifier>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="2r" to="202r" facs="002">Fols 2r–202r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="2r" to="162v" facs="002">Fols 2r–162v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1.1">
                        <locus target="#2r" facs="002">Fol. 2r</locus>
                        <title>Opening of Psalter</title>
                          <incipit xml:lang="gez">ተግሣጽ፡ ለኵሉ፡ በእንተ፡ ጸድቃን፡ ወኃጥአን፡</incipit>
                        </msItem>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> listed for only the first four letters</note>
                      <note><locus target="#162v" facs="163">Fol. 162v</locus>, <ref type="work" corresp="https://betamasaheft.eu/LIT2701Dawit#Chp151"><span xmlns="" class="w3-tag w3-red">No item: LIT2701Dawit#Chp151</span></ref> contains the first, third and fourth of the plusses that make up the long version</note>
                      <note>Scribal doxology at the end of the Psalms</note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="163r" to="179v" facs="163">Fols 163r–179v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note><locus target="#168v" facs="169">Fol. 168v</locus>, <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> noted as Prayer of Hana, mother of Samuel</note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="180r" to="187v" facs="180">Fols 180r–187v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>In the common version</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref> is laid out beginning with Monday and culminating in Sunday</note>
                      <note><locus target="#187v" facs="188">Fol. 187v</locus>, Scribal prayer invoking the memory of someone (whose name has been erased) at the end of the Song of Songs</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="188r" to="198r" facs="188">Fols 188r–198r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.4.1"><locus from="188r" facs="188">Fols 188r and following</locus><title>Monday</title></msItem>
                      <msItem xml:id="ms_i1.4.2"><locus from="189r" facs="189">Fols 189r and following</locus><title>Tuesday</title></msItem>
                      <msItem xml:id="ms_i1.4.3"><locus from="190v" facs="191">Fols 190v and following</locus><title>Wednesday</title></msItem>
                      <msItem xml:id="ms_i1.4.4"><locus from="192r" facs="192">Fols 192r and following</locus><title>Thursday</title></msItem>
                      <msItem xml:id="ms_i1.4.5"><locus from="194v" facs="195">Fols 194v and following</locus><title>Friday</title></msItem>
                      <msItem xml:id="ms_i1.4.6"><locus from="195v" facs="196">Fols 195v and following</locus><title>Saturday</title></msItem>
                      <msItem xml:id="ms_i1.4.7"><locus from="196v" facs="197">Fols 196v and following</locus><title>Sunday</title></msItem>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="198r" to="202r" facs="198">Fols 198r–202r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
                    </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">202</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>
                              <width/>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="16 19">
                         <locus from="1r" to="187v" facs="001">Fols 1r–187v</locus>
                       </layout>
                       <layout columns="2" writtenLines="16 19">
                         <locus from="188r" to="202v" facs="188">Fols 188r–202v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word for God is not rubricated in the first three works</desc>
                  <desc>Columetric layout is only in the 10th biblical canticle and not in <ref type="work" corresp="https://betamasaheft.eu/LIT2701Dawit#Chp150"><span xmlns="" class="w3-tag w3-red">No item: LIT2701Dawit#Chp150</span></ref> or <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps148"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps148</span></ref></desc>
                  <desc>The scribe distinguishes the numbers 6 from 7, by writing the 6 much smaller than the 7.  See, e.g., <ref type="work" corresp="https://betamasaheft.eu/LIT2701Dawit#Ps76"><span xmlns="" class="w3-tag w3-red">No item: LIT2701Dawit#Ps76</span></ref></desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r #1v" facs="001 002">Fols. 1r, 1v</locus>
                    <desc>
                    Measurement for the Shadow, <foreign xml:lang="gez">ስፍረ፡ ጽላሎት፡ ዘጊዜ፡ ቁርባን፡</foreign> List of shadows in each month, for the calculation of the times of services
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#202v" facs="203">Fol. 202v</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for help with pain in childbirth, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ወሊድ፡</foreign>, written in a later hand of the 20th century
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#84v" facs="085">Fol. 84v</locus>
                    <desc>
                    The midpoint of the Psalms is unmarked
                    </desc>
                    </item>
                    <item xml:id="e2">
                      <desc>Tooled leather covers (much of which is lost), with colored cloth visible between the paste downs</desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#179v" facs="180">Fol. 179v</locus>
                    <desc>
                    scribal doxology at the end of the Biblical Canticles, in a secondary hand
                    </desc>
                    </item>
                    <item xml:id="a4">
                      <desc type="Asmat"><locus target="#202v" facs="203">Fol. 202v</locus>, Asmat prayer against Barya, written in a later hand</desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment. Wooden boards, covered with tooled leather, fine fabric is visible between the pastedowns on the front and back inside covers.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1650" notAfter="1750">Late-seventeenth/early-eighteenth century</origDate>
                  </origin>
                  <provenance>The manuscript has been donated to Hope College, Holland Michigan, where it as assigned the accession number TR2017.75.485.1</provenance>
               </history>
            </msDesc>
         </sourceDesc>

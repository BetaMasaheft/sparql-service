                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                    <seg type="rubrication">
                    <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                    <foreign xml:lang="gez">ማርያም፡</foreign>
                    </seg>
                    <desc>The word God is rubricated in the first three works; the word Mary is rubricated in the final two works. The word God is occasionally written in alternating red and black letters, e.g. <locus target="#18v #19r" facs="019">Fols. 18v, 19r</locus>.</desc>
                    <desc>Columetric layout of text: <locus target="#113v #114r" facs="114">folss. 113v, 114r, </locus> (Psalm 148), <locus target="#114v #115r" facs="115">114v, 115r, </locus> (Psalm 150), <locus target="#123v #124r #124v" facs="124 125">123v, 124r, 124v</locus> (tenth biblical canticle)</desc>
                  </handNote>
                    </handDesc>
                    <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#5r" facs="005">Fol. 5r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> attended by the angels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#39r" facs="039">Fol. 39r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1024MosesLaw">Moses Receiving Law</ref> with captions <q>“Moses,” “the tablet”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#73r" facs="073">Fol. 73r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1092SacrificeIsaac">The Sacrifice of Isaac</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#93v" facs="094">Fol. 93v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref><persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> with caption<q>“Michael enthroned”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#135r" facs="135">Fol. 135r</locus><desc> Crude drawing of a person, in pencil</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#135v" facs="136">Fol. 135v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#155v" facs="156">Fol. 155v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> standing, center, with a saint on either side, and a crowd behind</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#156v" facs="157">Fol. 156v</locus><desc> crude drawing of a person, in pencil</desc></decoNote>
                    <decoNote type="frame" xml:id="d9">
                    Decorative designs:
                    <locus target="#1r #21r #37v #74r #115v" facs="001 021 038 074 116">folss. 1r, 21r, 37v, 74r, 115v, </locus> (haräg);
                    <locus target="#7r #30r #37v #42v #51v #61r #68v #134v" facs="007 030 038 043 052 061 069 135">7r, 30r, 37v, 42v, 51v, 61r, 68v, 134v, </locus> (line of alternating red and black dots);
                    <locus target="#89r" facs="089">89r, </locus> (line of red dots);
                    <locus target="#101r #104r #109v #115r #127v #137v #149r #150v" facs="101 104 110 115 128 138 149 151">101r, 104r, 109v, 115r, 127v, 137v, 149r, 150v, </locus> (line of full stops between lines of red and black dots);
                    <locus target="#140r #142v" facs="140 143">140r, 142v, </locus> (multiple full stops);
                    <locus target="#147v" facs="148">147v</locus> (lines of black dots)
                    </decoNote>

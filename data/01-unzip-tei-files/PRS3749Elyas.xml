         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ኤልያስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾElyās</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">monk</t:occupation>
          
               <t:floruit notBefore="1400" notAfter="1499">He was  a monk of the 15th century who had  a connection to the royal family. 
                  He lived during the reigns of  
                  <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY">
                     <t:roleName type="title">ʾaṣe</t:roleName> Zarʾa Yāʿqob</t:persName>, 
                 
                  <t:persName ref="https://betamasaheft.eu/PRS2334BaedaM"> 
                     <t:roleName type="title">ʾaṣe</t:roleName>  
                     Baʾǝda Māryām I</t:persName>,  
                  <t:persName ref="https://betamasaheft.eu/PRS3874eskender">
                     <t:roleName type="title">ʾaṣe</t:roleName> 
                     ʾƎskǝndǝr</t:persName> and 
                  <t:persName ref="https://betamasaheft.eu/PRS7481NaodA">
                     <t:roleName type="title">ʾaṣe</t:roleName>  Nāʿod (ʾAnbasā Baḍar)
                </t:persName>. 
                He is said to have clashed with the <t:persName ref="https://betamasaheft.eu/PRS11211Stephanites">Stephanites</t:persName> clergy and to have been persecuted by their supporters.</t:floruit>
           
               </t:person>
               
         </t:listPerson>

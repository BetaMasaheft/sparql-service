                        <additions>
                            <list>
                              <item xml:id="a1">
                                <locus from="1v" to="2v"/>
                                <desc type="GuestText">Hymns to the blessed Virgin Mary</desc>
                                <q xml:lang="gez"/>
                              </item>
                              <item xml:id="a2">
                                <locus target="#3r"/>
                                <desc type="Record">A deed in Amharic</desc>
                                <q xml:lang="am"/>
                              </item>
                              <item xml:id="a3">
                                <locus target="#4r"/>
                                <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                    <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                <q xml:lang="gez">ሰዓታት፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam"> ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                          </q>
                              </item>
                              <item xml:id="a4">
                                <locus from="133v"/>
                                <desc type="PoemSalam">Hymns to the blessed Virgin Mary for
                                various hours.</desc>
                                <q xml:lang="gez"/>
                              </item>
                              <item xml:id="a5">
                                <locus from="134v"/>
                                <desc type="PoemSalam">Hymns to the holy Trinity.</desc>
                                <q xml:lang="gez"/>
                              </item>
                              <item xml:id="a6">
                                <locus from="135r"/>
                                <desc type="GuestText">Prayers for the souls of various persons, whose names
                                are mentioned, probably priests and benefactors of <placeName ref="https://betamasaheft.eu/INS0330DDQ">Dabra Ḍaḥay Qʷǝsqʷām</placeName>.</desc>
                                <q xml:lang="gez">
                                  <seg part="I">
                                    አዕርፍ፡ እግዚኦ፡ ነፍሳተ፡ አበዊነ፡ ሕዝቅያስ። ቴዎድሮስ። አውሴ። ወልደ፡ ጊዮርጊስ።<gap reason="ellipsis"/>
                                    አዕርፍ፡ እግዚኦ፡ ነፍሳነ፡ <sic>አግብርቲከ፡</sic> ቴዎድሮስ። ሮብዓዓም። ሣህለ፡ ኪሮስ። ተክለ፡ ሃይማኖት።<gap reason="ellipsis"/>
                                    አዕርፍ፡ እግዚኦ፡ ነፍሰ፡ ንግሥትነ፡ <persName ref="https://betamasaheft.eu/PRS2682BerhanM">ወለተ፡ ጊዮርጊስ።</persName>
                                    አዕርፍ፡ እግዚኦ፡ ነፍሳተ፡ አእማቲከ፡ ወለተ፡
                                    ቅዱሳን። ወለተ፡ ሩፋኤል።
                                  </seg>
                                </q>
                              </item>
                            </list>
                        </additions>

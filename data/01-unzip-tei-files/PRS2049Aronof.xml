         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አሮን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAron of Dabra Dāret</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">አሮን፡ መንክራዊ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAron Mankrāwi</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="birth">እጬ፡ አሮን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">ʾƎč̣e ʾAron</t:persName>

               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>

               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               <t:birth when="1350" cert="medium"> He was born in around <t:date>1350</t:date>.
               </t:birth>
               <t:floruit notBefore="1350" notAfter="1450">He joined the monastery of
                  <t:placeName ref="https://betamasaheft.eu/LOC2278DabraG">Dabra Gʷāl</t:placeName> and he became a monk.
                  There, having witnessed his exceptional piety
                  and wisdom, the monks elected him as archdeacon and bursar of  the community.
                  He also took part in the l4th century controversy between the Ethiopian kings and monks.
                  He was the founder of the rock-hewn church of <t:placeName ref="https://betamasaheft.eu/LOC2230DabraA">Dabra ʾAbuna ʾAron </t:placeName> in the western
                  part of <t:placeName ref="https://betamasaheft.eu/LOC6132Wadla">Wādlā </t:placeName>.
               </t:floruit>

            </t:person>
            
         </t:listPerson>

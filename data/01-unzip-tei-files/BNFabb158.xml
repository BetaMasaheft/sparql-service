                       <msItem xml:id="ms_i16">
                          <locus from="155ra" to="164rb"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1638Homily">Homily on the Assumption of Mary</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                             <hi rend="rubric">በስመ፡ አብ፡ <gap reason="ellipsis" resp="DN"/></hi>ድርሳን፡ ዘ<hi rend="rubric">ደረሰ፡  አቡነ፡ ክቡር፡ በኵሉ፡ ምግ</hi>ባራት፡ አባ፡ ሕርያቆስ፡ ኤጲስ፡ 
                             ቆ<hi rend="rubric">ጶስ፡ ዘሀገረ፡ ብህንሳ፡ እንዘ፡ ይነ</hi>ብር፡ ውስተ፡ ቤተ፡ ክርስቲያና፡ ለእግዝእትነ፡ <hi rend="rubric">ማርያም፡</hi> ድንግል፡ ቅድስት፡ በዕለተ፡ ዕርገታ፡ ቅዱስ፡ አነ፡ ፲ወ፮ለነሐሴ፨
                             ወዜነወ፡ ንስቲተ፡ እምስብሐታቲሃ፡ በሰላመ፡ እግዚአብሔር፨ <gap reason="ellipsis" resp="DN"/><hi rend="rubric">ይቤ፡ ቃል፡ ሥጋ፡ ኮነ፡ ወኃደረ፡ ላዕሌነ። ኦፍቁራኘ፡ አምላክ፡ ቃ፡ ተሰ</hi>ብአ፡ 
                             እምከርሠ፡ <hi rend="rubric">ማርያም፡</hi> ድንግል፡ እግዚእትነ፨ መለኮት፡ ዘኢያስተርኢ፡ አስተርአየ፡                            
                         </incipit>                         
                       </msItem>           
               

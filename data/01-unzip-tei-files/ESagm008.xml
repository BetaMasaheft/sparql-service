                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#153rb">f. 153rb</locus>
                           <desc type="Genealogy">Monastic genealogy (from <persName ref="https://betamasaheft.eu/PRS1962Anthony">St Anthony</persName> to <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</persName>).</desc>

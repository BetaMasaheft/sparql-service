                     <msItem xml:id="ms_i1.18">
                        <locus from="26v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3023RepCh303">ተፈሥሒ፡ ማርያም፡ ድንግልተ፡ ሥጋ፡</title>
                     </msItem>
                     <msItem xml:id="ms_i1.19">
                        <locus from="28v"/>
                        <title>Short invocation to Our Lady Mary</title>
                        <incipit xml:lang="gez">
                           ሰላም፡ ለኪ፡ ድንግልተ፡ በሕሊናኪ፡ ወድንግልት፡ በሥጋኪ፡ እመ፡ እግዚአብሔር፡ ጸባኦት፡ ሰላም፡ ለኪ፡ <del rend="expunctuated">ድንግልት፡</del> ቡርክት፡ እምአንስት፡ ወቡሩክ፡ ፍሬ፡ 
                           ከርሥኪ፡
                        </incipit>
                     </msItem>

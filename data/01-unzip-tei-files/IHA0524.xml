                        </item>
                        <item xml:id="a2_1525">
                           <locus target="#2r-13r-22v">-2r, 13r, 22v</locus>
                           <desc>Marginalia</desc>
                           <note>Corrections marked Ṣaḥīḥ or Ṣaḥḥ.</note>
                           <note/>

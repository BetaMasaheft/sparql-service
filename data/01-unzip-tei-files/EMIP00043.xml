               <msContents>
                  <summary>Prayer of the Covenant, ጸሎተ፡ ኪዳን፡, Supplications, መስተብቍዕ, incomplete, The different Litanies, incomplete, Ordinary of the Mass, incomplete, ሥርዓተ፡ ቅዳሴ፡, Praises of Mary, ውዳሴ፡ ማርያም፡, Gate of Light</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="8v" facs="003"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="8v" to="23v" facs="011"/>
                     <locus from="29r" to="36v" facs="031"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</title>
                     <note>Incomplete; includes the supplication for Mary, containing the expression condemned at the Boru Meda Council of 1878, and the Cross</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="24r" to="29r" facs="026"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3188Liton">Liṭon</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="37r" to="43r" facs="039"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddase">Maṣḥafa qǝddāse, Śǝrʿāta qǝddāseሥርዓተ፡ ቅዳሴ፡</title>
                     <note>Incomplete at the end, erased to make room for the forged picture</note>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="46r" to="71v" facs="048"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>

                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="71r" to="75v" facs="073"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                     <note>Incomplete in the middle (to make room for forgery) and at the end</note>
                  </msItem>
               </msContents>

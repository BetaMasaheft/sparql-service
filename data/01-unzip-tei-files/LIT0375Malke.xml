         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ወጠንኩ፡ ሰቆቃወ፡ ሥጋ፡ ግሱስ፨</l>
                  <l n="2">ተላዌ፡ ሰቆቃው፡ ዘነፍስ፨</l>
                  <l n="3">ባሕቱ፡ ብሂለ፡ ኢትበለኒ፡ ክርስቶስ፨</l>
                  <l n="4">ለምንት፡ ትነብብ፡ በአፉከ፡ እንዘ፡ ልብከ፡ ግሑሥ፨</l>
                  <l n="5">እምገቢረ፡ ዓሥር፡ ትእዛዝ፡ ወቃላት፡ ሳድስ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">በእንቲአኪ፡ ነበብኩ፡ መንፈቀ፡ ሠላሳ፡ ድርሳናት፨</l>
                  <l n="2">ኦሥጋየ፡ ድሉተ፡ ኵለንታ፡ ለሞት፨</l>
                  <l n="3">ለመጽሐፈ፡ ዜናኪሰ፡ እስከ፡ ፍጻሜ፡ እምጥንት፨</l>
                  <l n="4">በረቀ፡ ሰማይ፡ ወበማየ፡ ሕመት፨</l>
                  <l n="5">አብሕርት፡ እምኢፈጸምዎ፡ ወብዙኃን፡ ጸሐፍት፨</l>
               </lg>
            </div>
         </div>
      </body>

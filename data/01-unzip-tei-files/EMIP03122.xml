                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r" facs="001">Fol. 1r</locus>
                    <desc type="GuestText">
                    excerpt from <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>, written in a secondary hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#22v" facs="023"> f. 22v, col 2, end</locus>
                    <desc>
                    Excerpt of text recording the conversation between Jesus and Mary Magdalene, written in a different hand
                    </desc>
                    <notatedMusic><desc>with musical notation</desc></notatedMusic>
                    </item>
                    <item xml:id="a3">
                    <locus from="80r" facs="080"> f. 80r, col. 2, bottom</locus><locus to="82r" facs="082"> f. 82r, col. 1</locus>
                    <desc type="GuestText">
                    Excerpt from <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke">Wangel
                                                  za-Luqās</title>, where Mary visits her cousin Elsabet; the story from Mark about John the Baptist and King Herod; and the pericope about the Word from John 1, all written in a different hand
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#82r" facs="082"> f. 82r, col. 2</locus>
                    <desc type="OwnershipNote">
                    Note of ownership: This book belongs to Alaq Estifanos, son of Atsme Giyorgis, <foreign xml:lang="gez">እስጢፋኖስ ወልደ አጽመ ጊዮርጊስ</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Part of the collection of Haroutune Nazarian, who had microfilms made of his Ethiopian manuscripts and the microfilms sent to the Institute of Ethiopian Studies. They were digitized by EMIP workers in Addis Ababa in the first half of 2010
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#88r" facs="088">Fol. 88r</locus>
                    <desc>
                    The microfilming information board (image 88) indicates that the manuscript was microfilmed in 1982 and assigned the number 105
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    64v‒65r: missed shot
                    </desc>
                    </item>
                  </list>

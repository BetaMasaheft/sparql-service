                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="003">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref> (<persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>?)and <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, painted over text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#1r" facs="003">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>, painted over text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#20r" facs="022">Fol. 20r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/>, rainted over text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#40r" facs="042">Fol. 40r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref>Three figures: 1. a saint offering a blessing; 2. a person holding a handkerchief; 3. a person folding a handcross and a handkerchief, painted over text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#82v" facs="085">Fol. 82v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> holding handcrosses and prayer staffs, painted over text</desc></decoNote>
                    <decoNote type="frame" xml:id="d6">
                      Decorative designs:
                      <locus target="#1r #10r #59v" facs="003 012 062">folss. 1r, 10r, 59v, </locus>, ornamental band;
                      <locus target="#57v" facs="060">57v</locus>, line of alternating red and black dots</decoNote>
                  </decoDesc>
                  <additions><list>
                    <item xml:id="a1"><desc type="GuestText"><locus target="#82r #82v #83r #83v" facs="084 085 086">Fols. 82r, 82v, 83r, 83v</locus>Excerpts of lectionary readings. Written in a later hand in blue ink. </desc></item>
                    <item xml:id="a2"><desc type="GuestText"><locus target="#84r #84v #85r #85v #86r #86v #87r" facs="086 087 088 089">Fols. 84r, 84v, 85r, 85v, 86r, 86v, 87r</locus>Excerpts of lectionary readings. Written in a later hand in pencil.</desc></item>
                    <item xml:id="a3"><desc type="OwnershipNote"><locus target="#ir" facs="001">Fol. ir</locus>Note of secondary ownership written in blue ink. The name of the owner is Bäqälä Täkle (<foreign xml:lang="gez">በቀለ፡ ተክሌ፡</foreign>), whose baptismal name is Gäbrä ʾIyyäsus (<foreign xml:lang="gez">ገብረ፡ ኢየሱስ፡</foreign>)</desc></item>
                    <item xml:id="a4"><desc><locus target="#iv" facs="002">Fol. iv</locus>Illegible note written in blue ink.</desc></item>
                    <item xml:id="a5"><desc type="Record"><locus target="#iir" facs="002">Fol. iir</locus>Record of birthday on <date calendar="ethiopian">1952, Sane 8</date>, mostly covered by a miniature</desc></item>
                    <item xml:id="a6"><desc type="Record"><locus target="#87r" facs="089">f.87r, bottom</locus>Note of birth in 1942, written in blue ink.</desc></item>
                    <item xml:id="e2"><desc><locus target="#88v" facs="091">Fol. 88v</locus>Blank</desc></item>
                    <item xml:id="e3"><desc>
                      Scribal intervention: words of text are written interlinearly (<locus target="#35v #44r #76v #79v #80r" facs="038 046 079 082">folss. 35v, 44r, 76v, 79v, 80r, </locus>, etc.);
                      and in the upper margin with a symbol (┴) marking the location where the text is to be inserted (<locus target="#5r #5v #62r" facs="007 008 064">5r, 5v, 62r, </locus>),
                      and in another case where the symbol (+) is used (<locus target="#7r" facs="009">7r, </locus>);
                      erasure markings are visible (<locus target="#36r #37v" facs="038 040">36r, 37v, </locus>);
                      text has been removed (<locus target="#21v #79v" facs="024 082">21v, 79v</locus>)</desc></item>
                  </list></additions>


               <msContents>
                  <summary/>


                  <msItem xml:id="ms_i1">
                     <locus from="1" to="34">Fols 1–34</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba ṭabibān</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>ኦእግዚአብሔር፡ ጠቢበ፡ ጠቢባን፡ ከሃሊ። <lb n="2"/>እስከ፡ ለዓለም፡ እምጥንት፡ እንተ፡ ኢትበሊ።
                           <lb n="3"/>ድኩመ፡ ሕሊና፡ ገብርከ፡ ወፈራሄ፡ ልብ፡ ኢተሀባሊ። <lb n="4"/>እስመ፡ ኃቤከ፡ እግዚኦ፡
                        ጸሎተ፡ አድኅኖ፡ እጼሊ። <lb n="5"/>አድኅነነ፡ ወባልሐኒ፡ እምኵሉ፡ ቀታሊ። </incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="34" to="35">Fols 34–35</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4629Praise">Rhymed Praise of God</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>ስብሐት፡ ለከ፡ እግዚአብሔር፡ አብ፡ ጥንተ፡ መዋዕል፡ ወዕድሜ። <lb n="2"/>ለመለኮትከ፡ ዘአልቦ፡
                        ትርጓሜ። <lb n="3"/>ወለመንግሥትከ፡ ግብረ፡ <sic resp="PRS3562Dillmann">ፈጻሜ።</sic>
                     </incipit>
                     <note>This hymn consists of seven stanzas, each of which begins with <foreign xml:lang="gez">ስብሐት፡ ለከ፡</foreign>.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="35" to="42">Fols 35–42</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">Māḫbara mǝʾmanān</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>ማኅበረ፡ ምዕመናን፡ ወምዕመናት፡ እለ፡ ኪያከ፡ ተአምኑ። <lb n="2"/>ለነሢአ፡ ሥጋከ፡ ወትረ፡
                        ኀበ፡ ተአየኑ። <lb n="3"/>ወልደ፡ አብ፡ ክርስቶስ፡ ዘኢትትፈለጥ፡ እምሕፅኑ። <lb n="4"/>እሰብክ፡ ሎሙ፡
                        ሕማመከ፡ ወመስቀለከ፡ እዜኑ። <lb n="5"/>ጸጋ፡ መንፈስ፡ ቅዱስ፡ ሊተ፡ እምሰማይ፡ ፈኑ። </incipit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="42" to="47">Fols 42–47</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2903RepCh184">Malkǝʾ-hymn to the Fathers of Nicea</title>
                     
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>ሰላም፡ ለዝክረ፡ ስምክሙ፡ ምሉዓ፡ ውዳሴ፡ ወስብሐት። <lb n="2"/>ለርእስክሙ፡ ወለገጽክሙ፡ ገጻተ፡
                        ጽዱላን፡ ብርሃናት። <lb n="3"/>፫፻፲ወ፰ ርቱዓነ፡ ሃይማኖት። <lb n="4"/>ባርኩኒ፡ በእዴክሙ፡ እደ፡ ጸጋ፡
                        መንፈስ፡ ወሀብት። <lb n="5"/>በበረከቶሙ፡ ለአቤል፡ ወሴት። </incipit>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="47" to="62">Fols 47–62</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3082RepCh362">Hymn to Our Lady Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>እግዚአብሔር፡ ወሀቤ፡ ብርሃን፡ ዘይሤለስ፡ በአካሉ። <lb n="2"/>እንዘ፡ ተዋህዶ፡ ያጸንዕ፡
                        በመለኮቱ፡ ወኃይሉ። <lb n="3"/>ዓይነ፡ <sic resp="PRS3562Dillmann">ልቦናየ፡</sic> ያብርህ፡
                        በማኅቶተ፡ ጥበብ፡ ስነ፡ ጸዳሉ። <lb n="4"/>ከመ፡ ይርአይ፡ ገጸ፡ ነገር፡ ለኪዳንኪ፡ ይደሉ። <lb n="5"/>ማርያም፡ እግዝእተ፡ ኵሉ፡ ዘታሕቱ፡ ወላዕሉ። </incipit>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="62" to="63">Fols 62–63</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2812RepCh96">Malkǝʾ-hymn to Our Lady Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb n="1"/>ሰላም፡ ለኪ፡ ኪዳነ፡ ምሕረት፡ ተስፋየ፡ ዘታጸድቂ፡ ኃጥአ። <lb n="2"/>ወዘተኃሥሢ፡ አሐደ፡
                        በግዓ። <lb n="3"/>ዘተገድፈ፡ እምነ፡ ተስዓ። </incipit>
                  </msItem>

               </msContents>


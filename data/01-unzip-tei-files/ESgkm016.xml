                           <quote xml:lang="en"/>
                           <note> The note is written in the same hand as Additio 3. It contains a
                              rubricated incipit of the miracle. </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#77r">f. 77r</locus>

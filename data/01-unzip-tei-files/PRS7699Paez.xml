      <body>
         <listPerson>
            <person sex="1" sameAs="wd:Q708822">
               <persName>
                  <forename>Pedro</forename>
                  <surname>Páez</surname> 
               </persName>
               
               
          
            
      
               <occupation type="ecclesiastic">missionary</occupation>
               <nationality type="Spain"/>
               <faith type="Catholicism"/>
               <birth>1564 </birth>
               <residence>He was in the court of <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>
               </residence>
               <floruit when="1603" evidence="internal">He arrived in Ethiopia<date> on 22 March 1603</date>. 
                  He was succesful to convert King <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>in <date> 20 May 1622</date> to Catholicism. 
                  He contributed to the early building projects of the mission. 
                  He authored several letters addressed to fellow Jesuits, friends and relatives in India and Europe.
                  In his final years of his life,  he authored an important book on Ethiopian history called História da Etiópia.
               </floruit>
               <death> He died on <date>20 May 1622</date> at <placeName ref="https://betamasaheft.eu/LOC3589Gorgor">Gorgora</placeName> 
               </death>
            </person>
            
         </listPerson>
    

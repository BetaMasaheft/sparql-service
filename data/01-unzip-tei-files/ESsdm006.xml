                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: mediocre; hand b: mediocre.</seg>
                        <seg type="ink">Black, reddish-brown</seg>
                        <date>19th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; directives to the
                           minister and their abbreviations; title of books to be read; the word
                           ʾǝgäle in fol. 6v; elements of the punctuation signs; elements of
                           Ethiopic numerals.
 On the incipit page of Text I (fol. 1r), few
                           lines are rubricated (alternating with black lines).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="1r" to="45r">1r-45r</locus>.</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="46r" to="55r">46r-55r</locus>.</handNote>

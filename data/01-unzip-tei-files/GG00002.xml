               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="90r">Fols 2r–90r</locus>
                     <title>Gadla Estifanos</title>
                     <incipit xml:lang="gez">በስመ ፡ አብ ፡ ወወልድ ፡ ወመንፈስ ፡ ቅዱስ ። ገድል ፡ ወስምዕ ፡ ዘብፁዕ ፡ ወቅዱስ ፡ ዓምደ ፡ ሃይማኖት ፡ ማኅቶተ ፡ ክርስቲያን ፡ አብ ፡ እስጢፋኖስ ፡ ለባሴ ፡ አክሊል ። ዘፈጻመ ፡ በድሮ ፡ በጽንዐ ፡ መዊእ ፡ በሀገረ ፡ ጓትር ፡ በመንግሥቱ ፡ ለድብ ፡ ፀር ፡</incipit>
                     
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">100</measure>
                           <dimensions type="outer" unit="mm">
                              <height unit="mm"> 150</height>
                              <width unit="mm">110</width>
                              <depth>55</depth>
                           </dimensions>                           
                        </extent>                        
                        <foliation>Unfoliated leaf after fol. 44</foliation>
                        <collation>Number of folios: 3 (I-III) + 91 + 5 (IV-VIII);
                           Number of quires: 16</collation>
                        <condition key="deficient">Leaf deterioration with some loss of text, fol. 18-26, 34-54, 84-91</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout writtenLines="14 22" columns="2"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc><decoNote xml:id="d1">Miniature of the Madonna and child flanked by the archangels Michael and Gabriel on fol. 1r; miniature of Esṭifānos of Gunda Gundē on fol. 1v; ḥarag on fol. 2r
                     
                  </decoNote></decoDesc>
                  <additions><list><item xml:id="a1">Account of the transfer of the land of Ānzā to Gunda Gundē by the śeyyums of Āgāmē, along with the curses of Abuna Yoḥannes (1710-1726 CE) against whoever violates the agreement, fol. 90v-91v
                     
                  </item></list></additions>
                  <bindingDesc><binding><decoNote xml:id="b1">Wood boards. An incipit written in pencil on verso of second foreguard leaf</decoNote></binding></bindingDesc>
                  

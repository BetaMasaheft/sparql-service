                  <summary/>

                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="3r">Fols 1r–3r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara
                    Bǝhnǝsā</title>
                        <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#1r">Fol. 1r</locus>
                        <hi rend="rubric">በእንተ፡ ብጽእት፡ ወፍስሕት፡ ወስብሕት፡ በኵሎ፡ ቡርክት፡ ወንጽሕት፡ ኦእግዝትነ፡ ወላዲተ፡ አምላክ፡ ማርያም፡ ድንግል፡ ወበእንተ፡</hi> ኵሎሙ፡ ቅዱሳን፡ ስቡሐን፡ <sic resp="DN">መንፈሳውን፡</sic>
                        ሊቃነ፡ መላእክት፡ ሰማያውያን፡ ሚካኤል፡
                        ወገብርኤል፡ ሱራኤል፡ ወኪሩቤል፡ ኃይላት፡ ሰባኬ<sic resp="DN">የ</sic>፡
                         ወጸያሄ፡ ፍኖት፡ ዮሐንስ። መጥምቅ፡ ወበእንተ፡ ኵሉሙ፡ ቅዱሳን፡ ስቡሀን፡ ወላእካን፡ ማቴዎስ፡ ወማርቆስ። <sic resp="DN">ልቋስ፡</sic>
                         <sic resp="DN">ወዮንስ፡</sic> <sic resp="DN">እንድርርዖስ፡</sic>
                        ወፊልጶስ፡ <sic resp="DN">ወበርተ፡ ሌሜዎስ፡</sic> ቶማስ፡ ወያዕቆብ፡
                        ወልደ፡ እልፋያስ፡ ታዴዎስ፡ ወስምኦን፡ ፲ወ፪ቱ፡ ሐዋርያት፡ ወበእንተ፡ ኵሎሙ፡ ቅዱሳን፡ ስቡሐን፡ ወላእካን፡ ማቴዎስ፡ ወማርቆስ፡ <sic resp="DN">ሉቋስ፡</sic> ወዮሐንስ፡ ፬ወንጌላውያን።
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#3r">Fol. 3r</locus>
                        <hi rend="rubric">ኦማርያም፡</hi> በእንተ፡ ዝ፡ ናፈቅረኪ፡ ወናአብየኪ፡ እሥመ፡ ወልድኪ፡ ለነ፡ መብልአ፡ ጽድቅ፡
                        ዘበአማን፡ <sic resp="DR">ወስትየ፡</sic> ህይወት፡ ዘበአማን፡ ኦአበዊበ፡
                        ንቡራነ፡ ዕድ፡ ዕለ፡ መትልወ፡ መትልወ፡ ሀዋርያት፡ እስመ፡
                        ነሣእክሙ፡ አስተበቌዕያነ፡ ለነ፡ ለሀበ፡
                        <hi rend="rubric">እ<hi rend="ligature">ግዚ</hi>አብሔር፡</hi>
                        ወነሣእናሆሙ፡ በመዋእሊነ፡ እሎንተ፡ ፪ሊቃነ፡ ጳጳ<add place="above">ሳ</add>ት፡
                        አባ፡ <sic resp="DN">ቌርሎስ፡</sic> ዘሀግር፡ አባይ፡ እለ፡ እስክንድርያ፡ ወዲበ፡ ርእሰ፡ ሀገር፡ አበዊነ፡ ብፁእ፡ ጳጳስ፡ አባ፡ ስራባሞን።
                     </explicit>
                     <note>A part of the beginning, cp. <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">108-109</citedRange><citedRange unit="paragraph">8-24</citedRange></bibl>
                   (cp. <bibl corresp="http://zotero.org/groups/358366/items/UV8BMXC4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Euringer1937AnaphMaria"/><title level="a">Die äthiopische Anaphora unserer Herrin Maria</title><title level="j">Oriens christianus</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sebastian</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Euringer</t:surname></author><date>1937</date><biblScope unit="volume">12</biblScope><biblScope unit="page">63-102, 248-262</biblScope><citedRange unit="number">11-29</citedRange></bibl>).
                   Copied with mistakes and omissions; the leaves are misplaced.
                       The text on <locus target="#1r">fol. 1r</locus>
                        corresponds to <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">108</citedRange><citedRange unit="paragraph">11-12</citedRange></bibl>.
                      The text on <locus from="1v" to="2v">fols 1v–2v</locus> corresponds to
                      <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">108</citedRange><citedRange unit="paragraph">13-24</citedRange></bibl>.
                    The text on <locus target="#3r">fol. 3r</locus> corresponds to
                    <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">108</citedRange><citedRange unit="paragraph">8-10
                  </citedRange></bibl>. The entire text precedes
                        the part in <ref type="mss" corresp="https://betamasaheft.eu/DSEthiop17"><hi rendition="simple:smallcaps">MS</hi> DS Ethiop. 17</ref>.
                    </note>
                  </msItem>



               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2946IHA">نظم بسم الذي انشا الاشياء من عدم</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم \ باسم الذي انشا الاشيا من عذام \ الواحد القادر المريد ذي القدم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1r">-1r</locus>يا من غدا قلبه بالشوق ذا قلق , ودمعه حاملا للوجد ذا سجم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="21v">1v-21v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0251IHA">قصيدة البردة للبوصيري</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم \ امن تذكر جيران بذي سلم , مزجت دمعا جر من مقلة بدم \ ام هبت الريح من تلقا كاظمة , واومض البرق فى الظلماء من اضم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#21v">-21v</locus>واذا لصحب صلوة منك دائمة \ على النبي بمنحل ومنسهم , والال والصحب ثم التابعين لهم</explicit>
                     <note>Four verse lines on each page. From folio 7v onwards, the second hemistich is in the beginning of each line.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="59v" to="59v">59v-59v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4457IHA">نظم المصطفى سر الوجود</title>
                     <incipit xml:lang="ar">
                        <locus target="#59v">-59v</locus>صلى الله عليه وسلم فجلا , حندس الظلم ونطق لسان حاله \ المصطفى سر الوجود واجود , يا سادتى صلوا عليه لتسعد

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#59v">-59v</locus>يا ليت كل الدهر عندي ذكره , يا ليت طول الدهر عندى مولد</explicit>
                     <note>
                        <note>
        Manuscript item  7792 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7792</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="60r" to="60r">60r-60r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4668IHA">نظم يا ليلة المولد الزهراء</title>
                     <incipit xml:lang="ar">
                        <locus target="#60r">-60r</locus>يا ليلة المولد الزهراء كم شرفا , قد نلت بالمصطفى المختار من مضر \ يا ليلة ما يجارى في فضائلها , لانها فى الليالى غرة القمر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60r">-60r</locus>ان كان عيسى برى الاعمى بدعوته , فكم بتقلبه قد رد من بصر \ صلى عليه اله العرش ما صد حب , ورق الحمام وهبت نسمة التسحر</explicit>
                     <note>
                        <note>
        Manuscript item  7794 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7794</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="64r" to="64v">64r-64v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4302IHA">نظم يا دائم المعروف</title>
                     <incipit xml:lang="ar">
                        <locus target="#64r">-64r</locus>يا دائم المعروف يا دائم المعروف , يا دائم المعروف يا خير ما ذكرا \ قد اظهر الدمع منى الان ما سترا , وان ترد [شرح] حالى فهم سترى

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#64v">-64v</locus>يا قلب هذا الذى قد كنت احذره , صبرا علي ما قضى طوعا لما امرا</explicit>
                     <note>
                        <note>
        Manuscript item  7797 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7797</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="66r" to="66r">66r-66r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4303IHA">نظم ان صح منك الرضى يا من هو الطلب</title>
                     <incipit xml:lang="ar">
                        <locus target="#66r">-66r</locus>لا اله الا الله , لا اله الا الله \ ان صح منك الرضى يا من هو الطلب \ فلا ابالى بكل الناس [ان] غضبوا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#66r">-66r</locus>كيف التصبر والسلوان عن قمر \ موافق فى هواه العجب والعرب \ لا اله الا الله , لا اله الا الله</explicit>
                     <note>
                        <note>
        Manuscript item  7798 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7798</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="66v" to="67v">66v-67v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3785IHA">دعاء ختم المولد الشريف اللهم انا قد حضرنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#66v">-66v</locus>بسم الله الرحمن الرحيم \ اللهم انا قد حضرنا قراة مولد نبيك الكريم فائض علينا ببركاته خلع القبول والتكريم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#67v">-67v</locus>وارسلته رحمة للعالمين وعلى اله وصحبه اجمعين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحد لله رب العالمين  

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="68r" to="68v">68r-68v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0752IHA">توسل بابادر عمر الرضى توسلت بشيخ الابادر</title>
                     <incipit xml:lang="ar">
                        <locus target="#68r">-68r</locus>صلاة وتسليم وازكي تحية , على احمد المختار طها المفاخر \ توسلت بالشيخ الابادر انه , لما يطلب الانسان فيه يبادر \ فبادر وعجله فيا عمر الرضى , لانك ملحوظ اليه وناظر

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68v">-68v</locus>وصل وسلم كل يوم وليلة , على احمد المختار طه المفاخر , واصحابه ذوى المكارم والتقى , فانهم شمس الهدي والجواهر  \ وتباعه والداخلين جواره \ مدي الذهر ما دامت منى والمشاعر

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="68v" to="70r">68v-70r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4276IHA">مدح عبد القادر الجيلاني يا قطب الوجود بكم صفا وجودي
                    فعندكم سعودي</title>
                     <incipit xml:lang="ar">
                        <locus target="#68v-69r">-68v-69r</locus>يا قطب يا رباني , [اليك] النورني , عبد القاد جيلانى \ يا جالي الكروني [كذا] , ويا ستر العيوبي , يا جابر القلوب \ ايا قطب الوجود , بكم صفا وجودي , نَغْدَكُمْ سعودي

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#70r">-70r</locus>سلام على البرهانى , على نور الرحمانى , شيخ انس والجانى \ صلات وسلام , على خير الانام \ دائما بالدوامي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="70v" to="71v">70v-71v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4612IHA">مدح الشيخ هاشم قلت ذرني وسبيل</title>
                     <incipit xml:lang="ar">
                        <locus target="#70v">-70v</locus>شى الله ولي الله , شى الله ولي الله \ شيخ هاشم ولى الله المدد هاشم با الله \ قلت ذرنى وسبيل , أقف ليلى بالرحيل , لم اجد لها دليلي \ سلبت عقلى لماها , او برق من ثناها \ او بدر بداد حماها

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71v">-71v</locus>صلاة الله العظيم , على المصطفى الكريم , المسم بالرحيم \ وعلى الال الكرام , واصحابه الفخام , ما اضئا نجم للظلام

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="22r" to="22v">22r-22v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2196IHA">نظم اليك يا رب قد فوضت</title>
                     <incipit xml:lang="ar">
                        <locus target="#22r">-22r</locus>بسم الله الرحمن الرحيم \ اليك [يا] رب قد فوضت حاجاتى \ وجئت بابك يا ربى برعباتى \ واقىص الحريح لى ربى فلست ارى \ سواك يا رب من فاض الخاجاتى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22v">-22v</locus>يا خالق الخلق يا من لا شبيه له \ اسمع دعائى ويسر لى حاجاتى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="23r" to="23r">23r-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1163IHA">نظم الوهم لا يدركه</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>بسم الله الرحمن الرحيم \ لا اله الا الله , لا اله الا الله \ الوهم لا يدركه , والعجز لا يلحقه \ فهو الذي نعبده , جل اله هو هو</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>يا راحم الشيب أجر , من حر نار تستعر \ عبدا اتاك منكسر , سواك من يجبره \ لا اله الا الله محمد رسول الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="23v" to="24r">23v-24r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2983IHA">نص الصلاة والسلام الاتمان الاكملان</title>
                     <incipit xml:lang="ar">
                        <locus target="#23v">-23v</locus>بسم الله الرحمن الرحيم \ بسم الله والحمد لله , والصلاة والسلام الاتمان الاكملان , وتبتدى , بسم الله نسوق ميعة المولد اعوذ بالله من الشيطان الرجيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23v-24r">-23v-24r</locus>ان الله وملئئته [كذا] يصلون على النبي , يايها الذين امنوا صلوا عليه وسلموا تسليما</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="24r" to="25r">24r-25r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0589IHA">سلامات على النبي السلام عليك زين الأنبياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#24r">-24r</locus>السلام عليك زين الانبيا السلام عليك اصفي الاصفيا \ السلام عليك يا بهج الضيا السلام عليك دام بلا نقضاء

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25r">-25r</locus>السلام عليك ذ النورين رأس الناسكين السلام عليك على السامي يقينا \ السلام عليك اصحابك اجمعن السلام عليك والك كلهم ولتابعين

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="25v" to="66r">25v-66r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0706IHA">عنوان الشريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>بسم الله الرحمن الرحيم \ الحمد لله الذي شرف العالمين , باشرف العالمين , واصطفاه من خلقه اجمعين , ونباه وادم بين الماء والطين , ونوه بذكره فى الاولين كما شرف بقدره فى الاخرين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#66r">-66r</locus>كيف التصبر والسلوان عن قمر \ مرافق فى هواه العجب والعرب \ لا اله الا الله , لا اله الا الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="29v" to="32r">29v-32r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4238IHA">نظم صلاة وتسليم يفوق المطالب</title>
                     <incipit xml:lang="ar">
                        <locus target="#29v">-29v</locus>صلوة وتسليم يفوق المطالب , على المصطفى والال ما هبت الصبا \ سحائب او جود المصطفى عمت الربا , شهر ربيع جانا منه بالنبا

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#32r">-32r</locus>هو المصطفى المبعوث للخلق رحمة , عليه صلاة ما هبت الصبا</explicit>
                     <note>
                        <note>
        Manuscript item  7781 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7781</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="36v" to="37r">36v-37r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4279IHA">نظم الله الله الفرد ما له ثاني</title>
                     <incipit xml:lang="ar">
                        <locus target="#36v">-36v</locus>الله الله الفرد ما له ثانى , حي قيوم كريم ليس ينسانى \ لا اله الا الله لا اله الا الله , لا اله الا الله محمد رسول الله \ رفعت قصة اشواقى واشجانى , جئت ارجوك يا من جل عن ثانى<note>The first verse line is written in red as a refrain.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#37r">-37r</locus>صلى الاله على من جانا بالهدي , مع اله والاصحاب لهم جيرانى</explicit>
                     <note>
                        <note>
        Manuscript item  7782 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7782</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="57r" to="57v">57r-57v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4294IHA">نظم الله الله الله يا من له رتب</title>
                     <incipit xml:lang="ar">
                        <locus target="#57r">-57r</locus>الله الله الله يا من له رتب , صل وسلم علي من اشقه [كذا] يجب \ راق الزمان فزال الهم والنصب , واختفى الشرك والعصيان والرتب

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57v">-57v</locus>صلى عليك اله العرش ما طلعت , شمش النهار ومال الظل يعترب</explicit>
                     <note>
                        <note>
        Manuscript item  7788 relates to manuscript item 7777</note>
                        <note>
        Manuscript item  7777 relates to manuscript item 7788</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>

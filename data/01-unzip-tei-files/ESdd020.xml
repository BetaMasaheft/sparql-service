                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine and careful</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Early 18th century</date>
                        <seg type="rubrication">Divine names; names of the ruler, the commissioner
                           and other individuals; a few lines (alternating with black lines) and one
                           group of lines in the incipit page of each section of the text; two
                           initial lines of the first commemorative notice of the day and one
                           initial line of the subsequent commemorative notices of the day; the word
                           salām opening the salām-hymns; elements of the punctuation signs;
                           Ethiopic numerals or their elements.</seg>
                     </handNote>

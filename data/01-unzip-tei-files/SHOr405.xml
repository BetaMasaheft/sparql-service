                                <condition key="deficient">
                                  The front board is linked to the text block only at the third and fourth sewing station.
                                  The margins of the leaves that are not protected by the wooden boards are damaged. Stains of dirt and water are present.
                                </condition>

                            </supportDesc>

                            <layoutDesc>
                              <layout columns="2" writtenLines="19">
                                <note>Data on dimension are taken from <locus target="#28">fol. 28</locus>.</note>
                                <locus from="1" to="63">Fols 1–63</locus>
                                <dimensions unit="mm">
                                  <height>152</height>

                    <decoNote type="miniature" xml:id="d6"><locus target="#130r" facs="132">Fol. 130r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref> and unidentified <ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref> (<foreign>ዴልታዎስ፡</foreign>?)</desc></decoNote>

               <msContents>
                  <summary>Three Miracles of Mary, ተአምረ፡ ማርያም፡; Prayer to Mary, “I take refuge,” ተማኅፀንኩ፡; Hymn to Mary, “In Heaven and on Earth,” በሰማይ፡ ወበምድር፡; Image of the Passion of the Cross, መልክአ፡ ሕማማት፡; Hymn to Sebastian, መልክአ፡ ስብስትያኖስ፡; Image of the Savior of the World, መልክአ፡ መድኃኔ፡ ዓለም፡; Image of Mary Qwǝsqwam, መልክአ፡ ቍስቋም፡; Excerpt of the Image of Mary of Edom, መልክአ፡ ኤዶም፡; Hymn to Jesus Christ</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                      <msItem xml:id="ms_i1"><locus from="1r" to="9v" facs="001">Fols 1r–9v</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                        <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="3r" facs="001">Fols 1r–3r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3588Miracle">Miracle of Mary:
                                                  Miracle of a picture of Mary speaking to a
                                                  worker</title>
                        <note>(Budge, II; Princeton 20, <locus target="#41v #42r" facs="042">folss. 41v, 42r, </locus>; Princeton 23, <locus target="#28v #29r #29v" facs="029 030">28v, 29r, 29v, </locus>; Princeton 41, <locus target="#54v" facs="055">54v, </locus>; Princeton 43, <locus target="#8r #8v" facs="009 010">8r, 8v, </locus>; Princeton
                        46, <locus target="#10v #11r" facs="011">10v, 11r, </locus>; MYS 1, <locus target="#171v" facs="172">171v</locus>)</note>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="3v" to="6v" facs="004">Fols 3v–6v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3589Miracle">Miracle of Mary:
                                                  Miracle of a Jew of ʾAḫmīm</title><note>(Budge, III; MYS 1, <locus target="#6v #7r" facs="007">fols. 6v, 7r</locus>)</note>
                      <msItem xml:id="ms_i1.3">
                        <locus from="6v" to="9v" facs="007">Fols 6v–9v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3590Miracle">Miracle of Mary:
                                                  Miracle of the scribe Damianus from
                                                  Philippi</title>
                        <note>(Budge, IV; Princeton Ethiopic 41, <locus target="#55v #56r" facs="056">folss. 55v, 56r, </locus>; MYS 1, <locus target="#7r #7v" facs="007 008">7r, 7v</locus>).</note>
                    </msItem>
                  </msItem>
               <msItem xml:id="ms_i2"><locus from="10r" to="24v" facs="010">Fols 10r–24v</locus>
                 <title ref="https://betamasaheft.eu/LIT6161BakwelluH">Litany to Mary</title>
                        <incipit xml:lang="gez">
                          በኵሉ፡ ሕማሙ፡ ዘዕለተ፡ ዓርብ፡ ለፍቁር፡ ወልድኪ፡ ተማኅፀንኩ፡ ኦ፡ እግዝእትየ፡ ማርያም፡ በእኅዞቱ፡ በመጣብሕ፡<gap reason="omitted"/>
                        </incipit>
                    </msItem>
                      <msItem xml:id="ms_i3"><locus from="24v" to="28r" facs="025">Fols 24v–28r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2967RepCh248">Ba-samāy
                                                  wa-ba-mǝdr ʾalbǝya bāʿd</title>
                        <incipit xml:lang="gez">
                          በሰማይ፡ ወበምድር፡ አልብየ፡ ባዕደ፡<gap reason="omitted"/>
                        </incipit>
                    </msItem>
                      <msItem xml:id="ms_i4"><locus from="28r" to="51v" facs="028">Fols 28r–51v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our
                                                  Lady Mary</title>
                      <incipit xml:lang="gez">
                      ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡ ዘመዓዛ፡ አፉኪ፡ ኮል፡<lb/>
                      እንተ፡ ትጼንዊ፡ በገዳም፡ ወሐቅል፡<lb/>
                      ወልታ፡ ረዲኦትየ፡ በውስተ፡ ቀትል፡<lb/>
                      </incipit>
                    </msItem>
                      <msItem xml:id="ms_i5"><locus from="51v" to="60r" facs="052">Fols 51v–60r</locus>
                        <title>Hymn to Sebastian</title>
                        <incipit xml:lang="gez">
                          እንዘ፡ እፈቅድ፡ ፈቂደ፡ ወትሜነይ፡ ተምኔተ።<gap reason="omitted"/>ሰላም፡ ለኆኅያተ፡ ስምከ፡ በኍልቈ፡ ሰማያት፡ ሰብኡ።<gap reason="omitted"/>
                        </incipit>
                        <note>Could be any of Chaîne 55, 168, 355</note>
                      </msItem>
                      <msItem xml:id="ms_i6"><locus from="60v" to="74v" facs="061">Fols 60v–74v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne
                                                  ʿālam</title>
                        <incipit xml:lang="gez">
                          ሰላም: ለዝክረ: ስምከ: ዘኢረከቡ: ተፍጻሜተ: መላእክተ: ሰማይ: ወምድር: እለ: ለመዱ: ስብሐተ።<gap reason="omitted"/>
                        </incipit>
                      </msItem>
                      <msItem xml:id="ms_i7"><locus from="74v" to="82v" facs="075">Fols 74v–82v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1862Malkea">Malkǝʾa
                                                  Qʷǝsqʷām</title>
                        <note>This is a form of the text different than Chaîne Répertoire 175</note>
                        <incipit xml:lang="gez">
                          በስመ: እግዚአብሔር: ቀዳማዊ: እንተ: ኢይብልዎ: ማእዜ።<lb/>
                          ወደኃራዊ: ለሊሁ: ዘኢያወሥእዎ: እስከ: ይእዜ።<lb/>
                          ከመ: እጽሐፍ: ለኪ: ማርያም: ተዝካረ: ግፍዕኪ: ባሕረ: ተከዜ።<lb/>
                          ቊስቋም: ትተረጐም: ለርእስየ: በከናፍሪሃ: ኑዛዜ።<lb/>
                          እስመ: ነበረት: ምስሌኪ: በውእቱ: ጊዜ።
                        </incipit>
                      </msItem>
                      <msItem xml:id="ms_i8"><locus target="#82v" facs="083">Fol. 82v</locus>
                        <note>First few lines only</note>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2940RepCh221">Malkǝʾ-hymn to Our
                                                  Lady Mary</title>
                      </msItem>
                      <msItem xml:id="ms_i9"><locus from="82r" to="82v" facs="082">Fols 82r–82v</locus>
                      <title>Hymn to Jesus Christ</title>
                      <note>incomplete at the beginning</note>
                    </msItem>
                      </msItem>
               </msContents>

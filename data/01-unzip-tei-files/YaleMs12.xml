          <msContents>
            <summary/>
            <msItem xml:id="ms_i1">
              <locus from="4r" to="35r" facs="004">Fols 4r–35r</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">arranged for the days of the week</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <msItem xml:id="ms_i1.1">
                <locus from="4r" facs="004">Fols 4r and following</locus>
                <title>Monday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.2">
                <locus from="7v" facs="008">Fols 7v and following</locus>
                <title>Tuesday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.3">
                <locus from="13r" facs="013">Fols 13r and following</locus>
                <title>Wednesday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.4">
                <locus from="19v" facs="020">Fols 19v and following</locus>
                <title>Thursday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="27r" facs="027">Fols 27r and following</locus>
                <title>Friday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.6">
                <locus from="32v" facs="033">Fols 32v and following</locus>
                <title>Saturday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
              <msItem xml:id="ms_i1.7">
                <locus from="36r" facs="036">Fols 36r and following</locus>
                <title>Sunday</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
              </msItem>
            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="36r" to="57r" facs="036">Fols 36r–57r</locus>

            <additions>
              <list>
                <item xml:id="a1">
                  <locus target="#2r" facs="002">Fol. 2r</locus>
                  <desc> Calendar of feast days </desc>
                </item>
                <item xml:id="a2">
                  <locus target="#2v #3r #3v #57v" facs="003 004 058">Fols. 2v, 3r, 3v, 57v</locus>
                  <desc type="GuestText"> Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa
                                                  saʿātāt</title> for the Night Hours, Sä‘ätat, <foreign xml:lang="gez">ሰዓታት ሌሊት</foreign>
                  </desc>
                </item>
                <item xml:id="e1">
                  <locus target="#Inside cover" facs="001">Fols. Inside, </locus>
                  <desc> Yale University Library. Gift of Charles Fleishman, Yale 1950 </desc>
                </item>
                <item xml:id="e2">
                  <locus target="#1r #1v #58r #58v" facs="001 002 058 059">Fols. 1r, 1v, 58r, 58v</locus>
                  <desc> appear to be leaves (a bifolium?) discarded from another manuscript,
                    covered with pen trials of one sort and another </desc>
                </item>
                <item xml:id="a3">
                  <locus target="#57r" facs="057">Fol. 57r</locus>
                  <desc> Prayer by one Gabra Selassie to Mary to “keep me in body and soul.” A
                    secondary hand adds the name Gabra Maryam </desc>
                </item>
              </list>
            </additions>

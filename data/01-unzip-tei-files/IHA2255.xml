               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="71v">1r-71v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4597IHA">مقدمة في اصل العلوم المهمة على مذهب الامام ابي
                    حنيفة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم.
الحمد لله الذي خلق الانسان وعلمه البيان واكرمه بالفهم واللسان وجمله بالعينين واليدان حمدا يوجب رضا الرحمن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71v">-71v</locus> ان يختم لنا بالخير والسعادة والشهادة بفضله وجوده وكرمه انه ذو الفضل والإحسان والاكرام والامتشان ه امين امين امينونساله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="72v" to="93v">72v-93v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4606IHA">كتاب على علم الحديث</title>
                     <incipit xml:lang="ar">
                        <locus target="#72v">-72v</locus>بسم الله الرحمن الرحيم. 
والصلاة والسلام على سيدنا محمد واله وصحبه اجمعين ونذكر شيئا من اقوال سيد العارفين [...] بالاسانيد الصحيحة عن الثقات الايمة كالشيخ الامام المحقق المدقق صالح بن الشيخ العابد الوارع محمد بن ملك أي رضي الله عنهم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#93v">-93v</locus>الشيخ العارف بالله الشيخ العارفين وفضيله ومواعظه ورياضته واقواله وحكاياته بحمد الله ومته واطفه ومنه وسيره وحسن توفيقه والحمد لله رب العلمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="93v" to="98v">93v-98v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4599IHA">بيان في اصول الايمان ورغم الكفر والطفيان على مذهب ابي
                    حنيفة النعمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#94r">-94r</locus>بسم الله الرحمن الرحيم الحمد لله. وحده وصلي الله علي سيدنا محمد واله اجمعين أجمع العقلا من كل مومن [...] فصل فاذا ثبت من المحال ان تكون الدار موجودة من غير بان بناها </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98v">-98v</locus>وجميع ما امثله في هذه المكتوبة مذهب اهل السنة والعلم ومنهاج المتحققين من اهل الرشاد ومن لم يعتقد بهذه المعتقدة لم يحكم بصحة ايمانه فافهم بذلك والله اعلم. تمت الكتاب بعون الله تعلى ومنه وحسن توفيقه والحمد لله رب العلمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="98v" to="102r">98v-102r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4600IHA">كشف الاغتياء من اصول الدين</title>
                     <incipit xml:lang="ar">
                        <locus target="#98v">-98v</locus>بسم الله الرحمن الرحيم. كتاب كشف الأغطيا من أصول الدين وتأويل الخبرين الحمد لله ذي الجلال [...] ما بعد أيها الطالب للثابت في الإيمان </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#102r">-102r</locus>فاذا تمت  [...] فبطن الأرض خبر من ظهرها ثم تبدوا مقدمات أشراط القيمة ه ه ه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="102r" to="115v">102r-115v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4601IHA">كتاب المتفرقات</title>
                     <incipit xml:lang="ar">
                        <locus target="#102r">-102r</locus>بسم الله الرحمن الرحيم وبه نستعين.
كتاب المتفرقات هذا الكتاب يشتمل علي نوعين نوع في المواعظ ونوع احد فيما سال من المتشبهات اما النوع الأول </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#115v">-115v</locus>فقلت له وأين أبو حنيفه رحمه الله هيهات هيهات هو في اعلا العلتيين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="116r" to="117v">116r-117v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4602IHA">كتاب من مسائل التوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#116r">-116r</locus>بسم الله الرحمن الرحيم.
كتاب من مسائل التوحيد مما يجب علي المعتقدين معرفتها ولا يسعهم جهلها وهي هذه ان يسالك سائل فقال اول ما افترض الله عليك قيل له اثنان</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="119v" to="159v">119v-159v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4603IHA">مصباح في وقوف القرآن الكريم</title>
                     <incipit xml:lang="ar">
                        <locus target="#120r">-120r</locus>بسم الله الرحمن الرحيم [...] وبعد هذا مختصر في كتاب الوقوف القران الكريم للشيخ الامام شمس العارفين ابي الفضل محمد بن ظيفور السجاوندي طيب الله ثراه واكرم مثواه وذلك على خمس مراتب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#159v">-159v</locus>وفي سورة الم نشرح لذ لا وقف اليسر ذكرك وهو يسر الاولي والثاني وفي سورة والتين لا وقف صدرك وزرك فلهوك فانصب يسرا يسرا </explicit>
                     <note/>
                     <note/>
                  </msItem>

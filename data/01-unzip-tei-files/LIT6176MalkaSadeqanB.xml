            <div type="bibliography">
                <listBibl type="text">
                    <bibl corresp="http://zotero.org/groups/358366/items/RSA6WCVU"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Raineri1980Sadqan"/><title level="a">Vita dei giusti: missionari dell'Etiopia nel sesto secolo: varianti e inno</title><title level="j">Ephemerides Carmeliticae</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Osvaldo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Raineri</t:surname></author><date>1980</date><biblScope unit="volume">31</biblScope><biblScope unit="issue">2</biblScope><biblScope unit="page">377-413</biblScope></bibl>
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>
                
            </div>
            <div type="edition" xml:lang="gez"><note>from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">በስመ፡ ሥሉስ፡ ቅዱስ፡ ማሕድ፡ ባሕርይ፡ ከሃሊ፨</l>
                        <l n="2">ዘኢየሐጽጽ፡ ምንግሥቱ፡ ወዘኢይበሊ፨</l>
                        <l n="3">ዝክረ፡ ውዳሴክሙ፡ ጻድቃን፡ ዘበበ፡ ጾታሁ፡ አሐሊ፨</l>
                        <l n="4">ያንቅሐኒ፡ ወያንሥአኒ፡ እምንዋመ፡ ሀኬት፡ ማህጐሊ፨</l>
                        <l n="5">ጰራቅሊጦስ፡ ስቴ፡ ጽድቅ፡ ዘዕጹብ፡ መቅለሊ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለንግደትክሙ፡ እምድረ፡ ሮምያ፡ ርኁቅ፨</l>
                        <l n="2">ኀበ፡ አዜባዊት፡ ሀገር፡ ዐውደ፡ ዘውራቲሃ፡ ምሥራቅ፨</l>
                        <l n="3">ማኅበረ፡ ኖምና፡ ጻድቃን፡ ተለውተ፡ ክርስቶስ፡ ሊቅ፨</l>
                        <l n="4">ጸግዉኒ፡ አጋእዝትየ፡ ኅሊና፡ መንፈስ፡ ዕዉቅ፨</l>
                        <l n="5">ለዝክረ፡ ስምክሙ፡ ሐዋዝ፡ አሐሊ፡ በጽድቅ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ኀበ፡ ዐምደ፡ ወርቅ፡ ዘተጽሕፈ፨</l>
                        <l n="2">ማኅበረ፡ ኖምና፡ ጻድቃን፡ ዘትትኌለቁ፡ አእላፈ፨</l>
                        <l n="3">እምኔክሙ፡ አሐዱ፡ ሶበ፡ በአሕጻ፡ ተነድፈ፨</l>
                        <l n="4">አምሳለ፡ አንስርት፡ አስሪፆ፡ አክናፈ፨</l>
                        <l n="5">ብሂለ፡ ኖምኩ፡ ኑሙ፡ ተሰምዐ፡ አጽናፈ፨</l>
                    </lg>
                    <lg type="stanza" n="29">
                        <l n="1">ሰላም፡ ለመቃብሪክሙ፡ በእደ፡ ሰብእ፡ ዘኢተከርየ፨</l>
                        <l n="2">ኀበ፡ በአታት፡ ወጾላዕት፡ ለለ፡ ዘቆምክሙ፡ ህየ፨</l>
                        <l n="3">ዜና፡ ዝኅርክሙ፡ ጻድቃን፡ ዘበምድረ፡ አግዓዚ፡ ተሠምየ፨</l>
                        <l n="4">ቦ፡ እምኔሁ፡ ዘይፌውስ፡ ድዉየ፨</l>
                        <l n="5">ወቦ፡ በረድኤቱ፡ ዘአውፅአ፡ ማየ፨</l>
                    </lg>
                    <lg type="stanza" n="30">
                        <l n="1">ሰላም፡ ለክሙ፡ ጻድቃን፡ ዘቅድም፨</l>
                        <l n="2">እምአዳም፡ ወእለ፡ ኖምና፡ እስከ፡ መዋዕሊነ፡ ዮም፨</l>
                        <l n="3">ወእለ፡ ትመጽኡ፡ እምዮም፡ እስከ፡ ኅልቀተዝ፡ ዓለም፨</l>
                        <l n="4">ጸሐፉ፡ ስመ፡ ዚአየ፡ በደመ፡ በግዑ፡ ቀለም፨</l>
                        <l n="5">መንገለ፡ ተጽሕፈ፡ ዘዚአክሙ፡ ስም፨</l>
                    </lg>
                    <lg type="stanza" n="31">
                        <l n="1">አምኃ፡ ሰላም፡ ኅዳጠ፡ ለመልክእክሙ፡ አቅረብኩ፨</l>
                        <l n="2">አምጣነ፡ ዘብየ፡ ክህልኩ፨</l>
                        <l n="3">ነገረ፡ ዜናክሙ፡ ጻድቃን፡ እመ፡ ኢያሠነይኩ፨</l>
                        <l n="4">ወለእመኒ፡ በድካም፡ አቅረብኩ፨</l>
                        <l n="5">ሞገሰ፡ ጻማክሙ፡ አበውየ፡ ዲቤሁ፡ ወስኩ፨</l>
                    </lg>
                </div>
            </div>
            
        </body>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለጽንሰትከ፡ ወለልደትከ፡ መዐድም፨</l>
                  <l n="2">እምሐቌ፡ ዘብዴዎስ፡ አብ፡ ወእማሕፀነ፡ ትእማር፡ እም፨</l>
                  <l n="3">ወልደ፡ ነጐድጓድ፡ ዮሐንስ፡ ረኣዬ፡ ምሥጢር፡ ግሩም፨</l>
                  <l n="4">ከዐው፡ በላዕሌየ፡ ሀብተ፡ ቡራኬሁ፡ ለሢም፨</l>
                  <l n="5">ከመ፡ እምደመና፡ ይትከዐው፡ ዝናም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ተቀባኤ፡ ዘይት፨</l>
                  <l n="2">ለርእስከ፡ ዓዲ፡ ወለገጽከ፡ መጽሔት፨</l>
                  <l n="3">ወልደ፡ ነጐድጓድ፡ ዮሐንስ፡ ወሃቤ፡ ፯ቱ፡ ሀብታት፨</l>
                  <l n="4">በከመ፡ ወሀቦ፡ እግዚኡ፡ ለወልደ፡ ዕሴይ፡ ዳዊት፨</l>
                  <l n="5">ሀበኒ፡ ሀብተ፡ ለጸማድከ፡ በኵሉ፡ ዕለት፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ ዘኮነ፡ በእስያ፨</l>
                  <l n="2">በፈቃደ፡ አምላክ፡ ወልደ፡ ማርያ፨</l>
                  <l n="3">ወልደ፡ ነጐድጓድ፡ ዮሐንስ፡ ነቢይ፡ ወሐዋርያ፨</l>
                  <l n="4">ሀብተ፡ ለሥጋየ፡ ወለነፍስየ፡ ምስካያ፨</l>
                  <l n="5">እስእለከ፡ ታስተዳሉ፡ ብእሲ፡ ኬንያ፨</l>
               </lg>
            </div>
         </div>
      </body>

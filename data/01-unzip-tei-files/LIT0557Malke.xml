      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0557</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ለዘአጸቦ፡ ረዳኢ፨</l>
                  <l n="2">ወለዘጸውዖ፡ በቋዒ፨</l>
                  <l n="3">ቂርቆስ፡ ሕፃን፡ ወሰማዕት፡ መዋኢ፨</l>
                  <l n="4">በላዕሌየ፡ ትእምርተ፡ ሠናያት፡ አርኢ፨</l>
                  <l n="5">ኀጢ__ ዘያ__ ይትሐፈር፡ ጸላኢ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለርእስከ፡ አክሊለ፡ ምዝጋና፡ አክሊሉ፨</l>
                  <l n="2">ቂርቆስ፡ ሕፃን፡ ለበግዐ፡ ፍርቃን፡ ክፍሉ፨</l>
                  <l n="3">ወንጌላዊያን፡ ሕዝብ፡ በእንቲአከ፡ ይብሉ፨</l>
                  <l n="4">ኦአ፡ ሚአዳም፡ ሥነ፡ ገድሉ፨</l>
                  <l n="5">ለቂርቆስ፡ አንገቤናይ፡ ምኩር፡ በኵሉ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለአዕፅምቲከ፡ ለአስራዊከ፡ ወአምትንቲከ፨</l>
                  <l n="2">ምንዳቤ፡ ዘጾሩ፡ ውስተ፡ ዐውደ፡ ስምዕ፡ አመ፡ ቆምከ፨</l>
                  <l n="3">ቂርቆስ፡ ሰማዕት፡ አስተበቍዐከ፨</l>
                  <l n="4">አስራውየ፡ ወአምትንትየ፡ ወዐፅምትየ፡ ለገብርከ፨</l>
                  <l n="5">ኢይኩን፡ ብከ፡ ዕቀብ፡ በእዴከ፨</l>
               </lg>
               <lg type="stanza" n="61">
                  <l n="1">ዘምስለ፡ ሰባዕቱ፡ ሊቃነ፡ መላእክት፡ ህላዌ፡ ኪዳን፡ ነሥአ፨</l>
                  <l n="2">ቂርቆስ፡ ሕፃን፡ ለአርዌ፡ ሰማይ፡ ሞአ፨</l>
                  <l n="3">አሣእነ፡ መኰንን፡ ይበስ፡ ሕያዎ፡ አንሥአ፨</l>
                  <l n="4">እምክሳ</l>
                  <l n="5">[The remainder of the text is lost.]</l>
               </lg>
            </div>
         </div>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">በጸሎተ፡ ሚካኤል፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Baṣalota Mikāʾel</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               <t:birth>He was born in <t:placeName ref="https://betamasaheft.eu/LOC5454Sagla">Saglā</t:placeName>
               </t:birth>
               <t:floruit notBefore="1300" notAfter="1399">He was one of the most venerated saints of the Ethiopian Orthodox Church and a moral reformer of the 14th century. He joined the monastery of
                  <t:placeName ref="https://betamasaheft.eu/LOC2278DabraG">Dabra Gʷal</t:placeName> and became a monk. He made reform efforts to monasticism, the church hierarchy and the monarchy.
                  He tried to break the existing custom according to which monks and nuns were allowed to live together. He made an effort to moral reform of the royal court. In this regard,
                  he reproved King <t:persName ref="https://betamasaheft.eu/PRS1854Amdase">ʿAmda Ṣǝyon I</t:persName> for his marriage to his father's widow and for keeping numerous concubines.
               </t:floruit>

            </t:person>
            
         </t:listPerson>

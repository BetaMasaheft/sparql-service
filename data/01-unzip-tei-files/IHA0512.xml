               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="13v">1r-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1097IHA">Unidentified draft</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم الحمد لله الشاكر الذاكر المرمن شكره وذكرى بفضله المخصصو بمعرفة انواع الذكر ه واالعمل به مطلقا اوقاته أو مجاله اشهد ان لا اله الا الله وان محمد  ه ورسوله المبعوث رحمة لخلقه صلى الله عليه وعلى اله وصحبه وأتباعه وبعد فيقول الفقير الى رحمة ربه العاجز الضعيف المتوكل على الله والراجى الى عفو الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>وفى الحديث ان الذى يقعد فى مصلاه يذكر الله تعالى بعد صلاة لصبح اسرع فى تحصيل من الذى يضرب الآفاق يعنى يسافر فيها يطلب الرزق هذا والسلام الا ذكار التى تطلب ممن يزيد النوم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="22r" to="128v">22r-128v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0006IHA#s62IHA">فـتـح الـوهـّاب بشرح منهج الطلاب, From kitāb
                    al-bay‘ to the end of kitāb al-ǧi‘āla</title>
                     <incipit xml:lang="ar">
                        <locus target="#22v">-22v</locus>كتاب البيع يطلق البيع على قسيم الشراء وهو تمليك بثمن على  وجه مخصوص والشراء تملك بذلك وعلى العقد المركب منها وهو المراد بالترجمة وهو لغة مقابلة شيء بشيء وشرعا مقابلة مال بمال على وجه مخصوص والاصل فيه قبل الاجماع ايات كقوله تعالى واحد الله البيع واخبار كخبر سئل رسول الله صلى الله عليه وسلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#128v">-128v</locus>وحلف ملتزم انكر شرط جعل اوردا فيصدق لان الاصل عدمه فان اختلفا بعد استحقاق في قدر جعل او قدر مردود تحالفا وللعامل اجرة المثل كما علم من باب الاختلاف في كيفية العقد وكتاب القراض</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <title type="complete" ref="https://betamasaheft.eu/LIT3190Tergwam">Tǝrgʷāme Mātewos</title>
                          <textLang mainLang="gez"/>
                          <note>The names of several commentators are frequently added to the
                          word <foreign xml:lang="gez">መተርጕም፡</foreign>, in the earlier part
                        of the manuscript; namely, <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName>,
                      <persName ref="https://betamasaheft.eu/PRS3255CyrilI">Cyril I</persName>, <persName ref="https://betamasaheft.eu/PRS4824Gregory">Gregory of Nyssa</persName>,
                    <persName ref="https://betamasaheft.eu/PRS4822Gregory">Gregory of Nazianzos</persName> (<locus target="#37v"/>),
                    <persName ref="https://betamasaheft.eu/PRS2546Basilth">Basil of Caesarea</persName>, <persName ref="https://betamasaheft.eu/PRS2213Athanasi">Athanasius</persName>,
                    <persName ref="https://betamasaheft.eu/PRS3828Epiphani">Epiphanius of Salamis</persName>, <persName ref="https://betamasaheft.eu/PRS9471Theodore">Theodore “the Interpreter”</persName>
                    (<locus target="#27v #87v"/>), <foreign xml:lang="gez">አውሣንዮስ፡</foreign>
                    (<locus target="#24v #31v #34r #40r #49v #56v #62r"/>),
                    <persName ref="https://betamasaheft.eu/PRS3827Ephrem">St Ephrem the Syrian</persName>, <persName ref="https://betamasaheft.eu/PRS5581Isaacof">
                  <certainty locus="value" match="@ref" cert="low"/></persName>
                  (<locus target="#43r #46v #64r"/>), <persName ref="https://betamasaheft.eu/PRS5655Jacobof">Jacob of Sarug</persName>
                  (<locus target="#45r"/>), <persName ref="https://betamasaheft.eu/PRS7853Philoxen">Philoxenus of Mabbog</persName>
                  (<foreign xml:lang="gez">ፊለስኪኖስ፡</foreign>, <locus target="#36v #41v #54r"/>).
                  </note>

                  <msItem xml:id="ms_i1.1">
                    <locus from="163r"/>
                    <title type="complete">Colophon</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">
                      ወዝኬ፡ ውእቱ፡ ትርጓሜ፡ አረጋዊ፡ ቀሲስ፡ ትሩፍ፡ ገብረ፡ እግዚአብሔር፡
                      <persName ref="https://betamasaheft.eu/PRS5503Ibnatt">አባ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ምሥራቃዊ።</persName> ወፈለሰት፡ ዛቲ፡
                      እምልሳነ፡ ሱርስት፡ ኀበ፡ ልሳነ፡ ዓረቢ፡ በከመ፡ ዘከራ፡ ለሊሁ፡ ዛቲሰ፡ ፍካሬ፡ ጽሪት፡ ወንጥፍት፡ እንተ፡ ይእቲ፡ ፍካሬ፡ ቃለ፡
                      ቀሲስ፡ ዘዝኩር፡ እምኵሎን፡ ፍካሬያት፡ ዘብሊት፡ ይእቲ። ወተጽሕፈት፡ ዛቲ፡ መጽሐፍ። <date calendar="alexander" when-custom="1328">በ፲፻፡ ወ፫፻፳ወ፰ እምዓመተ፡
                      እስክንድር፡ ዮናናዊ፡</date> ዘስንዕው፡ ለዓመተ፡ ተንበላት። በ፬፻ ዓመት። ወስብሐት፡ ለእግዚአብሔር፡
                    </incipit>
                  </msItem>

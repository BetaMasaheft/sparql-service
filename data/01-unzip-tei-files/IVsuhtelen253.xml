               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="3ra" to="121ra"/>
                    <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1146Argano">ʾArgānona wǝddāse</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"/>
                     <explicit xml:lang="gez">
                        <hi rend="rubric"> አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ </hi> ይኩን፡ ምስሌየ፡ ሊተ፡ ለገብርኪ፡ <del rend="erasure"/>
                        ኅጥእ፡ ወአባሲ፡ በኵሉ፡ መዋዕል፡ ወኵሉ፡ አዝማን፨ ይእዜኒ፡ ወዘልፈኒ፡
                     </explicit>
                     <note> &gt;The text is divided into 100 units through indications in the margins, but
                        <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> does not explain exactly how </note>


                  </msItem>


               </msContents>


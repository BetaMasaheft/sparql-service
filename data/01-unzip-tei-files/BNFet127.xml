                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="OwnershipNote">The note mentions the names of <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</persName>, his father <persName ref="https://betamasaheft.eu/PRS10077WasanS">Wasan Sagad</persName> and mother
                      <persName ref="https://betamasaheft.eu/PRS10604Zannaba">Zannaba Warq</persName> and of the scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS11244WaldaM">Walda Mikāʾel</persName>.</desc>
                           <q xml:lang="gez">ዝመጽሐፍ፡ ዘ<persName ref="https://betamasaheft.eu/PRS8346sahlase">ሣህለ፡ ሠላሴ፡</persName> ንጉሠ፡
                    ሻዋ፡ ወአቡሁ፡ <persName ref="https://betamasaheft.eu/PRS10077WasanS">ወሰን፡ ሰገድ፡ ወልደ፡ ጊዮርጊስ፡</persName> ወእሙ፡
                      <persName ref="https://betamasaheft.eu/PRS10604Zannaba">ዘነመ፡ ወርቅ፡</persName> ኢያሴሜር። ወጸሓፊሁ፡ <persName ref="https://betamasaheft.eu/PRS11244WaldaM">ወልደ፡ ሚካኤል</persName>።</q>
                        </item>

                        <item xml:id="e1">
                           <desc>The name of the owner, king <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</persName>, is mentioned
                    in the invocations after each entry (except <locus from="71" to="80"/>).</desc>
                        </item>

                        <item xml:id="e2">
                           <locus from="71" to="80"/>
                           <desc>The name of <persName ref="https://betamasaheft.eu/PRS11245HabtaG">Habta Gabrǝʾel</persName> is mentioned in the invocations
                    after each entry. </desc>
                        </item>
                     </list>

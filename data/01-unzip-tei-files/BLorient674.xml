                        <history>
                            <origin>
                                <origDate notBefore="1650" notAfter="1699" evidence="lettering"/>
                            </origin>
                            <provenance>The manuscript seems to have belonged to a church of ʾArbāʿtu ʾƎnsǝsā. This might possibly be identified with
                               <placeName ref="https://betamasaheft.eu/LOC1526Arbaet">ʾArbāʿtu ʾƎnsǝsā</placeName>. From there it was taken by
                                    <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted 
                                    by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.
                                </provenance>
                            
                        </history>
                    

         <listPerson>
            <person sex="1" sameAs="wd:Q365941">
               
               <persName xml:lang="en" xml:id="n1">Theophilos of Alexandria</persName>
               <persName xml:lang="en" xml:id="n2">Theophilus of Alexandria</persName>
               
               <persName xml:lang="gez" xml:id="n3" type="birth">ቴዎፍሎስ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Tewoflos</persName>
               <persName xml:lang="gez" xml:id="n4" type="birth">ቴዮፍሎስ፡</persName>
               <persName xml:lang="gez" corresp="#n4" type="normalized">Teyoflos</persName>
               <persName xml:lang="gez" xml:id="n5" type="birth">ቴኦፊሎስ፡</persName>
               <persName xml:lang="gez" corresp="#n5" type="normalized">Teʾofilos</persName>
               
               <occupation type="ecclesiastic">Patriarch of Alexandria</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
               <birth>345</birth>
               
               <floruit notBefore="0384" notAfter="0412">He was  a patriarch of Alexandria from <date> 384/87-412</date>. He built several churches in Egypt while suppressing paganism and destroying temples. 
                  He condemned the doctrine of <persName ref="https://betamasaheft.eu/PRS7672Origeno">Origen of Alexandria</persName> at a synod in Alexandria in <date>400</date>. He is venerated as a saint in the
                  Ethiopian Orthodox Church as well as in Coptic and Syrian Orthodox Churches. He has written extensively. 
               </floruit>
               <death>412</death>
            </person>
            
         </listPerson>

                        <item xml:id="e1">
                           <desc>
                          Overlooked words of text are written interlinearly (<locus target="#17v #20v #29v #63r #64v" facs="020 023 032 065 067">folss. 17v, 20v, 29v, 63r, 64v, </locus>, etc.);

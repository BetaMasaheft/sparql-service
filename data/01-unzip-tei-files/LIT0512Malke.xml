      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0512</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እግዚአብሔር፡ ዘአስተብፅዖ፨</l>
                  <l n="2">ወለእዝነ፡ ዓለም፡ አስምዖ፨</l>
                  <l n="3">ዘርአ፡ ቡሩክ፡ ማይ፡ ለእሳተ፡ ጋዕዝ፡ ዘታጠፍኦ፨</l>
                  <l n="4">አሐዱ፡ እምእለ፡ ምስሌከ፡ ይጸውዐኒ፡ ጸውዖ፨</l>
                  <l n="5">እምነቅዐ፡ ጸጋከ፡ እስተይ፡ ዘአምላክ፡ አንቅዖ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ዘየዐቅቦ፡ ኪሩብ፨</l>
                  <l n="2">ሰረገላሁ፡ ለአብ፨</l>
                  <l n="3">ዘርአ፡ ቡሩክ፡ ልዑል፡ ሕፃነ፡ ማርያም፡ ርግብ፨</l>
                  <l n="4">መርሖሙ፡ ኀበ፡ ሰከበ፡ ማእከለ፡ ጎል፡ ጥበብ፨</l>
                  <l n="5">ለሰብአ፡ ሰገል፡ ካህናት፡ ጽድቅከ፡ ኮከብ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ፈጸምኩ፡ አንሰ፡ ዘወሀብከኒ፡ ተግባረ፨</l>
                  <l n="2">ኀበ፡ ልብየ፡ ፈተወ፡ ወኅሊናየ፡ አፍቀረ፨</l>
                  <l n="3">ተሀበኒ፡ አባ፡ ዘሰልኩከ፡ ነገረ፨</l>
                  <l n="4">ሰሎሞን፡ ንጉሠ፡ ጽድቅ፡ ድኅረ፡ ቤተ፡ መቅደስ፡ ሣረረ፨</l>
                  <l n="5">ከመ፡ ወሀቦ፡ ለኪራም፡ እስራኤል፡ አህጉረ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary>Accordion-fold Codex of Artwork</summary>
                  <msItem xml:id="ms_i1">
                     <title>Accordion-fold Codex of Artwork</title>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">10</measure>
                           <dimensions type="outer" unit="mm">
                              <height>150</height>
                              <width>130</width>
                              <depth>20</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>This is an accordion-fold codex.</note>
                        </collation>
                     </supportDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1" facs="001">Fol. 1</locus><desc><persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/>, <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> with caption "How Saint George, the arch-martyr killed the dragon"</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#2" facs="002">Fol. 2</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with angels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName> with captions <q>"Gab(riel)," "With her beloved son," "Saint Michael"</q> </desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#3" facs="003">Fol. 3</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> with <term key="halo" ana="#halo"/> centre, and standing, blessing four men who are kneeling before him. The front man has his arms folded across his chest in the traditional pose for receiving blessing. With caption <q>"How our Lord healed the sick ones"</q> </desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#4" facs="004">Fol. 4</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> with <persName ref="https://betamasaheft.eu/PRS7805Peter">Peter</persName> on the left and <persName ref="https://betamasaheft.eu/PRS6902Matthew">Matthew</persName> on the right. Captions <q>"Saint Peter," "Our Lord," and "Saint Mathias"</q> </desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#5" facs="005">Fol. 5</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> <persName ref="https://betamasaheft.eu/PRS7805Peter">Peter</persName> and <persName ref="https://betamasaheft.eu/PRS7743Paul">Paul</persName> standing, with hands in front holding small crosses <term key="cross" ana="#cross"/> </desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#6" facs="006">Fol. 6</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> <persName ref="https://betamasaheft.eu/PRS11023Mathias">Mathias</persName> and Saint M(?), (text is obliterated) standing, with hands in front holding small crosses <term key="cross" ana="#cross"/>. Caption: <q>“Saint Mathias; Saint Ma(?).”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#7" facs="007">Fol. 7</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (center) touching members of the crowd (below and to the right); Man holding sack stands on the left. Caption: <q>“How our Lord, comforted his disciples</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#8" facs="008">Fol. 8</locus><desc>A saint with a <term key="halo" ana="#halo"/> (left) ( probably <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>) is seated on a chair holding a book. Before him, on another chair, sits a man (without halo) (probably <persName ref="https://betamasaheft.eu/PRS7805Peter">Peter</persName>). Caption: <q>“How our Lord gave authority to Saint Peter"</q> <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#9" facs="009">Fol. 9</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (with one hand on her head in grief) is on the left; <persName ref="https://betamasaheft.eu/PRS5695John">John</persName> (with arms folded over chest) is on the right. Captions (l. to r.): <q>“How our Lady wept,” “How Saint John wept.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#10" facs="010">Fol. 10</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1008Descent">Descent into Hell</ref> Jesus raises two naked saints (Adam and Eve, from death?). Two saints holding hand crosses look on. Caption: <q>“How our Lord rose from the tomb.”</q> </desc></decoNote>
                  </decoDesc>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">150 x 130 x 20 mm. No covers. Single sheet of heavy parchment. The parchment is folded so that ten panels are available for artwork. On the back of the parchment, the lines of the fold have been scored with a knife and the parchment cut half way through. The backs of the panels are blank. Though the parchment is dirty, it appears to be new and firm.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

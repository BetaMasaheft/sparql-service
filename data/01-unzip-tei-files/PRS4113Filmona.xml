         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ፊልሞና፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Filmonā</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  <t:occupation type="ecclesiastic">abbot</t:occupation>
                
               <t:floruit notBefore="1350" notAfter="1371">He was a holy monk from 
                  <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName> who was active in the 
                  regions of <t:placeName ref="https://betamasaheft.eu/LOC2947Endart">ʾƎndartā</t:placeName> and 
                  <t:placeName ref="https://betamasaheft.eu/LOC5882Tamben">Tamben</t:placeName>.
                  He lived in the second half of the fourteenth century during the reigns of 
                  <t:persName ref="https://betamasaheft.eu/PRS1854Amdase">ʿAmda Ṣǝyon I</t:persName>
                  and <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName>. 
                  He was the nephew and disciple of <t:persName ref="https://betamasaheft.eu/PRS9086Tadewos">
                     Tādewos</t:persName> and the founder of the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2237DabraA">
                        Dabra ʾAysamā</t:placeName>. 
                  His succcessor was <t:persName ref="https://betamasaheft.eu/PRS3800endreyas">ʾƎndrǝyās of Dabra ʿAysamā</t:persName>.</t:floruit>
                  
               </t:person>  
               
                   
         </t:listPerson>

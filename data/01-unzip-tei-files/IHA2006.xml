                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a4_6382">
                           <locus target="#8r">-8r</locus>
                           <q xml:lang="ar">بشير اه سنة ١٣٥٦</q>
                           <desc>Date</desc>
                           <note>Partially deleted</note>
                           <note/>
                        </item>
                        <item xml:id="a0_6382">
                           <locus target="#1r-2r">-1r-2r</locus>
                           <q xml:lang="ar">فأذا [سلّىت] عن الصلاة تقول بلسانك متذكرا معناه باطنا ألحمد لله رب العالمين على كل حال ثلثا</q>
                           <note/>
                        </item>
                        <item xml:id="a1_6382">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">تعليم بدء دلائل الخيرات اولا الاءستغفار ثلاث مرات ثانيا تصلى صلى النبي صلى الالله عليه وسلم ثلاث مرات ثم تقرء سورة الفاتحة ثلاث مرات</q>
                           <note/>
                        </item>
                        <item xml:id="a2_6382">
                           <locus target="#2r-6r">-2r-6r</locus>
                           <q xml:lang="ar">بسم الله الرحمن الرحيم هو الله الذي لا اله هو الرحمن الرحيم الملك القدوس السلام المؤمن المهيمن العزيز الجبار المتكيز الخالق البارئ المصور</q>
                           <desc>Muqaddima</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_6382">
                           <locus target="#8r">-8r</locus>
                           <q xml:lang="ar">كتاب دلائل الخيرات وشوارق الانوار فى ذكر الصلوة على النبي المختار واله وصحبه الاخيار تاليف الشيخ العارف يالله الواحد القهارابي عبد الله محمد بن سليمان الجزولي رضي الله عنه ونفعنا به امين</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                        <item xml:id="a5_6382">
                           <locus target="#95r">-95r</locus>
                           <q xml:lang="ar">سنة ١٢٣٥ الهجر</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#31v">-31v</locus>
                           <desc>Scribal verses</desc>
                           <q>ها عدد القرأن سورته في مائة اربع عشر لاتهلا؟...
وكاتبها المستفيد عبلغ كلنا كاملا؟...</q>
                           <note/>
                        </item>
                     </t:list>

         <listPerson>
            <person sameAs="wd:Q147677" sex="1">

                        <persName xml:lang="gez" xml:id="n1" type="birth">ዘርአ፡ ያዕቆብ፡</persName>
                        <persName xml:lang="gez" corresp="#n1" type="normalized">Zarʾa Yāʿqob</persName>
               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
                     <persName xml:lang="gez" xml:id="n2" type="regnal">ቈስጠንጢኖስ፡</persName>
                        <persName xml:lang="gez" corresp="#n2" type="normalized">Qʷasṭanṭinos</persName>

                     <occupation type="ruler">Emperor</occupation>
               <birth when="1399">He was born in <placeName ref="https://betamasaheft.eu/LOC3061Fataga">Faṭagār</placeName> in <date>1399</date>.</birth>
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC2246DabraB">Dabra Bǝrhān</placeName>
               </residence>
               <floruit notBefore="1434" notAfter="1468">He was the fourth son of
                  <persName ref="https://betamasaheft.eu/PRS3429DawitII">
                     <roleName type="title">ʾaṣe</roleName>Dāwit</persName>
                  to become a king and ascended to the throne after several years of chaos following the death of his brother

                  <persName ref="https://betamasaheft.eu/PRS10342Yeshaq">
                     <roleName type="title">ʾaṣe</roleName> Yǝsḥaq</persName> and
                  the short reign of another brother King <persName ref="https://betamasaheft.eu/PRS9175TaklaMa">Takla Māryām</persName>
                  in <date>1430-1433</date> as well  as three of his nephews.
                  He was an outstanding ruler of the early Solomonic period, between <date>1270-1527</date>.
                  He played a remarkable role to the development of Gǝʿǝz literature.</floruit>

                     <death when="1468"/>
                  </person>
            
         </listPerson>

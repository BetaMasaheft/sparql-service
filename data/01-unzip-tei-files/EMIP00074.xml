               <msContents>
                  <summary>Image of Gabriel, መልክአ፡ ገብርኤል፡, Mystagogia, ትምህርተ፡ ኅቡዓት፡, Prayer of the Blessed Virgin Mary at Golgotha, ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ዘሰኔ፡ ጎልጎታ፡, Bandlet of Righteousness</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="10r" facs="001">Fols 1r–10r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa
                                                  Gabrǝʾel</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="11r" to="18v" facs="011">Fols 11r–18v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="19r" to="41v" facs="019">Fols 19r–41v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="42r" to="51v" facs="042">Fols 42r–51v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                  </msItem>

               </msContents>

                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 130 x 107 x 38 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards covered with tooled leather over decorative linen patches visible inside the turn-ins on front and back cover.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>

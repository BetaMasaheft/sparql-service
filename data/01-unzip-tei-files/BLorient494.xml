                            <title type="complete" ref="https://betamasaheft.eu/LIT2516Wisdom">Ṭǝbaba Salomon</title>          
                        </msItem>
                        
                            <msItem xml:id="p1_i3">
                            <locus from="17r" to="19v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1320Eccles">Ecclesiastes</title>     
                            <colophon xml:id="coloph1" xml:lang="gez">ተፈጸመ፡ በዝየ፡ ጥበቢሁ፡ ለኢያሱ፡ ወልደ፡ ሲራክ።  ዘተጽሕፈ፡ በ፰፻ወ፱፻ወ፸ዓመት።</colophon>
                            <note>The colophon provides the date <date>AM 6970 = AD 1478</date>, probably the date of the MS from which this volume was copied.</note>
                        </msItem>
                        
                            <msItem xml:id="p1_i4">
                            <locus from="20r" to="21v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>          
                            <rubric>ዘሰሎሞን፡ ጠቢብ፡ በረከተ፡ ጸሎቱ፡ ወሀብተ፡ ረድኤቱ፡ የሀሉ፡ ምስለ፡ ፍቁራኒሁ፡<del> ... ፡ .... ፡</del> ለዓለመ፡ (sic)</rubric>

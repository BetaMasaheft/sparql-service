                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">Decorative designs: <locus target="#20r" facs="020">fol. 20r</locus> (two full rows of stops)</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <desc>
                              <locus target="#1r" facs="001">Fol. 1r</locus> The first hymn of the <title ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                           </desc>
                        </item>
                        <item xml:id="a2">
                           <desc type="Asmat">
                              <locus target="#21v" facs="022">Fol. 21v</locus>Asmat prayer against the serpent, i.e. the Devil (<foreign xml:lang="gez">ከይሲ፡</foreign>), in a crude hand
                        </desc>
                        </item>
                        <item xml:id="a3">
                           <desc type="RecordTransaction">
                              <locus target="#22r #22v" facs="022 023">Fols. 22r, 22v</locus> Record of transaction of a certain good, damaged with water stain
                        </desc>
                        </item>
                        <item xml:id="a4">
                           <desc>Several names, in crude hands, are copied on several pages</desc>
                        </item>
                        <item xml:id="a5">
                           <desc type="ScribalNoteCommissioning">Copied by <foreign xml:lang="gez">ሠህለ፡ ማርያም፡</foreign> for <foreign xml:lang="gez">ተክላ፡ ማርያም፡</foreign>, <locus target="#20r" facs="020">fol. 20r</locus>
                           </desc>
                        </item>
                        <item xml:id="a6">
                           <desc>
                          Overlooked words of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted (<locus target="#10v" facs="011"> f. 10v, line 18</locus>)
                        </desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 120 x 82 x 23 mm, prepared for three rows of stitches and attachments but bound with a loose web of strings to rough-hewn boards made of the atypical wide-grained wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>

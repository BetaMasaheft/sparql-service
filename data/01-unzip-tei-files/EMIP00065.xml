               <msContents>
                  <summary>Praises of Mary, ውዳሴ፡ ማርያም፡, Gate of Light, Hymn, "The Angels Praise Her", ይዌድስዋ፡ መላእክት፡ ለማርያም፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="13v" facs="002">Fols 1v–13v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                      <msItem xml:id="ms_i1.1"><locus target="#1v" facs="002">Fol. 1v</locus><title>Monday</title></msItem>
                      <msItem xml:id="ms_i1.2"><locus target="#2v" facs="003">Fol. 2v</locus><title>Tuesday</title></msItem>
                      <msItem xml:id="ms_i1.3"><locus target="#5r" facs="005">Fol. 5r</locus><title>Wednesday</title></msItem>
                      <msItem xml:id="ms_i1.4"><locus target="#7r" facs="007">Fol. 7r</locus><title>Thursday</title></msItem>
                      <msItem xml:id="ms_i1.5"><locus target="#9v" facs="010">Fol. 9v</locus><title>Friday</title></msItem>
                      <msItem xml:id="ms_i1.6"><locus target="#11r" facs="011">Fol. 11r</locus><title>Saturday</title></msItem>
                      <msItem xml:id="ms_i1.7"><locus target="#12v" facs="013">Fol. 12v</locus><title>Sunday</title></msItem>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="13v" to="20r" facs="014">Fols 13v–20r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="20r" to="21v" facs="020">Fols 20r–21v</locus>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አካለ፡ አብ፡ ባሕርይ፡ ወበአካለ፡ ወልድ፡ ቃል፨</l>
                  <l n="2">ወበስመ፡ አካሉ፡ ሕይወት፡ ለመንፈስ፡ ቅዱስ፡ ባዕል፨</l>
                  <l n="3">ዜና፡ መልክኡ፡ እትናገር፡ ለአፍቀረነ፡ እግዚእ፡ መርጡል፨</l>
                  <l n="4">ጥበበ፡ ባስልኤል፡ ማርያም፡ ለልቡናየ፡ ምስሐል፨</l>
                  <l n="5">ኪሩቤል፡ አእምሮ፡ ጸልሊ፡ ዘክንፉ፡ መስቀል፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ መዝገበ፡ ሕይወት፡ ወተስፋ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ልጹይ፡ ለሰንዱነ፡ እንጦስ፡ ዘትትዐጽፋ፨</l>
                  <l n="3">አፍቀረነ፡ እግዚእ፡ መምህር፡ ተመጣዌ፡ ትምህርት፡ እምቃለ፡ ኬፋ፨</l>
                  <l n="4">ኢትግድፈኒ፡ ውስተ፡ ደይን፡ ከመ፡ ለሰዶም፡ ገደፋ፨</l>
                  <l n="5">እግዚአብሔር፡ ዘኮነ፡ ለጥበብ፡ ምዕራፋ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ጸራይቀ፡ ማኅሌት፡ ዘተረክበ፡ እምንዴተ፡ ልሳን፡ ወከናፍር፨</l>
                  <l n="2">ለዕበይከ፡ አቅረብኩ፡ በኍልቈ፡ ሠላሳ፡ ብሩር፨</l>
                  <l n="3">አፍቀረነ፡ እግዚእ፡ ሊቆሙ፡ ለያዕቆባውያን፡ ማኅበር፨</l>
                  <l n="4">ግበር፡ ሊተ፡ እግዚኦ፡ ለደምስሶ፡ ጌጋይ፡ ወነውር፨</l>
                  <l n="5">እስመ፡ አነ፡ ረድእ፡ ወአንተ፡ መምህር፨</l>
               </lg>
            </div>
         </div>

      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ፊልጶስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Filǝṗṗos</persName>
                  <persName>
                  <roleName type="title">ʾAbbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">abbot</occupation>
               <birth notBefore="1322" notAfter="1323">He was born  
                  during the reign of King <persName ref="https://betamasaheft.eu/PRS1854Amdase">ʿAmda Ṣǝyon I</persName>. </birth>
               <floruit notBefore="1350" notAfter="1406">He was a saint and prominent member of the 
                  <persName ref="https://betamasaheft.eu/PRS11207Ewostateans">ʾEwosṭāteans</persName>
                  who lived in the 14th and 15th century. He was the spiritual son of <persName ref="https://betamasaheft.eu/PRS2385Bakimos">
                     Bakimos of Dabra Ṣarābi</persName>, 
                  who was the pupil of <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</persName>. 
                  He was the founder of the monastery of 
                  <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizan</placeName> in <date>1373/74</date>, the strong hold of 
                  <persName ref="https://betamasaheft.eu/PRS11207Ewostateans">ʾEwosṭāteans</persName>.
                  During his tenure as an  abbot, the monastery of  
                  <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizan</placeName> became prosperous. 
                  Due to his refusal to renounce the teaching of the
                  two Sabbaths, he was imprisoned in <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos</placeName> and set free in <date>1403/04</date>. 
                  He was succeeded by
                  <persName ref="https://betamasaheft.eu/PRS10371Yohanne"> 
               ʾabbā Yoḥannǝs</persName>, 
                  the second abbot of <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizan</placeName>.</floruit>
                  <death when="1406">He died at the age of 84.</death>
               </person>  
               
         </listPerson>
         

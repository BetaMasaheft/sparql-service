                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <seg type="rubrication">In <ref target="#ms_i2"/>, <foreign xml:lang="gez">አብ፡</foreign> and <foreign xml:lang="gez">ስብሐት፡</foreign> are rubricated.</seg>

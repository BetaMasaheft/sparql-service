                        <additions>
                            <list>   
                          <item xml:id="e1">
                              <desc>The name of <persName ref="https://betamasaheft.eu/PRS4015Fasilada">Fāsiladas</persName> is mentioned throughout the manuscript.</desc>
                          </item>
                                
                                <item xml:id="a1" corresp="#h2">
                                    <locus target="#1"/>
                                    <desc type="PoemSalam">Salām to a saint, incomplete. The name of the saint is omitted.</desc>
                                    <q xml:lang="gez"/>
                                </item>
                                
                                <item xml:id="a2" corresp="#h2">
                                    <locus target="#1"/>
                                    <desc type="PoemSalam">Salām to a saint. The name of the saint is omitted.</desc>
                                    <q xml:lang="gez"/>
                                </item>
                                
                                <item xml:id="a8">
                                    <locus from="8r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ተአምረ፡ ማርያም፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅ'፡ 
                                        መ'፡ ዓለም።</placeName>
                           </q>
                                </item>
                                
                                <item xml:id="a9">
                                    <locus target="#177v"/>
                                    <date when="1663"/>
                                    <desc type="LandGrant">Deed of gift by <persName ref="https://betamasaheft.eu/PRS4015Fasilada">Fāsiladas</persName> of certain lands, the following the recipient:</desc>
                                    <q xml:lang="gez">ቤተ፡ ክርስተያነ፡ አእዳወ፡ ክርስቶስ፡ እኅወ፡ ኢ ፲ቤጌ፡ አባ፡ ዘክርስቶስ፡ ^ወልደ፡ አባለ፡ ክ ርስቶስ፡</q>
                                </item>
                                
                                <item xml:id="a10">
                                    <locus from="177v"/>
                                    <desc type="GuestText">
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT3065RepCh345">Hymn to Our Lady Mary</title>, the end is missing. The following is the incipit:</desc>
                                    <q xml:lang="gez">እሴብሕ፡ ጸጋኪ፡ ኦዑጽፍተ፡ ልብሰ፡ ወርቅ፡ ንግስትየ፡ ወለተ፡ ዳዊት፡ ንጉሥ።</q>
                                </item>
                                
                                <item xml:id="a11">
                                    <locus from="178v"/>
                                    <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2833RepCh117">Malkǝʾ-hymn to John the Evangelist</title>. The following is the incipit:</desc>
                                    <q xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምሉዓ፡ ሞገስ፡ ወጸጋ።
                                    </q>
                                </item>
                                
                                <item xml:id="a12">
                                    <locus from="179v"/>
                                    <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT3064RepCh344">ʾƎsebbǝḥ ṣaggāki ʾo-mǝlʾǝta ṣaggā</title>. The following is the incipit:</desc>
                                    <q xml:lang="gez">እሴብሕ፡ ጸጋኪ፡ ኦምልእተ፡ ጸጋ፡ ወእትጋነይ፡ ለኪ፡ ኦምልእተ፡ ውዳሴ፡
                                    </q>
                                </item>
                                
                                <item xml:id="a13">
                                    <locus from="180r" to="180rc"/>
                                    <desc type="Unclear">Possibly a land grant. The writing in <locus target="#180rc"/> has been erased, except the last six lines.</desc>
                                    <q xml:lang="gez">በጸሎታ፡ ወበስእለ<sic resp="PRS10171Wright">ተ</sic>፡ ለእግዝእትነ፡ ማርያም፡ ተሣሀለነ፡ እግዚኦ፤
                                        ንጉሠ፡ ነገሥት፡ አእላፍ፡ ሰገድ፡ ዘወሀቡ፡ ለስልጣነ፡ ከርስቶስ፡ ከመ፡ ይኩን፡  ሎቱ፡ ምድረ፡ መስቀል፡ ፪መዓረ፡ ዘዘ ስቀል፡ ወዘዮ፤፤ <gap reason="omitted" resp="PRS10171Wright"/>
                                        <del rend="erasure"/> ንጉሠ፡ ነገሥት፡ <persName ref="https://betamasaheft.eu/PRS10375Yohanne">አእላፍ፡ ሰገድ፡</persName> ዘወሀቡ፡ ለስልጣነ፡ ከርስቶስ፡ ከመ፡ ይኩን፡
                                        ሎቱ፡ ምድረ፡ መስቀል፡ ፪መዓረ፡ ዘዘመስቀል፡ ወዘዮ፤፤</q>
                                </item>
                                
                                <item xml:id="a14">
                                    <locus from="180v"/>
                                    <desc type="GuestText">
                              <foreign xml:lang="am">Maṣḥaf za-ḫʷǝlqʷ marhočč</foreign> for <foreign xml:lang="gez">Maskaram</foreign>
                                    and <foreign xml:lang="gez">Ṭǝqǝmt</foreign>.</desc>
                                    <q xml:lang="am">መጽሐፍ፡ ዘኍልቍ፡ መርሆች፡</q>
                                </item>
                                
                                <item xml:id="e3">
                                    <locus from="100r"/>
                                    <desc/>
                                    <q xml:lang="gez">ጥራዝ፡ ዘመልክዓ፡ ክርስቶስ፡</q>
                                </item>
                            </list>
                        </additions>

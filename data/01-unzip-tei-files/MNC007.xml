                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus from="41v" to="42r"/>
                           <desc type="GuestText">
                              <title ref="https://betamasaheft.eu/LIT5888AsmatPrayer"><foreign xml:lang="gez">ʾAsmāt</foreign>-prayer</title>. The prayer is similar to the
                              shorter one contained in <ref type="mss" corresp="https://betamasaheft.eu/EMIP02011">Washington, D.C., Howard University School of Divinity, Tweed Codex 062</ref>. The
                              prayer was written by two scribes. The first started writing with
                              bulky letters and stopped after a few lines. The remaining text was
                              written by a more skilled hand in very small characters.</desc>
                           <note/>
                           <q xml:lang="gez">
                              <seg part="I">
                                 <locus target="#41v"/>ቶቤር፡ ፯፡ አለበዎ፡ ቃለ፡ ድርሰት፡ ወት<supplied reason="omitted" resp="SH">ር</supplied>ጓሜ፡ ወይ<add place="inline">ት</add>ረኃዋ፡ ሎቱ፡ አናቅ<del rend="expunctuated" cause="superfluous">ፅ</del>ጸ፡ ሰማያት፡ ከመ፡ ማይ፡ አሩጽ፡ ቃለ፡ ድርሰት፡ ወት<supplied reason="omitted" resp="SH">ር</supplied>ጓሜ፡ <del rend="expunctuated" cause="superfluous">ኵ</del>፩፡ መጻሕ<supplied reason="omitted" resp="SH">ፍ</supplied>ት፡ በምድር፡ ልብየ፡</seg>
                              <seg part="F">
                                 <locus target="#42r"/>በ፫፡ አስማት፡ ተርኅወ፡ ሰማይ፡ ወተከሥተ፡ ምድር፡ ከማሁ፡ ክሥት፡
                                 አዕይንተ፡ ልብብ፡ ሊተ፡ ለገብርከ፡ እገሌ፡ ፵፱፡ ዘቢብ፡ በለሚ፡ በስም፡ ጽዋ፡ ፵፱፡ <add place="interlinear">ድ</add>ግም፡ ፯ዕለት፡ ግበር፡</seg>
                           </q>
                        </item>

                        <item xml:id="a2">
                           <locus target="#1v"/>
                           <desc type="Unclear">Unclear note, written in ink, mentioning different
                              names (partly in abbreviated forms).</desc>
                           <q xml:lang="gez">
                              <seg part="I">
                                 <locus target="#1v"/><del rend="expunctuated">አ</del>ገብረየስ፡ አብተ፡
                                 ወልድ፡ ጋባዠ፡ ኪዳነ፡ ወልድ፡</seg>
                           </q>
                        </item>

                        <item xml:id="a3">
                           <locus from="2r" to="1v"/>
                           <desc type="CalendaricNote">List of commemorations days for one
                              unspecified month. The note begins on <locus target="#2r"/>, continues
                              and terminates on <locus target="#1v"/>.</desc>
                           <q xml:lang="gez"> በ፩ልደታ፡ በ፪<persName ref="https://betamasaheft.eu/PRS4855Guba"><t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">አባ፡</t:roleName> ጉባ፡</persName> በ፫<persName ref="https://betamasaheft.eu/PRS10708ZenaMa">ዜና፡ ማርቆስ፡</persName> በአታ፡ <gap reason="ellipsis" resp="SH"/> በ፴<persName ref="https://betamasaheft.eu/PRS5741Johnthe">ዮሐንስ፡ መጥምቅ።</persName></q>
                        </item>
                        
                        <item xml:id="a4">
                           <locus target="#2v"/>
                           <desc type="GuestText">
                              <title ref="https://betamasaheft.eu/LIT2769RepCh53">Excerpt from a <foreign xml:lang="gez">salām</foreign>-hymn to <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla
                                    Hāymānot</persName></title> The same hymn is preserved, e.g. in
                                 <ref type="mss" corresp="https://betamasaheft.eu/ESath002">Gulo Maḵadā, ʾArāʿro Takla Hāymānot, ATH-002</ref> (<locus from="199va" to="200ra"/>). The text is crudely written in ink and ends
                              abruptly.</desc>
                           <note/>
                           <q xml:lang="gez">
                              <seg part="I">
                                 <locus target="#2v"/>ሰላም፡ ለከ፡ ተክለ፡ ሃይማኖት፡ አቡነ፡ ምሉዓ፡ ሞገስ፡ ወጸጋ፡ ስፉሃ፡
                                    አእፁ<supplied reason="omitted" resp="SH">ቅ</supplied>፡ ወወይን፡
                                 እንበለ፡ ንትጋ፡ ለባሕር፡ እስከ፡ ድንጋጋ፡ ሰ፡ እም፡ ልደትከ፡ ሕፃን፡</seg>
                           </q>
                        </item>

                        <item xml:id="e1">
                           <desc> Scribal corrections occur rarely. Erroneous characters or words
                              are encircled or marked with lines above and below (e.g. <locus target="#34v #35r #37r"/>). Scribbles on <locus from="1r" to="2r"/>.</desc>
                        </item>

                        <item xml:id="e2">
                           <desc>A sticker of the monastic library with the signature ‘Ms 35’ is
                              glued onto the inner side of the front board. The signature Et I is
                              written in pencil in the lower margin of <locus target="#1r"/>. The
                              inventory number 50432 is written in pencil on <locus target="#44v"/>.</desc>
                        </item>
                     </list>
                  </additions>


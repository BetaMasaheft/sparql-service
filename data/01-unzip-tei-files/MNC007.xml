                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic" corresp="https://betamasaheft.eu/MNC007#ms_i1 #ms_i2">
                        <locus from="3r" to="21v"/>
                        <seg type="ink">Black, red</seg>
                        <date notBefore="1800" notAfter="1976">19th/20th century</date>
                        <seg type="script">Mediocre hand with broadly formed letters. The
                           handwriting becomes sometimes irregular, e.g. on <locus target="#18r"/>.
                              <persName ref="https://betamasaheft.eu/PRS12028WaldaAr">Walda ʾAragāwi</persName> is mentioned
                           as ‘scribe’ on <locus target="#16v"/> and as ‘servant’ on <locus target="#41v"/>.</seg>
                     </handNote>

                     <handNote xml:id="h2" script="Ethiopic" corresp="https://betamasaheft.eu/MNC007#ms_i3 #ms_i4 #ms_i5">
                        <locus from="21v" to="41v"/>
                        <seg type="ink">Black, red</seg>
                        <date notBefore="1800" notAfter="1976">19th/20th century</date>
                        <seg type="script">Trained hand with slender, rather curved characters. The
                           writing is oriented slightly to the left.</seg>
                     </handNote>

                     <handNote xml:id="h3" script="Ethiopic" corresp="https://betamasaheft.eu/MNC007#ms_i3">
                        <locus from="42v" to="44v"/>
                        <seg type="ink">Black, red (partly faded)</seg>
                        <date notBefore="1800" notAfter="1976">19th/20th century</date>
                        <seg type="script">Rushed hand. The strokes of the characters are often not
                           aligned resulting in a sort of fragmented handwriting.</seg>
                        <seg type="rubrication" corresp="#h1 #h2 #h3">Groups of lines on the incipit
                           page of <ref target="#ms_i1"/>, initial two lines of <ref target="#ms_i2"/>; initial words of all other texts and of each stanza; holy names (each
                           character alternates with black ink in the name of God on <locus target="#21r"/>); names of the individuals related to the production
                           and ownership of the manuscript; partly elements of the punctuation
                           marks, text dividers, and numerals.</seg>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሰ፡ or ሰላ፡</abbr> for <expan>ሰላም፡</expan>
                           </item>
                        </list>
                     </handNote>

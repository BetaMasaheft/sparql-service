               <msContents>
                  <msItem xml:id="ms_i1" corresp="#h1">
                     <locus from="3r" to="16v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">Malkǝʾa Śǝllāse<foreign xml:lang="gez">Malkǝʾa
                           Śǝllāse</foreign></title>
                     <note>The hymnodic portrait poem praises the Trinity and consists of 47
                        stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#3r"/>
                        <pb n="3r"/>
                        <hi rend="rubric">ሰላም፡ ለሕላዌክሙ፡ ዘይመውዕ፡ ሕላውያተ። ለ</hi>ረኪበ፡ ስሙ፡ ኅቡዕ፡ ዓመ፡ ወጠንኩ፡
                           ተም<hi rend="rubric">ኔተ። እምግ<supplied reason="omitted" resp="SH">ብ</supplied>ርናክሙ፡ ሥላሴ፡ ሶበ፡ ረከብኩ፡ አስማተ።</hi> መለኮተ፡ ለለ፩ዘዚአክሙ፡ ገጻተ።
                        እንበለ፡ ትድምርት፡ እሰሚ፡ ወእሁብ፡ ትድምርተ።</incipit>
                     <explicit xml:lang="gez">
                        <locus from="16r" to="16v"/>
                        <hi rend="rubric">ለ<gap reason="illegible" unit="chars" quantity="1"/>በነጊድ፡</hi> አቅረብኩ፡ መካልየ፡ ልሳን፡ ስብሐታተ። መጠነ፡ አስር፡ ርብዕ፡ እንዘ፡ አተሉ፡ ፯ተ። <pb n="16v"/> ህየንተ፡ ፩ዱ፡ <hi rend="rubric">ሥላሴ፡</hi> እለ፡ ትፈድዩኒ፡ ፻ተ። ጸግውኒ፡
                        ለገብርክሙ፡ ንዋየ፡ ገጽ፡ ትፍሥሕተ። ወዲበ፡ ፲ቱ፡ አኅጉር፡ ኀቡኒ፡ ሢመተ። <hi rend="rubric">ኦሥሉስ፡
                           ቅዱስ፡</hi>
                        <supplied reason="omitted" resp="SH">ዕቀቡነ፡</supplied> እመከራ፡ ሥጋ፡ ወነፍስ፡
                        ለገብርክሙ። <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12029GabraMa">ገብረ፡
                              ማርያም፡</persName></hi> ወጸሐፊሁ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12028WaldaAr">ወልደ፡ አረጋዊ፡ </persName></hi> ለዓለመ፡ ዓለም፡ አሜን፡
                        ወአሜን፡ ለይኩን፡ ለይኩን።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i2" corresp="#h1">
                     <locus from="16v" to="21v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus<foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas
                           Qǝddus</persName></foreign></title>
                     <note>The work comprises 17 stanzas.</note>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus from="16v" to="17r"/>
                        <hi rend="rubric">ሰላም፡ ለጽንሰትከ፡ መሰረተ፡ ነገር፡ ወውጣኔ። ወ<choice>
                              <sic>ልለሌ</sic>
                              <corr resp="SH">ለል</corr>
                           </choice>ደ</hi>ትከ፡ ሰላም፡ <choice>
                           <sic>ብ</sic>
                           <corr resp="SH">በ</corr>
                        </choice>ብስራተ፡ መልአክ፡ ሠናየ፡ ቅኔ። <hi rend="rubric">ገብረ፡ <pb n="17r"/> መንፈስ፡
                              <add place="interlinear">ቅ</add>ዱስ፡</hi> ጳውሎስ፡ ሰባኬ፡ ሃይማኖት፡ ውስተ፡ ኵርጓኔ።
                        ተማኅፀንኩ፡ በኪዳንከ፡ ከመ፡ ኢይርአይ፡ ኵነኔ። ወበእንተዝ፡ ኃሠሥኩ፡ ኪያከ፡ መድኅኔ።</incipit>
                     <explicit xml:lang="gez"><locus from="21r" to="21v"/><hi rend="rubric">ሰላም</hi>
                        ለሀገሩ፡ ወሰላም፡ ለደብሩ። ወሰላም፡ ለመቃብሩ። <hi rend="rubric">ገብረ፡ መንፈስ፡ ቅዱስ፡</hi> እቡየ፡
                           ለእ<hi rend="rubric">ግ</hi>ዚ<hi rend="rubric">አ</hi>ብ<hi rend="rubric">ሔ</hi>ር፡ ፍቅሩ። ደመናተ፡ አንኰርኮሩ፡ ወአእዋፈ፡ ሰማይ፡ ዘመሩ። ወጊዜ፡ ሞትከ፡ መላእክት፡ አንከሩ። ኦ<hi rend="rubric">ገብረ፡ መንፈስ፡ ቅዱስ፡</hi> ዕቀበነ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገ<pb n="21v"/>ብርከ። <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12029GabraMa">ገብረ፡
                              ማርያም፡</persName></hi> ለዓለመ፡ ዓለም፡ አሜ<surplus resp="SH">ን</surplus>ን።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i3" corresp="#h2 #h3">
                     <locus from="21v" to="22v"/>
                     <locus from="42v" to="44v"/>
                     <note>The text begins on <locus target="#21v"/> and is written by <ref target="#h2"/> until <locus target="#22v"/>, where it breaks off in the
                        middle of a sentence. <ref target="#h3"/> continues the text seamlessly on
                           <locus target="#42v"/>. The last lines are barely legible due to faded
                        ink.</note>
                     <title>Hymn addressing different saints</title>
                     <textLang mainLang="gez"/>
                     <note>This hymn is included in the <ref type="work" corresp="https://betamasaheft.eu/LIT1961Mashaf">Maṣḥafa Saʿātāt</ref> belonging to the horologium for the night
                              (<bibl corresp="http://zotero.org/groups/358366/items/I6R8Q66K"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Tasfa1955Saatat"/><title level="m">&lt;hi rend="italics"&gt;ሰዓታት። ዘሌሊት፡ ወዘነግህ። (&lt;/hi&gt;Saʿātāt. Za-lelit wa-za-nagh&lt;hi rend="italics"&gt;, ‘The Book of the Hours. Of the night and of the morning’)&lt;/hi&gt;</title><editor><name>Tasfā Gabra Śǝllāse</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā Gabra Śǝllāse māttamiyā bet</publisher><date>1954</date><note type="tags"><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note></note><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note><citedRange unit="page">136–139</citedRange></bibl>).</note>
                     <incipit xml:lang="gez">
                        <locus target="#21v"/>
                        <hi rend="rubric">ኦእግዚኦ፡ መሐረነ፡ ኦእግዚኦ፡ መሐከነ፡ ኦእ</hi>ግዚኦ፡ መሐርከነ፡ ኦሥሉስ፡ ቅዱስ፡
                        አምላክነ፡ ወተስፋነ፡ መሐር፡ ልህኵትከ፡ አድኅን፡ ነፍሳተነ፡ </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#44v"/>ዘአምትረትከ፡ ሄሮድያዳ፡ በግፍዕ፡ እንበለ፡ እዳ፡ ሰ፡ ዕበ፡ ስእንኩ፡
                           ጸ<supplied reason="lost" resp="SH">ዲቀ</supplied>፡ ለኦሪተ፡ ሙሴ፡ <supplied reason="lost" resp="SH">በ</supplied>ሕጋ፡ <gap reason="lost" unit="chars" quantity="7"/> እንበለ፡ ንትጋ፡ <supplied reason="lost" resp="SH">ዘአ</supplied>ርኃውከ፡ ቍልፈ፡ መ<add place="interlinear">ን</add>ሰጋ፡ ሰ፡ <gap reason="illegible" unit="chars" quantity="4"/> ጻማየ፡ እግዚኦ፡ ከመ፡ <gap reason="illegible" unit="chars" quantity="5"/> በከንቱ፡ ዮሐንስ፡ ሀበኒ፡
                           ዘ<supplied reason="lost" resp="SH">እ</supplied>ፈቱ፡ እስመ፡ <gap reason="illegible" unit="lines" quantity="3"/> ማርያም፡ ወለጸሐፊሁ፡ ወ<supplied reason="lost" resp="SH">ል</supplied>ደ፡ ቂር<gap reason="illegible" unit="chars" quantity="2"/></explicit>
                     <note>Most probably the name of <persName ref="https://betamasaheft.eu/PRS12029GabraMa">Gabra
                           Māryām</persName> is stated here at the very end together with that of a
                        scribe, probably named Walda Qirqos (<ref target="#h3"/>).</note>
                  </msItem>

                  <msItem xml:id="ms_i4" corresp="#h2">
                     <locus from="23r" to="32r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172"><foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS6819Mary">Māryām</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 60 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#23r"/>
                        <pb n="23r"/>
                        <hi rend="rubric">ሰላም፡ ሰላም፡</hi> ለዝክረ፡ ስምኪ፡ ሐዋዝ፡ እምነ፡ ከልበኒ፡ ወ<choice>
                           <sic>ቁ</sic>
                           <corr resp="SH">ቍ</corr>
                        </choice>ስጥ፡ ወእምነ፡ ሰንበልት፡ ምዑዝ፡ <hi rend="rubric">ማርያም፡</hi> ለባሲተ፡ ዓቢይ፡ ትእዛዝ፡
                        ይስቅየኒ፡ ለለጽባሁ፡ ወይነ፡ ፍቅርኪ፡ አዚዝ፡ ከመ፡ ይሰቅዮ፡ ውሂዝ፡ ዘሰናይ፡ አርዝ።</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#32r"/>
                        <hi rend="rubric">ስብሐት፡</hi> ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በ<choice>
                           <sic>ኁ</sic>
                           <corr resp="SH">ኍ</corr>
                        </choice>ልቈ፡ ኵሉ፡ ስእርትየ፡ <hi rend="rubric">ስብሐት፡</hi> ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በ<choice>
                           <sic>ኁ</sic>
                           <corr resp="SH">ኍ</corr>
                        </choice>ልቈ፡ ኵሉ፡ አእጽምትየ፡ <hi rend="rubric">ስብሐት፡</hi> ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በ<choice>
                           <sic>ኁ</sic>
                           <corr resp="SH">ኍ</corr>
                        </choice>ልቈ፡ ኵሉ፡ ዘተርእየ፡ ስብሐት፡ ለኪ፡ ንግሥትየ፡ በ<choice>
                           <sic>ኁ</sic>
                           <corr resp="SH">ኍ</corr>
                        </choice>ልቈ፡ ኵሉ፡ ዘኢያስተርአየ፡ ስብሐተ፡ ድንግልናኪ፡ ዘልፈ፡ ይነግር፡ አፉየ።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i5" corresp="#h2">
                     <locus from="32v" to="41v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123"><foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS5684JesusCh">ʾIyasus</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 55 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#32v"/>
                        <pb n="32v"/>
                        <hi rend="rubric">ሰላም፡</hi> ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይኄሱ፡ ዘአንበረ፡ ቅድመ፡ አግዚአብሔር፡
                        በአትሮንሱ፡ <hi rend="rubric">ኢየሱስ፡</hi> ክርስቶስ፡ ለዳዊት፡ ባሕርየ፡ ከርሡ፡ አክሊለ፡ ስምከ፡ እንዘ፡
                        ይትቄጸል፡ በርእሱ፡ አኅጉረ፡ ፀር፡ ወረሰ፡ ኢያሱ።</incipit>
                     <explicit xml:lang="gez">
                        <locus from="41r" to="41v"/><hi rend="rubric">ሰላም፡</hi> ሰላም፡ ለኵሉ፡ መልክዕከ፡ ከመ፡ መል<choice>
                           <sic>ኩ</sic>
                           <corr resp="SH">ክዑ</corr>
                        </choice>፡ ለአቡከ፡ <hi rend="rubric">ኢየሱስ፡</hi> ክርስቶስ፡ ሕማማተ፡ መስቀል፡ ዘፆ<gap reason="illegible" unit="chars" quantity="1"/>ርከ ፡ ኅብዓኒ፡ አምገጸ፡ ሞት፡ በእንት፡
                           <hi rend="rubric">ማርያም</hi> እምከ፡ አማኑኤል፡ አምላኪየ፡ ኢይጽናዕ፡ ልብከ። <pb n="41v"/>
                        ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ኵነኒ፡ መድኃኒተ፡ ሥጋ፡ ወነፍስ፡ ለኃጥዕ፡ ገብርከ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12028WaldaAr">ወልደ፡ አረጋዊ።</persName></hi></explicit>
                  </msItem>
               </msContents>

               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                           <p>A tear repaired on <locus target="#34"/>.</p>
                        </support>
                        <extent>
                           <measure unit="leaf">44</measure>

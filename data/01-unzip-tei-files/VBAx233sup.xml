                        </altIdentifier>
                    </msIdentifier>
                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="4r">Fols 1r–4r</locus>
                            <title>Hymns to Mary</title>
                            <msItem xml:id="ms_i1.1">
                                <locus from="1r" to="2r">Fols 1r–2r</locus>
                                <title>Dopo: Nel nome del Padre ... e il titolo
                                    Kidan za-nagh viene in realtà un saluto alla
                                    Vergine: inc. Mahdara Malakot salam laki</title>                                
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="2r">Fols 2r and following</locus>
                                <title ref="https://betamasaheft.eu/LIT6779Annun">Annunciation followed by salām-laki-greetings</title>
                                
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="5r" to="21v">Fols 5r–21v</locus>
                            <title ref="https://betamasaheft.eu/LIT1716Kidanz">Kidān za-nagh</title>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="21v" to="49v">Fols 21v–49v</locus>
                            <title>Prayers from the Missal: Anaphoras of Our Lord</title>
                            <msItem xml:id="ms_i3.1">
                                <locus from="21v">Fols 21v and following</locus>
                                <title>Mashafa Kidan za-nagaromu la-hawaryatihu 'Egzi'ena ..</title>
                            </msItem>
                            <msItem xml:id="ms_i3.2">
                                <locus from="24v">Fols 24v and following</locus>
                                <title ref="https://betamasaheft.eu/LIT1100Anapho">ʾAkkʷateta qʷǝrbān za-ʾǝgziʾǝna ʾIyasus Krǝstos</title>
                            </msItem>
                            <msItem xml:id="ms_i3.3">
                                <locus from="35v">Fols 35v and following</locus>
                                <title ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat za-wald</title>
                            </msItem>
                            <msItem xml:id="ms_i3.4">
                                <locus from="40v">Fols 40v and following</locus>
                                <title>Litany for deacons</title>
                                <note>as in Brightmann, Liturgies Eastern and Western, V. I,
                                    Oxford 1896, p. 206 s</note>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="49v" to="62r">Fols 49v–62r</locus>
                            <title ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="62r" to="84v">Fols 62r–84v</locus>
                            <title>Various prayers</title>
                            <msItem xml:id="ms_i5.1">
                                <locus from="62r">Fols 62r and following</locus>
                                <title ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>                                
                            </msItem>
                            <msItem xml:id="ms_i5.2">
                                <locus from="70r">Fols 70r and following</locus>
                                <title> O Signor mio G. Cristo figlio del Dio vivo,
                                    per Maria tua genitrice aiutami...</title>                                
                            </msItem>
                            <msItem xml:id="ms_i5.3">
                                <locus from="79r">Fols 79r and following</locus>
                                <title>Iyasus Krestos tasfaya, I. K. rada'eya, I. K. sawaneya ...</title>                                
                            </msItem>
                            <colophon xml:id="coloph1"><locus target="#82r">Fol. 82r</locus><note>Colofone, con la scomunica per chi rubasse il libro</note></colophon>
                            <msItem xml:id="ms_i5.4">
                                <locus target="#82v">Fol. 82v</locus>
                                <title>Lode a te, Signore, che a tua immagine mi hai creato, l. a. t. S. che dai lombi di mio padre mi hai fatto germinare</title></msItem>
                            <msItem xml:id="ms_i5.5">
                                <locus from="83r" to="84v">Fols 83r–84v</locus>
                                <title> Nel nome del Padre ... Gloria e lode a Colui che ha fondato  tutto il mondo con una sola parola ecc. Alla fine i nomi magici
                                di Dio Markéwon, Sarbewon, Faldeheran ...</title></msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="85r" to="87r">Fols 85r–87r</locus>
                            <title>Calendar of saints for every month</title>
                        </msItem>
                    </msContents>

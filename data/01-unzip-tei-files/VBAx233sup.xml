            <sourceDesc>
                <msDesc xml:id="ms">
                    <msIdentifier>
                        <repository ref="https://betamasaheft.eu/INS0415Biblioteca_Ambrosiana">Biblioteca Ambrosiana</repository>
                        <idno>X 233 sup.</idno>

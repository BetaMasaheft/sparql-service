         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ጐሸን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gʷašǝn</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">ጎሸን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Gošǝn</t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="Judaism"/>


               <t:occupation type="political">ruler</t:occupation>



               <t:floruit notBefore="1563" notAfter="1587">He was a
                  <t:persName ref="https://betamasaheft.eu/ETH1274Betaes">Beta ʾƎsrāʾel</t:persName> leader during the reign of


                  <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Śarḍa Dǝngǝl</t:persName>. In <t:date>1586-87</t:date>, he led unsuccessful raid
                  in <t:placeName ref="https://betamasaheft.eu/LOC6144Wagara">Wagarā</t:placeName> against

                  <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Śarḍa Dǝngǝl</t:persName> which ended with the captivity of hundreds of <t:persName ref="https://betamasaheft.eu/ETH1274Betaes">Beta ʾƎsrāʾel</t:persName>,
                  massacre of a number of  them and the enslavement of women and children.
               </t:floruit>
               <t:death when="1587">He died in <t:date>1587</t:date> at <t:placeName ref="https://betamasaheft.eu/LOC6234WarqAm">Warq ʾAmbā</t:placeName>. </t:death>

            </t:person>
            
         </t:listPerson>





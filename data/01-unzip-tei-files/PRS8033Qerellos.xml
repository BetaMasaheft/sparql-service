         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ቄርሎስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Qerǝllos</t:persName>
               <t:persName type="alt">Sidaros Ben Antoni</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾAbuna</t:roleName>
               </t:persName>
               <t:occupation type="ecclesiastic">metropolitan</t:occupation>
               <t:nationality type="Egypt"/>
               <t:faith type="Coptic"/>
               <t:birth when="1880"/>
               <t:residence>
                  <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">Addis Ababā</t:placeName>
               </t:residence>
               <t:floruit notBefore="1929" notAfter="1950">He was the last Egyptian metropolitan of the
                  Ethiopian Orthodox Church,
                  consecrated by <t:persName ref="https://betamasaheft.eu/PRS5714JohnXIX">John XIX</t:persName>  
                  in <t:date>1929</t:date> and he was also the first to be appointed over the first five Ethiopian Bishops. 
                  He annointed 
                  <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫayla Śǝllāse I</t:persName> as king of kings of Ethiopia on 
                  <t:date> 2 November 1930</t:date> in 
                  <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName>.
            </t:floruit>
               <t:death when="1950">He died on <t:date>22 October 1950</t:date>
               </t:death>
            </t:person>
            
         </t:listPerson>

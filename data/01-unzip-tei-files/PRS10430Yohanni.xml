      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዮሐኒ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yoḥanni</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Egypt"/>
               <t:faith type="Coptic"/>
               
             
               <t:floruit> According to the tradition, he was a saint of an Aksumite time who came from <t:placeName ref="https://www.wikidata.org/entity/Q79">Egypt</t:placeName>
                  with his followers in the reign of either King  <t:persName ref="https://betamasaheft.eu/PRS5841Kaleb">Kāleb</t:persName> or 
                  <t:persName ref="https://betamasaheft.eu/PRS4327GabraMa">Gabra Masqal</t:persName>, or during the reign of a historical son of King  <t:persName ref="https://betamasaheft.eu/PRS5841Kaleb">Kāleb</t:persName> 
                  , <t:persName ref="https://betamasaheft.eu/PRS10178WZBW">WʿZB (Waʿzeb)</t:persName>. He is said to be the founder of the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2379DabraS">Dabra Sinā</t:placeName> in 
                  <t:placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</t:placeName> 
               </t:floruit>
               <t:death/>
            </t:person>  
            

      <t:body>
         <listPlace>
            <t:place type="church monastery gadam" subtype="institution">
               <t:placeName>Makāʿǝlo Makāna Lǝʿul</t:placeName>
               <t:placeName type="alt">Makāʿǝlo</t:placeName>
               <t:placeName type="alt">Makāʿlo</t:placeName>

               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>
               <t:settlement type="warada" from="2011-11-16" to="2011-11-16" ref="https://betamasaheft.eu/LOC3640GuloMa">Gulo Maḵadā</t:settlement>
               <t:settlement type="tabiya" from="2011-11-16" to="2011-11-16" ref="https://betamasaheft.eu/LOC6547Haban">Ḥaban</t:settlement>
               <t:settlement from="2011-11-16" to="2011-11-16" type="qushat" ref="https://betamasaheft.eu/LOC7223Makalo">Makāʿǝlo</t:settlement>
               <t:location>
                  <t:geo>14.411504 39.465905</t:geo>
                  <t:height unit="m">2230.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1500" notAfter="1600">1500-1600</t:date>
                  <t:desc type="foundation">Founded possibly during the time of King <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">Sarṣa Dǝngǝl</t:persName> (r. <t:date>1563–1597</t:date>).</t:desc>
                  <t:ab type="history">Gadām. It is still considered a monastery, but there are no monks. A small recent church dedicated to <t:persName ref="https://betamasaheft.eu/PRS10322Yemata">Yǝmʾātā</t:persName> is located on the other side of the road, on the rock, close to
                     <t:placeName ref="https://betamasaheft.eu/INS0097AQG">ʿĀddi Qolqʷāl (AQG)</t:placeName>. The church of <t:placeName ref="https://betamasaheft.eu/INS0039MY">Dabra Māʿṣo Yoḥannǝs</t:placeName> and it's flat-top mountain can be seen from the compound of Makāʿǝlo. 
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/MKMG.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>12 Mss photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg001">MKMG-001</t:ref> “ Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg002">MKMG-002</t:ref> “ Prayer of Incense”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg003">MKMG-003</t:ref> “ Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg004">MKMG-004</t:ref> “ Synaxarion (September-February)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg005">MKMG-005</t:ref> “Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg006">MKMG-006</t:ref> “ Miracles of Mary”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg007">MKMG-007</t:ref> “Vita of  Zä-Mikaʾel Arägawi”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg008">MKMG-008</t:ref> “ The Book of Baptism”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg009">MKMG-009</t:ref> “ Synaxarion (March-February)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg010">MKMG-010</t:ref> “ The Rite of the Holy Week”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg011">MKMG-011</t:ref> “The Book of Gǝṣṣǝw”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmkmg012">MKMG-012</t:ref> “Miracles of Mary”.</t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="2"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10775Trinity">Trinity</t:persName>, <t:ref type="authFile" corresp="https://betamasaheft.eu/CovenantMercy">Kidāna Mǝḥrat</t:ref>.</t:ab>
               </t:note>
            </t:place>

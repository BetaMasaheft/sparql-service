                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful. Smaller letters starting from <locus target="#120va">120va</locus>.</seg>
                        <seg type="ink">Black, red (sometimes reddish-brown, e.g. <locus target="#79v">79v</locus>, 80r)</seg>
                        <date>second half of 19th century</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                           <item>በእ፡ for በእንተ፡</item>
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the king, bishop and
                           patriarch; groups of lines alternating with black lines on the incipit
                           page of Text I; heading of Text I; incipits of the texts and their
                           sections; musical notation signs; (abbreviated) directives for the
                           ministers; some other words, e.g. ʾǝgle, ʾǝmzǝ, kahǝn, ʾǝmmare; elements
                           of the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>

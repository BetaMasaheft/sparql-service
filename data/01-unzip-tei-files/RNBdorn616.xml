                  <msItem xml:id="ms_i1">
                    <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</title>
                    <textLang mainLang="gez"/>

                    <msItem xml:id="ms_i1.1">
                        <locus from="1r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4116AboutFaithBasil">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ድርሳን፡ ዘባስልዮስ፡ ኤጲስ፡ ቆጶስ፡ ርቱዓ፡ ሃይማኖት፡ በእንተ፡ ሃይማኖት፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <incipit>አልቦ፡ አመ፡ ትጸግብ፡ ቤተ፡ ክርስቲያን፡ እንዘ፡ ከመዝ፡ ቃላት፡ እንዘ፡ መዝሙረ፡ ዳዊት፡ ትሬሲ፡ ዘእመክብበ፡ ቃል፡ ዘይብል፡ ይመልእ፡ እዝን፡
                        በአጽምዖ፡ ነገር፡ ገበርነ፡ በሐሳብ፡ ኃይልነ፡ ኢኮነ፡ መጠነ፡ ውእቱ፡ እግዚአብሔር፡ አው፡ መጠነ፡ ንክል፡ ንሕነ፡ እስመ፡ ዘማዕከለ፡ ሰማይ፡ ወምድር፡ በመልዓ፡ አዕይንቲነ፡
                        ነጽሮተ፡ እንተ፡ ምዕር፡ ኢኮነሂ፡ በእንቲአሁ፡ ነጽሮቶ፡ እንተ፡ ምዕር። ከማሁ፡ ይእዜኒ በሕዳጥ ቃላት ንፌጽም፡ ወለአብሂ፡ በሐሳበ፡ ህላዌሁ፡
                        ነሀብ፡ ኵሎ፡ ነገረ፡ መዊዕ፡ ኢመላእክት፡ ልሳናት፡ ይከውን፡ ወኢሊቃነ፡ መላእክት፡ ምስለ፡ መላእክት፡ ምስለ፡ ፍጥረትመላእክት፡ ህላዌ፡
                        አው፡ ተሀቢሮሙ፡ <hi rend="rubric">ሚካኤል</hi>፡ መክፈልተ፡ መላእክት፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/> እእምሮ፡ አላ፡ ምስለ፡ ኵሉ፡ የዓርዩ፡
                        ለሕፀት። ወአንተሰ፡ ለእመ፡ ትፈቅድ፡ በእንተ፡ መለኮት፡ ነገረ፡ አው፡ ሰሚዓ፡ ሕድግ፡ ሥጋከ፡ ወሕድግ፡ ሥጋ፡ ሕሊና፨ ወሕድጋ፡ ለምድር፡ ወሕድጋ፡ ለባሕር፨ </incipit>
                        <note>A liberal and poor translation of the homily of <persName ref="https://betamasaheft.eu/PRS2546Basilth">Basil the Great</persName>,
                         see <bibl corresp="http://zotero.org/groups/358366/items/EWF5CPWI"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Migne1885Basilius"/><title level="m">Patrologiae cursus completus: sive bibliotheca universalis, integra... Series graecae: in qua prodeunt patres, doctores, scriptoresque ecclesiae Graeca a S. Barnaba ad Bessarionem. Tomus XXXI. S. Basilius Caesariensis episcopus.</title><editor><forename>Jaques Paul</forename><surname>Migne</surname></editor><pubPlace>Paris</pubPlace><publisher>Paul Dupont</publisher><date>1885</date><biblScope unit="volume">31</biblScope><note type="url">https://ia600502.us.archive.org/5/items/patrologicursus02migngoog/patrologicursus02migngoog.pdf</note><note type="tags"><note type="tag">bm:Migne1885Basilius</note></note><note type="tag">bm:Migne1885Basilius</note><citedRange unit="column">450-471</citedRange></bibl>.
                        According to  <persName ref="https://betamasaheft.eu/PRS9602Turaev">B. Turaev</persName>, the presence of this text in <title>Dǝrsāna Mikāʾel</title>
                          is not common</note>
                    </msItem>
                       <msItem xml:id="ms_i1.2">
                        <locus from="5r"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyTimothy">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                          ድርሳን፡ ዘቅዱስ፡ ዲማቴዎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ በበዓለ፡ ሊቀ፡ መላእክት፡ <hi rend="rubric">ሚካኤል</hi>፡ አመ፡ ፲ወ፪ለኅዳር፡ ሃይማኖት፡<gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        </title>
                        <textLang mainLang="gez"/>
                         <note>The homily by <persName ref="https://betamasaheft.eu/PRS9523Timothy">Timothy III of Alexandria (Aeluros)</persName>  for <date>12 Ḫǝdār</date>.
                        </note>
                        </msItem>

                    <msItem xml:id="ms_i1.3">
                        <locus from="12r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyDeratewos">
                           <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ወሀሎ፡ ፩ብእሲ፡ ርቱዕ፡ ሃይማኖት፡ ወስሙ፡ ድራቴዎስ፡ ወስመ፡ ብእሲቱ፡ ቴዎብስታ።
                        ወይነብሩ፡ ውስተ፡ ሀገር፡ እንተ፡ ስማ፡ ቀሎንያ።
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        </title>
                        <textLang mainLang="gez"/>
                         <note>The homily on <persName ref="https://betamasaheft.eu/PRS11306Deratewos"> Dǝrāwetos </persName> and his wife
                           <persName ref="https://betamasaheft.eu/PRS11307Tewobesteya"> Tewobǝstā </persName> from <placeName ref="https://betamasaheft.eu/LOC6571Qalonya"> Qalonyā </placeName>
                        an anonymous author for <date>12 Tāhśās</date>.</note>
                       </msItem>

                    <msItem xml:id="ms_i1.4">
                        <locus from="18v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyGenbot">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ነገር፡ ዘቅዱስ፡ ዘዮሐንስ፡ ጳጳስ።
                      </title>
                        <textLang mainLang="gez"/>
                        <incipit>ወሀሎ፡ ፩ብእሲ፡ ዓቢይ፡ ውስተ፡ ሀገር፡ ወልቡ፡ ጸኑዕ፡ በከመ፡ ፈርዖን፡ ወአልቦቱ፡
                        ምሕረት፡ ነዳያን፡ ወኢየአምር፡ ጾመ፡ ወጸሎተ።</incipit>
                        <note>Discourse of Metropolitan John, supposed to be read on
                          <date>12 of Gǝnbot </date> but here placed in the position for <date>12 Ṭǝrr</date>.
                        </note>
                    </msItem>

                    <msItem xml:id="ms_i1.5">
                        <locus from="23r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyOrthodox">ድርሳን፡ ዘደረሰ፡ ርቱዓ፡ ሃይማኖት፡ በእንተ፡ ብፁዕ፡ ወቅዱስ፡
                        <hi rend="rubric">ሚካኤል</hi>፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>፡ አመ፡ ፲ወ፪፡
                        ለወርኃ፡ ታኅሣሥ፡ ዘይትነበብ፡ </title>
                        <textLang mainLang="gez"/>
                        <incipit> መፍትው፡ ለነ፡ ኦአኃውየ፡ ፍቁራን፡ ንዘከር፡ ዕበየ፡ አብ፡ </incipit>
                        <note>A homily of <persName ref="https://betamasaheft.eu/PRS8121RetuaH">Rǝtuʿā Hāymānot</persName>,  more commonly placed for <date> 12 Miyāzyā
                    </date> but here for <date> 12Tāḫśāś.</date>
                        </note>
                    </msItem>


                    <msItem xml:id="ms_i1.6">
                        <locus from="29r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyGenbot">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/> ፡ ድርሳን፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>  ነገር፡ በእንተ፡ ዮሐንስ፡ ጳጳስ፡ ዘኢትዮጵያ፡ ተሠሃለኒ፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/> አመ፡ ፲ወ፪፡ ለግንቦት፡
                      </title>
                        <textLang mainLang="gez"/>
                        <note>The homily about Yoḥannǝs the Metropolitan of <placeName ref="https://betamasaheft.eu/LOC3010Ethiop"> Ethiopia </placeName>
                        who came after <title>ʾabuna</title> Yǝsḥāq, for <date> 12 Gǝnbot</date>.
                        </note>
                    </msItem>

                    <msItem xml:id="ms_i1.7">
                        <locus from="31v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilySane">ድርሳን፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ዘደረሰ፡ ዮሐንስ፡ ጳጳስ፡ ዘአኵሱም፡ ቀደሶሙ፡ ለአብያተ፡ ክርስቲያናት፡ ዘቤተ፡ <hi rend="rubric">ሚካኤል</hi>፡ </title>
                        <textLang mainLang="gez"/>
                        <note>The homily by <persName ref="https://betamasaheft.eu/PRS10382Yohanne">Yoḥānnǝs</persName> the metropolitan of <placeName ref="https://betamasaheft.eu/LOC1310Aksum"> who consecrated
                        the churches of <persName ref="https://betamasaheft.eu/PRS7049Michael">St Michael</persName>.
                      </placeName> ʾAkʷǝsum for <date> 12 Sane.</date>
                        </note>
                    </msItem>


                    <msItem xml:id="ms_i1.8">
                        <locus from="37v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#HomilyPoor">ድርሳን፡ ዘወርኃ፡ ነሐሴ፡ አመ፡ ፲ወ፪፡ ዘያትነበብ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit> ወኮነ፡ እምድኅረ፡ ዝንቱ፡ ነገር፡ ወሀሎ፡ ፩ነዳይ፡ ውስተ፡ ውእቱ፡ ብሔር፡ ወዐቢይ፡ ሃይማኖቱ፡ ወይጸሊ፡
                    </incipit>
                        <note> The homily by an anonymous author for <date>12 Naḥāse</date> that otherwise is placed under
                        <date>12 Yakkātit.</date>
                        </note>
                    </msItem>


                    <msItem xml:id="ms_i1.9">
                        <locus from="41r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#Jerusalem">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ዛቲ፡ መጽሐፍ፡ ዘወፅአት፡ እምኢየሩሳሌም፡</title>
                        <textLang mainLang="gez"/>
                        <note>The beginning is missing.</note>
                    </msItem>

                    <msItem xml:id="ms_i1.10">
                        <locus from="51r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#Maskaram">በስመ፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        ድርሳን፡  <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>አመ፡ ፲ወ፪፡ ለወርኃ፡ መስከረም፡
                        <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>በከመ፡ ገብረ፡ ለተላፊኖስ፡ እስመ፡ ወልደ፡ መበለት፡ ነዳይት፡ ይእቲ፡
                        ወትገብር፡ ተዝካሮ፡ ለ<hi rend="ሚካኤል"/></title>
                        <textLang mainLang="gez"/>
                        <note>The story about <persName ref="https://betamasaheft.eu/PRS11321Talafinos">Talāfinos</persName> who used to make commemoration feast for
                        <persName ref="https://betamasaheft.eu/PRS7049Michael">St Michael</persName>, for <date>12 Maskaram.</date>
                        </note>
                    </msItem>

                    <msItem xml:id="ms_i1.11">
                        <locus from="55r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan#Teqemt">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS9602Turaev"/>
                        አመ፡ ፲ወ፪፡ ለወርኃ፡ ጥቅምት፡<gap reason="omitted" resp="PRS9602Turaev"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <incipit>በዛቲ፡ ዕለት፡ ዕረፍቱ፡ ለቅዱስ፡ በኵር፡ ንጹሕ፡ ብፁዕ፡ መስተጋድል፡ ለፍትወተ፡ ነፍስ፡ ወሥጋ፡ ደማትርዮስ፡ ሊቀ፡ ጳጳሳት፡  ዘለእስክንድርያ፡ ወእማርቆስ፡ ወንገላዊ፡
                          እስከ፡ ደማትርዮስ፡ ሊቀ፡ ጳጳሳት፡ ኮኑ፡ ፲ወ፪፡ ሊቃነ፡ ጳጳሳት።
                       </incipit>
                       <note>The story of the life of <persName ref="https://betamasaheft.eu/PRS3499Demetriu">Damātrǝyos</persName>, the 12th patriarch of the Coptic Church
                        for reading on <date>12 Ṭǝqǝmt.</date>
                        </note>
                    </msItem>

                    <msItem xml:id="ms_i1.12">
                        <locus from="61v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT4155MiraclesMichael">ዜና፡ ተአምራቲሁ፡ ለመልአከ፡ ክቡር፡ ሚካኤል፡ </title>
                        <textLang mainLang="gez"/>
                        <note> 12 miracles of <persName ref="https://betamasaheft.eu/PRS7049Michael">St Michael</persName>
                        </note>
                    </msItem>
                  </msItem>

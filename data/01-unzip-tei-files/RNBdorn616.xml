                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS11323Efrem">Efrem</persName>
                        <date notBefore="1700" notAfter="1799"/>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Regular, careful, by trained hand.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Early 18th cent.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the ruling Kings, Patriarch
                           and Metropolitan; incipits and headings of the texts; directives for the
                           ministers; the word ሃሌ፡ ሉያ፡; some of the musical notation signs above the
                           lines (the rest is black); abbreviations; elements of the punctuation
                           signs; elements of Ethiopic numerals.
 
 The text in fol. 3r and
                           the incipits of most Anaphoras are written alternately in red and black
                           lines.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Texts V-VIII (<locus from="177rb" to="178vb">177rb-178vb</locus>) seem to have been written by a different
                        hand (different
                        hands?).</handNote>
                  </handDesc>

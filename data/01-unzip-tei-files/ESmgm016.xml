                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular.</seg>
                        <seg type="ink">Black (a different hue, <locus target="#32v">32v</locus>),
                           red (faded, hartly visible vermillion on <locus from="1r" to="47v">1r-47v</locus>; sometimes vivid red on <locus from="48r" to="72va">48r-72va</locus>)</seg>
                        Scribe: Tawalda Madḫǝn. Tawalda
                        Madḫǝn is mentioned as the scribe in the colophon.<date>Early 20th
                           cent.</date>
                        <seg type="rubrication">Nomina sacra; name of the protagonists; names of the
                           donor; name of the king and the metropolitan; several groups of lines on
                           the incipit page of Text I, alternating with black lines; incipit of Text
                           II; incipit of every section of Text III; elements of the punctuation
                           signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- Many scribbles and doodles: e.g., fols. 17v, 18r, 20r, 72v.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards (possibly re-used) covered with
                           reddish-brown tooled leather (partly missing).
 Two pairs of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible on the spine fold
                           of the quires, close to the head and the tail of the codex.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornaments on the leather cover (at least
                           4 tools were used: triple line fillet, double circle, dot fillet,
                           x-form).</decoNote>
                     </binding>
                  </bindingDesc>

                <msContents>
                  <summary>
                  </summary>
                  <msItem xml:id="ms_i1">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5826MagicPrayer">Magic Prayer Against Evil Spirits</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡
                    ጸሎት፡ በእንተ፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ዛር፡ ወትግሪዳ፡ ቡዳ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5827MagicPrayer">Magic Prayer Against Evil Spirits</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡
                    ጸሎት፡ በእንተ፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ዛር፡ ወትግሪዳ፡ ቡዳ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <title type="complete" ref="https://betamasaheft.eu/LIT3002RepCh282">Hymn to Jesus Christ</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ዘሠርዓ፡ ጐሐ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5828MagicPrayer">Prayer Against Bleeding</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ቀሀቀሀቀሀቀሀፀርፀርፀቀፀፀፀፀፀፀፀፀፀፀፀፀ፡ በስመ፡
                    አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎተ፡ ሰንካ፡ ሬምሰ፡ ንታም፡ ዘወጽአ፡
                  ደም፡ እምገበከ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i5">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5829MagicPrayer">Prayer to the Divine</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ባሕርየ፡ መለኮት፡ ንጹሕ፡ ደብረ፡ ምጡቅ፡ ደብረ፡ መለኮት፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i6">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5830MagicPrayer">Prayer to Jesus Christ</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በትር፡ ዘዘበጦ፡ ለሰዶን፡ ወስፍ፡ <gap reason="illegible"/> ውእቱ፡ ኢየሱስ፡ ክርስቶስ፡</incipit>
                  </msItem>




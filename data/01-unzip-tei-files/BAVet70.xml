                     <decoNote type="band" xml:id="d1">
                        <locus target="#8v #16v #24v #34v #42v #49r #58r #69r #76r #81r #94r #114r"/>
                        <desc>Simple ornamental bands in black and red ink separate groups of psalms in <ref target="#ms_i1.1"/>.</desc>

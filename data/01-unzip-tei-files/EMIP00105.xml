                  <desc>with musical notation on <locus from="3r" to="16r" facs="005">fols 3r–16r, </locus>, <locus target="#26r #26v" facs="051 052">26r, 26v, </locus>, <locus from="28v" to="29r" facs="056">28v–29r, </locus>,

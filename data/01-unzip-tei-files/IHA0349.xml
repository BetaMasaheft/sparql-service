                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a6_826">
                           <locus target="#Inner lining of the back cover">-Inner lining of the back cover</locus>
                           <q xml:lang="ar">Geometric pattern and multiple frames in re, yellow and blue.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_826">
                           <locus target="#Inner lining of the front cover">-Inner lining of the front cover</locus>
                           <q xml:lang="ar">لا يمسه الا المطهرون \ تنزيل من رب العلمين</q>
                           <desc>Drawings / Decorations</desc>
                           <note>Calligraphic rendition of the text. Multiple frames with decorative elements in red and blue.</note>
                           <note/>
                        </item>
                        <item xml:id="a2_826">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">فائدة الذي رسم بغير الالف من فعل المقاتلة ثمانية اربعة هنا على التوالى وواحد فى ال عمران وهو وقاتلو وواحد فى النساء وهو فلقاتلوكم وواحد فى الحج وهو اذن للذين يقاتلون وواحد فى القتال وهو والذين قاتلو فى سبيل الله</q>
                           <note>Example in 4r (brown/golden ink)</note>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                              <term key="Koran" ana="#Koran"/>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a4_826">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Double circles as ǧuz' markers. Ḥizb and ṯumn markers in red.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a5_826">
                           <locus target="#1v-2r">-1v-2r</locus>
                           <q xml:lang="ar">سورة الفاتحة مكية سبع ايات \ سور البقرة [...]  ايات \ لا يمسه الا المطهرون تنزيل رب العلمين</q>
                           <desc>Drawings / Decorations</desc>
                           <note>Decorative frames in red, green and yellow. Names of the first and second sūra in the top panels. The last text line is in the lower panel on fol. 2r. The lower panel on fol. 1v is torn off.</note>
                           <note/>
                        </item>
                        <item xml:id="a3_826">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Verse markers (three circles), taǧwīd and titles of the sūras in red. </q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_826">
                           <locus target="#Throughout ">-Throughout </locus>
                           <q xml:lang="ar">قرا نافع ان ترك خير اتام</q>
                           <desc>Marginalia</desc>
                           <note>Variant readings (qirā'āt). Example in 3v (red ink)</note>
                           <note>
                              <term key="Koran" ana="#Koran"/>
                           </note>
                        </item>

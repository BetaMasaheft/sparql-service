                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="251v">1v-251v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ

الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ

الرَّحْمَنِ الرَّحِيمِ

مَالِكِ يَوْمِ الدِّينِ

إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ

اهدِنَا الصِّرَاطَ الْمُسْتَقِيمَ

صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلاَ الضَّالِّينَ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#251v">-251v</locus>يَا أَيُّهَا الَّذِينَ آمَنُوا اتَّقُوا اللَّهَ وَلْتَنظُرْ نَفْسٌ مَّا قَدَّمَتْ لِغَدٍ وَاتَّقُوا اللَّهَ إِنَّ اللَّهَ خَبِيرٌ بِمَا تَعْمَلُونَ<note>59:18</note>
                     </explicit>
                     <note>1:1-59:18. The words are not divided. Notes in the margins in red and brown (or golden) ink. Vocalized.  </note>
                     <note/>
                  </msItem>

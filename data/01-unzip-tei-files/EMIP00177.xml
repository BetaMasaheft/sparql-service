                  <additions>
                    <list>
                      <item xml:id="e1">
                      <desc>
                      <locus target="#ir(ecto) #137r #137v" facs="001 139 140">Fols. ir(ecto), 137r, 137v</locus> blank except for scrawls
                      </desc>
                      </item>

               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዚር፡ ጋኔላ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Zir Gānelā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="monastic">በርባራ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Barbārā</t:persName>
             
               
               
          
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">abbess</t:occupation>
               
               
               <t:floruit notBefore="1300" notAfter="1450">
                  <t:persName ref="https://betamasaheft.eu/PRS10733ZirGan">Zir Gānelā</t:persName> 
                  is the name of the patroness of the de luxe illuminated manuscript of the <t:ref type="work" corresp="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</t:ref>
                  which was commissioned for an unnamed monastery where <t:persName ref="https://betamasaheft.eu/PRS10733ZirGan">Zir Gānelā</t:persName> was abbess. 
                  <t:persName ref="https://betamasaheft.eu/PRS10733ZirGan">Zir Gānelā</t:persName> was a member of the royal family who rejected the fleeting world and became a nun. 
                  She entered the monastic life at the middle age, as she had two sons and two daughters. </t:floruit>
            
               
               
            </t:person>  
            
         </t:listPerson>
            
            
         

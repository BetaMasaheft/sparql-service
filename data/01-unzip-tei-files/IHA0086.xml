               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="138v">2v-138v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0030IHA#s49IHA">تحفة المحتاج بشرح المنهاج, From the beginning of
                    kitāb al-ǧirāḥ to the end of kitāb al-aḍḥiya</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>كتاب الجراح جمع جراحة غلبت لانها الكثر طرق الزهوق واعم منها الجنية ولذا اثها غيرع لشمولها القتل بنحو سم او سحر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#138v">-138v</locus>وان سلم ان الكثر العلماء عليه ان العتيرة بفتح العين المهملة وكسر الفوقية ونهى ما تذبح في العشر الاول من رجب والفرع بفتح الفاء والراء وبالعين المهملة ونهي اول نتاج البهيمة تذبح مرجاء بركتها وكثرة نسىلها مند وبتان لان القصد بهما ليس الا اا التقرب الى الله بالتصدق بلحمها على المحتاجين فلا يثبت بهما احكام الاضحية كما هو ظاهر النتهى</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">

               <msContents>
                  <summary>Unsewn folios between two covers</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="9r">1r-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2354IHA">فواتق الفلاح وبوارق الصلاح في ذكر مولد الناطق بالنجاح</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>صلّ وسلم وبارك يا واحد صل وسلم وبارك يا أحـ[د] \ صل وسلم وبارك يا واجد على الأمين الصادق المؤيد \ وهو المبعوث رحمة في الملة منعما مكرما بالخلة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>كان وكان مددا لخلق الله عليك الله سلما احمد يا محمد \ رب صلى على النبي صلاة  لاتحد ولا تعد منّة \ سلم عليه وبارك دائمة عليك الله سلم احمد يا محمد \ واله وصحبه مقيمة والحمد لله تكافي لي نعمة \ تمم لي الخير يا الهي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="9v" to="13v">9v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2965IHA">افضلية مولد خير البرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>بسم الله يا ربي هبلي المغفرة جد لي الرضا في هذه والأخرة \ كن لي كن لي مقدرا للميسرة نعم المولى حتى في الخلد [...] \ الحمد شافيا لضرنا الحمد كاشفا لجهدنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13r">-13r</locus>صلّى عليه سلم عليه بارك عليه واله \ وصحبه أنصاره أمّته نبي نعم يعبد الله لا يكسل \ إرحم يا رب من حضر مجلسنا من غاب عنها ولنا يا ربنا \ أولادنا ووالدينا معنا ألظف بنا حتى ياتينا قبول \ تمت </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="52v" to="57v">52v-57v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <title ref="https://betamasaheft.eu/LIT3079IHA">Poem in ʻaǧamī ʻAfar (19)</title>
                     <incipit xml:lang="ar">
                        <locus target="#52v-53r">-52v-53r</locus>اللهم صلى على محمد وسلم على محمد [۲] \\ الله مِلَعْ يَيْشِيْ كَلَهْ كُلُ كِبْدَا \ أَالرَجِيْمِ حِنِّتِيْ وَاللهْ أَعْدَ اَلْلأَعْدَى \ إشسْتِعَادَ أَكِّوَيْتِيْمِكْ وَيْ مِيَادَا \ أَعُوْذُ بِااللهِ إِتِيْمِكْ شَيْطَانَ كُدَا كِنْكِيْ شَيْطَانْ فَنَلْ يَلِّيْ حِجَابْ عِدَا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57v">-57v</locus>يُلَّوْكُلْ ءُوْبِسْ يْكُرَحْمَتَ يْ كَدَّاكَيْ أَهْلِ ءَصْحَابَل عُلُيْ دَائِمْ فَيْدَا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="57v" to="60r">57v-60r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1716IHA">دعاء بدأت نظمتي بذكر إلهى والحمد والشكر دائما لله</title>
                     <incipit xml:lang="ar">
                        <locus target="#57v-58r">-57v-58r</locus>اللهم صلي على محمد أللهم \ صلي على محمد وءله وصحبه  \ بدءت نظمتي بدكر إلاهي \ والحمد وشكر دائما لله \ ثم صلاة الله والسلامة \ على الرسول الله خير خلقه \ إسمعوا مقالي لا تنظر وحالي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60r">-60r</locus>ثم الصلاة الله على حبيبه \ عدد اخلقه ووزن عرسه \ وعلئ له كذا أصحابه أختمنا ربّنا حخاتمه \ تمت وبالخير عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="60v" to="63v">60v-63v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <title ref="https://betamasaheft.eu/LIT1732IHA">Poem in ʻaǧamī ʻAfar (20)</title>
                     <incipit xml:lang="ar">
                        <locus target="#60v">-60v</locus>يَلِّيْ وَارَمْ سَلَامْ عَلَيْكَ \ نَبْيُ نُوْرُ سَلَامَ عَلَيْكَ \ بِسْمِ الله يَلِّه مِكَعْنِيْ \ جَالِيْلِنَّيْ نِوَالْ كَابَنِّيْ \ بِسْمِ اللهِ هِكْ بِيْنِيْ كْوَانِيْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#63v">-63v</locus>طَهَ يَسِنْ صَلَّ اللهُ عَلَيْكَ \ عَدَدْ مَلِيْ كُبَا كِيْ دَكَا \ شُنَّهْ كُوْ أَهْلِلْ ءُوْبِسَّامْ فَنِّيْ \ نِهْ سَرِّ لِمْ كُرَبِّلْ حَبْنِيْ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="64r" to="68r">64r-68r</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1731IHA">Poem in ʻaǧamī ʻAfar (11)</title>
                     <incipit xml:lang="ar">
                        <locus target="#64r">-64r</locus>يَلَّا يُبْلِيْ كَيِّبْ يُوْبِيْ \ أَحْمَدْ مُحَمَّدْ نِيْمِنِيْ \ ابِسْمِ اللهِ وَبِا اللهِ أَجَلُّ حَمْدُ للهِ \ أَرْحَمُ الخَلْقِ بِااللهِ أحمد محمد نيمي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68r">-68r</locus>رَبِىُ بَارِكْ عَلَيْهِمْ وَسَمِعْنَا بِهِمْ بِهِمْ \ وَاَكْرِمْنَاا بِسِرِهِمْ أَحْمَدْ مُحِمَّدْ مُحَمَّدْ تمّت \ أللهَنَا لَكُمْ هَنَا يَعَاشِقِيْ ن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="68r" to="68v">68r-68v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1719IHA">صلاة على النبي ألهنا لكم هناء يا عاشقيني</title>
                     <incipit xml:lang="ar">
                        <locus target="#68r">-68r</locus>صلو على خير العباد أالمصطفى كنز الرشادا \ شفيعنايوم المعادا لتبلغو نيل المرادا \ من رحمة الله الودود أبد لنا نور الوجود</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68v">-68v</locus>تُبْ وَاعْتَرِفْ وَرْجُو الكِوَامْ ٬ وَلُذْ بِمَنْ حَلَّ الحَرَامْ \ وَنُوْرُهُ عَمَّ البِلَادْ ٬ تمت وبالخير عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="14r" to="14v">14r-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT2966IHA">نظم الحمد لله ذي الجلال والاكرام والمنة</title>
                     <incipit xml:lang="ar">
                        <locus target="#14r">-14r</locus>بسملة \ الحمد لله ذي الجلال والاكرام والمنة \ والانعام الخالق المصور في الأرحام يعلم \ خائنة الأعين وما تخفي الصدور أول \ بلا ابتدا أخر بلا انتها حي قديم رحمان \ رحيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14v">-14v</locus>والناهين عن المنكر سبحنك \ ما اكرمك ربنا عليك توكلنا واليك أنبنا وإليك\ المصيرولا حول ولا قوة الا بالله العلي العظيم \ لا إله إلا الله تجلّى النور</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="15r" to="16v">15r-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1710IHA">دعاء الله بسم الله يا كافي يا شافي</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>الله بسم الله يا كافي الله بسم الله يا شافي ربي ملاذي معافي حقا قوي متين \ الحمد لله عمدني الحمد لله عدتي الحمد لله رقدتي حي قيوم نومن \ ربي صلى صلاتك علي احمد من نورك شفيع مشفع عندك غدات الخشر نامن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus>بالعشرة المبشرة بالجنة المعطر وبالزهر المنورا فيهم سنا لا يوزن  \ حسن الخير والحسين والمحسن والمحي الدين بهم ارحمنا ربنا وكن \ لنا مكون ذيان</explicit>
                     <note>Disrupted</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="17r" to="20v">17r-20v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT1710IHA">دعاء الله بسم الله يا كافي يا شافي</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>الله بسم الله يا كافي الله بسم الله يا شافي ربي ملاذي معافي حـ[قا] \ قوي متين الحمد لله عمدتي الحمد لله عدّتي الحمد لله رفدتي \ حي قيوم نومن ربي صلي صلاتك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20v">-20v</locus>لله الشكر ربّنا نور يا ربّ قلبنا نور يا ربّ قبرنا \ أصلح يا ربّ شئتا أسعدنا في المقادر \ رسول الله المومن حبيب الله الموقن صلى وسلم \ وبارك عليه مهيمن</explicit>
                     <note>Disrupted</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="21r" to="21v">21r-21v</locus>
                     <title ref="https://betamasaheft.eu/LIT3028IHA">دعاء يا رجاء الله يا أهل البيت</title>
                     <incipit xml:lang="ar">بسملة٬ حمدلة \ يا رجا لله يا أهل البيت قوم نشفعو \ لنا إلا لله \ ببسم الله والحمد لله والشكر لله أهل \ كشف لله أهل</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="32r" to="36v">32r-36v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2729IHA">منظومة بسم الله يا رب يا كريم يا حي يا عظيم</title>
                     <incipit xml:lang="ar">
                        <locus target="#32v">-32v</locus>بسم الله بسم الله يا رب يا كريم \ بسم الله بسم الله يا حي يا عظيم \ ملك يوم الدين قرّبنا بالنعيم \ يا الله يا ربّ يا رحمان يا رحيم كن لي معزًّا بالرضا وبالهنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#36r">-36r</locus>وكن لنا مهيمنا بمذكور  وعبدك بتقي وحيي بمقتف \ ونقي بوافيّ وجواد بحريص وغني أبطحي تهامي \ بفصيح بعليم باول واخر بباطن وظاهر بخاتم و \ شفيع باإمام ومجتبا بمناد حبيبك بأمي حجار بي بمبين \ ومنيب بصاحب وقاسم الهي من نظم هذا  فارحم له \ الهي من ألف هذا فاغفر له حيث ما كان يا ربنا فكن \ له مع كل مسلم ومؤمن علمته على النبي والأل صلى \ مولانا علي النبي والصحب سلم عليه وأرضه الحمد لله \ </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="39r" to="43v">39r-43v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3067IHA">دعاء بالعفرية بسم الله يا ربي ظاهر باطن</title>
                     <incipit xml:lang="ar">
                        <locus target="#39r">-39r</locus>بسم الله الرحمان الرحيم الله بسم الله يا الله \ ببسم الله يا ربي ظاهر باطن نك يمعي \ أغفرنه ذنبي يا ربي كويل كوداعي \ صلى وسلم عليه وعلى الأل يا واسع</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43r">-43r</locus>خير كل ني ذو دي شر \ ذا شامله منع لا بدنه يكي \ كال نه كغر كافر بكي لي كنيع</explicit>
                     <note>f. 43v blank</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="44r" to="44v">44r-44v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3069IHA">Poem in ʻaǧamī ʻAfar (7)</title>
                     <incipit xml:lang="ar">
                        <locus target="#44v">-44v</locus>بسم الله الرحمان الرحيم \ يَلَّوْنَوْكُوْ كَبَّانِيْنَيْ كِيْ أَصْحَابَانه تي لي \ بِاسْمِ الله افَنَّامَا نِيَكْ مَرْحَاتَمَا مَا به ثي لي \ نِكَّلْ قَلْبِيْ حَجَابَا كُيْتَوْ نَرْحِمْ نِيَبَا نه تي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#44r">-44r</locus>كِنْ حُرْمَتْكِيْ كَرَامَانَحُوْسِرِّكْمِرَا مَان \ نِهْ كُوْرِيْ كِنْ أسْرَارَا نِيْ كَرَسْ كِيْنِلْ بِيْرَا \ تمت وبالخير عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="45r" to="52v">45r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3077IHA">صلاة على النبي عصفره طيب ونسله طاهر</title>
                     <incipit xml:lang="ar">
                        <locus target="#45v">-45v</locus> نبي سلام على النبي سلام على رسول سلام على صلا[...] لله عليه [كذا]ا \ عفصره [عصفره؟] طيب ونسله طاهر \ ليس به كدر صلاة الله عليه \ ونوره سبقت قبل الأشيا كلها \ ألاف ءل بع سنين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>نبي دين فاكي باطل دين دو \ كي كادسه ييركي الموي بير \ حاحي وقد كتبه شيخ لباك</explicit>
                     <note>f. 45r blank </note>
                     <note/>
                  </msItem>

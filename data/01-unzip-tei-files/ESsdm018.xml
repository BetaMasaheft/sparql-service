                  <additions>
                     <list>
                        <item xml:id="a1"><locus target="#45r">fol.  45r</locus><desc>A prayer taken from the Anaphora of Our Lord Jesus Christ (Qǝddase ʾƎgziʿ), crudely written</desc></item> <item xml:id="a2"><locus target="#45v">fol.  45v</locus><desc> An extract from a prayer of exorcism</desc></item> <item xml:id="a3"><locus target="#46v">fol.  46v</locus><desc>A note on the computus</desc></item> <item xml:id="e1"><desc>Pen trial: fols. 46r, 47v, 49v.</desc></item>
                     </list>

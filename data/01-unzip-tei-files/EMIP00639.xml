                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.5"><locus from="35r" to="35v" facs="039">Fols 35r–35v</locus><title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat Prayer of the Archangel Saquel</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.6"><locus from="36r" to="36v" facs="040">Fols 36r–36v</locus><title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat Prayer of the Archangel Fanuel</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>

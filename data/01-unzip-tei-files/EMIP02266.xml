                  <list>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001"/>
                    several words written in blue pencil or crayon by an untrained hand
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#9v" facs="011"/>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#19v" facs="021"/>
                    pentrials and the Trinitarian formula in a crude hand
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc type="GuestText">
                    <locus target="#20r" facs="021"/>
                    Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT3100RepCh380">Malkǝʾa Giyorgis</title>. Written in a different hand
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#31r #31v" facs="032 033"/>
                    pentrials
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#31v" facs="033"> f. 31v, top</locus>
                    note in an untrained hand, largely illegible due to damage
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#31v" facs="033"> f. 31v, bottom</locus>
                    title of the work “Image of Mary, Mälkǝʾä Maryam, <foreign xml:lang="gez">መልክአ፡ ማርያም፡</foreign>,” written in purple ink
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <desc>
                      words of text are written interlinearly (<locus target="#2r #2v #5r #7v #8v" facs="003 004 006 009 010"/>, etc.);
                      text has been removed (  <locus target="#22r" facs="023"/>)
                    </desc>
                    </item>

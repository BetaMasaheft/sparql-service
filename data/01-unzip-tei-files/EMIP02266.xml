                  <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName>, with notice of two women offering prayers to him</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#9r" facs="010"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/>, flanked by lions and leopards</desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#10v" facs="012"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with the archangels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName>, with a patron prostrate below</desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#19r" facs="020"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John on either side of the <term key="cross" ana="#cross"/> and a prostrate patron, Wälättä Zämuse (<foreign xml:lang="gez">ወለተ፡ ዘሙሴ፡</foreign>), clings to the base of the cross</desc></decoNote>
                  <decoNote type="miniature" xml:id="d5"><locus target="#20v" facs="022"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>

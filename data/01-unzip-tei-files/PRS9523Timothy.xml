      <t:body>
         <t:listPerson>
            <t:person sex="1">
       
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ጢሞቴዎስ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n1" type="normalized">Timothy III</t:persName>
                  <t:persName xml:lang="en" xml:id="n2" type="alt">Ailourous</t:persName>
                  <t:persName>
                  <t:roleName type="title">patriarch</t:roleName>
               </t:persName>
                  
                  <t:occupation type="ecclesiastic">patriarch</t:occupation>
                  
            
                  <t:floruit notBefore="0457" notAfter="0477">He was an anti-Chalcedonian patriarch of <t:placeName ref="https://betamasaheft.eu/LOC1338Alexan">Alexandria</t:placeName>. 
                     He was a monk in the monastery of <t:placeName ref="https://betamasaheft.eu/LOC5153Qalamu">Qalamūn</t:placeName>, 
                     who was brought by force to <t:placeName ref="https://betamasaheft.eu/LOC1338Alexan">Alexandria</t:placeName> and consecrated presbyter during the pontificate 
                     of patriarch <t:persName ref="https://betamasaheft.eu/PRS3255CyrilI">Cyril I (of Alexandria)</t:persName>. Some of his works were translated into Gǝʿǝz. </t:floruit>
                  <t:death when="0477"/>
                  
            </t:person>
            
            
         </t:listPerson>
         
         
         

                      <incipit>
                        <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ ትርጓሜ፡ መልእክታቲሁ፡ ለጳውሎስ፡ ረድኤተ፡ ጸሎቱ፡ የሃሉ፡ ምስሌነ፡ ለዓለመ፡ ዓለም፡ አሜን። መልእክት፡ ቀዳማዊ፡ ኀበ፡ ሰብአ፡ ቆሮንቶስ፡ </foreign>
                        <foreign xml:lang="am">ሁለተኛ፡ ይጽፋልና፡ ቀዳማዊ፡ አለ፡ በመላዋ፡ አካደያ፡ ትባላለች፡ ቆሮንቶስ፡ መዲናይቱ፡ ናት፡ በመቄዶንያ፡ ፊልጵስዩስ፡ እንዳለች፡ <gap reason="omitted"/></foreign>
                      </incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.2.2">
                      <locus from="97r" to="174r" facs="107">Fols 97r–174r</locus>
                      <title>Text and Commentary on 1 Corinthians</title>
                      <textLang mainLang="am" otherLangs="gez">Gǝʿǝz and Amharic</textLang>
                      <incipit xml:lang="am">በፈቃደ፡ እግዚአብሔር፡ ጸንቺ፡ ብገኝ፡ ሰውን፡ በፈቃደ፡ እግዚአብሔር፡ አጸና፡ ዘንድ፡ ኢየሱስ፡ ክርስቶስ፡
                        ከሾመኝ፡ ከኔ፡ ከጳውሎስ፡ እሱ፡ ሿሚ፡ እኔ፡ ተሿሚ፡ ምን፡ አገናኝቶን፡ ከሱ፡ ታነጻጽሩናላችሁ፡ ለማለት፡ እንዲህ፡ አለ፡ ከወንድማችን፡
                        ከሶስቴንስ፡ የተላከ፡ በጽሕፈት፡ በድርሰት፡ አግዞት፡ አይደለም፡ ስለ፡ ትሕትና፡ ያነሳዋል፡ እንጂ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                    </msItem>

                  <msItem xml:id="ms_i1.3">

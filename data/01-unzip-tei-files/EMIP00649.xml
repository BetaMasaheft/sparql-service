                    <incipit>
                      <foreign xml:lang="gez">መልእክት፡ ኀበ፡ ሰብአ፡ ኤፌሶን፡ ኤፌሶን፡ ምድረ፡ ጽርዕ፡ </foreign>
                      <foreign xml:lang="am">ናት፡ ቁጽሯም፡ ከ፯፡ ዮናናውያን፡ ነው ፤ ቅዱስ፡ ጳውሎስ፡ ከዚህ፡ ገብቶ፡ ጌታ፡ ያደረገውን፡
                        ተአምራት፡ ያስተማረውን፡ ትምህት፡ ያሰራውን፡ ግምባር፡ ትሩፋት፡ አስተማራቸው፡ ከአምልኮተ፡ ጣዖት፡ ወደ፡ አምልኮተ፡
                        እግዚአብሔር፡ ከገቢረ፡ ኃጢአት፡ ወደ፡ ገቢረ ጽድቅ፡ ተመለሱ፡ አመኑ፡ ተጠመቁ፡ <gap reason="omitted"/></foreign>
                      </incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.5.2">
                      <locus from="233r" to="251v" facs="243">Fols 233r–251v</locus>
                      <title>Text and Commentary on Ephesians</title>

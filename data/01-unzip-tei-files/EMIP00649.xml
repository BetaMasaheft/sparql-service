                        </incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.3.2">
                        <locus from="174v" to="212r" facs="185">Fols 174v–212r</locus>
                        <title>Text and Commentary on 2 Corinthians</title>
                        <textLang mainLang="am" otherLangs="gez">Gǝʿǝz and Amharic</textLang>
                        <incipit>
                          <foreign xml:lang="am">ቸር፡ አላችሁ፤ የጌታችን፡ የኢየሱስ፡ ክርስቶስ፡ ጸጋው፡ ይደረግላችሁ፡ የፍጹም፡ ተስፋው፡ ባለቤት፡ ልጅ፡

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title>Prayers against vaginal haemmorrhage</title>
                            <note>Written on the first page of the recto.</note>
                            <msItem xml:id="ms_i1.1">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7263PPHaem">Prayer against vaginal haemorrhage</title>
                                <incipit xml:lang="gez">ጨራታኤል፡ በርናኤል፡ ከኩሳኤል፡</incipit>
                                <explicit xml:lang="gez">ክትር፡ ደመ፡ ዓመትከ፡ እገሊት።</explicit>
                                <textLang mainLang="gez"/>                                
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7264PPHaemorrhage">Prayer against vaginal haemorrhage</title>
                                <incipit xml:lang="gez">ሰየሃሃ፡ ቅቅ፡ ሶቤሃ፡ ላሃ፡ <gap reason="ellipsis"/> ከማሁ፡ አርግዕ፡ ደመ፡ ዓመትከ፡ 
                                    <expan>እገ<abbr/><ex>ሊት</ex></expan>፡ ለዝንቱ፡ ደም፡ እስከ፡ የዓርግ፡</incipit>
                                <textLang mainLang="gez"/>                                
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7277PrDiseases">Anathema against the diseases of Bāryā, the evil eye, chest pain,
                                mǝtʿat, ṣǝfʿat, rheumatism, mǝč, Magāññā, contagion, fever, talāwāš, Legewon, Dask, and the eye of the shadow</title>
                            <note>Written on the second page of the recto.</note>
                            <note>Containing <term key="MagicSymbols" ana="#MagicSymbols">magic glyphs (charaktêres)</term> in the incipit.</note>
                            <incipit xml:lang="gez"><gap reason="ellipsis"/> ከማሁ፡ አጽርእ፡ ሕማመ፡ ባርያ፡ ወዓይነት፡ ወውግዓት፡ ወምትዓት፡ ወጽፍዓት፡ 
                                ወቍርጥማት፡ ምች፡ መጋኛ፡ ወንዳድ፡ ወተላዋሽ፡ ወሌጌዎን፡ ደስክ፡ ወዓይነ፡ ጽላ፡ አውገዝ፡ ኩክሙ፡ እምላዕለ፡ ዓመትከ፡ 
                                <expan><abbr>እገ</abbr><ex>ሊት</ex></expan>፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7278AmhPrescription">Prescription in Amharic</title>
                            <note>Written on the second page of the recto.</note>
                            <incipit xml:lang="am">ጤና፡ አዳም፡ ቅጸል፡ ጸሌንጅ፡ ቅጸል፡</incipit>
                            <textLang mainLang="am"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7282ColicPleurisy">Prayer and prescription against colic and
          pleurisy</title>
                            <note>Written on the third page of the recto.</note>
                            <incipit xml:lang="gez">ጋኔን፡ ጋኔን፡ አውዬን፡ አውዬን፡ በዝንቱ፡ አስማቲከ፡ አድኅኖ፡ 
                                እመኳንንተ፡ ጽል<choice><sic>ማ</sic><corr>መ</corr></choice>ት፡ ወእምእለ፡ ይነከንኩ፡ ነፍስ፡ ወሥጋ፡</incipit>
                            <explicit xml:lang="gez">፯ ጊዜ፡ ድግም፡ በማተብ፡ ወበማይ፡ ለሆድ፡ ቍርፀት፡ ወለጉሥምት፡</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7283PrBirth">Prayer for a successful delivery</title>
                            <note>Written on the fourth page of the recto.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ወሊድ፡ ቤሃ፡ ፯ ጊዜ። ለልሃ፡ ፯ ጊዜ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4274AkkonuB#Stanza31">ʾAkko-nu bǝʾsi: Stanza 31, referring to</title>
                            <note>31st stanza of <ref type="work" corresp="https://betamasaheft.eu/LIT4274AkkonuB#Stanza31">ʾAkko-nu bǝʾsi: Stanza 31, referring to</ref> being a prayer for a pregnant woman.
                               The text is written on the fifth page of the recto.</note>
                            <incipit xml:lang="gez">ለብእሲት፡ ፅንስት፡ ወልድ፡ ወሐሪስ። ማዕከለ፡ ሞገድ፡ መፍርህ፡ ዘከደንኪያ፡ በልብስ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7284PPBirth">Ṣalot baʾǝnta ḥǝmāma walid</title>
                            <note>Written on the fifth to seventh page of the recto.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/>ጸሎት፡ በእንተ፡ ሕማመ፡ ወሊድ፡ ቁርቃር፡ ፯ ጊዜ፡ በል።<pb/><gap reason="ellipsis"/> 
                                ፍታሕ፡ ማኅፀና፡ ለልጁ፡ ወለእንግዴ፡ ልጅ፡ ለዓመትከ፡ እገሊት፡ በስሙ፡ ለአብ፡</incipit>
                            <explicit xml:lang="gez">አርግዕ፡ ደማ፡ ለ<pb/>ዓመትከ፡ እገሊት።</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7300PrPhanuel">Salām la-lǝssānǝka za-ʾi-yǝṣarrǝʿ sǝbḥatāta</title>
                            <note>Written on the seventh page of the recto.</note>
                            <incipit xml:lang="gez">ሰላም፡ ለልሳንከ፡ ዘኢጸርዕ፡ ስብሐታተ።</incipit>
                            <explicit xml:lang="gez">ኦአምላከ፡ ፋኑኤል፡ ፈውሳ፡ እምሕማመ፡ ወሊድ፡ ለዓመትከ፡ እገሊት። 
                                <add place="unspecified">በማይ፡ ድ<choice><sic>ግ</sic><corr>ገ</corr></choice>ም፡ አስትያ።</add></explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7280PresBirthAmh">Prescription for a smooth birth in Amharic</title>
                            <note>Written on the second page of the verso.</note>
                            <incipit xml:lang="gez">ቶሎ፡ ለማይ፡ ሂድ፡ ልጅ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i10">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7281PresCataractAmh">Prescription against cataract in Amharic</title>
                            <note>Written on the third to seventh page of the verso.</note>
                            <incipit xml:lang="gez">ዓይኑ፡ ለጣለበት፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ጊዮርጊስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Giyorgis</t:persName>
             
               <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
               <t:occupation type="ecclesiastic">metropolitan</t:occupation>
               <t:nationality type="Egypt"/>
               <t:faith type="Coptic"/>
             
               <t:floruit when="1102">He was a metropolitan of the Ethiopian Orthodox Church who succeeded 
                   
                  <t:persName ref="https://betamasaheft.eu/PRS8588Sawiros">
                     <t:roleName type="title">ʾabuna</t:roleName> Sāwiros</t:persName> 
                  in <t:date>1102</t:date>. However, as soon as he reached 
                  <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> his behaviour caused him to be arrested by 
                  the king of <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> by his infamous affairs and vile deeds.
                  Then, he was sent back to <t:placeName ref="https://www.wikidata.org/entity/Q79">Egypt</t:placeName>.
                  He was succeeded by ʾabuna <t:persName ref="https://betamasaheft.eu/PRS7072Mikael">Mikāʾel [I]</t:persName>
               </t:floruit>
       
            </t:person>
            
         </t:listPerson>
         

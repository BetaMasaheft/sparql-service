                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="MagicText"/>
                          <locus target="#1r"/>
                           <q xml:lang="gez">ቃል፡ ዘኮነ፡ ኃበ፡ ኖኅ፡
                              <gap reason="ellipsis"/>
                           </q>
                           <q xml:lang="en"> Word that came to Noah </q>
                           <note>The text is half-erased.</note>
                        </item>


                        <item xml:id="a2">
                           <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT3012RepCh292">Bǝḍǝʿt ʾanti</title>
                           </desc>
                             <locus target="#1r"/>
                           <q xml:lang="gez">ብፅጽዕት፡ አንቲ፡ ወንግሥተ፡ ጽድቅ፡
                              ዘትመነኒ፡ ማርያም፡ መንበረ፡ ስላቅ፡
                              ታቦትነ፡ አንቲ፡ እንተ፡ ወርቅ።ሃ።
                              <gap reason="ellipsis"/>
                           </q>
                           <note>The text is composed of 50 strophes separated by hallelujatic refrain.</note>
                           <q xml:lang="en"/>
                        </item>

                           <item xml:id="a3">
                              <desc type="GuestText">
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT2861RepCh142">Malkǝʾ-hymn to Jesus Christ</title>
                           </desc>
                              <locus target="#3v #71v"/>
                              <q xml:lang="gez">
                              <hi rend="rubric">ሰላም፡</hi>ለዝክረ፡ ስምከ፡ ዘሀሎ፡ ወይሄሉ፡ ለትውልድ፡ ኵሉ፡</q>

                              <note>The end of the text is on the last folium. The text contains 29 strophes, probably incomplete. </note>
                              <q xml:lang="en">Hail to the mention of your name that exist and will exist for all generations.</q>
                             </item>

                        <item xml:id="a4">
                           <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT4517Prayer">Ṣalota manfaqa lelit</title>
                           </desc>
                           <locus target="#3v #71v"/>
                           <q xml:lang="gez">በጸሎታ፡ ወበስእለታ፡ ለእግዚእትነ፡ <hi rend="rubric">ማርያም፡</hi>
                              <gap reason="ellipsis"/>
                           </q>
                           <note>The cataloguer indicates that the translation of the excerpt is printed in <bibl corresp="http://zotero.org/groups/358366/items/9DY6MRK7"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Turaev1901Nochnoe"/><title level="a">Nočnoe bogosluzenie Efiopskoj cerkvi po rukopisi No. 143 Arheologičeskago Muzeja pri Kievskoj Duhovnoj Akademii</title><title level="j">Trudy Kievskoy Duhovnoy Akademii</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Boris</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Turaev</t:surname></author><date>1901</date><biblScope unit="issue">3</biblScope><biblScope unit="page">1-36</biblScope><note type="url">http://books.e-heritage.ru/book/10079178</note></bibl>
                           </note>
                           <q xml:lang="en"/>
                        </item>


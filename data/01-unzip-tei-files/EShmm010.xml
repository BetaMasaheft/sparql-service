                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine</seg>
                        <seg type="ink">Black; red (luminous vivid red)</seg>
                        <date>19th century</date>
                        <seg type="rubrication">Nomina sacra; three pairs of lines on the incipit
                           page of Text I alternating with black lines; the initial line in the
                           beginnings of sections of Text I and II; two initial lines on the incipit
                           page of Text II; corrections written interlineally (e.g., fols. 12v, 18r,
                           37v); elements of the punctuation signs; the word kǝfǝl “Part”; elements
                           of Ethiopic numerals; some other words, e.g., wängel “Gospel” (fols. 15v,
                           17v, 30r), ʾorit, “Pentateuch” (fols. 25r, 48v), dǝrsān “Homily” (fol.
                           66v), liqawǝnt “Scholars”(fol. 120v).</seg>
                     </handNote>
                  </handDesc>

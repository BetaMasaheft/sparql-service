                     <origDate notBefore="1400" notAfter="1500">15th cent. (?)</origDate>
                        <origDate notBefore="1500" notAfter="1600">The text was added later (16th
                        cent. ?)</origDate>
                  </origin>
                  <provenance>The name of Yoḥannǝs is written in the supplication formulas of Text
                     II-1.</provenance>
               </history>

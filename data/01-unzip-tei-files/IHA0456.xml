               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="80v">1r-80v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0111IHA">موصل الطلاب الى قواعد الاعراب</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>عِشَاءً بَيْكونَ فجملة بيكون من الفعل والفاعل في محلّ نصبٍ على الحالِ من الواو وعشاءً منصوب على الظرفية</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#80v">-80v</locus>فنسألُ الله التوفيق والهداية إلى أقوم طريق الخير بمنّه وكرمه كما فعل في أوّل الكتاب حيث ومن الله أستمدّ التوفيق والهداية الى اقوم طريق بمنّه وكرمه</explicit>
                     <note>Ff. 1-8 only fragments of the spine of the quire still attached to the rest of the book block. Ff. 9r-80v page page number visible on the upper margin (pp. ۱۶-۱۶۲).</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="81r" to="107v">81r-107v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0914IHA">فوائد جليلة في قوائد الإعراب</title>
                     <incipit xml:lang="ar">
                        <locus target="#81v">-81v</locus>بسملة, اما بعد ... فهاذه فوائد جليلة في قوائد الإعراب تقتفي بمتأمّلها جادّة الصواب وتطلِّعه في الأمد القصير على نكتٍ كثيرٍ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#107v">-107v</locus>لكن اجتناب هاذه العبارة قي التنزيل واجب وفي هاذا القدر كفاية لمن تأمّله والله الموفق والهادي الى سبيل الخيرات بمنّه وكرمه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="110r" to="286v">110r-286v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0179IHA">مجيب النداء في شرح قطر الندى</title>
                     <incipit xml:lang="ar">
                        <locus target="#110r">-110r</locus>بسملة, الحمد لله الرافع من الخفض ولعزه وسلطانه المفيض على من نحاه الخ... اما بعد شرح لطيف وضعته على المقدمة الموضوعة في علم العربية المسماة بقطر الندا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#286r-v">-286r-v</locus>ان اشكر نعمتك التي انعمت عليّ وعلى والديّ وان اعمل صالحا ترضاه وادخلني برحمتك في عبادك الصالحين والحمد لله رب العالمين</explicit>
                     <note>ff. 110v-270r, page numbers on the upper margin ۱-۳۲۵</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="295r" to="295r">295r-295r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0873IHA">نظم الجود من افضل الطاعات في القرب</title>
                     <incipit xml:lang="ar">
                        <locus target="#295r">-295r</locus>الجود من أفضل الطاعات في القرب بذاك قد قال اهل العلم والكتب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#295r">-295r</locus>وما معونته إلّا بجودكم فخذ وسلم فظنّي فيك لم تخب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="297r" to="297r">297r-297r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0875IHA">بيت عن زوجات النبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#297r">-297r</locus>خليلي سبا عقلي حلي زين هالة \ زها جفنها رمزا صحيحا مهذبا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#297r">-297r</locus>ميمونة بنت الحارث الهلالية العامرية وكانت قبله تحت ابي رهم العامري وهي خالة بن عباس وخالد بن الوليد هـ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="307r" to="307r">307r-307r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0854IHA">قصيدة معط اخا كرم</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="307r" to="307r">307r-307r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0856IHA">قصيدة طلبوا الذي نالوا وما حرموا</title>
                     <incipit xml:lang="ar">
                        <locus target="#307r">-307r</locus>وله ايضا بالكلمة المستوى مدخا والمقلوب ذمّا \ طلبوا الذي نالوا فما حرموا ٬ رفعت فما حُطّت لهم رتب
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#307r">-307r</locus>عصب لهم نصرت فما خذلو ٬ شَرُفوا فما يدنوا لهم حسب</explicit>
                     <note>Cf. AAIE00304, f. 7r</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="300v" to="305r">300v-305r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0918IHA">خاتمة في المساحة</title>
                     <incipit xml:lang="ar">
                        <locus target="#300v">-300v</locus>خاتمة المساحة اعلم ان الممسوح اما ان يكون مربعا او مثلثا او مدورا او مقوسا فان كان مربعا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#305r">-305r</locus>وهو مساحة المدورة الاصلية  وليكن هذا \ اخرما اردناه فاسل لله تعالى ان ينفع به الطا \ لبين ويختم لنا ولهم خاتمة الخير بجاه سيّد \ المرسلين فانه اكرم الاكرمين امين امين امين</explicit>
                     <note/>
                     <note/>
                  </msItem>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black; red; vinous.</seg>
                        <date>Late 19th - first half of the 20th century.</date>
                        <seg type="rubrication">Nomina sacra; name of the tabot to which the Ms. was
                           donated; incipits of the sections; directives to the ministers
                           (occasionally partially rubricated); elements of the punctuation signs
                           and Ethiopic numerals.
 
 A few groups of lines (alternating with
                           black lines) on the incipit page.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The Ms. was apparently written by
                        several hands; delimitation of text portions written in each hand appears
                        difficult.</handNote>
                  </handDesc>
                  <decoDesc>

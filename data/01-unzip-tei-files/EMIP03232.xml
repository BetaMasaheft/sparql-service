                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is not rubricated</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#164v #186v #187r" facs="165 187">Fols. 164v, 186v, 187r</locus>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT2889RepCh170">Malkǝʾa
                                                  sanbat</title>, written in a smaller hand
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#70r" facs="070">Fol. 70r</locus>
                    <desc>
                    The scribe does not mark the midpoint of the Psalms
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps118">Psalms of
                                                  David, Psalmus 118</title> employs the new, simple system. <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps151">Psalms of
                                                  David, Psalmus 151</title> has only the first of the four plusses that make up the long version
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    The fourth biblical canticle is Prayer of Hana, mother of Samuel, prophet
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title> are laid out beginning on Monday and culminating on Sunday
                    </desc>
                    </item>
                  </list>
                </additions>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መዝራእተ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Mazrāʾǝta Krǝstos</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">መዝራተ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Mazrāta</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">ኮርኖ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Korno</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">abbot</t:occupation>
               <t:birth when="1613"/>
               <t:floruit notBefore="1600" notAfter="1699">He was a monk 
                  during the contemporary of  
                  <t:persName ref="https://betamasaheft.eu/PRS4015Fasilada">
                     <t:roleName type="title">ʾaṣe</t:roleName>Fāsiladas</t:persName> 
                  and credited with  the foundation of 
                  the monastery bearing his name in the district of <t:placeName ref="https://betamasaheft.eu/LOC1292Ahsaa">ʾAhsaʾa</t:placeName>.
                In his youth time, he was frequently in the court of 
                  <t:persName ref="https://betamasaheft.eu/PRS4015Fasilada">
                     <t:roleName type="title">ʾaṣe</t:roleName>Fāsiladas</t:persName>, 
                  where the king offered him his daughter. However, he chose to take  a monastic habit from 
                  <t:persName ref="https://betamasaheft.eu/PRS8751senaKre">Śǝna Krǝstos</t:persName>. As a result, he was much disliked by his relative and he then settled in 
                  <t:placeName ref="https://betamasaheft.eu/LOC6171Waldeb">Wāldǝbbā</t:placeName> from where he made various sancturies. He is reported to have converted pagans at lake 
                  <t:placeName ref="https://betamasaheft.eu/LOC1017AbbaNa">ʾAbbā Nāza</t:placeName>.</t:floruit>             
               <t:death when="1706"> He died at the age of 93. </t:death>
            </t:person>
            
         </t:listPerson>
         

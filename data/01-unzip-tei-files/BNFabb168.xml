                    <msContents>
                      <msItem xml:id="ms_i1">
                        <locus from="1ra" to="105va"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme">Miracles of Jesus (42 stories)</title>
                         <textLang mainLang="gez"/>
                         <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ። ተአምር፡</hi>
                         ዘገብረ፡ እግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶ<hi rend="rubric">ስ፡
                         በረከተ፡ ጸጋሁ፡ የሀሉ፡ ምስለ፡ ገብ</hi><add place="above">ሩ፡ ወልደ፡ ዋህድ፡</add>
                         <hi rend="rubric">ወአቡሁ፡</hi><add place="above"><gap reason="illegible" unit="chars" quantity="3"/>ሚካኤል፡ ወእሙ፡ <gap reason="illegible" unit="chars" quantity="5"/></add>
                          ዘለዓለም፡ ዓሜን፨
                         ዘንቱ፡ ምሥጢር፡ አምላካዊ፡ ዘነገሮ፡ እግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ለረድኡ፡
                         ወሐዋርያሁ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ እምቅድመ፡ ዕርገቱ፡ ለእግዚእነ፡
                         </incipit>
                         <note>The Miracles are numbered. The witness has been extensively used in
                           the edition started with <bibl corresp="http://zotero.org/groups/358366/items/BGRGT37I"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1917MiraclesJesusI"/><title level="m">Les miracles de Jésus, texte éthiopien publié et traduit&lt;hi rend="italics"&gt;, I:&lt;/hi&gt; Miracles I à X</title><title level="s">Patrologia Orientalis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sylvain</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Grébaut</t:surname></author><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sylvain</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Grébaut</t:surname></editor><pubPlace>Paris</pubPlace><publisher>Firmin-Didot et C&lt;sup&gt;ie&lt;/sup&gt;, imprimeurs-éditeurs</publisher><date>1917</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Patrologia Orientalis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">12/4</t:biblScope></series><biblScope unit="volume">12/4</biblScope><note type="url">https://archive.org/details/patrologiaorient12pariuoft/mode/2up?view=theater</note></bibl>.</note>
                        </msItem>

                        <msItem xml:id="ms_i2">
                          <locus from="105vb" to="111rb"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1759Legend">Legend of Abgar (general record)</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ ሥሉስ፡ ቅዱስ፡ አበ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi>
                           ፩አምላክ፨ ንዌጥን፡ ኀበ፡ ጥንተ፡ ነገር፡ ዘከመ፡ ለአከ፡ ብፁዕ፡ አቃርዮስ፡ ንጉሠ፡ ሮሃ፡ ኀበ፡ እግዚእነ፡ <hi rend="rubric">ኢየሱስስ፡</hi>
                           ለዘክሮቱ፡ ይደሉ፡ ሰጊድ፡ እንዘ፡ ሀሎ፡ በመዋዕለ፡ ትሥጉቱ፡ እምቅድመ፡ ይዕርግ፡ ዲበ፡ ዕፀ፡ መስቀል፡ ከመ፡ ይግዝማ፡ ለኃይለ፡ ኃጢአት፡ በድካመ፡
                          ትሕትናሁ፡ ማሕያዊት፨
                           </incipit>
                              </msItem>

                          <msItem xml:id="ms_i3">
                            <locus from="111va" to="129vb"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT1922Mashaf">Maṣḥafa dorho</title>
                           <textLang mainLang="gez"/>
                             <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አበ፡ ወወልድ፡ ወመ</hi>ንፈስ፡ ቅዱስ፡
                             ፩አምላክ፨ ድ<hi rend="rubric">ርሳን፡ ወትምህርት፡ ዘአባዊነ፡</hi> ሕዋርያት፡
                             ቅዱሳን፡ ዘመሀሩ፡ <hi rend="rubric">ከመንፈሳውያን፡ እሉ፡ እሙ</hi>ንቱ፡ እሉ፡ ገብሩ፡ ኃይላተ፡ ወተአምራተ፡ ወትምህርተ፡
                             መድኃኒት፡
                             </incipit>
                              </msItem>






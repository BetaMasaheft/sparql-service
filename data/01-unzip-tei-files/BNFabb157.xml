                    <summary/>

                    <msItem xml:id="p1_i1">
                       <locus from="1ra" to="50vb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation">Interpretation and Symbolic Commentary on Genesis and Exodus (<foreign xml:lang="gez">Mamhǝra ʾorit</foreign>)</title>

                       <msItem xml:id="p1_i1.1">
                          <locus from="1ra" to="12vb"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Exodus">Commentaries on Exodus </title>
                         <textLang mainLang="gez" otherLangs="am"/>                      
                         <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ እግዚአብሔር፡ መ</hi>ሐሪ፡ ወመስተሣህል፡ <gap reason="ellipsis" resp="DN"/> 
                           እወጥን፡ <hi rend="rubric">ጽሒፈ፡ መጽሐፍ፡ ዘይ</hi>ሰመይ፡ መምህረ፡ ተስኢልየ፡ እማእምራን፡ መጻሕፍት፨ ወረባሑሰ፡ ለዝ፡ መጽሐፍ፡ ይሜህር፡ ወይተረጐም፡ ቃላተ፡ ወነገራተ፡ እንተ፡
                           <sic resp="DN">የዐፅብ፡ </sic> ወይሰአን፡ ዘይትኀባእ፡ ወዘይሴውር፡ <gap reason="ellipsis" resp="DN"/><hi rend="rubric">ኦሪት፡ ዘልደት፡ ኦሪት፡ 
                             ብሂ</hi>ል፡ ሕግ፡ ኪዳን፡ ፍትሕ፡ መጽ<hi rend="rubric">ሔት፡ ወሥርዓት፡ ዘልደት፡</hi> ብሁል፡ ዘፍጥረት፨
                           በቀዳሚ፡ ገብረ፡ እግዚአብሔር፡ ስማየ፡</incipit>
                          </msItem>

                       <msItem xml:id="p1_i1.2">
                          <locus from="13ra" to="24vb"/>
                         <locus from="36ra" to="36vb"/>
                          <title type="complete">About the Tabernacle</title>
                            <textLang mainLang="gez" otherLangs="am"/>
                       <incipit xml:lang="gez"><hi rend="rubric">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ ግብረ፡ ደብተራ፡</hi>ዘኦሪት፡ አዕናቅ፡
                         ኢያስጲስ፡ ወአቡቀለምሲስ፡ ያስቢስ፡ ወጥልም፡ በኦሪት። 
                       </incipit>
                            </msItem>

                            <msItem xml:id="p1_i1.3">
                              <locus from="36vb" to="39vb"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Leviticus">Commentary on Leviticus</title>
                              <textLang mainLang="gez" otherLangs="am"/>
                              <incipit xml:lang="gez">፫፡ ወ፴ወ፩፡ ዓመት፡ እምአመ፡ ወፅኡ፡ ፳ኤል፡ እምግብጽ፡ ተጽሕፈ፡ ኦሪት፡ ዘሌዋውያን፡ ዝውእቱ፡ ፍካሬሁ፡ ቃሉ፡ ክዱን፡ 
                                መባአ፡ ዘ፡ ዘያበውኡ፡ እስራኤል፡ ለእግዚአብሔር፡ ዘንቱ፡ ውእቱ፡ ላህም፡ ወ በግዕ፡ ፍየል፡ ወርግብ፡ ወማዕነቅ።  ማዕነቅ፡ ዘ፡ ዋኖስ። ወእምነ፡ እክል፡ ስንዴ፡ ዕጣነ፡ ወቅብዕ።
                                ወባዕደሰ፡ ኢያበውዑ፡ ለመሥዋዕት፡ 
                              </incipit>
                            </msItem>
                                  
                              <msItem xml:id="p1_i1.4">
                                <locus from="39vb" to="43rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Numbers">Commentary on Numbers</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez">በ፴፡ ወ፰፡ ዓመት፡ እምአመ፡ ወፅኡ፡ እስራኤል። ተጽሕፈ፡ ኦሪት፡ ዘኍልቍ፡ ኍልቍሰ፡ ዘተብህለ፡ እስመ፡ ይነግር፡ ኆልቆሙ፡ ለእስራኤል፡ ዛቲ፡ ይእቲ፡ 
                                  ፍቅዶ፡ ዘአስተፋቀድዎሙ፡ ሙሴ፡ ወአሮን፡ ወመላእክት። ወኮነ፡ ፍ<pb n="40ra"/>ቅዶሙ፡ ለደቂቀ፡ እስራኤል፡ ዘእም፳፡ ዓም፡ ወለእለ፡ እምኔሁ። ኵሉ፡ ዘይጽብእ፡ ፀብአ፡  
                                    </incipit>
                              </msItem>  
                                  
                              <msItem xml:id="p1_i1.5">
                                <locus from="43rb" to="45va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Deuteronomy">Commentary on Deuteronomy</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez">በ፵፡ ዓመት፡ እምአመ፡ ወፅኡ፡ እስራኤል፡ እምግብጽ፡ ተጽሕፈ፡ ኦሪት፡ ዘዳግም፡ ዝውእቱ፡ ትርጓሜ፡ ሕቱም፡ ጻረባ፡ በዳ፡ ፋራን፡ ዘ፡ ዝኒ፡ በዳ፡ ኮሬብ፡ ዘ፡ ዝወው፡ ሌባ፡ ዘ፡ ቀኝእ፡ 
                                  ጳራልያ፡ ጽንፈ፡ ባሕር፡ አንጢሊባኖስ፡ ዘ፡ አንጻረ፡ ሊባኖስ፡  
                                </incipit>
                              </msItem>
                              
                              <msItem xml:id="p1_i1.6">
                                <locus from="45va" to="47rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Joshua">Commentary on Joshua</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez"><hi rend="rubric">ኦሪት፡ ዘሆሴዕ፡  ተጽሕፈ፡ በል</hi>ሳነ፡ አሜሌቅ፡ ወይትኈለቊ፡ ምስለ፡ መጽሐፈ፡ ነገሥት፡ ዝውእቱ፡ 
                                  ትርጓሜ፡ ቃሉ፡ ክቡት፡ ኢየሱስ። ብሂል፡ መድኅ<cb n="b"/>ን፡ ዘከፈሎ፡ በፈለገ፡ ዮርዳኖስ፡ እስመ፡ ለዝሰ፡ ፈለግ፡ ቦቱ፡ ፪፤ ዓይኒ፡ ፩፡ ዳኖስ፡ ይሰመይ፡ 
                                  ቦቱ፡ ይሣቅዩ፡ ኣሕዛበ፡ <sic resp="DN">ምድረ፡</sic>
                                </incipit>
                                <note>Called Hosea in the incipit.</note>
                              </msItem>
                              
                              <msItem xml:id="p1_i1.7">
                                <locus from="47ra" to="50va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Judges">Commentary on Judges</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez"><hi rend="rubric">ኦሪት፡ ዘመሳፍንት፡ ተጽሕፈ፡ </hi>በልሳነ፡ ከናኔዎን። ዝውእቱ፡ ፍካሬ፡ ቃላቲሁ፡ 
                                  ኅቡአን፡ ዝኒ፡ ይትኌለቊ፡ ምስለ፡ መጽሐፈ፡ ነገሥት፡ አዶኒ። ዘ፡ እግዚእ፡ ቀርያቦ፡ ቄሴፌር፡ ዘ፡ ሀገረ፡ መጽሓፍ፡  
                                </incipit>
                              </msItem>
                              
                              <msItem xml:id="p1_i1.8">
                                <locus from="50va" to="50vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4117Interpretation#Ruth">Commentary on Ruth</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez"><hi rend="rubric">ኦሪት፡ ዘሩት፡ ተጽሕፈ፡ በልሳነ፡</hi> ሞአብ፡ ኒኃ፡ ሚን፡ ዘ፡ ትፍሥሕት፡
                                  መራዕዊሃ፡ ዘ፡ አንስትያ፡ ዉሉዳ። መረረኝ፡ ዘይቤ፡ ቈጨኝ። መራር፡ ዘይቤ፡ ኅዝንት፡ ምልዕትየ፡ ዘ፡ ይቤ፡ ብዝኅትየ።  
                                </incipit>
                              </msItem>
                              
                              <msItem xml:id="p1_i1.9">
                                <locus target="#50vb"/>                                              
                                <title type="complete" ref="https://betamasaheft.eu/LIT6838MeasuresWeightHebrew">Explanations of Hebrew weight measurements</title>
                                <textLang mainLang="gez" otherLangs="am"/>
                                <incipit xml:lang="gez"><hi rend="rubric">ነገረ፡ መዳልው፡ መክሊት፡</hi>
                                  ዓሠርቱ፡ ወከልኤቱ፡ ምእት፡ ወቄት፡ አስታር፡ ፲ወ፪፡ ወቄት፡ ወቦ፡ ዘይቤ፡ መክሊት፡ ሕልቅ፡ ፩ወቄት። ገመስ፡ ፩ድሪም፡ ዲናር፡ ዓላድ።
                                </incipit>                       
                            </msItem>
                            </msItem>
                   
                   <msItem xml:id="p1_i2">
                     <locus from="50vb" to="103rb"/>
                       <title type="complete">Commentaries on other Old Testament books</title>
                     
                     <msItem xml:id="p1_i2.1">
                       <locus from="50vb" to="103rb"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT6837CommentaryKings">Commentaries on the Books of Kings</title>
                       
                       <msItem xml:id="p1_i2.1.1">
                     <locus from="50vb" to="57rb"/>                                              
                         <title type="complete" ref="https://betamasaheft.eu/LIT6837CommentaryKings#KingsFirst">Commentary on 1 Kings (1 Samuel)</title>
                         <textLang mainLang="gez" otherLangs="am"/>
                     <incipit xml:lang="gez"><hi rend="rubric">ትርጓሜ፡ ነገሥት፡ ዘተጽሕፈ፡ በልሳነ፡ ዕብራይስጥ፡</hi>
                       ወሀሎ፡ ፩ብእሲ፡ እምአርማቴም፡ ዘሙሴ፡ ፋ፡ ዘ፡ ስሙ፡ ወ፤ እ፡ ይ፡ አርማቴዎስ፡ ሀገር። ወበዓረቢሰ፡ ወግር፡ ወመሴፉሰ፡ ዘ፡ ገዳም፡ ወቦ፡ እለ፡ ይቤሉ፡ 
                       እስመ፡ ባሕር። ደብረ፡ ኤፍሬም፡ ዘ፡ ሀገረ፡ ካህናት፡ ዘ፡ ሀለወት፡ በብሔረ፡ ኤፍሬም።
                     </incipit>                       
                   </msItem>
                     
                     <msItem xml:id="p1_i2.1.2">
                       <locus from="57va" to="61va"/>                                              
                       <title type="complete" ref="https://betamasaheft.eu/LIT6837CommentaryKings#KingsSecond">Commentary on 2 Kings (2 Samuel)</title>
                       <textLang mainLang="gez" otherLangs="am"/>
                       <incipit xml:lang="gez"><hi rend="rubric">ወአመ፡ ሣልስት፡ ዕለት፡ መጽአ፡ ብእሲ፡</hi> እምትዕይንተ፡ ዘ፤ እምነ፡ ፀብእ፡ ወስሉጥ፡ አልባሲሁ፡ 
                       </incipit>                       
                     </msItem>
                     
                     <msItem xml:id="p1_i2.1.3">
                       <locus from="61va" to="67ra"/>                                              
                       <title type="complete" ref="https://betamasaheft.eu/LIT6837CommentaryKings#KingsThird">Commentary on 3 Kings (1 Kings)</title>
                       <textLang mainLang="gez" otherLangs="am"/>
                       <incipit xml:lang="gez"><gap reason="illegible"/>ወኃለፈ፡ መዋዕሊሁ፡ ወይከድንዋ፡ አልባስ፡ ወያመውቆ፡ ዘ፡ ይቤሉ፡ በእንተ፡ ርስዓን፡ ወቦ፡ እ፡ ሶበ፡ 
                       </incipit>                       
                     </msItem>
                     
                     <msItem xml:id="p1_i2.1.4">
                       <locus from="67ra" to="69rb"/>                                              
                       <title type="complete" ref="https://betamasaheft.eu/LIT6837CommentaryKings#KingsFourth">Commentary on 4 Kings (2 Kings)</title>
                       <textLang mainLang="gez" otherLangs="am"/>
                       <incipit xml:lang="gez"><hi rend="rubric">ወእምድኅረ፡ ሞተ፡ አክአብ፡ አፅ</hi>ረሩ፡ ሞአን፡ ዘ፡ አመፁ፡
                       </incipit>                       
                     </msItem>
                     </msItem>
                     
                     <msItem xml:id="p1_i2.2">
                       <locus from="69vb" to="76va"/>                                              
                       <title type="complete" ref="https://betamasaheft.eu/LIT6836CommChronicles">Commentary on 1 and 2 Chronicles (ሕፁፃን፡)</title>
                       <textLang mainLang="gez" otherLangs="am"/>
                       <incipit xml:lang="gez"><hi rend="rubric">ሕፁፃን፡ ብሂል፡ የነገሥት፡ ት<gap reason="illegible" resp="DN"/></hi>
                        ት፡ ማጎግ፡ ዘ፡ አቡሆሙ፡ ለሰብእ፡ ወይዜክሮሙ፡ ሕዝቅኤል፡ ወአቡቀለምሲስ፡ ማዳይኒ፡ አቡሆሙ፡ ለሜ<gap reason="illegible" unit="chars" quantity="1"/>
                       ኢዮኅያን፡ አቡሆሙ፡ ለዮናናውያን፡</incipit>
                       <note>The begining is similar to <ref type="work" corresp="https://betamasaheft.eu/LIT6834CommentarFirstChronicles">Commentary on 1 Chronicles</ref>. </note>                       
                     </msItem>
                     
                     <msItem xml:id="p1_i2.3">
                       <locus from="76vb" to="102va"/>                                              
                       <title type="complete" cert="medium" ref="https://betamasaheft.eu/LIT6676CommDaniel">Commentary on Daniel</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez"><hi rend="rubric">ትርጓሜ፡ ዳንኤል፡ መገብት፡</hi> ይትበሀሉ፡ በእንተ፡ ሠለስቱ፡ አሐዱ፡ መሃይምናን፡ ክልኤቱ፡ ምእመናን፨ ሠለስቱ፡ 
                         ሕፅዋን፡ ወሊቀ፡ መገብት፡ ሊቆሙ፡ ለሕፅዋን፡ ወዘይቤ፡ ይጌሥጽዎሙ፡ ለጽሒፍ፡ ወነቢብ፡ ወጥበብ፡ ወልሳነ፡ ከለዳውያንሰ፡ ነገረ፡ ሶርያ፡ ቃል፨ ወአዘዘ፡ ይሕፅንዎሙ፡ እስከ፡ ኀበ፡ ይብል፡ ዘይሰቲ፡ እምወይን፨
                       </incipit>
                     </msItem>
                     
                     <msItem xml:id="p1_i2.4">
                       <locus from="103ra" to="192vb"/>                                              
                       <title type="complete" cert="medium" ref="https://betamasaheft.eu/LIT3183Commen">Commentaries on the Books of the Minor Prophets, in Gǝʿǝz</title>
                       <textLang mainLang="gez" otherLangs="am"/>     
                       <note>It includes <ref type="work" corresp="https://betamasaheft.eu/LIT3149Haggai">Za-Ḥagge nabiyy</ref>, <ref type="work" corresp="https://betamasaheft.eu/LIT3148Zephan">Za-Sofonyās nabiyy</ref>, 
                         <ref type="work" corresp="https://betamasaheft.eu/LIT1567Bookof">Book of Habakkuk</ref> and others.</note>
                     </msItem>
                     
                     <msItem xml:id="p1_i2.5">
                       <locus from="193ra" to="227rb"/>                                              
                       <title type="complete" ref="https://betamasaheft.eu/LIT6839CommentaryIsaiah">Commentary on Isaiah</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ እግዚአብሔር፡ መ</hi>ሐሪ፡ ወመስተሣህል፡ ንወ<hi rend="rubric">ጥን፡ ትርጓሜ፡ መጽሐፈ፡ ኢ</hi>ሳይያስ፡ 
                         <gap reason="ellipsis" resp="DN"/> ራእይ፡ ዘርእየ፡ በእንተ፡ ይሁዳ፡ ወበእንተ፡ ኢየሩሳሌም፡ ዘ፡ ዘይከውን፡ ፄዋዌ፡ ላዕለሆን፨ ኢሳይያስ፡ ብሂል፡ ቅቡዕ፡ እምቀብዓ፡ ትንቢት፨                        
                       </incipit>
                     </msItem>              
                                                              
                   </msItem>
                              
                              

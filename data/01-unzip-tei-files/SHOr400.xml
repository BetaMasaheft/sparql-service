                        <decoDesc>
                            <decoNote type="drawing" xml:id="d1">
                              <locus target="#1r">Fol. 1r</locus>
                              <desc>Pencil sketch depicting a Saint holding two undefined objects in the hands.
                              </desc>
                            </decoNote>
                            <decoNote type="drawing" xml:id="d2">
                              <locus target="#1v">Fol. 1v</locus>
                              <desc>Pencil sketch depicting a monk (?) with the arms opened and raised.
                              </desc>
                            </decoNote>
                            <decoNote type="band" xml:id="d3">
                              <locus target="#2r">Fol. 2r</locus>
                              <desc>Ornamental band in black and red ink on the top of the incipit page with rombuses, crosses and double circles.</desc>
                            </decoNote>
                            <decoNote type="band" xml:id="d6">
                              <locus target="#37r">Fol. 37r</locus>
                              <desc>Ornamental band in black and red ink at the end of the text with rombuses, circles and crosses.</desc>
                            </decoNote>
                            <decoNote type="drawing" xml:id="d7">
                              <locus target="#37r">Fol. 37r</locus>
                              <desc>Pencil sketch depicting the <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                        </desc>
                            </decoNote>
                            <decoNote type="miniature" xml:id="d8">
                              <locus target="#37v">Fol. 37v</locus>
                              <desc>
                           <term key="donordepiction" ana="#donordepiction">Donor</term> portrait.
                              </desc>
                              <q xml:lang="gez">ዘከመ፡ ተማኀነ፡ መምሕሬ፡ ወልደ ጸድቅ። አቡሁ</q>
                            </decoNote>
                            <decoNote type="miniature" xml:id="d9">
                              <locus target="#38r">Fol. 38r</locus>
                              <desc>A miniature of the <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                              <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> with a rayed <term key="halo" ana="#halo">halo</term> holds <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> with both hands. The Child holds a <term key="codex" ana="#codex">codex</term> in his left hand.
                              Two angels in the background.
                              </desc>
                              <q xml:lang="gez">ምስለ፡ ፍቁር፡ ወልዳ</q>
                            </decoNote>
                            <decoNote type="drawing" xml:id="d10">
                              <locus target="#38v">Fol. 38v</locus>
                              <desc>Pencil sketch depicting an interlace.</desc>
                            </decoNote>
                        </decoDesc>

                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus target="#2r">Fol. 2r</locus>
                              <desc type="GuestText">Der Beginn der Interzessio aus der Apostelanaphora</desc>
                            </item>
                          <item xml:id="e1">
                            <desc>The stamp of the Staats- und Universitätsbibliothek Hamburg.</desc>
                            <locus target="#38v">Fol. 38v</locus>
                          </item>
                          </list>
                        </additions>

                        <bindingDesc>
                          <binding contemporary="true" xml:id="binding">
                            <decoNote xml:id="b1">
                              Ethiopic bookbinding with uncovered wooden boards.
                            </decoNote>
                            <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                            <decoNote xml:id="b3" type="Boards">
                              Two wooden boards of the same species, externally bevelled.
                              In the central area of the lower board there is a hole where the ends of the sewing threads converge.
                            </decoNote>
                            <decoNote xml:id="b6" type="SewingStations">4</decoNote>
                            <decoNote xml:id="b7">
                              The sewing is a chain-stitch on four sewing stations (two pairs). The sewing corresponds to the <term key="patternA3" ana="#patternA3">pattern A3</term> defined by G. Bozzacchi.
                              A thread of <term key="animalThread" ana="#animalThread">animal origin</term> has been used for the sewing.
                            </decoNote>
                            <decoNote xml:id="b9" type="Spine">
                              Small holes are present close to the head and tail of the quires, prabably remains of the tackets.
                            </decoNote>
                            <decoNote xml:id="b11" type="EndLeaves">
                              The first bifolio has a protective function.
                            </decoNote>
                            <decoNote xml:id="b12" type="other">
                              Textile bookmark inserted in the upper text prick of fol. 35
                            </decoNote>
                          </binding>
                        </bindingDesc>

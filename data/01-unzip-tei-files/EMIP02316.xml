         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Weiner</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/2316/" n="276" corresp="https://betamasaheft.eu/api/iiif/EMIP02316/manifest">Weiner Codex 302</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter</summary>
                <msItem xml:id="ms_i1">
                  <locus from="1r" to="194v" facs="003">Fols 1r–194v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters</note>

                <msItem xml:id="ms_i1.1">
                  <locus from="1r" to="158r" facs="003">Fols 1r–158r</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                </msItem>

                <msItem xml:id="ms_i1.2">
                <locus from="158r" to="177v" facs="160">Fols 158r–177v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                </msItem>

                <msItem xml:id="ms_i1.3">
                  <locus from="177v" to="185v" facs="180">Fols 177v–185v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                </msItem>

                <msItem xml:id="ms_i1.4">
                  <locus from="186r" to="191v" facs="188">Fols 186r–191v</locus>
                  <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>

                <msItem xml:id="ms_i1.4.1">
                  <locus from="186r" facs="188">Fols 186r and following</locus>
                  <title>Thursday</title>
                  <note>incomplete at beginning</note>
                </msItem>

                <msItem xml:id="ms_i1.4.2">
                  <locus from="186r" facs="188">Fols 186r and following</locus>
                  <title>Friday</title>
                  <note>incomplete at the end</note>
                </msItem>

                <msItem xml:id="ms_i1.4.3">
                  <locus from="188r" facs="190">Fols 188r and following</locus>
                  <title>Saturday</title>
                  <note>incomplete at the beginning</note>
                </msItem>

                <msItem xml:id="ms_i1.4.4">
                  <locus from="189v" facs="192">Fols 189v and following</locus>
                  <title>Sunday</title>
                </msItem>
                </msItem>

                <msItem xml:id="ms_i1.5">
                  <locus from="191v" to="194v" facs="194">Fols 191v–194v</locus>
                  <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <note>Incomplete at the end</note>
                </msItem>
                </msItem>

                </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                          <measure unit="leaf">ii + 194</measure>
                           <dimensions type="outer" unit="mm">
                             <height>143</height>
                             <width>124</width>
                             <depth>82</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Many quires have been rebound and many folios are missing, making a quire map impossible.</note>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                         <dimensions type="margin" unit="mm">
                           <dim type="top">19</dim>
                           <dim type="bottom">31-35</dim>
                           <dim type="right">16-20</dim>
                           <dim type="left">8</dim>
                         </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="15">
                         <locus from="1r" to="185v" facs="003">Fols 1r–185v</locus>
                       </layout>
                       <layout columns="2" writtenLines="15">
                         <locus from="186r" to="194v" facs="188">Fols 186r–194v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word God is not rubricated in the first three works; the word Mary is rubricated in the final two works</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#95v" facs="098">Fol. 95v</locus><desc>crude drawing of a <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref> in purple ink</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#135r #138r" facs="137 140">Fols. 135r, 138r</locus><desc>crude drawing of a face</desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#185v #194r" facs="188 196">Fols. 185v, 194r</locus><desc>ornamental band drawn with black ink in the bottom margin</desc></decoNote>
                  <decoNote type="frame" xml:id="d4">
                  Decorative designs:
                  <locus target="#10r #28r #41r #50v #57r #68r #73r #87v #97r #104v #121r #137r #141r #149v #158r #177v #185v #186r #189v #191v" facs="012 030 043 053 059 070 075 090 099 107 123 139 143 152 160 180 188 192 194">folss. 10r, 28r, 41r, 50v, 57r, 68r, 73r, 87v, 97r, 104v, 121r, 137r, 141r, 149v, 158r, 177v, 185v, 186r, 189v, 191v, </locus> (line of alternating red and black dots);
                  <locus target="#41r #50v #73r #97r #104v #158r #177v #185v" facs="043 053 075 099 107 160 180 188">41r, 50v, 73r, 97r, 104v, 158r, 177v, 185v</locus> (multiple full stops)
                  </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto) #iv(erso) #iir(ecto)" facs="001 002">Fols. ir(ecto), iv(erso), iir(ecto)</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                    unidentified text, oriented upside down to the rest of the codex. A great deal of the folio has been lost
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#81r" facs="083">Fol. 81r</locus>
                    The midpoint of the Psalms is marked with a small design in red and black ink
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#105v #106r #106v" facs="108 109">Fols. 105v, 106r, 106v</locus>
                    several lines of text in Amharic. Written in pencil
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    A number of notes written on paper in Amharic have been tucked into the codex
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#59r #80r #82r #82v" facs="061 082 084 085">Fols. 59r, 80r, 82r, 82v</locus>
                      There are a number of scrawls in purple ink throughout the codex
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <desc>
                    <locus target="#10 #28 #38 #57 #81 #92 #102 #113 #158" facs="012 030 040 059 083 094 104 115 160">Fols. 10, 28, 38, 57, 81, 92, 102, 113, 158</locus>
                      red string stitched into fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                    Numbered quires: quires 4–5, 7, 3 (<locus target="#69r" facs="071">fol. 69r</locus>), 8–9, and 12–19
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <desc>
                      words of text are written interlinearly (<locus target="#10v #13r #14r #18v #75r" facs="013 015 016 021 077">folss. 10v, 13r, 14r, 18v, 75r, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#181r" facs="183">181r, </locus>);
                      lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted (<locus target="#98v" facs="101">98v, </locus>);
                      text has been removed (<locus target="#16v #18r #23v #31r #61v" facs="019 020 026 033 064">16v, 18r, 23v, 31r, 61v</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                      <decoNote xml:id="b1">Parchment, three Coptic chain stitches attached with bridle attachments to a rough-hewn board of the traditional wood for the front cover, back cover is heavy leather.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                    <origDate notBefore="1650" notAfter="1699">Late-seventeenth century</origDate>
                  </origin>
               </history>
            </msDesc>
         </sourceDesc>

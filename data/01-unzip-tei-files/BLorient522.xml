                            <msItem xml:id="ms_i1.1">
                                <locus from="1v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1190Baenta">Baʾǝnta qǝddǝsāt</title>
                                <textLang mainLang="gez"/> 
                                <incipit xml:lang="gez">በእንተ፡ ቅድሳት፡ ሰላማዊት፡ ሰላመ፡ ናስተበቍዕ፡ ከመ፡ እግዚአብሔር፡ ያስተሳልመነ፡ በሣህለ፡ ዚአሁ፡</incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="3v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4327Basamay">

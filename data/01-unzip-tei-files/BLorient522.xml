                        </title>
                                <textLang mainLang="gez"/> 
                                <incipit xml:lang="gez">በሰማይ፡ የሀሉ፡ ልብክሙ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="4r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT5899HymnCommunion">Hymn Following Communion</title>
                                <textLang mainLang="gez"/> 
                                <incipit xml:lang="gez">ቅዱስ፡ ቅዱስ፡ ቅዱስ፡ ሥሉስ፡ ዘኢይትነገር፡ ኃበኒ።</incipit>
                            </msItem>
                        </msItem>
                        

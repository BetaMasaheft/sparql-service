                            <locus from="83r"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3957SalotaB">ጸሎተ፡ ቡራኬ፡</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">ኦሥሉስ፡ ቅዱስ፡ ባርክ፡ ዲበ፡ ሕዝብከ፡ ፍቁራን፡ ክርስቶሳውያን፡ በበረከት፡ ሰማይውያን፡ ወምድራውያን።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="87r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3012RepCh292">Bǝḍǝʿt ʾanti</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">ብፅዕት፡ አንቲ፡ ወንግሥተ፡ ጽድቅ። ዘትሜንኒ፡ ማርያም፡ መንበረ፡ ሥላቅ። ታቦትነ፡ አንቲ፡ እንተ፡ ወርቅ። ሃሌ፡ ሉያ።
                                ሃሌ፡ ሉያ። ሃሌ፡ ሉያ።</incipit>
                        </msItem>

               <msContents>
                  <summary>Pillars of Mystery, Passion of the Cross</summary>
                <msItem xml:id="ms_i1">
                  <locus from="2r" to="68r" facs="002"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest">ʾAmmǝstu ʾaʿmāda mǝśṭir</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                <msItem xml:id="ms_i1.1">
                  <locus from="2r" to="5r" facs="002"/>
                  <title>Introduction</title>
                  <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ<gap reason="omitted"/> ከተግባረ፡ ሥጋ፡ ከተግባረ፡ ነፍስ፡ አስቀድሞ፡ ሃይማኖትን፡ ሊማሩ፡ ዘንድ፡ ይገባል፡ መቅድመ፡ ኵሉ፡ ንትመሃር፡ ሃይማኖተ፡ እንዳለ፡ ቄርሎስ፡ ሃይማኖትስ፡ ማለት፡ ምን፡ ማለት፡ ነው፡ ቢሉ<gap reason="omitted"/></incipit>
                </msItem>

                <msItem xml:id="ms_i1.2">
                  <locus from="5r" to="13r" facs="005"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Trinity">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Trinity ()</title>
                </msItem>

                <msItem xml:id="ms_i1.3">
                  <locus from="13r" to="27r" facs="013"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Incarnation">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Incarnation ()</title>
                </msItem>

                <msItem xml:id="ms_i1.4">
                  <locus from="27r" to="38v" facs="027"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#BaptismMystery">No item: LIT1097Ammest, could not check for BaptismMystery</title>

                <msItem xml:id="ms_i1.4.1">
                  <locus from="27r" to="33r" facs="027"/>
                  <title>The Baptism of Our Lord</title>
                </msItem>

                <msItem xml:id="ms_i1.4.2">
                  <locus from="33r" to="38v" facs="033"/>
                  <title>Christian Baptism</title>
                </msItem>
                </msItem>

                <msItem xml:id="ms_i1.5">
                  <locus from="38v" to="44r" facs="039"/>
                  <title>Mystery of Communion, Mǝ śṭir Qurǝban, <foreign xml:lang="gez">ምሥጢረ፡ ቍርባን</foreign></title>
                </msItem>

                <msItem xml:id="ms_i1.6">
                  <locus from="44r" to="68r" facs="044"/>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Resurrection">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Resurrection ()</title>

                <msItem xml:id="ms_i1.6.1">
                  <locus from="44r" to="52r" facs="044"/>
                  <title>The Resurrection of Our Lord</title>
                </msItem>

                <msItem xml:id="ms_i1.6.2">
                  <locus from="52r" to="68r" facs="052"/>
                  <title>General Resurrection</title>
                </msItem>
                </msItem>
                </msItem>

                <msItem xml:id="ms_i2">
                  <locus from="68r" to="93r" facs="068"/>
                  <title>On the Passion of the Cross, Ḥǝmamatä Mäsqäl, <foreign xml:lang="gez">በእንተ፡ ሕማማተ፡ መስቀል</foreign></title>
                  <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ<gap reason="omitted"/> (f. 68v) ሕማማተ፡ መስቀል፡ እንናገርአለን፡ የሕማማተ፡ መስቀልስ፡ ነገር፡ እንደምነው፡ ቢሉ፡ ጌታችን፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ የጸሎተ፡ ሐሙስ፡ ዕለት፡ ማታ፡ ፲፪ቱን፡ ሐዋርያት፡ ይዞ<gap reason="omitted"/></incipit>
                </msItem>

                </msContents>

               <msContents>
                  <summary>Fragment of a manuscript containing ‎Chants called Mǝ‘raf, ምዕራፍ፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="34v" facs="003">Fols 1v–34v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3186Meeraf">Mǝʿrāf</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1.1">
                     <locus from="1v" to="6v" facs="003">Fols 1v–6v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>incomplete at the beginning</note>
                          <msItem xml:id="ms_i1.1.1">
                            <locus from="1v" facs="003">Fols 1v and following</locus>
                            <title>Monday (only a few lines)</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.2">
                            <locus from="1v" facs="003">Fols 1v and following</locus>
                            <title>Tuesday</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.3">
                            <locus from="2v" facs="004">Fols 2v and following</locus>
                            <title>Wednesday</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.4">
                            <locus from="3v" facs="005">Fols 3v and following</locus>
                            <title>Thursday</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.5">
                            <locus from="4v" facs="006">Fols 4v and following</locus>
                            <title>Friday</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.6">
                            <locus from="5v" facs="007">Fols 5v and following</locus>
                              <title>Saturday</title>
                          </msItem>
                          <msItem xml:id="ms_i1.1.7">
                            <locus from="6r" facs="007">Fols 6r and following</locus>
                            <title>‎Sunday</title>
                          </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                     <locus from="7r" to="9r" facs="008">Fols 7r–9r</locus>
                     <title>Chants called Ezel, <foreign xml:lang="gez">ዕዝል</foreign>
                     </title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <notatedMusic>
                       <desc>with musical notation</desc>
                     </notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="9r" to="10v" facs="010">Fols 9r–10v</locus>
                     <title>Chant called Yǝtbaräk, <foreign xml:lang="gez">ይትባረክ፡</foreign>
                     </title>
                     <incipit xml:lang="gez">ይትባረክ፡ እግዚአብሔር አምላከ፡ አበዊነ፡ ስቡሕኒ፡ ውእቱ፡ ወልዑልኒ፡ ውእቱ፡ ለዓለም። ወይባትባረክ፡ ስመ፡ ስብሐቲሁ ቅዱስ፡ ስቡሕኒ፡ ው፡ ወልዑልኒ፡ ው። በኵሉ፡ ዓለም።</incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <notatedMusic>
                       <desc>with musical notation</desc>
                     </notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="11r" to="19r" facs="012">Fols 11r–19r</locus>
                     <title>Chant called Qalǝyä aṣmǝ`, <foreign xml:lang="gez">ቃልየ፡ አጽምዕ፡</foreign>
                     </title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>incomplete at the beginning</note>
                     <notatedMusic><desc>with musical notation</desc></notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                     <locus from="19r" to="26v" facs="020">Fols 19r–26v</locus>
                     <title>Chant called Sǝmǝ‘ani, <foreign xml:lang="gez">ስምዓኒ፡</foreign>
                     </title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>incomplete at the end</note>
                     <notatedMusic><desc>with musical notation</desc></notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i1.6">
                     <locus from="27r" to="30r" facs="028">Fols 27r–30r</locus>
                     <title>Aryam, <foreign xml:lang="gez">አርያም፡</foreign>
                     </title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <notatedMusic>
                       <desc>with musical notation</desc>
                     </notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i1.7">
                     <locus from="30r" to="34v" facs="031">Fols 30r–34v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2605Zayena">Za-yǝnaggǝś</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                </msItem>

               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">34</measure>
                           <dimensions type="outer" unit="mm">
                              <height>161</height>
                              <width>155</width>
                              <depth>18</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>The original construction of the codex is impossible to discern.</note>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                         <dimensions type="margin" unit="mm">
                           <dim type="top">16</dim>
                           <dim type="bottom">35</dim>
                           <dim type="right">18</dim>
                           <dim type="left">13</dim>
                         </dimensions>
                       </layout>
                       <layout columns="2" writtenLines="19"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  <locus target="#6v #19r #27r #29r" facs="008 020 028 030">folss. 6v, 19r, 27r, 29r, </locus> (multiple full stops);
                  <locus target="#30r" facs="031">30r</locus> (line of black dots)
                  </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                            <item xml:id="a1">
                            <locus target="#7v" facs="009"> f. 7v, bottom margin</locus>
                             <desc type="GuestText">Excerpt from the book of <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title></desc>
                            </item>
                            <item xml:id="a2">
                              <locus target="#21v #22r #22v" facs="023 024"> f. 21v, 22r, 22v, bottom margin</locus>
                              <desc>Instruction for reciting the Biblical Canticles, written in a later ‎hand‎</desc>
                            </item>
                            <item xml:id="a3">
                              <locus target="#30r" facs="031"> f. 30r, bottom margin</locus>
                              <desc>writing exercise, copying text from above, written in a twentieth-‎century hand‎</desc>
                            </item>
                            <item xml:id="e1">
                            <locus target="#1r" facs="002">Fol. 1r</locus>
                             <desc>blank</desc>
                            </item>
                            <item xml:id="e2">
                           <desc>Identified in the insurance hand list as Case 67/20</desc>
                            </item>
                            <item xml:id="e3">
                              <locus target="#2v #3v #5r #6v" facs="004 005 006 008">Fols. 2v, 3v, 5r, 6v</locus>
                           <desc>Words of text are written interlinearly</desc>
                            </item>
                            <item xml:id="e4">
                            <locus target="#14v" facs="016">Fol. 14v</locus>
                            <desc>Erasure markings are visible</desc>
                            </item>
                            <item xml:id="e5">
                            <locus target="#9v #11v #17v #18r #19v" facs="011 013 019 019 021">Fols. 9v, 11v, 17v, 18r, 19v</locus>
                            <desc>etc., text has been removed</desc>
                            </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                      <decoNote xml:id="b1">Parchment, folios have been rebound together with no covers.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1700" notAfter="1799">Eighteenth century</origDate>
                  </origin>
               </history>

         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ጴጥሮስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Ṗeṭros</persName>
               <persName>
                  <roleName type="title">ʾabuna</roleName>
               </persName>
               <occupation type="ecclesiastic">metropolitan</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
             
               
               <floruit notBefore="1551" notAfter="1570">He was a metropolitan of the Ethiopian Orthodox Church 
                  who arrived in <date>1551</date> and succeeded  ʾabuna
                  <persName ref="https://betamasaheft.eu/PRS10449YosabI">Yosāb I</persName>.
                  He served in three successive reigns of King <persName ref="https://betamasaheft.eu/PRS4428Galawdew">Galāwdewos</persName> , 
                  <persName ref="https://betamasaheft.eu/PRS7102Minas">Minās</persName>and during the first years of 
                  <persName ref="https://betamasaheft.eu/PRS8550sardaDe">Śarḍa Dǝngǝl</persName>.
          </floruit>
               <death>1570</death>
            </person>
            

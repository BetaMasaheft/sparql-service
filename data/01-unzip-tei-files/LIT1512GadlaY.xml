         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" n="1" xml:id="FirstPart">
               <t:label>Acts of Yāred</t:label>
               <t:listBibl type="clavis">
                  <t:bibl type="BHO" corresp="http://zotero.org/groups/358366/items/D9KQXSXB"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:BHO"/><title level="m">Bibliotheca hagiographica orientalis</title><title type="short">BHO</title><title level="s">Subsidia Hagiographica</title><author><name>Socii Bollandiani</name></author><pubPlace>Bruxellis–Beyrouth</pubPlace><publisher>Apoud Editores–Imprimerie Catholique</publisher><date>1910</date><series><title level="s">Subsidia Hagiographica</title><biblScope unit="volume">10</biblScope></series><biblScope unit="volume">10</biblScope><note type="url">https://archive.org/stream/bibliothecahagi00peet</note><note type="tags"><note type="tag">bm:BHO</note></note><note type="tag">bm:BHO</note><t:citedRange unit="item">428</t:citedRange></t:bibl>
               </t:listBibl>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab>
                     ንዑኬ፡ ኵልክሙ፡ ሕዝበ፡ ክርስቲያን፡ ደቂቃ፡ ለጽዮን፡ ገበዘ፡ አክሱም፡
                  </t:ab>
               </t:div>
               <t:div type="textpart" subtype="explicit" xml:lang="gez">
                  <t:ab>
                     በከመ፡ ተምህረ፡ እም፳ወ፬ካህናተ፡ ሰማይ። ጸሎቱ፡ <t:gap reason="omitted" extent="unknown"/> አሜን፡
                  </t:ab>
               </t:div>
            </t:div>
            <t:div type="textpart" subtype="chapter" n="2" xml:id="SecondPart">
               <t:label>Acts and Miracles of Yāred</t:label>
               <t:listBibl type="clavis">
                  <t:bibl type="BHO" corresp="http://zotero.org/groups/358366/items/D9KQXSXB"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:BHO"/><title level="m">Bibliotheca hagiographica orientalis</title><title type="short">BHO</title><title level="s">Subsidia Hagiographica</title><author><name>Socii Bollandiani</name></author><pubPlace>Bruxellis–Beyrouth</pubPlace><publisher>Apoud Editores–Imprimerie Catholique</publisher><date>1910</date><series><title level="s">Subsidia Hagiographica</title><biblScope unit="volume">10</biblScope></series><biblScope unit="volume">10</biblScope><note type="url">https://archive.org/stream/bibliothecahagi00peet</note><note type="tags"><note type="tag">bm:BHO</note></note><note type="tag">bm:BHO</note><t:citedRange unit="item">429</t:citedRange></t:bibl>
               </t:listBibl>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab>
                     ንንግር፡ ከመ፡ ተጋድለ፡ ምስለ፡ ሰይጣን፡ ወሞአ፡ እንዘ፡ ይትቀነይ፡
                  </t:ab>
               </t:div>
               <t:div type="textpart" subtype="explicit" xml:lang="gez">
                  <t:ab>
                     ወይቀውም፡ ወይጸንዕ። ወበሰማይኒ፡ ቦቱ፡ ይትረከብ፡ ተስፋ፡ ሕይወት፡ ዘኢየኃልፍ፡ <t:gap reason="omitted" extent="unknown"/>
                  </t:ab>
               </t:div>
            </t:div>
         </t:div>

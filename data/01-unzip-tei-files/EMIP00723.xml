               <msContents>
                  <msItem xml:id="ms_i1"><locus from="1r" to="48r" facs="010">Fols 1r–48r</locus><title>Chants called Mäzǝmur, <foreign xml:lang="gez">መጽሐፈ: መዝሙር:</foreign></title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>arranged for the Sundays of the year</note>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="48r" to="71r" facs="057">Fols 48r–71r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <notatedMusic><desc>with musical notation</desc></notatedMusic>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="71r" facs="080">, lower</locus><title>A short poem written for the one who commissioned the manuscript</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>This poem mentions the scribe whose baptismal name is Kidana Maryam, and given name of Liqä Liqawǝnt Ḥägos Täklä, son of Mälǝ’akä Bǝrhanat Täklä Haymanot</note>
                  <incipit type="supplication" xml:lang="gez">
                    ጸማሁ፡ ለኪዳነ፡ ማርያም፡ ዝድጓ። ለቢተ፡፡ክርስቲያን፡ ሠርጓ። ወጸሐፊሁ፡ ኃጥዕ፡ ወአባሲ፡ ዘሰመ፡ ጥምቀቱ፡ ኪዳንእ፡ ማርያም፡<gap reason="omitted"/>ሰላም፡ ለከ፡ ገብረ፡ መስቀል፡ እኁየ። እስመ፡ ልብየ፡ ያፈቅረከ፡
                  </incipit>
                </msItem>
                  <msItem xml:id="ms_i4"><locus from="71v" to="82v" facs="081">Fols 71v–82v</locus><title>Hymns for the Passion Week and for Holy Saturday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <notatedMusic><desc>with musical notation</desc></notatedMusic>
                </msItem>
                  <msItem xml:id="ms_i5"><locus from="83r" facs="092">Fols 83r and following</locus><title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Haleta">Dǝggʷā, Table of
                                                  melodic variations for the Hallelujah (same as
                                                  https://betamasaheft.eu/LIT1110Anqasa)</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>Excerpt from the Variations of Hallelujah</note>
                  </msItem>
               </msContents>


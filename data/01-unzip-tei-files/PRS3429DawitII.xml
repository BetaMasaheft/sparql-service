               <persName xml:lang="en" xml:id="n3" type="alt">Dāwit I</persName>
               <note>Although he was the first Ethiopian emperor by the name of Dāwit, local sources refer to him often
                   as Dāwit II, taking into account the Biblical King David
                  (see  <bibl corresp="http://zotero.org/groups/358366/items/PZUH8EEM"><seg type="encyclopediaArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Derat2005DawitII"/><title level="a">Dawit II</title><title type="short">EAe</title><title level="m">Encyclopaedia Aethiopica</title><author><forename>Marie-Laure</forename><surname>Derat</surname></author><editor><forename>Siegbert</forename><surname>Uhlig</surname></editor><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>2005</date><biblScope unit="volume">II</biblScope><biblScope unit="page">112a-113a</biblScope><note type="tags"><note type="tag">bm:Derat2005DawitII</note></note><note type="tag">bm:Derat2005DawitII</note><citedRange unit="page">112a</citedRange></bibl>).</note>
                  <occupation type="ruler">Emperor</occupation>

               <floruit notBefore="1380" notAfter="1413">He succeeded
                  his brother
                  <persName ref="https://betamasaheft.eu/PRS7559NewayaM">
                     <roleName type="title">ʾaṣe</roleName>
                     Nǝwāya Māryām</persName> in <date>1380</date>.
                  Numerous works are said to have been translated during his reign.
                </floruit>
                  <death when="1413" evidence="internal"/>
            </person>

               

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ እብል፡ ዘአስማቲክሙ፡ ዝክረ፨</l>
                  <l n="2">እንተ፡ ይጥዕም፡ መዐረ፨</l>
                  <l n="3">ሐዋርያት፡ አድባር፡ ዘታተልዉ፡ አውግረ፨</l>
                  <l n="4">ከመ፡ አሐዱ፡ ብእሲ፡ እዌድሰክሙ፡ ምዕረ፨</l>
                  <l n="5">እስመ፡ ንዋየክሙ፡ በንዋዩ፡ ኢየሱስ፡ ደመረ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘጥቀ፡ አፍታዊ፨</l>
                  <l n="2">እምፍትወተ፡ ዓለም፡ ምድራዊ፨</l>
                  <l n="3">ሐዋርያት፡ ጽኑዓን፡ ዕቀብተ፡ አንቀጽ፡ ሰማያዊ፨</l>
                  <l n="4">ጽንሑኒ፡ ታብኡኒ፡ ውስተ፡ ጽርሐ፡ ሥርግው፡ መርዓዊ፨</l>
                  <l n="5">ከመ፡ ብእሲ፡ ከብካብ፡ ጽውዐ፡ ይጸንሕ፡ ዐፃዊ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስክሙ፡ ዘጥሉል፡ በቅብዑ፨</l>
                  <l n="2">ለመለኮታዊ፡ በግዑ፨</l>
                  <l n="3">ሐዋርያት፡ ስንዕዋን፡ ነገርያኒሁ፡ ወሰብኡ፨</l>
                  <l n="4">ከመ፡ ታንግፉኒ፡ አስተበቍዐክሙ፡ ንዑ፨</l>
                  <l n="5">አመ፡ ላዕሌየ፡ ዕድወ፡ ደም፡ ተንሥኡ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለግንዘትክሙ፡ በስንዱናተ፡ ኪን፡ ዘፈተሎ፨</l>
                  <l n="2">ወለመቃብሪክሙ፡ ኵሎ፨</l>
                  <l n="3">ሐዋርያት፡ በልዎ፡ ለዘይፃረረኒ፡ በተሐብሎ፨</l>
                  <l n="4">ይኂስከ፡ እግዚአብሔር፡ ወያርኢከ፡ ኀይሎ፨</l>
                  <l n="5">ከመ፡ ሚካኤል፡ ቅድመ፡ ለሰይጣን፡ ይቤሎ፨</l>
               </lg>
            </div>
         </div>
      </body>

         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q1358506">
         
                  <t:persName>
                     <t:forename>Ernst</t:forename>
                     <t:surname>Hammerschmidt</t:surname> 
               </t:persName>
                  
                  <t:occupation type="academic">scholar</t:occupation>
                  <t:nationality type="Germany"/>
                  <t:faith type="Catholicism"/>
                  <t:birth when="1928"/>
                  <t:floruit notBefore="1958" notAfter="1993">He was a prominent scholar of Ethiopian Studies 
                     who succeeded in the institutionalization of the discipline 
                     within the German language Oriental studies framework.
                     He studied Oriental languages, theology and law from <t:date>1946</t:date> to <t:date>1958</t:date>.
                     In <t:date>1958</t:date>, he was ordained as an old Catholic priest. 
                     In <t:date>1968</t:date>, he was appointed as Extraordinary Professor in
                     the University of Saarbrücken. In <t:date>1970</t:date>, he became a full Professor of African Studies in the University of <t:placeName ref="https://www.wikidata.org/entity/Q1055">Hamburg</t:placeName> 
                     where he lectured Ethiopian Studies, Codicolgy, Gǝʿǝz, Ethiopian Church and history in the focus of his attention.
                     He was also the founder of Aethiopistische Forschungen,
                     the only scholarly monograph series specializng exclusively in Ethiopian Studies.
                     He also catalogued the Ethiopian manuscripts from the libraries of Lake 
                     <t:placeName ref="https://www.wikidata.org/entity/Q116685">Lake Tana</t:placeName> and published in <t:date>1983</t:date>. 
                     He assembled a rich specialized private library today in possession of Asia-Africa-Institute, 
                     University of Hamburg. </t:floruit>
               <t:death when="1993">He died at <t:placeName ref="https://www.wikidata.org/entity/Q1741">Vienna</t:placeName> in <t:date>1993</t:date>. 
               </t:death>
               </t:person>
               
         </t:listPerson>
         
         

         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3255/" n="203" corresp="https://betamasaheft.eu/api/iiif/EMIP03255/manifest">Antippas 5</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1"><locus from="5r" to="196r" facs="005">Fols 5r–196r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="5r" to="153v" facs="005">Fols 5r–153v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> from the common new system</note>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="154r" to="169r" facs="154">Fols 154r–169r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>The fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>“Prayer of Hana, mother of Samuel, prophet.”</q></note>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="169v" to="177r" facs="170">Fols 169v–177r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Common edition</note>
                  </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="178r" to="191v" facs="178">Fols 178r–191v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Arranged for the days of the week, beginning on Monday and culminating on Sunday</note>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                    <locus from="192r" to="196r" facs="192">f. 192r-196r and completed on
                    </locus><locus from="1v" to="2r" facs="002">1v–2r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Written in a different hand</note>
                </msItem>
              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">196</measure>
                           <dimensions type="outer" unit="mm">
                              <height>140</height>
                              <width>100</width>
                              <depth>60</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="15">
                         <locus from="5r" to="177r" facs="005">Fols 5r–177r</locus>
                       </layout>
                       <layout columns="2" writtenLines="17">
                         <locus from="2r" to="2v" facs="002">Fols 2r–2v, </locus>
                         <locus from="178r" to="196r">178r–196r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is systematically rubricated</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#3r" facs="003">Fol. 3r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName> (left) and another saint</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#3v" facs="004">Fol. 3v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> (right) before a crowd</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#4r" facs="004">Fol. 4r</locus><desc>A crowd (left) following a man holding a hand cross</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#4v" facs="005">Fol. 4v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#177v" facs="178">Fol. 177v</locus><desc>God (or a saint) hovering in a cloud, giving directions to an angel (left) with sword drawn</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#196v" facs="197"> f.196v, top</locus><desc>groups of <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#196v" facs="197"> f. 196v, bottom</locus><desc>individual <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref></desc></decoNote>
                    <decoNote type="frame" xml:id="d8"><locus target="#67r" facs="067">Fol. 67r</locus> the harag at <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps61"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps61</span></ref> is in the style of the Menilek/Selassie scriptorium</decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                      <desc>The quire numbers are highly ornate</desc>
                    </item>
                    <item xml:id="e2">
                      <locus target="#84r" facs="084">Fol. 84r</locus>
                      <desc>The midpoint is indicated in the base hand by micrography, and in a note,
                        <q><foreign xml:lang="am">የዳዊት እኩሌታ ነው፡</foreign></q>, in Amharic, written in black ink or pencil, in a secondary hand</desc>
                    </item>
                    <item xml:id="e3">
                      <desc>
                        There are marginal notations from the strophe counting system;
                        a later hand has systematically marked every tenth strophe with the number 10 in the left margin</desc>
                    </item>
                    <item xml:id="e4">
                      <desc>Occasionally, the superscriptions are written in the pink fluorescent ink of the early twentieth century
                        (e.g., <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps86"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps86</span></ref><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps87"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps87</span></ref>
                    </desc>
                    </item>
                  </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="leather"/>
                        <material key="textile"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1950">Early-twentieth century</origDate>
                  </origin>
               </history>
            </msDesc>

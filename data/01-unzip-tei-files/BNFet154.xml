                  <msItem xml:id="ms_i1">
                    
                    <title type="complete" xml:lang="la">Lexicon æthiopico-latinum</title> 
                    <textLang mainLang="gez" otherLangs="la"/>
                    <note>This volume consists of the first edition of <persName ref="https://betamasaheft.eu/PRS6378Ludolf">Hiob Ludolf</persName>'s
                      <foreign xml:lang="la">Lexicon</foreign>, interleaved with some comments and corrections by <persName ref="https://betamasaheft.eu/PRS6378Ludolf">Hiob Ludolf</persName>.
                    There are less notes added to the dictionary and more to the grammar than in <ref type="mss" corresp="https://betamasaheft.eu/BNFet153">Paris, Bibliothèque nationale de France, BnF Éthiopien 153</ref>.</note>
                    <listBibl type="secondary">

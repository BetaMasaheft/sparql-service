               <msContents>
                  <summary>Canticle of the Flower, ማሕሌተ፡ ጽጌ፡  Book of the Dead, Mäṣḥafä Mutan, መጽሓፈ፡ ሙታን፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="47r" facs="003">Fols 1r–47r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="47v" to="56r" facs="050">Fols 47v–56r</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i2.1">
                    <locus from="47v" facs="050">Fols 47v and following</locus>
                    <title>Instructions</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2.2">
                    <locus from="47v" to="56r" facs="050">Fols 47v–56r</locus>
                    <title>the Prayer</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                </msItem>

               </msContents>

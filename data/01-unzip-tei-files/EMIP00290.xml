                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word Mary is rubricated</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#iiv(erso)" facs="003"> f. iiv(erso), bottom (written upside down)</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT6375HeavenOpen">Rǝḫwa samāy</title>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="ReceiptNote">
                    <locus target="#iv(erso)" facs="002"> f. iv(erso) (written upside down)</locus>
                    Date on which the owner sold the book: Yäkkatit 6, 1923 E.C. (= February 13, 1931)
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                    Warning against writing in the book, in red pen
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                    Three names in blue ink, Habtä Gäbrǝ’el, Abärraš, and Maräfiya
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    <locus target="#56r" facs="058">Fol. 56r</locus>
                    Note of ownership, Täklä Iyyäsus
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#56v" facs="059">Fol. 56v</locus>
                    pen trials
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc>
                    <locus target="#Inside back cover" facs="059">Fols. Inside,, </locus>
                    The titles of the two main works are given
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    marginal notation to mark readings
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                      words of text are written interlinearly (<locus target="#15v #25v #41v" facs="018 028 044">fols. 15v, 25v, 41v</locus>)
                    </desc>
                    </item>
                  </list>
                </additions>

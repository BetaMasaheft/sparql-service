                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red (brilliant red)</seg>
                        <date notBefore="1900" notAfter="1930">Early 20th-century script</date>
                        <seg type="rubrication"> Nomina sacra; the word <foreign xml:lang="gez">salām</foreign>; several lines or groups of lines in the incipit page
                           of the commemorative notices for each month; one or two initial lines of
                           each commemorative notice; elements of punctuation signs throughout the
                           Ms. (e.g., nine dot asterisks in red and black, separating the
                           commemoration notes; chains of red and black dots and nine dot asterisks
                           separates the months Maskaram and Ṭǝqǝmt on <locus target="#42r"/>);
                           elements of Ethiopian numerals. </seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- The readings for the next three months (Taḫśaś, Ṭǝrr, Yäkkatit) are given in Ms. MR-041. - A line of numbers is written in pencil on <locus target="#110r">fol.  110r</locus>. - The beginning lines of the Prayer Zä-ʾaqräbku maḫletä..., often recited after Synaxarion readings, was started on <locus target="#110v">fol.  110v</locus> (cp. Mss. FBM-003, FBM-007, MR-041, DD-37). It is incomplete, and crudely written in red (modern) pen. - No name of a commissioner or owner is mentioned.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards covered with reddish-brown tooled
                           leather; textile inlays. Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                           <material key="textile"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other"/>
                        <decoNote xml:id="b5">Blind tooled ornament visible on front and back cover
                           (8 tools were used: criss cross, triple line fillet, small x, x-form,
                           type of double sine waves with dots, double circle, corniform, cross
                           hatching).</decoNote>
                     </binding>

                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word God is not rubricated in the first three works</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#3r" facs="005">Fol. 3r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s holding <term key="sword" ana="#sword"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#3v" facs="006">Fol. 3v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#42r" facs="044">Fol. 42r</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#42v" facs="045">Fol. 42v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1015Flagellation">Flagellation of Jesus</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d5"><locus target="#43r" facs="045">Fol. 43r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d6"><locus target="#43v" facs="046">Fol. 43v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d7"><locus target="#50v" facs="053">Fol. 50v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John stand beside the <term key="cross" ana="#cross"/></desc></decoNote>
                  <decoNote type="miniature" xml:id="d8"><locus target="#94r" facs="096">Fol. 94r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                  <decoNote type="miniature" xml:id="d9"><locus target="#94v" facs="097">Fol. 94v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d10"><locus target="#95r" facs="097">Fol. 95r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/> with lions and leopards</desc></decoNote>
                  <decoNote type="miniature" xml:id="d11"><locus target="#108v" facs="111">Fol. 108v</locus><desc>crude drawing of a face</desc></decoNote>
                  <decoNote type="miniature" xml:id="d12"><locus target="#109r" facs="111">Fol. 109r</locus><desc>Simple drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref></desc></decoNote>
                  <decoNote type="frame" xml:id="d13">
                  Decorative designs:
                  <locus target="#5r #53r #90v #96r #108r" facs="007 055 093 098 110">folss. 5r, 53r, 90v, 96r, 108r, </locus> (line of alternating red and black dots);
                  <locus target="#10r #19v #25v #28v #50r #61r #71v #77r #81v #82r" facs="012 022 028 031 052 063 074 079 084">10r, 19v, 25v, 28v, 50r, 61r, 71v, 77r, 81v, 82r, </locus> (secondary ornamental band);
                  <locus target="#5r #61r #71v #102v #104r" facs="007 063 074 105 106">5r, 61r, 71v, 102v, 104r</locus> (multiple full stops)
                  </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    A number of folios are missing from the manuscript (e.g., between <locus target="#1v #2r" facs="004">folss. 1v, 2r, </locus> and between <locus target="#71v #72r" facs="074">71v, 72r, </locus>). Additionally, a number of Psalms are numbered incorrectly (e.g., on <locus target="#11v" facs="014">11v</locus>, Psalm 33 is numbered 43)
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    There are a number of folios with scrawls and isolated words written by an untrained hand (e.g., <locus target="#1r #8v #104v #106v" facs="003 011 107 109">fols. 1r, 8v, 104v, 106v</locus>)
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    The Trinitarian Formula in an untrained hand
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#iv(erso)" facs="002"> f. iv(erso), top</locus> and <locus target="#iir(ecto)" facs="002">iir(ecto)</locus>
                    pen trials of the syllabary (<foreign xml:lang="gez">ፊዳል፡</foreign> ʿfidalʾ)
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#iv(erso)" facs="002"> f. iv(erso), bottom</locus>
                    pen trial on the beginning of <title type="incomplete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa
                                                  Mikāʾel</title>. Written in blue ink
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <desc>
                    <locus target="#39r" facs="041">Fol. 39r</locus>
                    The midpoint of the Psalms is not marked
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                    <locus target="#108r" facs="110"> f. 108r, middle</locus>
                    erased text
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc type="ReceiptNote">
                    <locus target="#108r" facs="110"> f. 108r, bottom</locus>
                    An inventory or receipt. Written in purple ink
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <desc>
                    <locus target="#109v" facs="112">Fol. 109v</locus>
                    illegible text and pen trials
                    </desc>
                    </item>
                    <item xml:id="e10">
                    <desc>
                    Numbered quires: quires 3–5 and 8. Illegible quire numbers on <locus target="#64r #72r" facs="066 074">fols. 64r, 72r</locus>
                    </desc>
                    </item>
                    <item xml:id="e11">
                    <desc>
                      words of text are written interlinearly (<locus target="#1r #4r #4v #5v #6r" facs="003 006 007 008">folss. 1r, 4r, 4v, 5v, 6r, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#9r #14v #24r #34r #47r" facs="011 017 026 036 049">9r, 14v, 24r, 34r, 47r, </locus>, etc.);
                      text has been removed (<locus target="#12r #13v #22v #27r #29r" facs="014 016 025 029">12r, 13v, 22v, 27r, 29r</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, back cover has broken and been repaired.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

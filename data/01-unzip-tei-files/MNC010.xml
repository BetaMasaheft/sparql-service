                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="4r" to="40r"/>
                        <seg type="ink">Black, red (different tones of red)</seg>
                        <date notBefore="1700" notAfter="1899">eighteenth or nineteenth
                           century</date>
                        <seg type="script">Careful but somewhat irregular hand. The scribe wrote the
                           last three lines of <ref target="#ms_i3"/> in small script in order to
                           complete the section on the same folio <locus target="#33v"/>. Characters
                           are occasionally set at wide intervals to fill the line at the end of a
                           text (e g. <locus target="#34v #35r"/>).</seg>
                        <seg type="rubrication">Two initial lines, and occasionally two more lines
                           further down, in the incipit of all texts; first word of each stanza of
                              <ref target="#ms_i1 #ms_i3 #ms_i8"/>; holy names; the name of the
                           apparent owner <persName role="owner" ref="https://betamasaheft.eu/PRS13232EhetaMar">ʾƎḫǝta Māryām</persName>; elements
                           of the punctuation marks, text dividers, and numerals.</seg>
                        <list type="abbreviations">
                           <item>
                              <abbr>መ፡</abbr> for <expan>መለኮት፡</expan> (<ref target="#ms_i8"/>)
                           </item>
                        </list>
                     </handNote>

                     <handNote xml:id="h2" script="Ethiopic" corresp="https://betamasaheft.eu/MNC010#a1">
                        <locus from="2r" to="2v"/>
                        <seg type="ink">Black</seg>
                        <desc>Mediocre. Broad script with hairlines.</desc>
                     </handNote>
                  </handDesc>


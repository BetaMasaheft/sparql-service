               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="19r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172"><foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS6819Mary">Māryām</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 63 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#4r"/>
                        <pb n="4r"/>
                        <hi rend="rubric">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ። እምነ፡ ከልበኔ፡ ወቍ</hi>ስጥ፡ ወእምነ፡
                        ሰንበልት፡ ምዑዝ። <hi rend="rubric">ማርያም፡</hi> ድንግል፡ ለባሲተ፡ ዓቢይ፡ ትእዛዝ። ይስቅየ<hi rend="rubric">ኒ፡ ለለጽባሑ፡ ወይነ፡ ፍቅርኪ፡ አዚዝ። ከመ፡ ይሰቅዮ፡ ውኂ</hi>ዝ፡ ለሠናይ፡ አርዝ
                        ።</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#19r"/><hi rend="rubric">እግዚአብሔ<add place="interlinear">ር፡</add></hi> ኀቤኪ፡ ፈነወ፡ ቃሎ። በአምሳለ፡ ገብርኤል፡ አስተማሲሎ። <hi rend="rubric">ማርያም፡</hi> አምላከ፡ ዘወለድኪ፡ በተደንግሎ። ሰላም፡ ሰላም፡ ወሰላም፡ እብሎ። ለመልክዕኪ፡ <hi rend="rubric">ማርያም፡</hi> ፈጺምየ፡ ኵሎ።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus target="#19v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5050Mary16Yakkatit"><foreign xml:lang="gez">Salām</foreign>-hymn to <persName ref="https://betamasaheft.eu/PRS6819Mary">Mary</persName></title>
                     <textLang mainLang="gez"/>
                     <note>See the transcription in <ref target="#Salam"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="20r" to="33v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123"><foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS5684JesusCh">ʾIyasus</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 56 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#20r"/>
                        <pb n="20r"/>
                        <hi rend="rubric">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይኄሱ። ዘአንበረ፡ ቅድመ፡</hi> አግዚአብሔር፡
                        በአትሮንሱ። <hi rend="rubric">ኢየሱስ፡ ክርስቶስ፡</hi> ለዳዊት፡ ባሕርየ፡ ከርሡ። አክሊለ፡ ስምከ፡ እንዘ፡
                        ይትቄጸል፡ በርእሱ። አኅጉረ፡ ፀር፡ ወረሰ፡ ኢያሱ።</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#33v"/><hi rend="rubric">አምላከ፡</hi> ምድር፡ ወሰማያት፡ አምላከ፡ ባሕር፡
                        ወቀላያት። ወአምላከ፡ ኵሉ፡ ፍጥረት። አምላኮሙ፡ አንት፡ ለአበው፡ ቀደምት። አምላኮሙ፡ ለመላእክት፡ አምላከ፡ ለነቢያት፡
                        ወሐዋርያት። አምላከ፡ ጻድቃን፡ ወሰማዕት። መሐረነ፡ ለነ፡ አምላክነ፡ እስመ፡ ግብረ፡ እዴከ፡ ንሕነ። ወኢትዝክር፡ ኵሎ፡
                        አበሳነ።</explicit>
                  </msItem>


                  <msItem xml:id="ms_i8">
                     <locus from="35v" to="38v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4963Naahabeya">Naʿā ḫabeya ʾo-ʾǝgziʾǝya ʾIyasus Krǝstos</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#35v"/>
                        <hi rend="rubric">ነዓ፡ ኀቤየ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአ</hi><del rend="expunctuated effaced" cause="dittography">እግዚአ</del>ብሔር፡ ሕያው። ወወልደ፡
                           <hi rend="rubric">ማርያም፡</hi> ሥግው። መ<del rend="effaced" cause="superfluous">ለ</del>ብረቀ፡ <hi rend="rubric">መለኮት፡</hi> መደንግፅ። ፍሕመ፡
                           <hi rend="rubric">መለኮት፡</hi> ብቁጽ። ሐፀ፡ <hi rend="rubric">መለኮት፡</hi>
                        ርውፅ።</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#38v"/>እጼለል። ሳዶር፡ አላዶር፡ ዳናት፡ አዴራ፡ ሮዳስ፡ በዝንቱ፡ አስማተ፡ ፭ ቅንዋተ፡
                        መስቀሉ፡ ለእግዚእነ፡ <hi rend="rubric">ኢየሱስ፡ ክርስቶስ፡</hi> ዘቦቱ፡ ለስሐ፡ ሕምዙ፡ ለሞት።
                        ወተቀጥቀጠ፡ ኃይሎሙ፡ ለሰይጣናት። ከማሁ፡ ይልሳሕ፡ ሕምዞሙ፡ ለአጋንንት፡ ወይትቀጥቀጥ፡ ኃይሎሙ፡ ለሰይጣናት፡ ከመ፡
                        ኢይቅረቡ፡ ኀበ፡ ነፍሳ፡ ወሥጋሃ፡ ለዓመትከ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS13232EhetaMar">ʾƎḫǝta Māryām<hi rend="rubric">እኅተ፡ ማርያም።</hi></persName> ለዓለመ፡ ዓለም።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i9">
                     <locus target="#39r"/>
                     <title ref="https://betamasaheft.eu/LIT2715John">Excerpt from the Gospel of <persName ref="https://betamasaheft.eu/PRS5695John">John</persName></title>
                     <note>The excerpt comprises <ref type="work" corresp="https://betamasaheft.eu/LIT2715John.1.1-5">John
                           1,1–1,5</ref>.</note>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#39r"/>
                        <pb n="39r"/>
                        <hi rend="rubric">ቀዳሚሁ፡ ቃል፡ ውእቱ፡ ወውእቱ፡ ቃል፡ ኀበ፡ እግዚአብሔር፡ ው</hi>እቱ። ወእግዚአብሔር፡
                        ውእቱ፡ ቃል።</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#39r"/>ወጽልመትኒ፡ ኢይረክቦ፡ ወኢይቀርቦ።</explicit>
                  </msItem>


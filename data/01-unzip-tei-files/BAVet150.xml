                    <msContents>
                      <summary/>
                      
                      <msItem xml:id="ms_i1">
                        <locus from="3r" to="14v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                        <textLang mainLang="gez"/>
                      <explicit xml:lang="gez">
                        እስመ። ማርያምሰ፡ እግዝእትነ፡ ቅድስት፡ ይእቲ፨ ወትረ። በሰማይ፡ ወበምድር፡ ጸሎታ፡ ውኩፍ፡ ወበረከታ፡ ትሩፍ፨ <sic>ለዓለም፡</sic> ዓለም፡ አሜን፨
                        <seg type="supplication">ኦእግዝእትየ፡ ማርያም፡ እቀብኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፨ ሊተ፡ ለገብርኪ፨ <persName role="owner" ref="https://betamasaheft.eu/PRS14403WaldaG">ወልደ፡ ጊዮርጊስ።</persName> </seg>
                      </explicit>
                      </msItem>
                      
                      <msItem xml:id="ms_i2">
                        <locus from="15r" to="18r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          ሰላም፡ ለጽንሰትከ፡ መሰረተ፡ ነገር፡ ወውጣኔ። ወለልደትከ፡ ሰላም፡
                        </incipit>
                        <explicit xml:lang="gez">
                          ሰላም፡ ለሃገሩ፡ ወሰላም፡ ለደብሩ፡ ወሰላም፡ ለመቃብሩ፡ ገብረ፡ መንፈስ፡ ቅዱስ፡ አቡየ፡ ለእግዚአብሔር፡ ፍቁሩ፨ ደመናት፡ 
                          <choice><corr>ዓንኰርኰሩ፨</corr><sic>ዓንኵርኵሩ፨</sic></choice> አዕዋፈ፡ ሰማይ፡ ዘመሩ፨
                          በጊዜ፡ ሞትከ፡ መላእክት፡ አንከሩ፨ <seg type="supplication">ኦአምላከ፡ ገብረ፡ መንፈስ፡ ቅዱስ፡ <sic>ዕቀብኒ፡</sic> ወአድኅነኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፨ ለገብርከ፨ 
                          <persName role="owner" ref="https://betamasaheft.eu/PRS14403WaldaG">ወልደ፡ ጊዮርጊስ።</persName> </seg>
                        </explicit>
                      </msItem>
                      

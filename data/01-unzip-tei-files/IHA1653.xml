                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_5294">
                           <locus target="#Envelope">-Envelope</locus>
                           <q xml:lang="ar">يصل جناب الاخ العزيز الشيخ ابا جهاد بن ابى الفضل التجانى دام قدره وزاد فخر ءامين</q>

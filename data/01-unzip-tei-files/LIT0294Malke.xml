         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ብዝኀ፡ ውዳሴከ፡ ዘልፈ፡ ሶበ፡ ትፈቅድ፡ ነፍስየ፨</l>
                  <l n="2">በሕገ፡ ሥጋ፡ ወደም፡ ይደክመኒ፡ ኀይልየ፨</l>
                  <l n="3">ዮርጊስ፡ ዳእሙ፡ ተስጥወኒ፡ ቃልየ፨</l>
                  <l n="4">ወሰከኒ፡ በኪዳንከ፡ ከመ፡ አፉየ፡ ጸለየ፨</l>
                  <l n="5">ሞገሰ፡ ስምከ፡ ያሞግሶ፡ ስምየ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እንተ፡ የዐውዶ፡ መዐዛ፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ጽሑድ፡ ዘርእስከ፡ አክሊለ፡ ቤዛ፨</l>
                  <l n="3">ጊዮርጊስ፡ ኀያል፡ ፍጡነ፡ ረድኤት፡ ከመ፡ ሰኬዛ፨</l>
                  <l n="4">ያድኅነኒ፡ ደመ፡ ስምዕከ፡ ለንኡሰ፡ ወሬዛ፨</l>
                  <l n="5">እምባሕለ፡ ልሳን፡ ስክርት፡ ዘይቅትል፡ ሕምዛ፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ሰላም፡ ለመልክእከ፡ በደመ፡ ስምዕ፡ ዘተሐፅበ፨</l>
                  <l n="2">ጊዜ፡ ፍልጠተ፡ ነፍስ፡ እምሥጋ፡ አመጽዋዐ፡ ሰይፍ፡ ሰረበ፨</l>
                  <l n="3">ጊዮርጊስ፡ ንሥአኒ፡ ከመ፡ እኩን፡ ማዕተበ፨</l>
                  <l n="4">ወምላእ፡ ውስተ፡ ልብየ፡ ወመጠነ፡ ኆፃ፡ ባሕር፡ ጥበበ፨</l>
                  <l n="5">እምነ፡ ፍቅር፡ ኢታፈቅር፡ መዝገበ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋከ፡ ግብረ፡ ትንሣኢሁ፡ ዘሰበከ፨</l>
                  <l n="2">ወለግንዘትከ፡ ሰላም፡ ምስለ፡ ገባሬ፡ ኀይል፡ ዝኅርከ፨</l>
                  <l n="3">መሥዋዕተ፡ አምልኮ፡ እንተ፡ ዘተክዕወ፡ ደምከ፨</l>
                  <l n="4">ይትፌሥሐኒ፡ ኅሊናየ፡ ሶበ፡ እጼሊ፡ ኪያከ፨</l>
                  <l n="5">ውስተ፡ ሰማያት፡ አጥረይኩ፡ አርከ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ጊዮርጊስ፡ ተወክፍ፡ አምኃ፡ ሰላምየ፡ ዘፍቅር፨</l>
                  <l n="2">ወተናበብ፡ ቃለ፡ በልሳነ፡ ሰማይ፡ ወምድር፨</l>
                  <l n="3">ሊተኒ፡ ለሕጹጸ፡ ጥበብ፡ ወምክር፨</l>
                  <l n="4">አንብረኒ፡ ከመ፡ ሕልቀት፡ ውስተ፡ ልብከ፡ ክቡር፨</l>
                  <l n="5">እምነ፡ ዛቲ፡ ትውልድ፡ እስመ፡ ሐልቀ፡ ኄር፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ነዓ፡ ኀቤየ፡ እግዚኦ፡ ጸሎተ፡ ልብየ፡ እጼሊ፨</l>
                  <l n="2">እንዘ፡ እትአመን፡ ኀይለከ፡ ወረድኤትከ፡ እሔሊ፨</l>
                  <l n="3">ከመ፡ እስራኤል፡ ድኅኑ፡ እመልአከ፡ ሞት፡ በደመ፡ ጠሊ፨</l>
                  <l n="4">አድኅነኒ፡ ወባልሐኒ፡ ጊዜ፡ ተንሥአ፡ ቀታሊ፨</l>
                  <l n="5">በደመ፡ ስምከ፡ ዘተክዕወ፡ ጊዮርጊስ፡ ከሃሊ፨</l>
               </lg>
            </div>
         </div>
      </body>

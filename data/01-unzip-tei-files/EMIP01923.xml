                  <locus target="#78v #133r #154v #160r" facs="083 137 159 164">78v, 133r, 154v, 160r, </locus> (multiple full stops);
                  <locus target="#121v #163r" facs="126 167">121v, 163r</locus> (multiple full stops between lines of red and black dots)
                  </decoNote>

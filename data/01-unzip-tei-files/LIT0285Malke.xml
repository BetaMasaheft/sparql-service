         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እንዘ፡ እሴፎ፡ ረድኤተክሙ፡ በጊዜ፡ ምንዳቤ፡ ወተፅናስ፨</l>
                  <l n="2">ከመ፡ ይርድአኒ፡ ሊተ፡ በአፀደ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="3">ሕፃናት፡ ኄራን፡ ወንጹሓን፡ እምርኵስ፨</l>
                  <l n="4">ናሁ፡ ወጠንኩ፡ ሰላመክሙ፡ በብርሃነ፡ ጥበብ፡ ቅዱስ፨</l>
                  <l n="5">ጽልመተ፡ ኅሊናየ፡ ያብርህ፡ ኢየሱስ፡ ክርስቶስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ በሰላመ፡ አምላክ፡ እብኖዲ፨</l>
                  <l n="2">ወሰላም፡ ካዕበ፡ ለሥዕርተ፡ ርእስክሙ፡ ዓዲ፨</l>
                  <l n="3">ሕፃናት፡ ኄራን፡ አዝማደ፡ ዮሐንስ፡ ቃለ፡ ዐዋዲ፨</l>
                  <l n="4">እፎ፡ ተክዕወ፡ ደምክሙ፡ በትእዛዘ፡ ሄሮድስ፡ ከሓዲ፨</l>
                  <l n="5">ማሕተመ፡ ሞት፡ ዘነሥአ፡ እምሰይጣን፡ ረዋዲ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ናሁ፡ አብጻሕኩ፡ ሰላመክሙ፡ በኍልቈ፡ ውሳኔ፡ ሠላሳ፨</l>
                  <l n="2">ዘውእቱ፡ መንፈቀ፡ ስሳ፨</l>
                  <l n="3">ሕፃናት፡ ኄራን፡ ኅሩማነ፡ በቀል፡ ወአበሳ፨</l>
                  <l n="4">ቅድመ፡ አምላክ፡ ኰናኒ፡ አመ፡ ይከውን፡ ኀሠሣ፨</l>
                  <l n="5">አክሊለ፡ ጽድቅ፡ ለነፍስየ፡ አንብሩ፡ በርእሳ፨</l>
               </lg>
            </div>
         </div>

                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#118v"/>
                                    <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT3107RepCh387">Hymn to St Cyriacus</title>, copied by <persName role="scribe" ref="https://betamasaheft.eu/PRS13625Abreham">ʾAbrǝhām</persName>.</desc>
                                    <q xml:lang="gez">
                                        <seg part="I">
                                            <hi rend="rubric">ይትባረክ፡ እግዚአብሔር፡ ለክብርከ፡ ዘደ</hi>መራ<hi rend="rubric">፨</hi> በክብረ፡ ዛቲ፡ መቅደስ፡ ለማኅደረ፡ አምላክ፡
                                            ማኅደራ<hi rend="rubric">፨</hi> <hi rend="rubric">ህርያቆስ፡</hi> ካህና፡ ለደብረ፡ ሊባኖስ፡ ደብተራ<hi rend="rubric">፨</hi>
                                            ባሕቱ፡ ይዘምር፡ ውሣጤሃ፡ ምስለ፡ መንፈሳዊት፡ እንዚራ<hi rend="rubric">፨</hi> ዳዊት፡ ይምጻእ፡ ወኢይትርፍ፡ እዝራ<hi rend="rubric">፨</hi>
                                        </seg>
                                        <gap reason="ellipsis" resp="DR"/>
                                        <seg part="F"><hi rend="rubric">ሰላም፡ ለከ።</hi> ዘክርስቶስ፡ ጻድቅ፡ ወየማነ፡ አብ፡ አቡከ<hi rend="rubric">፨</hi>
                                            ዘክርስቶስኒ፡ ወእምቅድሜከ፡ <hi rend="rubric">ህርያቆስ፡ </hi>ኅዳጠ፡ እስመ፡ ወደስኩ፡ ለባርኮትየ፡ ይምጽኡ፡ ምስሌከ<hi rend="rubric">፨</hi></seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#119r"/>
                                    <desc type="LandGrant">Deed of the reign of <persName ref="https://betamasaheft.eu/PRS8421Salomon">Salomon I</persName> or <persName ref="https://betamasaheft.eu/PRS8422Salomon">Salomon II</persName>.</desc>
                                    <q xml:lang="am">የ<persName ref="https://betamasaheft.eu/PRS13626WaldaS">ወይዘሮ፡ ወልደ፡ ሰላን፡</persName> ፻ውን፡ የዙፋኑን፡ ምድር፡ 
                                        ወይዘሮ፡ <persName ref="https://betamasaheft.eu/PRS13627Tesal">ትሻል፡</persName> ። ፳፯ወቄት፡ ጠፉበት፡ በአጼ፡ ዳዊት፡ ልጅ፡ በአጼ፡ ሰሎሞን፡ መንግሥት፡
                                        በ<persName ref="https://betamasaheft.eu/PRS13628Tasfu">ይጨጌ፡ ተስፉ፡</persName> እጨግነት፡ በ<persName ref="https://betamasaheft.eu/PRS13629Safonyas">ጸባቱ፡ ሰፎንያስ፡</persName> ጸባትነት፡ 
                                        በ<persName ref="https://betamasaheft.eu/PRS13630Zaagaezt">መጋቢ፡ ዘዓጋእዝት፡</persName> መጋብነት፡ በ<persName ref="https://betamasaheft.eu/PRS13631Marqoryos">ቄስ፡ ገበዝ፡ መርቆርዮስ፡</persName> ገበዝነት፡ ከሞቱም፡ በኻላ፡
                                    ፰ወቄት፡ ለፍታትና፡ ለተዝካር፡ ሠጡ፡ ይህነን፡ መሥጠተዎ፡ በአይራ፡ በጓሪ፡ በአቡነ፡ አረጋዊ፡ ባለው፡ ምድር፡ ነው፡ ዘሠረቆ፡ ወዘፈሐቆ፡ ውጉዘ፡ ለይኩን፡ 
                                    በሥልጣነ፡ ጴጥሮስ፡ ወጳውሎስ፡</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#1r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ስንክሳር፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                                    </q>
                                </item>
                                
                                <item xml:id="e1">
                                    <desc>The name of the owner was ʾAbuna Hǝryāqos.  It might be speculated whether this person is identical with
                                        <persName ref="https://betamasaheft.eu/PRS5306Heryaqos">Hǝryāqos</persName>, who is apparently commemorated in the guest text <ref target="#a1"/>.</desc>
                                </item>
                            </list>
                            
                        </additions>
                        

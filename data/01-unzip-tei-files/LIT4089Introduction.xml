      <t:profileDesc xmlns:t="http://www.tei-c.org/ns/1.0">
         <t:abstract>
            <t:p>Chronological summary attributed to <t:persName ref="https://betamasaheft.eu/PRS4711Giyorgis">Giyorgis Walda ʾAmid</t:persName>,
               including a brief chronology of biblical kings, probably an extract from the 
               <t:ref type="work" corresp="https://betamasaheft.eu/PRS4711Giyorgi">Tārika Walda ʾAmid</t:ref>, followed by an outline of Ethiopian kings.
               It was possibly compiled in <t:date notBefore="1600" notAfter="1705" cert="low">the 17th or begin of the 18th century</t:date> by
               an unknown Ethiopian author and later included as an introduction to the <t:ref type="work" corresp="https://betamasaheft.eu/LIT2352ShortC">Short chronicles</t:ref>.</t:p>
         </t:abstract>
         <t:langUsage><t:language ident="en">English</t:language></t:langUsage>

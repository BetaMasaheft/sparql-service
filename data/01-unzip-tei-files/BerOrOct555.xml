                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"> <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወ</hi>መንፈስ፡ ቅዱስ፡ <hi rend="rubric">፩</hi>አም<hi rend="rubric">ላክ፡ በስመ፡ እግዚአ</hi>ብሔር፡ አብ፡
                     ዘኢይትዌ<hi rend="rubric">ለጥ፡ እምህላዌሁ።</hi> ወበስሙ፡ ለወልድ፡ እግ<hi rend="rubric">ዚአብሔር፡ ዘኢይተፈ</hi>ለጥ፡ እምህላዌሁ፡ ለአ<hi rend="rubric">ቡሁ።</hi> </incipit>
                     <note>The manuscript is ms M in <bibl corresp="http://zotero.org/groups/358366/items/C7VW5NDM"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Marrassini2003GabraManfasQeddusVersio"/><title level="m">«Vita», «Omelia», «Miracoli» del santo Gabra Manfas Qeddus</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><author><forename>Paolo</forename><surname>Marrassini</surname></author><pubPlace>Lovanii</pubPlace><publisher>Peeters</publisher><date>2003</date><series><title level="s">Corpus Scriptorum Christianorum Orientalium</title><biblScope unit="volume">598, Scriptores Aethiopici, 108</biblScope></series><biblScope unit="volume">598, Scriptores Aethiopici, 108</biblScope><note type="tags"><note type="tag">bm:Marrassini2003GabraManfasQeddusVersio</note></note><note type="tag">bm:Marrassini2003GabraManfasQeddusVersio</note></bibl> and <bibl corresp="http://zotero.org/groups/358366/items/UC5DM6H6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Marrassini2003GabraManfasQeddusTextus"/><title level="m">«Vita», «Omelia», «Miracoli» del santo Gabra Manfas Qeddus</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><author><forename>Paolo</forename><surname>Marrassini</surname></author><pubPlace>Lovanii</pubPlace><publisher>Peeters</publisher><date>2003</date><series><title level="s">Corpus Scriptorum Christianorum Orientalium</title><biblScope unit="volume">597, Scriptores Aethiopici, 107</biblScope></series><biblScope unit="volume">597, Scriptores Aethiopici, 107</biblScope><note type="tags"><note type="tag">Hagiography</note><note type="tag">bm:Marrassini2003GabraManfasQeddusTextus</note><note type="tag">Gabra Manfas Qeddus</note></note><note type="tag">Hagiography</note><note type="tag">bm:Marrassini2003GabraManfasQeddusTextus</note><note type="tag">Gabra Manfas Qeddus</note></bibl>.</note>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red (luminous vivid vermilion and strong amaranth
                           e.g., <locus target="#49v">49v</locus>, 50r).</seg>
                        <date>19th century.</date>
                        <seg type="rubrication">Nomina sacra; a few groups of lines on the incipit
                           page, alternating with black lines; two initial lines of each sub-section
                           of the text; some words like yä-gǝbr (fol. 11rb), baḥrǝy (fol. 15ra),
                           ḥatäta (fol. 45rb), maṣḥaf (fol. 47vb), ʾǝmäbo (e.g., fols. 52ra, 53ra,
                           54rb), ʾǝndih (e.g., fols. 55rb, 60va, 70rb), nägär gǝn (fols. 72va,
                           74ra), etc.; elements of punctuation signs; elements of Ethiopic
                           numerals.</seg>
                     </handNote>
                  </handDesc>

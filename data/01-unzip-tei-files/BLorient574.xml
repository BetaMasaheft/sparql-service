                    <msContents>

                        <msItem xml:id="p1_i1">
                            <locus from="9r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1850Malkea">Malkǝʾa gubāʾe</title>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.1">
                            <locus from="9r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2897RepCh178">To Hanna, the
                                mother of the blessed Virgin Mary</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምኪ፡ እምዝክር፡ ማኅሌት፡ አዳም።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.2">
                            <locus from="16r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3022RepCh302">To the
                                blessed Virgin Mary</title>
                            <incipit xml:lang="gez">ተፈሥሒ፡ ማርያም፡ ለአዳም፡ ፋሲካሁ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.3">
                            <locus from="18r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2932RepCh213">መልክአ፡
                                ፍልሰታ፡</title>
                            <incipit xml:lang="gez">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ ምስለ፡ ነፍስኪ፡ ኢመዋቲ፡ በተሰናዕዎ፡
                                አሐቲ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.4">
                            <locus from="20r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2896RepCh177">መልክዓ፡
                                መጥለሊ፡</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምኪ፡ አምሳለ፡ ስቴ፡ ወይን፡ መጥለሊ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.5">
                            <locus from="21v"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2940RepCh221">ንዒ፡
                                ማርያም፡</title>
                            <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ በአምኃ፡ ሰርካ፡ ወነግሃ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.6">
                            <locus from="22v"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2960RepCh241">መልክዓ፡ አንቀጸ፡
                                ብርሃን፡</title>
                            <incipit xml:lang="gez">ቅድስት፡ ወብፅዕት፡ በልሳነ፡ ኵሉ፡ ዘነፍስ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.7">
                            <locus from="24r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT3017RepCh297">ተማኅፀንኩ፡</title>
                            <incipit xml:lang="gez">ተማኅፀንኩ፡ ተማኅፅኖ፡ ኦእግዝእትየ፡ ድንግል፡ ማርያም፡ ወላዲተ፡ አምላክ፡
                                ለገብርኪ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.8">
                            <locus from="26r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2967RepCh248">በሰማይ፡
                                ወበምድር፡</title>
                            <incipit xml:lang="gez">በሰማይ፡ ወበምድር፡ አልብየ፡ ባዕደ፡ አበ፡ ወእመ፡ እንተ፡
                                ወውሉደ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.9">
                            <locus from="27r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2941RepCh222">በአታ፡ ውስተ፡
                                ቤተ፡ መቅደስ፡</title>
                            <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ባቍዕ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.10">
                            <locus from="30r"/>
                            <title xml:lang="gez" type="complete" ref="https://betamasaheft.eu/LIT2941RepCh222">መልክአ፡ ጻድቃን፡
                                ወሰማዕታት፡</title>
                            <incipit xml:lang="gez">አዳም፡ ወአቤ፡ ሴት፡ ወሄኖስ፡ ቀይናን፡ ወመላልኤል።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.11">
                            <locus from="33r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT6483Hymn">To Antony</title>
                            <incipit xml:lang="gez">በረድኤተ፡ ቅዱስ፡ መንፈስ፡ ኅጡአ፡ ህላዌ፡ እምተረክቦ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.12">
                            <locus from="36r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">To Gabra
                                Manfas Qǝddus</title>
                            <incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ መሠረተ፡ ነገር፡ ወውጣኔ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.13">
                            <locus from="37v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2876RepCh157">To
                                Abib</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዓ፡ በእልፍ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.14">
                            <locus from="40r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3079RepCh359">To
                                Libānos</title>
                            <incipit xml:lang="gez">እገኒ፡ በአፉየ፡ እንዘ፡ እሰግድ፡ በብረክ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.15">
                            <locus from="44r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3076RepCh356">To St
                                Philip</title>
                            <incipit xml:lang="gez">እወጥን፡ ስብሐት፡ ለስብሐቲከ፡ ወአስተዋድድ፡ መዝሙረ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.16">
                            <locus from="48v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3042RepCh322">To
                                Samuel</title>
                            <incipit xml:lang="gez">አኃዝኩ፡ አንሰ፡ ለልየ፡ እምሐኬቱ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.17">
                            <locus from="51r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2956RepCh237">To
                                Eustathius</title>
                            <incipit xml:lang="gez">ቀዳሚሁስ፡ ለዘየአምን፡ በረድኤትከ፡ በኃይል።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.18">
                            <locus from="55v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">To Takla
                                Hāymānot</title>
                            <incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ እምከርሥ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.19">
                            <locus from="61r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">To St
                                George</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.20">
                            <locus from="67v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">To
                                Fāsiladas</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ፀባዖት፡ ዘይትወሐድ፡ በመለኮት።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.21">
                            <locus from="72v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2902RepCh183">To Victor and
                                Claudius</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ መዓዛ፡ ክርስቶስ፡ እምዓዞ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.22">
                            <locus from="75v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2972RepCh253">To St
                                Stephen</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ፩ናሁ፡ ወጠንኩ፡ ሰላመ፡ መልክዕከ፡ ዘበበ፡
                                ፍቅዱ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.23">
                            <locus from="81r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2847RepCh129b">To the angel
                                Rufāʾel</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በአፈ፡ ኵሉ፡ ጥዑም።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.24">
                            <locus from="86v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2885RepCh166">To the angel
                                Fānuʾel</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘይደልዎ፡ ተበፅዖ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.25">
                            <locus from="91v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2846RepCh129">To the angel
                                ʾUriʾel</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ በአፃብዓ፡ ኄኖክ፡ ዘተጠብጠበ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.26">
                            <locus from="96v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3085RepCh365">To the angel
                                Rāguʾel</title>
                            <incipit xml:lang="gez">እጼውዕ፡ ስመከ፡ ወእኤምኅ፡ ራጕኤል፡ መንፈሰ፡ ዓለም፡
                                መስተብቅላ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.27">
                            <locus from="101v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2872RepCh153">To the Four
                                Beasts</title>
                            <incipit xml:lang="gez">ሰላም፡ ለፍጥረትክሙ፡ እምነፋስ፡ ወነድ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.28">
                            <locus from="103r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">To the
                                archangel Michael</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.29">
                            <locus from="107v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">To the angel
                                Gabriel</title>
                            <incipit xml:lang="gez">በሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአዕረፈ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.30">
                            <locus from="111r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">To the holy
                                Trinity</title>
                            <incipit xml:lang="gez">ሰላም፡ ለህላዌክሙ፡ ዘይመውእ፡ ህላዌያተ።</incipit>
                            <textLang mainLang="gez"/>
                            <note><locus from="111" to="115"/> are written in a different hand and appear a somewhat later addition. It cannot be excluded that
                            they constitute a different codicological unit.</note>
                        </msItem>

                        <msItem xml:id="p1_i1.31">
                            <locus from="116r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2901RepCh182">To Abraham,
                                Isaac and Jacob</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ወለሥዕርቲክሙ፡ በፍቅድ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.32">
                            <locus from="117r"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279">To St
                                John</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ እሳት፡ በሐቅለ፡ ሕሊና፡ ነዳዲ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.33">
                            <locus from="120v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3026RepCh306">To the holy
                                Apostles</title>
                            <incipit xml:lang="gez">ኀበ፡ ክርስቶስ፡ አምላኪያ፡ ወተስፋየ፡ ሊተ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.34">
                            <locus from="125v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2906RepCh187">To St Peter
                                and Paul</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘአልባስጥሮስ፡ አፈው።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

                        <msItem xml:id="p1_i1.35">
                            <locus from="130v"/>
                            <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2978RepCh259">To the holy
                                Prophets</title>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥላሴ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

            <t:listPerson>
                <t:person sex="1" sameAs="wd:Q1348849">
                    <t:persName xml:lang="gez" xml:id="n1"> ዮሐንስ፡ ሰይላሚ፡ </t:persName>
                    <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yoḥannǝs Daylāmi</t:persName>
                    <t:persName xml:lang="en" corresp="#n1" type="main">John of Dailam</t:persName>
                    <t:persName xml:lang="syr" xml:id="n2">ܝܘܚܢܢ ܕܝܠܡܝܐ </t:persName>
                    <t:persName xml:lang="syr" type="normalized" corresp="#n2">Yoḥannan Daylamáyá</t:persName>
                    <t:floruit>He was a 7th-century East Syriac Christian saint and monk, who founded several monasteries in Mesopotamia and Persia.</t:floruit>
                    <t:birth when="0660">According to the hagiographical Syriac Life of John of Dailam, John was born in Ḥdattā, a town on the confluence of the Upper Zab and the Tigris, in AD 660</t:birth>
                    <t:death when="0738">He died in his monastery near Kashkar on 26 January 738 AD and is commemorated on <t:date type="diesNatalis" ref="ethiocal:Teqemt19">19 Ṭǝqǝmt</t:date></t:death>
                </t:person>

            </t:listPerson>
            

                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                            <textLang mainLang="gez"/>
                            <note>This is the printed edition of the Ethiopic psalter <bibl corresp="http://zotero.org/groups/358366/items/RMEHMDFJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Potken1513Psalterium"/><title level="m">Psalterium David et cantica aliqua</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Johannes</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Potken</t:surname></author><pubPlace>Romae</pubPlace><publisher>Marcellus Silber</publisher><date>1513</date><note type="url">http://www.kingscollections.org/exhibitions/specialcollections/psalter1513/</note></bibl> (on this, see also 
                                <bibl corresp="http://zotero.org/groups/358366/items/B26LFLAG"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Lofgren1968Stefano"/><title level="a">San Stefano dei Mori och de fürsta etiopiska bibeltrycken</title><title level="m">Särtryck ur Corona Amicorum. Studier tillägnade Tönnes Kleberg</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1968</date><citedRange unit="page">160</citedRange></bibl>).</note>
                        </msItem>
                    </msContents>
                    
                    <physDesc>
                        <objectDesc form="Book">
                            <supportDesc>
                                <support>
                                    <material key="paper"/>
                                </support>
                            </supportDesc>
                        </objectDesc>
                        
                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <desc>Hand of <ref target="#a1"/>, <ref target="#a2"/> and
                                    <ref target="#a3"/>, probably by <persName role="scribe" ref="https://betamasaheft.eu/PRS11501Endreyas">ʾƎndrǝyās</persName>.</desc>
                                <date notBefore="1526" notAfter="1569"/>
                            </handNote>                  
                        </handDesc>
                        
                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <desc type="PurchaseNote">Purchase note on the recto of the guard leaf following the last
                                        printed page, probably written by <persName ref="https://betamasaheft.eu/PRS11501Endreyas">ʾƎndrǝyās</persName> shortly after the publication
                                        of the Psalter.</desc>
                                    <q xml:lang="gez">ዛቲ፡ መጽሐፈ፡ ዳዊት፡ ዘተሣየጣ፡ <persName ref="https://betamasaheft.eu/PRS11501Endreyas">እንድርያስ፡</persName> በ፪፡ ዙልዬ፡ በሮማ፡
                                        በመንበረ፡ ጴጥሮስ፡ ወጳውሎስ፡ በደብረ፡ ቅዱስ፡ እስጢፋኖስ፡ በቅድመ፡ ራይስ፡ ዮሐንስ። 
                                        ወኵሎሙ፡ ነጋድያን። ወውእቱኒ፡ ወልዱ፡ ለአቡነ፡ <sic>እዮስጣቴዎስ።</sic>
                                    </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT3308Nicene">Nicene Creed</title>, written on the recto of the guard leaf following the last
                                        printed page, probably written by <persName ref="https://betamasaheft.eu/PRS11501Endreyas">ʾƎndrǝyās</persName> shortly after the publication
                                        of the Psalter.</desc>
                                    <q xml:lang="gez">ጸሎተ፡ ሃይማኖት፡ ንእመን፡ በአሐዱ፡ አምላክ፡ እግዚአቤሔር፡ አብ፡
                                        አኃዜ፡ ኵሉ፡ ገባሬ፡ ሰማያት፡ ወምድር፡ ዘይሬኢ፡ ወኢያስተሬኢ። ወነአምን፡ በአሐዱ፡ እግዚእ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ አብ፡ ዋኅድ፡ ዘህልው፡ ምስሌሁ፡ እምቅድመ፡ ይትፈጠር፡ ዓለም።</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <desc type="Supplication">Supplication for the patriarch, the
                                        metropolitan, the saints and martyrs etc., written on the recto of the guard leaf following the last
                                        printed page, probably by <persName ref="https://betamasaheft.eu/PRS11501Endreyas">ʾƎndrǝyās</persName> shortly after the publication
                                        of the Psalter. The patriarch mentioned at the beginning is
                                        probably <persName ref="https://betamasaheft.eu/PRS4380Gabriel">Gabriel VII</persName>, which would be corroborated by
                                        the palaeography (<persName ref="https://betamasaheft.eu/PRS4381Gabriel">Gabriel VIII</persName> should be excluded from consideraton since he was in office
                                         too late). A metropolitan is not mentioned.</desc>
                                    <q xml:lang="gez">በእንተ፡ ብፁዕ፡ ወቅዱስ፡ ሊቀ፡ ጳጳስነ፡ አባ፡ ገብርኤል። ወብፁፅ፡
                                        ወቅዱስ፡ ጳጳስነ፡ አባ፡ እገሌ። እንዘ፡ <sic>ይአኵቱከ፡</sic> ወትረ፡ በጸሎቶሙ፡ ወበትንብልና፡ ሣህሎሙ።
                                        እስጢፋኖስ፡ ቀዳሚ፡ ሰማዕት፡ ዘካርያስ፡ ካህን፡ ወዮሐንስ፡ <sic>መጥመቅ።</sic> ወበእንተ፡ ኵሎሙ፡
                                        ቅዱሳን፡ ወሰማዕት፡ እለ፡ <sic>አዕሩፉ፡</sic> በሃይማኖት። ማቴዎስ፡ ወማርቆስ፡ ሉቃስ፡ ወዮሐንስ፡ ፬ ወንጌላውያን፡ ማርያም፡ ወላዲተ፡ አምላክ፡</q>
                                </item>
                                
                                <item xml:id="a4">
                                    <desc type="Comment">Notes in Hebrew on the arm of King David
                                        (<foreign xml:lang="he">מֶלֶךְ דָּוִד</foreign>) on
                                    the frontispiece, in the introduction, before the Canticles and
                                    in the Song of Songs.</desc>
                                    <q xml:lang="he"/>
                                </item>
                                
                                <item xml:id="a5">
                                    <desc type="Comment">Notes in Latin within Psalms 7, 50, 81,
                                        103, 123, 125 and Song of Songs 1.</desc>
                                    <q xml:lang="la"/>
                                </item>
                                
                                <item xml:id="a6">
                                    <desc type="Comment">Notes and translations in Greek within 
                                        Psalms 8, 31, 32, 33, 35, 36, 50, 77, 81, 83, 115, 123, 125,
                                        138, on the page with the syllabary, and all along the Song
                                        of Songs.</desc>
                                    <q xml:lang="grc"/>
                                </item>
                                
                                <item xml:id="a7">
                                    <desc type="Comment">Attempt of transliteration of the first
                                        four verses of Psalm 84 in Hebrew and Greek script. Verses 1
                                    and 2 are transliterated in Hebrew (vocalized Rashi script, but
                                    written from left to right), and verses 3 and 4 are
                                    transliterated in Greek, partly with Hebrew vocalization.</desc>
                                    <q xml:lang="gez-tr"/>
                                </item>
                                
                                <item xml:id="a8">
                                    <desc type="OwnershipNote">Note by <persName ref="https://betamasaheft.eu/PRS3182ContiRo">Carlo Conti Rossini</persName> on the
                                        recto of the first guard leaf.</desc>
                                    <q xml:lang="it">Roma, <date when="1939-05-18">18 maggio
                                        1939</date>. — Volume donatomi oggi dal <persName role="donor" ref="https://betamasaheft.eu/PRS14874Osio"><roleName type="title">dr.</roleName> Arturo Osio</persName>, direttore
                                        generale della Banca del Lavoro. Da una nota finale ms. risulta comperato
                                        da un abbā Endreyās di Santo Stefano dei Mori; altri possessori:
                                        p. 1 <persName role="owner" ref="https://betamasaheft.eu/PRS14875Doria">Bartolomeo
                                            Doria</persName>, <persName role="owner" ref="https://betamasaheft.eu/PRS14877BonaventuraR">Roberti</persName> e <persName ref="https://betamasaheft.eu/PRS14878BonaventuraJ">Jacobus Bonaventura</persName>; p. 2
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS14876Grimaldis">Pelegrinus de
                                        Grimaldis Roby di Genova</persName>. <persName ref="https://betamasaheft.eu/PRS3182ContiRo">Conti Rossini Carlo</persName></q>
                                </item>
                                
                                <item xml:id="e1">
                                    <desc>Some scribbles on the recto of the guard leaf following the last
                                        printed page.</desc>
                                </item>
                            </list>
                        </additions>
                    </physDesc>
                    

               </msIdentifier>
               <msContents>
                  <summary>Homiliary in Honor of the Monthly Feast of the Archangel Mika’el</summary>
                  <msItem xml:id="ms_i1"><title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan"> </title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">102</measure>
                           <dimensions type="outer" unit="mm">
                              <height>210</height>
                              <width>170</width>
                              <depth>47</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="2" writtenLines="20"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#2r" facs="003">Fol. 2r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#89v" facs="090">Fol. 89v</locus><desc>Jesus and two evil accusers; Jesus holds his hands in supplication as in <ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#102r" facs="102">Fol. 102r</locus><desc>An <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> in a cloud (right) making a proclamation to <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and others (left)</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#ms_i1">Fols. ms_i1, </locus>
                    <locus target="#5r 14v #21r #27v #32v #49v #58r #61v #76v #83v #88v #94v" facs="005 015 021 028 003 050 058 062 077 084 089 095">5r,, 21r, 27v, 32v, 49v, 58r, 61v, 76v, 83v, 88v, 94v</locus>
                    <desc>Headings arranged for months of the year: Ḫǝdar, Taḫśaś, Ṭǝrr, Yäkkatit, Mäggabit, Miyazya, Gǝnbot, Säne, Ḥamle, Näḥase, Mäskäräm, Ṭǝqǝmt</desc>
                    </item>

                    <item xml:id="a2">
                    <locus target="#1r" facs="001"> f. 1r, upper margin</locus>
                    <desc>
                    note of ownership written in the harag by a secondary hand, <foreign xml:lang="gez">አባ ተግባ ተፈራ</foreign>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#19r" facs="019"> f. 19r and passim</locus>
                    <desc>
                    A name appears in the primary hand, <foreign xml:lang="gez">ገብረ ሕይ[ዎት]</foreign>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#26r" facs="026"> f. 26r and passim (e.g., 28v, 31v)</locus>
                    <desc>
                    King Menilek, <foreign xml:lang="gez">ንጉሥ ምኒልክ</foreign> (1868‒1913), or our king Menilek, <foreign xml:lang="gez">ምኒልክ ንጉሥነ</foreign>, –and not king of kings—is mentioned, perhaps indicating the timeframe from 1868‒1889 when he was regional king and not yet emperor
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#57v" facs="058">Fol. 57v</locus>
                    <desc>
                    another name appears in the primary hand, <foreign xml:lang="gez">ገብረ ሚካኤ</foreign>
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#59v" facs="060">Fol. 59v</locus>
                    <desc>
                    another name, <foreign xml:lang="gez">ወልድ ኪዳን</foreign>
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#61v #62r" facs="062">Fols. 61v, 62r</locus>
                    <desc>
                    another name is written in red ink pen, <foreign xml:lang="gez">ወልደ ሚካኬል</foreign>
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <locus target="#82r" facs="082">Fol. 82r</locus>
                    <desc>
                    another name, <foreign xml:lang="gez">ገብረ ማርያም</foreign>
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>

                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="39r"/>
                            <title ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                            <incipit xml:lang="gez">አኰቴተ፡ <supplied reason="undefined">ቍርባን፡</supplied> ዘእግዝእትነ፡ ማርያም፡ ዘደረሰ፡ አባ፡ ሕርያቆስ፡ 
                                <supplied reason="undefined">ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ብሕንሳ፡</supplied> በመንፈስ፡ ቅዱስ፡ በእንተ፡ እግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ </incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="39v" to="88v"/>
                            <title ref="https://betamasaheft.eu/LIT6971YahegennaYaserat">Ya-ḥǝgǝnnā ya-śǝrʿat maṣḥaf</title>
                            <note>Amharic version of the <ref type="work" corresp="https://betamasaheft.eu/LIT1968Mashaf">Maṣḥafa śǝrʿat</ref>.</note>
                            <incipit xml:lang="am">በስመ፡ <gap reason="ellipsis"/> በዚህቺ፡ በቅድስት፡ ሥላሴ፡ ሠራነ፡ መስሪነታቺው፡ ፩አምላክ፡ በሚባል፡ አንደነታቺው፡ አብ፡ 
                                ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በሚባል፡ ፫፡ እነታቸው፡ ፫አካል፡ ፩ህልውና፡ ፩ግብር፡ ፩ባሕርያ፡ ፩አምላክ፡ በሆነ፡ ሰሪናቸው፡ አነ፡ ውእቱ፡ አምላከ፡ አብርሃም፡ ወአምላከ፡ 
                                ይስሐቅ፡ ወ<pb n="40r"/>አምላከ፡ ያዕቆብ፡ ቢሚባሉ፡ ሥላሴ፡ <gap reason="ellipsis"/> ዛቲ፡ መጽሐፈ፡ ሥርዓት፡ ዘወጽአት፡ እመንበረ፡ ማርቆስ፡ ሐዋርያ፡ 
                                <pb n="41v"/>እመካነ፡ ማልቃ፡ ዘምስር፡ ማለት፡ ይህቿ፡ የሕግና፡ የሥርዓት፡ መጽሐፍ፡ የምስር፡ ወገን፡ ከምትሆን፡ ከማልቃ፡ ቦታ፡ ተነሥታ፡ በሐዋርያው፡ በማርቆስ፡ 
                                ቦታ፡ የተገንቲ፡ ናት፡ ሲል፡ ነው፡ ዘአንበሩ፡ መምሕራን፡ ሊቃውንት፡ ክቡራን፡ መጋብያ፡ ምስጢር፡ ርቱዓነ፡ ሃይማኖት፡ እለኒኸውም፡ ያስቀመጥዋት፡ ሰወቺ፡ ምግባር፡ 
                                ተሃ<pb n="42r"/>ይማኖት፡ ሃይማኖት፡ ተመግባር፡ አስተባብረው፡ የያዙ፡ ናቸው፤ </incipit>
                            <textLang mainLang="am"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="88v" to="91v"/>
                            <title ref="https://betamasaheft.eu/LIT3585Taamme">Three miracles of the Virgin Mary</title>
                            <msItem xml:id="ms_i3.1">
                                <locus from="88v" to="90r"/>
                                <title ref="https://betamasaheft.eu/LIT5265MiracleAdam">Miracle of Mary: The descent of the holy seed from Adam
          to St Mary</title>
                                <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪፡ ማርያም፡ ወላ<sic>ዳ</sic>ተ፡ አምላክ፡ ጸሎታ፡ ወበረከታ፡ <gap reason="ellipsis"/>
                                    ወእንዘ፡ ትትፋለስ፡ ነበረት፡ እግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ዘበዕራይስጢ፡ 
                                    ማሪ<sic resp="PRS8999Strelcyn">ሃ</sic>ም፡ እምአዳም፡ ውስተ፡ ከርሡ፡ ለሴት፡ ወሄኖክ፡
                                    ወቃይናን፡ ወመላልየል፡ ወያሬድ፡ ወኖኅ፡ ወትትፋለስ፡ እምከርሠ፡ ፩፡ ውስተ፡ ከርሠ፡ ፩ወእምዝ፡ ኃደረት፡ ውስተ፡ ከርሠ፡ አዳም፡ ይስሐቅ፡ ወያዕቆብ፡ </incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i3.2">
                                <locus from="90v" to="91r"/>
                                <title ref="https://betamasaheft.eu/LIT3587Miracle">Miracle of Mary: Miracle of a poor monk whom Mary gave a
          garment</title>
                                <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእት፡ ቅድስት፡ ድንግል፡ በ፪ማርያም፡ ወላዲተ፡ አምላክ፡ ጸሎታ፡ ወበረከታ፡ <gap reason="ellipsis"/> 
                                    ተብሕለ፡ ከመ፡ ሀሎ፡ ፩መ<supplied reason="undefined" resp="PRS8999Strelcyn">ነ</supplied>ኮስ፡ ወአልቦቱ፡ ሲሳይ፡ ዘየሴሰይ፡ 
                                    ወአልባስ፡ ወይትአምና፡ ለእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ወይቤላ፡ አዝዚ፡ ሊተ፡ ዘእበልዕ፡ ወዘእለብስ፡ ወዘንተ፡ ብሂሎ፡ ኖመ፤ </incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i3.3">
                                <locus from="91r" to="91v"/>
                                <title ref="https://betamasaheft.eu/LIT3906Miracle">Miracle of Mary: How the Virgin Mary obtained entry to
          paradise for the soul of a monk who had kept her fast annually</title>
                                <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ማርያም፡ ወላዲተ፡ አምላክ፡ ጸሎታ፡ ወበረከታ፡ <gap reason="ellipsis"/>
                                    ወሀሎ፡ ፩መነኮስ፡ ዘይፀውም፡ ፆመ፡ ዚአሀ፡ በንጽሕ፡ ወአል<supplied reason="undefined" resp="PRS8999Strelcyn">ቦ</supplied>ቱ፡ 
                                    ምግባረ፡ ሠናይ፤ ወበጊዜሃ፡ መጽአ፡ <sic>መላከ፡</sic> ሞት፡ ወወሰደ፡ ነፍሶ፡ ውስተ፡ ሲኦል፡ ወሖረት፡ እግዝእትነ፡ ማርያም፡ ኀበ፡ ወልዳ፡ ወትቤሎ፡ መሐር፡ 
                                    <sic>ለ</sic>ተ፡ ኦወልድየ፡ ዛቲ፡ ነፍስ፡</incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                        </msItem>

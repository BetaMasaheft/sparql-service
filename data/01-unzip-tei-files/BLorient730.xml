                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="5r" to="121v"/>
                            <title ref="https://betamasaheft.eu/LIT7229DossierWP">Hagiographic Dossier of St Walatta Ṗeṭros</title>
                      
                        <msItem xml:id="ms_i1.1">
                            <locus from="5r" to="104r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1509GadlaW">Gadla Walatta Ṗeṭros</title>  
                                <note><cit><quote>After a short introduction, the life begins on f. 8a</quote></cit>, (<bibl corresp="http://zotero.org/groups/358366/items/MIFKZCUN"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Wright1877BM"/><title level="m">Catalogue of the Ethiopic Manuscripts in the British Museum Acquired since the Year 1847</title><author><forename>William</forename><surname>Wright</surname></author><pubPlace>London</pubPlace><publisher>Gilbert and Rivington</publisher><date>1877</date><note type="url">https://archive.org/details/catalogueofethio00brituoft</note><note type="tags"><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note></note><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note><citedRange unit="page">197b</citedRange></bibl>)</note>
                            <textLang mainLang="gez"/>
                  
                            <incipit xml:lang="gez">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወንጽሐፍ፡ ዜና፡ ፅንሰታ፡ ወልደታ፡  ለእምነ፡
                                ቅድስት፡ ወልዕልተ፡ ዝክር። <persName ref="https://betamasaheft.eu/PRS9848Walatta">ወለተ፡ ጴጥሮስ፡ </persName> እምዘመደ፡ 
                                ኄራን፡ ወእምነገደ፡ ክቡራን፡  ወእምቤተ፡ <placeName ref="https://betamasaheft.eu/LOC2582Dawaro">ደዋሮ፡</placeName> ወ
                                <placeName ref="https://betamasaheft.eu/LOC3061Fataga">ፈጠጋር።</placeName>
                                ስሙ፡ ለአቡሃ፡ <persName ref="https://betamasaheft.eu/PRS2359BaherSa">ባሕር፡ ሰገድ።</persName> 
                                ወስመ፡ እማ፡ <persName ref="https://betamasaheft.eu/PRS6075Krestos">ክርስቶስ፡ ዕበያ።</persName>   
                                ወክልኤሆን፡ ጻድቃን፡ ወፈራህያነ፡   እግዚአብሔር፡ እሙንቱ። ወብዑላን፡ ጥቀ፡ በንዋየ፡ ዝንቱ፡ ዓለም።  etc. </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2">
                            <locus from="104r" to="118v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT7073TammeraW">Taʾammǝra Walatta Ṗeṭros</title>
                            <note><cit><quote>11 in number</quote></cit>, (<bibl corresp="http://zotero.org/groups/358366/items/MIFKZCUN"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Wright1877BM"/><title level="m">Catalogue of the Ethiopic Manuscripts in the British Museum Acquired since the Year 1847</title><author><forename>William</forename><surname>Wright</surname></author><pubPlace>London</pubPlace><publisher>Gilbert and Rivington</publisher><date>1877</date><note type="url">https://archive.org/details/catalogueofethio00brituoft</note><note type="tags"><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note></note><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note><citedRange unit="page">197b</citedRange></bibl>)</note>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                            <locus from="121v" to="122r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3001RepCh281">Malkǝʾa Walatta Ṗeṭros</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ዘሀሎ፡ አመ፡ ኢሀሎ፡ ዘመን። ወኢቀደሞ፡ ሰዓት፡ መጠነ፡ ቅጽበታ፡ ለዓይን።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.4">
                            <locus from="122r" to="126v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2813RepCh97">Tarafa-hymn to Walatta Ṗeṭros</title>
                            <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ ገነት፡ ክልልተ፡ መዓዛ፡ ጥዑም።</incipit>
                        </msItem>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="122r" to="126v"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT4314Malke">A hymn to our Lord</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይኄይሱ፡ ዘአንበረ፡  ቅድመ፡ እግዚአብሔር፡ በአትሮንሱ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="126v" to="131r"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT2891RepCh172">A hymn to the blessed Virgin Mary</title>
                            <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ፤  እምነ፡ ከልበኔ፡ ወቊስጥ፡
                                ወእምነ፡  ሰንበልት፡ ምዑዝ፤  ማርያም፡ ድንግል፡ ለባሲተ፡ ዐቢይ፡ ትእዛዝ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="131r" type="134v"/>
                           
                            <title ref="https://betamasaheft.eu/LIT1141Aposto">ዝንቱ፡ ሥራዓት፡ ዘሐዋርያት፡ ዘሠርዑ፡ በሢኖዶሶሙ።(Canons of the Apostles) </title>
                            <incipit xml:lang="gez"> በአኰቴተ፡ አብ፡ ወወልድ፡
                                ወምንፈስ፡ ቅዱስ፡ ጸሐፍነ፡  ዘንተ፡ ቀኖና፡ ዘይትነገር፡ ላዕለ፡ ኲሉ፡ ዘይኔስሕ፡ በእንተ፡ ኃጢያቱ፡
                                ወእመኒ፡ ክርስታናዌ፡ ቀተለ፡ ኢያቅልሎ፡ እምንስሓሑ፡(sic) ቀኖና። </incipit>
                        </msItem>
                        
                    </msContents>
                    
                    
                    
                    
                    
                    

                    <locus target="#143r" facs="146"> f. 143r, line 3</locus>
                    <locus target="#153v" facs="157"> f. 153v, col. 5</locus>
                    <desc>
                    lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#4r" facs="007">Fol. 4r</locus>
                    <desc>
                    text has been removed

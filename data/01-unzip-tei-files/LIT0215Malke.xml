      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ በእማኄ፨</l>
                  <l n="2">ነቢየ፡ ሴሎ፡ ኤልያስ፡ ወመምህር፡ ቅድመ፡ ኤሎሄ፨</l>
                  <l n="3">እምቅኔ፡ ዝንቱ፡ ዓለም፡ ወእምነ፡ መርገም፡ ዘገላቡሄ፨</l>
                  <l n="4">አድኅነኒ፡ ወባልሐኒ፡ በልማድከ፡ ርኅራኄ፨</l>
                  <l n="5">እስመ፡ እንበሌከ፡ ባዕደ፡ ኃጣእኩ፡ በላሔ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምከ፡ እብሎ፨</l>
                  <l n="2">ዘጥንተ፡ ፊደሉ፡ አሌፍ፡ ወላሜድ፡ ዘምድረ፡ ሴሎ፨</l>
                  <l n="3">ኤልያስ፡ እምዮድ፡ እስከ፡ ሳን፡ ዘበበ፡ መትሎ፨</l>
                  <l n="4">ናሁ፡ ወጠንኩ፡ ውዳሴከ፡ ውስተ፡ ልብየ፡ ዘሀሎ፨</l>
                  <l n="5">ከመ፡ በትፍሥሕት፡ እግበር፡ ማሕሌተ፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">በዝንቱ፡ ማሕሌትነ፡ በከናፍሪሁ፡ የቢቦ፨</l>
                  <l n="2">ለዘወሀበከ፡ ብእሲ፡ ምስለ፡ ቃለ፡ ድርሳን፡ ወተናብቦ፨</l>
                  <l n="3">ኤልያስ፡ ስፋሕ፡ ትባርኮ፡ ህየንተ፡ ዐስቦ፨</l>
                  <l n="4">አእዳዊከ፡ ምሉኣነ፡ ጸጋ፡ ሕይወተ፡ ቃል፡ ዘቦ፨</l>
                  <l n="5">ወማዕተበ፡ ጸጋከ፡ መንፈሳዊ፡ ለይግበር፡ ማዕተቦ፨</l>
               </lg>
            </div>
         </div>
      </body>

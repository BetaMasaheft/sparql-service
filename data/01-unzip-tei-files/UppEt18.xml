                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="2" to="17"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title>
                            <textLang mainLang="gez"/>
                            <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">85</citedRange></bibl>
                                notes that the hymn here contains 33 stanzas, that one line is missing from the first stanza, and that there
                                is an erased stanza after the last one, leading him to suggest that the text here is incomplete.
                            </note>
                            
                            <incipit xml:lang="gez">
                                ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ፡ 
                                ወልደ፡ ያሬድ፡ ሄኖክ፡ በከመ፡ ጸሐፈ፡ 
                                ረድአ፡ ምንዱባን፡ ሚካኤል፡ በከመ፡ ታለምድ፡ ዘልፈ፡ 
                                ለረዲኦትየ፡ ነዓ፡ ሰፊሐከ፡ ክንፈ፡ 
                            </incipit>
                            <explicit xml:lang="gez">
                                ሰላም፡ ለሕሊናከ፡ ዘኢይሔሊ፡ ኀጕለ፡ 
                                እንበለ፡ ዳእሙ፡ ይስእል፡ ምሕረተ፡ ወሣህለ፡ 
                                ሚካኤል፡ ንሣእ፡ ወልታከ፡ ፅዱለ፡ 
                                ወምላ<choice><sic>ዕ</sic><corr resp="PRS6337Lofgren">ኅ</corr></choice>፡ ዲበ፡ መስቴማ፡ ሰይፈከ፡ ስሁለ፡ 
                                ለዘተፃብዐከ፡ ቅድመ፡ ኢትርሳእ፡ በቀለ፡ 
                            </explicit>
                        </msItem>
                            
                            <msItem xml:id="ms_i2">
                                <locus from="18" to="35"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
                                <textLang mainLang="gez"/>
                                <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">85</citedRange></bibl>
                                    notes that this attestation of the text contains 55 stanzas.
                                </note>
                                <incipit xml:lang="gez">
                                    ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይኄሱ፡ 
                                    ዘአንበረ፡ ቅድመ፡ እግዚአብሔር፡ በአትሮንሱ፡ 
                                    ኢየሱስ፡ ክርስቶስ፡ ለዳዊት፡ ባሕርየ፡ ከርሡ፡ 
                                    አክሊለ፡ ስምከ፡ እንዘ፡ ይትቄጸል፡ በርእሱ፡ 
                                    አሕጉረ፡ ፀር፡ ወረሰ፡ ኢያሱ፡ 
                                </incipit>
                                <explicit xml:lang="gez">
                                    ሰላም፡ ሰላም፡ ለኩሉ፡ መልክዕከ፡ 
                                    ወበከመ፡ መልክዑ፡ ለአቡከ፡ 
                                    ኢየሱስ፡ ክርስቶስ፡ ሕማማተ፡ መስቀልከ፡ ዘፆርከ፡ 
                                    ህብዐኒ፡ እምገጸ፡ ሞት፡ በእንተ፡ ማርያም፡ እምከ፡ 
                                    አምላኪየ፡ አምላኪየ፡ ኢይፅናዕ፡ ልብከ፡ 
                                </explicit>
                            </msItem>
                      
                    </msContents>


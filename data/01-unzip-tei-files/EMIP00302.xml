                  <decoDesc>
                      <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/>" and <term key="scabbard" ana="#scabbard"/></desc></decoNote>
                      <decoNote type="miniature" xml:id="d2"><locus target="#39r" facs="039">Fol. 39r</locus><desc>Evangelist <ref type="authFile" corresp="https://betamasaheft.eu/AT1013Evangelist"><span xmlns="" class="w3-tag w3-red">No item: AT1013Evangelist</span></ref> Seated evangelist holding pen writing in book</desc></decoNote>
                      <decoNote type="miniature" xml:id="d3"><locus target="#71r" facs="071">Fol. 71r</locus><desc> crude drawing of a figure</desc></decoNote>
                      <decoNote type="miniature" xml:id="d4"><locus target="#70v" facs="071">Fol. 70v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/>" and <term key="scabbard" ana="#scabbard"/></desc></decoNote>
                      <decoNote type="frame" xml:id="d5">
                      Decorative designs:
                      <locus target="#41v #45v #69v" facs="042 046 070">fols. 41v, 45v, 69v</locus> (pattern of red and black dots);
                      multiple full stops are used as section dividers throughout
                      </decoNote>
                  </decoDesc>
                  <additions>

                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#14 #34" facs="014 034">Fols. 14, 34</locus>
                    <desc>
                    red yarn sewn into the fore edge to mark readings as navigation system;
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <locus target="#23" facs="023">Fol. 23</locus>
                    <desc>
                    white yarn sewn into the fore edge to mark content as navigation system;
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                    marginal notation to mark readings
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <locus target="#50r #58r #65r #68v" facs="050 058 065 069">Fols. 50r, 58r, 65r, 68v</locus>
                    <desc>
                    words of text are written interlinearly;
                    </desc>
                    </item>

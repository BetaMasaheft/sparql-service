                    <desc>
                    words of text are written in the upper margin with a symbol (┬) is used;
                    </desc>
                    </item>
                    <item xml:id="e11">
                    <locus target="#5r #31v #33r #43r #47v" facs="005 032 033 043 048">Fols. 5r, 31v, 33r, 43r, 47v</locus>
                    <desc>

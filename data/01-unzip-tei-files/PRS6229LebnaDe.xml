                  <persName xml:lang="gez" xml:id="n1" type="birth">ልብነ፡ ድንግል፡</persName>
                 <persName xml:lang="gez" type="normalized" corresp="#n1">Lǝbna Dǝngǝl</persName>
               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
                  <persName xml:lang="gez" type="regnal" xml:id="n2.1">ወናግ፡ ሰገድ፡</persName>

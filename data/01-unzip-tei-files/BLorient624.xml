                        <additions>
                            <list>   
                                <item xml:id="a1" corresp="#h2">
                                    <locus target="#154r"/>
                                    <desc type="DonationNote"/>
                                    <q xml:lang="gez">ዘወሀበት፡ ወርቂት፡ ኍልቈ፡ አብያት፡ ክልኤተ፡ ወ፪ምንጻፍ፡ ለኢየሱስ፡ ከመ፡ ይኩና፡ ለመድኃኒተ፡ ሥጋ፡ ወነፍስ።
                                    </q>
                                </item>
                                
                                <item xml:id="a2" corresp="#h3">
                                    <locus target="#154v"/>
                                    <desc type="GuestText">
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT2732RepCh16">Hymn to Dioscorus and Severus</title>, incomplete at the end. The following is the incipit:</desc>
                                    <q xml:lang="gez">ማኅሌተ፡ ዲዮስቆሮስ፡ አብ፡ ወሳዊርያኖሰ፡ ክቡር። እለ፡ መገቡ፡ ዓለመ፡ በዘእስክንድርያ፡ መንበር። አሥተናስኡኒ፡ እጽሐፍ፡ ሥላሴ፡ 
                                        አጋእዝተ፡ ሰማይ፡ ወምድር፡</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#3v"/>
                                    <desc type="GuestText">
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT3049RepCh329">Hymn to Jesus Christ</title>. The following is the incipit:</desc>
                                    <q xml:lang="gez">ኢየሱስ፡ ሕፃን፡ ስብሐት፡ ለከ፡ ዘድንግል፡ ፍሬ፡ ማኅፀን።
                                    </q>
                                </item>
                                

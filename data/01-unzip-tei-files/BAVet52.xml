                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="70r"/>
                     <title type="complete">Malkǝʾ-hymns</title> 
                     <msItem xml:id="ms_i3.1">
                        <locus from="70r"/>
                        <title ref="https://betamasaheft.eu/LIT4505Salam">Malkǝʾ-hymn to St George the Martyr</title>
                        <incipit xml:lang="gez">
                           ሰላም፡ ለከ፡ ጊዮርጊስ፡ ረቡኒ፡ ዓራዊተ፡ ህለት፡ ኰናኒ፡
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i3.2">
                        <title ref="https://betamasaheft.eu/LIT4506Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                        <incipit xml:lang="gez">
                           ሰላም፡ ለገጽኪ፡ ዘጥቀ፡ 
                              <sic>ይሌሂ፡</sic>
                            እምስነ፡ ከዋክብት፡ ወወርኅ፡ ወእምስነ፡ ፀሐይ፡ መብርኂ፡ ማርያም፡ ድንግል፡
                        </incipit>
                     </msItem>
                  </msItem>

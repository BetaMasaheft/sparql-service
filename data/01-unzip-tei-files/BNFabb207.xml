                    <msPart xml:id="p1">
                        <msIdentifier/>
                        <msContents>
                            <summary/>
                            
                            <msItem xml:id="p1_i1">                              
                        <locus from="1r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1919Mashaf">Maṣḥafa bāḥrǝy</title>
                         <textLang mainLang="gez"/>
                         <note>The same text as in <ref type="mss" corresp="https://betamasaheft.eu/BNFabb69">Paris, Bibliothèque nationale de France, BnF Éthiopien d'Abbadie 69</ref>.</note>
                            </msItem>

                                <msItem xml:id="p1_i2">
                           <locus from="33r"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our Lady Mary</title>
                             <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡ ዘመዐዛ፡ አፉኪ፡ ኮል</incipit>
                                </msItem>

                                <msItem xml:id="p1_i3">
                            <locus from="34v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7021BaryaAganentGudale">Protective prayer against Bāryā, demons, Dask,
          gudāle and budā</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis" resp="CR"/>ዛሙስ፡ የአድ፡ ታውሚ፡ አስሆሩ<gap reason="illegible" unit="chars" quantity="1" resp="CR"/>ብለባርያ፡ 
                                  አገባጅ፡ ዘበላዕለ፡ ምሻቱር፡ ሰሎሞን፡ አርምኃ። <gap reason="ellipsis" resp="CR"/>ወለአጋንንት፡ ለደስክ፡ ወለጉዳሌ፡ ለቡዳ፡ ወለተግባረ፡ ሰብእ፡ ለውግዓት፡ 
                                  ወለቁርጥማ፡ ለድድቅ፡ ወለጋኔነ፡ ቀትር፡ ለፌራ፡ ወለዳስማ፡ ለምትአት፡ ወለፅፋፍአት፡</incipit>
                         </msItem>

                                <msItem xml:id="p1_i4">
                            <locus from="38r"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT7022HemamaBedbed">Prayer against plague</title>
                             <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ብድብድ፡</incipit>
                                    <note>How the Lord spoke to ʾAmru at Mirod, he sent to ʾAmru an angel called Ṭǝqonṭoqyā, 
                                    </note>
                                </msItem>                              
                        </msContents>
                                     

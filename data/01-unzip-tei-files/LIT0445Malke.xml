      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0445</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘመለኮቱ፡ ዋሕድ፨</l>
                  <l n="2">ወበስመ፡ ማርያም፡ ጳጦስ፡ ጸዋሪተ፡ ግሩም፡ ነድ፨</l>
                  <l n="3">መጽሐፈ፡ ገድልከ፡ እጽሕፍ፡ ጸውዐተኒ፡ መፍቅድ፨</l>
                  <l n="4">ገብረ፡ እንድርያስ፡ አባ፡ ጽዱለ፡ ምግባር፡ መረግድ፨</l>
                  <l n="5">እስመ፡ መሰንቆ፡ ፍቅርከ፡ ኮነኒ፡ ለእድ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ከመ፡ ዝክረ፡ አባ፡ እንጦኒ፨</l>
                  <l n="2">ዘበአፈ፡ ኵሉ፡ ይጥዕም፡ ወእምወይነ፡ ቃና፡ ዘይሤኒ፨</l>
                  <l n="3">ገብረ፡ እንድርያስ፡ ጻድቅ፡ በትረ፡ ተዐቅቦ፡ ሀበኒ፨</l>
                  <l n="4">ኢይደቅ፡ ውስተ፡ እዴሁ፡ ለመልአከ፡ ሥጋ፡ ኰናኒ፨</l>
                  <l n="5">ከመ፡ በኲናት፡ ወጽቁ፡ ፊንሐስ፡ ወአፍኒ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ ተስፋ፡ ሕዝበ፡ ገዳም፡ ወዕፅ፨</l>
                  <l n="2">ወለመቃብሪከ፡ ጽርሕ፡ በአእዳወ፡ ኄራን፡ ሕኑጽ፨</l>
                  <l n="3">ገብረ፡ እንድርያስ፡ ሙሴ፡ መልአከ፡ አምላክ፡ ለግብጽ፨</l>
                  <l n="4">ለዓለም፡ አዕድወኒ፡ እምቀላይ፡ ፍቅራ፡ ሕጹጽ፨</l>
                  <l n="5">እስመ፡ ዴገኑኒ፡ ለአህጕሎ፡ እኩያን፡ አብያጽ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ ለመልክእከ፡ አዳም፨</l>
                  <l n="2">እስመ፡ አቅረብከ፡ ወልድከ፡ ብእሴ፡ ሥጋ፡ ወደም፨</l>
                  <l n="3">ገብረ፡ እንድርያስ፡ አባ፡ ለነሢአ፡ ጸጋ፡ ፍጹም፨</l>
                  <l n="4">የማንከ፡ ትባርከኒ፡ ለኤፍሬም፡ ሥዩም፨</l>
                  <l n="5">ከመ፡ ባረኮ፡ ያዕቆብ፡ አቡሁ፡ ዘቅድም፨</l>
               </lg>
            </div>
         </div>
      </body>

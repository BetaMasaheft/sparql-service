               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">i + 33</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>

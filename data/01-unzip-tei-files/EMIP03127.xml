                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Part of the collection of Haroutune Nazarian, who had microfilms made of his Ethiopian manuscripts and the microfilms sent to the Institute of Ethiopian Studies. They were digitized by EMIP workers in Addis Ababa in the first half of 2010
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#1r" facs="001 038">Fol. 1r</locus>
                    <desc>
                    the number 155 is written. The microfilming information board (image 38) indicates that the manuscript was microfilmed in 1982 and assigned the number 155
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    Some of the folios in fore guard and the rear guard were left unmicrofilmed
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <locus target="#31r" facs="032">Fol. 31r</locus>
                    <desc>
                    mentions several names, Walatta Iyasus, Walatta Takla Haymanot
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#32v #33r" facs="034">Fols. 32v, 33r</locus>
                    <desc>
                    mostly undecipherable, written in a different, untrained hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#33v" facs="035">Fol. 33v</locus>
                    <desc type="OwnershipNote">
                    mentions the original owner, Amata Maryam. The name Amata Egzi’ is written in secondarily
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#34r" facs="035">Fol. 34r</locus>
                    <desc>
                    note of secondary owner, Walatta Egzi’ written in an untrained hand
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ገዳመ፡ ዕዝራ፡ ወፃእኩ፡ እንዘ፡ እሴብሖ፡ በኵሉ፨</l>
                  <l n="2">ለእግዚአብሔር፡ ኪያኪ፡ ዘፈጠረ፡ በቃለ፡ ኀይሉ፨</l>
                  <l n="3">ምክሐ፡ ደናግል፡ ማርያም፡ ለሀየለ፡ ክርስቶስ፡ አክሊሉ፨</l>
                  <l n="4">አንብሪ፡ ዲበ፡ ርእስየ፡ አክሊለ፡ ጥበብ፡ ዘላዕሉ፨</l>
                  <l n="5">እስመ፡ ህየ፡ አእምሮ፡ ወነቢብ፡ ይሄሉ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘጥንተ፡ ሆህያት፡ ጥንተ፡ ስሙ፨</l>
                  <l n="2">ወቅሩጽ፡ ዓዲ፡ በማሕተመ፡ አምላክ፡ ማሕተሙ፨</l>
                  <l n="3">ሀየለ፡ ክርስቶስ፡ ሰማዕት፡ ለክርስቶስ፡ ህየንተ፡ ደሙ፨</l>
                  <l n="4">ከመ፡ ይረድ፡ ውስተ፡ ቤትከ፡ ጠለ፡ በረከት፡ በዐቅሙ፨</l>
                  <l n="5">ጸሊ፡ ለውሉድከ፡ ወአስተምሕር፡ ሎሙ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ በንፍሐተ፡ ቀርን፡ ዘደኃሪ፨</l>
                  <l n="2">ወለዕርገትከ፡ በክብር፡ መንገለ፡ ዐርገ፡ ፈጣሪ፨</l>
                  <l n="3">ሀየለ፡ ክርስቶስ፡ ዕዝራ፡ በአምሳለ፡ አብ፡ መሓሪ፨</l>
                  <l n="4">በጸሎትከ፡ ቀዳሜ፡ ቃል፡ ኃጣውኢነ፡ አስተስሪ፨</l>
                  <l n="5">እስመ፡ ጸሎትከ፡ ሰላመ፡ ትፈሪ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ፍሬ፡ ከናፍር፡ ስብሐተ፡ መጠነ፡ ራብዕ፡ ስቡኣዔ፨</l>
                  <l n="2">ዘአቅረብኩ፡ ለከ፡ እንዘ፡ አተሉ፡ ክልኤ፨</l>
                  <l n="3">ሀየለ፡ ክርስቶስ፡ ተወከፍ፡ ከመ፡ ትኩነነ፡ ረዳኤ፨</l>
                  <l n="4">አመ፡ ያስተናጽሕ፡ ዐውደ፡ እክሉ፡ ዘውስተ፡ እዴሁ፡ መሥዔ፨</l>
                  <l n="5">ወያውኢ፡ በእሳት፡ ክርዳደ፡ ጸላኤ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለክሙ፡ ምዑዛነ፡ ምግባር፡ እምኮል፨</l>
                  <l n="2">ተወልደ፡ መድኅን፡ ወየማነ፡ አብ፡ ወህርያቆስ፡ አስካል፨</l>
                  <l n="3">አብ፡ ቅዱስ፡ አምሳሉ፡ ለገብረ፡ ኢየሱስ፡ አምሳል፨</l>
                  <l n="4">ወካዕበ፡ እዌድሶ፡ ለሀብተ፡ ሥላሴ፡ መስተጋድል፨</l>
                  <l n="5">በገረር፡ ቅድስት፡ እንተ፡ ዕማ፡ ቤቴል፨</l>
                  <l n="6">ቤቴል፡ ብሂል፡ ቤተ፡ ማርያም፡ ድንግል፨</l>
               </lg>
            </div>
         </div>
      </body>

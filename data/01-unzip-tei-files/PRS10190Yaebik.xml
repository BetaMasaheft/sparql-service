         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ያዕቢከ፡ እግዚእ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Yāʿǝbika ʾƎgziʾ</persName>
      
               
               <occupation type="political">ruler</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               <residence ref="LOC1400AmbaSa">ʾAmbā Śannāyti</residence>
               <floruit notBefore="1300" notAfter="1350">He was a local lord of <placeName ref="https://betamasaheft.eu/LOC5932Tegray">Tǝgrāy</placeName>
                  during the first half of the 14th century. 
                  He was the successor of <persName ref="https://betamasaheft.eu/PRS11344Tasfaezgi">Tasfā ʾƎgziʾ</persName>.
              He had a hostile relation with his contemporary king of Solomonic dynasty,        
                  <persName ref="https://betamasaheft.eu/PRS1854Amdase">
                     <roleName type="title">ʾaṣe</roleName>
                      ʿAmda Ṣǝyon I</persName>.
             
          He refused to submit to 
                  <persName ref="https://betamasaheft.eu/PRS1854Amdase">
                     <roleName type="title">ʾaṣe</roleName> ʿAmda Ṣǝyon I</persName> and contested his power. 
                  But later he was defeated. </floruit>
          
            </person>
            
         </listPerson>
        
         

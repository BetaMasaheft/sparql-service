               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="11v">Fols 1r–11v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara
                    Bǝhnǝsā</title>
                        <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#1r">Fol. 1r</locus>
                        ሰማያዊ፡ እምሰማየ፡ ሰማያት፡ ዘበሰለ፡ <sic resp="DN">ኦድንል፡</sic> አኮ፡ ለዮሴፍ፡ ዘተፍህርኪ፡ ለ<add place="above">ተ</add>ቃርቦ፡ አላ፡ ከመ፡ ይእቀብኪ፡ ንጹሐ፡ እስመ፡ ከማሁ፡
                        ኮነ፡ ወሶበ፡ ርእየ፡ ንጽሐ፡ ዚአኪ፡ ለሊሁ፡ <hi rend="rubric">እግዚአብሔር። አብ፡ ፈነወ፡</hi> ሀቤኪ፡ መልአከ፡ ብርሃናዌ፡ ዘስሙ፡ ገብርኤል፡ ወይቤለኪ፡ መንፈስ፡
                        ቅዱስ፡ ይመጽእ፡ ላእሌኪ፡ ወኃይለ፡ ልዑል፡ ይጼልለኪ፡ መጽአ፡ ኃቤኪ፡ ቃል፡ እንዘ፡ ኢይትፈለጥ፡ እምህጽነ፡ አቡሁ፡ ፀነስኪዮ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#10v">Fol. 10v</locus>
                        ይ፡ ካህ፡ አንብሮ፡ እድ፡ ነአኩቶ፡ ለእ<hi rend="ligature">ግዚ</hi>አብሔር፡ በእንተ፡ ኩሉ፡ ጸጋ፡ ዘአልጠና፡ ለእሙ፡ ወለእለ፡ ዛቲ፡ ቅዳሴ፡ ወለነኒ፡ ንንብብ፡ በኂሩቱ፡
                        ወንፈጽም፡ በሥምረቱ፡ ሎቱ፡ ስብሐት፡ ወውእቱ፡ ጠቢብ፡ ለአመ፡ አለም፡ አሜን፡ ኤአሜየን፡ ይበ፡ ካህ። ወረከብኩ፡ በውሥቴታ፡ ዘንተ፡ ቅዳሴ፡ ዘይዌድስ፡
                        <add place="above">ካህን፡</add> አኮ፡ ማርያም፡ ዘይዌድስ፡ አላ፡ ለሊሁ፡ ይትዌደስ፡ ወኩሎሙ፡ እለ፡ ሰምዕዋ፡
                        ይትዌደድሱ፡ እስመ፡ ማርያም፡ ቅድስት፡ ይእቲ፡ በሰማይ፡
                        ወበምድር፡ በባህር፡ ወበቀላያት፡ ለአለመ፡ አለም፡ አሜን፡
                    </explicit>
                     <explicit type="supplication" xml:lang="gez">
                        <locus target="#11r">Fol. 11r</locus>
                        ጸሎታ፡ ወበረከታ፡ የኀሉ፡ ምስለ፡ ገብራ፡ <persName ref="https://betamasaheft.eu/PRS12139GabraH">ገብረ <supplied reason="omitted" resp="DN">፡
                      </supplied>ህይወት፡</persName> ወፍቁራ፡
                        <persName ref="https://betamasaheft.eu/PRS12140HabtaS">
                           <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">አባ፡</t:roleName> ኀብተ፡ ጽዮን።</persName> ለአለመ፡ አለም፡ አሜን።
                     </explicit>
                     <note>The initial part of the work is missing.
                        The beginning of the text corresponds to
                        <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Ba-gǝʿzǝnnā ba-ʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><name>Anon.</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><note type="tags"><note type="tag">bm:1962Qeddase</note></note><note type="tag">bm:1962Qeddase</note><citedRange unit="page">112</citedRange><citedRange unit="paragraph">40</citedRange></bibl> (see also <bibl corresp="http://zotero.org/groups/358366/items/UV8BMXC4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Euringer1937AnaphMaria"/><title level="a">Die äthiopische Anaphora unserer Herrin Maria</title><title level="j">Oriens christianus</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sebastian</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Euringer</t:surname></author><date>1937</date><biblScope unit="volume">12</biblScope><biblScope unit="page">63-102, 248-262</biblScope><citedRange unit="number">43γ</citedRange></bibl>).
                  </note>

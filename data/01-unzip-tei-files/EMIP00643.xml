               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="53v" facs="005">Fols 1r–53v</locus>
                      <title>Acts of Gälawǝdewos (Claudius), Gädlä Gälawǝdewos, <foreign xml:lang="gez">ገድለ፡ ገላውዴዎስ፡</foreign></title>
                      <incipit xml:lang="gez">
                        በስመ፡ ወወልድ፡<gap reason="omitted"/>ድርሳን፡ ዘነበበ፡ በእንተ፡ ቅዱስ፡ ክቡር፡ ገላውዴዎስ፡ ክቡር፡ አባ በዘዚአሁ፡ ፆታ፡ አባ፡ ቴዎድርስ፡ ሊቀ፡ ጳጳሳት፡ ዘአንጾኪያ፡ በእንተ፡ ክብሩ፡ ለቅዱስ፡ ጽኑዕ፡ ወኃያል፡ ድንግል፡ ወንጹሕ፡ መዋዒ፡ ወመስተጋድል፡ መልክዓ፡ መላእክት፡<gap reason="omitted"/>
                        </incipit>

                        <note>arranged for the months</note>
                      </msItem>


                  <msItem xml:id="ms_i2"><locus from="53v" to="79v" facs="058">Fols 53v–79v</locus>
                    <title>Nine Miracles of Gälawǝdewos (Claudius), Tä’ammǝrä  Gälawǝdewos, <foreign xml:lang="gez">ተአምረ፡ ገላውዴዎስ፡</foreign></title>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="79v" to="85r" facs="084">Fols 79v–85r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3035RepCh315">Hymn to
                                                  Galāwdewos</title>
                    <incipit xml:lang="gez">
                      ናሁ፡ ተወጥነ፡ ለመልክእኮ፡ ስላም፡
                      እንዘ፡ መንፈስ፡ ቅዱስ፡ ይረድእ፡ ወያበጽሕ፡ እስከ፡ ተፍጻሙ፡
                      ገላውዴዎስ፡ ዓርከ፡ መንግሥት፡ ገላውዴዎስ፡ ለለጌሠሙ፡
                      ዘምስለ፡ ንግሥከ፡ ንግሥሡ፡ ወምስለ፡ ስምከ፡ ስሙ፡
                      እስመ፡ ተሳተፈ፡ እምርሐይ፡ ቀዲሙ፡
                    </incipit>
                  </msItem>

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጽሎተ፡ 
                                <supplied reason="lost" resp="PRS8999Strelcyn">ቅዱስ፡ ሱስ</supplied>ንዮስ፡ በእንተ፡ 
                                አሰ<supplied reason="lost" resp="PRS8999Strelcyn">ስሎ፡ ደዌ፡</supplied> እምሕፃናት፡ እለ፡ 
                                ይ<supplied reason="lost" resp="PRS8999Strelcyn">ጠብው፡ ጥ</supplied>በ፡ እሞሙ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4623Prayer">Ṣalot baʾǝnta ḥǝmāma qʷǝrṭat</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> አበከፓኮስ፡ ስምከ፡ በሕርያኖስ፡ ስምከ፡ <gap reason="ellipsis"/> አድኅና፡ 
                                እምሕማመ፡ ቍርፀት፡ ለአመትከ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS14816WalattaSy">ወለተ፡ 
                                    <supplied reason="lost" resp="PRS8999Strelcyn">ጽዮን፡</supplied></persName></incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4625Prayer">Ṣalot baʾǝnta ḥǝmāma wǝgāt</title>
                            <incipit xml:lang="gez">ሰላም፡ ለገባከ፡ በእደ፡ ለ<supplied reason="lost" resp="PRS8999Strelcyn">ን</supplied>ጊኖስ፡ ዘትወጋዕከ፡ 
                                <gap reason="ellipsis"/> በእንተ፡ ስምከ፡ ኢየሱስ፡ ክርስቶስ፡ ናስተበቍዓከ፡ ኪያነ፡ ጸጋከ፡ አድኅና፡ እምሕማመ፡ ውግዓት፡ ወ፡ ቍርጥማት፡ 
                                ው<supplied reason="lost" resp="PRS8999Strelcyn">ግ</supplied>ዓት፡ <sic>ወፍቅቃት፡</sic> ወስቅስቃት፡ ፍጌን፡ ወአልጉም፡
                                    </incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT7444PPLofham">... ʾǝnza yǝbǝl ʾasmāta Lofḥam ...</title>
                            <note>The beginning is missing.</note>
                            <incipit xml:lang="gez"><gap reason="lost"/>
                                ፼ገጸ፡ ሰብእ፡ ወደገመ፡ ዘንተ፡ እንዘ፡ ይብል፡ አስማተ፡ <persName ref="https://betamasaheft.eu/PRS6357Lot">ሎፍሐም፡ ሎፍሐም፡ ሎፍሐም፡</persName>
                                <persName ref="https://betamasaheft.eu/PRS8925Solomon">ሰሎሞን፡ ሰሎሞን፡ ሰሎሞን፡</persName> ዮአስ፡ ዮአስ፡ ዮአስ፡ <gap reason="ellipsis"/> 
                                ወሶበ፡ ይብል፡ ዘንተ፡ አስማ<supplied reason="lost" resp="PRS8999Strelcyn">ተ፡</supplied> ከመዝ፡ አውፅእ፡ ልሣኖ፡ ንጉሥ፡ በእመተ፡ 
                                መላእክት፡ ወአተበ<supplied reason="lost" resp="PRS8999Strelcyn">፡</supplied> ገጾ፡ ለሰሎሞን፡ እንዘ፡ ይብል፡ <gap reason="ellipsis"/> 
                                አድኅነኒ፡ እምተቀታሌ፡ ነሀብት፡ ወእም፡ ውግረተ፡ እብን፡ <gap reason="ellipsis"/> ከመ፡ እይምክሩ፡ እኩየ፡ በላእሌየ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7445PPQahashun">Qāḥašun qāḥašun qāḥašun ʾǝm-qāḥašun ba-ʾaboñu mǝʿomu
          la-ʾagānǝnt la-Bāryā wa-Legewon Dask</title>
                            <incipit xml:lang="gez">ቃሐሹን፡ ቃሐሹን፡ ቃሐሹን፡ እምቃሐሹን፡ በዘቦኙ<supplied reason="lost" resp="PRS8999Strelcyn">፡</supplied> ምዖሙ፡ 
                                ለአጋንንት፡ ለባርያ፡ ወሌጌዎን፡ ደስክ፡ በዝንቱ፡ አስማቲከ፡ ለእግዚአብሔር፡ ሎፍሐም፡</incipit>
                            <textLang mainLang="gez"/>
                            <textLang otherLangs="am"/>
                        </msItem>

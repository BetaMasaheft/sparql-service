               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="2v">2v-2v</locus>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0688IHA">دعاء ختم القرآن الهمّ اجعلنا لنعمائك شاكرين</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>شاربين وبزمرته محشورين وبجماعته داخلين ويوم القيامة امين برحمتك يا ارحم الراحمين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>اللهم اجعل لنا خير الدنيا والاخرة وقنا شر الدنيا والاخرة وبرحمتك يا ارحم الراحمين</explicit>
                     <note>
                        <note>
        Manuscript item  6974 relates to manuscript item 6973</note>
                     </note>
                     <note>The beginning of the duʻā' is on fol. 19v</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="19r">3r-19r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT0049IHA#s24IHA">قران, Seventeenth ǧuz’ (17/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيْمِ اُقْتَرَبَ لِلْنَاسِ حِسَابُهُمْ وَهُمْ فِي غَفْلَةٍ مُّعْرِضُونَ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19r">-19r</locus>وَ أَتُوْا الـ[  ]كَوَةَ واُعْتَصِمُوْا بِا اللهِ [هكذا] [.؟.]ـمْ فَنِعْمَ المَوْلَيْ و[    ]ـنِّصِيْرُ <note>Part of the folio torn off. Last word: šadda above fatḥa.</note>
                     </explicit>
                     <note>21:1-22:78. Ihmāl marks on rā's. 13 lines a page. Rubricated title of suras. Elaborated execution of lām/lā. Several words completed on the following line. Several words were started on a line, and were entirely rewritten on the following line. Deletions and corrections by the copyist. Catchwords.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="19v" to="19v">19v-19v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT0688IHA">دعاء ختم القرآن الهمّ اجعلنا لنعمائك شاكرين</title>
                     <incipit xml:lang="ar">
                        <locus target="#19v">-19v</locus>بسم الله الرحمن الرحىم \ اللهم اجعلنا لنعماك شاكرين وعن [بلايك] ناجين وبما قضيت علىنا راضين

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>ثابتين والي الانبياء مراف[.؟.] \ الكريم يا رب ناطرين .؟<note>Ends of the lines torn off</note>
                     </explicit>
                     <note>Written by a different hand than the Qur'ān. Part of the folio torn off.</note>
                     <note/>
                  </msItem>

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="108v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1719Bookso">Books of Kings</title>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="3r" to="29v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2697Sam">Book of Samuel 1 = (Ethiopic) Book of Kings 1</title>
                                
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="29v" to="53r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2698Sam">Book of Samuel 2 = (Ethiopic) Book of Kings 2</title>                                
                            </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="53r" to="81r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2699Kings">Kings 1 = (Ethiopic) Book of Kings 3</title>
                                <note/>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="81r" to="108v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2700Kings">Kings 2 = (Ethiopic) Book of Kings 4</title>
                                <note/>
                            </msItem>
                            
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="109r" to="133v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2358Sirach">Book of Sirach</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="134r" to="174r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1819Maccab">Maccabees, Book of (Ethiopic)</title>
                            <note>in three parts</note>
                            <incipit xml:lang="gez">በመንግሥተ፡ ሜዶናውያን፡ ወሞአባዊያን። ወሀሎ፡ ፩ንጉሥ፡ ዘስሙ፡ ፂሩፃይደን፡ ፈታዊሃ፡ ለእኪት፡</incipit>
                            <explicit type="subscriptio" xml:lang="gez">ተፈጸመ፡ ፫ብሔር፡ ዘመቃብያን፡ በሰላመ፡ እግዚአብሔር፡ አሜን።</explicit>
                        </msItem>
                   
                                              
                        <msItem xml:id="ms_i4">
                            <locus from="175r" to="183v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1362Esther">Book of Esther</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="183v" to="195r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1701Judith">Book of Judith</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="195r" to="202v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2473TobitB">Tobit, Book of</title>
                        </msItem>
                        

                        <additions>
                            <list> 
                                <item xml:id="a1">
                                    <locus target="#2r #202v #203r"/>
                                    <desc type="Unclear">List of clergy (dabtarā Kidāna Mǝḥrat, ʾalaqā ʾAbib, dabtarā qes Mikāʾel, etc.) 
                                        who were to undertake certain duties during certain months </desc>
                                    <q xml:lang="gez">ኍልቈ፡ ደብተራ፡ ዘኪዳነ፡ ምሕረት፡ የቀኝ፡ መሪ፡ ዘመስከረም፡ አለቃ፡
                                        አቢብ፡ ደብተራ፡ ቄስ፡ ሚካኤል፡ 
                                        እንበረም፡ ጫሮ፡ ጊዮርጊስ፡ ...</q>
                               </item>
                                
                                <item xml:id="a2">
                                    <locus target="#2v"/>
                                    <desc type="Inventory">Inventory of books, articles of dress, etc.</desc>
                                    <q xml:lang="gez">ኍልቈ፡ መጻሕፍት፡ ወግምጃ፡ ዘደፈጫ፡ ኪዳነ፡ ምሕረት፡ ነገሥ ት፡ ሲራክ፡ መቃብያን፡ 
                                        አስቴር፡ ፯ግ ምጀ፡ በርኖስ፡ ፩ቋቋቴ፡ በርኖስ፡ ፩ካፓ፡ ...</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#3r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                    </desc>
                                    <q xml:lang="gez">ነገሥት፡ ዘቅ' ፡ መ' ፡ ዓለም።</q>
                                </item>
                            </list>
                        </additions>
                        
                        <bindingDesc>
                            <binding contemporary="partly" xml:id="binding">
                                <decoNote xml:id="b1" type="Boards">Two wooden boards.</decoNote> 
                                <decoNote xml:id="b2" type="Cover">Blind-tooled leather <term key="quarterCover" ana="#quarterCover">quarter cover</term>
                                    (with the gilded title and shelfmark on the spine).</decoNote> 
                                <decoNote xml:id="b3" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                </decoNote>
                                <decoNote xml:id="b4" type="SewingStations">4</decoNote> 
                                <decoNote xml:id="b5" type="SewingStations">Sewing stations are used in an irregular way.</decoNote> 
                                <decoNote xml:id="b6">The back board looks very different from the front board and might have been furnished in the library
                                    (Wright, on the contrary, states that both boards are original). The leather quarter cover also does not seem to be original, possibly supplied together with the back board.
                               </decoNote>
                            </binding>
                        </bindingDesc>

               <msPart xml:id="p2">
                  <msIdentifier>
                     <collection/>
                  </msIdentifier>
                  <msContents>
                     <summary/>
                     <msItem xml:id="p2_i1">
                        <locus from="32a" to="64a">Fols 32a–64a</locus>
                        <title type="supplied">Symbolic interpretation of the creation by a different hand. Since it is called also [śena fetrat], (f. 64a). Also, since the story of the fall of Adam and his attempt to go back to Garden of Eden is also related.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>This part seems to represent creation on Friday even though it is incomplete at the beginning and is copied by a different hand. Ff. 1a, 59a-60a, 64b-65a, 74a-75a, 79b, 81b and 82b blank.</note>
                     </msItem>
                     <msItem xml:id="p2_i2">
                        <locus from="65b" to="81a">Fols 65b–81a</locus>
                        <title type="supplied">Symbolic interpretation of the creation of man by a different hand. The prophecies about salvation is also realted here. Ff. 80a-81a is still by a different hand in pencil.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i3">
                        <locus target="#82a">Fol. 82a</locus>
                        <title type="supplied">15 lines in pencil on the teachings of the Gospel called here [Mestira āśara Wangēl] "Mystery of the trace of the Gospel".</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i4">
                        <locus target="#82a">Fol. 82a</locus>
                        <title type="supplied">A note in pencil on the meaning of life from birth to death [ka-ledat eska mot].</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i5">
                        <locus target="#82a">Fol. 82a</locus>
                        <title type="supplied">A note in pencil on Resurrection.</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                  </msContents>

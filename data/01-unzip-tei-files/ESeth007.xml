                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Notes in the upper margin of some fols. indicate
                              the monthly readings from the Vita of Takla Hāymānot as follows:
                              reading for Yakkātit (fols. 3r-8r); reading for Maggābit (fols.
                              8r-15v); reading for Tāḫśāś (fols. 15v-24r); reading for Maskaram
                              (fols. 24r-28r); reading for Ṭǝrr (fols. 28r-33v); reading for Naḥāse
                              (fols. 33v-38r); reading for Ṭǝqǝmt (fols. 38r-46v); reading for Ḫǝdār
                              (fols. 46v-49v); reading for Ḥamle (fols. 49v-57v); reading for Gǝnbot
                              (fols. 57v-68r); reading for Sane (fols. 68r-74r); reading for Miyāzyā
                              (fols. 74r-80v).</desc>
                        </item>
                     </list>
                  </additions>

                     <incipit xml:lang="gez">
                        ቅዱስ፡ ቅዱስ፡ ሥሉስ፡ ዘኢ<supplied reason="omitted" resp="DR">ይ</supplied>ትነገር፡ ሀበኒ፡ ከመ፡
                        <supplied reason="omitted" resp="DR">እ</supplied>ንሣእ፡ ለህይወት<hi rend="rubric">፨</hi>
                        ዘንተ፡ ሥጋ፡ ወደም፡ ዘእንበለ፡ ኵነኔ፡ ሀበኒ፡ እግበር፡ ፍሬ፡ ዘያሰምረከ፡
                        ወከመ፡ አስተርኢ፡ ወስብሐቲከ፡ ወእህየው፡ ለፀከ፡ እንዘ፡ እግብር፡ ዘዚአከ፡
                        ፈቃደ፡ በተአምኖ፡ ወእጼውእ<hi rend="rubric">፨</hi>
                     </incipit>
                     <explicit xml:lang="gez">
                        መንግሥትከ፡ ይትቀ<pb n="112r"/>ደስ፡ እግዚኦ፡
                        ስመከ<hi rend="rubric">።</hi> በላዕሌነ<hi rend="rubric">፨</hi>
                        እስመ፡ ኃያል<supplied resp="DR" reason="omitted">፡</supplied> አንተ፡ እኩት፡ ወስቡሕ፡ ወለከ፡ ስብሐት፡ ለዓለመ፡
                        ዓለም<hi rend="rubric">፨</hi> አሜን<hi rend="rubric">፨</hi> <hi rend="rubric">፨</hi>
                     </explicit>

                  <msItem xml:id="ms_i1">
                        <locus from="2v" to="53v">Fols 2v–53v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara
                    Bǝhnǝsā</title>

                        <textLang mainLang="gez"/>

                     <incipit xml:lang="gez" type="inscriptio">
                         <hi rend="rubric">በስመ፡ አብ<supplied resp="DR" reason="omitted">፡</supplied> ወወልድ፡ <sic resp="DR">ወመንፈንስ፡</sic> ቅዱስ፡</hi>
                        ፩አምላክ፡ አኰቴተ፡ ቍርባን፡ <hi rend="rubric">ዘእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላ</hi>ክ፡
                     ዘደረሰ፡ አባ፡ ሕርያቆስ፡ <sic resp="DR">ዘሀገር፡</sic> <sic resp="DR">ብንህሳ፡</sic>
                     </incipit>

                     <incipit type="supplication" xml:lang="gez">
                        ጸሎታ፡ ወበረከታ፡ የሃሉ፨ ምስለ፡ ገብራ፨ <persName ref="https://betamasaheft.eu/PRS11960HabtaM">
                           <hi rend="rubric">ኀብተ፡ ማርያም፡</hi>
                        </persName> ለዓለመ፡ ዓለም፨ አሚን፡
                     </incipit>

                     <incipit xml:lang="gez">
                        <hi rend="rubric">ጐሥዓ፡ ልብየ<supplied resp="DR" reason="omitted">፡</supplied> ቃለ። ሠናየ። ጐሥዓ፡ ልብየ ቃለ፡</hi> ሠናየ፡ ጐሥዓ፡
                        ልብየ<hi rend="rubric">፨</hi> ቃለ፡ ሠናየ<hi rend="rubric">፨</hi>
                     </incipit>

                     <explicit xml:lang="gez">
                        <locus from="52v" to="53r">Fols 52v–53r</locus>
                        <hi rend="rubric">ወረከብኩ፡ <del rend="expunctuated">መ</del>በውስቴታ፡ ዘይ</hi>ብል፡
                        ዘይቄድስ<hi rend="rubric">፨</hi> ዘንተ፡ ቅዳሴ፡ ካ <pb n="53r"/>ህን፡ አኮ፡
                        <hi rend="rubric">ማርያም፡</hi>ሃ<hi rend="rubric">፨</hi> ዘይቄድስ<hi rend="rubric">፨</hi>
                        አላ<supplied resp="DR" reason="omitted">፡</supplied> ውእቱ፡ ይትቄድስ<hi rend="rubric">፨</hi>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2v">1r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0026IHA">مختصر ﺍبي شجاﻉ على مذﻫب ﺍلشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>جائز ولكل منهما فسخها متى شاء وتنفسخ بموت أحدهما والوكيل أمين فيما يقبضه وفيما يصرفه ولا يضمن إلا بالتفريط </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>ويجوز الوصية من كل مالك حاقل لكل متملك وفي سبيل الله تعلى وتصلح الوصية [...] فيه خمس شرائط الاسلام والبلوغ والعقل والحرية والامانة. كتاب [نكاح] وما يتعلق به من ءحكام و [والقص وبنكاح] مستحب</explicit>
                     <note>Fragment</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="51v">3r-51v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0033IHA">اتحاف ﺍلمرﻳد بجوﻫرة ﺍلتوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>بسم الله الرحمن الرحيم الحمد لله الذي رفع لاهل السنة المحمدية في الحاقيقين اغلى ووضع يواضح ادلته من شبه المخالفين اغلى ما واشهد لا اله الا الله وحده لا شريك له</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#51v">-51v</locus>فقال ولكن انها المكلف بعد رفض الموانع والشواغل العايقة عن الوصول الى الحق في حقذك</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="88r" to="93v">88r-93v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0399IHA">آجرومية</title>
                     <incipit xml:lang="ar">
                        <locus target="#88r">-88r</locus>كقولك ضرب زيد عمرا رفعت زيدا لانه فاعل ونصبت عمرا لانه مفعول</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#93v">-93v</locus>واما الافعال ثلاثة ماض ومضارع وامر نحو ضرب ويضرب واضرب فالماضي مفتوح</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="94r" to="96v">94r-96v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0970IHA">رسالة في الايمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#96v">-96v</locus>احدا وفسر الشرك هنا باالرياء فلعلها تقلع بذالك وتخلص</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#94r">-94r</locus>فمن كان يرجو لقاء ربه فليعمل عملا صالحا ولا يشرك بعبادة ربه<note>Qur'an 18:110</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="97r" to="98v">97r-98v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0543IHA">قصيدة الهمزية في مدح خير البرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#97r">-97r</locus>ويح قوم جفوا نبيا بأرض ألفته ضبأبها والظباء | وسلوه وحـن جذع اليه وقلوه ووده الغـرباء| أخرجوه منها وآواه غار وحمته حمامة ورقاء| وكفته بنسجها عنكبوت ما كفته الحمامة الحصداء | واختفــي منهم علي قرب مرآه ومن شدة الظهور الخفــــــاء 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98v">-98v</locus>كل وصف له ابتدأت به استوعب أخبار الفضل منه سيد ضحكه التبتسم المشي الهوينا ونومه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="99r" to="99v">99r-99v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#99r">-99r</locus>نَنْسَاهُمْ كَمَا نَسُوا لِقَاءَ يَوْمِهِمْ هَذَا وَمَا كَانُوا بِآَيَاتِنَا يَجْحَدُونَ<note>Qur’ān 7:50</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#99v">-99v</locus>واغرقنا الذين كذبوا باياتنا انهم كانوا<note>Qur’ān 7:64</note>
                     </explicit>
                     <note>Fragment: verses 7:50-7:64.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="52r" to="69v">52r-69v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0668IHA">فتح القريب المجيب في شرح ألفاظ التقريب</title>
                     <incipit xml:lang="ar">
                        <locus target="#69v">-69v</locus>يع السير على هيئة السفينة في البحر ولو اشتدت الريح وهكذا ذاهب القمر في البر خصوصا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52r">-52r</locus>اقلهم اربعة اشهد بالله انى لمن الصادقين فيما رميت به زوجتى الغائبة فلانة من الزنا وان كانت حاضرة اشاربها بقوله زوجتى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="70r" to="79v">70r-79v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT1611IHA">شرح منظومة وثوب حياتي</title>
                     <incipit xml:lang="ar">
                        <locus target="#70r">-70r</locus>بفتح اللام اي انا ضعيف على مخالفة النفس والهوى وعاجز عن متابعة الهدى وموافقة التقى وحرصت حريصا عىل ارتكاب المناهى واكتساب وثوب حياتى بالذنوب ترقعا بالاف الاطلاق </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#79v">-79v</locus>فعجل علاجي انني لسقيم اي فستعجل في علاج المريض المقيم فانني لسقيم وانت حبيب كريم طبيب حليم وباالمؤمنين رحيم رؤف ضعيف وبالعصيان اصبحت مولعا بفتح اللام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="80r" to="80v">80r-80v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0371IHA">صحيح البخاري</title>
                     <incipit xml:lang="ar">
                        <locus target="#80r">-80r</locus>سار ساعة ثم قال يا معاذ بن جبل قلت لبيك يا رسول الله وسعد يك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#80v">-80v</locus>ومن راني في المنام فقدراتي حقا فان الشيطان لا يتمثل على صورتي ومن كذب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="81r" to="82v">81r-82v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0970IHA">رسالة في الايمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#81r">-81r</locus>من راحلته فبينما هو كذلك اذهي بهما قائمة عنده فأخذ بحطامها رواه مسلم وروا الترمذي وصحه حديث</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#82v">-82v</locus>قال تعلى هو الأول والأخر الخالق اي الموجد للأشيا قال الله خالق كل شيء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="83r" to="84v">83r-84v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT2218IHA">شهاب الاخبار في الحكم والامثال والاداب من الاحاديث
                    المروية عن الرسول المختار</title>
                     <incipit xml:lang="ar">
                        <locus target="#83r">-83r</locus>غريبا وسيعود غريبا الدين كما بدأ فطوبي للغرباء ان الفتنة تجيا فتنسف العبادة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#84v">-84v</locus>اعظم الخطايا اللسان الكذوب ماملا أذمي وعائش من بطن باب باطن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="85r" to="85v">85r-85v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1611IHA">شرح منظومة وثوب حياتي</title>
                     <incipit xml:lang="ar">
                        <locus target="#85r">-85r</locus>نحن المتقدمون ما جأنا علم الموؤدة من قبل [.؟.] عليه السلام ان لم تكن هذه من معجزا [ترو] خوارق عاداته الدالة انه من الرسل الكرام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#85v">-85v</locus>واعلن قدما بكسر فسكون فى الخلائق فضلهم اي واظهر فى قديم الزمان فى ما بين الانبياء وعلماء الأعيان فضلهم على سائر اهل الاديان وعظمهم بتشديد الظا اي تعظيما عظيما</explicit>
                     <note>The text appears to be written by the same hand as fols 70r-79v.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="86r" to="86v">86r-86v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0970IHA">رسالة في الايمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#86r">-86r</locus>وسلم لا نعدل بابي بكر احدا ثم عمر ثم عثمان ثم علي سو في رؤية الطبراني كنا نقول ورسول لله [مع؟] حي افضل هذا الامة بعد نبيها ابو بكر وعمر وعثمان وعلي  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#86v">-86v</locus>روى البخاري عن بن عمر رضي الله عنهما قال كنا في زمن النبي صل الله عليه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="87r" to="87v">87r-87v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0020IHA">منهاج الطالبين</title>
                     <incipit xml:lang="ar">
                        <locus target="#87r">-87r</locus>والا فان كان للصلب بنت فلها النصف والباقى لولد الابن الذكور أو الذكور والاناث</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#87v">-87v</locus>فلا فضل الاخوة والاخوات لابوين اذ انفردوا ورثوا كاولاد الصلب وكذا ان كانو الاب الا فى المشركة<note>It is in fol. 88r, but I think that the image is upside down, so it should be in 87v</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>

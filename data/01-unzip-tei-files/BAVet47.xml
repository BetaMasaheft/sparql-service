                  <msItem xml:id="ms_i3">
                     <locus from="189rb" to="203vb" facs="0192"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2300Sebhat">ስብሐተ፡ ፍቁር፡</title> 
                     <incipit xml:lang="gez">
                        ዝንቱ፡ ስብሐተ፡ ፍቁር፡ <choice>
                           <sic>ዘይትኀሀለሉ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ዘይትመሀለሉ፡</corr></choice>
                         ቦቱ፡ 
                        
                           <sic>ክርስትያን፡</sic>
                         
                        
                           <sic>በጌዜ፡</sic>
                         ምንዳቤሆሙ። ኦብእሲ፡ 
                           <sic>ክርስትያናዊ፡</sic>
                         
                        
                           <sic>ክርስቶሰዊ፡</sic>
                        ለእመ፡ <choice>
                           <sic>ረከብኪ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ረከብከ፡</corr>
                        </choice>
                        ቤተ፡ ክርስቲያን፡ ተማህለል፡ ቦቱ፡ በምሥዋዕ፡ ለእመ፡ በጽሐከ፡ ተሰዶ፡ ተማህለል፡ በስደትከ። 
                     </incipit>
                     <explicit xml:lang="gez">
                        ሃ፡ በእንተ፡ ሥጋከ፡ ለሀጥኣን፡ ዘተጠብሃ፡ ምህላነ፡ ረሲ፡ ንፁሐ። ሃ፡ በእንተ፡ ደምከ፡ በዲበ፡ ዕፅ፡ ዘተክዕወ፡ ምህላነ፡ ረሲ፡ ህልወ። በዝ፡ ሥጋከ፡ ወበዝ፡ ደምከ፡ ተማኅፀነ፡ እሊአከ፡ ምህላነ፡ ደይ፡ 
                        በሕ<supplied reason="omitted">ፅ</supplied>ንከ።
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="204ra" to="212rb" facs="0207"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4322Mahtam">ጸሎተ፡ ማኅተም፡</title> 
                     <incipit xml:lang="gez">
                        አኀትም፡ ገጽየ፡ ወገጸ፡ ኵሎሙ፡ መሃይምናን፡ በማ<supplied reason="omitted">ኅ</supplied>ተመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘይበርህ፡ እመብረቅ፡ ወይበልሕ፡ እምሰይፍ፡ ዘኢይክሉ፡ ቀሪቦቶ፡ ሰራዊተ፡ መስቴማ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        አኀትም፡ ገጽየ፡ 
                           <sic>በማኅተማ፡</sic>
                         ኵሎሙ፡ ተዓይነ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨ በረከተ፡ እዴሆሙ፡ ወበረከተ፡ አፉሆሙ፨ በረከተ፡ ጸሎቶሙ፡ 
                        
                           <sic>ወሰእለቶሙ፨</sic>
                         
                        
                           <sic>ተኩን፡</sic>
                         ምስሌነ፡ ወትባርከነ፡ 
                           <sic>እሰከ፡</sic>
                         
                        
                           <sic>ለዓለም፡</sic>
                         ዓለም፡ አሜን፡ አሜን፡ አሜን፨ ወአሜን፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="212va" to="213vb" facs="0216"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4323SalotaHa">ጸሎተ፡ ሃይማኖት፡</title> 
                     <incipit xml:lang="gez">
                        አአምን፡ በአብ፡ ከመ፡ አብ፡ ውእቱ፡ በህላዌሁ። ወአአምን፡ በወልድ፡ ከመ፡ ወልድ፡ ውእቱ፡ በህላዌሁ። አአምን፡ በ<supplied reason="omitted">መ</supplied>ንፈስ፡ ቅዱስ። ከመ፡ 
                        መንፈስ፡ ቅዱስ፡ ውእቱ፡ 
                           <sic>በህላዊሁ።</sic>
                        
                     </incipit>
                     <explicit xml:lang="gez">
                        ወመንፈስ፡ ቅዱስኒ፡ ዘተሰምየ፡ ጰራቅሊጦስ፡ ዘይወፅእ፡ እምአብ፡ ወይነሥእ፡ እምወልድ። ዘወረደ፡ ላዕለ፡ ሐዋርያት፡ ንጹሐን፡ በደብረ፡ ጽዮን። ፶ጽባሕ። ወአንበቦሙ፡ በነገረ፡ ኵሉ፡ በሐውርት። ሎቱ፡ 
                        ስብሐት፡ በአፈ፡ ኵሉ፡ ፍጥረት፡ በምድር፡ ወበሰማያት፡
                     </explicit>
                     <explicit type="subscriptio" xml:lang="gez">
                        <locus target="#213vb" facs="0217"/>
                        ዛቲ፡ ህይማኖት፡ እምነትየ፡ ወተስፋየ፡ ኀ<supplied reason="omitted">ይ</supplied>ልየ፡ ወጽንዕየ፡ ወምስካይየ፡ ወጸወንየ፡ ወባቲ፡ እድኅን፡ እምፀርየ፡ 
                        ወእ<supplied reason="omitted">መ</supplied>ውኦሙ፡ ለኵሎሙ፡ ጸላዕ<supplied reason="omitted">ት</supplied>የ። ወልታ፡ ሥላሴ፡ 
                        <supplied reason="omitted">ተ</supplied>ወኪልየ፡ 
                           <sic>ዕፅ፡</sic>
                         
                        
                           <sic>መስቀ<supplied reason="omitted">ል፡</supplied>
                           </sic>
                         
                         ተመርጕዝየ፡ እምዮርዳኖስ፡ ዘተአንመ፡ <choice>
                           <sic>ንዳነ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ክዳነ፡</corr></choice>
                         ብርሃን፡ 
                        <choice>
                           <sic>ተአጽየ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ተአጺፍየ።</corr></choice>
                         በጸሎታ፡ 
                           <sic>ወበስዕላተ፡</sic>
                         
                        ለማርያም፡ 
                           <sic>ደን<supplied reason="omitted">ግ</supplied>ል፡</sic>
                         
                        
                           <sic>እግዚእትየ፡</sic>
                         እንተ፡ 
                        ባቲ፡ 
                           <sic>እትማኃጸን፡</sic>
                         እ<supplied reason="omitted">ም</supplied>ንእስየ፡ 
                        <choice>
                           <sic>አሳከ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">እስከ፡</corr>
                         </choice>
                        <choice>
                           <sic>ርእስ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ርስእየ።</corr>
                        </choice>
                     </explicit>
                     <note/>
                  </msItem>

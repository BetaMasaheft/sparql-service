                        <additions>
                            <list> 
                                                             
                                
                                
                                <item xml:id="a1">
                                    <locus target="#5r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                    </desc>
                                    <q xml:lang="gez">ሰሎሞን፡ ዘቅ' ፡ መ' ፡ ዓለም።</q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#86v"/>
                                    <desc type="GuestText">
                              <title>Heads of knowledge, ነገረ፡ አርእስተ፡ አእምሮ፡ ቀዳማዊ፡ ወፍካሬሁ፡ ረቂቀ፡ ልቡ፡</title>:</desc>
                                    <q xml:lang="gez">beginning: ለባሕታዊ፡ ገነተ፡ ተድላ፡ ውእቱ፡ ወእምኔሁ፡ ይፈለፍል፡ ነቅዓ፡ ሕይወት፡
                                        ወይሰቅዮሙ፡ ለ፬ዘይቤ፡ አንብዕ።</q>
                                    
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#88r"/>
                                    <desc type="GuestText">A paragraph regarding <persName ref="https://betamasaheft.eu/PRS11386Arag">ʾAragāwi</persName> and 
                                        <persName ref="https://betamasaheft.eu/PRS11387Yoh">Yoḥannǝs</persName>.
                                        <q xml:lang="gez">አረጋዊ፡ ወዮሐንስ፡ አኃው፡ እሙንቱ፡ ወነበሩ፡ በደብረ፡ ኮናብዮስ፡ etc.</q>
                                    </desc>
                                    
                                </item>
                                
                                <item xml:id="a4">
                                    <locus target="#88r"/>
                                    <desc type="GuestText">A paragraph regarding <persName ref="https://betamasaheft.eu/PRS11388George">George the Syrian</persName>, in Amharic.
                                        <q xml:lang="am">
                                 <persName ref="https://betamasaheft.eu/PRS11388George">ጊዮርጊስ፡ ሶርያዊ</persName>፡ 
                                            ድምሆኝን፡ የ<placeName ref="https://betamasaheft.eu/LOC1602Atrons">አትሮንስ፡ ማርያምን</placeName> ፡ ደብተሩ፡ ድምሆኝ፡ 
                                            ገብረ፡ መድኅንን፡ ዘፃና፡ ገብረ፡ 
                                            መድኅን፡ እጫ፡ <persName ref="https://betamasaheft.eu/PRS2538BatraGi">በትረ፡ ጊዮርጊስን</persName> ፡ 
                                            እጫ፡ <persName ref="https://betamasaheft.eu/PRS2538BatraGi">በትረ፡ ጊዮርጊስ</persName> ፡ 
                                            <persName ref="https://betamasaheft.eu/PRS1280Abranyos">አበራንዮስን</persName> ፡ አብራንዮስ፡ መንፈቆ፡ 
                                            <persName ref="https://betamasaheft.eu/PRS11389Walda">ወልደ፡ ሃይማኖት</persName>ን፡ መንፈቆ፡ መምህሬ፡ 
                                            <persName ref="https://betamasaheft.eu/PRS11390Muse">ሙሴ</persName>ን፡ ዘአምሓራ።</q>
                                    </desc>
                                    
                                </item>
                                
                                
                                
                                
                                
                                <item xml:id="a5">
                                    <locus from="1v" to="4r"/>
                                    
                                    <desc type="Gloss">A gloss on the Song of Songs in Amharic, <ref type="mss" corresp="https://betamasaheft.eu/BLorient494#a11">BL orient 494</ref>.
                                        <q xml:lang="am">ስባሔ፡ ስባሔያት፡ ሰርድስን። ይትና፡ ያፈቅ፡ በፍቅረ፡ ቃሉ። 
                                            በነገረ፡ አፉሁ፡ ቃለ፡ እግዚ፡ ፪ጽላት፡ ቦ፡ እስራኤል። እለ፡ ይቤሉ፡ ምግባ። ከቀደም፡ ምግባ። 
                                            ቃለ፡ እስ፡ ቤተስ። etc.</q>
                                    </desc>
                                    
                                </item>
                                
                                
                                
                               
                                
                            </list>
                        </additions>
                        

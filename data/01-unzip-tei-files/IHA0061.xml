               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="98r">1r-98r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0020IHA#s1IHA">منهاج الطالبين, Rub‘ al-‘ibādāt: from the kitāb
                    al-ṭaḥāra to the end of kitāb al-ḥaǧǧ (first rub‘) 1/4</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>باسم الله الرحمن الرحيم الحمد لله البر الخواد الذي خلت نعمه عن الاحصاء بالاعداد المان باللطف والارشاد الهادي الى سبيل الرشاد الموفق للتفقه في الدين من لطف به واختاره من العباد احمد ابلغ حمد واكمله
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98r">-98r</locus>فان كان فرضا مستقرا بقى في ذمته او غير مستقر اعتبرت الاستطاعة بعد ومن فانه الوقوف تحلل بطواف وسعي وحلق وفيهما قول وعليه دم والقضاء لقضاء</explicit>
                     <note>Some of the words are divided into two different lines</note>
                     <note/>
                  </msItem>
               </msContents>

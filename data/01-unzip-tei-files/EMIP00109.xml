                  <additions>
                    <list>
                        <item xml:id="a1">
                           <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                           <desc type="Asmat">Asmāt prayer for help in learning with incipit <q xml:lang="gez"><gap reason="omitted"/>ትትር፡ ቦትር፡ አላቶር፡ በዝ፡ ቃልከ። ይኩን፡ ልብየ፡ ከመ፡ ፀሐይ፡ ወከመ፡ መብረቅ፡ ብሌህ፡</q></desc>
                        </item>
                        <item xml:id="a2">
                           <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                           <desc>Genealogical lists</desc>
                        </item>
                        <item xml:id="a3">
                           <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                           <desc type="Asmat">Asmāt prayer for help to win an argument at court with incipit
                             <q xml:lang="gez"><gap reason="omitted"/>በስመ፡ አብ፡ ብል፡ <gap reason="omitted"/> ጸሎት፡ በእንተ፡ ነገረ፡ ምጉት፡</q></desc>
                        </item>
                        <item xml:id="a4">
                           <locus from="139r" to="139v" facs="143">Fols 139r–139v</locus>
                           <desc type="Directive">The spiritual benefits produced through prayer, recitations, hymns, helping the church, etc., with incipit
                             <q xml:lang="gez">ዘአቡነ፡ ዘበሰማያት፡ ፍሬሁ፡ ፶፼፡ ዘምስለ፡ ፩ሽህ፡ ይከውን፡</q>
                             </desc>
                            </item>
                        <item xml:id="a5">
                           <locus target="#139v" facs="144">Fol. 139v</locus>
                           <desc type="Asmat">Asmāt prayer for help for protection against diarrhea, with incipit
                             <q xml:lang="am">ለትቅማጥ፡ ያሽክምት፡ ፯ጊዜ፡ ደመና፡ ሕር፡ ፯ጊዜ፡ ያከርፍትዕ፡ ፯ጊዜ፡ ሳዶቅ፡ ወጭት፡ ጽሒፈነ፡ ሐፂበከ፡ </q></desc>
                        </item>
                        <item xml:id="a6">
                           <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc type="OwnershipNote">Note of later ownership, in ink pen <foreign xml:lang="gez">ማሪጌታ፡ ካሴ፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="e1">
                           <locus target="#2r #10r #23r #73r #77r" facs="006 014 027 077 081">Folss. 2r, 10r, 23r, 73r, 77r, </locus>(erased)<locus target="#96v #97r #103r" facs="101 107">96v, 97r, 103r</locus>
                       Some folios contain marginal notations about the situation in which the Pslam should be read
                       </item>
                        <item xml:id="e2">
                      Numbered quires 1-14
                      </item>
                        <item xml:id="e3">
                      Scribal intervention:
                      words of text are written interlinearly <locus target="#19v" facs="024">fols. 19v, </locus>;
                      lines of text are written interlinearly <locus target="#86v" facs="091">86v, </locus>;
                      lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted <locus target="#4r" facs="008"> f. 4r, line 7</locus>;
                      <locus target="#88r" facs="092"> f. 88r, line 12</locus> to correct homoeoteleuton);
                      erasure markings are visible in red ink <locus target="#17v" facs="022"> f. 17v, line 5</locus>;
                      <locus target="#51v" facs="056"> f. 51v, line 9</locus>;
                      <locus target="#59r" facs="063"> f. 59r, line 19</locus>;
                      <locus target="#79v" facs="084"> f. 79v, line 21</locus>;
                      <locus target="#94v" facs="099"> f. 94v, line 6</locus>; etc.).
                      </item>



      <t:body>
         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">እሌኒ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾƎleni</t:persName>
               <t:occupation type="political">governor</t:occupation>
               <t:faith type="EOTC"/>
               <t:nationality type="Ethiopia"/>
             
               <t:floruit notBefore="1682" notAfter="1708">She was a daughter of <t:persName ref="https://betamasaheft.eu/PRS10375Yohanne">
                     <t:roleName type="title">ʾaṣe</t:roleName>Yoḥannǝs I</t:persName> and a sister of <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</t:persName>. 
                  She was a remarkable figure in Ethiopian political life during the last quarter of the 17th century.
                  She was brought to prominence by <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</t:persName> who immediately after his coronation in <t:date>1682</t:date>
                  granted her the title of the govenor of <t:placeName ref="https://betamasaheft.eu/LOC5671Semen">Sǝmen</t:placeName>. After <t:date>1685</t:date>
                  she held no official post at the court and led the usual life of Ethiopian women of the royal blood,
                  with one important exception: she actively interefered in religious disputes which rendered the Ethiopian 
                  Church an ardent adherent of the Qǝbāt doctrine. This adherance went smoothly during the reign of her brother
                  <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</t:persName>, who himself seemed symphathetic to the doctrine, but when his son 
                  <t:roleName type="title">ʾaṣe</t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS9152TaklaHa">Takla Hāymānot I</t:persName>
                  refused to proclaim the Qǝbāt faith as a state doctrine, ʾƎleni with her nephew- in-law 
                  <t:persName ref="https://betamasaheft.eu/PRS9592Tulluu">Tulluu</t:persName> started a conspiracy in <t:date>1706</t:date>. 
                  The result was fatal for them:
                  <t:roleName type="title">daǧǧāzmāč</t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS9592Tulluu">Tulluu</t:persName> was blinded and exiled to <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName> 
                  and ʾƎleni was exiled to <t:placeName ref="https://betamasaheft.eu/LOC5897Tankal">, where she died. </t:placeName>
                     </t:floruit>
               <t:death when="1708"/> 
            </t:person>
            
         </t:listPerson>
         

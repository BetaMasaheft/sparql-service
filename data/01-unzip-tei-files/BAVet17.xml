               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="10v"/>
                     <title type="complete">Prayer for Sunday</title>
                     <note/>
                     <incipit xml:lang="gez">
                        በእንተ፡ ከመ፡ መፍትው፡ ናዕርፍ፡ ሰንበታተ፡ ወናጽም<supplied reason="omitted">እ</supplied>፡ ቃለ፡ ቅዱሳት፡ መጻሕፍት፡ ከመ፡ ንግበር፡ ፈቃዶ፡ ወንዘከር፡ ሕማማቲሁ፡ ዘገብረ፡ 
                        በእንቲኣነ፡ እግዚአብሔር፡ ቃል። እግዚኣብሔር፡ አኃዜ፡ ኵሉ፡ ዘ<supplied reason="omitted">ፈ</supplied>ጠረ፡ 
                           <sic>ዓለም፡</sic>
                         
                        በኢየሱስ፡ ክርስቶስ፡ ወመድኀኒነ፡ ወሠርዐ፡ 
                           <sic>ሰንበት፡</sic>
                         ወአዕረፈ፡ ባቲ፡ እምኵሉ፡ ግብሩ። ወለነኒ፡ አዘዘነ፡ ናዕርፍ፡ እምኵሉ፡ ግብረ፡ እደዊነ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ዕቀበነ፡ እንከ፡ ወሀበነ፡ ሲሳየነ፡ ወሚጠነ።ውስተ፡ ንስሓ። እስመ፡ ለከ፡ ይደሉ፡ ስብሐት፡ ወሰጊድ፡ በኵሉ፡ ዘገበርከ፡ ለነ፡ በወልድከ፡ ኢየሱስ፡ ክርስቶስ፡ 
                           <sic>ለዐለም፡</sic>
                         
                        ዓለም፡ አሜን። ዘንተ፡ 
                           <sic>ተለው፡</sic>
                         አኃዊነ፡ 
                           <sic>ኵሉ፡</sic>
                         ጊዜ፡ እግዜአብሔር፡ የሀልው፡ ምስሌክሙ፡ በዲበ፡ ምድር፡ 
                        ወበሰማያት፡ ... <choice>
                           <sic>ወወሀለ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ወወሀበ፡</corr>
                         </choice>
                        
                           <sic>ሒወት፡</sic>
                         
                        ለእለ፡ የአምኑ፡ በእግዚኣብሔር፡ አምላክ፡ ፈጣሪ፡ ከመ፡ 
                           <sic>ይኅየው፡</sic>
                         እለ፡ <supplied reason="omitted">የ</supplied>አምኑ፡ በክርስቶስ። 
                        <supplied reason="omitted">ሎቱ፡</supplied> 
                        
                           <sic>አኵቴት፡</sic>
                         ዘይደሉ፡ ናዕርግ፡ ለእግዚአብሔር፡ አብ፡ በኢየሲስ፡ ክርስቶስ፡ ናሁ፡ አቅደምነ፡ 
                        
                           <sic>ነጊሮትኮሙ፡</sic>
                         ወምህርናክሙ፡ ተዐቀቡ፡ ዘንተ፡ 
                           <sic>ኵሉ፡</sic>
                         ከመ፡ ትርከቡ፡ 
                           <sic>ሒወት፡</sic>
                         ዘለዐለም።
                     </explicit>
                     <msItem xml:id="ms_i1.1">
                        <locus target="#10v"/>
                        <title>Supplication to God</title>
                        <quote xml:lang="gez">
                           ጸሎት፡ ኦእግዚኦ፡ ተሣሀለኒ፡ ለኃጥ<supplied reason="omitted">እ</supplied>፡ ወለአባሲ፡ ወኮንኩ፡ ከመ፡ እንስሳ፡ 
                              <sic>ወተኆለቁ፡</sic>
                            ከማሆሙ፡ ... 
                           ተወከፈኒ፡ እግዚኦ፡ ለዘ፡ መጻእኩ፡ ኀቤከ፡ እንዘ፡ እሴፈው፡ ሣህለ፡ ወስርየተ፡ ዘእምኀቤከ፡ 
                              <sic>ላዓለመ፡</sic>
                            ዓለም፡ አሜን።
                        </quote>
                        
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="12r" to="25v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3582Prayer">Prayer to Our Lady Mary for the night</title> 
                     
                     <note/>
                     <incipit xml:lang="gez">
                        ጸሎት፡ ወስእለት፡ 
                           <sic>ወአስተበቍዖት፡</sic>
                         ኀበ፡ 
                           <sic>እግዚእትነ፡</sic>
                         ማርያም፡ ዘይትነበብ፡ 
                        በሌ<add place="inline">
                           <supplied reason="omitted">ሊት፡</supplied>
                        </add> እሴብሕ፡ ጸጋኪ፡ 
                           <sic>ኦእግዚእትየ፡</sic>
                         ወእስእለኪ፡ 
                        
                           <sic>ታበርሂ፡</sic>
                         ልብየ፡ ወታርትዒ፡ ፍኖትየ፡ ከመ፡ እሖር፡ <choice>
                           <sic>በንጽሕ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">በንጹሕ፡</corr>
                         </choice>
                        ልብ፡ በፍኖተ፡ ክርስቶስ፡ ወትእዛዛቲሁ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ሰአሊ፡ ለነ፡ ይክሥት፡ ለነ፡ ኵሎ፡ መንግሥቶ፡ አመ፡ ምጽአቱ፡ 
                           <sic>ዳግመ፡</sic>
                         ያቅመነ፡ ቅድሜሁ፡ በሰላም፡ ወበጽድቅ፡ ወያስተሳትፈነ፡ ምስሌሁ፡ እግዚእነ፡ ወአምላክነ፡ 
                        ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ እምይእዜ፡ ወእስከ፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን። 
                           <sic>ለይኵን፡</sic>
                         
                        
                           <sic>ለይኵን። = ።</sic>
                        
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="25v" to="30v"/>
                     <title type="complete">Unspecified prayer</title>
                     <note/>
                     <incipit xml:lang="gez">
                        ወንዘምር፡ ምስለ፡ ብፁዕ፡ ነቢይ፡ ወንበል። እግዚኦ፡ በመዐትከ፡ ኢትቅሥፈኒ፡ እስመ፡ ነቢይ፡ አእመረ፡ በጥበቡ፡ ወነጸራ፡ ለነፍሱ፡ ከመ፡ ዕራቁ፡ ውእቱ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ወባሕቱ፡ ተሣሀለኒ፡ ወአንሥአኒ፡ እምድቀትየ፡ ወእመሰ፡ ኢይደልወኒ፡ 
                           <sic>ምሕረተ፡</sic>
                         እስመ፡ ኵነኔከ፡ ርቱዕ፡ ውእቱ፡ እግዚኦ፡ በመዐትከ፡ ኢትቅሥፈኒ፡ ወበመቅሠፍትከ፡ ኢትገሥጸኒ።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="30v" to="33v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4261Prayer">Prayer of the Sunday</title>
                     <note/>
                     <incipit xml:lang="gez">
                        ጸሎት፡ ቡርክት፡ ዘይትነበብ፡ በዕለተ፡ እሑድ፡ ሰንበተ፡ ክርስቲያን። እግዚአብሔር፡ እግዚእየ፡ ወአምላክየ፡ እስእለከ፡ በፍቁር፡ ወልድከ፡ ኢየሱስ፡ ክርስቶስ፡ እግዚእነ፡ ወአምላክነ፡ ወመድኀኒነ፡ ወበአስማቲከ፡ 
                        ቅዱሳት፡ ትስማዕ፡ ጸሎትየ፡ ወአስተብቍዖትየ፡ ዮም፡ አርሕቅ፡ እምኔየ፡ ሰይጣን፡ ወሰራዊቶ፡ ወአድኅነኒ፡ እመስገርቱ፡ ወአሰስል፡ እምላዕሌየ፡ እከዮ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        እስእለከ፡ ታብርህ፡ አዕይንተ፡ ልብየ፡ ከመ፡ እግበር፡ ትእዛዘከ፡ ወእሑር፡ በፈቃድከ፡ እስመ፡ ኵሉ፡ 
                           <sic>ይትካሀለከ፡</sic>
                         ስረይ፡ ሊተ፡ ወለአቡየ፡ ወለእምየ፡ 
                        ወኢትኅሥ<supplied reason="omitted">ሥ</supplied>፡ እምኔየ፡ እከየ፡ ምግባርየ፡ 
                           <sic>ወበላሐኒ፡</sic>
                         
                        
                           <sic>እምእሳት፡</sic>
                         
                        ገሀነም፡ በሣህልከ፡ ወምሕረትከ፡ እስከ፡ ለዓለም፡ አሜን፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="34r" to="45r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2611Zenaab">Zenā ʾabaw</title>
                     <note/>
                     <incipit xml:lang="gez">
                        ወካዕበ፡ ይቤ፡ ቅዱስ፡ እንጦንስ። ዘይነብር፡ ውስተ፡ በድቅ፡ 
                           <sic>የዐርፋ፡</sic>
                         ለነፍሱ፡ እምሠለስቱ፡ ፀብእ። አሐዱ፡ ሰሚዕ። ወአሐዱ፡ ሐሜት፡ ወአሐዱ፡ ራእይ፡ ዘያቈስላ፡ ለነፍስ። 
                        ወካዕበ፡ ይቤ፡ እንጦንስ፡ ይደልው፡ ይኩን፡ ፈሪሀ፡ እግዚኣብሔር፡ ወትረ፡ ቅድመ፡ አዕይንቲነ፡ ወዘክሮ፡ ሞት፡ ወጸሊአ፡ ዓለም።
                     </incipit>
                     <explicit xml:lang="gez">
                        ዝኬ፡ ውእቱ፡ ዘይደልው፡ ለትሕትና፡ ወያነጽሕ፡ 
                           <sic>ልቦ።</sic>
                         ወእለ፡ በጽሑ፡ ኀበ፡ ተፍጻሜተ፡ ዝንቱ፡ ፍቅር፡ ትእምርቱ፡ ለእመ፡ ያገብእዎ፡ ለአውዕዮ፡ ዐሠርተ፡ ጊዜ፡ 
                        ኢይግባእ፡ ውስተ፡ ዓለም። በከመ፡ ይቤ፡ ሙሴ፡ ለእግዚአብሔር። እመ፡ ኢሰረይከ፡ ሎሙ፡ ለደቂቀ፡ እስራኤል፡ ደምስስ፡ ኪያየኒ፡ እመጽሐፈ፡ ሕይወት፡ ዘጸሐፍከኒ።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus from="45r" to="49v"/>
                     <title type="complete">Lament for the coming death</title>
                     <note/>
                     <incipit xml:lang="gez">
                        ወእምዝ፡ ሐለየ፡ በልቡ፡ ወይቤ፡ አሌ፡ ሊተ፡ ምንተ፡ እገብር፡ ሶበ፡ ይሔውጸኒ፡ እግዚአብሔር፡ ወይፌኑ፡ መልአኮ፡ ከመ፡ ያውፅአኒ፡ እምዝ፡ ዓለም፡ እንዘ፡ ኢተደለውኩ፡ ወኢያጥረይኩ፡ መድኀኒትየ። 
                        ምንተ፡ እገብር፡ ሶበ፡ የአውዱኒ፡ መኳንንተ፡ ጽልመት፡
                     </incipit>
                     <explicit xml:lang="gez">
                        እስመ፡ ዐቢየ፡ ይኔስሑ፡ ወየሐዝኑ፡ እለ፡ ኢዐቀቡ፡ 
                           <sic>ትእዘዘ፡</sic>
                         እግዚኣብሔር፡ ዘሎቱ፡ ክብር፡ ወስብሐት፡ ወይእ<supplied reason="omitted">ዜኒ</supplied>፡ 
                        ወዘልፈኒ፡ ወለዓ<supplied reason="omitted">ለመ</supplied>፡ ዓለም፡ አሜን።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i7">
                     <locus from="49v" to="54r"/>
                     <title type="incomplete">Prayers for the weekdays</title> 
                     
                     
                     <note/>
                    <msItem xml:id="ms_i7.1">
                       <locus from="49v"/>
                       <title type="complete">Prayer for Monday</title>
                       <incipit xml:lang="gez">
                          ጸሎት፡ በሰኑይ፡ እግዚአብሔር፡ አምላክ፡ ዐቢይ፡ ወግሩም፡ ዘአልቦ፡ ጥንተ፡ ወኢተፍ<supplied reason="omitted">ጻ</supplied>ሜተ፡
                       </incipit>
                       <explicit xml:lang="gez">
                          በከመ፡ ባረከ፡ 
                              <sic>ያዕቆብ፡</sic>
                            
                           
                              <sic>ወደቂቁ።</sic>
                           
                       </explicit>
                    </msItem>
                     <msItem xml:id="ms_i7.2">
                        <locus from="50r"/>
                        <title type="complete">Prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ በሠሉስ፡ እግዚኦ፡ አርእየኒ፡ 
                              <sic>በረካተ፡</sic>
                            ዛቲ፡ ዕለት፡ ወሠናይታ፡ ስማዕ፡ ጸሎትየ፡ 
                              <sic>ወተወካፍ፡</sic>
                            
                           ስእለትየ፡ ወስረይ፡ ሊተ፡ 
                              <sic>ኀጢኣትየ፡</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ስማዕ፡ ጸሎትየ፡ ወተወከፍ፡ 
                              <sic>ስእላትየ፡</sic>
                            
                           
                              <sic>በሣሕልካ፡</sic>
                            
                           
                              <sic>ወምሕረትካ፡</sic>
                            ኣሜን።
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i7.3">
                        <locus from="52r" to="54r"/>
                        <title type="complete">Prayer for Wednesday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ በረቡዕ። ይትባረክ፡ እግዚኣብሔር፡ እግዚእነ፡ 
                              <sic>ናኣኵቶ፡</sic>
                            በኵሉ፡ ዕለት፡ በእንተ፡ ኵሉ፡ ጸጋ፡ ዘወሀበነ፡ ኅቡአ፡ ወክሡተ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           በዳኅን፡ ወበሰላም፡ ረስየኒ፡ ኣፍቅር፡ ገቢረ፡ ሠናይ፡ ወእጽላእ፡ 
                              <sic>እኵየ፡</sic>
                            ምግባረ፡ በሣህልከ፡ ወምሕ<supplied reason="omitted">ረ</supplied>ትከ፡ 
                           እስመ፡ 
                              <sic>ኣንተ፡</sic>
                            መሐሪ፡ ወመስተሣህል፡ ወለከ፡ ይደሉ፡ ክብር፡ ወስብሐት፡ እስከ፡ 
                              <sic>ላዓላመ፡</sic>
                            
                           ዓ<supplied reason="omitted">ለ</supplied>ም፡ ኣሜን።
                        </explicit>
                     </msItem>
                  </msItem>

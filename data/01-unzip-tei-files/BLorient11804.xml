                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5696MagicPrayer">Prayer for subduing enemies and for catching devils</title>
                            <note>According to <bibl corresp="http://zotero.org/groups/358366/items/RSEA4WPK"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1978BritishLibrary"/><title level="m">Catalogue of Ethiopian Manuscripts in the British Library acquired since the Year 1877</title><author><forename>Stefan</forename><surname>Strelcyn</surname></author><pubPlace>London</pubPlace><publisher>British Museum</publisher><date>1978</date><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note><citedRange unit="page">131</citedRange></bibl> with some parts of a 'Hymn to the Cross'.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎተ፡ መግረሬ፡ ፀር፡ ወመሣግሪሆሙ፡ ለአጋንንት፡ መስቀል<sic>።</sic> 
                                መግረሬ<sic>።</sic> ፀር።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Prayer for expelling devils and demons</title>
                            <note>Including one line of <term key="MagicSymbols" ana="#MagicSymbols">magic glyphs (charaktêres)</term>.</note>
                            <incipit xml:lang="gez">በሐሺቢም፡ አሸርዋሽ፡ <gap reason="ellipsis"/> በዝ፡ አስማት፡ ይሰደድ፡ ጋኔን፡ ወሰይጣን፡ 
                                እ<supplied reason="undefined">ም</supplied>ገጸ፡ ዓመትከ፡ <gap reason="illegible"/></incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ፈጣሪ፡ ሕያው፡ ነባቢ፡ ወተናጋሪ፡ <sic>ጸሎት፡</sic> ቅዱስ፡ 
                                <persName ref="https://betamasaheft.eu/PRS9038Susenyos">ሱስንዮስ፡</persName> በእንተ፡ አሰስሎ፡ ደዌ፡ እምሕፃናት፡ እለ፡ ይጠብው፡ ጥበ፡ እሞሙ፡ እምኵሉ፡ 
                                ደዌያት፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4007Salotb">Ṣalot baʾǝnta maftǝḥe śǝrāy</title>
                            <note>Containing <term key="Asmat" ana="#Asmat">ʾasmāt</term>, which are not present in other witnesses of this text.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጽሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡ ዘተቀድሐ፡ እም፹ወ፩መጻሕፍት፡ ድንጥኤል፡ 
                                ክፍትኤል፡ ያዝሕዝዮን፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

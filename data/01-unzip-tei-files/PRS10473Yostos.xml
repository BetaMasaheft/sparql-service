         <listPerson>
            <person sameAs="wd:Q711866" sex="1">

                  <persName xml:lang="gez" xml:id="n1" type="birth">ዮስጦስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Yosṭos</persName>

                  <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
               <persName xml:lang="gez" xml:id="n2" type="regnal">ፀሐይ፡ ሰገድ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Ḍaḥay Sagad</persName>

                  <occupation type="ruler">Emperor</occupation>

                  <floruit notBefore="1711" notAfter="1716">He was a Gondarine king from <date>1711</date> to <date>1716</date>.
                     Prior to being crowned, <persName ref="https://betamasaheft.eu/PRS10473Yostos">Yosṭos</persName> acted as a kingmaker. He was devoted to hunting,
                     which he did every year of his reign. Blinding was a favoured punishment for his enemies. A revolt broke out in the court which he could not prevent.
                     A number of notables were killed, and  the son of
                     <persName ref="https://betamasaheft.eu/PRS5616IyasuI">
                     <roleName type="title">ʾaṣe</roleName> ʾIyāsu the Great</persName>, <persName ref="https://betamasaheft.eu/PRS3430DawitII">Dāwit III</persName>, was bought
                     from <placeName ref="https://betamasaheft.eu/LOC6157WahniA">Wahni ʾAmbā</placeName>.
                     <persName ref="https://betamasaheft.eu/PRS3430DawitII">Dāwit III</persName> was proclaimed king and

                     <persName ref="https://betamasaheft.eu/PRS10473Yostos">
                     <roleName type="title">ʾaṣe</roleName> Yosṭos</persName> pronounced dead.


                  </floruit>
                  <death when="1716"/>

               </person>
               
         </listPerson>




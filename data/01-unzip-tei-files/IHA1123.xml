               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="3v">2r-3v</locus>
                     <textLang xml:lang="am">Amharic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2667IHA">نظم طهاق زلّقش كماد اشراق منڠد</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>صلى الله وسلم على محمد يمار وللا صلى الله وسلم على مصطفى اهلا وسهلا


طهاق زلّقش كماد اشراق منڠد| تسا كانڠر هلا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>رحمة دهنثة يور دوسن يللو عدد بنياشن زلالا
تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3v" to="5r">3v-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2666IHA">نظم طلع البدر بل بدى الفجر</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>صلا لله على من به على حياه سفلا والعلى|
طلع البدر بل بدى الفجر| فزال الهجر وانجلا| فزال الحجب| ودنى القرب| وطاالشرب وحلا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>عرش الأستوى| كرسى النجوى| سماء نزول المولا| عرش الأستوى كرسى النجو سما ونزولا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="6r" to="9v">6r-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2668IHA">نظم الحمد لله مبرز القدم باسط النعم من كل العالم</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>الهم صلى على خمر الورود ٢ سيدى مرءاة الشهود| الحمد لله مبرز القدم| باسط النعم من كل العالم| در بحر اليقيى نعمة الأنام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>فاجعلها مقبولا منك يا الهق فجاز يهابه بالكرم والجود
تمت
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="10r" to="11v">10r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2669IHA">نظم عجبا من الاحباب خرقا واكل الحجاب دخلوا من كل
                    باب</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>صل وسلم ربى صل وسلم ربى على النبى طه مطلب|
عجبا من الاحباب خرقا واكل الحجاب  دخلوا من كل باب| ركبوا مركب الحب وجالوا فى واد الغيب </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>ما هب ريح المحبا حرك الروح والقلبا ودارت شراب الحب| وبالخير عمت ليلة ثلاثاء منه حره تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="11v" to="13v">11v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2670IHA">نظم لما قرب الشهر وأدبر السفر</title>
                     <incipit xml:lang="ar">
                        <locus target="#11v">-11v</locus>من ذ القعدة. صلى الله عليك شمس سماء مكه وسلم عليك ما يد امحاياك| لما قرب الشهر وأدبر السفر والأحباب قد حار وللتلكب محيا اكه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ما تم عبد منا وبد اذات الأسنى فى غيب عرش الرنا أوسع رحمت فتمت المكية ومسكة الشذية ومشكاة الروحيه ومسلك السلام تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

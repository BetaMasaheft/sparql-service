                        <msItem xml:id="ms_i1.1.3">
                           <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionGessawe">Four Gospels, Gǝṣṣāwe śǝrʿāt (same  as LIT1548Gessaw)</title>
                           <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.4">
                           <title type="complete" ref="https://betamasaheft.eu/LIT1558Matthew#SecondIntroduction">Wangel za-Mātewos, New introduction to the gospels, see</title>
                           <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.5">
                           <locus from="9ra" to="11rb">Fols 9ra–11rb</locus>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionCanons">Four Gospels, Canons of Eusebius  (same as LIT1224Canons)</title>
                           <textLang mainLang="gez"/>  

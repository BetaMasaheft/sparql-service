                           <textLang mainLang="gez"/> 
                           <note>The various divisions of the Gospel of Mark and the 48 sections into which the
                           Ethiopic text is divided are listed.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.4">
                           <locus from="57ra" to="80rb">Fols 57ra–80rb</locus>
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2711Mark">ወንጌል፡ ዘማርቆስ፡</title>
                           <textLang mainLang="gez"/> 
                           <note>There are many glosses, but less than in <ref target="#ms_i1.2"/>.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5">
                           <locus from="80rb" to="81ra">Fols 80rb–81ra</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke#BiographyLuke">Wangel za-Luqās, Introduction and Biography of Luke</title>

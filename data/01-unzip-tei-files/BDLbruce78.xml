                        <textLang mainLang="gez"/> 
                        <note>The text of this Gospel is filled to such an extent with glosses that it resembles more a paraphrase
                        than a translation of the Greek text.</note>
                     </msItem>
                        
                        <msItem xml:id="ms_i1.3">
                           <locus from="56ra" to="56va">Fols 56ra–56va</locus>

         <listPerson>
            <person sex="1" sameAs="wd:Q59313443">


               <persName xml:lang="gez" xml:id="n1" type="birth">ጉግሳ፡ መርሳ፡</persName>
                  <persName xml:lang="gez" corresp="#n1" type="normalized">Gugsā Marsā</persName>
               <persName>
                  <roleName type="title">rās</roleName>
               </persName>

               <occupation type="ruler">governor</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>

               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC2385DabraT">Dabǝra Tābor</placeName> which was founded by him in <date> around 1802 </date>
               </residence>


               <floruit notBefore="1800" notAfter="1825">He became one of the greatest rulers of  Warrasek (Yaǧǧu) in<date>1800</date> and he was said to be "Gugsā the Great".
                  He was a Muslim and later converted to Christianity. He acted as a kingmaker throughout his rule.
                  He had an important place in the history of land tenure system in the first quarter of the nineteenth century.
                </floruit>
               <death when="1825"/>
            </person>
            

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="2r" to="32b">2r-32b</locus>
                        <seg type="script">Hand a: very fine and careful. slender, finely shaped,
                           big letters. Hand b: fine</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Second half of the 18th century.</date>
                        <seg type="rubrication">Nomina sacra; name of the donor; incipits of the
                           texts (two initial lines in Text I, III and V; the word ʾo-za-...and the
                           following verbal form in Text I; the word salām in Texts II, III and IV;
                           part of Additio 1; elements of the punctuation signs; elements of
                           Ethiopic numerals.
 
 On the incipit page of Texts II four lines
                           are rubricated (alternating with black lines).
 On the incipit page
                           of Texts IV two lines are rubricated (alternating with black
                           lines).</seg>
                     </handNote>

                     <handNote xml:id="h2" script="Ethiopic">
                        <locus target="#2v">2v</locus>
                        <seg type="script">Hand b: fine</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Second half of the 18th century.</date>
                     </handNote>





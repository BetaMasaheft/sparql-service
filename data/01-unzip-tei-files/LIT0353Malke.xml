         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ በብስራተ፡ መልአክ፡ ግሩም፨</l>
                  <l n="2">ወለልደትከ፡ ሰላም፡ ለብርሃነ፡ ዐቢይ፡ ተቅዋም፨</l>
                  <l n="3">ኤልያስ፡ ነቢይ፡ ዘሰብእናከ፡ ፍጹም፨</l>
                  <l n="4">ጸሓፌ፡ ትእዛዙ፡ ለአምላከ፡ ኵሉ፡ ሰላም፨</l>
                  <l n="5">ዘምስለ፡ ነቢይ፡ ሄኖክ፡ ዘሰምዐ፡ ዓለም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተበፅአ፡ ትንቢተ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ እምዘተወልደ፡ ኢሞተ፨</l>
                  <l n="3">ኤልያስ፡ ነቢይ፡ ዘደናግል፡ ዐበይተ፨</l>
                  <l n="4">እንበለ፡ ሩካቤ፡ እግዚእከ፡ ለቤዛ፡ ዓለም፡ ዘሞተ፨</l>
                  <l n="5">ከርቤ፡ ብኂዐ፡ ወደዩ፡ ሐሞተ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለቆምከ፡ ዘአዳም፡ ቆሙ፨</l>
                  <l n="2">ወለመልክእከ፡ በይነ፡ ሰላም፨</l>
                  <l n="3">ቅዱስ፡ ኤልያስ፡ ሐውጸኒ፡ ለለ፡ ጌሠሙ፨</l>
                  <l n="4">አኮ፡ ዘነሣእከ፡ በእንተ፡ ኤልዛቤል፡ ቀዲሙ፨</l>
                  <l n="5">ድኅረ፡ ዝናመ፡ ሣህል፡ አውረድከ፡ ዘሣህልከ፡ ሎሙ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ናሁ፡ ፈጸምኩ፡ ለመልክእከ፡ አምኃ፡ ጽዋዔ፡ አርብዓ፨</l>
                  <l n="2">ወዳግመ፡ ክሥት፡ ለገብርከ፡ ምሥጢረ፡ ክህነት፡ ኅቡአ፨</l>
                  <l n="3">ሥርግወ፡ ምእመናን፡ ኤልያስ፡ ለነፍስየ፡ ተራድኣ፨</l>
                  <l n="4">ጊዜ፡ ሰአልኩከ፡ ሐውጸኒ፡ ነዓ፨</l>
                  <l n="5">ማሕሌተ፡ ዚአየ፡ ትረሲ፡ ምሥዋዐ፨</l>
               </lg>
            </div>
         </div>
      </body>

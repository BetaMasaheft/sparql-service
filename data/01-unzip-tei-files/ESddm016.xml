                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, but careful.</seg>
                        <seg type="ink">Black; red.</seg>The hand is similar but probably not
                        identical to that of <persName ref="https://betamasaheft.eu/PRS12076ZawaldaMaryam">Zawalda
                           Māryām</persName> (cp. UM-042).<date>Mid-18th - mid-19th century</date>
                        <seg type="rubrication">Incipit of the chapters; on the incipit page of Text
                           I (fol. 3r), three lines are rubricated alternating with black lines;
                           elements of the punctuation signs; elements of the numerals.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">- <locus target="#1v">1v</locus> (heading):
                        Crude coloured (red, black) ornamental band; interlaces.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Names of the days of the week are written in the
                              upper margin of some fols., encircled with think lines or lines of
                              dots, indicating the respective daily readings: ዘቀዳም: <locus target="#21v">fol. 21v</locus>. ዘረቡዕ: <locus target="#48r">fol.
                                 48r</locus>. ዘሐሙስ: <locus target="#61r">fol. 61r</locus>. ዘዓርብ:
                                 <locus target="#80r">fol. 80r</locus>. ዘእሁድ: <locus target="#91r">fol. 91r</locus>.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Supplication written in a secondary, crude hand: <locus target="#100v">fol.  100v</locus>.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards covered by crudely tooled
                           reddish-brown leather (for the most part missing).
 Two pairs of
                           sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible in the centre
                           fold of the quires, one close to the head and one close to the tail of
                           the codex.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament of poor quality on the
                           reddish-brown leather cover (1 tool was used: single line
                           fillet).</decoNote>
                     </binding>
                  </bindingDesc>

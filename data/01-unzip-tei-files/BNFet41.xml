      <t:body>
         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.1.1" xml:lang="gez">
               <t:ab>
          ለኢየሱስ፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.2.1" xml:lang="gez">
               <t:ab>
          ዘኮነ፡ ስምዓ፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.2.2" xml:lang="gez">
               <t:ab>
          ዘርእዮ፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.3" xml:lang="gez">
               <t:ab>
          ተነብዮቱ፡ ወዘየዓቅብ፡ ዘጽሑፍ፡ ውስቴቱ፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.4.1" xml:lang="gez">
               <t:ab>
          ሞገሱ፡ ወሰላሙ፡ ለክሙ፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.4.2" xml:lang="gez">
               <t:ab>
          ወይሄሉ፡ ወዘመጽአ፡ ወዘይመጽእ፡
        </t:ab>
            </t:div>
  
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.5" xml:lang="gez">
               <t:ab>
          ዝውእቱ፡ ስምዓ፡ መሃይምናን፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.6" xml:lang="gez">
               <t:ab>
          እግዚ"፡ በሰማያት፡
        </t:ab>
            </t:div>
      
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.7.1" xml:lang="gez">
               <t:ab>
            ዓይን። ወእልክቱኒ፡
          </t:ab>
            </t:div>
        
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.7.2" xml:lang="gez">
               <t:ab>
            ይበክዩ፡
          </t:ab>
            </t:div>
        
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.7.3" xml:lang="gez">
               <t:ab>
          ፡ እወ፡ አማን፡
          </t:ab>
            </t:div>
        
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.8.1" xml:lang="gez">
               <t:ab>
            አልፋ፡ ወኦ፡ ቀዳማዊ፡ ወደኀራዊ፡
          </t:ab>
            </t:div>
        
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Rv1.8.2" xml:lang="gez">
               <t:ab>
            ወይሄሉ፡ ዘመጽአ፡ ወዘይመጽእ፡
          </t:ab>
            </t:div>
         </t:div>
      
      </t:body>

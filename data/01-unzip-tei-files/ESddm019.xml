                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Irregular</seg>
                        <seg type="ink">Black, red</seg>
                        <date>20th century</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሰላ፡</abbr> for <expan>ሰላም፡ </expan> (e.g., <locus target="#13r">13r</locus>, 38v, 39r)</item>
                           <item>
                              <abbr>ለገ(ብ)፡</abbr> for <expan>ለገብርከ፡ </expan> (e.g., <locus target="#10v">10v</locus>, 11v, 12r)</item>
                        </list>
                        <seg type="rubrication">Divine names; name of the king; the first two lines
                           on the incipit page of the text; incipit of each section of the text; the
                           word salām; elements of Ethiopic numerals; elements of the punctuation
                           signs.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The quality of writing varies
                        throughout the Ms. The writing in the last quire is executed more
                        hastily.</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#2r">2r</locus> (incipit page): coloured (white, red, black)
                        ornamental band; geometric motifs.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#49v">f. 49v</locus>
                           <desc type="OwnershipNote">Ownership note</desc>
                           <q xml:lang="ti">
                              ዝተሐዳስትሉ 24/12/96 ዓ/ም እዚ መፅሐፍ መፍትሄ፡
                              ስራይ ናይ ቀሺ ብርሃነ ተስፍይ ገብረትንሳኤ</q>
                           
                           <note> Written in a crude secondary hand with red and blue ballpoint pen
                              on cardboard, in Tǝgrǝñña. It states that the book belongs to qašši
                              Bǝrhāna Tasfǝy Gabra Tǝnśāʾe. The date 24/12/96 A.M. (= 2003/04 A.D.)
                              is mentioned. </note>
                        </item>
                        <item xml:id="e1"><desc>Erasures: <locus target="#31v">31v</locus>, 36r.</desc> </item>
                        <item xml:id="e2"><desc>Omitted words or letters written interlineally: <locus target="#13v">13v</locus>, 21r.</desc> </item>
                        <item xml:id="e3"><desc>Lacunae (space for rubricated names left
                           unfilled): e.g., <locus target="#4r">4r</locus>, 4v, 5r, 5v, 6r</desc> </item>
                        <item xml:id="e4"><desc>Scribbles and doodles: <locus target="#49">49</locus>.</desc></item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards covered with reddish-brown tooled
                           leather. 
 One pair of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="cardboard"/>
                           <material key="leather"/>
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two pairs of chains of endband stiches at
                           the spine cover.
 Before the first and after the last quire a page of
                           cardboard has been inserted.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the leather cover (at least 4
                           tools were used: double line fillet, double circle, triple line fillet,
                           wave form with dots).</decoNote>
                     </binding>
                  </bindingDesc>

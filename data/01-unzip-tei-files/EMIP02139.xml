               <msContents>
                  <summary>Gadla Walatta Ṗeṭros</summary>
                  <msItem xml:id="ms_i1"><locus from="4r" to="71v" facs="004">Fols 4r–71v</locus><title>Biography Walatta Ṗeṭros</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="4r" to="6r" facs="004">Fols 4r–6r</locus><title>Introduction</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="6r" to="71v" facs="006">Fols 6r–71v</locus><title>Conception and Birth, and Biography, Establishment of the first community, and of a second and third, fourth, fifth community (<locus target="#48r">fols. 48r, </locus>), sixth community (<locus target="#51r">51r, </locus>), seventh community (<locus target="#66r">66r</locus>)</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
              </msItem>
                  <msItem xml:id="ms_i2"><locus from="72r" to="85v" facs="072">Fols 72r–85v</locus><title>Sixteen Miracles of Walatta Ṗeṭros</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="86r" to="102" facs="086">Fols 86r–102</locus><title>Further Miracles of Walatta Ṗeṭros and Stories about the Community of Walatta Ṗeṭros, written in a later hand</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <msItem xml:id="ms_i3.1"><locus from="86r" to="87r" facs="086">Fols 86r–87r</locus><title>Miracle in the time of King Bakāffā</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.2"><locus from="87r" to="89v" facs="087">Fols 87r–89v</locus><title>Second miracle in the time of King Iyasu</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.3"><locus from="89v" to="90v" facs="090">Fols 89v–90v</locus><title>Third miracle on the Island of Remā</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.4"><locus from="90v" to="92r" facs="091">Fols 90v–92r</locus><title>Fourth miracle at the time of king ʾIyoʾas</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.5"><locus from="92r" to="93r" facs="092">Fols 92r–93r</locus><title>Fifth miracle about a man called ʾAsāhel</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.6"><locus from="93r" to="94v" facs="093">Fols 93r–94v</locus><title>Sixth miracle about daǧǧāzmāčč Mikāʾel of Tǝgray</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.7"><locus from="94v" to="95v" facs="095">Fols 94v–95v</locus><title>Seventh miracle about a fisherman</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.8"><locus from="95v" to="96v" facs="096">Fols 95v–96v</locus><title>Eighth miracle about a crippled man</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.9"><locus from="96v" to="98r" facs="097">Fols 96v–98r</locus><title>Ninth miracle about a wealthy man</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.10"><locus from="98r" to="99r" facs="098">Fols 98r–99r</locus><title>Tenth miracle about a sick man</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.11"><locus from="99r" to="101v" facs="099">Fols 99r–101v</locus><title>Eleventh miracle in the time of king Yoḥannǝs</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3.12"><locus from="101v" to="102v" facs="102">Fols 101v–102v</locus><title>The chronology of Walatta Ṗeṭros and the subsequent community.  The account is written in the time of the fifth year of the reign of king ʾIyāsu, son of king Bakāffā</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
              </msItem>
                  <msItem xml:id="ms_i4"><locus from="103r" facs="103">Fols 103r and following</locus><title>Gadla Takla Hāymānot</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
               </msContents>

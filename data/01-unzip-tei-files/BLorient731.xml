                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i0">
                          <locus from="1r"/>
                          <title type="incomplete" xml:lang="en">Discourses</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i0.1">
                            <locus from="1r"/>
                            <title type="incomplete" xml:lang="en">Discussion on the woman who
                            anointed the Lord's feet.</title>
                            <textLang mainLang="gez"/>
                            <note>The text is imperfect at the beginning.</note>
                          </msItem>
                          <msItem xml:id="ms_i0.2">
                            <locus from="2r"/>
                            <title type="complete" xml:lang="en">Discussion on the time of the
                            Crucifixion</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                        </msItem>
                        <msItem xml:id="ms_i1">
                          <locus from="4r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2456Tergwa">Tǝrgʷāme wangel</title>
                          <textLang mainLang="gez"/>

                          <msItem xml:id="ms_i1.1">
                            <locus from="4r"/>
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2456Tergwa#Matthew">
                            መጽሐፈ፡ ትርጓሜ፡ ብስራተ፡ ማቴዎስ፡ ሐዋርያዊ።</title>
                            <textLang mainLang="gez"/>

                            <msItem xml:id="ms_i1.1.1">
                              <locus from="4r"/>
                              <title type="complete" xml:lang="en">Introduction, chiefly derived from Ephraim Syrus</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">እምቃለ፡ ቅዱስ፡ ማሪ፡ ኤፍሬም፡ ወጠነ፡ ዘንተ፡ መቅድመ፡ ኅሩየ፡ ወሥሙረ፡
                              በሰላመ፡ እግዚአብሔር፡ አሜን።</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.1.2">
                              <locus from="11r"/>
                              <title type="complete" xml:lang="en">Discussion on the woman who
                              anointed Lord's feet</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.3">
                              <locus from="12r"/>
                              <title type="complete" xml:lang="en">Commentary</title>
                              <textLang mainLang="gez"/>
                              <note>The commentary is principally taken from the writings of
                                <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName> and
                                <persName ref="https://betamasaheft.eu/PRS3255CyrilI">Cyril of Alexandria</persName></note>
                            </msItem>
                          </msItem>
                          <msItem xml:id="ms_i1.2">
                            <locus from="209r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT2456Tergwa#Mark">Tǝrgʷāme wangel: Commentary on Mark (same as LIT3191Tergwam)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወሠናይ፡ ስንአሁ፡ በጽሒፈ፡ ቃላተ፡ ብስራተ፡
                            ማርቆስ፡ ወንጌላዊ፡ እንተ፡ ነበበ፡ ባቲ፡ ቅዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ሊቀ፡ ጳጳሳት።</incipit>
                          </msItem>
                          <msItem xml:id="ms_i1.3">
                            <locus from="223r"/>
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2456Tergwa#Luke">ብስራተ፡ ሉቃስ፡ ሐዋርያ፡ ላእክ።</title>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i1.3.1">
                              <locus from="260r"/>
                              <title type="complete" xml:lang="en">List of patristic authorities, Coptic,
                              Jacobite Syriac, Armenian, Greek, and Nestorian Syriac</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                          </msItem>
                          <msItem xml:id="ms_i1.4">
                            <locus from="261r"/>
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2456Tergwa#John">ብስራተ፡ ዮሐንስ፡ ሐዋርያዊ፡
                            ፈጻሜ፡ ብስራተ፡ ክቡር፡ ነባቤ፡ መለኮት።</title>
                            <textLang mainLang="gez"/>
                            <note>Besides <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName>,
                            there are often cited
                              <persName ref="https://betamasaheft.eu/PRS3827Ephrem">Mār Ephraim</persName> and
                            <persName ref="https://betamasaheft.eu/PRS1566Ahobof">Aḥob of Qatar<foreign xml:lang="gez">አጎብ፡</foreign></persName>.</note>
                          </msItem>
                        </msItem>

                    </msContents>


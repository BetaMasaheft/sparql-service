      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መድኃኒነ፡ እግዚእ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Madḫānina ʾƎgziʾ</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                
                  <t:residence/>
               <t:floruit> He was a medieval holy saint, a disciple of  
                  <t:persName ref="https://betamasaheft.eu/PRS9162TaklaHa">
                     <t:roleName type="title">ʾabbā</t:roleName>Takla Hāymānot</t:persName>, who lived during the reigns 
                  of <t:persName ref="https://betamasaheft.eu/PRS10111WedemR">Wǝdǝm Raʿad</t:persName>, <t:persName ref="https://betamasaheft.eu/PRS1854Amdase">ʿAmda Ṣǝyon I</t:persName> and
                  <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName>. He is credited with the foundation of the monastery of  
                  <t:placeName ref="https://betamasaheft.eu/LOC2242DabraB">Dabra Bankʷal</t:placeName>, near <t:placeName ref="https://betamasaheft.eu/LOC1310Aksum">ʾAksum</t:placeName> during the reign of King 
                  <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName>. It is also reported that King <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName> visited him and
                  richly endowned the monastery <t:placeName ref="https://betamasaheft.eu/LOC2242DabraB">Dabra Bankʷal</t:placeName> with lands in <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgray</t:placeName>
               </t:floruit>
                  <t:death when="1372"/>
               </t:person>  
               
               
         </t:listPerson>

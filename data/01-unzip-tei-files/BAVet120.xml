                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="42v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2314senafe">Śǝna fǝṭrat (General record)</title>
                            <textLang mainLang="am"/>
                            <incipit>
                                <locus target="#3"/>
                                በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ ስነ፡ ፍጥረት፡ እግዚአብሔር፡ እምቅድመ ዓለም፨
                                ዓለም፡ ሳይፈጠር፡ ዘመን፡ ሳይቈጠር፡ ባ፩ነት፡ በ፫ነት፡ በ፫ነት፡ ባ፩ነት፡ ሲሰለስ፡ ሲቀደስ፡ ይኖር፡ ነበር፡ ፩ነቱ፡ ፫ነቱን፡ ሳይጠቀልለው፡ ፫ነቱ፡ ፩ነቱን፡ ሳይከፍለው፡ ባ፩ነቱ፡ በ፫ነት፡ በ፫ነት፡ ባ፩ነት፡
                                ሲሰለስ፡ ሲቀደስ፡ ይኖር፡ ነበር፨
                            </incipit>
                            <explicit>የዓርብ፡ ስነ፡ ፍጥረት፡ እስከዚህ፡ ድረስ፡ ነው፨፨ ይህነንም ሁሉ ይማሩት፡ ያስተምሩት፡ ብሎ፡
                                ሰጥ<add place="above">ቶ</add>ናል፤
                                አባት፡ ተምሮ፡ ለልጁ፡ እናት፡ ተምራ፡ ለልጇ፡ ንጉሥ፡ ተምሮ፡ ለ<add place="above">ሎ</add>ሌው፡
                                <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                ኦገብር፡ ሐካይ፡ ብለህ፡ ጥቀስ፨ ከዚህም፡ ቀጽሎ፡ ምስጢረ፡ ሥጋዌን፡ ይማሩ፡ ዘንድ፡ ይገባል፨
                            </explicit>
                            
                            <colophon xml:lang="am" xml:id="coloph1">
                                <locus target="#42v"/>
                                ዝ፡ መጽሐፍ፡ ዘ<placeName ref="https://betamasaheft.eu/LOC1713Bagemd">በጌምድር፡</placeName>
                                <placeName ref="https://betamasaheft.eu/INS1013FAG">ፋርጣ፡ ዓዲኮ፡ ገብርኤል፡</placeName>
                                ዘወሀቦ፡ <persName role="donor" ref="https://betamasaheft.eu/PRS12978GabraSelassie">ገብረ፡ ሥላሴ፡</persName> እኁሁ፡
                                ለ<persName ref="https://betamasaheft.eu/PRS12980WaldaGiyrgis">ወልደ፡ ጊዮርጊስ፡ ዘውእቱ፡ ወርቄ፡ መርሻ</persName>፡ ሳምን፡ ትውልድ፡ እምነ፡ አቅኚው፡ <persName ref="https://betamasaheft.eu/PRS12991BegaKrestos">በጎ፡
                                    ክርስቶስ</persName>፨ <persName ref="https://betamasaheft.eu/PRS12993ShumeKrestos">ሹመ፡ ክርስቶስ</persName>።
                                <persName ref="https://betamasaheft.eu/PRS12992WalattaKrestos">ወለተ ማርያም</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS12995GetaWeldye">ጌታ፡ ወልድየ</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS12996AdadaMaryam">ዓፀደ፡ ማርያም</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS12997Altasab">አልታሰብ</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS12998Werqe">ወርቄ</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS12999GebSelMer">ገብረ፡ ሥላሴን፡ መርሻን</persName>።።።
                                ያቡቲ፡ አቅኚው፨ <persName ref="https://betamasaheft.eu/PRS13000DemeKrestos">ደመ፡ ክርስቶስ</persName>፨
                                ዘሜ። <persName ref="https://betamasaheft.eu/PRS13007WalattaNabiyat">ወለተ፡
                                    ነቢያት</persName>። <persName ref="https://betamasaheft.eu/PRS13008Akal">አካል</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS13009Gezot">ግዛት</persName>፨
                                <persName ref="https://betamasaheft.eu/PRS13005WalattaSeyon"> ወለተ፡ ጽዮን</persName>፨ <persName ref="https://betamasaheft.eu/PRS13010Warqe">ወርቄን፡</persName>
                                ስመ፡ ጥምቀቱ፡ ወልደ፡ ሚካኤል፤ እረፍቱኒ፡
                                እመ፡ <surplus>ተ</surplus> ፱ለሚያዝያ፡ ወብእሲቱ፡ <persName ref="https://betamasaheft.eu/PRS13011WalattaGabriel">ወለተ፡ ገብርኤል፡</persName>
                                እቴ፡ ናት፡ ዕረፍታ፡ አመ፡ ፳ወ፱ለነሐሴ፨
                                ወመቃብረ፡ ክልዔሆሙ፡ <placeName ref="https://betamasaheft.eu/LOC7343SirabaSeyon">ሲራባ፡ ጽዮን</placeName>፨ ዝኒ፡ ለተዝካረ፡ ስሞሙ፡ ተጽሐፈ፨
                                <date calendar="grace" when="1915" when-custom="1923" evidence="internal">
                                    በ፲ወ፱፻፲ወ፭ዓመተ፡ ምሕረት፨</date>
                                <note>
                                    The colophon states that the manuscript was written in the year of mercy <date calendar="ethiopian">1915 EC</date>, i.e. 
                                    <date>1922/23 AD</date>. The colophon also mentions several place names and individuals, among whom
                                    <persName role="donor" ref="https://betamasaheft.eu/PRS12978GabraSelassie">Gabra Śǝllāse</persName>, who donated the book to 
                                    <placeName ref="https://betamasaheft.eu/INS1013FAG">Fārṭā ʿAddiko Gabrǝʾel</placeName> in <placeName ref="https://betamasaheft.eu/LOC1713Bagemd">Bagemdǝr</placeName>.
                                </note>
                            </colophon>
                        </msItem>

                        <msItem xml:id="ms_i2">
                            <locus from="43" to="89v"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1097Ammest">ኃምስቱ፡ አዕማደ፡ ምስጢር፡</title>
                            <textLang mainLang="am" otherLangs="gez"/>
                            <incipit>
                                በስመ አብ<gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                መቅድመ፡ ኵሉ፡ ንትመሐር፡ ሃይማኖተ፡ እንዳለ፡ ከተግባረ፡ ሥጋ፡ ከተግባረ፡ ነፍስ፡
                                አስቀድሞ፡ ሃይማኖትን፡ ይማሩ፡ ዘንድ፡ ይገባል፡
                                <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>
                                ሃይማኖትሰ፡ ማለት፡ ምን፡ ነው፡ ቢሉ፡ ኃምስቱ፡ አዕማደ፡
                                ምሥጢር፡ ናቸው፡ ኃምስቱ፡ አዕማደ፡ ምስጢርስ፡ ምንና፡ ምን፡ ናቸው፡ ቢሉ፡ ምስጢረ፡ ሥላሴ፡ ምሥጢረ፡ ሥጋዌ፡
                                ምሥጢረ፡ ጥምቀት፡ ምሥጢረ፡ ቍርባን፡ ምሥጢረ፡ ትንሣኤ፡ ሙታን፡ ናቸው፨
                            </incipit>
                            <explicit>
                                ወበከየ፡ ጴጥሮስ፡ አንብዓ፡ መሪረ፡ እንዳለ፡ ንስሐሰ፡ <sic>ትሬስዮ፡</sic> ለሰብእ፡ ለዘአበሰ፡
                                ከመ፡ ዘኢአበሰ፡ ለኃጥእኒ፡ ከመ፡ ጻድቅ፡ ወለዘማኒ፡ ከመ፡ ድንግል፡ እንዳለ። አስጀምሮ፡ ለአስጨረሰን፡ እግዚአብሔር፡ ክብር፡
                                ይገባው፡ ይቆየን፡ አሜን።
                            </explicit>
                        </msItem>
                    </msContents>
                    

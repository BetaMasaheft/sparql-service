                  </objectDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#1r" facs="003">fol. 1r</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black);
                      <locus target="#19r #62v" facs="021 065">19r, 62v, </locus> (dotted line using alternating black and red);
                      <locus target="#41r" facs="043">41r</locus> (row of full-stop symbols)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <desc>
                              <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus> Note that the promised vow is one curtain</desc>
                        </item>
                        <item xml:id="a2">
                           <desc>
                              <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus> Note on the vow to kill a cow for <foreign xml:lang="gez">ሓራ፡ መድኃኔ፡ አለም፡</foreign> church if the person who vowed and his/her daughter are healed from the cough</desc>
                        </item>
                        <item xml:id="a3">
                           <desc>
                              <locus target="#19r #19v" facs="021 022">Fols. 19r, 19v</locus> Personal prayer (of <foreign xml:lang="gez">አስካለ፡ ጽዮን፡</foreign>) to the Lord for salvation</desc>
                        </item>
                        <item xml:id="a4">
                           <desc>
                              <locus target="#72r" facs="074">Fol. 72r</locus>Record of an unidentified incident that happened to the writer of the note on <date calendar="ethiopian" when="1935" when-custom="1943">የካቲት፡ ፳፭፡ ፲፱፻፴፭፡ (March 4, 1943 AD)</date>
                           </desc>
                        </item>
                        <item xml:id="a5">
                           <desc>
                              <locus from="63r" to="71v" facs="065">Fols 63r–71v</locus> purple ink used instead of red</desc>
                        </item>
                        <item xml:id="a6">
                           <desc>Prayer for <foreign xml:lang="gez">አስካለ፡ ጽዮን፡</foreign>, <locus target="#71r" facs="073">fol. 71r</locus>
                           </desc>
                        </item>
                        <item xml:id="a7">
                           <desc>Overlooked lines of text are written interlinearly (<locus target="#56v" facs="059">fol. 56v</locus>)</desc>
                        </item>

                        <item xml:id="e1">
                           <desc>
                              <locus target="#ir(ecto) #iir(ecto) #20r #20v #71v #72v" facs="001 002 022 023 074 075">Fols. ir(ecto), iir(ecto), 20r, 20v, 71v, 72v</locus> blank</desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding>
                        <decoNote xml:id="b1">Parchment, three Coptic chain stitches attached with bridle attachments to rough-hewn boards.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <provenance>
                    This codex was donated to Trinity Western University by Robert N. Thompson, who spent some years immediately following World War II in Ethiopia working with the Ministry of Education.
                    Later, he served with the mission organization, SIM (then “Sudan Interior Mission,” now “Serving In Ministry”)
                  </provenance>
               </history>

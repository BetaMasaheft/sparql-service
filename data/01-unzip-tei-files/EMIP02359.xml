                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word God is not rubricated in the first three works. The word Mary is not rubricated in the two extant folios of the final two works</desc>
                  <desc>Columetric layout of text: <locus target="#113v" facs="116">fols. 113v, </locus> (Psalm 150); <locus target="#123v #124r" facs="126">123v, 124r</locus> (Tenth Biblical Canticle)</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc>An <ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref> spears a figure</desc></decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#5r" facs="007">Fol. 5r</locus><desc>crude drawing of a face</desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#8r" facs="010">Fol. 8r</locus><desc>crude drawing of the <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName></desc></decoNote>
                  <decoNote type="miniature" xml:id="d5"><locus target="#57r" facs="059">Fol. 57r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s holding <term key="sword" ana="#sword"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d6"><locus target="#57v" facs="060">Fol. 57v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1015Flagellation">Flagellation of Jesus</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d7"><locus target="#58r" facs="060">Fol. 58r</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d8"><locus target="#58v" facs="061">Fol. 58v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                  <decoNote type="miniature" xml:id="d9"><locus target="#81r" facs="083">Fol. 81r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> surrounded by six <term key="angel" ana="#angel"/>s</desc></decoNote>
                  <decoNote type="miniature" xml:id="d10"><locus target="#81v" facs="084">Fol. 81v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/> with lions and leopards</desc></decoNote>
                  <decoNote type="miniature" xml:id="d11"><locus target="#82r" facs="084">Fol. 82r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and <persName ref="https://betamasaheft.eu/PRS5695John">John</persName> stand beside the <term key="cross" ana="#cross"/></desc></decoNote>
                  <decoNote type="miniature" xml:id="d12"><locus target="#82v" facs="085">Fol. 82v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                  <decoNote type="frame" xml:id="d13">
                  Decorative designs:
                  <locus target="#6v #21v #63v #71r #76r #88r #99v #101v #107v #127v" facs="009 024 066 073 078 090 102 104 110 130">folss. 6v, 21v, 63v, 71r, 76r, 88r, 99v, 101v, 107v, 127v, </locus> (line of alternating red and black dots);
                  <locus target="#31r #39r #45r" facs="033 041 047">31r, 39r, 45r, </locus> (line of black dots);
                  <locus target="#114r" facs="116">114r, </locus> (multiple full stops and a line of alternating red and black dots);
                  <locus target="#132r" facs="134">132r</locus> (multiple full stops)
                  </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc type="GuestText">
                    <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                    Excerpt of <title type="incomplete" ref="https://betamasaheft.eu/LIT2932RepCh213">Malkǝʾa
                                                  fǝlsatā</title> Written in a different hand. First line is largely illegible.
                    Incipit: <foreign xml:lang="gez"><supplied reason="omitted">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡</supplied> ምስለ፡ ነፍ<supplied reason="omitted">ስኪ፡ ኢ</supplied>መዋቲ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="GuestText">
                    <locus target="#132r #132v" facs="134 135">Fols. 132r, 132v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer
                                                  za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>. Written in a different hand
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Many folios are missing between <locus target="#130v #131r" facs="133">fols. 130v, 131r</locus>
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    scrawls and pen trials
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#59r" facs="061">Fol. 59r</locus>
                    The midpoint of the Psalms is not marked
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#76" facs="078">Fol. 76</locus>
                    red thread stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                      words of text are written interlinearly (<locus target="#3v #4v #5r #27v #28v" facs="006 007 030 031">folss. 3v, 4v, 5r, 27v, 28v, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#47r #100r #115v #119v #123v" facs="049 102 118 122 126">47r, 100r, 115v, 119v, 123v, </locus>, etc.);
                      text has been removed (<locus target="#2v #11r #19v #22v #24r" facs="005 013 022 025 026">2v, 11r, 19v, 22v, 24r</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, four silver medallions have been embedded into the front cover, front cover has broken and been repaired.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="metal"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

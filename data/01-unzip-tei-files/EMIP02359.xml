               <msContents>
                  <summary>Psalter</summary>
                <msItem xml:id="ms_i1">
                  <locus from="1r" to="132r" facs="003">Fols 1r–132r</locus>
                  <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Praises of Mary, is missing</note>
                </msItem>

                <msItem xml:id="ms_i1.1">
                  <locus from="1r" to="114r" facs="003">Fols 1r–114r</locus>
                  <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                  <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118</span></ref> does not contain the spiritual meanings of the Hebrew letters</note>
                  <note>Incomplete at the beginning, starting at the end of Psalm 2.
                    Many folios are missing between <locus target="#130v #131r" facs="133">fols. 130v, 131r</locus></note>
                </msItem>

                <msItem xml:id="ms_i1.2">
                  <locus from="114r" to="127v" facs="116">Fols 114r–127v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                </msItem>

                <msItem xml:id="ms_i1.3">
                  <locus from="127v" to="130v" facs="130">Fols 127v–130v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                </msItem>

                <msItem xml:id="ms_i1.4">
                  <locus from="131r" to="132r" facs="133">Fols 131r–132r</locus>
                  <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <note>Incomplete at the beginning</note>
                </msItem>
                </msContents>

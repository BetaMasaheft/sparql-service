               </msIdentifier>
               <msContents>
                  <summary>Psalter with cloth cover (including strap for fore edge) and double-slip Mahdar</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="139v" facs="001">Fols 1r–139v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="3r" to="114v" facs="003">Fols 3r–114v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Each section of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118</span></ref> contains the transliterated Hebrew letter in red ink, but no <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has all four of the additions for the long version</note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="114v" to="126v" facs="115">Fols 114v–126v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>The superscription to the fourth biblical canticle, <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref>, is <q>“Prayer of Hana, mother of Samuel, prophetess.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="126v" to="133r" facs="127">Fols 126v–133r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Common edition</note>
                      <msItem xml:id="ms_i1.3.1">
                        <locus from="133r" facs="133">Fols 133r and following</locus>
                        <title>Scribal doxology at the end of <ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref></title>
                        <incipit xml:lang="gez">
                          ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</incipit>
                      </msItem>
                  </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="133v" to="139r" facs="134">Fols 133v–139r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Arranged for the days of the week, laid out beginning on Monday and culminating on Sunday</note>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="139v" to="141v" facs="140">Fols 139v–141v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">140</measure>
                           <dimensions type="outer" unit="mm">
                              <height>175</height>
                              <width>125</width>
                              <depth>55</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="23 39">
                         <locus from="3r" to="133r" facs="003">Fols 3r–133r</locus>
                       </layout>
                       <layout columns="2" writtenLines="23 39">
                         <locus from="133v" to="142r" facs="134">Fols 133v–142r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word for God is unrubricated</desc>
                  <desc><ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa#ThreeYouths3"><span xmlns="" class="w3-tag w3-red">No item: LIT1566hababa#ThreeYouths3</span></ref> employs columetric rubrication</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                      <locus target="#142r" facs="142">Fol. 142r</locus>
                      <desc>List of the feast days of the Apostles</desc>
                    </item>
                    <item xml:id="e1">
                      <locus target="#1r #1v #2r" facs="001 002">Fols. 1r, 1v, 2r</locus>
                      <desc>Missed shots: The two folios of the protection sheet were not digitized</desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#3r" facs="003">Fol. 3r</locus>
                      <desc type="OwnershipNote">
                        Opening prayer is the five-line, rhyming poem from <ref type="work" corresp="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</ref>. <locus target="#112v" facs="113">Fol. 112v</locus>:
                        Name of secondary owner, <foreign xml:lang="gez">ወልደ፡ [.]ዮሐንስ፡</foreign>, written by another hand, in another shade of red ink
                      </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#60r" facs="060">Fol. 60r</locus>
                    <desc>
                    The midpoint of the Psalms is unmarked
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment. Simple wooden boards, covered with linen two-pouch with fore-edge strap.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1999">Twentieth century</origDate>
                  </origin>
               </history>

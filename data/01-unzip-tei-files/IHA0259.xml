                           <note/>
                        </item>
                        <item xml:id="a1_555">
                           <locus target="#7v-99v-115v-131r-145r-160v-175r-206v">-7v, 99v, 115v, 131r, 145r, 160v, 175r, 206v</locus>
                           <q xml:lang="ar">Ǧuz’ markers: double circle in red</q>
                           <desc>Drawings / Decorations</desc>

                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="238v">1v-238v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة الكهف مكية هي مائة وخمس ايات \ بسم الله الرمنم الرحيم المحمد لله الذي انزل على عبده الكتب ولم تجعل له عوجا قيما </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#238v">-238v</locus>الذي يوسوس في صدور الناس من الجنة والناس</explicit>
                     <note>Contains sūras 18-114. Some lines end with incomplete words but the complete word is given in the beginning of the next line. Vocalized.</note>
                     <note/>
                  </msItem>
               </msContents>

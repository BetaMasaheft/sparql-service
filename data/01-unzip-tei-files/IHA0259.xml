                        </item>
                        <item xml:id="a2_555">
                           <locus target="#37v-53v-69r-84r">-37v, 53v, 69r, 84r</locus>
                           <q xml:lang="ar">Ǧuz’ markers: al-ǧuz’ beside a double circle</q>

               <t:persName xml:lang="gez" xml:id="n1" type="birth">አካለ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAkāla Krǝstos</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">አካለ፡ ክሶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAkāla Kǝsos</t:persName>
            
               
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               
               <t:floruit notBefore="1680" notAfter="1707">He was a father of the Qǝbāt school of theology. 
                  <t:persName ref="https://betamasaheft.eu/PRS1581AkalaKr">ʾAkāla Krǝstos</t:persName> represented 
                  Qǝbāt at the council of  <t:placeName ref="https://betamasaheft.eu/LOC1542Aringo">ʾAringo</t:placeName>, 
                  convened by <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                      ʾIyāsu I</t:persName> in <t:date>1682</t:date> 
                  to reconcile the doctrinal differences with Tawāḥǝdo. 
               </t:floruit>
               <t:death when="1707"/>
               
               
            </t:person>  
            

         <listPerson>
            <person sex="1">
               <persName>
                  
                  <forename>Casimir</forename>
                  <forename>François Marie</forename>
                  <surname>Mondon-Vidailhet</surname> 
               </persName>
               
               <occupation type="academic">scholar</occupation>
               <nationality type="France"/>
               <faith type="notSpecified"/>
               <birth when="1847"/>
               <floruit notBefore="1864" notAfter="1910">He was a French journalist and scholar
                  actively engaged in Ethio-European affairs 
                  who contributed with pioneer works to the knowledge of Ethiopia and its language. 
                  He was in Ethiopia from <date>1892</date> to <date>1897</date>. 
                  During his stay in Ethiopia, he advised <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</persName> 
                  on various matters and wrote for him projects of reform. He also engaged in collecting of 
                  valuable Ethiopic manuscripts. </floruit>
               <death when="1910">He died at <placeName ref="https://www.wikidata.org/entity/Q90">Paris</placeName>
               </death>
            </person>
            
         </listPerson>
         
         

                        <msItem xml:id="ms_i1">
                            <locus from="1ra" to="107va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6935TarWaAmidAlpha">Tārika Walda ʾAmid (α-recension)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ <gap reason="ellipsis"/> ንዌጥን፡ በረድኤተ፡ እግዚአ</hi>ብሔር፡ መጽሐፈ፡
                                ታሪክ፡<gap reason="ellipsis"/><hi rend="rubric">ዘአስተ</hi>ጋብአ፡ ኅሩይ፡ ወትሩፍ፡ ክርስቶሳዊ፡ <hi rend="rubric">ጊዮርጊስ፡</hi> 
                                ወልደ፡ አሚድ፡ ዘብሔረ፡ ግብጽ።</incipit>
                            <explicit xml:lang="gez"><hi rend="rubric">ተፈጸመ፡ ዝንቱ፡ መጽሐፈ፡ ታሪክ፡ ዘአስተጋብአ፡ ብእሲ፡</hi> ክቡር፡ ወትሩፍ፡ ክርስቲያናዊ፡ 
                                <sic>አ</sic>ርቶዶክሳዊ፡ <hi rend="rubric">ጊዮርጊስ፡</hi>ግብጻዊ፡<gap reason="ellipsis"/>ወአመ፡ ፯ ለወርኃ፡ ስዋል። ወበ ፯፻፺ወ፫
                                እምአመታተ፡ ተንበላት።<gap reason="ellipsis"/>ሣህሉ፡ የሀሉ፡ ምስለ፡ ገብሩ፡ 
                                <persName role="donor" cert="medium" ref="https://betamasaheft.eu/PRS14690KeflaKrestos">ክፍለ፡ ክርስቶስ፡</persName> ወምስለ፡ ንጉሥነ፡ 
                                <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName> ወምስለ፡ 
                                ጸ<choice><sic>ሐ</sic><corr>ሓ</corr></choice>ፊሁ፡ ምኑን፡ በኀበ፡ ሰብእ፡ ወትሑት፡ በውስተ፡ ሕዝብ፡ ዘተሰምየ፡ በጸጋ፡ እግዚአብሔር፡ 
                                <persName role="scribe" ref="https://betamasaheft.eu/PRS14691ZawaldaMar">ዘወልደ፡ ማርያም።</persName> ለዓለመ፡ ዓለም፡ አሜን፤ ወአሜን፤</explicit>
                        </msItem>

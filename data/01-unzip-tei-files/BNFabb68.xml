                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus from="107vb" to="108ra"/>
                                    <desc type="Inventory">Inventory of books of the monastery of <placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">Ṭānā Qirqos</placeName>
                                        during the time of <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>.</desc>
                                    <q xml:lang="gez"><sic>ኈ</sic>ልቈ፡ መጻሕፍት፡ ዘ<placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">ፃና፡</placeName> ዘተጽሕፈ፡ 
                                        በመዋዕለ፡ ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName>
                                        እንዘ፡ መምህርነ፡ <persName ref="https://betamasaheft.eu/PRS14692WaldaIyasus">ወልደ፡ ኢያሱስ፡</persName> 
                                        ወቄሰ፡ ገበዝ፡ <persName ref="https://betamasaheft.eu/PRS14693Agnatyos">አግናጥዮስ፡</persName> <gap reason="ellipsis"/></q>
                                </item>
                                <item xml:id="a2">
                                    <locus from="108ra" to="108rb"/>
                                    <desc type="Inventory">Inventory of church utensils in Amharic.</desc>
                                    <q xml:lang="am">ኍልቈ፡ ግምጃ፡ ፲፪ካፓ፡ <add place="overstrike">፫</add> ኩፋር፡ ግምጃ፡<gap reason="ellipsis"/>
                                        ፬ከበሮ፡ ፩አንካሴ፡</q>
                                </item>
                                <item xml:id="a3">
                                    <locus target="#108rc"/>
                                    <desc type="Inventory">Unclear note in Amharic, probably an addition to the aforementioned inventory (<ref target="#a2"/>),
                                        mentioning the name of the mamhǝr of that time in the monastery of <placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">Ṭānā Qirqos</placeName>.</desc>
                                    <q xml:lang="am"><add place="overstrike">፱፡</add> ብስጥ፡ መምህር፡ 
                                        <persName ref="https://betamasaheft.eu/PRS14692WaldaIyasus">ወልደ፡ ኢያሱስ፡</persName> የሰጡት፡</q>
                                </item>
                                <item xml:id="a4">
                                    <locus from="108rb" to="108va"/>
                                    <desc type="Inventory">Inventory of books of the monastery of <placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">Ṭānā Qirqos</placeName>
                                        during the time of <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas I</persName>. Written partly in Amharic.</desc>
                                    <q xml:lang="gez"><sic>ኈ</sic>ልቈ፡ መጻሕፍት፡ ዘፃና፡ ዘተጽሕፈ፡ 
                                        በመዋዕለ፡ ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ኢዮአስ፡</persName>
                                        እንዘ፡ መምህርነ፡ <persName ref="https://betamasaheft.eu/PRS14694ZafaraSel">ዘፈረ፡ ሥላሴ፡</persName> 
                                        ወቄሰ፡ ገበዝ፡ <persName ref="https://betamasaheft.eu/PRS14695Aymathono">አይሞትሆኖ፡</persName> 
                                        ወዓቃቤ፡ ቤተ፡ መዛግብት፡ <persName ref="https://betamasaheft.eu/PRS14696MehratWald">ምሕረተ፡ ወልድ፡</persName><gap reason="ellipsis"/>
                                        ፩ገድለ፡ ተክለ፡ ሃይማኖት፡ ነው።</q>
                                </item>
                                <item xml:id="a5">
                                    <locus target="#108va"/>
                                    <desc type="Inventory">Inventory of church utensils in Amharic mentioning the mamhǝr of that time.</desc>
                                    <q xml:lang="am">፰ብስጥ፡ ፰ብሣጥ፡ <gap reason="ellipsis"/> ፩ብስጥ፡ መምህር፡ 
                                        <persName ref="https://betamasaheft.eu/PRS14697Zaffaru">ዘፈሩ፡</persName> የሰጡት፡</q>
                                </item>
                                <item xml:id="a6">
                                    <locus target="#108vb"/>
                                    <desc type="Inventory">Inventory of church. Probably written by two hands.</desc>
                                    <q xml:lang="am">ኍልቈ፡ ግምጃ፡ ፲፪ካፓ፡ ፫ቱ፡ ኩፋር፡ ነው፡ <gap reason="ellipsis"/> ፬ ፓናት፡ ፫ ምንዛህ፡</q>
                                </item>
                                <item xml:id="a7">
                                    <locus target="#108vc"/>
                                    <desc type="MixedNote">Note on the date of the decoration of the church of the monastery of
                                        <placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">Ṭānā Qirqos</placeName> in the year 1768/1769.</desc>
                                    <q xml:lang="gez">ተወጥነ፡ መሠረተ፡ ሕንፃሃ፡ ለመቅደሰ፡ ቂርቆስ፡ ዘፃና፡ 
                                        በ <date when-custom="5500" calendar="creation" notBefore="0007" notAfter="0008"><sic>፶፻ወ፭፻ ዓመተ፡ ዓለም፡</sic></date>
                                        በ <date when-custom="1761" calendar="ethiopian" notBefore="1768" notAfter="1769">፲፻ወ፯፻ በ፷ወ፩ ዓመተ፡ ምሕረት፡</date> 
                                        በዘመነ፡ ማቴዎስ፡ አመ፡ ፲ወአሚሩ፡ ለወርኅ፡ ጥቅምት፡<gap reason="ellipsis"/> 
                                        መንግሥቱ፡ ለ<persName ref="https://betamasaheft.eu/PRS5636IyoasI">ኢዮአስ፡</persName> 
                                        ወሲመተ፡ መምሕርነ፡ <persName ref="https://betamasaheft.eu/PRS14694ZafaraSel">ዘፈረ፡ ሥላሴ፡</persName> 
                                        ወአፈ፡ መምሕር፡ <persName ref="https://betamasaheft.eu/PRS14698ZaffaraMik">ዘፈረ፡ ሚካኤል፡</persName> 
                                        ወቄስ፡ ገበዝ፡ <persName ref="https://betamasaheft.eu/PRS14695Aymathono">አይሞት፡ ሁኖ፡</persName></q>
                                </item>
                                <item xml:id="a8">
                                    <locus target="#108vc"/>
                                    <desc type="Inventory">Inventory of church utensils in Amharic.</desc>
                                    <q xml:lang="am">፩ ዓውድ፡ የሚቆምበት፡ ወንበር፡ <gap reason="ellipsis"/> ፩ መቅድም፡</q>
                                </item>
                                <item xml:id="a9">
                                    <locus target="#109v"/>
                                    <desc type="LandGrant">Probably a record of a regular donation to the monastery of 
                                        <placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">Ṭānā Qirqos</placeName> in Amharic.</desc>
                                    <q xml:lang="am">ባጼ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName> መንግሥት፡ የሻለቃ፡ ተፋለጥ፡ ባስጐለቱት፡ ጉልት፡ 
                                        በዛራ፡ የሲዛን፡ ጋሻ፡ ለፃና፡ ቅዱስ፡ ቂርቆስ፡ ጫን፡ ስንዴ፡ ለመስዋዕት፡ ይገበርበታል፡</q>
                                </item>
                                <item xml:id="a10">
                                    <locus target="#111r"/>
                                    <desc type="RecordReconciliation">Record in Amharic of the settlement of a dispute between mamhǝr 
                                        <persName ref="https://betamasaheft.eu/PRS14699WaldaIy">Walda ʾIyasus</persName> and two "nomads" (<foreign xml:lang="gez">ዘላኖች፡</foreign>)
                                        The date of the note can be assumeed on linguistic grounds to be no earlier than the 19th century: "The mamhǝr of 
                                        Ṭānā (Qirqos) Walda ʾIyasus and the horsemen of the Emperor (namely) Kǝnfe and ʾAyyāko reconciled with each 
                                        other. Before, they (Kǝnfe and ʾAyyāko) said, ‘(give us) our money’ and quarrelled. But then (Walda ʾIyasus) said, ‘as 
                                        for money we have no, except to buy grass and feed them (the domestic animals); the land belongs to (the) Ṭānā 
                                        (monastery). They took an oath and finished (the dispute). The mediators are mamhǝr ʾAmmǝḫā, blātengetā ʾAkāla 
                                        Krǝstos, (commander of) the battalion Zafaṭāri, ʾabeto ʾAdrǝya. The witnesses are these: liqe Takla Hāymānot, ʾazzāž 
                                        Tadasewos, liqe Batre" (translation by Magdalena Krzyżanowska).</desc>
                                    <q xml:lang="am">የ<placeName ref="https://betamasaheft.eu/INS1004TanaQirqos">ፃና</placeName>ው፡ መምህር፡ 
                                        <persName ref="https://betamasaheft.eu/PRS14699WaldaIy">ወልደ፡ ኢየሱስ</persName>ና፡ የሐፄ፡ ዘላኖች፡ 
                                        <persName ref="https://betamasaheft.eu/PRS14700Kenfe">ክንፌ</persName>ና፡ <persName ref="https://betamasaheft.eu/PRS14701Ayako">አያኮ፡</persName>
                                        ሲታረቁ፡ ቀድሞ፡ ገንዘባችን፡ ብለው፡ ተከራክረው፡ ነበር፡ ኋላግን፡ ገንዘብም፡ የለን፡ ሣር፡ ገዝተን፡ ከማብላት፡ በቀር፡ ርስት፡ የፃና፡ ነው፡ ብለው፡ ሐፄ፡ ይሙቱ፡ ብላው፡ 
                                        ተፈጽመዋሱ። አስታራቆቹም፡ መምህር፡ <persName ref="https://betamasaheft.eu/PRS14702Ammeha">አምኃ፡</persName> 
                                        ብላቴን፡ ጌታ፡ <persName ref="https://betamasaheft.eu/PRS14703AkalaKr">አካለ፡ ክርስቶስ፡</persName> 
                                        የሻለቃ፡ <persName ref="https://betamasaheft.eu/PRS14704Zafatari">ዘፈጣሪ፡</persName> 
                                        አቤቶ፡ <persName ref="https://betamasaheft.eu/PRS14705Adarya">አደርየ።</persName> 
                                        መሳክርቱም፡ ሊቄ፡ <persName ref="https://betamasaheft.eu/PRS14706TaklaHaym">ተክለ፡ ሃይማኖት፡</persName> 
                                        አዛዥ፡ <persName ref="https://betamasaheft.eu/PRS14707Tadasewos">ተደሴዎስ፡</persName> 
                                        ሊቄ፡ <persName ref="https://betamasaheft.eu/PRS14708Batre">በትሬ፡</persName> እሌህ፡ ናችው።</q>
                                </item>

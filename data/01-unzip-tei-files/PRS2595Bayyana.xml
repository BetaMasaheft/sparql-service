         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">በየነ፡ ዛህላይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Bayyana Zāhlāy</t:persName>
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč</t:roleName>
               </t:persName>
               
               
               <t:nationality type="Eritrea"/>
              
               <t:birth when="1900">He was born at <t:placeName ref="https://betamasaheft.eu/LOC5999Tokond">Toḵondaʿ</t:placeName>, 
                  southern <t:placeName ref="https://betamasaheft.eu/LOC1298Akkala">Akkälä Guzay</t:placeName> in <t:date>1900</t:date>.</t:birth>
               
               
               <t:occupation type="political">governor</t:occupation>
               
               
               <t:floruit notBefore="1925" notAfter="1974">He was an important 
                  <t:placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</t:placeName> n politician. He inherited the chieftainship 
                  from his father in <t:date>1925</t:date> and became the chief administrator of the
                  <t:placeName ref="https://betamasaheft.eu/LOC1188AddiQa">ʿAddi äyyǝḥ</t:placeName> district. 
                  He was also elected as a representative of the <t:placeName ref="https://betamasaheft.eu/LOC1188AddiQa">ʿAddi äyyǝḥ</t:placeName>
                  district to the <t:placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</t:placeName> n assembly in <t:date>1952</t:date>.</t:floruit>
         
               
               
            </t:person>
            
            

                        <msContents>
                        <summary/>
                        
                            <msItem xml:id="ms_i1">
                            <locus from="1r" to="24v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1452GadlaG">Gadla Gabra Maśiḥ</title>
                            <textLang mainLang="gez"/>
                                <filiation>
                                    
                                </filiation>
                            <incipit xml:lang="gez">
                                <locus target="#4r"/>
                                በስመ፡ እግዚአብሔር፡ አብ፡ ብሑተ፡ ሥልጣን፡ ወምክር። ወበ<surplus>፡</surplus>ስመ፡
                                እግዚአብሔር፡ ወልድ፡ ዕሩየ፡ መለኮት፡ እንበለ፡ ድኂር። ወበስመ፡ እግዚአብሔር፡ መንፈስ፡ ቅዱስ፡ ጳራቅሊጦስ፡ ንጉሥ፡ ዘኢይሰዓር። ሎቱ፡ ይደሉ፡ ስብሐት፡ 
                                ወክብር። ። ። ከመ፡ ንዜኑ፡ ንስቲተ፡ ሥነ፡ ኂሩቱ፡
                                ወግብሩ፡ ወኅቡአተ፡ ገድሉ፡ ለብፁዕ፡ ወቅዱስ፡ አብ፡ መሲሐዊ፡ መምህረ፡
                                ሕግ፡ ዘደብረ፡ ገርዜን፡ ኖትያዊ፡ ሊቀ፡ ሐመር፡ ቀላየ፡ መጻሕፍት፡ <sic>ዘይጾቢ።</sic> በአስራገ፡
                                ኦሪት፡ ወፈለገ፡ ነቢያት፡
                            </incipit>
                            </msItem>
                    </msContents>
                    

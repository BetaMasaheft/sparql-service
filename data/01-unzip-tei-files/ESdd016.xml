                  <msItem xml:id="ms_i1.6">
                     <locus from="173va" to="173vc"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1395Fethan#ColophonTranslation">Fǝtḥa nagaśt: Final note on the translation</title>
                     <colophon xml:id="coloph1" xml:lang="gez">
                        The original dates (cf. <ref type="mss" corresp="https://betamasaheft.eu/BLorient799">London, British Library, BL Oriental 799</ref>) of the embedded colophon were replaced by other dates in <ref target="#h2">Hand 2</ref>or in a secondary hand. 
                        The dates most likely refer to the time when the copying of the present text was completed; they do not match exactly:
                        <date calendar="creation" when-custom="7162" when="1670">7162 <foreign xml:lang="gez">ʿamata ʿālam</foreign> ʻyear of the worldʼ (=1670 CE)</date>, 
                        <date calendar="grace" when-custom="243" when="1667">243 <foreign xml:lang="gez">ʿamata mǝḥrat</foreign> ʻyear of mercyʼ (=1667 CE)</date>, 
                        <date calendar="ethiopian" when-custom="1666" when="1673">1666  <foreign xml:lang="gez">ʿamata śǝggāwe</foreign>  ʻyear of the Incarnationʼ (= 1673 CE)</date>, 
                        <date calendar="diocletian" when-custom="1383" when="1667">1383 <foreign xml:lang="gez">ʿamata samāʿtāt</foreign> ʻyear of the martyrsʼ (=1667 CE.), 
                           the second year of the reign of ʾIyasu (most likely <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyasu I</persName> (=1684 CE).</date> 
                     </colophon>
                  </msItem>
                  

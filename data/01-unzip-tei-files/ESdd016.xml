                        <item xml:id="e4">
                           <q xml:lang="am"/>
                           <t:desc xmlns:t="http://www.tei-c.org/ns/1.0">Amharic commentaries written in smaller script in the upper margins and in the intercolumns in <ref target="#ms_i1">Text 1.1</ref>.</t:desc></item>
                     </list>


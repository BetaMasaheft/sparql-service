                           <t:desc xmlns:t="http://www.tei-c.org/ns/1.0">A crudely written title <foreign xml:lang="gez">Sǝnkǝsār</foreign>.</t:desc></item>
                        
                        <item xml:id="e2">
                           <locus target="#1r"/>
                           <t:desc xmlns:t="http://www.tei-c.org/ns/1.0">Shelfmark 444</t:desc></item> 
                        

                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards.</decoNote>
                        <decoNote xml:id="b2" type="Cover">Reddish-brown leather. <t:term xmlns:t="http://www.tei-c.org/ns/1.0" key="overCover" ana="#overCover">Overback made of tooled reddish-brown leather.</t:term>
                           <t:term xmlns:t="http://www.tei-c.org/ns/1.0" key="tooling" ana="#tooling">Blind tooled ornament</t:term> (6 tools were used: <t:term xmlns:t="http://www.tei-c.org/ns/1.0" key="doubleStraightLine" ana="#doubleStraightLine">double line fillet</t:term>, <t:term xmlns:t="http://www.tei-c.org/ns/1.0" key="doubleCircle" ana="#doubleCircle">double circles</t:term>, 
                           two types of <t:term xmlns:t="http://www.tei-c.org/ns/1.0" key="crissCross" ana="#crissCross">criss-cross</t:term>, three line interlaced fillet, double sine wave with dots).</decoNote>
                           <decoNote xml:id="b3" type="Sewing">Two pairs of sewing stations.</decoNote>
                           <decoNote xml:id="b4" type="SewingStations">4</decoNote>
                        <decoNote xml:id="b5" type="Endbands">Two pairs of chains of endband stitches at the spine cover.</decoNote>

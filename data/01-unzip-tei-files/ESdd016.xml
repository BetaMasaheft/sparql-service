                     <handNote xml:id="h2" script="Ethiopic">
                        <locus from="175ra" to="229rc"/> (from <ref target="#q23"/> to <ref target="#q29"/>)
                        <t:seg xmlns:t="http://www.tei-c.org/ns/1.0" type="script">Seventeenth-century script.</t:seg>
                        <t:seg xmlns:t="http://www.tei-c.org/ns/1.0" type="ink">Black, vivid red.</t:seg>

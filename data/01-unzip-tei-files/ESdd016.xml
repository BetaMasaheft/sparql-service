                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ንጽሕፍ፡ ዘይደሉ፡ እምሥርዓተ፡ ቅኔ፡ መልእክት፡ ዘክህነት፡ ዘይትፈቀድ፡ በውስተ፡ ጸሎታት፡ ወቅዳስያት፡<gap reason="ellipsis" resp="MK"/></incipit>
                     
                  </msItem>

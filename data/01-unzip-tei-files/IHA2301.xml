               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="iv" to="7r">iv-7r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2009IHA">انشودة يا رب هيئ لنا من امرنا رشدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#iv">-iv</locus>بسم الله الرحمن الرحيم / يا رب هي لنا من أمرنا رشد / وأجعل معونتك الحسن لنا مدد / ولا تكلنا إلى تدبير أنفسنا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7r">-7r</locus>أذن ولا نطقت في الكون أفواه / وكلنا منك راجون الشفاعة من / هوي أطعناه او ذنب جنيناه / فاقبل توسلنا سيدي سيدي / فإنسا ضيفكم والضيف محترام / آمين <note>إ</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="7v" to="13r">7v-13r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0710IHA">تخميس القصيدة المضرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>بسم الله الرحمان الرحيم / إذا أردت سلوك الخير في زمر / قم في غدو  وأصال وفي سحر / وقل إلهي بلاعجز والضجر / يا رب صل على المختار من مضر / والأنبيا وجميع الرسل ما ذكر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13r">-13r</locus>صل صلاة وتسليما مضاعفة / على النبي إله الخلق نامية / تزكو [لوكشموا؟] على الكرسي عالية / كذالك الرسل والأملاك قاطبة / والأل والصحب الأتباع ما ذكر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="13v" to="19r">13v-19r</locus>
                     <textLang xml:lang="x-un">Unidentified</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4685IHA">تطلحوا زبير تعامرا عبد الرحمن</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ِتِطَلْحَّوا زُبَيِّر تِعَامِرَا عَبْدُ الرَّحْمَنَ الصًلاَةُ والسًلاَمُ عَلَيكَ رَسُوْلُ الله تِسَعْدَا سَعِيدْ تِحَسَنَا حُسَيْنِ الصلاة والسلام عليك رسول الله [نِحَمْزَ] وَاَعَبَّاْسَ تَخضِيْرَا إِْليّاس </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19r">-19r</locus>اللهم لك الحمد والشكر كما أنت أهله وصل وسلم وبارك على سيدنا محمد بما أنت أهله وافعل بنا ما أنت أهله فلك الحمد والشكر أبدا سرمدا سبحانك اللهم وبحمدك أشهد أن لا إله الا أنت نستغفرك و نتوب إليك سبحان</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="19v" to="21v">19v-21v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0753IHA">قصيدة طف بحالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#19v">-19v</locus>الله الله الله الله الله / صلوتي على النبي وسلامي / طف بحاني سبعا وقف يذماي / وتحرد لزورتي كل عامي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#21v">-21v</locus>فهو قصدي وبغير ومقاءي / وأسكنى في جار خير الأنامي / فالحمد للحي الحليم الكريم / العليم القدير محي العظامي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="21v" to="26v">21v-26v</locus>
                     <title ref="https://betamasaheft.eu/LIT4609IHA">نظم بدأت بحمد فاضل متكاثر</title>
                     <incipit xml:lang="ar">
                        <locus target="#21v">-21v</locus>صلاة وتسليم وأزكي تحية / على نور عرش الله حاوي المفاخر / بدأت بحمد فاضل متكاثر / لذي نعم لم يحصها حصر حاضر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>أصلي صلاة مع سلام ململا / على نور ذات الله [طه؟] المفاخر / وأصحابه والتابعين ذريعه / أولي الفضل والإحسان خير مصابر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="27r" to="31v">27r-31v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4165IHA">قصيدة ثق بمولاك ولاتسال احدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>بسم الله الرحمن الرحيم / ثق بمولاك ولا تسئل أحد / وبطه لذ إذا خطب ورد / وبجد قل فمن جد وجد / يا رسول الله غوثا ومدد - أنتم  الوالد والعبد الولد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#31v">-31v</locus>ما همى دمع  بخد ساجما / ما عص صب عدولا لائما / وتمادى في هواه دائما / كد وام الله يبقي دائما - فهم أعلى العلا ثم الرشد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="32r" to="33v">32r-33v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0734IHA">مدح النبي صلاة على المشفع</title>
                     <incipit xml:lang="ar">
                        <locus target="#32r">-32r</locus>بسم الله الرحمن الرحيم / بجمال وجهك سيدي أتشفع \ ولباب جودك بالدعا أتضرع \ يا من لقدرته الجبابر تخضع \ يا من يرى ما في الضمير ويسمع - أنت المعد لكل ما يتوقع </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33v">-33v</locus>ثم الصلاة على امين يشفع - للمذنيين اذ الخلايق يجمع / مع السلام على النبي وأله - خير الخلائق شافع ومشفع</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="33v" to="34v">33v-34v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4347IHA">نظم بدأت ببسم الله والحمد أولا</title>
                     <incipit xml:lang="ar">
                        <locus target="#33v">-33v</locus>بسم الله الرحم الحيم / بدأت ببسم الله والحمد أولا - على نعم لم تحص فيما تنزلا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34v">-34v</locus>كريم العطا يا رب أجول عطيتي - رقيب على الأعدء يلفي إذا [كلا؟] / دعوت مجيبا امرا متفيلا - كثير العطا يا وسيع الجود مجزلا</explicit>
                     <note/>
                     <note/>
                  </msItem>

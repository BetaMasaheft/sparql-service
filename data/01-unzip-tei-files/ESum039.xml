                        <extent>Made of <measure unit="leaf">162+2</measure> folia, in <measure unit="quire">22</measure> quires. 
                           
                           <dimensions type="outer">
                              <height unit="mm" atLeast="310" atMost="330">320</height>                              
                              <width unit="mm" atLeast="210" atMost="245">220</width>
                              <depth unit="mm">75</depth>

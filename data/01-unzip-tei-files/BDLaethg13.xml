                  <additions>
                     <list>
                        
                        <item xml:id="a1"> 
                           <locus from="1" to="2">Fols 1–2</locus>
                           <desc type="GuestText">Hymn to <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName>, largely illegible. The following is the incipit:</desc> 
                           <q xml:lang="gez">ሰላም፡ ለከ፡ ጊዮርጊስ፡</q>
                        </item>
                        
                        <item xml:id="e1">
                           <desc>The name of the orginal owner has been erased in <ref target="#ms_i1"/> and
                              elsewhere, and that of <persName role="owner" ref="https://betamasaheft.eu/PRS11452WaldaM">Walda Māryām</persName> been substituted.</desc> 
                           <q xml:lang="gez"/>
                        </item>
                     </list>
                  </additions>
                  

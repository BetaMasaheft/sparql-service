                        <idno>Ullendorff 69</idno>
                     </altIdentifier>
                  </msIdentifier>
               
               <msContents>
                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <locus from="3r">Fols 3r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="39v">Fols 39v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2967RepCh248">Ba-samāy
                                                  wa-ba-mǝdr ʾalbǝya bāʿd</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በሰማይ፡ ወበምድር፡ አልብየ፡ ባዕደ፡ አበ፡ ወእመ፡ እኅተ፡ ወውሉደ፡ ማርያም፡ ድንግል፡</incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="45r" to="56v">Fols 45r–56v</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2444Temher">ትምህርተ፡ ኅቡአት፡</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="58v" to="66r">Fols 58v–66r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6161BakwelluH">Litany to Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ኦእግዝእትየ፡ ማርያም፡ በእኅዘቱ፡ በመጣብሕ፡</incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="66r">Fols 66r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3090RepCh370">Hymn to Jesus
                                                  Christ</title> 
                     
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ <t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="undefined" resp="PRS9622Ullendor">ክ</t:supplied>ርስቶስ፡ ወልደ፡ 
                        እግዚአብሔር፡ ሕያው፡ በእንተ፡ ማርያም፡ ወላዲትከ፡ ርድአኒ፡</incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus target="#78v">Fol. 78v</locus>
                     <title type="complete">Prayer to <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>Consists of six lines.</note>
                  </msItem>
               </msContents>
                     

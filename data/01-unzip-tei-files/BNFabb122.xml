                    <msItem xml:id="ms_i2">
                          <locus from="64ra" to="68rb"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT3177Canon">Canon of the Doctors of the Church on those who abjure</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                          <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ።</hi> ቀኖና፡ ዘአንበሩ፡
                        አበው፡ መምህራነ፡ ቤተ፡ ክርስቲያን፤ በእንተ፡ ዘክሕደ፡ ሃይማኖቶ፡ አው፡ ዘአርኰሰ፡ ሥጋሁ፡ ምስለ፡ ዘኢማእምንት።</incipit>
                          </msItem>

                          <msItem xml:id="ms_i3">
                                <locus from="69ra" to="148vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT7145MFTabiban">Maṣḥafa falāsfā ṭabibān</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                  <hi rend="rubric">በስመ፡ እግዚአብሔር፡ መሐሪ፡</hi> ወመስተሣህል፡ ወላዕሌሁ፡
                                  ት<hi rend="rubric">ውክልነትነ፡ ወርድኤትነ፡ ንወጥ</hi>ን፡ በረድኤተ፡ እግዚእነ፡
                                  ኢየሱስ፡ ክርስቶስ፡ በጸሒፈ፡ መጽሐፈ፡ ፈላስፋ፡ ጠቢባን፡ ዘተናገሩ፡
                                  ባቲ፡ ለለ፡ ፩፩፡ እምኔሆሙ፡ በአምጣነ፡ ክሂሎቶሙ፨ ወናሁ፡ አስተጋብኡ፡ ውስቴታ፡ ነገረ፡ ማዕዳን፡
                                </incipit>
                                </msItem>

                                <msItem xml:id="ms_i4">
                                      <locus from="149ra" to="168ra"/>
                                      <title type="complete" ref="https://betamasaheft.eu/LIT6574AssartuSelat">The Ten Questions</title>
                                      <textLang mainLang="gez"/>
                                      <incipit xml:lang="gez">
                                        <hi rend="rubric">በስመ፡ እግዚአብሔር፡ ኃያል፡</hi> ንወጥን፡ በረድኤተ፡ እግዚ<hi rend="rubric">አብሔር፡
                                        ሎቱ፡ ስብሐት፡ በጸ</hi>ሒፈ፡ ዓሠርቱ፡ ተስእለታ<hi rend="rubric">ት፡ ተስአሎ፡ ቀዳማዊት፡ ዘ</hi>
                                        ብዩን፡ ውስቴታ፡ ትርጓሜ፡ ትሥልስት፡ ወተዋሕዶ፨ ይቤ፡ ረድእ፡ ኦመምህር፡ ነገር፡ ኅፁር፡ ብያኔ፡ ለዓለማውያን፡
                                      </incipit>
                                      <note>Published in <bibl corresp="http://zotero.org/groups/358366/items/CCDTTNRG"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Cerulli1960ScrittiII"/><title level="m">Scritti teologici etiopici dei secoli XVI-XVII&lt;hi rend="italics"&gt;, II:&lt;/hi&gt; La Storia dei Quattro Concili ed altri opuscoli monofisiti</title><title level="s">Studi e Testi</title><author><forename>Enrico</forename><surname>Cerulli</surname></author><pubPlace>Città del Vaticano</pubPlace><publisher>Biblioteca Apostolica Vaticana</publisher><date>1960</date><series><title level="s">Studi e Testi</title><biblScope unit="volume">204</biblScope></series><biblScope unit="volume">204</biblScope><note type="tags"><note type="tag">bm:Cerulli1960ScrittiII</note></note><note type="tag">bm:Cerulli1960ScrittiII</note></bibl></note>
                                      </msItem>

                                      <msItem xml:id="ms_i5">
                                            <locus from="169ra" to="179vb"/>
                                            <title type="complete" ref="https://betamasaheft.eu/LIT4010Haymanotu">Hāymānotu la-qǝddus ʿābiyy māri Yāʿqob ʾƎlbarādʿi</title>
                                            <textLang mainLang="gez"/>
                                            <incipit xml:lang="gez">
                                              <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ </hi>ቅዱስ፡ ፩አምላክ።
                                              ንቀድም፡ በ<hi rend="rubric">ረድኤተ፡ እግዚአብሔር፡ ወሥ</hi>ነ፡ ሰርሒቱ፡ በጸሒፈ፡ ሃይማኖ<hi rend="rubric">ቱ፡
                                              ለቅዱስ፡ ዐቢይ፡ ማሪ፡ ያዕቆ</hi>ብ፡ እልበራድዒ፡ ጳጳሶሙ፡ ለያዕቆባውያን፡ ለሶርያ፨ ወለቅብጥ፡ ወለኢትዮጵያ፨
                                            </incipit>
                                            </msItem>

                                            <msItem xml:id="ms_i6">
                                            <locus from="180ra" to="193ra"/>
                                            <title type="complete" ref="https://betamasaheft.eu/LIT6575TemhertaHaymanot">The Teaching of the Orthodox Faith</title>
                                              <textLang mainLang="gez"/>
                                                <incipit xml:lang="gez">
                                                <hi rend="rubric">ትምህርተ፡ ሃይማኖት፡ ርትዕት፡ ወፍኖተ፡ አም</hi>ላክ፡ ጽይሕት፡ ዘጼሕዋ፡ ሐዋርያት፡ ወተለውዋ፡
                                                ሊቃውን<hi rend="rubric">ተ፡ ቤተ፡ ክርስቲያን፡ ርቱዓነ፡ ሃይማኖት፡ ትብል፡ ከ</hi>መዝ፨
                                                ነአምን፡ ወንትአምን፡ በልብ፡ ወበቃል፡ በአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                                              </incipit>
                                                </msItem>


                                          <msItem xml:id="ms_i7">
                                          <locus from="193rb" to="213ra"/>
                                            <title type="complete" ref="https://betamasaheft.eu/LIT3560Chrfaith">Untitled Amharic treatise on the Christian faith</title>
                                            <textLang mainLang="am"/>
                                            <incipit xml:lang="am">
                                              <hi rend="rubric">ሃይማኖት፡ ለሚየከስ፡ የሃይማኖት፡ አመላለስ፡ እንዴኽ፡ ነው።</hi> በማን፡ ታምናለኽ፡
                                                በእግዚአብሔር፤ እግዚአብሔር፡ ስንትነው፡ ሶስትም፡ ነው፡ ሐንድም፡ ነው፨ ሶስትም፡ ሐንድም፡
                                                በምን፡ ይቻላል፨ ይኸሳ፡ ፀሐይ፤ እሳት፤ ባሕር፤ ነፍስ፤ ሶስትምናቸው፡ ሐንድምቸው፨
                                              </incipit>
                                                </msItem>


                                                <msItem xml:id="ms_i8">
                                                <locus from="213ra" to="218va"/>
                                                  <title type="complete" ref="https://betamasaheft.eu/LIT1385Fekkar">Fǝkkāre ʾIyasus</title>
                                                  <textLang mainLang="gez"/>
                                                  <incipit xml:lang="gez">
                                                    <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ። ፍካሬ፡ ኢየ</hi>ሱስ፡ ክርስቶስ፨
                                                     ዘተስእልዎ፡ አርዳኢሁ፡ ለኢየሱስ፡ እምዘ፡ ይመስሕ፡ ምስሌሆሙ፡ ሐተትዎ፡ ወይቤልዎ፨
                                                     እስኩ፡ ንገሩነ፡ ኦሊቅነ፡ በደኃሪ፡ ትውልድ፡ ዘይመጽእ፡ መዋዕል፡ ወምንተ፡ ይከውን፡ ትእምርቱ፨
                                                    </incipit>
                                                      </msItem>




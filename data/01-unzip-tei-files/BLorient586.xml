                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#1r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ምዕራፍ፡ ዝማሬ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                                    </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#111r"/>
                                    <desc type="GuestText"><title ref="https://betamasaheft.eu/LIT3186Meeraf#Mehella">Mǝʿrāf: Chants for the office of Rogationምዕራፍ፡ ዘአርእስት፡ ምህል፡ በምሉእ፡ ወበጐደሎ።</title></desc>
                                    <q xml:lang="gez"><seg part="I">ምህላ፡ ፱ ዘምሉእ፡ ፫ እምኔሆሙ፡ ምህላ፡ ዘሆሣዕና፡ ዘዓርብ፡
                                    ወምህላ፡ በበዓለ፡ ፶ ዘረቡዕ።</seg></q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#111v"/>
                                    <desc type="GuestText"/>
                                    <q xml:lang="gez"><seg part="I">ወግ፡ ዘፋሲካ፡ እምፋሲካ፡ እስከ፡ ዕርገት፡ ዘእኁድ፡ ትንሣኤ፡ ዮም፡ ፋሲካ፡ ይትበሀል። እምፋሲካ፡ እስከ፡
                                    ዕርገት፡ በሰኑይ፡ ፀአተ፡ ሲኦል፡ ይትበሀል።</seg></q>
                                </item>
                                
                                <item xml:id="a4">
                                    <locus target="#128v"/>
                                    <desc type="GuestText">Probably an excerpt from <title ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title>.</desc>
                                    <q xml:lang="gez"><seg part="I">ዝማሬ፡ ዘደብረ፡  <del rend="erasure"/> ወአመ፡ ሰዱስ፡ ነሥኦሙ፡ ኢየሱስ፡ ለጴጥሮስ፡ ወለያዕቆብ፡ ወለዮሐንስ፡ ወአዕረጎሙ፡ ደብረ፡ ነዋህ፡</seg></q>
                                </item>
                                
                                <item xml:id="e1">
                                    <locus target="#1r"/>
                                    <desc>The name of the owner was <persName role="owner" ref="https://betamasaheft.eu/PRS13815WaldaG">Walda Giyorgis</persName> and that of the scribe 
                                        <persName role="scribe" ref="https://betamasaheft.eu/PRS13814MekhaG">Mǝkḥa Giyorgis</persName> (<locus target="#67r"/>).</desc>
                                </item>
                            </list>
                        </additions>
                        

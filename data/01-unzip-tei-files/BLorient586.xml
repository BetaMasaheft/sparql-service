                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1ra" to="67ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3186Meeraf">Mǝʿrāf</title>
                            <textLang mainLang="gez"/>
                            <notatedMusic><desc>With musical notes.</desc></notatedMusic>
                            <incipit xml:lang="gez">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ተፀዊነነ፡ ቦቱ፡ ጽሒፈ፡ ምዕራፍ፡ ሎቱ፡ ስብሐት፡ እስከ፡ ለዓለም፡ ዘይትቀነዩ፡ በበዘመኑ፡ እምዮሐንስ፡
                            እስከ፡ ዮሐንስ።</incipit>
                            <colophon xml:id="coloph1">
                                <locus target="#67r"/>
                                ዝመጽሐፍ፡ ዘ<persName role="owner" ref="https://betamasaheft.eu/PRS13815WaldaG">ወልደ፡ ጊዮርጉስ፡</persName>
                                ወጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13814MekhaG">ምክሃ፡ ጊዮርጊስ፡</persName> ለዓለመ፡ ዓለም፡ አሜን፡ ወኣሜን፡ ለይኩን፡ ለይኩን። በዝየ፡ ተፈጸመ፡ ምዕራፍ።
                            </colophon>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="68ra" to="110vc"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1990Mawase">Mawāśǝʾt</title>
                            <textLang mainLang="gez"/>
                            <notatedMusic><desc>With musical notes.</desc></notatedMusic>
                            <incipit xml:lang="gez">መዋሥዕት፡ እምዮሐንስ፡ እስከ፡ ዮሐንስ፡ ዘተጽሕፈ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="113ra" to="128rb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6489SchoolChants">School Chants</title>
                            <textLang mainLang="gez"/>
                            <notatedMusic><desc>With musical notes.</desc></notatedMusic>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">

                            <title type="complete" ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title>
                            <textLang mainLang="gez"/>
                            <notatedMusic><desc>With musical notes.</desc></notatedMusic>
                            <note>The text ends with creeds, <ref type="work" corresp="https://betamasaheft.eu/LIT2168PaterN">Our Father</ref>, etc.</note>
                        </msItem>

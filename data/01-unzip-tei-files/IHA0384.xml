               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="171r">1r-171r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>باب في فضل الصلاة على النبي صلى الله عليه وسلم وشرف وكرم ومجد وعظم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#171r">-171r</locus>وصل اللهم بجلالك وسلم وبارك على سيدنا ومولانا محمد خاتم النبيين , وامام المرسلين , والحمد لله رب العالمين امين امين امين يا رب العالمين تمت</explicit>
                     <note>Vocalized. </note>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>
                        <extent>
                           <measure unit="folio">174</measure>
                                        Pre: <measure unit="folio">0</measure>
                                        Post: <measure unit="folio">0</measure>
                        </extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA0384#ms_i0">
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS0675IHA">احمد بن هاشم</persName>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>Galligraphic rendering of the name Muḥammad and a pentagram. Pink felt-tip pen.</q>
                        <note/>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a5_872">
                           <locus target="#171r">-171r</locus>
                           <q xml:lang="ar">وقع الفراغ من كتابته وقت العصر يوم الثلاثا في شهر شعبان بعد ما مضى نصفه في يد الفقير الحقير الراجي عفو ربه القدير اللهه غفر لكاتبه والجميع المسلمين الخط يبقى [...] داىم الدوام وكاتبه احمد بن هاشم</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_872">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Chapter headings, verse markers and important words in red.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_872">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">الخط يبقى في القرطاس دهرا لو كنت يمكننى والرب [يرزقني] لكنت اكتبه [بالمسك والعالي]  وكاتبه احمد. سالتك بالله يا قارى خطى بان تسل الرحمن غفر ان ذلتى ومحو الخطايا فاني فلم  ا ت ل اخطى</q>
                           <desc>Scribal verses</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_872">
                           <locus target="#1r-1v">-1r-1v</locus>
                           <q xml:lang="ar">بوافعة ومقالاته بصادقة وما اظهر الله على يديه من الكرامات الخارقات</q>
                           <note>
                              <desc>
                                 <ref type="work" corresp="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</ref>
                              </desc>
                           </note>
                        </item>
                        <item xml:id="a4_872">
                           <locus target="#155r-171v-174r">-155r, 171v, 174r</locus>
                           <q xml:lang="am">Notes in Fidel script.</q>
                        </item>
                        <item xml:id="a2_872">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">كتاب مختصر تنبيه الانام  في مقام سيدنا ونبينا محمد عليه افضل الصلاة وازكى السلام تأليف سيدنا شيخ الامام عبد الجليل بن محمد بن احمد بن عظوم المرادي القيرواني غفر الله له ولوالديه ولجميع المسلمين وصلى الله على سيدنا محمد واله وصحبه وسلم تسليما كثيرا امين</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#108r">-108r</locus>
                           <desc>Waqf</desc>
                           <q>هذا تنبيه الانام ملك حج ابا بور أبا بلوا وقفت لجميع المسلمين وناظره ابنى شرفا [ه؟] في سنة ١٤١١ شهر رابع من المولد</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#3r">-3r</locus>
                           <desc>Ownership</desc>
                           <q>هذ الكتاب ملك حج ابا مڟا ابا بورا ابن ابا بلو وَلِسُو قريته قنبى وَلِسُو نَسَبًا</q>
                           <note/>
                        </item>
                        <item xml:id="a3">
                           <locus target="#3r">-3r</locus>
                           <desc>Ownership</desc>
                           <q>كل ملك حجى محمد ؟</q>
                           <note>The note is unclear.</note>
                        </item>
                        <item xml:id="a4">
                           <locus target="#47r">-47r</locus>
                           <q>اعلم ان جميع الفاظ ابن مجرورة على انه وصف القبي المجرور قبله الا ابن الاول فانه مرفوع فانه وصف للمرفوع كما نقل عن السبد [...] اه حاشية</q>
                           <note>Unidentified fragment. Some of the words are divided into two different lines</note>
                        </item>
                        <item xml:id="a5">
                           <locus target="#171v">-171v</locus>
                           <desc>Notes in Fidel script.</desc>
                           <q/>
                           <note/>
                        </item>
                     </t:list>
                  </additions>

                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="2r" to="10v">pp. 2–18</locus>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT7421CreedCommentary">Amharic Nicene Creed Commentary with Preamble</title>
                            <textLang mainLang="am"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ <gap reason="illegible"/><lb/>
                           ሁ፡ ወጠንኩ፡ ጸሎተ፡ ሃይማኖት፡ ዘተናገረ፡ በሀገረ፡ ኒቅያ፡ <lb/>
                               ፫፻ወ፲፰ ርቱዓነ፡ ሃይማኖት። ጸሎተ፡ ሃይመ</hi><gap reason="illegible"/><lb/></incipit>
                            <incipit xml:lang="am">
                                <supplied reason="lost">እንድም</supplied>ን፡ ጊዜ፡ ተዠመረ። እንደሆን። በቆስጠንጢኖስ። መንግሥት፡ ተዠመረ። እንደምን፡ ያሉ፡ እንደሆን። ኑማርያኖስ፡ የሚሉ፡ ንጉሠ፡ አንጾኪያ፡ ነበረ፡ ከንጉሠ፡ ቁዝ፡ ጋራ፡ ይዋጋ፡ ነበረ። አንድቀን፡ ከቤቱ፡ ሳለ፡ ንጉሠ፡ ቁዝ፡ መጻበት፡ እዋጋው፡ ብሎ፡ እርሱም፡ አይቶ፡ ወንድ፡ ልጅ፡ አልነበረዉምና፡ አንድ፡ ሴት፡ ልጅ፡ ነበረቸው። 
                            </incipit>
                            <explicit xml:id="am">ወንሴፎ፡ ትንሣኤ፡ ሙታን። ሙተን፡ ንነሣለን። እዝነን፡ እንፈሣለን። ስንል፡ ነው። ወሕይወተ፡ ዘይመጽእ፡ ለዓለመ፡ ዓለም። አሜን። ድንት፡ ለድንት፡ ሕይወት፡ አለን። ስንል። ከመ፡ ውእቱ፡ ሃይማኖተ፡ አበዊነ። ጸሎትክሙ፡ ወስእለትክሙ፡ ረድኤትክሙ። ወሃይማኖትክሙ። የሀሉ። ምስለ፡ ፍቁርክሙ። <persName ref="https://betamasaheft.eu/PRS14827MazgabaS">መዝገበ፡ ሥላሴ።</persName> ለዓለመ፡ ዓለም። አሜን። ወአሜን። ለይኩን። ለይኩን። ተፈጸመ፡ በሰላመ። እግዚአብሔር። አሜን። ምስለ፡ ብዙኅ። ቀኖና፡ </explicit>
                        </msItem>
                            <msItem xml:id="ms_i2">
                                <locus from="10v" to="12r">pp. 18–21</locus> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT5934CommOurFather">Amharic Commentary on the Our Father</title>
                                <textLang mainLang="am"/>
                                <incipit xml:lang="gez">አቡነ፡ ዘበሰማያት፡ ።</incipit><incipit xml:lang="am"> ማለት፡ የሰማይ፡ አባታችን፡ ክርስቶስ፡ አምላካችን፡ ሰማይ፡ ሀገራችን፡ መንግሥተ፡ ሰማያት፡ ርስታችን። ማለ፡ ነው።</incipit>
                                <explicit xml:lang="am">ለዓለመ፡ ዓለም፡ ማለ። ድንት፡ ለድንት፡ ማለ፡ ነው። አሜን። ማለት፡ አዋን፡ እውነት፡ ነው። በዚህ፡ ሁሉ፡ ሐሰት፡ የለበት፡ ማለት። ነው።</explicit>
                            </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="13r" to="49r">pp.23–95</locus> 
                            <title type="complete" ref="https://betamasaheft.eu/LIT5936CommWeddaseM">Amharic Commentary on the Praises of Mary</title>
                            <textLang mainLang="am" otherLangs="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">ውዳሴሃ፡ ለእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፤</hi>ዘይትነበብ፡ በዕለተ፡ ሰኑይ።</incipit>
                            <incipit xml:lang="am">በሰኞ፡ ቀን፡ የሚነገር፡ <hi rend="rubric">ውዳሴዋ፡ ይኽ፡ ነው፡ ይልዋል። ይህን፡ ግን፡ ቃለ፡ ጸሃፊ፡ ነው፡</hi> የሀገራችን፡ ሊቃውንት፡ እንዴኽ፡ አሉ፡ ይልዋል።</incipit>
                        <explicit xml:lang="am">ከሠተ፡ አፉሁ፡ ወይቤ። አፉን፡ ገልጾ፡ ያለችውን፡ ነገር፡ ይናገር፡ ዠመረ።</explicit>
                            <note>Starting from p. 33 the text is accompanied with musical notation.</note>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="49r" to="51r">pp.95–102</locus> 
                            <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ።</hi> ውዳሴ፡ ወግናይ። እሙ፡ ለአዶናይ፡ ወእምዝ፡ ንጽሕፍ። ቅድስት፡<hi rend="rubric"> ወብፅዕት፡ ስብሕት፡ ወቡርክት፡ ክብርት፡ ወልዕልት።</hi> አንቀጸ፡ ብርሃን፡ መዓርገ፡ ሕይወት፡ ወማኅደረ፡ መለኮት፡ ቅድስት፡ ቅዱሳን፡ አንቲ፡ ውእቱ፡</incipit>
                       <note>The text is accompanied with musical notation.</note>
                        </msItem>

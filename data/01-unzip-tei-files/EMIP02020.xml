               <msContents>
                  <summary>Funeral Ritual, መጽሐፈ፡ ግንዘት፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="168v" facs="002">Fols 1r–168v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1931Mashaf">Maṣḥafa
                                                  gǝnzat</title>

                  <msItem xml:id="ms_i1.1">
                     <locus from="1r" to="6r" facs="002">Fols 1r–6r</locus>
                     <title>The Prayer of Athanasius for the Passing of the Soul</title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ነገር፡ ዘበእንተ፡ሞተ፡  ቃለ፡ አትናቴዎስ፡ ወጸሎት፡ በእንተ፡ ማኅለፍተ፡ ነፍስ፡ ከመዝ፡ ትብል፡ አንተ፡ ውእቱ፡ ባሕቲትከ፡ ሕያው፡ ዘኢትመውት፡ ዘፈጠርኮ፡ ወገበርኮ፡ ለእጓለ፡ እመሕያው፡ ወንሕነሰ፡ ተፈጠርነ፡ እመሬት፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.2">
                     <locus from="6r" to="8r" facs="007">Fols 6r–8r</locus>
                     <title>Prayer of supplication</title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ንስእለከ፡ ወናስተበቁዓከ፡ ፃዒ፡ ወኢትሄልዪ፡ ንብረተ፡ ዓለም፡ ዝንቱ፡ ኃላፊ፡ ይኄይሰኪ፡ ዘበሰማያት፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="8r" to="19r" facs="009">Fols 8r–19r</locus>
                     <title>The Book that Came from Jerusalem, <foreign xml:lang="gez">መጽሐፍ፡ ዘወፅአት፡ እምኢየሩሳሌም፡</foreign>
                     </title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/>  ዛቲ፡ መጽሐፍ፡ ዘወፅአት፡ እምኢየሩሳሌም፡ ለመድኃኒተ፡ ነፍስ፡ ወሥጋ፡ በእንተ፡ ጻድቃን፡ ወኃጥአን፡ በእንተ፡ ጠቢባን፡ ወአብዳን፡ በእንተ፡ ጳጳሳት፡ወሊቃነ፡ ጳጳሳት፡ ወኤጲስ፡ ቆጶሳት፡ በእንተ፡  ቀሳውስት፡ ወዲያቆናት፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="19r" to="20v" facs="020">Fols 19r–20v</locus>
                     <title>Funeral ritual when they came out of the church with the body, <foreign xml:lang="gez">ወሶበ ይወፅኡ እምቤተ፡ ክርስቲያን፡ </foreign>
                     </title>
                     <incipit xml:lang="gez">ወሶበ፡ ይወፅኡ፡ እቤተ፡ ክርስቲያን፡ ይፍታሕ፡ ካህን፡ ዘንተ፡ ፍትሐተ፡ ለሥርየተ፡ ኃጢአት። እግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ፍቱሐ ረስዮ፡ ለዝንቱ፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                     <locus from="20v" to="24r" facs="022">Fols 20v–24r</locus>
                     <title>The Book that Came from Jerusalem, <foreign xml:lang="gez">መጽሐፍ፡ ዘወፅአት፡ እምኢየሩሳሌም፡</foreign>
                     </title>
                     <incipit xml:lang="gez">ዛቲ፡ መጽሐፍ፡ ዘወጽአት፡ እምኢየሩሳሌም፡ በእንተ፡ ኃጥአን፡ ወአባስያን፡ በእንተ፡ ርኩሳን፡ ወዘማውያን፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.6">
                     <locus from="24r" to="26r" facs="025">Fols 24r–26r</locus>
                     <title>Prayer of Our Lady Mary, <foreign xml:lang="gez">ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡</foreign>
                     </title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ጸሎተ፤ እግዝእትነ፤ ማርያም፤ ወላዲተ፡ መድኅን፡ ጸሎተ፡ እግዝእትነ፡ ማርያም፡  ወላዲተ፡ ሕይወት፡ ወላዲተ፡ መንፈስ፤ ወላዲተ ክርስቶስ፡ ወላዲተ፡ ኢየሱስ፡ ወላዲተ፡ አማኑኤል፡ ወላዲተ፡ የማን፡<gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.7">
                     <locus from="26r" to="31r" facs="027">Fols 26r–31r</locus>
                     <title>Reading of admonition at the time of entombment, <foreign xml:lang="gez">ተግሣጽ፡ ዘይትነበብ፡ ላዕለ፡ኵሎሙ፡ ምውታን፡ በጊዜ፡ ግንዘት፡</foreign>
                     </title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/>ተግሣጽ፡ ዘይትነበብ፡ ላዕለ፡ኵሎሙ፡ ምውታን፡ በጊዜ፡ ግንዘት፡ ስብ፡ት፡ ለእግዚአብሔር፡ ፈጣሪ፡ መንሥኤ፡ ኃያል፡ መሐሪ፡ ዝውእቱ፡ ውስተ፡ እዴሁ፡ ሥልጣነ፡ ሞት፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.8">
                     <locus from="31r" to="43r" facs="032">Fols 31r–43r</locus>
                     <title>Prayer of Incense, at the church, <foreign xml:lang="gez">ጸሎተ፡ ዕጣን።</foreign>. Published in Ethiopia, ጸሎተ፡ ዕጣን። (Addis Ababa: Tǝnśa’e Zä-Guba’e, 1951 EC)</title>
                     <incipit xml:lang="gez">ከመ፡ ተአጥን፡ ዕጣነ፡ በቤተ፡ ክርስቲያን፡ ባርክ፡ ምሥራቀ፡ ወምዕራበ፡ ሰሜነ፡ ወደቡበ፡ ወበል፡ አቡነ፡ ዘበሰማያት፡ ወጸሎተ፡ አኰቴት። ዘ፶ ዳዊት፡ በል።<gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.9">
                     <locus from="43r" to="44v" facs="044">Fols 43r–44v</locus>
                     <title>Funeral Ritual for Women who died during Passion Week, <foreign xml:lang="gez">አርእስተ፡ ምንባብ፡ ዘይትነበብ፡ ላዕለ፡ ምውታን፡ ሶበ፡ ይመውታ፡ አንስት፡ በሰሙነ፡ ሕማማት፡ </foreign>
                     </title>
                     <incipit xml:lang="gez">ክፍል፡ እምኦሪት፡ ሙሴ፡ ኮነ፡ ሕይወታ፡ ለሳራ፡፻፹ወ፯ ዓመታ፡ ወሞተት፡ ሣራ፡ በሀገረ፡ ርብቃ፡ እንተ፡ ቆላት፡  <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.10">
                     <locus from="44v" to="45v" facs="046">Fols 44v–45v</locus>
                     <title>Funeral Ritual for men who died in the Passion Week, <foreign xml:lang="gez">አርእስተ፡ ምንባብ፡ ዘይትነበብ፡ ሶበ፡ ይመውቱ፡ ዕደው፡ በሰሙነ፡ ሕማማት። </foreign>
                     </title>
                     <incipit xml:lang="gez">ወይብል፡ ኦሪተ፡ ሙሴ፡ ተፈጸመ፡ መዋዕለ፡ ላህ፡ ሰአሎሙ፡ ዮሴፍ፡ ለኃያላነ፡ ፈርዖን፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.11">
                     <locus from="46r" to="51r" facs="047">Fols 46r–51r</locus>
                     <title>Funeral Ritual for Priests, <foreign xml:lang="gez">መጽሐፈ፡ ግንዘት፡ በእንተ፡ አለ፡ኖሙ ካህናት፡ </foreign>
                     </title>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted"/> አርእስተ፡ ምንባብ፡ ላዕለ፡ ምውታን፡ በሰላመ፡ እግዚአብሔር፡ አሜን። መጽሐፈ፡ ግንዘት፡ በእንተ፡ እለ፡ ኖሙ፡ ካህናት፡ ወሶበ፡ ትወጽእ፡ ነፍሱ፡ በውስተ፡ ማኅደሩ፡ ይትበሀል። ጸሎተ፡ አኰቴት፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.12">
                     <locus from="51r" to="53v" facs="052">Fols 51r–53v</locus>
                     <title>Funeral Ritual for Faithful Fathers, <foreign xml:lang="gez">ግንዘት፡ ዘዲያቆናት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.13">
                     <locus from="53v" to="57v" facs="055">Fols 53v–57v</locus>
                     <title>Funeral Ritual for Faithful Fathers, <foreign xml:lang="gez">ግንዘት፡ ዘአበው፡ መሐይምናን፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.14">
                     <locus from="57v" to="59v" facs="059">Fols 57v–59v</locus>
                     <title>Funeral Ritual for Children, <foreign xml:lang="gez">ግንዘት፡ ዘሕፃናት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.15">
                     <locus from="59v" to="62v" facs="061">Fols 59v–62v</locus>
                     <title>Funeral Ritual for Women, <foreign xml:lang="gez">ግንዘት፡ ዘዓበይት፡ አንስት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.16">
                     <locus from="62v" to="64r" facs="064">Fols 62v–64r</locus>
                     <title>Funeral Ritual for Girls, <foreign xml:lang="gez">ግንዘት፡ ዘአዋልድ፡ ንዑሳት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.17">
                     <locus from="64r" to="66v" facs="065">Fols 64r–66v</locus>
                     <title>Funeral Ritual for Nuns, <foreign xml:lang="gez">ንዘት፡ ዘመነኮሳይያት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.18">
                     <locus from="66v" to="69v" facs="068">Fols 66v–69v</locus>
                     <title>Funeral Ritual for Monks, <foreign xml:lang="gez">ግንዘት፡ ዘመነኮሳት፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.19">
                     <locus from="69v" to="73v" facs="071">Fols 69v–73v</locus>
                     <title>Funeral Ritual for Bishop,  <foreign xml:lang="gez">ግንዘት፡ ዘኤጲስ፡ ቆጶስ፡</foreign>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i1.20">
                     <locus from="73v" to="54v" facs="075">Fols 73v–54v</locus>
                     <title>Funeral Processional with Seven Stations</title>
                    <msItem xml:id="ms_i1.20.1">
                        <locus from="73v" to="76v" facs="075">Fols 73v–76v</locus>
                        <title>Station One, when you bring out the body from the home</title>
                        <incipit xml:lang="gez">ሶበ፡ ታወጽኦ፡ ለምውት፡ እማኅደሩ። ቅድመ፡ ወንጌል፡</incipit>
                     </msItem>
                    <msItem xml:id="ms_i1.20.2">
                        <locus from="76v" to="78r" facs="078">Fols 76v–78r</locus>
                        <title>Station Two</title>
                     </msItem>
                    <msItem xml:id="ms_i1.20.3">
                        <locus from="78r" to="79v" facs="079">Fols 78r–79v</locus>
                        <title>Station Three</title>
                     </msItem>
                    <msItem xml:id="ms_i1.20.4">
                        <locus from="79v" to="82r" facs="081">Fols 79v–82r</locus>
                        <title>Station Four</title>
                     </msItem>
                    <msItem xml:id="ms_i1.20.5">
                        <locus from="82r" to="83v" facs="083">Fols 82r–83v</locus>
                        <title>Station Five</title>
                     </msItem>
                    <msItem xml:id="ms_i1.20.6">

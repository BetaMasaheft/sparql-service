               <msContents>
                  <summary>Psalter, ዳዊት፡, incomplete at the end</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="153v" facs="001">Fols 1r–153v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Due to the damage to the end of this codex, it is impossible to decipher further where the major works begin and end</note>

                  <msItem xml:id="ms_i1.1">
                     <locus from="1r" to="133r" facs="001">Fols 1r–133r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters, but space was left to include them</note>
                   </msItem>
                  <msItem xml:id="ms_i1.2">
                     <locus from="133r" to="145v" facs="133">Fols 133r–145v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="145v" to="151r" facs="146">Fols 145v–151r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="151v" to="153v" facs="152">Fols 151v–153v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                </msItem>


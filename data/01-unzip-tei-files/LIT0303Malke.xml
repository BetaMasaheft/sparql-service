      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ በሰሌዳ፡ ሕይወት፡ ጽሑፍ፨</l>
                  <l n="2">ወለሥዕርትክሙ፡ ሰላም፡ ጠለ፡ አርያም፡ ውኩፍ፨</l>
                  <l n="3">ኢያቄም፡ ወሐና፡ ገነተ፡ ጽባሕ፡ አዕዋፍ፨</l>
                  <l n="4">ከመ፡ እንብብ፡ ማሕሌትክሙ፡ ለከሢተ፡ ልሳን፡ ወአፍ፨</l>
                  <l n="5">መንፈሰ፡ አእምሮ፡ ዐዚዝ፡ ዲቤየ፡ ያዕርፍ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለርእስክሙ፡ በንድቀ፡ ጠባይዕ፡ ንቡር፨</l>
                  <l n="2">ወለገጽክሙ፡ ሰላም፡ እምገጸ፡ ኦርያሬስ፡ ንኩር፨</l>
                  <l n="3">ኢያዌም፡ ወሐና፡ ተስፋ፡ ሰማያት፡ ወምድር፨</l>
                  <l n="4">ይክድነኒ፡ ወይክብተኒ፡ ጸዳልክሙ፡ ምዕዙር፨</l>
                  <l n="5">ከመ፡ ከበቶ፡ ለዮናስ፡ ዐንበሪ፡ ዘባሕር፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ እብል፡ ለግንዘትክሙ፡ በእማኄ፨</l>
                  <l n="2">ወለመቃብሪክሙ፡ ሰላም፡ ጌቴሴማን፡ ዐይገ፡ ስባሔ፨</l>
                  <l n="3">ኢያቄም፡ ወሐና፡ ምሉኣነ፡ ስብሐት፡ ውስተ፡ ኵለሄ፨</l>
                  <l n="4">የዐድመኒ፡ ጽጌክሙ፡ ወመዐዛክሙ፡ ርሔ፨</l>
                  <l n="5">ምስለ፡ ኅሩያን፡ በዕለተ፡ መርዓ፡ እትዐጸፍ፡ ሱራኄ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ውሑደ፡ ነበብኩ፡ በማሕሌት፡ ወየብቦ፨</l>
                  <l n="2">እምስብሐታቲክሙ፡ ብዙኅ፡ ዘኢይትኈለቍ፡ ሐሳቦ፨</l>
                  <l n="3">ኢያቄም፡ ወሐና፡ ሐውጹኒ፡ በአስተርክቦ፨</l>
                  <l n="4">ተሀቡኒ፡ እንበለ፡ ዐቅም፡ ለከናፍርየ፡ ዐሥቦ፨</l>
                  <l n="5">ጸጋ፡ መንፈስ፡ ቅዱስ፡ ብዙኅ፡ ኈላቄ፡ ዘአልቦ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ስብሐት፡ ለአብ፡ ዘኪያክሙ፡ አፍቀረ፨</l>
                  <l n="2">ወሰጊድ፡ ለወልድ፡ እንተ፡ ጸገወክሙ፡ ክብረ፨</l>
                  <l n="3">ለመንፈስ፡ ቅዱስ፡ ግናይ፡ በሥንክሙ፡ ምዕዙረ፨</l>
                  <l n="4">ኢያቄም፡ ወሐና፡ አምኅለክሙ፡ ወትረ፨</l>
                  <l n="5">በስመ፡ ማርያም፡ ድንግል፡ ኵሎ፡ አሚረ፨</l>
                  <l n="6">ውስተ፡ ልብክሙ፡ ለእኩን፡ ኅዱረ፨</l>
               </lg>
            </div>
         </div>
      </body>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ዘሀሎ፡ በስብሐተ፡ ንግሡ፡ እንበለ፡ ጥንት፨</l>
                  <l n="2">ወይሄሉ፡ ዓዲ፡ እንበለ፡ ተፍጻሜት፨</l>
                  <l n="3">ውዳሴ፡ መልክእኪ፡ እንብብ፡ ማርታ፡ በትንባሌኪ፡ ቡርክት፨</l>
                  <l n="4">ያስትየኒ፡ ወይነ፡ አእምሮ፡ እምጽዋዔ፡ ጥበብ፡ ኅሪት፨</l>
                  <l n="5">ከመ፡ ለሱቱኤል፡ መልአከ፡ ገጽ፡ አስተዮ፡ ትካት፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ እብል፡ ለዝክረ፡ ስምኪ፡ እንዘ፡ ኣሌዕል፡ ዕበያ፨</l>
                  <l n="2">እምዝክረ፡ ብዙኃት፡ አንስት፡ እለ፡ ውስተ፡ ሮም፡ ወአንጾኪያ፨</l>
                  <l n="3">ማርታ፡ ዳግሚት፡ እኅተ፡ አልዓዛር፡ ወማርያ፨</l>
                  <l n="4">ለሥዕርትኪ፡ ሰላም፡ ወለርእስኪ፡ ነያ፨</l>
                  <l n="5">ደብረ፡ ቄርሜሎስ፡ ዘይመስል፡ አያያ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለቆምኪ፡ ወለመልክእኪ፡ ኵሎን፨</l>
                  <l n="2">ለፀአተ፡ ነፍስኪ፡ ወለበድነ፡ ሥጋኪ፡ ወለተ፡ አበው፡ ኄራን፨</l>
                  <l n="3">ማርታ፡ ብፅዕት፡ ሰይፈ፡ ብፅዓን፨</l>
                  <l n="4">እምኔኪ፡ እንተ፡ ተወልደ፡ ዕንቈ፡ ጳዝዮን፨</l>
                  <l n="5">ፊቅጦር፡ ዘያስተርኢ፡ ንኩረ፡ ለዓይን፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ከመ፡ እከሀል፡ ጥንቁቀ፡ ፈጽሞ፡ ውዳሴ፡ መልክእኪ፡ በበጾታሁ፨</l>
                  <l n="2">ንስቲተ፡ በተሀብሎ፡ ዘአቅረብኩ፡ ናሁ፨</l>
                  <l n="3">ተወከፊ፡ ሊተ፡ ማርታ፡ ሶበ፡ አብአት፡ ቅድሜሁ፨</l>
                  <l n="4">አሐቲ፡ ብእሲት፡ ከመ፡ ተወከፈ፡ ጻራይቀ፡ ለሊሁ፨</l>
                  <l n="5">ክርስቶስ፡ አምላክኪ፡ ዘፍድፉድ፡ ጽጋሁ፨</l>
               </lg>
            </div>
         </div>
      </body>

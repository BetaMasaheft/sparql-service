                  <additions>
              
                     <list>
                        <item xml:id="a1">
                           <locus target="#1r" facs="f9"/>
                           <desc type="MagicFormula">Excommunication formula/imprecation against worms</desc>
                           <q xml:lang="gez">አነ፡ አውገዝኩከ፡ አንተ፡ ሐሰካ፡ በ፬ ሙጻአ፡ ነፋሳት፡ በ፬ ፍጥረቱ፡ ለሰብእ፡ በ፬ ማዕዘኒሃ፡ ለምድር፡<gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                    አውገዝኩከ፡ አንተ፡ ሐሰካ፡ ሐሩዝ፡ ሐሩዝ፡ ሐሬይርን፡ ሐሬይርን፡ ሐሬይርን፡ ሐሬፑን፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
                
                        <item xml:id="a2">
                           <locus target="#2r" facs="f11"/>
                           <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT4912PrayerEucharist">Prayer for the Eucharist</title>
                           </desc>
                           <q xml:lang="gez">ሥጋ፡ ቅዱስ፡ ወደም፡ ክቡር፡ ዘእግዚእነ፡ ወአምላክነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘይትወሀብ፡ 
                    ለሥርየተ፡ ኀጢአት፡ ለእለ፡ ይነሥኡ፡ እምኔሁ፡ ዘበአማን፡ አሜን።</q>
                        </item>
                
                        <item xml:id="a3">
                           <locus target="#2v" facs="f12"/>
                           <desc type="Unclear">Two prayers</desc>
                           <q xml:lang="gez"/>
                        </item>
                
                        <item xml:id="a4">
                           <locus target="#3r" facs="f13"/>
                           <desc type="Unclear">A Prayer called
                              <title xml:lang="gez" ref="https://betamasaheft.eu/LIT3336Qeddase">ቅዳሴ፡ ሰንበት።</title>
                           </desc>
                           <q xml:lang="gez"/>
                        </item>
                
                        <item xml:id="a5">
                           <locus from="181r" to="182v" facs="f369"/>
                           <desc type="CalendaricNote">Computus for the epacts and Easter <foreign xml:lang="gez">ኀሳብ፡ ርቱዕ፡ እንተ፡ ኀበ፡ ይቀርብ።</foreign>
                           </desc>
                           <q xml:lang="gez"/>
                        </item>
                
                        <item xml:id="a6">
                           <locus from="182v" to="185r" facs="f372"/>
                           <desc type="CalendaricNote">Calendar of the feasts of the Saints. </desc>
                           <q xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                              ተዝከረ፡ ነቢያት፡ ወሐዋርያት፡ ወጳጳሳት፡ ወሰማዕት፡ ወጻድቃን፡ በዘ፡ ይትገበር፡ ተዝከሮሙ።</q>
                        </item>
                
                        <item xml:id="a7">
                           <locus from="185r" to="185v" facs="f377"/>
                           <desc type="CalendaricNote">Calendar of the days of fast</desc>
                           <q xml:lang="gez"/>
                        </item>
                
                        <item xml:id="a8">
                           <locus from="186r" to="187r" facs="f379"/>
                           <desc type="CalendaricNote">Computus of the epacts, followed by a chronological table of the kings of Abyssinia</desc>
                           <q xml:lang="gez"/>
                        </item>
                
                        <item xml:id="a9">
                           <locus target="#187r" facs="f381"/>
                           <desc type="Unclear">Note on the rewards of prayer</desc>
                           <q xml:lang="gez">በአኰቴተ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                              ስማዕ፡ እንግርከ፡ ዘወሀበ፡ እግዚአብሔር፡ ተሰፋ፡ ለውሉደ፡ አዳም።</q>
                        </item>
                
                        <item xml:id="a10">
                           <locus from="187v" to="188r" facs="f382"/>
                           <desc type="Unclear">A prayer</desc>
                           <q xml:lang="gez"/>
                        </item>
                     </list>

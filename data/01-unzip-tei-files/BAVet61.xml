               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v"/>
                     <title type="complete">Calendar of the feasts of the apostles</title>
                     
                     <note/>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሐፍነ፡ በዘ፡ ንዜከር፡ ተዝካሮሙ፡ ለብፁዓ<supplied reason="lost">ን፡</supplied> 
                        ሐዋርያት፡ አመ፡ ፩ለመስከረም፡ 
                           <sic>በትረ፡ ሎሜዎስ።</sic>
                         አመ፡ ፲፭ፍልሰተ፡ ስጋሁ፡ ለእስጢፋኖስ። 
                     </incipit>
                     <explicit xml:lang="gez">
                        አመ፡ ፲፡ ስምዖን፡ ወልደ፡ ቀለዮጳ። አመ፡ ፲፰ያዕቆብ፡ እኁሁ፡ ለእግዚእነ።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="2r" to="8"/>
                     <title type="complete">On the computation of the years</title>
                     
                     <note/>
                     <incipit xml:lang="gez">
                        በዘ፡ ታአምር፡ ሐሳበ፡ ኅገ፡ እግዚአ፡ ብሔር፡ ወእምዝ፡ ትቀድም፡ ለብዎ፡ በእንተ፡ ዘይትወለድ፡ አበቅቴ፡ ፲፩ለለ፡ ዓመቱ፡  
                     </incipit>
                     <explicit xml:lang="gez">
                        እምአዳም፡ እስከ፡ ኖኅ፡ ፬ቀመር፡ እምአይኅ፡ እስከ፡ ክርስቶስ፡ ፮፡ ቀመር፡ ወእምክርስቶስ፡ ፫፡ ቀመር፡ እስከ፡ ገብረ፡ መስቀል፡ 
                           <sic>ዘንተ፡</sic>
                         ዓመታት፡ ዘወሀበ፡ 
                        እግዚአ፡ ብሔር፡ በዘ፡ የሐዩ፡ ሰብእ፡ ለዓለመ፡ ዓለም፡ አሜን፡
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus target="#8"/>
                     <title type="complete">On the observance of the Sabbath and the Sunday</title>
                     <incipit xml:lang="gez">
                        ወካ<add place="inline">
                           <supplied reason="omitted">ዕ</supplied>
                        </add>በ፡ አክብሩ፡ ሰንበተ፡ ወእሑደ፡ ሰንበት፡ ዘኢያከብር፡ ሰንበተ፡ ወእሑደ፡ ሰንበት፡ ሞተ፡ ለይሙት፡ 
                        ወይደቅ፡ ወይትኀጐል፡ ይቤል፡ ሐዋርያት፡ በሴኖዶስ፡
                     </incipit>
                     <note>The <ref type="work" corresp="https://betamasaheft.eu/LIT2317Senodo">Senodos</ref> is mentioned in the incipit of the text.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="9" to="29v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4290Dersan">Homily by Isaac on the ascetic life</title>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="30" to="31v"/>
                     <title type="complete">Prayer before the Lord's Prayer</title>
                     <note/>
                     <incipit xml:lang="gez">
                        ጸሎት፡ ቅድመ፡ አቡነ፡ እግዚኦ፡ እግዚእነ፡ ጥቀ፡ ተሰብሐ፡ ስምከ፡ በኵሉ፡ ምድር፡ እስመ፡ ተለዐለ፡ ዕበየ፡ ስብሐቲከ፡ መልዕልተ፡ ሰማያት፡
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus from="31v" to="32v"/>
                     <title type="complete">Untitled prayer</title>
                     <note/>
                     <incipit xml:lang="gez">
                        
                           <sic>በሰመ፡ አብ፡</sic>
                         
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                        ኦእግዚኦ፡ እግዚእየ፡ ወአምላክየ፡ ኢየሱስ፡ ክርስቶ<supplied reason="omitted">ስ</supplied>፡ ክሥት፡ እግዚኦ፡ እዝንየ፡ ወአዕይንተ፡ ልብየ፡ ከመ፡ እስማዕ፡ ቃላቲከ፡ 
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i7">
                     <locus from="32v" to="33v"/>
                     <title type="complete">Untitled prayer</title>
                     <note/>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወላዕሌሁ፡ ተወከልኩ፡ ወኪያሁ፡ ተሰፈውኩ፡ ወቦቱ፡ አመንኩ፡
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i8">
                     <locus from="33v" to="34"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4539Praise">Untitled praises to Our Lord Jesus Christ</title>
                     <note/>
                     <incipit xml:lang="gez">
                        <choice>
                           <sic>ያእኵትዎ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ያአኵትዎ፡</corr></choice>
                         መንፈሳውያን፡ በአሐዱ፡ 
                        
                           <sic>አፈ፡</sic>
                         ወልሳን፡ <supplied reason="omitted">ለ</supplied>ንጉሥኪ፡ ጽዮን፡ ይጸውሩ፡ መንበሮ፡ ኪሩቤላውያን።
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i9">
                     <locus from="34v" to="38v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4540Bakimos">Anathema by ʾabbā Bakimos</title>
                     <incipit xml:lang="gez">
                        <add place="inline">
                           <supplied reason="omitted">
                              
                                 <sic>በሰመ፡</sic>
                              
                           </supplied>
                        </add> 
                        
                           <sic>ዘአበ፡</sic>
                         
                        በኪሞስ፡ 
                           <sic>ፈለሲ፡</sic>
                         
                        
                           <sic>ወእምዚ፡</sic>
                         ሐለየ፡ በልቡ፡ ወይቤ፡ አሌ፡ ሊተ፡ ምንት፡ 
                           <sic>እገበር፡</sic>
                         
                        ሶበ፡ 
                           <sic>ይኄውጽኒ፡</sic>
                         
                        
                           <sic>እግዚእ፡</sic>
                         
                        
                           <sic>በሔር፡</sic>
                         
                        
                           <sic>ወይፈኑ፡</sic>
                         መልአኮ፡ ከመ፡ ያውፅአኒ፡ 
                           <sic>እማ፡</sic>
                         ዝንቱ፡ ዓለም፡ እንዘ፡ 
                           <sic>ኢተደለውኵ፡</sic>
                         
                        ወኢያጥረ<supplied reason="omitted">ይ</supplied>ኩ፡ መድኀኒትየ፡ ምንተ፡ እገብር፡ ሶበ፡ የአውዱኒ፡ 
                           <sic>መኳንንት፡</sic>
                         ጽልመት፡ አሌ፡ ሊተ፡ መኑ፡ 
                        
                           <sic>ይርድአኒ፡</sic>
                         አኤ፡ ሊተ፡ ሶበ፡ እሬኢ፡ ኵሎ፡ 
                           <sic>ሰብእ፡</sic>
                         ፍሡሓነ፡ ወአነ፡ 
                           <sic>በኀቲትየ፡</sic>
                         
                        
                           <sic>ትኵዝ፡</sic>
                        
                     </incipit>
                     <explicit xml:lang="gez">
                        ወይቤ፡ በልቡ፡ እ<supplied reason="omitted">ን</supplied>ዘ፡ አአምር፡ ከመ፡ ይተክበኒ፡ 
                           <sic>ዘንቱ፡</sic>
                         ኵሉ፡ ለምንት፡ እትሀከይ፡ ወይቤ፡
                     </explicit>
                     <note>The text is incomplete, the end is missing. The author of the text <persName ref="https://betamasaheft.eu/PRS11472Bakimos">Bakimos</persName> might be the same as <persName ref="https://betamasaheft.eu/PRS11501Bakimos">Bakimos</persName>.</note>
                  </msItem>
               </msContents>
          

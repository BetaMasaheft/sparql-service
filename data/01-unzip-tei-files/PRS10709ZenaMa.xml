         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዜና፡ ማርያም፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Zenā Māryām</t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               <t:birth> She was born at a place called <t:placeName ref="https://betamasaheft.eu/LOC4298Libo">Libo</t:placeName>.
               </t:birth>
               <t:floruit notBefore="1300" notAfter="1400">A female saint of the 14th century and venerated as  the patron saint of the region of <t:placeName ref="https://betamasaheft.eu/LOC2951Enfraz">ʾƎnfrāz</t:placeName>.
                  She spent her ascetic life in the cave of <t:placeName ref="https://betamasaheft.eu/LOC6247WasaEn">Waššā ʾƎndrǝyās</t:placeName> for <t:date dur="P25Y">25 years</t:date>.
                  Then, she went to the monastery of <t:placeName ref="https://betamasaheft.eu/LOC3702Gwegwe">Gʷǝgʷǝben</t:placeName> in the lake <t:placeName ref="https://betamasaheft.eu/LOC5888Tana">Ṭānā</t:placeName>.
            </t:floruit>
            </t:person>  
            

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1023IHA">احدى وستون عقيدة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>والفطانة واجب للرسل \ والبلادة مستحيل عليهم \ وجائزهم حال الناس \ كالاكل واللباس  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ربنا احسن ختامنا \ واستجب دعانا \ صل وسلم يا رب القديم \ على النور العظيم \ وعلى ءاله وصحبه ورزقنا بقربه \ احدى وستون عقيدة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="4v">1r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3257IHA">باكورة الوليد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين الصلاة والسلام على سيدنا محمد
[...]
وبعد فاعلم انه يجب على كل احد ان يعرف ان له خالق رازقا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>وجوب لصلاة عليه اذا مات وصلى الله على سيدنا محمد وعلى أله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="4v" to="6r">4v-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1523IHA">Text about the merits of the Sura al-Fātiḥa</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين الحمد لله ان الكمال كله لله المراد بالكمال العشرون الواجبات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>ولا حول ولا قوة الا بالله علي العظيم وصلى الله على سيدنا محمد وعلى أله وصحبه وسلم اجمعين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="6r" to="10v">6r-10v</locus>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <title ref="https://betamasaheft.eu/LIT1525IHA">Poem in ʻaǧamī Oromo (5)</title>
                     <incipit xml:lang="om-Arab">
                        <locus target="#6r">-6r</locus>فارون كن غتان كن الكوفسن قبنى
ومتن نوتل كنهمنى ڟمنى
استوبا سى ادو لطنقمنى
</incipit>
                     <explicit xml:lang="om-Arab">
                        <locus target="#10v">-10v</locus>اكنن جڟمو اكة رغتنى</explicit>
                     <note/>
                     <note/>
                  </msItem>

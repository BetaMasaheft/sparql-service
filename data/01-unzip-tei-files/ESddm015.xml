                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, very irregular</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>First half of the 20th century</date>
                        <list type="abbreviations">
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of sections of Text I; titles
                           of books to be read; directives to the ministers; elements of the
                           punctuation signs; elements of Ethiopic numerals.
 On fols. 7r and
                           11r, few lines are rubricated alternating with black lines.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">It cannot be excluded that more than
                        one hand participated in
                        writing.</handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#25r">f. 25r</locus>
                           <desc type="GuestText">: Unidentified prayer.</desc>
                           <q xml:lang="gez"/>
                           
                           <note> Crudely written, partly unintelligible. </note>
                        </item>
                        <item xml:id="e1"><desc>- Doodles and pen trials: <locus target="#22r">22r</locus>, 23v, 25r, 25v, 26r, 27r, 28r, 28v.</desc>
                        </item> 
                        <item xml:id="e2"><desc>- Smaller script is
                           used for the bottom line on <locus from="1r" to="6v">1r-6v</locus>;</desc></item>
                        <item xml:id="e3"><desc>- The name of the owner/donor Walatta Śǝllāse (hardly readable)
                              is inserted in the supplication formula on <locus target="#11r">11r</locus>.</desc>
                        </item>
                     </list>
                  </additions>

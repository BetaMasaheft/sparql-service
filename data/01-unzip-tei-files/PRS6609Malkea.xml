      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መልክአ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Malkǝʾa Krǝstos</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabetohun</t:roleName>
               </t:persName>
                 <t:occupation type="military">officer</t:occupation>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                   
               <t:floruit> He was a prominent 17th century nobleman and high ranking officer 
                  of 
                  <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName> Susǝnyos</t:persName>. 
                  He was the husband of 
                  <t:persName ref="https://betamasaheft.eu/PRS9848Walatta">
                     <t:roleName type="title">ʾƎmmat</t:roleName> Walatta Ṗeṭros</t:persName> from whom he had three children. 
                  He was very loyal to  
                  <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName> Susǝnyos</t:persName> despite the king's  inclination to Catholicism. He was
                  involved in many anti-Catholic rebels assisting the king  but
                  in the final years of 
                  <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName> Susǝnyos</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/PRS6609Malkea">Malkǝʾa Krǝstos</t:persName> was in tension with the king and in <t:date>1632 </t:date> he avoided campaigning against the rebels. 
                  Finally, he was arrested, accused of treason and sentenced to death which was substituted by exile.</t:floruit>
               <t:death when="1633">He died in the second year of 
                  <t:persName ref="https://betamasaheft.eu/PRS4015Fasilada"> 
                     <t:roleName type="title">ʾaṣe</t:roleName> Fāsiladas</t:persName>.</t:death>
               </t:person>
               
         </t:listPerson>

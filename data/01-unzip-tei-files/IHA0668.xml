                        <item xml:id="a0_1957">
                           <locus target="#15r">-15r</locus>
                           <q xml:lang="ar">بيد لفقير لحقير لراجى محمد نور رحمة [رجه؟] القدير يا اخوان لا تنسا لدعاء</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1955">
                           <locus target="#9r">-9r</locus>
                           <q xml:lang="ar">بيد كتبها محمد نور وختمها يوم لاربعا فى وقت لاصحى يا اخوان لا تنسان لدعاء</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1954">
                           <locus target="#4r">-4r</locus>
                           <q xml:lang="ar">تمت بيد لحقير لفقير عمت \ بيد كتبها محمد نور وختمها يوم الاثنين فى وقت لاضحا فى شهر ربيع لاول بعد ثلاثة مضى ايامه يا اخوان لا تنسانى لدعاء</q>
                           <desc>Colophon</desc>
                           <note>No year is given.</note>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">

                        <msContents>
                            <summary/>

                        <msItem xml:id="p1_i1">
                            <locus from="3ra" to="4rb">Fols 3ra–4rb</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3033RepCh313">Hymn to Jesus Christ</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                           <hi rend="rubric">ናሁ፡ ስእንኩ፡ ለዐይንየ፡ መሊሖታ። ሶበ፡ ታስሕተኒ፡ ሊተ፡ ወታጌግየኒ፡</hi>
                            በነጽሮታ። <hi rend="rubric">ኢየሱስ፡ ክርስቶስ፡</hi> ለቤተ፡ ክርስቲያን፡ ርእሰ፡ ማእዘንታ።</incipit>
                        </msItem>
                            
                            <msItem xml:id="p1_i2">
                                <locus from="5ra" to="6rb">Fols 5ra–6rb</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4719Eweddesa">ʾƎweddǝsā la-wǝddǝst</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                           <hi rend="rubric">ውዳሴ፡ ዘእግዝእትነ፡ ማርያም፡ እዌድሳ፡ ለውድስት፡ ወእ</hi>ባርክካ፡
                                    ለቡርክት፡ ወእሴብሐ፡ ለስብሕት፡ እንዘ፡ እብል። ቡርክት፡ አንቲ፡ <hi rend="rubric">ማርያም፡</hi> ወቡሩክ፡ ፍሬ፡ 
                                    ከርሥኪ፡ ቡርክት፡ አንቲ፡ <hi rend="rubric">ማርያም፡</hi> ወቡሩካን፡ ኵሎሙ፡ እለ፡ ይባርክዎ፡ ለወልድኪ።</incipit>
                            </msItem>
                    </msContents>


               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="154r">2v-154r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s38IHA">قران, First half (ǧuz’ 1-15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الْحمد للّه رب الْعالمين الرحمن الرحيم ملك يوم الدينِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#154r">-154r</locus>قُلْ إِنَّمَا أَنَا بَشَرٌ مِّثْلُكُمْ يُوحَىٰ إِلَيَّ أَنَّمَا إِلَـٰهُكُمْ إِلَـٰهٌ وَاحِدٌ ۖ فَمَن كَانَ يَرْجُو لِقَاءَ رَبِّهِ فَلْيَعْمَلْ عَمَلًا صَالِحًا وَلَا يُشْرِكْ بِعِبَادَةِ رَبِّهِ أَحَدًا</explicit>
                     <note>Qur’an 1:1–18:110. The words aren't divided.</note>
                     <note/>
                  </msItem>
               </msContents>

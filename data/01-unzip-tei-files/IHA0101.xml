                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1_164">
                           <locus target="#Throughout all the text">-Throughout all the text</locus>
                           <q xml:lang="ar">الجزؤ, ثمن</q>
                           <desc>Drawings / Decorations</desc>
                           <note>Marks for the aǧzā' and the eighths. The word is inside a double circle that seems to symbolize the amulet of the protector eye </note>
                           <note/>
                        </item>
                        <item xml:id="a3_164">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">ط</q>
                           <desc>Marginalia</desc>
                           <note>Recitation marks</note>
                           <note/>
                        </item>
                        <item xml:id="a2_164">
                           <locus target="#31v">-31v</locus>
                           <q xml:lang="ar">Drawing of the protector eye</q>
                           <note>
                              <term key="Magic" ana="#Magic"/>
                           </note>
                        </item>
                        <item xml:id="a0_164">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Dots with tail to mark the end of the verses. Red titles for the suras. </q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#154r">-154r</locus>
                           <desc>Ownership</desc>
                           <q>هذا الكتاب ملك عرب ءبن شيخ يونس ءبن جبريل ءبن عبد الرحمن</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#2r">-2r</locus>
                           <desc>Ownership</desc>
                           <q>هذا الكتا ملك عرب ءبن شيخ يونس ءبن جبريل ءبن عبد الرحمن وبلده طسا وقريه شاق</q>
                           <note/>
                        </item>
                        <item xml:id="a3">
                           <locus target="#154r">-154r</locus>
                           <desc>Scribal verses</desc>
                           <q>ما كتبت كتابا خطه لم يستحسنا بيد الفقير موته متيقيا</q>
                           <note/>
                        </item>
                        <item xml:id="a4">
                           <locus target="#1v-2r">-1v-2r</locus>
                           <desc>Magic related material</desc>
                           <q>[...]فَانّهِ محمّدُ رَبّهم</q>
                           <note>Blessings.The text appears inside the protector eye so that it seems to be an amulet.</note>
                        </item>
                     </t:list>

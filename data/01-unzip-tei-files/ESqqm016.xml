               <msContents>
                  <summary>I) Dāwit “Psalter” (fols. 1r-54v), fragment
 I-1) Mazmura Dāwit
                     “Psalms of David” (fols. 1r-54r), incomplete
 I-2) Maḥālǝya nabiyāt “The
                     Canticles of the Prophets” (fols. 54r-54v), incomplete.</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>- The following Pss. are numbered incorrectly: 150 (numbered 140+50 =
                        ፻፵፶), 151 (numbered 150).</note>
                  </msItem>
               </msContents>

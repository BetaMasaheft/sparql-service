      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0526</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ አብ፡ ህላዌ፡ ዓለማት፡ ዘይጸውር፨</l>
                  <l n="2">እንዘ፡ መሠረት፡ ውእቱ፡ እስመ፡ ለሊሁ፡ ጠፈር፨</l>
                  <l n="3">አምጣነ፡ አኀዝኩ፡ እንግር፡ ጽድቀ፡ ማቴዎስ፡ ክቡር፨</l>
                  <l n="4">ከመ፡ አሳፍ፡ በመሰንቆ፡ ወከመ፡ ዳዊት፡ በመዝሙር፨</l>
                  <l n="5">አጽምዕ፡ ሰማይ፡ ወስምዒ፡ ምድር፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ጽሑድ፨</l>
                  <l n="2">በመንፈሰ፡ ቅብእ፡ ጥሉል፡ ጥንተ፡ ሕይወቱ፡ ለወልድ፨</l>
                  <l n="3">ማቴዎስ፡ ዮሐንስ፡ ወልደ፡ ነጐድጓድ፨</l>
                  <l n="4">ያስተበፅዑከ፡ ኵሉ፡ ትውልድ፨</l>
                  <l n="5">ወእነግር፡ አነ፡ ጽድቀከ፡ ለባዕድ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ደብረ፡ ሐዋርያት፡ እንታክቲ፨</l>
                  <l n="2">ከመ፡ ዝኅረ፡ ሙሴ፡ ነቢይ፡ ዘትትከበት፡ ይእቲ፨</l>
                  <l n="3">ትንሣኤ፡ መለኮት፡ ማቴዎስ፡ ሕይወተ፡ ኵሉ፡ መዋቲ፨</l>
                  <l n="4">ያድኅነኒ፡ ምክረ፡ ዚአከ፡ እምኂጠተ፡ አርሴ፡ ምስሓቲ፨</l>
                  <l n="5">ወይዕቀበኒ፡ ጥበብከ፡ እመሥገርት፡ ዛቲ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ንስረ፡ ገነተ፡ ጽድቅ፡ ቴዎድሮስ፡ ዘውርዙትከ፡ ተሐደሰ፨</l>
                  <l n="2">ወመልአከ፡ ሰማይ፡ ማቴዎስ፡ ዘረሰይከ፡ መንፈሰ፨</l>
                  <l n="3">ለዐሪገ፡ ገነት፡ ሀቡኒ፡ አክናፈ፡ ምግባራት፡ ሠላሰ፨</l>
                  <l n="4">እምነፍሳቲሆሙ፡ ሄኖክ፡ ኢይሁበኒ፡ ሐዋርያ፡ ዕርገት፡ ነፍሰ፨</l>
                  <l n="5">ወይከልአኒ፡ ኤልያስ፡ ፈውሰ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">መልአ፡ ምድረ፡ ወሰማያተ፡ ከደነ፨</l>
                  <l n="2">ነገረ፡ ስብሐቲከ፡ አባ፡ ከመ፡ ኢይፈጽም፡ አነ፨</l>
                  <l n="3">ማቴዎስ፡ ወልዱ፡ ለማዕቀበ፡ አልፋ፡ አቡነ፨</l>
                  <l n="4">ባሕቱ፡ ተወከፍ፡ አምኃየ፡ መጠነ፡ መልአ፡ ወሰነ፨</l>
                  <l n="5">ከመ፡ ተወክፈ፡ አምላከ፡ ጽድቅ፡ ዘአቤል፡ ቍርባነ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ናሁ፡ ድርሳን፡ ለመልክእከ፡ መጠነ፡ ፍቅዱ፨</l>
                  <l n="2">እንዘ፡ እመልእ፡ ሠላሳ፡ በበ፡ አሐዱ፡ አሐዱ፨</l>
                  <l n="3">ተልሚደ፡ አብሳዲ፡ ማቴዎስ፡ ወለቴዎድሮስ፡ ወልዱ፨</l>
                  <l n="4">አድኅነኒ፡ እቁም፡ እግዚኦ፡ ለምሕረትከ፡ በዐውዱ፨</l>
                  <l n="5">አመ፡ አድለቅለቁ፡ ሰማያት፡ ወአድባር፡ ርዕዱ፨</l>
               </lg>
            </div>
         </div>
      </body>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="1">
                  <l n="1">ሰላም፡ ለተፈጥሮትክሙ፡ እምነፋስ፡ ወነድ፨</l>
                  <l n="2">ምስለ፡ ሰማያት፡ ወምድር፡ በዕለተ፡ እሑድ፨</l>
                  <l n="3">ዘታጸንዑ፡ እንስሳ፡ መንበረ፡ ሥላሴ፡ በእድ፨</l>
                  <l n="4">ክፍሉኒ፡ ለገብርክሙ፡ ለዘለክሙ፡ ጸማድ፨</l>
                  <l n="5">ከመ፡ እቁም፡ ምስሌክሙ፡ ድርገተ፡ በዐውድ፨</l>
               </t:lg>
            </div>
            <div type="textpart" xml:id="malke" corresp="https://betamasaheft.eu/LIT2905RepCh186">
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘተለዐለ፡ ዕበዩ፨</l>
                  <l n="2">እምዝክረ፡ ከዋክብት፡ አርባዕ፡ መዋዕለ፡ ዓመታት፡ ዘይሌልዩ፨</l>
                  <l n="3">እንስሳ፡ አርባዕ፡ ለእግዚአብሔር፡ ጸወርተ፡ ሰማዩ፨</l>
                  <l n="4">ለዝክረ፡ ስምክሙ፡ ቦቱ፡ ከመ፡ ይሰንቀው፡ ማሕልዩ፨</l>
                  <l n="5">ነገረ፡ ጥበብ፡ በአፉየ፡ ደዩ፨</l>
               </t:lg>
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስክሙ፡ አርአያ፡ በረድ፡ ንጹሕ፨</l>
                  <l n="2">ወዘሕብረ፡ ያክንት፡ ቀይሕ፨</l>
                  <l n="3">ሰረገላቲሁ፡ ኪሩቤል፡ ለአምላክ፡ ስቡሕ፨</l>
                  <l n="4">ጸግዉኒ፡ አጋእዝትየ፡ እምጸጋክሙ፡ ብዙኅ፨</l>
                  <l n="5">ናህየ፡ በሰርክ፡ ወሣህለ፡ በነግህ፨</l>
               </t:lg>
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="45">
                  <l n="1">ሰላም፡ ለቆምክሙ፡ ዘጥቀ፡ ሠናይ፨</l>
                  <l n="2">እምነ፡ ዓምደ፡ ወርቅ፡ ጽሩይ፨</l>
                  <l n="3">እንስሳ፡ አርባዕ፡ ጸወርተ፡ ሰማይ፨</l>
                  <l n="4">በከመ፡ ጽሑፍ፡ እንበለ፡ ይዕርብ፡ ፀሐይ፨</l>
                  <l n="5">ዐስበ፡ አስበ፡ ማሕሌትየ፡ አኃሥሥ፡ ነዳይ፨</l>
               </t:lg>
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="46">
                  <l n="1">ሰላም፡ እብል፡ ለመልክእክሙ፡ መክብበ፨</l>
                  <l n="2">እንተ፡ ይሠረጎ፡ ላህበ፨</l>
                  <l n="3">እንስሳ፡ አርባዕ፡ ዘትሰመዩ፡ ኪሩበ፨</l>
                  <l n="4">ማሕሌትየ፡ በቅድሜክሙ፡ እመ፡ ሞገሰ፡ ረከበ፨</l>
                  <l n="5">ኑኀ፡ መዋዕል፡ ጸግዉኒ፡ ዓስበ፨</l>
               </t:lg>
               <t:lg xmlns:t="http://www.tei-c.org/ns/1.0" type="stanza" n="47">
                  <l n="1">ኦመናብርተ፡ አምላክ፡ አርባዕቱ፡ እንስሳ፨</l>
                  <l n="2">ገጸ፡ ላህም፡ ወንስር፡ ገጸ፡ ሰብእ፡ ወገጸ፡ አንበሳ፨</l>
                  <l n="3">ዲበ፡ ፍጥረትክሙ፡ አልቦ፡ ዘለሞት፡ አበሳ፨</l>
                  <l n="4">ረስዩ፡ ፍሬ፡ ዐስብየ፡ ህየንተ፡ አሐዱ፡ ሠላሳ፨</l>
                  <l n="5">ወተውሳኩ፡ ምስለ፡ ምእት፡ ወስሳ፨</l>
               </t:lg>
            </div>
         </div>
         
         
         

                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="51v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2358Sirach">Book of Sirach</title>
                        </msItem>
                            
                        <msItem xml:id="ms_i2">
                            <locus from="52r" to="83v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1376Apocal">Apocalypse of Ezra</title>
                            <note>Labelled Ezra 1 in Ethiopic; generally referred to as 4 Ezra.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="84v" to="106v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1377Bookof">Book of Ezra</title>
                            <note>Labelled Ezra 2 in Ethiopic; generally referred to as 3 Ezra or Greek Ezra.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="106v" to="137r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1374Bookof">Book of Ezra and Nehemiah</title>
                            <note>It comprises the canonical books of Ezra (1 Ezra) and Nehemias (2 Ezra).</note>
                            <explicit type="subscriptio" xml:lang="gez">
                            <locus target="#137r"/>
                            ተፈጸመ፡ ዘዕዝራ፡ ፫ ወተጽሕፈት፡ ዛቲ፡ መጽሐፍ፡ ዕዝራ። ዘአጽሐፈኒ፡ <gap reason="omitted" extent="unknown" resp="PRS3562Dillmann"/> 
                                ወጸሓፊሁ፡ መልከ፡ ጼዴቅ፡ ከመ፡ ይኩኖ፡ ለተዝካሩ፡ ወለተዝካረ፡ ደቂቁ፡ ወይዕቀቦ፡ እግዚአብሔር፡ እምኵሉ፡ እኩይ፡ ወያኑኅ፡ መዋዕሊሁ፡ በዲበ፡ ምድር፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፡ 
                                ለይኩን፡ ለኩን።
                                <note> 
                           <q xml:lang="en">Ezra 3 is finished, and this book of Ezra has been written. The one who commissioned me is ..., and its scribe is Melchisedek. 
                                Shall his memory and the memory of his sons be commemorated, and may God protect him from any evil and make his days long on the Earth, 
                                forever and ever, amen, amen. So be it, so be it.</q> 
                           The note mentions <persName role="scribe" ref="https://betamasaheft.eu/PRS10772MalkaS">Melchisedek</persName> as the 
                                scribe. The Book of Ezra and Nehemiah is here labelled Ezra 3, according to the Ethiopian numbering.
                            The note is reported in: 
                                <bibl corresp="http://zotero.org/groups/358366/items/F7MQBIM8"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Pereira1919Ezra"/><title level="m">Le troisième livre de 'Ezra (Esdras et Néhémie canoniques). Version éthiopienne</title><title level="s">Patrologia Orientalis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Francisco Maria Esteves</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Pereira</t:surname></author><pubPlace>Paris</pubPlace><date>1919</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Patrologia Orientalis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">13, 5</t:biblScope></series><biblScope unit="volume">13, 5</biblScope><citedRange unit="page">648</citedRange></bibl>.
                                </note>                            
                            </explicit>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="137v" to="142r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2353SibylW">Ṭǝbaba Sābelā</title>
                            <note/>
                            <explicit type="subscriptio">
                                <locus target="#142"/>
                                <note> 
                           <q xml:lang="en">"[The book of] Ezra [and] Sibyl is finished. Who allowed me to finish this book with my hands, the Father, the Son and the 
                                    Holy Spirit, shall be glorified now and ever, forever and ever. Amen. Who wrote it is me, Tābor, the sinner; remind of me.</q>
                                    The note mentions <persName role="scribe" ref="https://betamasaheft.eu/PRS10768Tabor">Thabor</persName> as the scribe.
                                </note>
                            </explicit>
                        </msItem>
                    </msContents>
                    

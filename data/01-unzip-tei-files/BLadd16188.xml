                            <handNote xml:id="h1" script="Ethiopic">
                                <seg type="script">Written in a fine handwriting.</seg>
                                <seg type="ink">Black, red.</seg>
                                <persName role="scribe" ref="https://betamasaheft.eu/PRS10768Tabor">Tābor</persName>
                                <seg type="rubrication">Titles and incipits are rubricated.</seg>
                            </handNote>

                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="197r">1v-197r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s38IHA">قران, First half (ǧuz’ 1-15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة فاتحة وهي سبع ءايات \ بسم الله الرحمن الرحيم الحمد لله رب العلمين الرحمن الرحيم ملك يوم الدين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#197r">-197r</locus>وقل الحمد لله الذي لم يتخذ ولدا ولم يكن له شريك في الملك ولم يكن له ولي من الذل وكبره تكبيرا</explicit>
                     <note>Contains sūras 1-17. Vocalized. Words divided into two lines.</note>
                     <note/>
                  </msItem>
               </msContents>

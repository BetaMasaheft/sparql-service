         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ክንፈ፡ ሚካኤል፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Kǝnfa Mikāʾǝl</t:persName>
               <t:persName>
                  <t:roleName type="title">ṣaḥafe tǝʾǝzāz</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="literary"> chronicler</t:occupation>
               <t:residence ref="LOC3577Gondar">Gondar</t:residence>
              
               <t:floruit notBefore="1600" notAfter="1750">He was <t:persName ref="https://betamasaheft.eu/PRS5941KenfaMi">
                     <t:roleName type="title">
                  ṣaḥafe tǝʾǝzāz</t:roleName>
                  </t:persName>
                   during the time of 
                 
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa"> 
                     <t:roleName type="title">ʾaṣe </t:roleName> Bakāffā</t:persName>. 
                  He continued to write the chronicle of 
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa">
                     <t:roleName type="title">ʾaṣe </t:roleName> Bakāffā</t:persName>
                  after the death of 
                  <t:persName ref="https://betamasaheft.eu/PRS8869Sinoda">
                     <t:roleName type="title">ʾazzāž </t:roleName> 
                     Sinodā</t:persName>. He wrote the
                  last 14 chapters of the chronicle of 
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa"> 
                     <t:roleName type="title">ʾaṣe </t:roleName> Bakāffā</t:persName>, 
                  recording events from mid-August 1726 to January 1727.</t:floruit>
              
            </t:person>  
            
         </t:listPerson>

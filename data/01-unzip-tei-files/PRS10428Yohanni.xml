      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዮሐኒ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yoḥanni</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">abbot</t:occupation>
               
               <t:floruit>He was a monk of medieval time born in <t:placeName ref="https://betamasaheft.eu/LOC5882Tamben">Tamben</t:placeName> where he built 42 churches.
                  His life is known from his <t:ref type="work" corresp="https://betamasaheft.eu/LIT1521GadlaY">Gadla Yoḥanni za-Dabra ʿAśā</t:ref>. He was born from a mother 
                  who was a wife of a certain <t:persName ref="https://betamasaheft.eu/PRS10428Yohanni"> 
                     <t:roleName type="title">šum
                  </t:roleName>  
                  </t:persName>of <t:placeName ref="https://betamasaheft.eu/LOC5882Tamben">Tamben</t:placeName>. Additional information of him is also evoked in a number of 
                  hymnological compositions.</t:floruit>
      
            </t:person>  
            
         </t:listPerson>

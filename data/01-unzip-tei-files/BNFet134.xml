                      ዝንቱ፡ መጽሐፈ፡ ዕረፍቱ፡ ለአቡነ፡ ያዕቆብ፡ ዘተሠምየ፡ እስራኤል። ወፍልሰቱ፡ እምሥጋሁ፡ አመ፡
                         ፳ወ፰፡ ለወርኀ፡ ነሐሲ፡ በሰላመ፡ እግዚኣብሔር፡ አብ፡ አሜን።</title>
                      <textLang mainLang="gez"/>
                      <incipit xml:lang="gez">ወሶበ፡ ቀርበ፡ መዋዕሊሁ፡ ለአቡነ፡ ያዕቆብ፡ አበ፡ አበው፡ ወልደ፡ ይስሐቅ፡ ወልደ፡
                      አብርሃም፡ ወፍልሰቱ፡ እምሥጋሁ፡ ወውእቱ፡ መእመን፡ ወብዙኅ፡ መዋዕሊሁ፡ ወኮነ፡ አረጋዌ፡ ወረስአ።
                      ወፈነወ፡ ኀቤሁ፡ እግዚኣብሔር፡ ሚካኤልሃ፡</incipit>
                      <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/PRMCKQVT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Heide2000Testamente"/><title level="m">Die Testamente Isaaks und Jakobs. Edition und Übersetzung der arabischen und äthiopischen Versionen</title><title level="s">Aethiopistische Forschungen</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Martin</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Heide</t:surname></author><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>2000</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Aethiopistische Forschungen</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">58</t:biblScope></series><biblScope unit="volume">58</biblScope><citedRange unit="page">208–219</citedRange></bibl>

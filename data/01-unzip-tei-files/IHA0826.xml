               <msContents>
                  <summary>Folios 15v-17r are blank</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="15r">1v-15r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s28IHA">قران, Twenty first ǧuz’ (21/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>لا تجادلوا اهل الكتاب الا بالتى هي احسن الا الذين ظلموا منهم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus>يا نسا النبي من يات منكم بفاحشة مبينة يضعف لها العذاب ضعفين وكان ذلك على الله يسيرا</explicit>
                     <note>29:46-33:30. Triple dots as verse markers. The words ǧuz' (fol. 1v) and ḥizb (fol. 9r) in the margin in red.</note>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>
                        <extent>
                           <measure unit="folio">17</measure>
                                        Pre: <measure unit="folio">0</measure>
                                        Post: <measure unit="folio">0</measure>
                        </extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA0826#ms_i0"/>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d6">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>Geometric pattern and multiple frames in re, yellow and blue.</q>
                        <note/>
                     </decoNote>
                     <decoNote xml:id="d5">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>سورة الفاتحة مكية سبع ايات \ سور البقرة [...]  ايات \ لا يمسه الا المطهرون تنزيل رب العلمين</q>
                        <note>Decorative frames in red, green and yellow. Names of the first and second sūra in the top panels. The last text line is in the lower panel on fol. 2r. The lower panel on fol. 1v is torn off.</note>
                     </decoNote>
                     <decoNote xml:id="d0">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>لا يمسه الا المطهرون \ تنزيل من رب العلمين</q>
                        <note>Calligraphic rendition of the text. Multiple frames with decorative elements in red and blue.</note>
                     </decoNote>
                     <decoNote xml:id="d4">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>Double circles as ǧuz' markers. Ḥizb and ṯumn markers in red.</q>
                        <note/>
                     </decoNote>
                     <decoNote xml:id="d3">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>Verse markers (three circles), taǧwīd and titles of the sūras in red.</q>
                        <note/>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_2912">
                           <locus target="#15r">-15r</locus>
                           <q xml:lang="ar">صدق الله العظيم وىلع رسله [كذا] النبي الكريم والحمد لله رب العالمىن امين</q>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#Throughout">-Throughout</locus>
                           <desc>Marginalia</desc>
                           <q>قرا نافع ان ترك خير اتام</q>
                           <note>Variant readings (qirā'āt). Example in 3v (red ink)</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#Throughout">-Throughout</locus>
                           <desc>Fawā'id / Masā'il</desc>
                           <q>فائدة الذي رسم بغير الالف من فعل المقاتلة ثمانية اربعة هنا على التوالى وواحد فى ال عمران وهو وقاتلو وواحد فى النساء وهو فلقاتلوكم وواحد فى الحج وهو اذن للذين يقاتلون وواحد فى القتال وهو والذين قاتلو فى سبيل الله</q>
                           <note>Example in 4r (brown/golden ink)</note>
                        </item>
                     </t:list>
                  </additions>

      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0500</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">መንፈሰ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘአስተናገረ፡ ነቢያተ፨</l>
                  <l n="2">ለሐዋርያትኒ፡ ዘልሳነ፡ ኵሉ፡ ከሠተ፨</l>
                  <l n="3">ተከሥተ፡ ብርሃን፡ አቡየ፡ እማሕፀነ፡ እምየ፡ አንተ፨</l>
                  <l n="4">ለወልድከ፡ ይእዜ፡ ይክሥት፡ ሊተ፨</l>
                  <l n="5">ሰላመ፡ ዚአከ፡ እትናበብ፡ ንስቲተ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">እዌጥን፡ ዝክረ፡ ውዳሴከ፡ አቡየ፡ ተከሥተ፡ ብርሃን፨</l>
                  <l n="2">በዓለ፡ ዛቲ፡ መካን፨</l>
                  <l n="3">ወአበ፡ ነፍሶሙ፡ አንተ፡ ለአበው፡ ጻድቃን፨</l>
                  <l n="4">ያስተበፅዑከ፡ በርቱዕ፡ ልሳን፨</l>
                  <l n="5">ዘርእየ፡ ዐይን፡ ወዘሰምዐ፡ ዕዝን፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ፈጣሪ፡ ልዑል፨</l>
                  <l n="2">ዘሆህያቲሁ፡ መስቀል፨</l>
                  <l n="3">ተከሥተ፡ ብርሃን፡ ኪያከ፡ ረዳኤ፡ ግፉኣን፡ ዘእብል፨</l>
                  <l n="4">አድኅነኒ፡ እምአፅራርየ፡ በጸሎትከ፡ ዘይክል፨</l>
                  <l n="5">አቡየ፡ ሰባኪሃ፡ ለሐዳስ፡ ወንጌል፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለሕንብርትከ፡ ተከሥተ፡ ብርሃን፡ ዕንቈ፡ ባሕርይ፨</l>
                  <l n="2">ወልዑል፡ ዕበይ፨</l>
                  <l n="3">ለቶማስ፡ ወልድከ፡ ዘትርጓሜ፡ ስሙ፡ ፀሓይ፨</l>
                  <l n="4">ፈንዎ፡ የሐውጸነ፡ በኀይለ፡ ረድኤቱ፡ ሠናይ፨</l>
                  <l n="5">ወይባልሐነ፡ እምኵሉ፡ እኩይ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ ከመ፡ በደኅሪት፡ ዘመን፨</l>
                  <l n="2">ምስለ፡ ኵሎሙ፡ ሙታን፨</l>
                  <l n="3">አባ፡ አቡነ፡ ተከሥተ፡ ብርሃን፨</l>
                  <l n="4">ምርሐነ፡ ፍና፡ የማን፡ ለደቂቅከ፡ ትሑታን፨</l>
                  <l n="5">ኀበ፡ ምቅዋሞሙ፡ ለአበው፡ ኄራን፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">በሰላም፡ ወፍቅር፡ ዘአቅረብኩ፡ ዘንተ፨</l>
                  <l n="2">ተወኪፈከ፡ ማሕሌተ፨</l>
                  <l n="3">ተከሥተ፡ ብርሃን፡ አቡነ፡ አስተምሕር፡ ሊተ፨</l>
                  <l n="4">ከመ፡ ትሥረይ፡ በምሕረቱ፡ ዘገበርኩ፡ ኃጢአተ፨</l>
                  <l n="5">ከመ፡ ለቤዝዎ፡ ኃጥኣን፡ ፈጣሪ፡ ዘሞተ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ኦአጋእዝትየ፡ ቡራኬ፡ አረጋይ፡ ኢታስትቱ፨</l>
                  <l n="2">በእንተ፡ ምግባርየ፡ ከንቱ፨</l>
                  <l n="3">ሰላመ፡ አቡክሙ፡ ጻድቅ፡ ዘጸሐፍኩ፡ በበ፡ መክፈልቱ፨</l>
                  <l n="4">ኪያክሙኒ፡ ይዕቀብክሙ፡ ረድኤቱ፨</l>
                  <l n="5">ረድኤተ፡ ጻድቃን፡ ውሉዱ፡ ወኄራን፡ አግብርቱ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
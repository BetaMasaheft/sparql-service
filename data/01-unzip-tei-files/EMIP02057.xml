               <msContents>
                  <summary>Psalter, ዳዊት፡, fragments prepared for the tourist trade</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="14v" facs="003">Fols 1r–14v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Fragments of a Psalter, prepared for the tourist industry</note>

                  <msItem xml:id="ms_i1.1">
                     <locus from="1r" to="1r" facs="003">Fols 1r–1r</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm101">Psalms of
                                                  David, Psalm101</title></title>

                  </msItem>
                  <msItem xml:id="ms_i1.2">
                     <locus from="2r" to="2v" facs="004">Fols 2r–2v</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm104">Mazmura Dāwit,  Psalm104</title> and <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm105">Mazmura Dāwit,  Psalm105</title> </title>

                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="3r" to="5v" facs="005">Fols 3r–5v</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                     </title>

                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="6r" to="6r" facs="008">Fols 6r–6r</locus>
                     <title>Excerpts from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm21">Mazmura Dāwit,  Psalm21</title> and <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm22">Mazmura Dāwit,  Psalm22</title></title>

                     <note><locus target="#6" facs="008">Fol. 6</locus> has been turned around and sewn into the book</note>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                     <locus from="6v" to="6v" facs="009">Fols 6v–6v</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm21">Mazmura Dāwit,  Psalm21</title></title>

                  </msItem>
                  <msItem xml:id="ms_i1.6">
                     <locus from="7v" to="9v" facs="010">Fols 7v–9v</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm102-3">Mazmura Dāwit,  Psalm102-3</title></title>

                  </msItem>
                  <msItem xml:id="ms_i1.7">
                     <locus from="10r" to="10r" facs="012">Fols 10r–10r</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm1">Psalms of
                                                  David, Psalm1</title> and <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm2">Mazmura Dāwit,  Psalm2</title></title>

                  </msItem>
                  <msItem xml:id="ms_i1.8">
                     <locus from="11r" to="13r" facs="013">Fols 11r–13r</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm103-4">Mazmura Dāwit,  Psalm103-4</title></title>

                  </msItem>
                  <msItem xml:id="ms_i1.9">
                     <locus from="14r" to="14v" facs="016">Fols 14r–14v</locus>
                     <title>Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm83-84">Mazmura Dāwit,  Psalm83-84</title></title>

                     <note><locus target="#14" facs="016">Fol. 14</locus> has been turned around and sewn into the book</note>
                  </msItem>

                </msItem>


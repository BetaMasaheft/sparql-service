               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="1r" to="2r">1r-2r</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT2005IHA">قصيدة قف بذات السفح من اضم</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#1r">-1r</t:locus>سيد السادات من مضر | غوث اهل البدو والحضر | صاحب الأيات والسور | منبع الأحكام والحكم | قمر طابت سر بر... | وسجاياه وسيرته </incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#2r">-2r</t:locus>المصفي منصب الشرفا | ذو الوفا الأغلا الوري شرفا | احمد المختار والخلفا شهدأ الله في الامم | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="2v" to="4v">2v-4v</t:locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4042IHA">Poem in Old Harari (4)</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#2v">-2v</t:locus>سق حميلا وبسم الله يبور دو اصل بسم الله ورش حميلاوا بسم الله يبرسا أواي بني ورش كرس ذال نخلفليو ملايكة سلام يل جرا </incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#4v">-4v</t:locus>وددينا يود نبيو سطينا الله حمدا وددينا | ملحينا ملح نبيو سطينا الله حمدا ملحينا | أواي محمدوا صل علي دووا نبيوا أمين | تمت</explicit>
                     <note>Vocalization in blue ballpoint only in the first part of the poem.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="4v" to="5v">4v-5v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4043IHA">Poem in praise of ʻUmar Ziyād</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#4v">-4v</t:locus>شي لله عمر زياد شي عمر زياد | مدحكم نعم المرادي المدد عمر زياد | ابتدي ببسم الله ثانيا بحمد الله | مادحا ولي الله المدد عمر زياد</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#5v">-5v</t:locus>وعليك اتكا لي المدد عمر زياد | سيدي فقل لبيك ابن عمر زياد يدعوك كن مغيثا لداعيك المدد عمر زياد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="6r" to="8v">6r-8v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4046IHA">Poem in old Harari (6)</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#6r">-6r</t:locus>عرش الرحما نب أ اجييوا | سبع سما نب او اجيوا | جمع مخلوقب أو احيوا | محمد بايت حرأت حرفا | جمع حروفب ترفانا </incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#8v">-8v</t:locus>نبو سطينا اللو حمدي | إيمان سطين ال؛لو حمدي المرسببن؟ اللو حمدي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="9r" to="9v">9r-9v</t:locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT4045IHA">Poem in Old Harari (5)</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#9r">-9r</t:locus>نبو معجزاتخ برد بر... لو إماموا | نبو معجزاتخ وراق مسر لو إماموا | درق نبو ... تمرم بس أطتلا اماوا | نبو حطر ذيمن نقن باتلا اماوا</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#9v">-9v</t:locus>نبو راج حالب ذحبعخل اماوا | نبو مت منعيتا ذحل كخل اماوا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="10r" to="10v">10r-10v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4044IHA">دعاء القهوة</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#10r">-10r</t:locus>ما حيو سلام عليك عربوا سلام عليك | أولو ببسم الله ثانيا بحمد الله | ثالثا ثلاة الله لنبي رسول الله | قهوة إذ شربا بدنا بها استرحنا | شوشنا بها يزول وكذا وجع وكسل</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#10v">-10v</t:locus>أكثروا في القهوات ذكر إسم بسم الله  أكثروا في القهوات للنبي صلوات | وادعوا للمسلمين وجميع المؤمنين إحذروا في القهوات لفظة من لفواتي </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="11r" to="16v">11r-16v</t:locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT4045IHA">Poem in Old Harari (5)</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#11r">-11r</t:locus>نبو نطف چوچا وذح... خچل؟ اماموا | نبو چار أباتم ذخل كخل إماموا | نبو أوا أيم ذحل كخل إماموا</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#16v">-16v</t:locus>نبو شكر جيب أخع نالخو إماموا | نبو جيزجي ب اخع نالخو إماموا | نبو أول حمد أخر شكر بيو إماموا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="16v" to="17v">16v-17v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT3052IHA">علي الأولياء القيت سري وبرهاني</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#16v">-16v</t:locus>بسم الله الرحمن الرحيم | نبي لله يا جيلاني شي لله يا جيلاني | عبد القادر كيلاني ولي الرحمن | ولي الأوليأ ألقيت سري وبرهاني</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#17v">-17v</t:locus>قرانا زبورا كاملا ثم فرقاني | وخصت بحار العلم من قبل نشاتي | أخي ورفيقا كان موسى ابن عمر...</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="18r" to="20v">18r-20v</t:locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4045IHA">Poem in Old Harari (5)</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#18r">-18r</t:locus>بسم الله الرحمن الرحيم | نبوا بسم الله زعزيز سموا إماموا | نبوا الرحمانوا زعزيز سموا إماموا | نبوا الرحيم زعزيز سموا إماموا | نبوا بسم الله داو خونني إماموا</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#19v">-19v</t:locus>نبو معجراتخ داكر ذيكرو اماموا | نبو معجراتخ عالم فيسرو اماموا</explicit>
                     <note/>
                     <note/>
                  </msItem>

                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ጸሎት፡ ዘእግዝእትነ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> 
                        <persName ref="https://betamasaheft.eu/PRS6819Mary">ማርያም፡</persName> 
                        <gap reason="ellipsis" resp="PRS9602Turaev"/>
                                እንተ፡ ጸሐፋ፡ <persName ref="https://betamasaheft.eu/PRS7953Prochoru">አብሮኮሮስ፡</persName> ረድአ፡ <persName ref="https://betamasaheft.eu/PRS5695John">ዮሐንስ፡</persName> 
                        <gap reason="ellipsis" resp="PRS9602Turaev"/>ዘጸለየት፡ ባቲ፡ አመ፡ ፳ወ፩ለወርኀ፡ ሰኔ፡ <placeName ref="https://betamasaheft.eu/LOC3563Golgot">በደብረ፡ ጎልጎታ።</placeName>
                                <foreign xml:lang="en">Prayer of Our Lady <gap reason="ellipsis" resp="PRS9602Turaev"/>  Mary  <gap reason="ellipsis" resp="PRS9602Turaev"/> written down
                                    by Prochorus, the disciple of John,  <gap reason="ellipsis" resp="PRS9602Turaev"/> which She pronounced on the twenty-first of Sǝne on the mountain of Golgotha.</foreign>
                     </incipit>

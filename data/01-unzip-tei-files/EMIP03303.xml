                  <idno facs="EMIP/Codices/3303/" n="92" corresp="https://betamasaheft.eu/api/iiif/EMIP03303/manifest">Westbrook 4</idno>
               </msIdentifier>
               <msContents>
                  <summary>Book of Baptism</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="44v" facs="003">Fols 3r–44v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1975Mashaf">Maṣḥafa
                                                  ṭǝmqat</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <incipit xml:lang="gez">ዝንቱ፡ መጽሐፈ፡ ጥምቀት፡ ዘይትነበብ፡ በ፲፩ለወርኃ፡ ጥር፤ ወየሥርቅ፡ ወይውግር፡ ካህን፡ ዕጣነ፤ ወይዲ[.]፡ ሊጦን፡ ዘሌሊት፡ ክሥተት፡ መዝሙር።</incipit>

                    <colophon xml:id="coloph1">
                      <locus target="#44v" facs="045">Fol. 44v</locus>
                      <foreign xml:lang="gez">ተጽሕፈ፡ በመዋዕሊሁ፡ ለዳግማዊ፡ ምኒልክ፡ ንጉሠ፡ ነገሥት፡ ዘኢትዮጵያ፡ በ ሀገረ፡ ራስ፡ መኰንን፡ በ ፲፰፻፺፮ዓመተ፡ ምሕረት።</foreign>
                      <q>“The book was made in the days of Menilek the second, King of Kings of Ethiopia, in the land of Ras Makwonen in 1896 Year of Mercy (=1903/4 CE).”</q>
                    </colophon>

                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="46r" to="85v" facs="046">Fols 46r–85v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1959Mashaf">Maṣḥafa qedar</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <colophon xml:id="coloph2">
                    <locus target="#85v" facs="086">Fol. 85v</locus>
                    <q>Finished in peace on Monday in the year of Matthew the Evangelist] in the Month of Tahsas by ደብተራ፡ ወልደ፡ ሐና፡,
                      Dabtara Walda Hana for መምሬ ፈለቀ, Mamre Falaqa and received 14 birr , 12 [….]</q>
                  </colophon>

                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">85</measure>
                           <dimensions type="outer" unit="mm">
                              <height>202</height>
                              <width>140</width>
                              <depth>45</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="2" writtenLines="20 21"/>
                     </layoutDesc>
                  </objectDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r #1v" facs="001 002">Fols. 1r, 1v</locus>
                    <desc>
                    Excerpt from Epistle of Saint John. The scribe for this excerpt is listed on 1v, <foreign xml:lang="gez">ፍሬ፡ ሰንበት፡</foreign>, Faray Sanbat, who is also mentioned in <locus target="#44v" facs="045">fol. 44v</locus>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    The book is comprised of two books, previously separate, but been rebound as one.  In the process, the orientation of the books was rotated 180 degrees to one another.  Consequently the images of the second book appear upside down
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#81v" facs="082">Fol. 81v</locus>
                    <desc>
                    Prayers for our Abba <persName ref="https://betamasaheft.eu/PRS8033Qerellos">Qerǝllos</persName>(?) and <persName ref="https://betamasaheft.eu/PRS6876Matewos">Mātewos X</persName>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#85r" facs="085">Fol. 85r</locus>
                    <desc type="OwnershipNote">
                    Prayer for <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</persName> and the owner, <foreign xml:lang="gez">ወልደ፡ አምላክ፡</foreign>, Walda Amlak, and scribe, <foreign xml:lang="gez">ወልደ፡ ማርያም፡</foreign>, Walda Maryam. Abba Matewos is also mentioned
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1903" notAfter="1904">1896 E.C. Year of Mercy (<locus target="#44v" facs="045">fol. 44v</locus>)</origDate>
                  </origin>
               </history>
            </msDesc>

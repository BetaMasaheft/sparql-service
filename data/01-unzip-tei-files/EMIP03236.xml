               </msIdentifier>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><title type="complete" ref="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">128</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>
                              <width/>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="2" writtenLines="20 22"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1v" facs="002"/><desc>Drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with <term key="angel" ana="#angel"/>s above and Ephrem before her. With caption <q>How our Lady blessed Ephrem</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#3r" facs="003"/><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> present with the Three Hebrew Children in the Fire</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#127v" facs="128"/><desc>Fine Drawing of the Crossing of the Red Sea and the Egyptians drowned by the river</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#4r #4v #5r #5v #6r #6v" facs="004 005 006 007"/>
                    <desc type="GuestText">
                      <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa Gabrǝʾel</title>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#114r #114v #115r #115v #116r #116v #117r #117v #118r #118v #119r #119v #120r #120v #121r" facs="114 115 116 117 118 119 120 121"/>
                    <desc type="GuestText">
                       <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title> written in another hand
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#122r" facs="122"/>
                    <desc>
                    Layman’s prayer, in Amharic, <foreign xml:lang="am">አዳምን፡ ከሲኦል፡ ኖኅን፡ ከማየ፡ አይኅ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#1r" facs="001"/>
                    <desc>
                    Despite the label, the Weiner collection number should be 464 and not 461
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    Very fine materials and workmanship
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    The harags represent some of the finest work of the government scriptorium of the Menilek, Zewditu, Silassie era
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    Fine, yellow fabric is visible between the paste downs on the inside front and back covers
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#1r" facs="001"/>
                    <desc>
                    Record of Renewal of will by a woman, <foreign xml:lang="gez">ብርቄ፡</foreign>, with witnesses and judge listed.
                    The date is given in the 42nd year of the Reign of Emperor Menilek
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#4v"> f. 4v and passim</locus>
                    <desc type="OwnershipNote">
                    mentions owner <foreign xml:lang="gez">መስቀለ፡ ቃል፡</foreign> Masqala Qal and his daughter Walata Wald, <foreign xml:lang="gez">ወለተ፡ ወልድ፡</foreign>
                    appearing nearby, written interlinearly
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#29v" facs="030"/>
                    <desc>
                    mentions scribe, <foreign xml:lang="gez">ወልዳ፡ ማርያም፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#124r" facs="124"/>
                    <desc type="OwnershipNote">
                    This book belongs to <foreign xml:lang="gez">መስቀለ፡ ቃል፡</foreign> and his mother <foreign xml:lang="gez">ወላተ፡ ኢየሱስ፡</foreign> and his wife,
                    <foreign xml:lang="gez">ወለተ፡ ወልድ፡</foreign> and his children <foreign xml:lang="gez">ወለተ፡ ኢያሱስ፡, ወለተ፡ ጻድቅ፡, ኅይለ፡ ማርያም፡, ኪዳና፡ ማርያም፡, ስኅለ፡ ማርያም፡</foreign>
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>

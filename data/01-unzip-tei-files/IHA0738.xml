               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="3v">1r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ما بال قلبك لا ينفكاذ ألم| مذ بان أهل الحما والبان والعلم| وانهل مد معك القان بمنسجم| من تذكر ديران بذي سلم مذجت دمعا جرى من مقلة بدم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>فكيف يوقظ واسنان لمفتبه| أمرت ك الخير لكن ما اتمرت به وما استقمت فما قول الك ستقم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="4v">4r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0543IHA">قصيدة الهمزية في مدح خير البرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>وترأت قصور قيصر الروم ليراها من داره البطحاء| وبدت في رضاعه معجزت ليس فيها عن العيون خفاء</incipit>
                     <explicit xml:lang="ar">رامـقا طرفه السماء ومرمىعين  من شأنه العلو العلاء|
وتدلّت زهر النجوم اليهفأضاءت بضوئها الأرجاء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5r" to="10v">5r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1704IHA">نظم أدير يا بشرا لكم</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>أدير يا بشرا لكم| بشرنا يا [...] لكم| [...]  المعظمى سلام عليكم  نبي برحمة نور دات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>عليك صلاة وكل حي  تحيا| لأل وصحب وكل لأصفيا دو ما بلده حب لغرام| ما دم تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="10v" to="13v">10v-13v</locus>
                     <textLang xml:lang="om-Arab">Oromo</textLang>
                     <title ref="https://betamasaheft.eu/LIT1705IHA">Poem in ʻaǧamī Oromo (16)</title>
                     <incipit xml:lang="om-Arab">
                        <locus target="#10v">-10v</locus>أصلي صلاة على طييك| عدو خلقلك ورض نفسك| ملاكر سيك وكذا عرشك | وسلم سلاما ربى كذا لك وأله طرا دوم ملك الله | قلقلاء غوفتان خيرتيتى</incipit>
                     <explicit xml:lang="om-Arab">
                        <locus target="#13v">-13v</locus>ألصلاة وسلام عليك يا جيب| وعلاء ليك أهل المر التبي| بعد لأشياء يا رحمة قلبي| صلاة وسلام عليك يا نبي وألك طز يا رسول الله</explicit>
                     <note>The language is not clear.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="13v" to="15r">13v-15r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1702IHA">نظم يا شمس المدينة</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>سلام علكم نبي سلام نبي [ذخيرتة ى] يا شمس لمدينة| ألاياحية يا سكن طية</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus>ما [غنت] ورق لأسواق فى واد قلب بعشاق| وطلب وقت تلماق لأهل |المعدة تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="17r" to="17v">17r-17v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1703IHA">نظم هو النبي لذى شراب قلوبنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#17v">-17v</locus>هو النبي لذى شراب قلوبنا وشفاء الصدور ودوا مجرب| فواد نجمر الحي بات مهرا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17r">-17r</locus>على خير مبعوث به فطا نوره| صلا عليه ربه ما دام لكون به وسلم  ءبدا ما دام المواهب</explicit>
                     <note/>
                     <note/>
                  </msItem>

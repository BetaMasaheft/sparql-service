                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                      <seg type="rubrication">
                        <foreign xml:lang="gez">ማርያም፡</foreign>
                        <foreign xml:lang="gez">ገብርኤል</foreign>
                        <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                        <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</foreign>
                      </seg>
                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#1r #47v" facs="001 048">folss. 1r, 47v, </locus>, line of black dots; <locus target="#75r" facs="075">75r</locus>, multiple full stops</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="a1">
                        <locus target="#ms_i1">Fol. ms_i1</locus>
                        <desc>Arranged for the days of the week in a secondary hand:
                          Monday <locus target="#1r" facs="001">fols. 1r, </locus>,
                          Tuesday <locus target="#9r" facs="009">9r, </locus>,
                          Wednesday <locus target="#16v" facs="017">16v, </locus>,
                          Thursday <locus target="#25r" facs="025">25r, </locus>,
                          Saturday <locus target="#37r" facs="037">37r, </locus>,
                          Sunday <locus target="#42r" facs="042">42r</locus></desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#75v" facs="076">Fol. 75v</locus>
                          <desc type="GuestText">Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title> written in a later hand in blue ink</desc>
                        </item>
                        <item xml:id="e1"><desc><locus target="#47v" facs="048">Fol. 47v</locus> The name of the owner has been erased</desc></item>
                        <item xml:id="a3"><desc><locus target="#50v" facs="051">Fol. 50v</locus> The spaces for the names of the patriarchs have been left blank. A secondary hand has written <foreign xml:lang="gez">መርቆርዮስ፡</foreign>, Märqoryos (1988–1991) in red ink</desc></item>
                        <item xml:id="a4"><desc><locus target="#75r" facs="075">Fol. 75r</locus> Mentions the scribe Zä-Wäldä Maryam (<foreign xml:lang="gez">ዘወልደ፡ ማርያም፡</foreign>). The name of the owner has been erased. The first word Wäldä (<foreign xml:lang="gez">ወልደ፡</foreign>) is partially visible, but the second part of the name is illegible</desc></item>
                        <item xml:id="a5"><desc><locus target="#75r" facs="075">f. 75r, bottom</locus> a note in red ink and a note in blank ink have been erased</desc></item>
                        <item xml:id="e2"><desc>
                          Scribal intervention:
                          words of text are written interlinearly <locus target="#4v #5r #5v #8v #10r" facs="005 006 009">folss. 4v, 5r, 5v, 8v, 10r, </locus>, etc.;
                          text has been removed <locus target="#4v #11v #16r #23v #28r" facs="005 012 016 024 028">4v, 11v, 16r, 23v, 28r</locus>, etc.</desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">

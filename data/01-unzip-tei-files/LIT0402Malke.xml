         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ ሥሉስ፡ ቅዱስ፡ ዘበተዋሕዶ፡ ኅቡረ፨</l>
                  <l n="2">ዓለማተ፡ ኵሎ፡ እንተ፡ በቅጽበት፡ ሣረረ፨</l>
                  <l n="3">ጸግወኒ፡ ዮናስ፡ ዘውዳሴከ፡ ምንሃረ፨</l>
                  <l n="4">ልሳነ፡ መልአክ፡ እሳታዊ፡ ከመ፡ ኪያኪ፡ መሀረ፨</l>
                  <l n="5">ንጽሐ፡ ኅሊና፡ ወገድል፡ ወዓዲ፡ መዝሙረ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">በስመ፡ ሥሉስ፡ ዋሕድ፡ አኃዜ፡ ኵሉ፡ ባሕቲቱ፨</l>
                  <l n="2">ዘእምኀበ፡ አልቦ፡ አቀመ፡ ሥዕለ፡ ሰሌዳ፡ ሰብዓቱ፨</l>
                  <l n="3">አርእየኒ፡ ዮናስ፡ ለክብርከ፡ ሥነ፡ ማኅቶቱ፨</l>
                  <l n="4">ወሥቅየኒ፡ ማየ፡ ልቡና፡ እምፈለገ፡ ብርሃን፡ አርባዕቱ፨</l>
                  <l n="5">ወጸጋ፡ ዚአከ፡ ሀበኒ፡ በከንቱ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">በስመ፡ ሥሉስ፡ ቅዱስ፡ ዋሕድ፡ ዘመንፈሰ፡ ሕይወት፡ ነፍሐ፨</l>
                  <l n="2">በትእዛዘ፡ ቃሉ፡ ግሩም፡ እንተ፡ ተከለ፡ ገሀሀ፨</l>
                  <l n="3">በአድያመ፡ ጽልመት፡ ዮናስ፡ ዘተመስልከ፡ ጽባሐ፨</l>
                  <l n="4">ከመ፡ እንግር፡ በበ፡ ምንታዌ፡ ተአምሪከ፡ ብዙኀ፨</l>
                  <l n="5">ውስተ፡ ልበ፡ ዕንቡዝ፡ ወልድከ፡ አዋኪ፡ ፍሥሓ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ብዕለ፡ ጸጋ፡ አምላክ፡ ልዑል፨</l>
                  <l n="2">እንተ፡ በዲቤሁ፡ ወረደ፡ በኈልቈ፡ ሠለስቱ፡ ፊደል፨</l>
                  <l n="3">ዘበመነፈስ፡ ቅዱስ፡ ዮናስ፡ ሥርግወ፡ አክናፍ፡ ቀሊል፨</l>
                  <l n="4">ነዓ፡ ነዓ፡ እምደብረ፡ ሣህል፡ ደወል፨</l>
                  <l n="5">ወነዓ፡ እምሕፃዛእትከ፡ ሀገረ፡ መስቀል፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለዐጽፍከ፡ ጸዳለ፡ ትሩፋት፡ ዘሰፈፎ፨</l>
                  <l n="2">ወግማኔ፡ ርስሐት፡ ዘኢለከፎ፨</l>
                  <l n="3">አብአኒ፡ ዮናስ፡ በቤተ፡ ትፍሥሕትከ፡ ለተሳትፎ፨</l>
                  <l n="4">ለሥጋየ፡ ወልደ፡ መሬት፡ አመ፡ ወርኀ፡ ወርዙት፡ ኀለፎ፨</l>
                  <l n="5">ወአመ፡ ለገዪስ፡ እዴሎ፡ እምዓለም፡ ግልፎ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ኅዳጠ፡ ጸሪቀ፡ ዘእምኅኩከ፡ ለእንግዳ፨</l>
                  <l n="2">እመዝገበ፡ ኀጥእት፡ ልብየ፡ ቅጽረ፡ ተፅናሳት፡ ዘየዐውዳ፨</l>
                  <l n="3">ረሲየከ፡ ዘንተ፡ መባአ፡ ነዳይት፡ ዕቤርተ፡ ኤልዳ፨</l>
                  <l n="4">ሀበኒ፡ ዮናስ፡ ቡራኬከ፡ ለጠለ፡ ሰማያት፡ እምድዳ፨</l>
                  <l n="5">ከመ፡ ወሀቦ፡ ያዕቆብ፡ ለወልዱ፡ ይሁዳ፨</l>
               </lg>
            </div>
         </div>
      </body>

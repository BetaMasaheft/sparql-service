                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="53v" facs="003">Fols 1r–53v</locus>
                    <title>Asmat prayers arranged for the days of the week</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1"><locus from="1r" to="7v" facs="003">Fols 1r–7v</locus><title>Monday</title>
                        <msItem xml:id="ms_i1.1.1"><locus from="1r" to="3v" facs="003">Fols 1r–3v</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer to drive out the enemy and demons, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ መስደዴ፡ ጸር፡ ወአጋንንት፡</foreign></title>
                        </msItem>
                        <msItem xml:id="ms_i1.1.2"><locus from="3v" to="7v" facs="006">Fols 3v–7v</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer against pain and demons and Magicians who kill the soul in the dreams of the night and the day</title>
                          <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ወአጋንንት፡ ወአቁያፃት፡ ወዓቃብያነ፡ ሥራይ፡ እለ፡ ይቀትሉ፡ ነፍሰ፡ በሕልመ፡ ሌሊት፡ ወመዓልት፡</incipit>
                        </msItem>
                      </msItem>

                      <msItem xml:id="ms_i1.2"><locus from="7v" to="15r" facs="010">Fols 7v–15r</locus><title>Tuesday</title>
                        <msItem xml:id="ms_i1.2.1"><locus from="7v" to="9v" facs="010">Fols 7v–9v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1878Marbab">Marbabta
                                                  Salomon</title>
                          <incipit xml:lang="gez">አስማተ፡ ሰሎሞን፡ ዘረበቦሙ፡ ለአጋንንንት፡ (sic) ከመ፡ መርበብተ፡ ዓሣ፡ ዘባህር፡ እንንዘ፡ (sic) ይብል፡ ሰዱቃኤል፡ አዳታኤል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.2"><locus from="9v" to="11v" facs="012">Fols 9v–11v</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer against Javelin, that David prayed in Hebron, <foreign xml:lang="gez">ኵይናት፡ ዘጸለየ፡ ዳዊት፡ በሀገረ፡ ኬብሮን፡ በቈላተ፡</foreign></title>
                          <incipit xml:lang="gez">ጸሎተ፡ ኵይናት፡ ዘጸለየ፡ ዳዊት፡ በሀገረ፡ ኬብሮን፡ በቈላተ፡ ኢሊ፡ ጌልኤሙሄ፡ ገለማላዊ፡<gap reason="omitted"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.3"><locus from="11v" to="12r" facs="014">Fols 11v–12r</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer against charm, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡</foreign></title>
                          <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሥራይ፡ ወኪን፡ ወተግባረ፡ ሰብእ፡ ዮፍታሔል። ድንግኤል፡ ክፍትናጌም፡ ይዛግዮን፡ በግዕት፡ ሲኖን፡ በገጸ፡ ሚካኤል፡<gap reason="omitted"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.4"><locus from="12r" to="12v" facs="014">Fols 12r–12v</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of Säbalyon</title>
                          <incipit xml:lang="gez">ዝንቱ፡ አስማት፡ ለሰባልዮን፡ ዘወኅቦ፡ እግዚአብሔር፡ ለሰባልዮን፡ ለኅልቀቀ፡ ብዙኅ፡ አፃቢዒሁ፡ ወብዙኅ፡ እዴሁ፡<gap reason="omitted"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.5"><locus from="13r" to="14r" facs="015">Fols 13r–14r</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer against Rheumatism, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ ውግዓት፡</foreign></title>
                          <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ውግዓት፡ አብ፡ እሳት፡ ወል(ድ)፡ እሳት፡ መንፈስ፡ ቅዱስ፡ በነድከ፡ ወበዋእይከ፡ ወበነበልባልከ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.6"><locus from="14r" to="14v" facs="016">Fols 14r–14v</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer against Liver Pain, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ከብድ፡</foreign></title>
                          <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ከብድ፡ አምላከ፡ አብርሃም፡ በውስተ፡ በዓታት፡ አምላከ፡ አናንያ፡ ወአዛርያ፡ ወሚሳኤል፡ በውስተ፡ እቶነ፡ እሳት፡<gap reason="omitted"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.7"><locus from="14v" to="15r" facs="017">Fols 14v–15r</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of Daniel, which he prayed in the lion’s den</title>
                          <incipit xml:lang="gez">ዘንተ፡ አስማተ፡ ዘወኀቦ፡ እግዚአብሔር፡ ወጾሮ፡ በውስተ፡ ግበበ፡ አናብስት፡ ኃበ፡ (sic) ዳንኤል፡ ወጾሮ፡ እግዚአብሔር፡ ለእንባቆም፡ ወአብጽሖ፡ ኃበ፡ (sic) ግበ፡ አናብስት፡<gap reason="omitted"/></incipit>
                        </msItem>
                      </msItem>

                  <msItem xml:id="ms_i1.3"><locus from="15r" to="20r" facs="017">Fols 15r–20r</locus><title>Wednesday</title>
                    <msItem xml:id="ms_i1.3.1"><locus from="15r" to="18v" facs="017">Fols 15r–18v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of the Three Holy Children which Michael told them in the middle of the fire</title>
                      <incipit xml:lang="gez">ዘንተ፡ አስማተ፡ ዘወሀቦ፡ እግዚአብሔር፡ ለአናንያ፡ ወአዛርያ፡ ወሚሳኤል፡ እንዘ፡ ይትናገሮሙ፡ ሚካኤል፡ ቀዊሞ፡ ማእከለ፡ እቶነ፡ እሳት፡ ዘይነድድ፡<gap reason="omitted"/></incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.3.2"><locus from="18v" to="20r" facs="021">Fols 18v–20r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of the Father, Son, and Holy Spirit, <foreign xml:lang="gez">አስማተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</foreign></title>
                      <incipit xml:lang="gez">ኦሥሉስ፡ ቅዱስ፡ አስማተ፡ አብ፡ ወወልድ፡ ወመ(ን)ፈስ፡ ቅዱስ፡ አስማተ፡ ሥላሴ፡ አብ፡ ወወልድ፡ ወመንፈስ። አሌፍ፡ ቤት፡ ጋሜል፡ ዳሌጥ፡ ሄ፡ ዋው፡ ዛይ፡ ሔት፡ ጤት፡ ዮድ፡ ካፍ፡<gap reason="omitted"/></incipit>
                    </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.4"><locus from="20v" to="26r" facs="023">Fols 20v–26r</locus><title>Thursday</title>
                    <msItem xml:id="ms_i1.4.1"><locus from="20v" to="22r" facs="023">Fols 20v–22r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of the Apostle Peter, <foreign xml:lang="gez">ጸሎቱ፡ ለጴጥሮስ፡</foreign></title>
                      <incipit xml:lang="gez">ጸሎቱ፡ ለጴጥሮስ፡ ዝውእቱ፡ ዘየዓቢ፡ እምሐዋርያቲሁ፡ ዘሐረዮ፡ ክርስቶስ፡ እምቅድመ፡ ኵሎሙ፡ ሐዋርያቲሁ፡ ለኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡<gap reason="omitted"/></incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.4.2"><locus from="22v" to="24r" facs="025">Fols 22v–24r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of Melchizedec</title>
                      <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ መልከ፡ ጼዴቅ፡ ወበእንተ፡ ጰራቅሊጦስ፡ መንፈሰ፡ ጽድቅ፡ ወጸሎተ፡ በእግዚአብሔር፡ አብ፡ በክርስቶስ፡ ወልድ፡ ወሳልሣይ፡ መንፈስ፡ ቅዱስ፡ አእትት፡ እምነፍስየ፡ እግዚኦ፡ ተሣሃለኒ፡</incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.4.3"><locus from="24v" to="26r" facs="027">Fols 24v–26r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer for Mercy which Angels Pray in Heaven, <foreign xml:lang="gez">ጸሎተ፡ ምሕረት፡ ዘጸለዩ፡ መላእክት፡</foreign></title>
                      <incipit xml:lang="gez">ጸሎተ፡ ምሕረት፡ ዘጸለዩ፡ መ(ላ)እክት፡ ወሰማያት፡ ወሰማእት፡ ጳጳሳት፡ ወመነኮሳት፡ እድ፡ ወአንስት፡<gap reason="omitted"/></incipit>
                    </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.5"><locus from="26v" to="35r" facs="029">Fols 26v–35r</locus><title>Friday</title>
                    <msItem xml:id="ms_i1.5.1"><locus from="26v" to="35r" facs="029">Fols 26v–35r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of Powers, <foreign xml:lang="gez">አስማተ፡ ኃይላት፡</foreign></title>
                      <incipit xml:lang="gez">አስማተ፡ ኃይላት፡ ኢያኤል፡ አፍናኤል፡ አስናኤል፡ አትናኤል፡ ወይሰልብ፡ ነፍሳተ፡ አልባስ: ዘለምጽ:<gap reason="omitted"/></incipit>
                    </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.6"><locus from="35r" to="39r" facs="037">Fols 35r–39r</locus><title>Saturday</title>
                    <msItem xml:id="ms_i1.6.1"><locus from="35r" to="39r" facs="037">Fols 35r–39r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of Christ, <foreign xml:lang="gez">ይቀድሰነ፡ አስማቲሁ፡ ለክርስቶስ፡</foreign></title>
                      <incipit xml:lang="gez">ይቀድሰነ፡ አስማቲሁ፡ ለክርስቶስ፡ ሲጅላዊ፡ ቢደጋዊ፡ ቴድሮፋ፡ ፈቃዴ፡ ገደላኤል፡ መታሮሮ፡ በዚዝል፡ ገመለፈለጉል፡ ገመለፈለኵል፡ ቄርሎካኤል፡<gap reason="omitted"/></incipit>
                    </msItem>
                    <msItem xml:id="ms_i1.6.2"><locus from="39r" to="40v" facs="041">Fols 39r–40v</locus>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of the Disciples and the Seventy-Two (who were sent out)</title>
                      <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሥርየተ፡ እምነቶሙ፡ ለሐዋርያት፡ ወለኵሎሙ፡ ፸ወ፪፡ አርድዕት፡</incipit>
                    </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.7"><locus from="41r" to="47v" facs="043">Fols 41r–47v</locus><title>Sunday</title>
                    <msItem xml:id="ms_i1.7.1"><locus from="41r" to="47v" facs="043">Fols 41r–47v</locus>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat prayer of the Disciples and the Seventy-Two (who were sent out), continued</title>
                    </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.8"><locus from="48r" facs="050">Fols 48r and following</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat reading for Monday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.9"><locus from="48v" facs="051">Fols 48v and following</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat reading for Tuesday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.10"><locus from="49r" facs="051">Fols 49r and following</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Asmat reading for Wednesday</title>

                     <title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾ-hymn to St George</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ።</incipit>
                     <note>Illegible towards the end.</note>
                  </msItem>
                  

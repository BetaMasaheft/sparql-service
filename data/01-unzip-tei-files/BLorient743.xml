                                   <desc type="GuestText">The catalogue does not state clearly whether this note is a later addition, see also
                                       <bibl corresp="http://zotero.org/groups/358366/items/XDA9IWH9"><seg type="encyclopediaArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Donzel2005Enbaqom"/><title level="a">ʿƎnbaqom</title><title type="short">EAe</title><title level="m">Encyclopaedia Aethiopica</title><author><forename>Emeri</forename><surname>Van Donzel</surname></author><editor><forename>Siegbert</forename><surname>Uhlig</surname></editor><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>2005</date><biblScope unit="volume">II</biblScope><biblScope unit="page">280a-282a</biblScope><note type="tags"><note type="tag">bm:Donzel2005Enbaqom</note></note><note type="tag">bm:Donzel2005Enbaqom</note></bibl>.</desc>
                                   <q xml:lang="gez"><seg part="I">ለዝንቱ፡ ትርጓሜ፡ ተርጐመ፡ አቡነ፡ <persName ref="https://betamasaheft.eu/PRS3779enbaqom">እንባቆም፡</persName> እምአረቢ፡ ለግዕዝ፡ ወወሀቦ፡ 
                                       ለወልዱ፡ <persName ref="https://betamasaheft.eu/PRS4935HabtaIy">ሀብተ፡ ኢየሱስ።</persName> እመቦ፡ ዘረቆ፡</seg></q>
                               </item>
                               
                               <item xml:id="a2">
                                   <locus target="#2r"/>
                                   <desc type="OwnershipNote">The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                   </desc>
                                   <q xml:lang="gez">ኩፋሌ፡ ዘቅዱስ፡ <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">መድኃኔ ፡ ዓለም።</placeName></q>
                               </item>

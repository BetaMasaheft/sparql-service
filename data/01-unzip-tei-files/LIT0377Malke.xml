         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በረድኤተ፡ ክርስቶስ፡ አምላክ፡ ለክብረ፡ ስሙ፡ ሰጊድ፨</l>
                  <l n="2">እመንፈሳውያን፡ ነገድ፡ ወእምሥጋውያን፡ ትውልድ፨</l>
                  <l n="3">ወይነ፡ መንፈስ፡ ቅዱስ፡ ፊቅጦር፡ ዘጣዕምከ፡ ፍድፉድ፨</l>
                  <l n="4">ያስክረኒ፡ ስቴ፡ ፍቅርከ፡ ወያጥብበኒ፡ ለአብድ፨</l>
                  <l n="5">ዜና፡ ዕበያቲከ፡ እጽሕፍ፡ በመዝራዕት፡ ወእድ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላን፡ ለፅንሰትከ፡ ወለልደትከ፡ ፍሥሓ፨</l>
                  <l n="2">ውስተ፡ ቅጽረ፡ መንፍሥት፡ ዐባይ፡ ዘቀርነ፡ በዓሉ፡ ተነፍሐ፨</l>
                  <l n="3">ሕፃነ፡ ማርታ፡ ፊቅጦር፡ ዘነገሥተ፡ ምሥራቅ፡ አበዊሃ፨</l>
                  <l n="4">ይሕፅበኒ፡ እምርስሐትየ፡ ወይጸግወኒ፡ ንጽሐ፨</l>
                  <l n="5">ፈለገ፡ ቅዳሴ፡ ደምከ፡ ዐውደ፡ ስምዕ፡ ዘነዝኀ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሰሌዳ፡ ስምከ፡ ሆህያተ፡ በቅጥር፡ ዘቦቱ፨</l>
                  <l n="2">ወፍካሬ፡ ባህሉሰ፡ በጽርዕ፡ ፊቅጦር፡ ዝንቱ፨</l>
                  <l n="3">ወብሂለ፡ ፊቅጦርኒ፡ ፍቁረ፡ ፈጣሪ፡ ውእቱ፨</l>
                  <l n="4">መምህራን፡ ወማእምራን፡ በጊዜ፡ አንበብዎ፡ ሎቱ፨</l>
                  <l n="5">እንዘ፡ ይብል፡ ከመዝ፡ ተረክበ፡ ጽሕፈቱ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ በእደ፡ እምከ፡ ማርታ፨</l>
                  <l n="2">እምውሳጤ፡ ይእቲ፡ ግብ፡ እንተ፡ ነበርከ፡ ውስቴታ፨</l>
                  <l n="3">ለእስክንድርያ፡ ፊቅጦር፡ ወለአንጾኪያ፡ ማኅቶታ፨</l>
                  <l n="4">ለዕበየ፡ ዛቲ፡ ፍልሰትከ፡ በዘትትሌዐል፡ ሥርዓታ፨</l>
                  <l n="5">በኈልቈ፡ ብፅዓናት፡ ዓሥር፡ ተጼሐ፡ ፍኖታ፨</l>
               </lg>
               <lg type="stanza" n="35">
                  <l n="1">በኈልቈ፡ ሱባዔ፡ ራብዕ፡ ወበፍቅደ፡ ክራማት፡ ኃምስ፨</l>
                  <l n="2">ውስተ፡ ዓለምነ፡ ቦቱ፡ ዘአንሶሰወ፡ ክርስቶስ፨</l>
                  <l n="3">አምኃ፡ ማሕሌት፡ አቅረብኩ፡ ለመልክእከ፡ ውዱስ፨</l>
                  <l n="4">ተወከፍ፡ ሊተ፡ እግዚእየ፡ እምነ፡ ባሪክ፡ ጽኑስ፨</l>
                  <l n="5">ፊቅጦር፡ መኰንን፡ ፊቅጦር፡ ንጉሥ፨</l>
               </lg>
            </div>
         </div>
      </body>

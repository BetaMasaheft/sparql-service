               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1"><locus from="5r" to="145v" facs="008">Fols 5r–145v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="5r" to="111r" facs="005">Fols 5r–111r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Opening Prayer is from the Psalter of the Virgin. The midpoint of the Psalms (<locus target="#59r">fol. 59r</locus>) is unmarked. The spiritual meanings of the Hebrew letters in Psalm 118 are according the modern system. Psalm 151 is the short version</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="111v" to="122r" facs="112">Fols 111v–122r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">The fourth canticle is described as the prayer of Hana, mother of Samuel, prophet</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="122v" to="128v" facs="123">Fols 122v–128v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">, common version</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="129r" to="140r" facs="129">Fols 129r–140r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">, beginning with Monday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="140r" to="145v" facs="140">Fols 140r–145v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="23r">1r-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>ما بال قبلك لا ينفك ذا ألم \ مذبان اهل الحمى والبان والعلم \ وانهل مد معك القانى بمنسجم  \ من تذكر جيران بذى سلم مزجت دمعا جرى من مقلة بدم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>واغفر لناظمها وارحم مخمسها \ ووف قارئها اجرا ودارسها \ واعط سامعها خيرا وحاسبها \ وجد بالبركات واغمر مجالسها يا وافر الفضل والاحسان والنعم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="2v">2r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0753IHA">قصيدة طف بحالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus> طف بحاني سبعا وقف بزمانى| وتجرد لزورتى كل عامي \ انا سر الاسرار من سر سري | كعبة راحتى وبسط مدامى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>انا عبد لقادر راق وقتي | جدى المصطفى شفيع الانامى \ الف صلوا عليه طول الدوام | بالبواكر وبالعشي والظلام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="59v" to="60v">59v-60v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0737IHA">مدح النبي أبتدئ بسم الكريم</title>
                     <incipit xml:lang="ar">
                        <locus target="#59v">-59v</locus>الف صلي الله على احمد |ابتدي باسم الكريم ٬ وبحمد الله ثاني , ثالثا بالصلوات , بالنبي الهادي الشفيع 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60v">-60v</locus>فاغفر عن فتح اجترامي| يا ملاذي واعتصامي|| فعلى خير الأنام| صلواتي وسلامي| كل أصحاب وءال
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="60v" to="60v">60v-60v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2889IHA">نظم هبوا لي من فضلكم هبوا لي</title>
                     <incipit xml:lang="ar">
                        <locus target="#60v">-60v</locus>الهى الهى ذ الجلال| تفضل علينا بالقبول هبو لي من فضلكم هبو لي | وجودوا للعبد بالقبول || منائي وبغيتي رضاكم| وانتم قصدي وكل سؤلي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60v">-60v</locus>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="61r" to="61r">61r-61r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0752IHA">توسل بابادر عمر الرضى توسلت بشيخ الابادر</title>
                     <incipit xml:lang="ar">
                        <locus target="#61r">-61r</locus>صلاة وتسليم وازكى تحتة على احمد المختار طه المفخر:
 توسّلت بالشيخ الابادر انه| لما يطلب الانسان فيه بيادن
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#61r ">-61r </locus>وصل وسلم كل يوم وليل| على احمد المختار طه الفاخر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="61v" to="62v">61v-62v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4626IHA">قصيدة لعبد القادر الجيلاني</title>
                     <incipit xml:lang="ar">
                        <locus target="#61v ">-61v </locus>عبد القادر الجيلاني ولي للرحماني<note>Blurred</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#62v">-62v</locus>وكل بلاد الله ملكي حقيقة| وكل ملوك العالمين رعيتي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="62v" to="62v">62v-62v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3669IHA">نظم خاطب المحبوب قلبا</title>
                     <incipit xml:lang="ar">
                        <locus target="#62v">-62v</locus>الله الله الله الله ربنا | رب واجمع في المدينا شملنا|| خاطبا لمحبوب قلبا شجنا| بالاشارات خطابا حسنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#62v">-62v</locus> إن لله عباد فطنا طلقوا الدنيا وخافوا الفتنا | نظروا فيها فلما علموا 
أنها ليست لحي وطنا| جعلوها لجة واتخذوا صالح الأعمال فيها سفنا </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="63r" to="63r">63r-63r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4625IHA">نظم سلام سلام كعد الرمال</title>
                     <incipit xml:lang="ar">
                        <locus target="#63r">-63r</locus>اللهم صل وسلم على حبيب محمد عليه السلام.

سلام سلام كعدا الرمال| على احمد بدر اهل الكمال</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="63v" to="63v">63v-63v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4276IHA">مدح عبد القادر الجيلاني يا قطب الوجود بكم صفا وجودي
                    فعندكم سعودي</title>
                     <incipit xml:lang="ar">
                        <locus target="#63v">-63v</locus>يا قطب يا رباني يا قطب يا رباني الهيكل النوراني عبد القادر الجيلاني
يا جالي الكروب| يا ساتر العيوب| يا جابر القلوب|| عبد القادر 
الجيلاني
ايا قطب الوجود| بكم صفى وجودى| فعندكم سعودي|| عبد القادر الجيلاني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#63v">-63v</locus>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="64r" to="64v">64r-64v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4623IHA">نظم لهي يا ذا العلا والمجد والكبرياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#64r">-64r</locus>شي لله ولي الله شي لله ولي الله شيخ مومن ولي امة المدد ولي الله.

الهي يا ذا العلا| والمجد والكبريا| دائما بلا انتها المدد ولي الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#64v ">-64v </locus>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="64v" to="65r">64v-65r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2802IHA">نظم اسمعوا يا كرام</title>
                     <incipit xml:lang="ar">
                        <locus target="#64v">-64v</locus>نبى سلام على نبى سلام على | محمد نبينا صلى الله على: إسمعو يا كرام| يا معشرالإسلام| نبي خير الأنام|| معارن الشفا| مراتب الوفا| فى جبر المصطفى
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#65r">-65r</locus>واغفر ذنوبنا| وستر عيوبنا| بجاه نبينا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2v" to="2v">2v-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4621IHA">نظم فهو الغوت والغياث ملاذي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>فهو الغوت والغياث ملاذي| وصل ربنا عليه مع سلامي|| وعلى الال والاصحاب جميعا| وبهم اكرمنا بدين الاسلامي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>فهو قصدي وبغيتي ومناء ي| وأسكنا ي في جار خير الانام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i20">
                     <locus from="65v" to="66r">65v-66r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2005IHA">قصيدة قف بذات السفح من اضم</title>
                     <incipit xml:lang="ar">
                        <locus target="#65v">-65v</locus>يا رسول الله سلام عليك يا حبيب الله سلام عليك . قف بذات السفح من اضم| وانشد السارين في ظلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#66r ">-66r </locus>المصطفى منصب الشرفا| ذ الوفا اعلى الورا شرفا|| أحمد المختار والخلفا| شهداء الله فى الأمم
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i21">
                     <locus from="66v" to="66v">66v-66v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4622IHA">نظم تذكر بالمدينة ساكنينا</title>
                     <incipit xml:lang="ar">
                        <locus target="#66v">-66v</locus>صلاة الله على الهاد الامينا امام الانبياء والمرسلينا.
تذكر بالمدينة ساكنينا| نرجع مثل ناقته حنينا</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i22">
                     <locus from="67r" to="68v">67r-68v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3113IHA">نظم أعلمت من ركب البراق عتيما</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="3r" to="3r">3r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2946IHA">نظم بسم الذي انشا الاشياء من عدم</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>باسم الذي انشا الاشيا من عدم |الواحد القادر المريد ذي القدم|| الحمد لله ربى خالق البشر| ثم الصلاة على المهدي الى الامم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>يا من غدا قلبه بالشوق ذا القلق| ودمعه هاملا للوجد ذا سجم
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="3v" to="23r">3v-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>بسم الله الرحمن الرحيم.


ما بال قلبك لاينفك ذا ألم| مذبان اهل الجمى والبيان والعلم| وانهل مد معك القانى بمنسجم


 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="# 23r">- 23r</locus>اغفر لناظمها وارحم مخمسها| ووف قارئها اجرا ودكرسها| واعط سامعها خيرا وحاسبها|| وجد بالبركات واغمر مجالسها يا وافر الفضل والاحسان</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="24v" to="25r">24v-25r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1163IHA">نظم الوهم لا يدركه</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>بسم الله الرحمن الرحيم | الوهم لا يدركه والعجز لا يلحقه فهوه الذي نعبده | جل اله هو هو ايا من على العرش استوى ومن على الملك 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25r">-25r</locus>فى المعاد سواك من أقصده يا راحم الشيب أجر | من حر نار تستعر سواك من مجبره </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="25v" to="25v">25v-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2983IHA">نص الصلاة والسلام الاتمان الاكملان</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>بسم الله الرحمن الرحيم بسم الله والحمد لله والصلاة والسلام الاتمان الاكملان ونبتدى| ببسم الله ونسوق ميعه المولد اعوذ بالله من الشيطان الرجيم 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>وبلغ رسوله النبي الكريم , والحمد لله رب العالمين | ان الله وملئكته يصلون على النبي , يايها الذين امنوا صلوا عليه وسلموا تسليما 
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="25v" to="26v">25v-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0589IHA">سلامات على النبي السلام عليك زين الأنبياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>السلام عليك زين الانبياء السلام عليك| السلام عليك اصفا الاصفياء السلام عليك| السلام عليك احمد يا محمد السلام عليك | السلام عليك طه يا ممجد السلام عليك </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>السلام على علي السامى يقينا السلا عليك |لسلام على اصحابك اجمعين السلام عليك |السلام على الك كلهم والتابعينا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="27r" to="59r">27r-59r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0706IHA">عنوان الشريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>بسم الله الرحمن الرحيم الحمد لله الذى شرف العالمين| بأشرف العالمين |واصطفاه من خلقه أجمعين| ونبأه وءادم بين الماء والطير| ونوه بذكره فى الاخرين والاولين| كما شرف بقدره فى الاخرين| خلق ءادم من سلالة من طين| فما ختمت صدفة جسده الاعلى درة محمد خاتم النبيين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57v">-57v</locus>كيف التصبّر والسلوان عن قمر| موافقي في هواه العجم والعرب
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="57v" to="58v">57v-58v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3785IHA">دعاء ختم المولد الشريف اللهم انا قد حضرنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#57v">-57v</locus>بسم الله الرحمن الرحيم اللهم إنا قد حضرنا قرأة مولد نبيك الكريم فأفض علينا ببركة
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#58v">-58v</locus>اللهم ما قدرت من قضاء وقدر فسلم لنا فيها العقل والدين وافضل الدين وافضل الصلاة والتسليم على اشرف الخلق سيدنا محمد الذي جأ بالحق المبين وأرسلته رحمه للعالمين وعلى اله وصحبه اجمعين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

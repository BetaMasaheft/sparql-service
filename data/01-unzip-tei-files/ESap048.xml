               <msContents>
                  <summary>The Ms. contains the following texts:
 I) Gadla Giyorgis "Vita of
                     George" (fols. 4r-33ra)
 II) Taʾammǝra Giyorgis "Miracles of George": 13
                     miracles (fols. 33ra-68v)</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="68v"/>
                     <title ref="https://betamasaheft.eu/LIT6172DossierGeorge">Hagiographic Dossier of St George of Lydda</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="4r" to="33ra"/>
                        <title ref="https://betamasaheft.eu/LIT1455GadlaG">Gadla Giyorgis "Vita of
                           George"</title>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="33ra" to="68v"/>
                        <title ref="https://betamasaheft.eu/LIT4006Taamme">Taʾammǝra Giyorgis "Miracles of George": 13
                           miracles</title>
                     </msItem>
                  </msItem>
               </msContents>

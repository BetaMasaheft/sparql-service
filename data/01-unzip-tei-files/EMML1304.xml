               <msContents>
                  <summary>Miracles of Mary, ተአምረ፡ ማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                     <title>Miracles of Mary, ተአምረ፡ ማርያም፡</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="2r" to="4v">Fols 2r–4v</locus>
                        <title>Maṣḥafa śerʻat, Introductory rite to the Miracles of Mary
                        </title>
                        <incipit xml:lang="gez">ዝንቱ፡ መጽሐፈ፡ ሥርዓት፡ ዘወጽአ፡ እመንበረ፡ ማርቆስ፡ ሐዋርያ፡ እመካነ፡ መዓልቃ፡ ዘምስር፡
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="4v" to="5v">Fols 4v–5v</locus>
                        <title ref="https://betamasaheft.eu/LIT3058RepCh338">Hymn to Mary, I worship thee</title>
                        <incipit xml:lang="gez">እሰግድ፡ ለኪ፡ እሰግድ፡ ለኪ፡ እሰግድ፡ ለኪ፡ ወእዌድስኪ፡ ኦእግዝእትየ፡ ማርያም፡ ለመርዓዊ፡ ሰማያዊ፡ ጽርሑ።
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="5v" to="6v">Fols 5v–6v</locus>
                        <title>Introductory exhortation to the Miracles of Mary</title>
                        <incipit xml:lang="gez">ንነግርክሙ፡ አኃዊነ፡ ፍቁራነ፡ ውሉደ፡ ቤተ፡ ክርስቲያን፡ እግዚአብሔር፡ ይባርክሙ፡ ወያብርህ፡ አዕይንተ፡ አልባቢክሙ፡ ለሰሚዓ፡ ተአምሪሃ፡ ለእግዝእትነ፡ ማርያም፡ ጥዕምተ፡ ስም፡ ሕይወተ፡ ኵሉ፡ ዓለም፡ ወላዲተ፡ አምላክ። ዘኢይክሉ፡ ፈጽሞ፡ ውዳሴሃ፡ ኢሰማያውያን፡ ወኢምድራውያን።
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="7r" to="52v">Fols 7r–52v</locus>
                        <title>46 Miracles of Mary
                        </title>                        
                     </msItem>
                  </msItem>

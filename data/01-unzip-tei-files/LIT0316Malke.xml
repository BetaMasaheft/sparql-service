         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ ዘአምጽአ፡ ዓለማተ፨</l>
                  <l n="2">ወዘበአርምሞ፡ ፈጠረ፡ ግሩማነ፡ ራእይ፡ ኀይላተ፨</l>
                  <l n="3">መዝራዕተ፡ ክርስቶስ፡ ያሬድ፡ እንዘ፡ ትብል፡ ክሡተ፨</l>
                  <l n="4">ኢያዕረፍከ፡ እምተናፍሮ፡ ወኢረሰይከ፡ ሀኬተ፨</l>
                  <l n="5">እስመ፡ ተሴስይከ፡ ምግበ፡ ነፍስ፡ ማሕሌተ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምስመ፡ ካልኣን፡ ዘተፈቅረ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘበቅብዐ፡ ጸሎት፡ ሠምረ፨</l>
                  <l n="3">መዝራዕተ፡ ክርስቶስ፡ ጳውሎስ፡ መፈክረ፨</l>
                  <l n="4">መጽሐፍ፡ ስዉረ፡ ገዳመ፡ መጒና፡ ሶበ፡ እግርከ፡ ወፈረ፨</l>
                  <l n="5">ደንገጸ፡ ብርያል፡ ወኮነ፡ ሕፋረ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ አመ፡ ሰዱሱ፡ ለኅዳር፨</l>
                  <l n="2">እምነ፡ ቀዳሚ፡ ታዕካ፡ መንገለ፡ ሐዳስ፡ ማኅድር፨</l>
                  <l n="3">መዝራዕተ፡ ክርስቶስ፡ ጥዑም፡ ጸዋውዐ፡ መስቀል፡ መዐር፨</l>
                  <l n="4">ዕቀበነ፡ ለደቂቅከ፡ አባግዐ፡ ያዕቆብ፡ ደብር፨</l>
                  <l n="5">እምነ፡ መሳጢ፡ አርዌ፡ መቅሰፍት፡ ዘሕምዙ፡ መሪር፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">በረቀ፡ ልቡና፡ እለ፡ ጸሐፉ፡ ፊደለ፡ መግባርከ፡ ኵሉ፨</l>
                  <l n="2">ለረኪበ፡ ፍጹመ፡ ዘገዳመ፡ ፍቅርከ፡ ዔሉ፨</l>
                  <l n="3">መዝራዕተ፡ ክርስቶስ፡ ቄድሮስ፡ ለንስረ፡ ንጽሕና፡ ምጽላሉ፨</l>
                  <l n="4">ተበሀሉ፡ ጊዜ፡ ሞትከ፡ ምስለ፡ ካህናቲከ፡ እሉ፨</l>
                  <l n="5">አማን፡ ለጻድቅ፡ ውዳሴ፡ ይደሉ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="129r">1v-129r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0030IHA#s51IHA">تحفة المحتاج بشرح المنهاج, From the beginning of kitāb
          al-ǧināya to the end</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>كتاب الجناية الشاملة للجناية بالجارح وغيره كسحر ومتقل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#129v">-129v</locus>هن الثلث كانفاقه المال في الشهوات فلا يوبّر فيه ذلك بخلاف ما لو اوصى بحجة الاسلام من الثلث وهذا من زيادي في الولد والله اعلم </explicit>
                     <note>Some of the words are divided into two different lines
</note>
                     <note/>
                  </msItem>
               </msContents>

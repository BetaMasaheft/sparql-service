                        <additions>
<list>

<item xml:id="a1">
<locus target="#134v #135r"/>
<desc type="GuestText">The names of the months in different languages.</desc>
<q xml:lang="gez"><seg part="I">ዓዲ፡ በልሳነ፡ ጽርዕ። ታርም፡ ሚያዝያ። ጳጉም፡ ግንቦት። ጲዮን፡ ሰኔ። ኤጳራ፡ ሐምሌ። ሜሴር፡ ነሐሴ። ቲቶ፡ መስከረም።
ታውፊ፡ ጥቅምት። ኣቴር፡ ኅዳር። ኪርቂ፡ ታኅሣሥ። ጦጢ፡ ጥር። ሚካር፡ የካቲት። ሚምንዮስ፡ መጋቢት። ። እጽሕፍ፡ ሠርቀ፡ አውራኂሆሙ፡ ለዕብራውያን፡ ወሮማውያን፡
ወቅብጢ፡ ወዕረቢ፡ ባሕቱ፡ ዓውደ፡ ዓመታቲሆሙ፡ ሊሉያን።</seg></q>
</item>

<item xml:id="a2">
<locus target="#134v #135r"/>
<desc type="GuestText">Distribution of the races springing from the sons of Noah.</desc>
<q xml:lang="gez"><seg part="I">ውሉደ፡ ያፌት፡ ፲ወ፭ነገድ፡ ወመክፈልቶሙ፡ ኮነ፡ ምድረ፡ የማን፡ ወመንፈቀ፡ ምዕራብ።</seg></q>
</item>

<item xml:id="a3">
<locus target="#134r"/>
<desc type="GuestText"><title type="incomplete" ref="https://betamasaheft.eu/LIT2228Ruleso">Rules of Pachomius<foreign>ግብረ፡ አበው፡ ዘመንኮሳት፡</foreign></title></desc>
<q xml:lang="gez"><seg part="I">ይቤ፡ ፩እምአበው፡ ቅዱሳን፡ ተዘኪሮ፡ ድሪተ፡ ዓለም፡</seg></q>
</item>

<item xml:id="a4">
<locus target="#2v"/>
  <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
          <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
      <q xml:lang="gez">ዜና፡ አበው፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName></q>
</item>

<item xml:id="a5">
<locus target="#1r"/>
<desc type="GuestText">Comparison of the lights of heaven</desc>
<q xml:lang="gez"><seg part="I">ምሳሌ፡ ዘሚጠተ፡ ብርሃንተ፡ ሰማይ። ፀሐይ፡ ይትሜሰል፡ በእግዝእነ፡ ኢየሱስ፡ ክርስቶስ፡ ፀሐየ፡ ጽድቅ።</seg></q>
</item>

<item xml:id="a6">
<locus target="#1r"/>
<desc type="GuestText">The names of the months in different languages.</desc>
</item>

<item xml:id="e1">
<locus target="#2r #133v"/>
<desc>The name of the first owner has been erased, and those
of <persName role="owner" ref="https://betamasaheft.eu/PRS13522NasaraAb">Naṣṣara ʾAb<foreign xml:lang="gez">ነጸረ፡ አብ፡</foreign></persName> and <persName role="owner" ref="https://betamasaheft.eu/PRS13523WalattaLeul">Walatta Lǝʿul<foreign xml:lang="gez">ወለተ፡ ልዑል፡</foreign></persName> substituted.</desc>
</item>

</list>

                        <incipit xml:lang="gez">በጸጋ፡ እግዚአብሔር፡ ዘከመ፡ እፎ፡ መፍትው፡ ይእመኑ፡ በእንተ፡ ተሠግዎቱ፡
                  ወተሰብኦቱ፡ ለወልደ፡ እግዚአብሔር፡</incipit>
                        <colophon xml:id="coloph2" xml:lang="gez">ከመዝ፡ የአምን፡ ወይጸሊ፡ በእንቲአየ፡ ለትሑት፡ ዘተርጐሞ፡ ለዝ፡ መጽሐፍ፡
                  ወጸሐፎ፡ ወዘከመዝ፡ ኢየአምን፡ ውጉዘ፡ ለይኩን፡ በከመ፡ ጽሑፍ።</colophon> 
                        
                     </msItem>
                
                     <msItem xml:id="ms_i2.4">
                        <locus from="344v"/>
                        <title type="incomplete">First two chapters of the <foreign xml:lang="la">Expicatio duodecim capitum</foreign>
                        </title> 
                        
                        <incipit xml:lang="gez">፷ወ፩፡ ፍካሬ፡ ግዘት። ኵሉ፡ ቅድሜሆሙ፡ ውእቱ፡ ለእለ፡ ይሌብዉ፡ ወርቱዕ፡ ውእቱ፡ ለእለ፡
                  ይረክቡ፡ አእምሮ።</incipit>
                     </msItem>
                
                     <msItem xml:id="ms_i2.5">
                        <locus from="347r"/>
                        <title xml:lang="gez" ref="https://betamasaheft.eu/LIT2220Refuta">
                           <certainty locus="value" match="../@ref" cert="low"/>
                           ዝልፈት፡ ወተጋብኦ፡ በእንተ፡ ዘኬልቄዶን፡ ሥርዐት፡
                  ከመ፡ ያእምሩ፡ እለ፡ ያነብብዎ፡ ከመ፡ ወኢምንትኒ፡ ካልእ።</title>
                        <note>Summary of the Acts and Definitions of the council of Chalcedon. <persName ref="https://betamasaheft.eu/PRS10747Zotenbe">Hermann Zotenberg</persName>
                    suggests <persName ref="https://betamasaheft.eu/PRS9523Timothy">Timothy III</persName> as a possible author.</note>
                        <incipit xml:lang="gez">ትእዛዝ፡ እንተ፡ በኬልቄዶን፡ ሲኖዶስ፡ እንተ፡ ዘእንበለ፡ 
                           <persName ref="https://betamasaheft.eu/PRS7553Nestoriu">ንስጥሮስ</persName>፡ ምኑን፡ ሥርዐት፡ ይቁም፡
                  ወይሰበክ፡ ውስተ፡ ኵሉ፡ አብያተ፡ ክርስቲያናት፡ እንዘ፡ እግዚአብሔር። እስመ፡ ከመዝ፡ ትብል፡ ቅድስት፡ እንተ፡
                  ኵሉ፡ ዓለም፡ ሲኖዶስ፡ እንተ፡ በእግዚአብሔር፡ ሞገስ፡ ወትእዛዝ፡ ለእለ፡ ሠናየ፡ አምልኮ። ወመፍቅራነ፡
                  ክርስቶስ፡ ነገሥትነ፡ ወሌኔጢያኖስ፡ ወ<persName ref="https://betamasaheft.eu/PRS6713Marcian">መርቅያኖስ</persName>፡ ተጋቢአ፡ 
                           በኬልቄዶን፡</incipit>
                     </msItem>
              
                <msItem xml:id="ms_i2.6">
                   <locus from="252vb" to="254rb"/>
                   <title ref="https://betamasaheft.eu/LIT6969Anathemas">Anathemas of the 12 bishops composed after the excommunication of Nestorius</title>

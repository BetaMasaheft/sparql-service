                     <msItem xml:id="ms_i2.1">
                        <locus from="323r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1785Letter">መጽሐፈ፡ <persName ref="https://betamasaheft.eu/PRS9523Timothy">ጢሞቴዎስ፡</persName>
                           ሊቀ፡ ጳጳሳት፡
                  ዘእልስክንድርያ፡ እንተ፡ ተጽሕፈት፡ እምጋንግራ፡ እልስክንድርያ፡ ርቱዓነ፡ ሃይማኖት፡ በእንተ፡ 
                  ዕልዋን፡ እለ፡ ኢየአምኑ፡ ዕሩየ፡ ፍጥረት፡ ለነ፡ ይኩን፡ በሥጋ፡ ዘለአብ፡ ዕሩየ፡ ህላዌ፡ በመለኮት።
                  </title>
                        <incipit xml:lang="gez">
                           <persName ref="https://betamasaheft.eu/PRS9523Timothy">ጢሞቴዎስ፡</persName> ለፈራህያነ፡ እግዚአብሔር፡ ወመምላክያነ፡ እግዚኣብሔር፡ ርቱዓነ፡ 
                           ሃይማኖት፡ ኤጲስ፡
                    ቆጶሳት፡ ቀሳውስት፡ ወዲያቆናት፡ ወሄጲዲያቆናት፡ አናጕኖስጢስ፡ አበው፡ መነኮሳት፡ ወለኵሎሙ፡
                    ታእኃ፡ ደናግል፡ ወለኵሉ፡ ርቱዓነ፡ ሃይማኖት፡ ሕዝብ፡ ዘእግዚኣብሔር፡ ፍሥሐ፡ ቅዱስ፡ ሐዋርያ፡
                    ዘእግዚኣብሔር፡ ንጹሐ፡ ተቀንየ። ዘቦቱ፡ እግዚኣብሔር፡ ተናገረ፡ እንዘ፡ ይሜህረነ፡ ፍኖተ፡ መድኀኒት፡
                    እንዘ፡ ይልእክ፡ ይቤ፡ ናሁ፡ ንጽሕፍ፡ ለ<choice>
                              <sic resp="DR">ከ</sic>
                              <corr resp="DR">ክ</corr>
                           </choice>ሙ፡ ሊተሰ፡ ኢመሐኪ፡ ወለክሙሰ፡ ጽኑዕ። ዑቁ፡ ከለባት፡ ዑቁ፡
                    እኩያነ፡ ግዕዝ፡ ዑቁ፡ መተርተ፡ ዑቁ፡ እለ፡ ይመትሩ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘኢይትከፈል፡
                    አንትሙ፡ እንከ፡ ውእቱ፡ ግዝረት፡ እለ፡ በመንፈሰ፡ እግዚኣብሔር፡ ወትትሜክሑ፡ በክርስቶስ፡ ኢየሱስ፡
                    ወኢበሥጋ፡ ዘትትዌከሉ፡  <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </incipit>

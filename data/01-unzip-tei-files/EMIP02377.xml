               <msContents>
                  <summary>Dawit in Mahdar</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="118v" facs="005">Fols 1r–118v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="94v" facs="005">Fols 1r–94v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note>Incomplete at the end</note>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="96r" to="104v" facs="100">Fols 96r–104v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note>Incomplete at the beginning</note>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="105r" to="109v" facs="109">Fols 105r–109v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4">
                    <locus from="110r" to="116v" facs="114">Fols 110r–116v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <note>Arranged for the days of the week. Incomplete at the beginning. The work ends with Saturday, so it is possible that the work began with Sunday and these folios have been lost</note>

                  <msItem xml:id="ms_i1.4.1">
                    <locus from="110r" facs="114">Fols 110r and following</locus>
                    <title>Monday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.2">
                    <locus from="110v" facs="116">Fols 110v and following</locus>
                    <title>Tuesday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.3">
                    <locus from="111v" facs="116">Fols 111v and following</locus>
                    <title>Wednesday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.4">
                    <locus from="113r" facs="117">Fols 113r and following</locus>
                    <title>Thursday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.5">
                    <locus from="115r" facs="119">Fols 115r and following</locus>
                    <title>Friday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.6">
                    <locus from="116r" facs="120">Fols 116r and following</locus>
                    <title>Saturday</title>
                  </msItem>
                </msItem>

                  <msItem xml:id="ms_i1.5">
                    <locus from="116v" to="118v" facs="121">Fols 116v–118v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                    <note>Folios are missing from the middle of the work</note>
                  </msItem>
                </msItem>

                  </msContents>

                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>Columetric layout of text: the folios containing the most common occurrences of columetric layout have all been lost</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#ivr(ecto)" facs="004">Fol. ivr(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> holding books</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#22r" facs="026">Fol. 22r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#22v" facs="027">Fol. 22v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#33r" facs="037">Fol. 33r</locus><desc>crude drawing of an <term key="angel" ana="#angel"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#95r" facs="099">Fol. 95r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John stand beside the cross</desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#95v" facs="100">Fol. 95v</locus><desc>Wrapping the body of <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> in a shroud</desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#117r" facs="121">Fol. 117r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#117v" facs="122">Fol. 117v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1039Magi">The Three Magi</ref></desc></decoNote>
                    <decoNote type="frame" xml:id="d12">
                    Decorative designs:
                    <locus target="#7v #13r #24r #32r #46r #58v #62r #72v #86r #91r #104v #111r #115r" facs="012 017 028 036 050 063 066 077 090 095 109 115 119">folss. 7v, 13r, 24r, 32r, 46r, 58v, 62r, 72v, 86r, 91r, 104v, 111r, 115r, </locus> (line of alternating red and black dots);
                    <locus target="#40 #113r #115r #116r #118v" facs="044 117 119 120 123">40, 113r, 115r, 116r, 118v</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc type="Asmat">
                    <locus target="#iv(erso)" facs="002"> f. iv(erso), col. 1</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="GuestText">
                    <locus from="iv(erso)" facs="002"> f. iv(erso), col. 2</locus><locus to="iiv(erso)"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3123Calend">Calendar of saints,
                                                  arranged according to their feast day</title>, arranged according to their feast day
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="Asmat">
                    <locus target="#iiv(erso)" facs="003"> f. iiv(erso), bottom</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#118v" facs="123"> f. 118v, upper col. 2</locus>
                    An Account of the Books of the Bible, <foreign xml:lang="gez">ኍልቈ፡ መጻሕፍት፡ ቅዱሳት፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    <locus from="118v" facs="123"> f. 118v, bottom col. 2</locus><locus to="119r"/>
                    prayer written in a secondary hand
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc type="GuestText">
                    <locus target="#119v" facs="124">Fol. 119v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5125MagicPrayer">ṣalot baʾǝnta
                                                  ʾarāwita mədr</title>
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <desc>
                    On the maḥdär, there is a small text about Mary, “the maḥdär of divinity.”
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Folios are missing throughout the manuscript
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    In several sections of the book, the number 10 (<foreign xml:lang="gez">፲</foreign>) or the letter <foreign xml:lang="gez">ዝ</foreign> marks every tenth line, as though an audit of the strophes were being performed
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    Many folios have pen trials and writing exercises in the margins (e.g., <locus target="#61r #72v" facs="065 077">fols. 61r, 72v</locus>).
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    illegible text
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    Folio 40 has been inserted to replace a lost folio
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#49r" facs="053">Fol. 49r</locus>
                    The midpoint of the Psalms is not marked
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <desc type="OwnershipNote">
                    <locus target="#118v" facs="123"> f. 188v, middle col. 2</locus>
                    note of ownership. The name of the owner has been erased. Includes a curse against anyone who would steal or deface the book
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <desc>
                    <locus target="#37" facs="041">Fol. 37</locus>
                    black thread stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                    <locus target="#58" facs="062">Fol. 58</locus>
                    yellow and red thread stitched into fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <desc>
                    <locus target="#72 #73 #75 #83" facs="076 077 079 087">Fols. 72, 73, 75, 83</locus>
                    white thread stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e10">
                    <desc>
                      words of text are written interlinearly (<locus target="#3r #4r #10v #14v #17v" facs="007 008 015 019 022">folss. 3r, 4r, 10v, 14v, 17v, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#11v #97v" facs="016 102">11v, 97v, </locus>);
                      erasure markings are visible (<locus target="#5r #16v #17r #20r #23r" facs="009 021 024 027">5r, 16v, 17r, 20r, 23r, </locus>, etc.);
                      text has been removed (<locus target="#10v #30r #33r #40r #45r" facs="015 034 037 044 049">10v, 30r, 33r, 40r, 45r</locus>, etc.).
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, back cover has broken and been repaired, rebound with stab stitch.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

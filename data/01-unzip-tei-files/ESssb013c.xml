               <msContents>
                  <summary>ʾArbāʿtu wangel “Four Gospels”, fragment 
 I) Canon tables (fols.
                     1r-4v), incomplete
 - Canon table III (fols. 1r-1v)
 - Canon table I
                     (fols. 2r)
 - Canon table II (fol. 2v)
 - Canon table IV (fols. 3r,
                     3v)
 - Canon table II (fol. 4r)
 - Canon table III (fol. 4v).</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>
                        <locus target="#1r">1r</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, brown, black) canon table.</note>
                     <note>
                        <locus target="#1v">1v</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, brown, black) canon table.</note>
                     <note>
                        <locus target="#2r">2r</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, brown, black) canon table.</note>
                     <note>
                        <locus target="#2v">2v</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, brown, black) canon table.</note>
                     <note>
                        <locus target="#3r">3r</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, orange, black) canon table.</note>
                     <note>
                        <locus target="#3v">3v</locus>: Skillfully decorated, coloured (red, yellow,
                        blue, green, orange, black) canon table.</note>
                     <note>
                        <locus target="#4r">4r</locus>: Skillfully decorated, coloured (red, yellow,
                        blue) canon table.</note>
                     <note>
                        <locus target="#4v">4v</locus>: Skillfully decorated, coloured (red, yellow,
                        blue) canon table.</note>
                     <note>The decoration reminds of the so-called Gunda Gunde style.</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">4.0</measure> folios, in <measure unit="quire"/> quires . <dimensions type="outer">
                              <height unit="mm">320</height>
                              <width unit="mm">270</width>
                              <depth unit="mm">3</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">The quire structure cannot be established due to the
                                 condition of the Ms.</item>
                           </list>
                        </collation>
                        <condition key="deficient">Four separate leaves from the "traditional
                           introduction" of a Four Gospels book, held together by means of parchment
                           guards and leather strips. 
 The fols. are affected by water.
                           The upper and lower part of all fols. has been cut off, which results in
                           minor text loss in <locus target="#2r">2r</locus>, 2v, 3r, 3v, 4v.
                           All fols. are damaged along the edges.
 The fols. are misplaced, the
                           correct order is: 2r, 2v, 4r, 4v, 1r, 1v, 3r, 3v.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout>
                           <dimensions unit="mm">
                              <height/>
                              <width/>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top"/>
                              <dim type="bottom"/>
                              <dim type="right"/>
                              <dim type="left"/>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <note/>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible.</ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern: 1A-1A/0-0/0-0/C
                              (?).</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine and regular.</seg>
                        <seg type="ink">Black; red (vivid vermillion) for the lines.</seg>
                        <date>First half of the 16th century (?)</date>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Archaic
                        features:</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> - form of 'one' (፩, triangular
                        upwards-oriented)</handNote>
                     <handNote xml:id="h4" script="Ethiopic"> - form of 'four' (፬, triangular
                        downwards-oriented)</handNote>
                     <handNote xml:id="h5" script="Ethiopic"> - form of 'six' (፮, looking like
                        "compressed" number
                        'seven')</handNote>
                     <handNote xml:id="h6" script="Ethiopic"> - the characters ወ, መ, ሠ are often
                        formed on a slant, the lower left side extends to the base line while the
                        upper right part extends to the upper
                        limit.</handNote>
                  </handDesc>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Both boards are missing. 
 Two pairs of sewing
                           stations (<locus from="2v" to="3r">2v-3r</locus>).</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial"/>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">The fols. are reinforced on the spine
                           with parchment guards, attached by means of chains of leather
                           strips.</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>

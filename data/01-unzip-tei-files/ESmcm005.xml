                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>18th century</date>
                        <seg type="rubrication">Nomina sacra; incipit of Texts I-1, I-2, I-3, I-4;
                           titles and numbers of each Ps., canticle or chapter; names of the Hebrew
                           letters in Ps. 118; incipit of sections of Text I-4; elements of the
                           punctuation signs and text dividers; elements of Ethiopic numerals.
                           On the incipit page of Text I-4 (fols. 176r), few lines are rubricated
                           (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>

      <body>
          <div type="edition" xml:lang="gez" xml:id="malkeagubae">
              <note>This edition is taken from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
              
              
              <div type="textpart" xml:id="malke">
                  
                  <lg type="stanza" n="1">
                      
                      <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አምላክ፨</l>
                      <l n="2">እንዘ፡ ኣአምን፡ ወአመልክ፡ እንበለ፡ ትአውሳክ፨</l>
                      <l n="3">እክሕደከ፡ ሰይጣን፡ አርዌ፡ ተመንግኖ፡ ድሩክ፨</l>
                      <l n="4">በቅድመ፡ ዛቲ፡ ቤተ፡ ክርስቲያን፡ መንፈሳዊት፡ ምስማክ፨</l>
                      <l n="5">እንተ፡ ይእቲ፡ ማርያም፡ ዳግሚት፡ ፈለክ፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="2">
                      
                      <l n="1">ኣአምን፡ በአብ፡ እምወልዱ፡ ዘኢቀደመ፡ ዘመነ፨</l>
                      <l n="2">ወኣአምን፡ በወልድ፡ ምስለ፡ ወላዲሁ፡ ዘየኀብር፡ ሥልጣነ፨</l>
                      <l n="3">ወኣአምን፡ በመንፈስ፡ ቅዱስ፡ እንተ፡ ዘአልቦቱ፡ ፍልጣነ፨</l>
                      <l n="4">እንዘ፡ ኣአምን፡ ከመዝ፡ አሐደ፡ ከዊነ፨</l>
                      <l n="5">ወእምዝ፡ እወጥን፡ ድርሳነ፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="3">
                      
                      <l n="1">ሰላም፡ ለህላዌክሙ፡ ዘኢይትበሀል፡ ዘመኑ፨</l>
                      <l n="2">እምዝየ፡ ምውጣኑ፡ ወእስከ፡ ዝየ፡ ወሰኑ፨</l>
                      <l n="3">ህላዌክሙ፡ ሥላሴ፡ እምዘተፈጥሩ፡ ወኮኑ፨</l>
                      <l n="4">እምሰብእ፡ ወመላእክት፡ ዘየአምር፡ መኑ፨</l>
                      <l n="5">እስመ፡ ክዋኔሁ፡ ምሥጢር፡ ወኅቡእ፡ ሥልጣኑ፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="4">
                      
                      <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ መሠረተ፡ ኵሉ፡ ዓለም፨</l>
                      <l n="2">ወስመ፡ መሀላሁ፡ ግሩም፨</l>
                      <l n="3">ሥሉስ፡ ቅዱስ፡ ኀይላተ፡ አርያም፨</l>
                      <l n="4">ይኩነኒ፡ ዝክረ፡ ስምክሙ፡ አርአያ፡ ሐጹር፡ ወጥቅም፨</l>
                      <l n="5">ብአድኅር፡ ወበፍጽም፡ በይምን፡ ወበፅግም፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="5">
                      
                      <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስክሙ፡ አምሳለ፡ በረድ፡ ወፀምር፨</l>
                      <l n="2">ጸዐድዒደ፡ ራእይ፡ ወሕብር፨</l>
                      <l n="3">ሥሉስ፡ ቅዱስ፡ ሥሉጣነ፡ ሰማያት፡ ወምድር፨</l>
                      <l n="4">ጊዜ፡ ኣቄርብ፡ ውዳሴ፡ ለንግሥክሙ፡ ክቡር፨</l>
                      <l n="5">በሉኒ፡ አደመነ፡ ቃልከ፡ ፍቁር፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="45">
                      
                      <l n="1">ሰላም፡ ለመልክእክሙ፡ ዘኢይትከሀል፡ ለተርጕሞ፨</l>
                      <l n="2">እመልክአ፡ መልአክ፡ ወሰብእ፡ በበ፡ ግጻዌሁ፡ ዘሤሞ፨</l>
                      <l n="3">ሥሉስ፡ ቅዱስ፡ ህልዋን፡ በተሳልሞ፨</l>
                      <l n="4">ለመልክእክሙ፡ ለለ፡ ጊዜ፡ እጼውዕ፡ ስሞ፨</l>
                      <l n="5">ውስተ፡ መልክእየ፡ አንብሩ፡ ማሕተሞ፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="46">
                      
                      <l n="1">በአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ተማሕፀንኩ፨</l>
                      <l n="2">በስመ፡ ሥላሴ፡ አምለኩ፨</l>
                      <l n="3">እምከርሠ፡ እምየ፡ በኀይለ፡ ሥላሴ፡ ጸናዕኩ፨</l>
                      <l n="4">እመኒ፡ ሞትኩ፡ ወሐየውኩ፡ በምክረ፡ ሥላሴ፡ አስመኩ፨</l>
                      <l n="5">በእደ፡ ሥላሴ፡ ነፍስየ፡ ወሥጋየ፡ ገደፍኩ፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="47">
                      
                      <l n="1">አብ፡ በአካሉ፡ ወልድ፡ በአካሉ፨</l>
                      <l n="2">ወመንፈስ፡ ቅዱስ፡ በአካሉ፨</l>
                      <l n="3">በሰማይ፡ ወበምድር፡ ህልዋን፡ በውስተ፡ ኵሉ፨</l>
                      <l n="4">በአፍአ፡ ወበውሥጥ፡ አመልክ፡ ለኵሉ፨</l>
                      <l n="5">አኰቴት፡ ወክብር፡ ለሥሉስ፡ ይደሉ፨</l>
                      
                  </lg>
                  
              </div>
              
              <div type="textpart" xml:id="tarafa-malke">
                  
                  <lg type="stanza" n="1">
                      
                      <l n="1">ስብሐት፡ ለክሙ፡ ሥሉስ፡ ቅዱስ፡ ዘበአሐቲ፡ ሥምረት፨</l>
                      <l n="2">ብክሙ፡ ቆመ፡ ሥነ፡ ፍጥረታት፨</l>
                      <l n="3">በምድር፡ ወበሰማያት፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="4">
                      
                      <l n="1">ስብሐት፡ ለክሙ፡ ሥሉስ፡ ቅዱስ፡ ዘበአሐቲ፡ ምልክና፨</l>
                      <l n="2">ባሕረ፡ ኤርትራ፡ ተከፍለት፡ ከመ፡ ትኩን፡ ፍና፨</l>
                      <l n="3">እስከ፡ ቃዴስ፡ ለሕዝበ፡ ሲና፨</l>
                      
                  </lg>
                  
                  <lg type="stanza" n="5">
                      
                      <l n="1">ስብሐት፡ ለክሙ፡ ሥሉስ፡ ቅዱስ፡ ዘትወልዱ፡ ሕይወተ፨</l>
                      <l n="2">ኵሎ፡ አዝማነ፡ ወዕለታተ፨</l>
                      <l n="3">ረድኤተክሙ፡ ትፈንዉ፡ ሊተ፨</l>
                      <l n="4">ቅድሜክሙ፡ እጼሊ፡ ጸሎተ፨</l>
                      
                  </lg>
                  
              </div>
              
          </div>
          
          <div type="edition" xml:lang="gez" xml:id="emip764">
            <note>the text follows <ref type="mss" corresp="https://betamasaheft.eu/EMIP00764">Ḉäläqot, Č̣alaqot Śǝllāse, Chelekot Silasie 23</ref> ff. 40r-43r</note>
            <div type="textpart" subtype="incipit" xml:lang="gez">
              <ab>
                በስመ፡ አብ፡ <gap reason="ellipsis"/>
                እንዘ፡ አአምን፡ ወአመልክ፡ እንበለ፡ ተውሳክ፡ እክሕደከ፡ ሰይጣን፡ አርዌ፡ ተመንግኖ፡ ድሩክ።
                በቅድመ፡ ዛቲ፡ ቤተ፡ ክርስቲያን፡ መንፈሳዊት፡ ምስማክ።
                እንተ፡ ይእቲ፡ ማርያም፡ ዳግሚት፡ ፈለክ።
                አአምን፡ በአብ፡ እምወልዱ፡ ዘኢቀደመ፡ ዘመነ።
                ወአአምን፡ በውልድ፡ ምስለ፡ ወላዲሁ፡ ዘየኃብር፡ ሥልጣነ።
                ወአአምን፡ በመንፈስ፡ ቅዱስ፡ እንተ፡ ዘአልቦቱ፡ ፍልጣነ።
              </ab>
            </div>
            <div type="textpart" subtype="explicit" xml:lang="gez">
              <ab>
                ስብሐት፡ ለክሙ፡ ሥሉስ፡ ቅዱስ፡ ዘትወልዱ፡ ሕይወተ፡ ኵሎ፡ አዝማነ፡ ወዕለታተ።
                ረድኤተክሙ፡ ተፈንዉ፡ ሊተ።
                ቅድሜክሙ፡ እጼሊ፡ ጸሎተ።
              </ab>
            </div>
          </div>
        
      </body>

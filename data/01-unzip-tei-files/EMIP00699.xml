                  <msItem xml:id="ms_i1.6"><locus from="124r" to="127v" facs="130"/><title>On the Holy Communion</title>
                  <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz and Amharic</textLang>
                  <note>incomplete at the end</note>
                  </msItem>
                </msItem>

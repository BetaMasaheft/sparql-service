               <msContents>
                  <summary>Collection of Chants called Mästägabǝ’</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="53v" facs="003">Fols 3r–53v</locus>
                    <title>Collection of Chants called Mastagab'a, with musical notation</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1">
                    <locus from="3r" to="21r" facs="003">Fols 3r–21r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">, arranged for the days of the week, starting with the (usually oral) introductory prayer for the Praises of Mary</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="21r" to="29v" facs="021">Fols 21r–29v</locus>
                    <title>Mästägabǝ’, <foreign xml:lang="gez">መስተጋብዕ፡</foreign>, arranged for the days of the week</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="29v" to="36r" facs="030">Fols 29v–36r</locus>
                    <title>Chants called Arba’ǝt, <foreign xml:lang="gez">አርባዕት</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.4">
                    <locus from="36r" to="48r" facs="036">Fols 36r–48r</locus>
                    <title>Chants called Śäläst, <foreign xml:lang="gez">ሠለስት፡</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.5">
                    <locus from="48r" to="53v" facs="048">Fols 48r–53v</locus>
                    <title>Chants called Aryam, <foreign xml:lang="gez">አርያም፡</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                </msItem>

               </msContents>

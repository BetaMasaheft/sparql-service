      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ዘበሕገ፡ አብርሃም፡ አብ፨</l>
                  <l n="2">ወለልደትከ፡ ኅሩይ፡ እምልደተ፡ አበው፡ ሕዝብ፨</l>
                  <l n="3">ስብሐት፡ ለአብ፡ ሰሎሞን፡ መሠረተ፡ ኵሉ፡ ጥበብ፨</l>
                  <l n="4">ናሁ፡ ያሰርኀኒ፡ ዜና፡ ግብርከ፡ ዕጹብ፨</l>
                  <l n="5">ለሕፃነ፡ ልብየ፡ እስመ፡ አልሐቆ፡ ፍቅርከ፡ ሐሊብ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ቃለ፡ ስብሐት፡ ወዝማሬ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ጥሉለ፡ ቅብአ፡ ዘይት፡ ፍካሬ፨</l>
                  <l n="3">ስብሐት፡ ለአብ፡ ዮሴፍ፡ ፍሬ፡ ብርከ፡ ያዕቆብ፡ ኅሬ፨</l>
                  <l n="4">አብሐኒ፡ እቅስም፡ ኵለሄ፡ እምጣዕመ፡ ዝማሬከ፡ ፍሬ፨</l>
                  <l n="5">ወአሠርግወኒ፡ ካዕበ፡ ኀይለ፡ ቃል፡ ጶዴሬ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ካህናት፡ ኄራን፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ መቃብረ፡ አበው፡ ጻድቃን፨</l>
                  <l n="3">ስብሐት፡ ለአብ፡ ኢያሱ፡ ዘሕዝበ፡ እስራኤል፡ መስፍን፨</l>
                  <l n="4">ተአዘዝከ፡ ታቅም፡ እግዚኦ፡ ሰኰና፡ ፀሓይ፡ ኪዳን፨</l>
                  <l n="5">እምእግዚአብሔር፡ ስኩር፡ በስብሐት፡ ወይን፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ተወከፍ፡ ማሕሌትየ፡ ከመ፡ ኢይሑር፡ በበክ፨</l>
                  <l n="2">ውስተ፡ ፍና፡ ቤቱ፡ ግሩም፡ ለመልአከ፡ ሞት፡ ድሩክ፨</l>
                  <l n="3">እንበለ፡ ኢትበል፡ ሕቀ፡ ስብሐት፡ ለአብ፡ አምላክ፨</l>
                  <l n="4">ወአዕርግ፡ ጸሎትየ፡ በሰዓተ፡ ጽባሕ፡ ወሰርክ፨</l>
                  <l n="5">ህየንተ፡ ሱራፊ፡ ካህን፡ ወኪሩብ፡ መልአክ፨</l>
               </lg>
            </div>
         </div>
      </body>

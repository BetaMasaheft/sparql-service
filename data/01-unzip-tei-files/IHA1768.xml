                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA1768#ms_i0">
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS2936IHA">عبد الرحيم شيخ بن عبد الرازق بن عبد الرحمن بن محسن</persName>
                     </handNote>
                     <handNote xml:id="h1" script="Arabic" corresp="https://betamasaheft.eu/IHA1768#ms_i1"/>
                  </handDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a3_6527">
                           <locus target="#352r">-352r</locus>
                           <q xml:lang="ar">تمت المصحف المبارك واتفق الفراغ من نساخته ىوم السبت فى سهر دو العقده \ [احد] \ نهار ١١ \ احد عس \ احدى عشر \ بيد الحقير الفقير المدنب الراحى عفو رىه الكرىم عىد الرحىم سىح ابن سىح عبد الراىق بن سىح عبم الرحمن بن سىح محسن غفر الله لوالدىه وحمىع المسلمىن</q>
                           <desc>Colophon</desc>
                           <note>The date consists of only month and day. The day is given in digits and in words.</note>
                           <note/>
                        </item>
                        <item xml:id="a0_6527">
                           <locus target="#2v">-2v</locus>
                           <q xml:lang="ar">كلام قديم لا يمل سماوه , تنزه عن [قولى] وفعلي ونيتي \ [به] استشفي من كل دا ونوره , دليل قلبي عند جهلي وحيرتي \ فيا رب فرحنا بسر ح روفه [كذا] , ونور به سمعي وقلبي ومقلتي </q>
                           <desc>Marginalia</desc>
                           <note>
                              <desc>
                                 َQuotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT0240IHA">نظم كلام قديم</ref>
                              </desc>
                              <desc>
                                 َQuotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT0240IHA">نظم كلام قديم</ref>
                              </desc>
                           </note>
                        </item>
                        <item xml:id="a1_6527">
                           <locus target="#2v-3r">-2v-3r</locus>
                           <q xml:lang="ar">Multiple frames; panels with floral and geometric ornamentation in red, black and white. </q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a2_6527">
                           <locus target="#351v">-351v</locus>
                           <q xml:lang="ar">تم كلمات ربك صدقا وعلدا لا مىدل لكلماته وهو السمىع العليىم \ صدق الله العطىم وىلع رسوله الىىى الكرىم والحمد لل رب العلمىن \ وصلى الله على سىدنا محمد واله وصحىه وسلم تسلىما</q>
                           <note/>
                        </item>
                        <item xml:id="a4_6527">
                           <locus target="#352r">-352r</locus>
                           <q xml:lang="ar">احىم لنا ىالسعد عند مماىىا ووسع لنا ىا رب فى طلمه القبر \ ويسر لنا من كل حىر ىحىه فاىحار وعد ىم عدم ىلا عدن </q>
                           <note>Written on along the frame of the colophon. Most of the diacritics missing.</note>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a5_6527">
                           <locus target="#352r">-352r</locus>
                           <q xml:lang="ar">اللهم اغفر لكاىىه ولمالكه ولقارىه ولساععه ولناظره ولمن حضر عند قاراته [.؟.] ولحمىع المسلمىن والمسلمات ولمومنىن والمومىات الاحىا مىهم والاموات انك المجيب الدعاوات بفضلك ورحمتك يى ارحم الرحامىن \ وصلى الله على سىدىا وعلى اله وصحىه وسلم ىسلىما كىىرا كىىرا</q>
                           <note/>
                        </item>
                     </t:list>
                  </additions>

         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ፍሬ፡ ጽዮን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Fǝre Ṣǝyon</t:persName>

               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">artist</t:occupation>

               <t:floruit notBefore="1430" notAfter="1470">He was an Ethiopian painter from
                  the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2279DabraG">
                  Dabra Gʷǝgʷǝben</t:placeName> on the lake <t:placeName ref="https://betamasaheft.eu/LOC5888Tana">Ṭānā</t:placeName>
                  during the reign of King <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</t:persName>.
                  He painted a series of devotional images of Our lady
                  <t:persName ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName> for King
                  <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</t:persName>.
                  He was also working with a theologian <t:persName ref="https://betamasaheft.eu/PRS10472Yostino">Yostino</t:persName>
                  in the court of  King <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</t:persName>
                  at <t:placeName ref="https://betamasaheft.eu/LOC2246DabraB">Dabra Bǝrhan</t:placeName>
               </t:floruit>

            </t:person>
            
         </t:listPerson>




                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="1r" to="80rb"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1824Mafteh">Maftǝḥe śǝrāy</title>
                          <textLang mainLang="gez" otherLangs="am"/>
                          <msItem xml:id="ms_i1.1">
                            <locus from="1r" to="5v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4007Salotb">Ṣalot baʾǝnta maftǝḥe śǝrāy</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላ</hi>ክ፡ ጸሎት፡ በእንተ፡ መፍትሔ፡
                              ሥራይ፡ ዘተቀድ<hi rend="rubric">ሐ፡ እም፹ወ፩መጻሕፍት፡ ዘወጽአት፡ እምኤሩ</hi>ሳሌም፡ ዘሞዖሙ፡
                              ለመሠርያን፡ ወነሀብያን፡
                              ወደጋምያን፡ ለአረሚ፡ ወክርስቲያን፡ ዘፈትሐ፡ ቆጵርያኖስ።
                            </incipit>
                            <note>The collection of magic texts is organized in smaller
                            sub-collections in the manuscript. Some of the texts are accompanied
                          with the directions for their use.</note>
                          </msItem>
                          <msItem xml:id="ms_i1.2">
                            <locus from="5v"/>
                            <title type="complete" xml:lang="en">Collection of magic prayers</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              <hi rend="rubric">ጸሎተ፡ ፍትሐት፡ ሌዊ፡ ሌዊ፡ ሌዊ፡ ሌዊ፡ ሌዊ፡ ሌዊ፡</hi>
                              ሐጀር፡ ሪማና፡ ፍታሕ፡ ታድሪ፡ ጣዖ፡ ለበሸለሾል፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i1.3">
                            <locus from="11rv" to="37va"/>
                            <title type="complete" xml:lang="en">Collection of magic prayers</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አ</hi>ምላክ፡ ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡
                              ዘይፈትሕ፡ ደጋምያነ፡ እስላም፡ ወክርስቲያን፡ ጋላ፡ ወሻንቅላ፡ ጠቢብ፡ ወረጋ፡ ወኵሉ፡ መናግንቲሁ፡ ለሰይጣን።
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i1.4">
                            <locus from="37vb" to="40v"/>
                            <title type="complete" xml:lang="en">Collection of magic prayers</title>
                            <textLang mainLang="am" otherLangs="gez ar"/>
                          </msItem>
                          <msItem xml:id="ms_i1.5">
                            <locus from="41r" to="80rb"/>
                            <title type="complete" xml:lang="en">Collection of magic prayers</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                        </msItem>

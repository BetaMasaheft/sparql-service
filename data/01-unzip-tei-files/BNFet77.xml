               <msContents>
                  <summary/> 
            
                  <msItem xml:id="ms_i1">
                     <title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">Kidān za-nagh</title> 
                     <textLang mainLang="gez"/>
                  </msItem>
            
                  <msItem xml:id="ms_i2">
                     <locus from="9v">Fols 9v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title> 
                     <textLang mainLang="gez"/>
                  </msItem>
            
                  <msItem xml:id="ms_i3">
                     <locus from="16r">Fols 16r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2741RepCh25">Malkǝʾa ḥǝmāmāta
                                                  masqal</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>ሰላም፡ ለዝክረ፡ ስምከ፡ ቤተ፡ አይሁድ፡ ዘአዓደደ።
                <lb/>ወረሰዮሙ፡ ሐመደ።
                <lb/>ማርያምሃ፡ እለ፡ ቦሙ፡ ክህደ።
                <lb/>ተማኅፀነ፡ በሕማምከ፡ መጥወነ፡ እደ።
                <lb/>አጽራሪነ፡ ወትረ፡ ረሲ፡ ብድብደ።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i4">
                     <locus from="27r">Fols 27r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2842RepCh125">Malkǝʾa
                                                  masqal</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>ሰላም፡ ለዝክረ፡ ስምከ፡ በመጽሔተ፡ መስቀል፡ ዘተለክዓ።
                <lb/>ወለሥዕርትከ፡ ጸሊም፡ በደመ፡ ተኰርዖ፡ ተቀብዓ።
                <lb/>ሰዋስወ፡ ፍቅር፡ ክርስቶስ፡ ትኩል፡ ዲበ፡ አንግድዓ።
                <lb/>አስትየኒ፡ ለተሳትፎ፡ እንተ፡ ሰተይከ፡ ጽዋዓ።
                <lb/>በዋዕየ፡ ፍቅርከ፡ አምላካዊ፡ ሕሊናየ፡ ጸምዓ።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i5">
                     <locus from="33r">Fols 33r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3070RepCh350">Hymn to Jesus
                                                  Christ</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>እቀድም፡ አእኵቶ፡ ዘአልቦ፡ ሕንካሴ።
                <lb/>ወለልደትከ፡ ሰላም፡ እንተ፡ ኢያእመረት፡ ብእሴ። 
                <lb/>ኢየሱስ፡ ክርስቶስ፡ ዋሕድ፡ ዘእምሥላሴ።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i6">
                     <locus from="38r">Fols 38r and following</locus>
                     <title type="incomplete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2733RepCh17">ማኅበረ፡ ምእመናን፡</title> 
                     <textLang mainLang="gez"/>
                     <note>The text stops at stanza 17, the end is missing.</note>
                  </msItem>
            
                  <msItem xml:id="ms_i7">
                     <locus from="41r">Fols 41r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2982RepCh263">Hymn to Jesus
                                                  Christ</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ጥንተ፡ ጸጋ።
                <lb/>ዘምሥጢረ፡ ቍርባን፡ አንበረ፡ ለቤተ፡ ክርስቲያን፡ መልዕልተ፡ ሕጋ።
                <lb/>ሶበ፡ ይትቀደስ፡ ኅብስት፡ ወጽዋዓ፡ ወይን፡ ቅድመ፡ እንግልጋ።
                <lb/>ይትዌለጡ፡ ወይከውኑ፡ እንበለ፡ ተከፍሎ፡ ወንትጋ።
                <lb/>ደመ፡ መለኮት፡ ነባቢ፡ ወሕያው፡ በሥጋ።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i8">
                     <locus from="46r">Fols 46r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3067RepCh347">Hymn to the Holy
                                                  Trinity</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>እስመ፡ ብዙኃን፡ እሙንቱ፡ እለ፡ አኀዙ፡ ይጽሐፉ።
                <lb/>ሃይማኖት፡ ቅድስት፡ ሥላሴ፡ እንተ፡ ተሳተፉ።
                <lb/>መጽሐፈ፡ ማኅሌት፡ ሠናየ፡ ዘእለ፡ አትረፉ።
                <lb/>ከመ፡ እስብክ፡ አንሰ፡ ወእንግር፡ ለዝላፉ።
                <lb/>አናቅጸ፡ ስብሐት፡ አርባዕ፡ ቅድሜየ፡ ይኅልፉ።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i9">
                     <locus from="57r">Fols 57r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3115RepCh395">Malkǝʾa
                                                  Ṗarāqliṭos</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <lb/>ጰራቅሊጦስ፡ ዓምደ፡ ደመና፡ ዘመራህኮሙ፡ ለአበው።
                <lb/>ጰራቅሊጦስ፡ መና፡ ወማየ፡ ስቴ፡ ዘበድው።
                <lb/>ጰራቅሊጦስ፡ ፀሐይ፡ ንጉሠ፡ ብርሃናት፡ ሥርግው። 
                <lb/>ጰራቅሊጦስ፡ አብርህ፡ ልቡናየ፡ በብርሃንከ፡ ፍንው።
                <lb/>ጰራቅሊጦስ፡ አፉየ፡ ቅስም፡ ጰራቅሊጦስ፡ ፄው።
              </incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i10">
                     <locus from="63r">Fols 63r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer
                                                  za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                እግዚአብሔር፡ ዘብርሃናት፡
              </incipit>
                  </msItem>
               </msContents>
          

      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ተንሤ፡ ማሞ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Tanśe Māmmo</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">ትንሳኤ፡ ማሞ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Tǝnsāʾe Māmmo</t:persName>
               
               <t:persName>
                  <t:roleName type="title">bitwaddad, daǧǧāzmāč
               </t:roleName>
               </t:persName>
               
               
               
               <t:faith type="EOTC"/>
               
               
               <t:occupation type="political">governor</t:occupation>
               
               
               <t:floruit notBefore="1722" notAfter="1733">He was a nobleman who in late<t:date>1732</t:date> 
                  led a revolt against <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</t:persName>
                  and the <t:placeName ref="https://betamasaheft.eu/LOC5284Qwara">Qwārā</t:placeName> faction at court. 
                  He was one of
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa"> 
                     <t:roleName type="title">ʾaṣe</t:roleName>
                     Bakāffā</t:persName>'s favoured officials, 
                  serving as <t:persName ref="https://betamasaheft.eu/PRS9239TanseT">
                     <t:roleName type="title">bitwaddad</t:roleName>Tanśe Māmmo</t:persName>
                   in <t:date>1722</t:date> and as 
                  <t:persName ref="https://betamasaheft.eu/PRS9239TanseT">
                     <t:roleName type="title">daǧǧāzmāč
                  </t:roleName> Tanśe Māmmo </t:persName> and governor of <t:placeName ref="https://betamasaheft.eu/LOC2488Damot">Dāmot</t:placeName>. 
                  In <t:date>1731</t:date>, 
                  <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">
                     <t:roleName type="title">ʾaṣe</t:roleName> ʾIyāsu II</t:persName> 
                  appointed him <t:persName ref="https://betamasaheft.eu/PRS9239TanseT">
                     <t:roleName type="title">ʾazzāž</t:roleName> 
                     Tǝnsāʾe Māmmo</t:persName> of <t:placeName ref="https://betamasaheft.eu/LOC6376Yebaba">Yǝbabā</t:placeName>.
                  He was angered by the maneuvering at the court upon 
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa">
                     <t:roleName type="title">ʾaṣe</t:roleName> Bakāffā</t:persName>'s death in which <t:persName ref="https://betamasaheft.eu/PRS2682BerhanM">Bǝrhān Mogasā</t:persName>, wife of <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa">Bakāffā</t:persName>, <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</t:persName>'s mother, 
                  and her <t:placeName ref="https://betamasaheft.eu/LOC5284Qwara">Qwārā</t:placeName> n relatives hastily and secretly crowned <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</t:persName>, seizing control of throne and state. 
                  The rebellion he led lasted from <t:date>19 December 1732</t:date> to <t:date>2 January 1733</t:date> and involved eight days of siege of the royal compound. 
                  Tanśe and his allied group were finally defeated by <t:placeName ref="https://betamasaheft.eu/LOC5284Qwara">Qwārā</t:placeName>'s forces. 
                  He was captured and publicly hanged in <t:date>1733</t:date>.
                 </t:floruit>
               <t:death when="1733"/>
               
               
            </t:person>
            
            

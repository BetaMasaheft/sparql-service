                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="2r" to="6r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ወካዕበ፡ ናስተበቊዓ፡ በል። በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥላሴ፡ በብሂል፡ ወጠንኩ፡ ለረኪብ፡ ውዳሴ፡ ማርያም፡ እኅቱ፡ ለሙሴ። ንዒ፡ ንዒ፡ ንዒ፡ ማርያም፡ ዘትነብሪ፡ ሃርያም፡ ወንዒ፡ ሠናይትየ፡ ዘገነት፡ ኤዴም፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus target="#7v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5063Hymn">Hymn to Archangels</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ነዓ፡ ነዓ፡ ነዓ፡ ሚካኤል፡ ሰዓሌ፡ ምሕረት፡ ወመተንብል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="8r" to="9v"/>
                            <title type="complete" cert="medium" ref="https://betamasaheft.eu/LIT2948RepCh229">Hymn to St George</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ነዓ፡ ነዓ፡ ነዓ፡ ጊዮርጊስ፡ እንዘ፡ ትሰርር፡ በአፈረስ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus target="#10r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3008RepCh288">Hymn to ʾEwosṭātewos</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በእንተ፡ ክቡር፡ አቡነ፡ ኤዎስጣቴዎስ፡ ካህን፡ ዘአርማንያ፡ መንሥኤ፡ ሙታን፡</incipit>
                            <note>According to <persName ref="https://betamasaheft.eu/PRS9602Turaev">Turaev</persName> this hymn is dedicated as well to <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName> and <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName> 
                     </note>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="10v" to="11r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2799RepCh83">Malkǝʾ-hymn to St George</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለከ፡ ጊዮርጊስ፡ ዘልዳ፡ መስተፅዕነ፡ ፈረስ፡ ፀዓዳ፡</incipit>
                            <note>According to <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> this hymn is a part of <ref type="work" corresp="https://betamasaheft.eu/LIT1961Mashaf">Maṣḥafa saʿātāt</ref>
                     </note>
                            <note>According to <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> this whole manuscript might represent parts and excerpts from <ref type="work" corresp="https://betamasaheft.eu/LIT1961Mashaf">Maṣḥafa saʿātāt</ref> . As an argument he points to the note on <locus target="#10v"/> as well ast the beginning of the manuscript
                          which states <foreign xml:lang="gez">መሐረነ። አብ፡ በል። ሰላም። በል።</foreign> 
                     </note>
                        </msItem>
                    </msContents>


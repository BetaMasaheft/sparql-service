               <msContents>
                  <summary>Psalter</summary>

                  <msItem xml:id="ms_i1"><locus from="3r" to="149r" facs="003">Fols 3r–149r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                    <msItem xml:id="ms_i1.1"><locus from="3r" to="114r" facs="003">Fols 3r–114r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118</span></ref>has only the transliterated letter for each section,
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref>contains two of the four plusses that make up the long version, <q>“and he saved me”</q> and <q>“Goliath.”</q></note>

                    <colophon xml:id="coloph1">
                      <locus target="#149r" facs="149">Fols. 149r, </locus>
                      The original owner was Gabra Selassie (mentioned previously on <locus target="#144v" facs="145">144v</locus>, in the Praises of Mary),
                      whose name is erased and written over with ኃይለ፡ ሚካኤል፡. 
                    The scribe is በኵረ፡ ጽዮን፡.
                  </colophon>

                    </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="114r" to="126v" facs="114">Fols 114r–126v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> has the superscription, <q>“Prayer of Hana, mother of Samuel, prophet.”</q></note>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="126v" to="133r" facs="127">Fols 126v–133r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title><note>common edition</note></msItem>
                  <msItem xml:id="ms_i1.4"><locus from="133v" to="144v" facs="134">Fols 133v–144v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title><note>arranged for the days of the week, laid out beginning on Monday and culminating on Sunday</note></msItem>
                  <msItem xml:id="ms_i1.5"><locus from="144v" to="149r" facs="145">Fols 144v–149r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title></msItem>

                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">149</measure>
                           <dimensions type="outer" unit="mm">
                              <height>165</height>
                              <width>115</width>
                              <depth>60</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="25">
                         <locus from="1r" to="133r" facs="001">Fols 1r–133r, </locus>
                         <locus from="144v" to="149v" facs="145">144v–149v</locus>
                       </layout>
                       <layout columns="2" writtenLines="25">
                         <locus from="133v" to="144r" facs="134">Fols 133v–144r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word for God is not rubricated</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for help in learning
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> calculation for when to gain favor from kings and rulers
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Judging by the fading pattern on the inside of both front and back boards, it would seem the book was, at one time, leather bound
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#58r" facs="058">Fol. 58r</locus>
                    <desc>
                    The midpoint of the Psalms is indicated with two lines of alternating red and black dots between the midpoint line and the one above
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#149v" facs="150">Fol. 149v</locus>
                    <desc>
                    a pen trial poem of greater length than normal
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="false">
                    <decoNote xml:id="b1">Parchment. Plain wooden boards, both are broken and repaired with leather strips and string. The front board has one piece that is separated.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1850" notAfter="1899">Late-nineteenth century</origDate>
                  </origin>
               </history>
            </msDesc>

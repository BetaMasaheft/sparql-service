         <t:listPerson>
            <t:person sex="1">
             
                  
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ብርሃኑ፡ ዘርይሁን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Bǝrhānu Zaryǝhun</t:persName>
                  
                  
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
                  <t:occupation type="literary">writer</t:occupation>
               <t:birth notBefore="1933" notAfter="1934">He was born at 
                  <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName> between <t:date>1933-1934</t:date>. </t:birth>
                  
                  
               <t:floruit notBefore="1959" notAfter="1987">He was a prominent Amharic writer. 
                  He received his elementary education
                  in <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>, then graduated from <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> 
                  Technical School in <t:date>1956/57</t:date> 
                  specializing in radio mechanics. 
                  But he left his field of specialization and turned to journalism, 
                  made swift progress from a curb reporter up to the editor in chief until <t:date>1966/67</t:date>. 
                  He authored novels and plays. 
               </t:floruit>
               <t:death when="1987"> He died at <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> in <t:date>1987</t:date>.</t:death>
                  
                  
               </t:person>
               
         </t:listPerson>
         
         

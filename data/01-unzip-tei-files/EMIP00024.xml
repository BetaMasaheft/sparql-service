               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="152v" facs="002">Fols 1r–152v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="123r" facs="002">Fols 1r–123r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="123v" to="135v" facs="125">Fols 123v–135v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="136r" to="142r" facs="137">Fols 136r–142r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                        <note>Common version</note>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="142r" to="149v" facs="143">Fols 142r–149v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                        <note>Arranged for the days of the week</note>
                          <msItem xml:id="ms_i1.4.1">
                            <locus from="142r" facs="143">Fols 142r and following</locus>
                            <title>Monday (Introduced with the first part of the story of its composition by a Syrian potter)</title>
                          </msItem>
                        <msItem xml:id="ms_i1.4.2">
                          <locus from="143r" facs="144">Fols 143r and following</locus>
                          <title>Tuesday</title>
                        </msItem>
                        <msItem xml:id="ms_i1.4.3">
                          <locus from="144v" facs="146">Fols 144v and following</locus>
                          <title>Wednesday</title>
                        </msItem>
                        <msItem xml:id="ms_i1.4.4">
                          <locus from="146r" facs="147">Fols 146r and following</locus>
                          <title>Thursday</title>
                        </msItem>
                        <msItem xml:id="ms_i1.4.5">
                          <locus from="147r" facs="148">Fols 147r and following</locus>
                          <title>Friday</title>
                        </msItem>
                        <msItem xml:id="ms_i1.4.6">
                          <locus from="148r" facs="149">Fols 148r and following</locus>
                            <title>Saturday</title>
                        </msItem>
                        <msItem xml:id="ms_i1.4.7">
                          <locus from="149r" facs="150">Fols 149r and following</locus>
                          <title>Sunday (Introduced with the last part of the story of the Syrian potter)</title>
                        </msItem>
                    </msItem>
                  </msItem>

               </msContents>

         <listPerson>
            <person sex="1">
            
                  
                  
                  <persName xml:lang="gez" xml:id="n1" type="birth">ክፍሌ፡ ገሪማ፡ ወልደ፡ ኪዳን፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Kǝfle Garimā Walda Kidān</persName>
               <persName xml:lang="gez" xml:id="n2" type="baptismal">ሚካኤል፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Mikāʾel II</persName>
               
              
               <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
               <occupation type="ecclesiastic">bishop</occupation>
                  
                  
                  
                  <faith type="EOTC"/>
                  
                  
          
               <residence ref="LOC3577Gondar"/>
               <residence ref="LOC3957Jerusa"/>
               <birth when="1886">He was born at <placeName ref="https://betamasaheft.eu/LOC1390AmbaGe">Amba Gǝšän</placeName>
               </birth>
                  
               <floruit notBefore="1946" notAfter="1959">He was the bishop of 
                  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> from <date>1946</date> to <date>1959</date>.
                  He became a monk and was consecrated priest in <date>1924</date> 
                  by 
                  <persName ref="https://betamasaheft.eu/PRS6876Matewos">
                     <roleName type="title">ʾabuna</roleName> 
                     Mātewos</persName>.
                  In <date>1924-25</date> he made a pilgrimage to <placeName ref="https://betamasaheft.eu/LOC3957Jerusa">Jerusalem</placeName> where he stayed for six months. In <date>1935</date>, 
                  he was appointed head of the Ethiopian monasteries in <placeName ref="https://betamasaheft.eu/LOC3957Jerusa">Jerusalem</placeName>. After the liberation of the country from Italian colonial rule, 
                  he was ordained as bishop of <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> in <date>1946</date>where he served until his death.
                  </floruit>
               <death when="1959">He died at <placeName ref="https://betamasaheft.eu/LOC1390AmbaGe">Amba Gǝšän</placeName>
               </death>
                  
                  
               </person>
               
               
         </listPerson>
         
         
         
         

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="16r">1v-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s22IHA">قران, Fifteenth ǧuz’ (15/30)</title>
                     <incipit xml:lang="ar">سورة ىىى اسرايل [مائة] واحدى عسر اىة مكىة \ بسم الله الرحمن الرحيم \ سبحان الذي أسري بعبده ليلا من المسجد الحرام الى المسجد الاقصي <note>Sūrat al-isrā', verse 1</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>قال أقتلت نفسا زاكية بغير نفس لقد جئت شيا نكرا<note>Sūrat al-kahf, verse 74</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>

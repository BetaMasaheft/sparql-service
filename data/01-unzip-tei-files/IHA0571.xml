                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_1338">
                           <locus target="#10r-16r">-10r-16r</locus>
                           <q xml:lang="ar">A crudely drawn single black frame around the text</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_1338">
                           <locus target="#16r">-16r</locus>
                           <q xml:lang="ar">صدق الله العطىم وصدق رسوله النبي الكرىم ونحن علي ذلك من الشاهدىن والحمد لله رب العالمين \ وصلى الله على سيدنا محمد واله وصحبه وسلم</q>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#3v">-3v</locus>
                           <desc>Title</desc>
                           <q>كتاب افضل القرى لقرا امّ القري تاليف الشيخ العلامة والحبر الفهامة شيخ الاسلام سلطان سلاطين علا الانام المحقق المدقق ذي التصانيف المفيدة والعلوم المفيدة شهاب الدين احمد بن حجر الهيتمي الانصاري رحمه الله تعلى ام</q>
                           <note>The text iw written in red, black and green ink.</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#3v">-3v</locus>
                           <q>ضبط وفات الشيخ احمد بن حجر رحمه الله تعالى شيخ مكة وعمره لله انتهى</q>
                           <note>Note on the author. The text is written in the same hand as the title information.</note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#5v">-5v</locus>
                           <q/>
                           <note>The text is faded and difficult to read.</note>
                        </item>
                        <item xml:id="a4">
                           <locus target="#3v">-3v</locus>
                           <desc>Note marked min kitāb al-Harawī</desc>
                           <q/>
                           <note>The note describes the death of the Prophet.</note>
                        </item>

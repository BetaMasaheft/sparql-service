      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ቅብአ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Qǝbʾā  Krǝstos</t:persName>
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  <t:occupation type="political">governor</t:occupation>
                 <t:floruit notBefore="1618" notAfter="1629">He was a noble and a successful military leader 
                    loyal to 
                    <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe
                    </t:roleName>  Susǝnyos</t:persName> who 
                  led a series military operations against a <t:placeName ref="https://betamasaheft.eu/LOC3109Funj">Funj</t:placeName> king,
                    <t:persName ref="https://betamasaheft.eu/PRS3845erubat">ʾƎrubāt</t:persName>
                  in <t:date>1618</t:date>. He also led  several military campaigns against those 
                    rebellions to the power of                <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe
                    </t:roleName> 
                        Susǝnyos</t:persName>. 
                    <t:persName ref="https://betamasaheft.eu/PRS8027QebaKr">Qǝbʾā  Krǝstos</t:persName>
                  was one of the first to have converted to Catholicism at the court.</t:floruit>
            </t:person>  
            
         </t:listPerson>

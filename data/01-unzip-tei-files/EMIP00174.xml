                      <desc type="GuestText">
                      <locus target="#iiv(erso) #iiir(ecto) #iiiv(erso) #ivr(ecto)" facs="004 005">Fols. iiv(erso), iiir(ecto), iiiv(erso), ivr(ecto)</locus> <title type="incomplete" ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat

                  <decoDesc>
                    <summary>Miniatures (added in the late-twentieth century by the “speckled garment artist” over text)</summary>
                    <decoNote type="miniature" xml:id="d1"><locus target="#ivv(erso)" facs="006">Fol. ivv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref> with caption <q>“King, prophet, David”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#13r" facs="017">Fol. 13r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#37r" facs="041">Fol. 37r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> with caption <q>“Saint George”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#72v" facs="077">Fol. 72v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref> with caption <q>"Mary: Enthroned"</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#73r" facs="077">Fol. 73r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref> with caption <q>“Annunciation”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#109r" facs="113">Fol. 109r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1117MosesandBrother"><span xmlns="" class="w3-tag w3-red">No item: AT1117MosesandBrother</span></ref> and <persName ref="https://betamasaheft.eu/PRS11610Miriam">Miriam</persName> (right) with caption (l. to r.): <q>“his brother, Aaron,” “Holy Spirit,” “Prophet Moses with his tablet,”</q> (Trinitarian formula on tablet) <q>“his singer, sister, Miriam”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#201v" facs="206">Fol. 201v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1025NativityJesus">Nativity of Jesus</ref> with caption <q>“Birth of Our Lord, Jesus Christ”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#202r" facs="206">Fol. 202r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1039Magi">The Three Magi</ref> with caption (l. to r.): <q>“Cherubim”, “the three wise men” </q></desc></decoNote>
                    <decoNote type="frame" xml:id="d9">
                      Decorative designs:
                      <locus target="#9v #29r #40v #49v #57v #69r #83r #94r #116v #132r #136r #143v #151v #168r #178v" facs="014 033 045 054 062 073 087 098 121 136 140 148 156 172 183">folss. 9v, 29r, 40v, 49v, 57v, 69r, 83r, 94r, 116v, 132r, 136r, 143v, 151v, 168r, 178v, </locus> (a line of alternating red and black dots);

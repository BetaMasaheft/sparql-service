          <msContents>
            <summary>Psalter, ዳዊት፡</summary>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="158v" facs="001"/>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>

              <msItem xml:id="ms_i1.1">
                <locus from="1r" to="105r" facs="001"/>
                <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                <note>Incomplete at the beginning. Starting at chapter 17</note>
                <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref> has a unique set of
                  section headings that focus on praise to God the Father</note>
              </msItem>

              <msItem xml:id="ms_i1.2">
                <locus from="105v" to="117r" facs="106"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                <note>with marginal insertions from the Hebraic version</note>
              </msItem>

              <msItem xml:id="ms_i1.3">
                <locus from="117r" to="118v" facs="117"/>
                <title type="incomplete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                <note>common version in the base text, with interlinear and marginal insertions from
                  the Hebraic edition, incomplete (through the middle of part two)</note>
              </msItem>
            </msItem>
          </msContents>

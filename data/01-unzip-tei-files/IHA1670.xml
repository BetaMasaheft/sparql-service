               <msContents>
                  <summary>Written in an English exercise book for school children.</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="4v">2r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT2713IHA">دعاء اللهم صل على زين الوجود</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم بسم الله الرحمن الرحيم / اللهم صل على زين الوجود</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>النور الأكمل المدد الأرباب السير تجدد حتى غاب بهم في ذلك المشهد</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4v" to="9r">4v-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0138IHA">تخميس قمر عز قد بدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>صلى الله على محمد صلى الله عليه وسلم / فاطربو أيا السعد / واضربوا الدف واليد / طلع الهلال الهدا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>وأما مخمسه / فعبد مات فلبه / ميم وشين إسمه / وإن كثرت إثمه للتبرك يا فهيم</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="22r" to="23r">22r-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0182IHA">نظم تجلى من أحبه كرامًا</title>
                     <incipit xml:lang="ar">
                        <locus target="#22r">-22r</locus>صلاة الله سلام الله على من محمد هاشمي عرب / تجلى من أحبه كراما فأبد لي من سناه عجيب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>وعلى الأل والأصحاب طر ما قال المحب هاشمي عرب</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="23r" to="25r">23r-25r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0193IHA">نظم هبت نسيمات الأسرار</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>الصلاة والسلام ألصلاة  والسلام على النبي خير الأنام / هبت نسيمات الأسرار ليلة الخميس ولأسحار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25r">-25r</locus>صلى وسلم عليه بهج قلبي بجماله / وعلى الأل والأصحاب ما دام الكون برنة</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="25r" to="26v">25r-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1425IHA">نظم طاف بنا ظبي كامل</title>
                     <incipit xml:lang="ar">
                        <locus target="#25r">-25r</locus>رب صلى و سلام على [.؟.] على النور المبجل / طاف بينا ظبي كامل بين تلك المنازل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>ثم صلاتي وسلامي على نبي المكرم / المخصوص بالمقام المحمود المبجل</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="9r" to="11r">9r-11r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0125IHA">نظم أبان ما في قلبي ما قد كنت أخفيه</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>صلاة وتسليمو وأزكى تحيه [.؟.] على المصطفى لهاد البرايا محمد يا رسول الله / ابان ما في قلبي ما قد كنت أخفيه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>على خير مبعوث بأفضل نوره / صلى عليه ربي ما دام[.؟.] الكون به وسلم أبدا ما دام الواهب</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="11r" to="13r">11r-13r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0126IHA">نظم نحمد الله ربّي على جلّ نعمه</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>أوي سلام عليك أوي سلا عليك / أوي سلام عليك صلواة الله عليك / نحمد الله ربي على جل نعمه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13r">-13r</locus>أمتنا عند الاجل بحسن الخماتة</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="13r " to="13v">13r -13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1722IHA">نظم حمدا لك ربنا خالق الأشياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#13r">-13r</locus>يا مصطفى الأنام يا مصطفى الأنام يا مصطفى الأنام عليك السلام / حمد لك ربنا خالق الأشياء , أوجدت لنا سرا من درة البهاء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>وأبدع خلق الله مستغرق الجمال / سفية السيار الى بحر الأسرار , ومحل الأنوار ومقام الكمال</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="13v" to="15v">13v-15v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1104IHA">نظم يا امام الحرام كنز مطلسم</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>أللهم صل اعلى محمد [.؟.] يا إمام الحرام كنز المطلسم / قام ببنا سر من المحب / فأسكر قلب شرابا منهم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15v">-15v</locus>ما دام السيار ينفتح له , أسرار غيوبا كان مكتم</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="15v" to="16v">15v-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1106IHA">نظم محمد بحر الهداية محمد برق العناية</title>
                     <incipit xml:lang="ar">
                        <locus target="#15v - 16r">-15v - 16r</locus>محمد سلام عليكم سيدي سلام عليكم صلاة الله على خير الباريا / محمد بحر الهداية محمد برق العناية / أيا حادي المطاية إلى أخير البرايا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>وكذ على الأصحاب , هم ولات ذاك لباب / ما ذاق أهل المحبة , و شرابا بقلع اللبا </explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="16v" to="18v">16v-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1111IHA">نظم محمد ذخر الهداية محمد بؤق العناية</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>محمد سلام عليكم سيد سلام عليكم صلاة الله على خير البرايا / محمد ذحر الهداية محمد برق العناية / محمد ظل الألهي ياله من ظل الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#18v">-18v</locus>صلاة الذت العلية , على الحضرة لسنية / ومع الأل الولات , قدوة ذو الخيرت</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="18v" to="19v">18v-19v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0129IHA">نظم جمال بدأ من فوق العزّ</title>
                     <incipit xml:lang="ar">
                        <locus target="#18v">-18v</locus>أوي نبي أوي نبي أوي نبي أوي نبي محمد نبي سلام عليكم / جمال بدا من فوق العز , دل محتاجا فقال هز</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>وعلى الأل وكل الأصحاب من ولى الكرام وكذ الأصحا</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="20r" to="22r">20r-22r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0130IHA">نظم أول نشء الوجود وسر الله الودود</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>صلى الله على محمد صلى الله محمد م محمد علم لهداى محمد / أول نشاء الوجود وسر الله الودد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>على أفضل الوجود معدن الفضل والجود / مع صحبه والأل ولمن له موالي</explicit>
                     <note>
                        <term key="Devotional" ana="#Devotional"/>
                     </note>
                     <note>The text on 20v &amp; 21r is upside down and contain no diacritical markers. It includes the last section of Naẓm "Awwal našā' al-wuǧūd wa-sirr Allāh al-wadūd" followed by the beginning of Naẓm "Taǧallā man uḥibbuhu karāman". At the top of 21v the scribe returns to Naẓm "Awwal našā' al-wuǧūd wa-sirr Allāh al-wadūd" where he ended at the bottom of 20r. </note>
                     <note/>
                  </msItem>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: texts I, II,
                           V. Mediocre.</seg>
                        <seg type="ink">Black; red.</seg>
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS12953WaldaMalaektScribe">Walda Malāʾǝkt</persName>
                        is mentioned as the scribe in the supplication formula on <locus target="#92vb">92vb</locus>.
                        <date>First half of the 19th century.</date>
                        <seg type="rubrication">Holy names; name of the protagonist; name of the
                           scribe; incipits of Text I and its subsections (fols. 20v, 21v, 26v, 27r,
                           39v, 50v); incipit of Text II; notes in the upper margin of some
                           fols.; elements of the punctuation signs; Ethiopic numerals.
                           In the incipit page of Text I  (fol. <locus target="#2r">2r</locus>), a few lines are rubricated (alternating with black lines).</seg>
                     </handNote>

                     <handNote xml:id="h2" script="Ethiopic">
                        <seg type="script">Hand b: text III,
                           IV (?). Mediocre (seems slightly different from Hand a).</seg>
                        <seg type="ink">Black; red.</seg>
                        <locus from="83ra" to="89va"/>

                        <date>First half of the 19th century.</date>
                        <seg type="rubrication">Holy names; name of the protagonist; incipit of Text III (a few lines are rubricated (alternating with black lines) on <locus target="#83r"/>); notes in the upper margin of some
                           fols.; elements of the punctuation signs; Ethiopic numerals; numbers of
                           the Miracles.</seg>
                     </handNote>

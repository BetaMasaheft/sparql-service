                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2r">f. 2r</locus>
                           <desc type="DonationNote">Donation note.</desc>
                           <q xml:lang="gez">ዝንቱ፡ መጽሐፍ፡ ዘተሣጦ፡ በንዋዩ፡ አቡነ፡ ገብረ፡ ሕይወት፡
                              በመንግሥተ፡ ደዠአጅማች፡ ውቤ፡ ወሃቦ፡ ለተክለ፡ ሃይማኖት፡</q>
                           <foreign xml:lang="en">
                             This is the book which ʾabuna Gabra
                              Ḥǝywat  bought with his own money during the reign of daǧǧāzmāč
                              Wǝbe and donated it to (the church of) Takla Hāymānot. </foreign>
                           <note>Written in the on <locus target="#16v">16v</locus>, 17r, 23r, 40r, 51r, 56r, 61r, 68r, 83r. </note>
                           
                        </item>
                        <item xml:id="a2">
                           <locus target="#82v">f. 82va-82vb</locus>
                           <desc type="DonationNote">Original donation note.</desc>
                           <q xml:lang="gez"/>
                           
                           <note> The name of the original donor was washed out. </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#91v">f. 91v</locus>
                           <desc type="GuestText">Salām-hymn for Takla Hāymānot.</desc>
                           <q xml:lang="gez"/>
                           
                        </item>
                        <item xml:id="a4">
                           <locus target="#92v">f. 92v</locus>
                           <desc type="Supplication">Crudely written supplication note mentioning fields donated to
                              the church.</desc>
                           <q xml:lang="gez"/>
                           <q xml:lang="am"/>
                           <note> Partly in Amharic. </note>
                        </item>
                        <item xml:id="e1">
                           <desc type="findingAid">- Notes in the upper margin of some fols. indicate
                              the monthly readings from the Vita of Takla Hāymānot as follows:
                              reading for Naḥāse (<locus target="#2r">fol. 2r</locus>); reading for
                              Ṭǝqǝmt (<locus target="#20v">fol. 20v</locus>); reading for Ḫǝdār
                              (<locus target="#26v">fol. 26v</locus>); reading for Tāḥśāś (<locus target="#39v">fol. 39v</locus>); reading for Ṭǝrr (<locus target="#50r">fol. 50r</locus>); reading for Miyāzyā (<locus target="#64r">fol. 64r</locus>); reading for Gǝnbot (<locus target="#67v">fol. 67v</locus>); reading for Säne (<locus target="#73r">fol. 73r</locus>).</desc>
                        </item>
                     </list>
                  </additions>

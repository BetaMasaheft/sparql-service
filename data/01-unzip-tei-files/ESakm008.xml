                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="2ra" to="112vb">2ra-112vb</locus>
                        <locus from="121ra" to="122rb">121ra-122rb</locus>
                        <seg type="script"> fine and careful; round shapes, broadly spaced
                           letters</seg>
                        <seg type="ink">Black, red (vivid red)</seg>
                        <date>18th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ፍ፡</abbr> for <expan>ፍቱሐ፡ ረስዮ፡ </expan> (e.g., <locus target="#12ra">12ra</locus>, 14vb, 15ra)</item>
                           <item>
                              <abbr>ይ፡ ካ፡</abbr> for <expan>ይበል፡ ካሕን፡ </expan> (e.g., <locus target="#13va">13va</locus>, 16rb, 62va)</item>
                           <item>
                              <abbr>ይ፡ ዲ፡</abbr> for <expan>ይበል፡ ዲያቆን፡ </expan> (e.g., <locus target="#13va">13va</locus>, 16rb, 62vb)</item>
                           <item>
                              <abbr>ይ፡ ሕ፡</abbr> for <expan>ይበል፡ ሕዝብ፡ </expan> (e.g., <locus target="#24vb">24vb</locus>, 25ra, 63rb)</item>
                           <item>
                              <abbr>አ፡</abbr> for <expan>አሜን፡ </expan> (<locus target="#100vb">100vb</locus>, 101ra, 102ra)</item>
                           <item>
                              <abbr>ን፤ እ፤ አ፤ ል፤</abbr> for <expan>ንስዕለከ፡ እግዚኦ፡ አበ፡ ልዑላን፡ </expan>
                                 (<locus target="#113ra">113ra</locus>, 113va)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donors; name of the king;
                           a few lines on the incipit page, alternating with black lines; two
                           initial lines of each section of the text; elements of the punctuation
                           signs; some other words, e.g., hāle luyā (e.g., fols. 2vb, 3ra, 4ra),
                           ṣallǝyu (e.g., fols. 9va, 18rb, 19rb), qǝdma wangel (e.g., fols. 10rb,
                           10vb, 43vb), ʾǝgale (e.g., fols. 28rb, 28vb, 57vb), wa-tǝbl (e.g., fols.
                           28vb, 79rb, 80va), salām (fol. 72rb), wa-ʾǝmzǝ (e.g., fols. 77ra, 78rb,
                           79ra).</seg>
                     </handNote>

                     <handNote xml:id="h2" script="Ethiopic">
                        <locus from="112vb" to="120rb">112vb-120rb</locus>
                        <locus from="112vb" to="120rb">122va-125rb</locus> mediocre hand; angular
                        letter shapes, hairlines, bifurcated extremities. <seg type="ink">Black, red
                           (strong red)</seg>
                     </handNote>

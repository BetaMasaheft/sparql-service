                    <decoNote type="miniature" xml:id="d8"><locus target="#63v" facs="064">Fol. 63v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1010Entombment">Entombment of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#86r" facs="086">Fol. 86r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the ground</desc></decoNote>

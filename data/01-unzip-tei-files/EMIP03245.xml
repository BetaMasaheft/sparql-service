                    <decoNote type="miniature" xml:id="d2"><locus target="#3v" facs="004">Fol. 3v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, with two guardian <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#26r" facs="026">Fol. 26r</locus><desc>Three <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> walking in procession, each carrying a book in their right hand and a processional <term key="cross" ana="#cross"/> in their left hand</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#26v" facs="027">Fol. 26v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#27r" facs="027">Fol. 27r</locus><desc>The beheading of John the Baptist(?), the executioner stands left (showing one eye), John lays in center, an <term key="angel" ana="#angel"/> kneels right to receive the head as it is severed</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#27v" facs="028">Fol. 27v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1039Magi">The Three Magi</ref></desc></decoNote>

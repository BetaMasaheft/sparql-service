               <msContents>
                  <summary>Fragment of the Harp of Praise, containing the readings for part of Monday, all of Tuesday through Friday and part of Sunday, with ten illuminations</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="87v" facs="001">Fols 1r–87v</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT1344enzira">, arranged for the days of the week, incomplete at the beginning, starting in the section for Tuesday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>

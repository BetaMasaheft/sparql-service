                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="181r">1v-181r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s38IHA">قران, First half (ǧuz’ 1-15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة الفاتحة وهي بِسْمِ اللّهِ الرَّحْمنِ الرَّحِيمِ الْحَمْدُ للّهِ رَبِّ الْعَالَمِينَ الرَّحْمنِ الرَّحِيمِ مَلِكِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#181r">-181r</locus>حتَّىٰ إِذَا لَقِيَا غُلَامًا فَقَتَلَهُ قَالَ أَقَتَلْتَ نَفْسًا زَكِيَّةً بِغَيْرِ نَفْسٍ لَقَدْ جِئْتَ شَيْئًا نُكْرًا </explicit>
                     <note>1:1–18:74. The aḥzāb, aǧzā’ and eighths are marked.</note>
                     <note/>
                  </msItem>
               </msContents>

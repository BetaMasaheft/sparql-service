      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0477</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለልደትከ፡ ማእከለ፡ ሮሜ፡ ዐባይ፨</l>
                  <l n="2">በቤተ፡ አቡከ፡ ንጉሥ፡ ብዙኀ፡ ዕበይ፨</l>
                  <l n="3">ኢያንከረከ፡ ምንተ፡ ዘደኃሪሁ፡ ብካይ፨</l>
                  <l n="4">ሑረትከ፡ ሄኖክ፡ ለባሕረ፡ ኤርትራ፡ ቀላይ፨</l>
                  <l n="5">ኖታያዊሃ፡ ኮንከ፡ በመርበብት፡ ሠናይ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ለምጽአትከ፡ ዝየ፡ እምቤተ፡ አቡከ፡ ቅድመ፨</l>
                  <l n="2">ምስለ፡ አኃዊከ፡ ኅሩያን፡ እለ፡ መነኑ፡ ዓለመ፨</l>
                  <l n="3">ጸላእክሙ፡ ፍግዐ፡ ወአፍቀርክሙ፡ ሕሰመ፨</l>
                  <l n="4">ዘያፈቅር፡ ውሉደ፡ አበ፡ ወእመ፨</l>
                  <l n="5">ኢኮነ፡ ምስሌየ፡ ፈቲዎ፡ ዓለመ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምነ፡ ብርሃን፡ ጽዱል፨</l>
                  <l n="2">ለቀራንብቲከ፡ ሰላም፡ ወለአዕይንቲከ፡ ኵሑል፨</l>
                  <l n="3">ቢጸ፡ ቂርቆስ፡ ሄኖክ፡ ወዐርከ፡ ጊዮርጊስ፡ ክሉል፨</l>
                  <l n="4">ቅረበኒ፡ ነዓ፡ ለምሕረት፡ ወሣህል፨</l>
                  <l n="5">እስመ፡ እምዘመን፡ እኩይ፡ አድኅኖተ፡ ትክል፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለሐቌከ፡ ኤፉደ፡ መቃርስ፡ ዘዐጠቀ፨</l>
                  <l n="2">ወለአቍያጺከ፡ ሰላም፡ እለ፡ ያገንያ፡ ጽፉቀ፨</l>
                  <l n="3">ሄኖክ፡ አቡነ፡ እንተ፡ ትከውን፡ መጽድቀ፨</l>
                  <l n="4">ሶበ፡ እገይስ፡ ኀቤከ፡ እመ፡ ኢነሣእኩ፡ ወርቀ፨</l>
                  <l n="5">በለኒ፡ ሠመርኩ፡ አሐተ፡ ጸሪቀ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ መላእክት፡ አርጋብ፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ ዐጸደ፡ አርዝ፡ ዕጹብ፨</l>
                  <l n="3">ሄኖክ፡ አቡየ፡ ከመ፡ ኬንያዊ፡ ጠቢብ፨</l>
                  <l n="4">ወእምኔከ፡ ይትፌወሱ፡ ብዙኃን፡ ሕዝብ፨</l>
                  <l n="5">ሰዳዴ፡ አጋንንት፡ አንተ፡ በመስቀል፡ ዘዐርብ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለቆብዕከ፡ ወለስምዕከ፡ ክልኤቲ፨</l>
                  <l n="2">ኅሩየ፡ ኢየሱስ፡ ሄኖክ፡ ምስለ፡ አኃዊሁ፡ ሰብዓቱ፨</l>
                  <l n="3">መኒኖሙ፡ መንግሥተ፡ ለክርስቶስ፡ በአፍቅሮቱ፨</l>
                  <l n="4">አርዑተ፡ መስቀል፡ ጾሩ፡ ወመካልየ፡ ገድል፡ ኃምስቱ፨</l>
                  <l n="5">ወተሠይሙ፡ ካዕበ፡ በአህጉረ፡ ዐሠርቱ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እንዘ፡ ኣቄርብ፡ ስብሐተ፨</l>
                  <l n="2">በከመ፡ ወጠንኩ፡ ቅድመ፡ ወፈጸምኩ፡ ዘንተ፨</l>
                  <l n="3">በልብየ፡ ዘሀሎ፡ ሠናየ፡ ተምኔተ፨</l>
                  <l n="4">ስብሐተ፡ ጸሎቱ፡ ፈጸምኩ፡ ይኩነኒ፡ ሀብተ፨</l>
                  <l n="5">በረከተ፡ አቡየ፡ ሄኖክ፡ ዘይመልእ፡ ቤተ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
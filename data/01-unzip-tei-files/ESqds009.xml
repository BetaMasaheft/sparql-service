                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, irregular</seg>
                        <seg type="ink">Black, red</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>ምልጣ፡ for ምልጣን፡</item>
                           <item>እስመ፡ ለዓ፡ for እስመ፡ ለዓለም፡</item>
                           <item>እግዚአ፡ ነግ፡ for እግዚአብሔር፡ ነግሠ፡</item>
                           <item>
                              <abbr>ኪ፡</abbr> for <expan>ኪሬ፡ ላይሶን </expan> (e.g., <locus target="#40ra">40ra</locus>).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; a few lines on the incipit page; names
                           of sections followed by the feast name and occasionally by initial words
                           (e.g., wāzemā za-kāhǝnāta samāy); names of antiphons and their
                           abbreviations (e.g., māḥlet, mazmur, salām, ba-5-tu, ʾabun, ʾaryām, ʾǝsma
                           la-ʿālam, za-ʾamlākiya, za-yǝʾǝze, yǝtbārak); names of other chants
                           (e.g., mǝlṭān, ʿǝzl); musical notation: intratextual signs (e.g.,
                           ʾaklilä) and elements of marginal signs; chains of red and black dots
                           separating groups of antiphons; elements of the punctuation signs;
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#9rb">9rb</locus>: simple ornamental band; geometric
                        motifs.</decoNote>
                     <decoNote type="frame" xml:id="d2">
                        <locus target="#40vb">40vb</locus>: simple ornamental band delimited by two
                        parallel lines; interlaces.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#40r">ff. 40r-42</locus>
                           <desc>r: ʾAbun-antiphone for the Holy Week from Mazmur, Antiphones for
                              seasons of the year.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> The antiphone is crudely written in the upper and right margins of
                              the fols. </note>
                        </item>
                        <item xml:id="e1">- There are unfilled spaces left for rubrication almost
                           throughout the Ms.: <locus from="3va" to="10ra">3va-10ra</locus>,
                           13va-48vb.
 - A sign, in the shape of a cross with a loop at the end
                           of each arm, is written in the left margin: <locus target="#12va">12va</locus>. 
 - Minor notes, writing exercises, doodles, pen
                           trails: <locus target="#2v">2v</locus>, 3rv, 16r, 18v, 30r, 48vb,
                           49r.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">Name of the feast zä-Hosaʿǝna “Palm Sunday” is
                              crudely written, in pen, in the upper margin on <locus target="#46ra">fol. 46ra</locus>.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards (back board and part of the front
                           board are missing).
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes and tears are visible in the
                           centre fold of the quires, one close to the head and one close to the
                           tail of the codex.</decoNote>
                        <decoNote xml:id="b5">None</decoNote>
                     </binding>
                  </bindingDesc>

                        <msItem xml:id="ms_i1">
                            <locus from="2r" to="3r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1978Mashaf">Maṣḥafa ṭomār</title>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡
                            ቅዱስ፡ ፩ አምላክ፡ መጽሓፈ፡ ጦማር፡ ዘወረደት፡ እምሳመይ፡ ላዕለ፡ እደ፡
                          አትናቴዎስ፡ በዕለተ፡ እሑድ፡ ወረደት፡ ዛቲ፡ መጽሐፈ፡ ጦማር፡ በሮምያ፡ በ፲፻ወ፳ ዓመት፡
                          እምዓመተ፡ እስክንድር፡</incipit>
                        </msItem>

                        <msItem xml:id="ms_i2">
                            <locus from="4r" to="17r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5512KamaKonaMadhenaAlam">ʾƎsma bakama kona lati madḫǝna ʿālam
          Krǝstos</title>
                            <incipit xml:lang="gez">እስመ፡ በከመ፡ ኮነ፡ ላቲ፡ መድኅነ፡ ዓለም፡
                            ክርስቶስ። እግዚእነ፡ ነቅዐ፡ ወሥርወ፡ ዘኲሉ፡ ቅድስና፡ ወአማናዊ፡ ዘይከውን፡ ምክንያተ፡ ወለውሂብ፡
                          ኲሉ፡ ብርሃናት፡ ጽዱቃን፡ በዝኩ፡ ፀዳል፡ ባሕቲቱ፡ ዘይሠርቅ፡ እምብርሃነ፡ ዚአሁ፡ </incipit>
                            </msItem>


                        <item xml:id="a5">
                           <locus target="#161v">Fol. 161v</locus>
                           <desc type="Record"/>
                           <q xml:lang="en">This book with four others was taken by <persName ref="https://betamasaheft.eu/PRS11412Hassan">Hafsan Bey</persName> from an 
                           Abyssinian who was found writing under a tree near the British Army in Upper
                           Egypt and given by <persName ref="https://betamasaheft.eu/PRS11412Hassan">Hafsan Bey</persName> to Col. <persName ref="https://betamasaheft.eu/PRS11410Murray">Murray</persName> Q<hi rend="apices">r</hi>
                              M<hi rend="apices">r</hi> Gen<hi rend="apices">l</hi> and by him 
                              given to me. <date>Sep. 1801</date> at <placeName ref="https://www.wikidata.org/entity/Q243699">Rosetta</placeName>. <persName ref="https://betamasaheft.eu/PRS11411Turner">J. N. Turner</persName>.</q>
                        </item>
                        
                        <item xml:id="e1">
                           <locus target="#161r">Fol. 161r</locus>
                           <desc>Scribbles.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        
                        <item xml:id="e2">
                           <locus target="#4v">Fol. 4v</locus>
                           <desc>The owner named in <ref target="#a1"/> and <ref target="#a2"/> was 
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11413WaldaSamuel">Walda Sāmuʾel</persName>. In <ref target="#a2"/>,
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11414Tewobest">Tewobǝst</persName> is mentioned as well.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        
                        <item xml:id="e3">
                           <desc>The owner named in <ref target="#ms_i1"/>, <ref target="#ms_i2"/>, <ref target="#ms_i3"/>,
                              <ref target="#ms_i4"/> was <persName role="owner" ref="https://betamasaheft.eu/PRS11418SeqayaG">Śǝqāya Giyorgis</persName>.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        
                        <item xml:id="e4">
                           <locus target="#4v">Fol. 4v</locus>
                           <desc>The owner named in <ref target="#ms_i5"/>, <ref target="#ms_i7"/>, <ref target="#ms_i8"/>,
                              <ref target="#ms_i9"/>, <ref target="#ms_i10"/>, <ref target="#ms_i11"/>, <ref target="#ms_i12"/>,
                              <ref target="#ms_i14"/>, <ref target="#ms_i15"/>, <ref target="#ms_i16"/>, <ref target="#ms_i17"/>,
                              <ref target="#ms_i18"/>, <ref target="#ms_i19"/> and <ref target="#ms_i20"/> was 
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11415KidanaM">Kidāna Māryām</persName>, who explains in <ref target="#ms_i18"/>, <ref target="#ms_i19"/> and <ref target="#ms_i20"/>
                              that <persName ref="https://betamasaheft.eu/PRS11418SeqayaG">Śǝqāya Giyorgis</persName> is his brother.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        
                        <item xml:id="e5">
                           <desc>The owners named in <ref target="#a3"/> were 
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11416KenfaMikael">Kǝnfa Mikāʾel</persName> and 
                              <persName role="owner" ref="https://betamasaheft.eu/PRS11417WalattaGiyorgis">Walatta Giyorgis</persName>.</desc>
                           <q xml:lang="gez"/>
                        </item>
                        

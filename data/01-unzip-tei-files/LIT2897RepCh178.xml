            <t:div type="textpart" xml:id="malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ እምዝክረ፡ ማሕሌት፡ አዳም፨</t:l>
                  <t:l n="2">ለሥዕርተ፡ ርእስኪ፡ ሰላም፡ ዘሕበሪሁ፡ ጸሊም፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ሕይወተ፡ ኵሉ፡ ዓለም፨</t:l>
                  <t:l n="4">ብኪ፡ ተሣረሩ፡ እለ፡ ዘሥጋ፡ ወደም፨</t:l>
                  <t:l n="5">ወመላእክት፡ ዘልዑል፡ አርያም፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለርእስኪ፡ ወለገጽኪ፡ ጎህ፨</t:l>
                  <t:l n="2">ለቀራንብትኪ፡ ሰላም፡ ወለአዕይንትኪ፡ ብሩህ፨</t:l>
                  <t:l n="3">አድኅንኒ፡ ሐና፡ እምኀዘነ፡ ወወይሌ፡ ወላህ፨</t:l>
                  <t:l n="4">ከመ፡ ድኀነ፡ በእንቲአኪ፡ እምሰርመ፡ አበሳ፡ ወአይኀ፨</t:l>
                  <t:l n="5">ምእመን፡ ምስለ፡ ደቂቁ፡ ወጻድቅ፡ ኖኅ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ሰላም ለአእዛንኪ፡ ወለመላትሕኪ፡ በአምኆ፨</t:l>
                  <t:l n="2">ለአእናፍኪ፡ ሰላም፡ ወለከናፍርኪ፡ በስብሖ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ኢይምጽአኒ፡ ሰይፈ አይኆ፨</t:l>
                  <t:l n="4">ፀርየሰ፡ ለእመ፡ ሐነፀ፡ በሰማይ፡ ጽርሖ፨</t:l>
                  <t:l n="5">በህየ፡ ፍጡነ፡ ሰይፈ፡ ሞት፡ ይንጽሖ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ሰላም፡ ለአፉኪ፡ ወለአስናንኪ፡ ዕብነ፡ በረድ፨</t:l>
                  <t:l n="2">ለልሳንኪ፡ ሰላም፡ ወለቃልኪ፡ መርዕድ፨</t:l>
                  <t:l n="3">ለእስትንፋስኪ፡ ወለጕርዔኪ፡ ወለዘዚአኪ ከሣድ፨</t:l>
                  <t:l n="4">ከመ፡ ታርእዪኒ፡ ሐና፡ ኀልፈተ፡ ፀርየ፡ አብድ፨</t:l>
                  <t:l n="5">ናሁ፡ እፀንሐኪ፡ በዝንቱ፡ ዓፀድ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ሰላም፡ ለመታክፍትኪ፡ መንጦላዕተ፡ ዘባን፡ ዘተዋሐዳ፨</t:l>
                  <t:l n="2">ለእንግድዓኪ፡ ረቅ፡ ወለሕጽንኪ፡ ሰሌዳ፨</t:l>
                  <t:l n="3">መጽሐፈ፡ ሕይወት፡ ሐና፡ ወእመ፡ ማርያም፡ ሳይዳ፨</t:l>
                  <t:l n="4">ይደምሰሱ፡ ፀረ፡ ዚአየ፡ ወኢይትርፉ ለፍዳ፨</t:l>
                  <t:l n="5">ከመ፡ ተደምስሰ፡ ወልዳ፡ ኃጕል፡ ይሁዳ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ሰላም፡ ለአእዳውኪ፡ ዘምስለ፡ መዘርእ፡ ወኵርናዕ፨</t:l>
                  <t:l n="2">ለእመታትኪ፡ ሰላም፡ ወለእራኃትኪ፡ አርባዕ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ወእምሔውተ፡ ክርስቶስ፡ እግዚእ፨</t:l>
                  <t:l n="4">ይሀኃጐሉ፡ ፀረ፡ ዚአየ፡ በናተ፡ አምላክ፡ ኅቡእ፨</t:l>
                  <t:l n="5">በከመ፡ ተኃጕለ፡ ቅድመ፡ ኤግሎም፡ ረሲዕ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሰላም፡ ለአፃብዕኪ፡ ፅዕዳዌ፡ አጽፋር፡ ዘገልበቦ፨</t:l>
                  <t:l n="2">ለአጥባትኪ፡ ሰላም፡ ወለዘዚአኪ፡ ገቦ፨</t:l>
                  <t:l n="3">ዕበያትኪ፡ ሐና፡ ዕፁብ፡ ለተናብቦ፨</t:l>
                  <t:l n="4">መቅሠፍተ፡ ምንዳቤ፡ ይንሣእ፡ ፀረ፡ ዚአየ፡ አስቦ፨</t:l>
                  <t:l n="5">ለአርዌ፡ ርጉም፡ ይትበሀል፡ ዘነቦ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">ሰላም፡ ለከርሥኪ፡ ወለልብኪ ይደሉ፨</t:l>
                  <t:l n="2">ለአማዑትኪ፡ ሰላም፡ ወለንዋየ ውስጥኪ፡ ኵሉ፨</t:l>
                  <t:l n="3">ለህሊናኪ፡ ሐና፡ ዘኢይትረከብ አምሳሉ፨</t:l>
                  <t:l n="4">ብኪ፡ ይትሜክሑ፡ ወብኪ፡ ያጸሉ፨</t:l>
                  <t:l n="5">ፍጥረታት፡ ዘታሕቱ፡ ወፍጥረታት፡ ዘላዕሉ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="9">
                  <t:l n="1">ሰላም፡ ለኀንብርትኪ፡ ወለማኀፀንኪ፡ ቡሩክ፨</t:l>
                  <t:l n="2">ለአቍያጽኪ፡ ሰላም፡ ዘምስለ፡ አብራክ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ወእምሔውተ፡ ክርስቶስ፡ አምላክ፨</t:l>
                  <t:l n="4">ለእመ፡ ይፀብዑኒ፡ በጽባሕ፡ ወሠርክ፨</t:l>
                  <t:l n="5">ፍኖተ፡ ዐርየ፡ ዕዕዊ፡ በሦክ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="10">
                  <t:l n="1">ሰላም፡ ለአእጋርኪ፡ ወለሰከናኪ፡ ወትረ፨</t:l>
                  <t:l n="2">ለመከየድኪ፡ ሰላም፡ ወለአፃብዕኪ፡ ዘተሠርገዋ፡ አጽፋረ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ እስእለኪ፡ ነገረ፨</t:l>
                  <t:l n="4">እስከ፡ ማእዜኑ፡ እግዚእትየ፡ እሄሉ፡ ኀቡረ፨</t:l>
                  <t:l n="5">ምስለ፡ እለ፡ ይጸልዑ፡ ሰብእ፡ ሰላም፡ ወፍቅረ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="11">
                  <t:l n="1">ሰላም፡ ለቆምኪ እንበለ፡ ሕፀዕ፡ ወንትጋ፨</t:l>
                  <t:l n="2">ለመልክእኪ፡ ሰላም፡ ወለፀአተ፡ ነፍስኪ፡ ምስለ፡ በድነ፡ ሥጋ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ወእምሔውተ፡ ክርስቶስ፡ ቀዳሜ፡ ጸጋ፨</t:l>
                  <t:l n="4">ይትዐሠር፡ ልሳነ፡ ፀርየ፡ ዘከመነ፡ መንሱት፡ ወጹጋ፨</t:l>
                  <t:l n="5">በሰናስል፡ ጽኑዕ፡ ወበድሩክ፡ ጋጋ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="12">
                  <t:l n="1">ሰላም፡ ለግንዘተ ሥጋኪ፡ በአልባስ፡ ሜላት፡ ኢማሳኒ፨</t:l>
                  <t:l n="2">ለመቃብርኪ፡ ሰላም፡ ውስተ፡ ርስተ፡ አቡኪ፡ ምድረ፡ ዮፎኒ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ወእምሔውተ፡ ክርስቶስ፡ መድኃኒ፨</t:l>
                  <t:l n="4">ባሕቱ፡ ለንስሐ፡ ንስቲተ፡ አጽንሕኒ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="13">
                  <t:l n="1">አኮ፡ አኮ፡ በአብዝኆ፡ ነገር፡ ወተርጕሞ፡</t:l>
                  <t:l n="2">አላ፡ ኀዳጠ፡ ወደስኩኪ፡ በኢያርምሞ፨</t:l>
                  <t:l n="3">ሐና፡ ግበሪ፡ ለልብየ፡ ዘይኤድሞ፨</t:l>
                  <t:l n="4">እመ፡ ሰፍሐ፡ አዕፁቂሁ፡ ወለእመ፡ አንኅ፡ ቆሞ፨</t:l>
                  <t:l n="5">ለጕንደ፡ ፀርየ፡ ሰይፈ፡ ሞት፡ ይግዝሞ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="14">
                  <t:l n="1">ስብሐት፡ ይደሉ፡ ለማርያም፡ በሰጊድ፡ ወዝማሬ፨</t:l>
                  <t:l n="2">ዘምስለ፡ ፪ሆን፡ በኁባሬ፨</t:l>
                  <t:l n="3">እመ፡ ማርያም፡ ሐና፡ ዕንቈ፡ ሶም፡ ወወራውሬ፨</t:l>
                  <t:l n="4">ይደምሰሱ፡ ፀረ፡ ዚአየ፡ ወኢይትርፉ፡ ለፍሬ፨</t:l>
                  <t:l n="5">ከመ፡ ተደምሰሱ፡ ደቂቁ፡ ለቆሬ፨</t:l>
               </t:lg>
            </t:div>
            <t:div type="textpart" xml:id="tarafa-malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለኪ፡ ጥዕምተ፡ ስም፡ ወዝክር፡ በፄወ፡ መለኮት፡ ቅሱም፨</t:l>
                  <t:l n="2">ሐና፡ ቅድስት፡ እመ፡ ማርያም፨</t:l>
                  <t:l n="3">ዘነገሥኪ፡ በአርያም፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለኪ፡ ሐና፡ ጽባሕ፡ ወማርያም፡ ሰማይ፨</t:l>
                  <t:l n="2">እንተ፡ ወለደቶ፡ ለክርስቶስ፡ ፀሓይ፨</t:l>
                  <t:l n="3">ዘያውዒ፡ ሦከ፡ ጌጋይ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ሰላም፡ ለኪ፡ ዘኪልቂዶን፡ ሐና፡ ወዘባሕርይ፡ ጽዱል፨</t:l>
                  <t:l n="2">እንተ፡ እምኔኪ፡ ወፅአት፡ ማርያም፡ ድንግል፨</t:l>
                  <t:l n="3">ዘጾረቶ፡ ለነበልባል፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ሰላም፡ ለኪ፡ ከመ፡ ዳሲለደስ፡ ሰማዕት፡ ወገላውዴዎስ፡ ካልኡ፨</t:l>
                  <t:l n="2">ሕዝብኪ፡ ሐና፡ ፍሬ፡ ጽድቅ፡ ይንሥኡ፨</t:l>
                  <t:l n="3">በስምኪ፡ እለ፡ ተጋብኡ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ሰላም፡ ለኪ፡ ሶበ፡ ሰማዕኩ፡ በዜና፡ ለጥበበ፡ ሰማይ፡ መጠና፨</t:l>
                  <t:l n="2">ኅሊናየ፡ ትቤ፡ ሀለወት፡ ሐና፨</t:l>
                  <t:l n="3">ለነፍስየ፡ ዘታድኅና፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ሰላም፡ ለኪ፡ የዋሂት፡ ሐና፡ ወመንፈሳዊት፡ ርግብ፨</t:l>
                  <t:l n="2">እንተ፡ እምኔኪ፡ ወፅአት፡ ማርያም፡ ጠባብ፨</t:l>
                  <t:l n="3">ዘጾረቶ፡ ለቃለ፡ አብ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሰላም፡ ለኪ፡ ሐና፡ ንጽሕት፡ ወማርያም፡ ጳጦስ፨</t:l>
                  <t:l n="2">እንተ፡ ወለደቶ፡ ለክርስቶስ፡ ንጉሥ፨</t:l>
                  <t:l n="3">ኀጢአተ፡ ዘይደመስስ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">ሰላም፡ ለኪ፡ አመኒ፡ መጽአኒ፡ መልአከ፡ ሞት፡ መስጢ፨</t:l>
                  <t:l n="2">እምኔየ፡ ሐና፡ ኢትትፈለጢ፨</t:l>
                  <t:l n="3">መጽሐፈ፡ ዕዳየ፡ እንዘ፡ ትሠጥጢ፨</t:l>
                  <t:l n="4">ወላህየ፡ በሐሤት፡ ወልጢ፨</t:l>
               </t:lg>
            </t:div>
         </t:div>
         
         <t:div type="edition">
            <t:note>The text edition follows <t:ref type="mss" corresp="https://betamasaheft.eu/BDLaethe38">Oxford, Bodleian Library, Bodleian Aeth. e. 38</t:ref>.</t:note>
            <t:div type="textpart" subtype="incipit" xml:lang="gez">
               <t:ab>
                  ሰላም፡ ለዝክረ፡ ስምኪ፡ እምዝክረ፡ ማኅሌት፡ አዳም።
               </t:ab>
            </t:div>
         </t:div>
      </t:body>
   </t:text></TEI>
                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title ref="https://betamasaheft.eu/LIT1763Legend">Prayer for protecting suckling infants</title>
                            <incipit xml:lang="gez">በሰመ፡ <gap reason="ellipsis"/> በስመ፡ እግዚአብሔር፡ ሕያው፡ ነባቢ፡ ወተናጋሪ፡ ጸሎተ፡ ቅዱስ፡ ሱስንዮስ፡ በእንተ፡
                                አሰስሎ፡ ደዌ፡ እምሕፃናት፡ እለ፡ ይጠብው፡ ጥበ፡ ይበቍዕ፡ ዓዲ፡ ለብእሲት፡ ወኢየሐይው፡ ላቲ፡ ደቂቃ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title ref="https://betamasaheft.eu/LIT7146Zar">Ṣalot baʾǝnta ḥǝmāma Zār wa-Tǝgridā</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ዛር፡ ወትግሪዳ፡ አላሁማ፡ አላሁማ፡ አላሁማ፡ ያቹነጂ፡ አለመለኪ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title ref="https://betamasaheft.eu/LIT4624Prayer">Prayer against stomach pain</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ <sic resp="PRS8999Strelcyn">ውጋአት፡ </sic> 
                                ወጨንቀት፡ ምድምያስ፡ ምድምያስ፡ ምድምያስ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title ref="https://betamasaheft.eu/LIT7220SalotTekto">Ṣalot baʾǝnta ḥǝmāma dam wa-wǝḥzata dam wa-tǝkto</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ደም፡ ወውኅዘተ፡ ደም፡ ወትክቶ፡ ሰስሎሜ፡ ሰስሎሜ፡ ሰስሎሜ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title ref="https://betamasaheft.eu/LIT2765RepCh49">Malkǝʾ-hymn (Salām) to Phanuel</title>
                            <incipit xml:lang="gez">ሰላም፡ ለከ፡ ሰዳዴ፡ አጋንንት፡ ፋኑኤል፡ ለእግዚአብሔር፡ እምጽርሑ፤</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

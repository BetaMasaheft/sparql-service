                     <summary/>

                     <msItem xml:id="p1_i1">
                        <locus from="1r" to="1v"/>
                        <title type="complete">Supplicative prayer</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                           አም፡ ላክን፡ አመላትኅ፡ ዘቤዘወነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተጸፋእክን፡ በእደ፡ ሰቃልያን፡ አይሁድ፡ ሰማይኒ፡ ዘነበረ፡ እጽወ፡ በእንቲአክን፡ ተርኅወ፡
                           <gap reason="lost"/>ተከሥተ፡ ከማሁ፡ ይትረኃው፡ ወይትፈታህ፡ አንቀጸ፡ ልብየ፡ ሊተ፡ ለኃዋ፡ ገብርክን፡ ወልደ።
                           <pb n="1v"/>
                           እግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ሊቀ፡ ካህናት፡ ወ<gap reason="lost"/>ኃጢአት፡ መፍቀሬ፡ ንስሐ፡ ወከባቴ፡ ዓበሳ፡ ለኃጥአን፡
                           <gap reason="lost"/>ፋ፡ ወልዱ፡ ወቃሉ፡ ለሕይወት፡ ዘሰረ<add place="above">ይ</add>ከ፡ ኃጢአተ፡ ዓለም፡ ስረይ፡ ኃጢአትየ።
                        </incipit>
                        <explicit xml:lang="gez">
                           ሃሌ፡ ሉያ፡ ለአብ፡ ሃሌ፡ ሉያ፡ ለወልድ፡ ሃሌ፡ ሉያ፡ ለመንፈስ፡ ቅዱስ፡ ፫ ጊዜ፡ በ፡ ባርክ፡ <add place="above">ኦእግዚኦ፡</add> <gap reason="illegible"/>ለሥጋየ፡ ባርክ፡ <add place="above">ኦእግዚኦ፡</add>
                           ጸሎትየ፡ ወስእለትየ፡ ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ይዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ <gap reason="lost"/>ለኃጥእ፡ ገብርከ፡
                        </explicit>
                     </msItem>
                  </msContents>


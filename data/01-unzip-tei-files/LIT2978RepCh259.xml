         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥላሴ፨</l>
                  <l n="2">እዌጥን፡ ዘዚአክሙ፡ ውዳሴ፨</l>
                  <l n="3">ተፈሥሑ፡ ብየ፡ ማኅበረ፡ ነቢያት፡ እለ፡ ሙሴ፨</l>
                  <l n="4">ከመ፡ ትትፌሣሕ፡ ብእሲት፡ ዘይከውና፡ ወራሴ፨</l>
                  <l n="5">ሶበ፡ በዓለም፡ አጥረየት፡ ወወደት፡ ብእሴ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">እመሰ፡ ይትከሀለኒ፡ ፍጻሜ፨</l>
                  <l n="2">ውዳሴክሙ፡ ወጠንኩ፡ ለዓለመ፡ ዓለም፡ ቀዋሜ፨</l>
                  <l n="3">ማኅበረ፡ ነቢያት፡ ንግሩኒ፡ ወመሐሩኒ፡ ትርጓሜ፨</l>
                  <l n="4">ኢየኀሥሥ፡ እንበሌክሙ፡ ወኢይሰአል፡ ሐላሜ፨</l>
                  <l n="5">ለእመ፡ መዋዕል፡ ኀለፈ፡ ወጐንደየ፡ ዕድሜ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ በመጽሐፈ፡ ሕይወት፡ ዘይሄሉ፨</l>
                  <l n="2">ድኅረ፡ ዓለማት፡ ወዘውስቴቶሙ፡ ኵሉ፨</l>
                  <l n="3">ማኅበረ፡ ነቢያት፡ ጽሑፋን፡ ለእግዚአብሔር፡ በቃሉ፨</l>
                  <l n="4">ከመ፡ ትጽብኡ፡ ጸላእትየ፡ ወዕድዋንየ፡ ትትትሉ፨</l>
                  <l n="5">ጽንዑ፡ እምአንበሳ፡ ወእምድብ፡ ኀይሉ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ሰላም፡ ለመቃብሪክሙ፡ እለ፡ ኮኖሆን፡ አብያተ፨</l>
                  <l n="2">ለበድነ፡ ሥጋክሙ፡ ሕሩም፡ ዘእምዕፄያት፨</l>
                  <l n="3">ውዳሴክሙ፡ ፈጸምኩ፡ ማኅበረ፡ ክርስቶስ፡ ነቢያት፨</l>
                  <l n="4">ጸግዉኒ፡ ንዋየ፡ ጽድቅ፡ በዘዚአክሙ፡ ሠናይት፨</l>
                  <l n="5">ዘመስጠቶ፡ ኢይክል፡ ዲያብሎስ፡ ፈያት፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ምንትኑ፡ እምዐሠይክዎ፡ ዕሤተ፨</l>
                  <l n="2">ለብእሲተ፡ ኤንዶር፡ ጠባብ፡ እንተ፡ ታነሥእ፡ ዘሞተ፨</l>
                  <l n="3">በኅቡእ፡ ዘይከውን፡ ወዘይትገበር፡ ክሡተ፨</l>
                  <l n="4">ይዜንወኒ፡ ምሥጢረ፡ ወይንግረኒ፡ ትንቢተ፨</l>
                  <l n="5">አሐደ፡ እምነቢያት፡ ከመ፡ ታንቅሕ፡ ሊተ፨</l>
               </lg>
               <lg type="stanza" n="55">
                  <l n="1">በእግዚአብሔር፡ አምላክ፡ እንዘ፡ እፀንስ፡ ኅሊና፨</l>
                  <l n="2">ለልሳንየ፡ እምሐቌሁ፡ ወለከናፍርየ፡ እማሕፀና፨</l>
                  <l n="3">ናሁ፡ ወለድኩ፡ ዘማኅበረ፡ ነቢያት፡ ዜና፨</l>
                  <l n="4">ለወላድ፡ ብእሲት፡ እምድኅረ፡ ወሊድ፡ ስእና፨</l>
                  <l n="5">ከመ፡ ወለደቶ፡ ለሳሙኤል፡ ሐና፨</l>
               </lg>
               <lg type="stanza" n="56">
                  <l n="1">እምዝንቱ፡ ቃለ፡ መጽሐፍክሙ፡ ዘአሰሰለ፡ ሐአሐተ፨</l>
                  <l n="2">እንዘ፡ ትትቤ፡ ተልዎ፡ ነቢያት፡ ወትትመዐዑ፡ መዐተ፨</l>
                  <l n="3">አሰስልዎ፡ እምዕፀ፡ ሕይወት፡ ወረስይዎ፡ እቱተ፨</l>
                  <l n="4">ወለእመ፡ ቦቱ፡ ወሰከ፡ ንስትአ፨</l>
                  <l n="5">እግዚአብሔር፡ ላዕሌሁ፡ ይወስክ፡ መቅሠፍተ፨</l>
               </lg>
            </div>
         </div>         

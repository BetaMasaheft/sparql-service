                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="10"/>
                            <title ref="https://betamasaheft.eu/LIT1716Kidanz">Kidān za-nagh</title>
                            <bibl corresp="http://zotero.org/groups/358366/items/TQ2NBVAC"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1866Chrestomathia"/><title level="m">Chrestomathia Aethiopica edita et glossario explanata</title><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Christian Friedrich August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></editor><pubPlace>Lipsiae</pubPlace><publisher>T. O. Weigel</publisher><date>1866</date><note type="url">https://archive.org/details/bub_gb_V2XoxZmczckC</note><citedRange unit="page">46-50</citedRange></bibl>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="11" to="24"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkǝʾ-hymn to Our Lady Mary</title>
                            <note>It contains 58 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ።
                                <lb n="2"/>እምነ፡ ከልበኔ፡ ወቁስጥ፡ ወእምነ፡ ሰንበልት፡ ምዑዝ።
                                <lb n="3"/>ማርያም፡ ድንግል፡ ለባሲተ፡ ዐቢይ፡ እዘዝ።
                                <lb n="4"/>ይሰቅየኒ፡ ለለጽባሑ፡ ወይነ፡ ፍቅርኪ፡ አዚዝ።
                                <lb n="5"/>ከመ፡ ይሰቅዩ፡ ውኂዝ።
                                <lb n="6"/>ለሠናይ፡ አርዝ።
                                </q>
                            </note>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="24" to="35"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾ-hymn to Jesus Christ</title>
                            <note>It contains 53 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለዝክረ፡ ሰምከ፡ ስመ፡ መሐላ፡ ዘኢይሔሱ።
                                <lb n="2"/>ዘአንበረ፡ ቅድመ፡ እግዚአብሔር፡ በአትሮንሱ።
                                <lb n="3"/>ኢየሱስ፡ ክርስቶስ፡ ለዳዊት፡ ባሕርየ፡ ከርሡ።
                                <lb n="4"/>አክሊለ፡ ስምከ፡ እንዘ፡ ይትቄጸል፡ በርእሱ።
                                <lb n="5"/>አኅጉረ፡ ፀር፡ ወሪሰ፡ ኢያሱ።
                                </q>
                            </note>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="36" to="84"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">ስዋስው፡ ብሂል፡ መሸጋገርያ፡ ወመሰላል፡</title>
                            <note>Gǝʿǝz-Amharic vocabulary</note>
                            
                            <msItem xml:id="ms_i4.1">
                                <locus from="43" to="45"/>
                                <title>ጽሕፍ፡ ነገረ፡ ሐጻውንት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.2">
                                <locus from="45" to="48"/>
                                <title>ጽሕፍ፡ ነገረ፡ ብርሃናት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.3">
                                <locus from="48" to="50"/>

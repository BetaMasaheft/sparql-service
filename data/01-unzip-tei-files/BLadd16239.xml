                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.4">
                                <locus from="50" to="52"/>
                                <title>ጽሕፍ፡ ነገረ፡ ማያት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.5">
                                <locus from="52" to="54"/>
                                <title>ጽሕፍ፡ ነገረ፡ ባእስ፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.6">
                                <locus from="54" to="60"/>
                                <title>ጽሕፍ፡ ነገረ፡ አዝርዕት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.7">
                                <locus from="60" to="63"/>
                                <title>ጽሕፍ፡ ነገረ፡ ሕዋሳት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.8">
                                <locus from="63" to="64"/>
                                <title>ጽሕፍ፡ ነገረ፡ ፀብእ፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.9">
                                <locus from="64" to="66"/>
                                <title>ጽሕፍ፡ ነገረ፡ ዕፀዋት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.10">
                                <locus from="66" to="68"/>
                                <title>ጽሕፍ፡ ነገረ፡ አራዊት፡ </title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.11">
                                <locus target="#68"/>
                                <title>ጽሕፍ፡ ነገረ፡ ሕማም፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.12">
                                <locus from="68" to="71"/>
                                <title>ጽሕፍ፡ ነገረ፡ አልባሳት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.13">
                                <locus from="71" to="73"/>
                                <title>እጽሕፍ፡ ነገረ፡ አጽህርት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.14">
                                <locus from="73" to="75"/>
                                <title>ጽሕፍ፡ ነገረ፡ መሰናቁት፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.15">
                                <locus target="#75"/>
                                <title>ጽሕፍ፡ ነገረ፡ ሥጋ፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.16">
                                <locus from="75" to="77"/>
                                <title>ጽሕፍ፡ ነገረ፡ አዕዋፍ፡</title>
                                <note/>
                            </msItem>
                            <msItem xml:id="ms_i4.17">
                                <locus from="77" to="84"/>
                                <title>Elements of grammar</title>
                                <note>
                                <q xml:lang="gez">
                                    <lb n="1"/>እንዘ፡ ይበልዕ፡ ሲበላ።
                                    <lb n="2"/>እንዘ፡ ይሰቲ፡ ሲጠጣ።
                                    <lb n="3"/>እንዘ፡ የሐውር፡ ሲሄድ።
                                    <lb n="4"/>እንዘ፡ ይትመየጥ፡ ሲመለስ።
                                    <lb n="5"/>እንዘ፡ ኢይገብር፡ ሰያደርግ፡ ሰለደርግ።
                                    <lb n="6"/>እንዘ፡ ኢይረክብ፡ ሰያገኝ፡ ሰለገኝ።
                                    </q>
                        </note>
                            </msItem>
                        </msItem>

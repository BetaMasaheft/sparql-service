                        <additions>
                            <list>   
                                <item xml:id="a1">
                                    <locus target="#2r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ገድለ፡ ኪሮስ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                           </q>
                                </item>
                                <item xml:id="e1">
                                    <desc>The name of the first owner was <persName ref="https://betamasaheft.eu/PRS12491Fesehagiyorgis">Fǝśśǝḥa Giyorgis</persName>, who has been substituted with  
                                        on <locus from="108v"/> , <locus from="109v"/>  that of <persName ref="https://betamasaheft.eu/PRS12496HaylaGiyorgis">Ḫāyla Giyorgis</persName> 
                                        who presented  the book to a church of <placeName ref="https://betamasaheft.eu/INS0905GabraManfas">Gabra Manfas Qǝddus</placeName> 
                           </desc>
                                    <g xml:lang="gez">ለዝንቱ፡ መጽሐፍ፡ ዘወሀቦ፡ ቦኸር፡ ኃይል፡ ጊዮርጊስ፡ ለአቡነ፡ ገብረ፡ መንፈ፡  ቅዱስ፡ ከመ፡ ይኩኖ፡ ለመድኃኒተ፡ ሥጋ፡ ወነፍስ።</g>
                                </item>
                                
                            </list>
                            
                            
                            
                            
                        </additions>

                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="2r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1468GadlaK">Gadla Kiros</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="2r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2851RepCh133">Malkəʾa Kiros</title>
                                <textLang mainLang="gez"/>
                                
                                <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ኀበ፡ ዓምደ፡ ወርቅ፡ ዘተጽሕፈ።</incipit>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <title ref="https://betamasaheft.eu/LIT1119DossierQMQ">Hagiographic Dossier of St Gabra Manfas Qǝddus</title>
                        <msItem xml:id="ms_i2.1">
                            <locus from="57r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1451GadlaG">Gadla Gabra Manfas Qǝddus (general record)</title>
                            <textLang mainLang="gez"/>
                            
                            <incipit xml:lang="gez">ንዌጥን፡ ዝንተ፡ ገድሎ፡ ለብፁዕ፡ ወለቅዱስ፡ etc  አቡነ፡ ገብረ፡ መንፈስ፡
                                ቅዱስ፡ ገዳማዊ፡ ዘሠረፀ፡ ወሠረቀ፡ እምሀገረ፡ ንሒሳ፡ መትሕተ፡ ምድር፡ እምደቡብ፡ ዘግብፅ። ወነበረ፡ 
                                ገዳመ፡ ፭፻፷ወ፪፡ ዓመታተ፡ ወወፂኦ፡ እምህየ፡ ኤለ፡ ገዳመተ፡ እትዮጵያ፡ 
                                ወነበረ፡ በዝቋላ፡ ወበኀቤሃ፡ በምድረ፡ ከብድ፡ በምድረ፡ ከብድ፡ ፪፻፷ወ፪ዓመተ ዕራቁ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2.2">
                            <locus from="109r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3977Taammer">Taʾammǝra Gabra Manfas Qǝddus</title>
                            <textLang mainLang="gez"/>
                            
                            
                        </msItem>
                        
                        <msItem xml:id="ms_i2.3">
                            <locus from="124r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5776HymnGabraManfasQeddus">Hymn to Gabra Manfas Qǝddus</title>
                            <textLang mainLang="gez"/>
                            
                            <incipit xml:lang="gez">ገብረ፡ መንፈስ፡ ቅዱስ፡ አቡየ፡ ተአምሪከ፡ ዋሕድ። ብእሲ፡ መነኮስ፡ ዘኃጢአቱ፡ ፍድፉድ።</incipit>
                        </msItem>
                        </msItem>
                    </msContents>
                    
                    
                    
                    
                    
                    

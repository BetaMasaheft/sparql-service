      <t:body>
         <t:listPerson>
            <t:person sex="1">
          
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ዮፍታሔ፡ ንጉሤ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yoftāhe Nǝguśe</t:persName>
                  
                  
               <t:persName>
                  <t:roleName type="title">qaññ getā</t:roleName>
               </t:persName>
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
            
                  <t:occupation type="literary">writer</t:occupation>
               <t:birth notBefore="1892" notAfter="1893">He was born in <t:placeName ref="https://betamasaheft.eu/LOC2272DabraG">ደብረ፡ ገነት፡ ኤልያስ፡</t:placeName> between <t:date>1892-1893</t:date>. </t:birth>
                  
                  
                  <t:floruit notBefore="1906" notAfter="1947">
                     He was a prolific writer with a pronounced background in traditional church education and 
                     a pioneer of Ethiopian theatre and Amharic drama. 
                     He was first appointed as <t:persName ref="https://betamasaheft.eu/PRS10369Yoftahe">
                     <t:roleName type="title">mač̣ane</t:roleName>
                  </t:persName> and 
                     <t:persName ref="https://betamasaheft.eu/PRS10369Yoftahe">
                     <t:roleName type="title">qaññgetā</t:roleName>
                  </t:persName>, later the head of 
                     <t:placeName ref="https://betamasaheft.eu/LOC2646DemahG">Dǝmaḥ Gännät ʿAlämayyähu Šašu</t:placeName>. In <t:date>1917/1918</t:date> he became 
                     <t:persName ref="https://betamasaheft.eu/PRS10369Yoftahe">
                     <t:roleName type="title">dabtarā</t:roleName> 
                  </t:persName> and later  
                     <t:persName ref="https://betamasaheft.eu/PRS10369Yoftahe">
                     <t:roleName type="title">ʾaggāfāri</t:roleName> 
                  </t:persName> of <t:placeName ref="https://betamasaheft.eu/LOC2271DabraG">Dabra Gannat ʾAbbo</t:placeName>. 
                     In <t:date>1923/24</t:date>, he was employed as an Amharic teacher at <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</t:persName> Secondary School where he started his first literary works. 
                   </t:floruit>
                  
               <t:death notBefore="1946" notAfter="1947">He died in <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> between<t:date>1946-1947</t:date>.</t:death>
                  
               </t:person>
               
               
         </t:listPerson>
         
         

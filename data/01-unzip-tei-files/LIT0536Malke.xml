      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0536</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ስቡሕ፡ ዘተሰብሐ፡ እምቅድም፨</l>
                  <l n="2">በአፈ፡ መላእክት፡ ወሰብእ፡ ለገቢረ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="3">ድርሳነ፡ መልክእከ፡ እንብብ፡ ተክለ፡ ማርያም፡ ፍጹም፨</l>
                  <l n="4">አስትየኒ፡ ወይነ፡ ጥበብ፡ በአርአያ፡ እሳት፡ ወፍሕም፨</l>
                  <l n="5">በከመ፡ አስተዮ፡ ለዕዝራ፡ ኡራኤል፡ ሥዩም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዐ፡ በዝክረ፡ ስማ፨</l>
                  <l n="2">ለድንግለ፡ ሙሴ፡ ነቢይ፡ ዘትሰመይ፡ ካልእተ፡ ራማ፨</l>
                  <l n="3">ተክለ፡ ማርያም፡ እንጦንስ፡ ወመቃርስ፡ መፍቀሬ፡ ጻማ፨</l>
                  <l n="4">አድኅነኒ፡ በረድኤትከ፡ እምእደ፡ ፀራዊ፡ መስቴማ፨</l>
                  <l n="5">ከመ፡ አምላከ፡ ጽድቅ፡ ይፈትሕ፡ በዐቢይ፡ ግርማ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ለእግዚአብሔር፡ በፈቃዱ፨</l>
                  <l n="2">ወለበድነ፡ ሥጋከ፡ ህልው፡ ለደብረ፡ ማርያም፡ ውስተ፡ ዐጸዳ፨</l>
                  <l n="3">ተክለ፡ ማርያም፡ አቡነ፡ ፍትወ፡ ምግባር፡ ዘእምናርዱ፨</l>
                  <l n="4">ባርከነ፡ አምሳለ፡ ኖኅ፡ በበረከተ፡ ሤም፡ አሐዱ፨</l>
                  <l n="5">ከመ፡ ባረኮ፡ አብርሃም፡ ለይስሐቅ፡ ወልዱ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በድምፀ፡ ከበሮ፡ ወበብኅንዛ፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ መልአከ፡ ሰማይ፡ ዘይናዝዛ፨</l>
                  <l n="3">ተክለ፡ ማርያም፡ ያዕቆብ፡ ሰዋስው፡ ዘምድረ፡ ሎዛ፨</l>
                  <l n="4">ሥጋከ፡ ትዕርግ፡ እምጻማሃ፡ አመ፡ ፈጣሪሃ፡ አዘዛ፨</l>
                  <l n="5">ህየንተ፡ አምኃ፡ ናርዶስ፡ ወሀበ፡ መዐዛ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለተፅዕኖትከ፡ በፈረሰ፡ መንፈስ፡ ጸዐዳ፨</l>
                  <l n="2">ምስለ፡ ዘርአ፡ ያዕቆብ፡ ንጉሥ፡ ዘሠረጸ፡ እምቤተ፡ ይሁዳ፨</l>
                  <l n="3">ተክለ፡ ማርያም፡ ፍትው፡ ወምዑዝ፡ እምጽጌ፡ ረዳ፨</l>
                  <l n="4">ጸሐፈኒ፡ ከመ፡ ቀለም፡ ውስተ፡ ልብከ፡ ሰሌዳ፨</l>
                  <l n="5">ወበለኒ፡ ጊዜ፡ ሞትየ፡ ዘአነ፡ እንግዳ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ይትባረክ፡ መድኃኔ፡ ዓለም፡ በጽንዐ፡ ሕያው፡ ጥበቡ፨</l>
                  <l n="2">ድርሳነ፡ መልክእከ፡ እንብብ፡ ረሰየኒ፡ ማእከለ፡ ሕዝቡ፨</l>
                  <l n="3">ተክለ፡ ማርያም፡ አቡየ፡ ለክርስቶስ፡ ወርኀ፡ ምግቡ፨</l>
                  <l n="4">ጸግወኒ፡ በቅድመ፡ ድርሳን፡ ለኁላቌከ፡ ዐሳቡ፨</l>
                  <l n="5">እስመ፡ መንፈስ፡ ቅዱስ፡ ኅቡእ፡ ዘእምኅቡእ፡ መዝገቡ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
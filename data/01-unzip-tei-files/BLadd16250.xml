                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="334"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1544Gebrah">መጽሐፈ፡ ግብረ፡ ሕማማምት፡</title>
                            
                        <msItem xml:id="ms_i1.1">
                            <locus from="1" to="3"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Introduction">Gǝbra Ḥǝmāmāt, Introduction</title>
                            <note>
                           <quote xml:lang="gez">
                            </quote>
                        </note>
                        </msItem>
                        
                            <msItem xml:id="ms_i1.2">
                            <locus from="4" to="16"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#PalmSundayGH">Gǝbra Ḥǝmāmāt, Palm Sunday</title>
                                <note>It includes <ref type="work" corresp="https://betamasaheft.eu/LIT3839Agains">Dǝrsān za-qǝddus Yoḥannǝs ʾafa warq baʾǝnta hosāʿnā</ref> (<q xml:lang="gez">ተግሣጽ፡ ዘአባ፡ ዮሐንስ፡ አፈ፡ በረከት፡</q>).</note>
                        </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="16v" to="43"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Monday">Gǝbra Ḥǝmāmāt, Monday</title>
                                <note>It includes the exhortation by <persName ref="https://betamasaheft.eu/PRS8823Shenute">Shenute of Atripe</persName> for the first hour of the day, <ref type="work" corresp="https://betamasaheft.eu/LIT2122OntheF">On the Fig Tree</ref>, 
                                    an anonymous exhortation for the ninth hour, and a homily by <persName ref="https://betamasaheft.eu/PRS8823Shenute">Shenute of Atripe</persName> for the eleventh hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="43v" to="67"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Tuesday">Gǝbra Ḥǝmāmāt, Tuesday</title>
                                <note>It includes the exhortation by <persName ref="https://betamasaheft.eu/PRS8823Shenute">Shenute of Atripe</persName> for the morning hour, and an anonymous one for the ninth hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.5">
                                <locus from="67v" to="93"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Wednesday">Gǝbra Ḥǝmāmāt, Wednesday</title>
                                <note>It includes <ref type="work" corresp="https://betamasaheft.eu/LIT2144OntheT">Dǝrsān za-qǝddus Yoḥannǝs ʾAfa Warq baʾǝnta ʿaśru
          danāgǝl</ref> for the sixth hour of the night, an anonymous exhortation for the morning 
                                    hour, an exhortation by <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName> on <ref type="work" corresp="https://betamasaheft.eu/LIT1558Matthew">Wangel za-Mātewos</ref> 26:3-16 for the ninth hour of the day, 
                                    and an exhortation by Severian of Behnesa for the eleventh hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <locus from="93" to="132"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Thursday">Gǝbra Ḥǝmāmāt, Thursday</title>
                                <note>It includes exhortations by <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName> on <ref type="work" corresp="https://betamasaheft.eu/LIT1812GospelLuke">Wangel za-Luqās</ref> 22:1-6 for the morning hour 
                                    and on <ref type="work" corresp="https://betamasaheft.eu/LIT1812GospelLuke">Wangel za-Luqās</ref> 22:7-13 for the ninth hour, and an exhortation by <persName ref="https://betamasaheft.eu/PRS8823Shenute">Shenute of Atripe</persName> on the 
                                    Washing of the Feet.</note>
                            </msItem>
                        
                            <msItem xml:id="ms_i1.7">
                            <locus from="132v" to="159"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridaySixthNight">Gǝbra Ḥǝmāmāt, Readings for the sixth night hour on Friday</title>
                                <note>It includes <ref type="work" corresp="https://betamasaheft.eu/LIT2142OntheS">On the Saying of Christ "If it be Possible, Let this Cup Pass
          from Me"</ref> for the sixth hour of the night.</note>
                        </msItem>
                            
                            <msItem xml:id="ms_i1.8">
                                <locus from="159" to="185"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridayMorning">Gǝbra Ḥǝmāmāt, Readings for Friday morning (i.e. the first day hour)</title>
                                <note>It includes <ref type="work" corresp="https://betamasaheft.eu/LIT2098OnJuda">On Judas Iscariot</ref> and an anonymous homily for the morning hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.9">
                                <locus from="185v" to="222"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridayThird">Gǝbra Ḥǝmāmāt, Readings for the third day hour on Friday</title>
                                <note>It includes an anonymous exhortation and a homily by <persName ref="https://betamasaheft.eu/PRS5655Jacobof">Jacob of Sarug</persName> for the third hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.10">
                                <locus from="222v" to="245"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridaySixth">Gǝbra Ḥǝmāmāt, Readings for the sixth day hour on Friday</title>
                                <note>It includes the homily on the thief, and an additional homily by <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName>.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.11">
                                <locus from="245v" to="258"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridayNinth">Gǝbra Ḥǝmāmāt, Readings for the ninth day hour on Friday</title>
                                <note>For the ninth hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.12">
                                <locus from="258v" to="291"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#FridayEleventh">Gǝbra Ḥǝmāmāt, Readings for the eleventh day hour on Friday</title>
                                <note>It includes an anonymous exhortation for the eleventh hour</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.13">
                                <locus from="291" to="310"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Saturday">Gǝbra Ḥǝmāmāt, Saturday</title>
                                <note>It includes an exhortation by <persName ref="https://betamasaheft.eu/PRS2209Athanasi">Athanasius</persName> for the morning hour.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.14">
                                <locus from="311" to="316"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1544Gebrah#Sunday">Gǝbra Ḥǝmāmāt, Sunday</title>
                                <note>Readings for the two last days are written in a poor and abbreviated way.</note>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="316" to="334"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3838Prayer">ጸሎት፡ በእንተ፡ ተአምኆ፡ ቅዱሳን፡</title>
                            <explicit xml:lang="gez">ተፈጸመ፡ መጽሐፈ፡ ግብረ፡ ሕማማት፡ በብሔረ፡ ሻዋ፡ ወጸሓፊሁ፡ ገብረ፡ ሕይወት፡ አሜን፡</explicit>
                            <note>The subscriptio mentions <persName role="scribe" ref="https://betamasaheft.eu/PRS11042GabraH">Gabra Ḥǝywat</persName> as the scribe.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="335" to="365"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1750LahaMa">ድርሳን፡ ዘደረሰ፡ አባ፡ ሕርያቆስ፡ ኤጲስ፡ ቆጶስ፡ ዘብህንሳ፡ በእንተ፡ ክብራ፡ ለድንግል፡ ወንጽሕት፡ ማርያም፡ ወብካያ፡ ወላሃ፡ በእንተ፡ ስቅለቱ፡ ለወልዳ፡ ወመቃብሪሁ።</title>
                            </msItem>

                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Second half of the 19th century.</date>
                        <seg type="rubrication">Holy names; name of the King, Patriarch and
                           Metropolitan; incipit of Text I; titles or initial lines of the prayers
                           to be read; the Trinitarian formula; directives to the ministers;
                           elements of the punctuation signs; elements of Ethiopic numerals. 
                           On the incipit page of Text I (fols. 2r) a few lines are rubricated
                           (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#2r">2r</locus>: Simple uncoloured ornamental band
                        (anthropomorphic and floral motifs).</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Daily readings are indicated by the names of the
                              days of the week written in the upper margin: ዘሠሉስ: <locus target="#4v">fol. 4v</locus>. ዘረቡዕ: <locus target="#7v">fol.
                                 7v</locus>. ዘሐሙስ: <locus target="#10v">fol. 10v</locus>. ዘዓርብ:
                                 <locus target="#15r">fol. 15r</locus>. ዘቀዳም: <locus target="#19r">fol. 19r</locus>. ዘእኁድ: <locus target="#22r">fol.
                              22r</locus>.</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>- Crude drawings in pen: <locus target="#30v">fol.  30v</locus>. </desc>
                        </item>
                        <item xml:id="e3"><desc>The title ጻሎተ፡ እጣን is crudely written in pen in the inner side of the back board.</desc>
                        </item>
                     </list>
                  </additions>

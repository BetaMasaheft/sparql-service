               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">48.0</measure> folios, of which
                              <measure unit="leaf" type="blank"/> blank 1rv, 2rv, 3rv, 4rv, 48rv, in
                              <measure unit="quire">6.0</measure> quires (A+5). <dimensions type="outer">
                              <height unit="mm">460</height>
                              <width unit="mm">200</width>
                              <depth unit="mm">40</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">4</dim>
                                 <locus from="1r" to="4v"/>A(4/fols. 1r-4v) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="5v" to="12v"/> I(8/fols. 5v-12v) </item>
                              <item xml:id="q3">
                                 <dim unit="leaf">8</dim>
                                 <locus from="13r" to="20v"/> II(8/fols. 13r-20v) </item>
                              <item xml:id="q4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="21r" to="28v"/> III(8/fols. 21r-28v) </item>
                              <item xml:id="q5">
                                 <dim unit="leaf">8</dim>
                                 <locus from="29r" to="36v"/> IV(8/fols. 29r-36v) </item>
                              <item xml:id="q6">
                                 <dim unit="leaf">8</dim>
                                 <locus from="37r" to="44v"/> V(8; s.l.: 3, stub after 6; 6, stub
                                 after 3/fols. 37r-44v) </item>
                              <item xml:id="q7">
                                 <dim unit="leaf">4</dim>
                                 <locus from="45r" to="48v"/> VI(4; s.l.: 2, stub after 2; 3, stub
                                 after 2/ fols. 45r-48v).</item>
                           </list>
                        </collation>
                        <condition key="good">A part of fol. 2 is cut out.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="18">
                           <dimensions unit="mm">
                              <height>127</height>
                              <width>120</width>
                              <dim type="intercolumn">10</dim>
                           </dimensions>

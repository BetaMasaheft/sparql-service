                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>
                           <desc type="Asmat">
                              Asmat prayer against hail, Ṣälotä bäräd, <foreign xml:lang="gez">ጸሎተ፡ በረድ፡</foreign>.  Incipit: <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ጸሎተ፡ በረድ፡ ምግማኤል፡ ፍልፍልናኤ፡ ቱማን፡ ቱማን፡ ቱማን፡ ቁናኤል፡ ዝንቱ፡ አስማት፡ ዘይመይጦ፡ ለመብረቅ፡ ወያጸንዖ፡ ለነጐድጓድ፡ <gap reason="omitted"/>
                              </foreign>
                           </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#iiv(erso)" facs="003"> f. iiv(erso), cols. 1 and 2</locus>
                           <desc type="Asmat">
                              Asmat Prayer against Wild Animals, <foreign xml:lang="gez">ጸሎት፡ በእንተ፡ መስተሃድር፡</foreign>
                              Incipit: <foreign xml:lang="gez">በስመ፡ አብ፡ በል፡ ጢን፡ በቀጢን፡ ሰለባ፡ ኢትግብ፡ ወኢትቅረብ፡ ለንዋየ፡ ገብርከ፡ ዢብ፡ እግርማ፡ እንበለ፡ ጽጋማማ፡ ነምር፡ ፍራማ፡ ነምርእሞራ፡ ተንዛላይ፡ <gap reason="omitted"/></foreign>
                           </desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#76v #77r #77v #78r #78v" facs="079 080 081">Fols. 76v, 77r, 77v, 78r, 78v</locus>
                           <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkǝʾ-hymn to
                                                  Gabra Manfas Qǝddus</title>, written in a later hand. Incipit: <foreign xml:lang="gez">ሰላም: ለጽንሰትከ: መሰረተ: ነገር: ወውጣኔ: </foreign>
                           </desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc>
                              pen trials
                            </desc>
                        </item>
                        <item xml:id="a4">
                          <locus target="#iiv(erso)" facs="003"> f. iiv(erso), col. 2</locus>
                           <desc type="DonationNote">
                              Record of gift of this book to the church, written in red ink. “This book [belongs to] Ǝmät Tadäsäč and she gave it for commemoration of Saint Gäbrä Mänfas Qǝddus and to be an intercession for her. She bought it for 50 birr and gave it in 1969 EC. Her baptismal name is Ǝḫǝtä Maryam.”
                            </desc>
                        </item>
                        <item xml:id="a5">
                          <locus target="#56r" facs="058"> f. 56r and passim</locus>

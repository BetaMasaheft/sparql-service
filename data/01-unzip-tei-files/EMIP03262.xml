         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3262/" n="59" corresp="https://betamasaheft.eu/api/iiif/EMIP03262/manifest">Antippas 12</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter Fragment, prepared for the tourist industry with four illuminations</summary>
                  <msItem xml:id="ms_i1"><title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit"> fragment, through Psalm 68</title>
                   <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">52</measure>
                           <dimensions type="outer" unit="mm">
                              <height>155</height>
                              <width>113</width>
                              <depth>32</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="20 22"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is usually rubricated, but the space left for the word is often too small and the scribe writing words in red ink, often abbreviates the word to fit it into the space available</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#7r" facs="007">Fol. 7r</locus><desc>The <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>?), holding a drawn <term key="sword" ana="#sword"/> above his head with his right hand and holding a set of balances in his left hand, defeats Satan who is depicted falling</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#25v" facs="026">Fol. 25v</locus><desc>The <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>?) stands holding a drawn <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/>.  Behind him are visible two demons prostrate on the ground. This illumination is identical in most of its details to the illumination in EMIP 3263, Antippas 13, frame 78, left</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#41v" facs="042">Fol. 41v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, with representations of two <term key="angel" ana="#angel"/>s (heads with wings) above them. This illumination is identical in many of its details to the illumination in EMIP 3263, Antippas 13, <locus target="#78r" facs="078">fol. 78r</locus></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#51v" facs="052">Fol. 51v</locus><desc>The <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>), holding drawn <term key="sword" ana="#sword"/> and processional staff with <term key="cross" ana="#cross"/> at the bottom, saving the three Hebrew Children. This illumination is identical in most of its details to that in EMIP 3262, Antippas 13, <locus target="#2v" facs="003">fol. 2v</locus></desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1v #2r #2v" facs="002 003">Fols. 1v, 2r, 2v</locus>
                    <desc type="GuestText">
                    Pen trial: consisting of a collection of phrases and various chants, and <title type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">Māḫbara
                                                  mǝʾmanān</title>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#Inside cover #1r #inside back cover" facs="001 053">Fols. Inside,, 1r, inside,, </locus>
                    <desc>
                    Student exercise, copying letters from the Ethiopic syllabary
                    </desc>
                    </item>
                  </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

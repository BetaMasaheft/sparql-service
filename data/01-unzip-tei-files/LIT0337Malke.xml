      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ ጰራቅሊጦስ፡ ኣቀድም፡ ዑታቤ፨</l>
                  <l n="2">ተሀበኒ፡ ቃለ፡ ወአእምሮተ፡ ዘእቤ፨</l>
                  <l n="3">ላዕለ፡ ሐዋርያት፡ ዘኮነ፡ መለኮትከ፡ ነባቤ፨</l>
                  <l n="4">ይትወለድ፡ ውስተ፡ አፉየ፡ ወይሰገው፡ ሶቤ፨</l>
                  <l n="5">መልክአ፡ ነገር፡ ዘአልቦ፡ ሩካቤ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለኍላቌክሙ፡ እግዚአብሔር፡ ቦቱ፡ አቅደመ፨</l>
                  <l n="2">ጊዜ፡ ከፈለ፡ ሰዓታተ፡ ወለዕለት፡ አቅመ፨</l>
                  <l n="3">ሐዋርያተ፡ ክርስቶስ፡ ኄራን፡ ዘጸባእክሙ፡ ዓለመ፨</l>
                  <l n="4">ተበአሱ፡ በእንቲአየ፡ ወተቀሐው፡ ዳግሙ፨</l>
                  <l n="5">ጊዜ፡ ቈስለ፡ ሞቱ፡ ሐይወ፡ ወአሥረጸ፡ አድመ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሞገሰ፡ ስምክሙ፡ እንተ፡ ቀደመ፡ በዝክር፨</l>
                  <l n="2">ቅድመ፡ ይርግዑ፡ ወይጽንዑ፡ ድዳተ፡ ኵሉ፡ አናስር፨</l>
                  <l n="3">ሐዋርያተ፡ ክርስቶስ፡ ዜራን፡ መኳንንተ፡ ቅድስት፡ ሀገር፨</l>
                  <l n="4">ይትመላእ፡ ውስተ፡ አፉየ፡ ዘሕገ፡ ዜናክሙ፡ ፍቅር፨</l>
                  <l n="5">ውስተ፡ እደ፡ ጠቢብ፡ ወኬንያ፡ ከመ፡ ይትመላእ፡ ግብር፨</l>
               </lg>
               <lg type="stanza" n="56">
                  <l n="1">ሰላም፡ ለመዐዛክሙ፡ መዐዛ፡ መልክኡ፡ ለክርስቶስ፨</l>
                  <l n="2">ዘቦቱ፡ ተሠውጠ፡ አምሳለ፡ መዐዛ፡ ዘልብስ፨</l>
                  <l n="3">ሀዋርያተ፡ ክርስቶስ፡ ኄራን፡ ለከሥዒተ፡ ነገር፡ ሐዲስ፨</l>
                  <l n="4">ይትረዐይ፡ በላዕሌየ፡ ዘላዕሌክሙ፡ መንፈስ፨</l>
                  <l n="5">ከመ፡ በመንበሩ፡ ይትረአይ፡ ንጉሥ፨</l>
               </lg>
            </div>
         </div>
      </body>

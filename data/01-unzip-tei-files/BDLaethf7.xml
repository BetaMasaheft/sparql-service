               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="62">Fols 1r–62</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                        <textLang mainLang="gez"/>
                  
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r">Fols 1r and following</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <textLang mainLang="gez"/>
                        <note>
                           <p>
                              <locus from="1r">Fols 1r and following</locus> begins with <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps24">Psalm 24:13b</ref>. 
                     Only the first few words can be recognized, as the right-hand top corner of this folio is missing. From here the manuscript
                     is complete up to <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps68">Psalm 68:3</ref>.</p>
                           <p>
                              <locus from="41r">Fols 41r and following</locus> begins with <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps95">Psalm 95:2</ref>
                           and is continued up to <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps104">Psalm 104:32</ref>.</p>
                           <p>
                              <locus from="51r">Fols 51r and following</locus> contains Psalm 133-146:8.</p>
                        </note>
                        
                     </msItem>
                  
                     <msItem xml:id="ms_i1.2">
                        <locus target="#62r">Fol. 62r</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                        <textLang mainLang="gez"/>
                     
                        <msItem xml:id="ms_i1.2.1">
                           <locus target="#62r">Fol. 62r</locus>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale#Hannah">Maḥālǝya nabiyāt, Song of Hannah (ጸሎተ፡ ሓና፡ እመ፡  ሳሙኤል፡ ነቢይ፡) (same as LIT2257salota)</title>
                           <note>Contains the end of <ref type="work" corresp="https://betamasaheft.eu/LIT1828Mahale#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT1828Mahale#Hannah</span></ref>.</note>
                        </msItem>
                     
                        <msItem xml:id="ms_i1.2.2">
                           <locus target="#62r">Fol. 62r</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale#Hezekiah">Maḥālǝya nabiyāt, Prayer of Hezekiah (ጸሎተ፡  ሕዝቅያስ፡ ንጉሠ፡ ይሁዳ፡) (same as LIT2258salota)</title>
                        </msItem>
                     
                        <msItem xml:id="ms_i1.2.3">
                           <locus target="#62r">Fol. 62r</locus>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale#Manasseh">Maḥālǝya nabiyāt, Prayer of Manasseh (ጸሎተ፡  ምናሴ፡ ነቢይ፡) (same as LIT2265salota)</title>
                           <note>Contains one verse of <ref type="work" corresp="https://betamasaheft.eu/LIT1828Mahale#Manasseh"><span xmlns="" class="w3-tag w3-red">No item: LIT1828Mahale#Manasseh</span></ref>.</note>
                        </msItem>
                     </msItem>
                  </msItem>
                  
               

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ወጠንኩ፡ ለመልክእከ፡ ሰላሞ፨</l>
                  <l n="2">በብዙኅ፡ አስተሐምሞ፨</l>
                  <l n="3">ጳውሎስ፡ አዕቢ፡ ለኅሊና፡ ልብየ፡ ዐቅሞ፨</l>
                  <l n="4">ከመ፡ ኢይበሉኒ፡ ሶበ፡ ስእንኩ፡ ነገረ፡ ዜናሁ፡ ተርጒሞ፨</l>
                  <l n="5">አኀዘ፡ ይጽሐፍ፡ ወስእነ፡ ፈጽሞ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዝክረ፡ ውዳሴ፡ ሥሉጥ፨</l>
                  <l n="2">አምሳለ፡ ዕፍረት፡ ምዑዝ፡ ወአፈወ፡ ክህነት፡ ጽዑጥ፨</l>
                  <l n="3">ከመ፡ ታጥብበኒ፡ ሊተ፡ እምዕበደ፡ አፍአ፡ ወውስጥ፨</l>
                  <l n="4">መሀረኒ፡ ሕገ፡ አፉከ፡ ዘኢይትረከብ፡ በሤጥ፨</l>
                  <l n="5">መምህረ፡ አሕዛብ፡ ኵሉ፡ ጳውሎስ፡ አስቄጥ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለብርሃነ፡ ገጽከ፡ ዘያስተንእስ፡ ፀሓየ፨</l>
                  <l n="2">ወጸዳለ፡ ወርኅ፡ ዓዲ፡ እንተ፡ ይኴንን፡ ለያልየ፨</l>
                  <l n="3">ጳውሎስ፡ በለኒ፡ እሬስየከ፡ ረድእየ፨</l>
                  <l n="4">ከመ፡ እትሉከ፡ ጸዊርየ፡ መጽሐፈ፡ መልእክት፡ ሠናየ፨</l>
                  <l n="5">ለእመ፡ ቲቶ፡ ተድኅረ፡ ወዴማስ፡ ጐንደየ፨</l>
               </lg>
               <lg type="stanza" n="56">
                  <l n="1">አኮ፡ መፍትው፡ ድልው፡ ሊተ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እንብብ፡ እንዘ፡ ኢየአምር፡ ምንተ፨</l>
                  <l n="3">እመኒ፡ ጳውሎስ፡ ተወከፍ፡ ሊተ፨</l>
                  <l n="4">ለብዙኅሰ፡ ኢይስእል፡ እንሣእ፡ ዕሤተ፨</l>
                  <l n="5">ዳእሙ፡ ንስቲተ፡ ሀበኒ፡ ምጽዋተ፨</l>
               </lg>
            </div>
         </div>

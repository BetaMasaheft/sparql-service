                        <item xml:id="a1_5477">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Words indicating the purpose of the amulet, written in red in the margins.</q>
                           <note/>
                        </item>
                        <item xml:id="a0_5477">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Additional amulets in the margins</q>
                           <desc>Marginalia</desc>

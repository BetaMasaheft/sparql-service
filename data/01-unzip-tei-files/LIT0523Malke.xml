      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0523</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዕሩየ፡ ምልክና፡ በአካሉ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እጽሕፍ፡ ለትውልደ፡ ትውልድ፡ ዘይሄሉ፨</l>
                  <l n="3">ሰይፈ፡ ሚካኤል፡ ቄርሎስ፡ ለዐጽቀ፡ ሃይማኖት፡ ቈጽሉ፨</l>
                  <l n="4">ኢይቅስሙ፡ ፍሬ፡ ጽድቅከ፡ ኅጡኣነ፡ ሥርየት፡ አስካሉ፨</l>
                  <l n="5">ተአስሩ፡ በቃልከ፡ ሕዝበ፡ ካሕድ፡ ኵሉ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ክብረ፡ ነዳያን፡ ነገድ፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ሰላም፡ ዘግልባቤሁ፡ መረግድ፨</l>
                  <l n="3">ሰይፈ፡ ሚካኤል፡ ሰሎሞን፡ ንጉሠ፡ ምናኔ፡ ውሉድ፨</l>
                  <l n="4">መኑ፡ እምግብር፡ ዘከማከ፡ እምግብረ፡ መላእክት፡ ልማድ፨</l>
                  <l n="5">እንበለ፡ ማርያም፡ እግዝእትከ፡ እምዓለም፡ ፈቃድ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ትንሣኤከ፡ በጼወ፡ መለኮት፡ ዘተቀሥመ፨</l>
                  <l n="2">ዓዲ፡ ክብርከ፡ በደብረ፡ ኤራር፡ ተሠይመ፨</l>
                  <l n="3">ድኅረ፡ ጸአልከ፡ አባ፡ አበሳ፡ ዘማ፡ መርገመ፨</l>
                  <l n="4">ነዋ፡ ይብለከ፡ እግዚእከ፡ ምስለ፡ ኤዎስጣቴዎስ፡ ዓለመ፨</l>
                  <l n="5">እስመ፡ አልቦ፡ እንበሌክሙ፡ ዘነፍሶ፡ አድከመ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለከ፡ ኖላዊነ፡ ኄረ፨</l>
                  <l n="2">ኪያከ፡ ረሰየ፡ ለጽንፈ፡ ነገዱ፡ መምህረ፨</l>
                  <l n="3">ሰይፈ፡ ሚካኤል፡ ጽድቅከ፡ ሕንጻ፡ ቤተ፡ አሚን፡ ሣረረ፨</l>
                  <l n="4">ሀበኒ፡ ሊተ፡ እግዚኦ፡ ለብእሴ፡ ነገድ፡ ማኅደረ፨</l>
                  <l n="5">እስመ፡ በዓለ፡ ቤት፡ አንተ፡ ታፈቅር፡ ግዩረ፨</l>
               </lg>
               <lg type="stanza" n="99">
                  <l n="1">ሰላም፡ ለሀገሩ፡ ጽርሐ፡ ሥላሴ፡ ታዕካ፨</l>
                  <l n="2">በዓልተ፡ ኪዳን፡ ቅድስት፡ ምስካየ፡ አእላፍ፡ ዋካ፨</l>
                  <l n="3">ሰይፈ፡ ሚካኤል፡ ጳውሎስ፡ ንዋየ፡ ሃይማኖት፡ ምህርካ፨</l>
                  <l n="4">ያስተበጽዕዋ፡ ክቡታነ፡ ሞት፡ ምስማካ፨</l>
                  <l n="5">እስመ፡ ደብረ፡ ኤራር፡ ደብረ፡ ጽዮን፡ ትመስል፡ ፋሲካ፨</l>
               </lg>
            </div>
         </div>
      </body>

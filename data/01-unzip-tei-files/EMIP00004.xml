                  <additions>
                    <list>
                        <item xml:id="a1">
                           <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc>Genealogy of the early Shoan dynasty, in Amharic in a crude hand</desc>
                         </item>
                        <item xml:id="a2">
                          <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                          <desc>The story of the sorcerer at the Sea of Tiberias with incipit:
                            <foreign xml:lang="am">በስመ፡ አብ፡ በል፡ አፍጠለሹም፡ ፫ጊዜ፡ ያሸብክ፡ ጸሎተ፡ ንድራ፡ ዘውእቱ፡ ወእንዘ፡ የሐውር፡ እግዚእነ፡ ውስተ፡ ባሕረ፡ ጥብርያዶስ፡<gap reason="omitted"/></foreign></desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#iiv(erso) #iiir(ecto) #iiiv(erso) #ivr(ecto) #ivv(erso)" facs="003 004 005">Fols. iiv(erso), iiir(ecto), iiiv(erso), ivr(ecto), ivv(erso)</locus>
                           <desc type="GuestText">Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title> with incipit: <foreign xml:lang="gez">ፍትሐ፡ ወዘእምታን፡ (sic) ተንስአ፡<gap reason="omitted"/></foreign></desc>
                        </item>
                        <item xml:id="a4">
                           <locus target="#178v" facs="183">Fol. 178v</locus>
                           <desc type="RecordLitigation">Settlement of an unidentifiable dispute</desc>
                      </item>
                        <item xml:id="a5">
                          <locus target="#2r" facs="006"> f.2r,  Psalm 3 for all occasions; </locus>
                          <locus target="#3v" facs="008"> f. 3v, Psalm 6 in time of plague; </locus>
                          <locus target="#22v" facs="027"> f. 22v, Psalm 29 when seeing a dream; </locus>
                          <locus target="#25v" facs="030"> f. 25v, Psalm 32 for help in falling in love; </locus>
                          <locus target="#44r" facs="048"> f. 44r, read Psalm 50 with Psalm 41; </locus>
                          <locus target="#44v" facs="049"> f. 44v, Psalm 51 against the enemy; </locus>
                          <locus target="#47r #49r" facs="051 053"> the directory on ff. 47r, 49r not clear; </locus>
                          <locus target="#122r" facs="126"> f. 122r, Psalm 127 when something bad happens to you; </locus>
                          <locus target="#159r" facs="163"> f. 159r, fifth part of the Song of Songs for meal (“daily bread”? sisit).</locus>
                          <desc>Directory for reading, in a later hand</desc>
                        </item>
                        <item xml:id="a6">
                          <locus target="#1r" facs="005"> f. 1r, Monday; </locus>
                          <locus target="#25r" facs="029"> f. 25r, Tuesday; </locus>
                          <locus target="#51r" facs="055"> f. 51r, Wednesday; </locus>
                          <locus target="#74v" facs="079"> f. 74v, Thursday; </locus>
                          <locus target="#105v" facs="110"> f. 105v, Friday; </locus>
                          <locus target="#122v" facs="127"> f. 122v, Saturday; </locus>
                          <locus target="#137r #151v" facs="131 156"> ff. 137r, 151v, Sunday.</locus>
                           <desc>The same later hand arranges the codex for the days of the week</desc>
                        </item>
                        <item xml:id="a7">
                          <locus target="#61r #61v" facs="065 066">Fols. 61r, 61v</locus>
                          <desc type="OwnershipNote">Note of ownership by <foreign xml:lang="gez">ተስፋው፡ ባዩህ፡</foreign></desc>
                            </item>
                        <item xml:id="a8">
                          <locus target="#177v #178r" facs="182">Fols. 177v, 178r</locus>
                            <desc>Other names: <foreign xml:lang="gez">ወልደ፡ ጸድቅ፡ አየነው፡</foreign>, and <foreign xml:lang="gez">ጋብራ፡ ኢየሱስ፡ አሠብር፡</foreign> (?),</desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>

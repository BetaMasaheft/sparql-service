      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እግዚአብሔር፡ ባዕል፡ ዘኢትነዲ፡ ለግሙራ፨</l>
                  <l n="2">ሕሩመ፡ ምንዳቤ፡ ወተጽናስ፡ ወግብረ፡ መከራ፨</l>
                  <l n="3">ትቤ፡ ነፍስየ፡ ዘአፈድፈደት፡ ቃለ፡ ገዐራ፨</l>
                  <l n="4">ያብዕለኒ፡ ተሣህሎትከ፡ መብዓሌ፡ ንጉሥ፡ ሐራ፨</l>
                  <l n="5">ከመ፡ አብዐልኮሙ፡ ቅድመ፡ ለሄኖክ፡ ወዕዝራ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስቡሕ፡ ወውዱስ፨</l>
                  <l n="2">ዘትሴባሕ፡ ወትረ፡ በአፈ፡ ኵሉ፡ ዘነፍስ፨</l>
                  <l n="3">እግዚአብሔር፡ አብ፡ እስመ፡ አልብከ፡ ተጽናስ፨</l>
                  <l n="4">እምቅድመ፡ ዘመን፡ ዘመናዊ፡ ወድኅረ፡ ዘመናት፡ ሐዲስ፨</l>
                  <l n="5">እንዘ፡ ለአዝማን፡ አንተ፡ ሕገ፡ ዛሕን፡ ወመርስ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ኦአምላከ፡ ኵሉ፡ እንዘ፡ አምላከ፡ ጽድቅ፡ ባሕቲትከ፨</l>
                  <l n="2">ወኵሎ፡ ገበርከ፡ በፈቃድከ፨</l>
                  <l n="3">እግዚአብሔር፡ አብ፡ አምጣነ፡ ተጽናስ፡ አልብከ፨</l>
                  <l n="4">ምርሐኒ፡ ፍኖተ፡ ጽድቅ፡ ወአለብወኒ፡ ሕገከ፨</l>
                  <l n="5">ወኵሉ፡ ቅሩብ፡ ወሥሩዕ፡ በኀቤከ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ስብሐት፡ ለከ፡ እግዚአብሔር፡ በሠርቀ፡ ዕለታት፡ ወለያልይ፨</l>
                  <l n="2">ስብሐት፡ ለከ፡ እግዚአብሔር፡ ተባርዮ፡ ክረምት፡ ወሐጋይ፨</l>
                  <l n="3">ስብሐት፡ ለከ፡ እግዚአብሔር፡ በመዋዕለ፡ መፀው፡ ወጸደይ፨</l>
                  <l n="4">ስብሐት፡ ለከ፡ እግዚአብሔር፡ በኍልቈ፡ ኵሉ፡ ዘኢይትረአይ፨</l>
                  <l n="5">ስብሐተ፡ ቅድምናከ፡ ዘልፈ፡ ይነግር፡ ሰማይ፡</l>
               </lg>
            </div>
         </div>
      </body>

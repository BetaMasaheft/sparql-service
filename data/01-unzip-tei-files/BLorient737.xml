                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus from="2r"/>
                              <desc type="GuestText">Exposition of words in Ezekiel, in Amharic</desc>
                              <q xml:lang="am">
                                <seg part="I">
                                  ፍካሬ፡ ዘሕዝቅኤል፡ ነቢይ። ሜላት፡ ዘይቤ፡ በዝየ፡ ሻሽ፡ ሲራይ፡ ዘ፡ የታለለ፡ አውቃፍ፡ ዘ፡ አምባር፡
                                  ባዝግና፡ ዘ፡ ዝርግፍ፡ አዕኑግ፡ ዘ፡ የዢሮ፡
                                </seg>
                              </q>
                            </item>
                            <item xml:id="a2">
                              <locus from="3r" to="4v"/>
                              <locus from="187v"/>
                              <desc type="GuestText">
                                Exposition of the Temple of Ezekiel
                                <foreign xml:lang="gez">ትርጓሜ፡ መቅደስ፡ ሕዝቅኤል፡ ነቢይ፡</foreign>
                              </desc>
                              <q xml:lang="gez"/>
                            </item>
                            <item xml:id="a3">
                            <locus target="#5r"/>
                            <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                            <q xml:lang="gez">አፈ፡ ወርቅ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                   </q>
                        </item>
                        <item xml:id="a4">
                          <locus target="#12v"/>
                          <desc type="GuestText">
                            Words and phrases from the Ethiopic text of Ezekiel, with explanations derived from
                            the Arabic translation, but also given in Ethiopic.
                          </desc>
                        </item>
                        <item xml:id="a5">
                          <locus from="188r"/>
                          <desc type="GuestText">More explanations of words and phrases in Ezekiel</desc>
                          <q xml:lang="gez">
                            <seg part="I">
                              ወኮነ፡ አመ፡ ሣልስ፡ ክረምት፡ ዘ፡ ድኅረ፡ ተጼወወ፡ ሕዝቅኤል፡ መጽአ፡ መንፈስ፡ እምደቡብ፡ ዘ፡ መንፈስ፡
                              ነፋስሂ፡ ይትበሃል፡
                            </seg>
                          </q>
                        </item>
                        <item xml:id="e1">
                          <locus target="#7v"/>
                          <desc>The name of the owner is <persName role="owner" ref="https://betamasaheft.eu/PRS13436AsfaK">ʿAṣfa Krǝstos</persName>.
                        His name has been erased on <locus target="#187r"/>.</desc>
                        </item>
                          </list>
                        </additions>
                        <bindingDesc>
                            <binding contemporary="true" xml:id="binding">

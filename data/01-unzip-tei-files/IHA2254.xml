               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="8r">1r-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4573IHA">نظم راحة ارباب الجلال من أصحاب ذاك المجال</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم. 
راحة ارباب الجلال من أصحاب ذاك المجال من اهل الوصال أجاء الودود.
لقد غد الروح طالبا في ذاك الجناب

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>ميزاب ر الأكرم باب وصل الأعظم ابي محمد عوث كل الوجود. تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="8r" to="10r">8r-10r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4575IHA">نظم قد لاح بدر من جرم</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>صلى الله على محمد صلى الله عليه وسلم.
قد لاح بدر من جرم في برج العز والكرم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>وعلى اله الكرام والصحب نجوم العالم. ما نحا القلب نحوه ولاح نور الاتم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="10r" to="12v">10r-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4576IHA">نظم الحمد لله لقد أكرمنا بأن اهدى لنا كنز الغيبه
                    الأصفى</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>اللهم صلى على محمد شراب الصفا مصطفى مصطفى.
الحمد لله لقد أكرمنا بأن اهدى لنا كنز الغيبه الأصفى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>أبو محمد شمس من ساقة قد طلع في قلوب أصل الصفا. كذاك علم اخى ذاك محمد وكل اخوتى الشموس العرفا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="13r" to="14r">13r-14r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4577IHA">نظم جاد بالقرب والامداد وباب مدخل جيوش الاحباب</title>
                     <incipit xml:lang="ar">
                        <locus target="#13r">-13r</locus>اللهم صل على محمد شراب اطرب قلوب الاحباب جواد. جاد بالقرب والامداد وباب مدخل جيوش الاحباب نالوا منه القربا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>محمد ما بد الوهاب من سيد محمد عابد الوهاب مجرنا الهرى ميزابى ميزابى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="14v" to="20v">14v-20v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4585IHA">نظم جمال بدا فينا ببدر جماله</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>صلاة وتسليم وازكى تحية صلى الله عليه على المصطفى والال ثم الصحابة يا رسول الله.
جمال بدا فينا ببدر جماله| به قد تعممنا بتاج جلاله| وقمنا صفوفا طالبين لوصله|| تجلى على قلبى بانوار ذاته فلما تولى راح منى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20v">-20v</locus>كذاك لكل المسلمين احبتى| جميعا الى قرب القيام لساعة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="21r" to="23r">21r-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-un">Unidentified</textLang>
                     <title ref="https://betamasaheft.eu/LIT4586IHA">نظم قد لاح في قلبنا نور من الحرم</title>
                     <incipit xml:lang="ar">
                        <locus target="#21r">-21r</locus>يا رب صل على المختار سيدنا محمد ما يد ايدر من الحرم| قد لاح في قلبنا نور من الحرم| سبى عقول الورى بالوجد والهيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>محمد خير خلق الله كلهم| والآل والصحب والاتباع متاطبة| ما حنّ  ذو وحج الى حرموانشاق</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="23r" to="25v">23r-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4589IHA">نظم في ذلك المجال نور معظما</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>اللهم صل على محمد جمال بهى اللهم صل على ومحمد نزر معظم. | في ذالك المجال نور معظما شرق في القلب من جد الجمال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>مائدة الصفا نزلت للوفا بجيش المعرفة لذيذ مطعم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="26r" to="31v">26r-31v</locus>
                     <textLang xml:lang="am">Amharic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT4588IHA">Poem in ʻaǧamī Amharic (11)</title>
                     <incipit xml:lang="ar">
                        <locus target="#30r">-30r</locus>  اللهم صل على محمد النبي المي, بسم الله الرحمن الرحيم محمد.
حمد لله ﯕلن كن ﯕيتا</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="28r" to="29v">28r-29v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4587IHA">نظم الدكن الأعظم عند الأحباء</title>
                     <incipit xml:lang="ar">
                        <locus target="#28r">-28r</locus>الدكن الأعظم عند الأحباء| ابحد المهيط عند الأولياء|القطب الأكب عنه الانبياء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29v">-29v</locus>فكان عاليا في حضرة العالي | فليس يعرف مفامة العالى</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

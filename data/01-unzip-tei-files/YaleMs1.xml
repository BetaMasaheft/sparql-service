               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="130r" facs="003">Fols 3r–130r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                    <msItem xml:id="ms_i1.1">
                      <locus from="3r" to="102v" facs="003">Fols 3r–102v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note><locus target="#102v" facs="103">Fol. 102v</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> is the short version</note>
                      <note><locus target="#3r #22v #42r" facs="003 023 042">Fols. 3r, 22v, 42r</locus>, the Psalms have been arranged for the days of the week</note>

                      <msItem xml:id="ms_i1.1.1">
                        <locus target="#3r" facs="003">Fol. 3r</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</title>
                        <note>The opening prayer is from the Psalter of the Virgin</note>
                        </msItem>

                </msItem>

                <msItem xml:id="ms_i1.2">
                  <locus from="103r" to="113v" facs="103">Fols 103r–113v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <note><locus target="#106v" facs="107">Fol. 106v</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref><q>Prayer of Hana, Mother of Samuel, prophet</q></note>
                </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="113v" to="119v" facs="114">Fols 113v–119v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <note>Common version</note>
                  </msItem>

                  <msItem xml:id="ms_i1.4">
                    <locus from="120r" to="127r" facs="120">Fols 120r–127r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>

                    <msItem xml:id="ms_i1.4.1"><locus from="120r" facs="120">Fols 120r and following</locus><title>Monday</title></msItem>
                    <msItem xml:id="ms_i1.4.2"><locus from="120v" facs="121">Fols 120v and following</locus><title>Tuesday</title></msItem>
                    <msItem xml:id="ms_i1.4.3"><locus from="121v" facs="122">Fols 121v and following</locus><title>Wednesday</title></msItem>
                    <msItem xml:id="ms_i1.4.4"><locus from="123r" facs="123">Fols 123r and following</locus><title>Thursday</title></msItem>
                    <msItem xml:id="ms_i1.4.5"><locus from="124v" facs="125">Fols 124v and following</locus><title>Friday</title></msItem>
                    <msItem xml:id="ms_i1.4.6"><locus from="125v" facs="126">Fols 125v and following</locus><title>Saturday</title></msItem>
                    <msItem xml:id="ms_i1.4.7"><locus from="126r" facs="126">Fols 126r and following</locus><title>Sunday</title></msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.5">
                    <locus from="127r" to="130r" facs="127">Fols 127r–130r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  </msItem>

                <colophon xml:id="coloph1">
                <locus target="#130v" facs="131">Fol. 130v</locus>
                Colophon beginning with a condemnation on anyone who steals or erases anything in the book.
                The book was written by <foreign xml:lang="gez">ተክለ ጊዮርጊስ</foreign> in 1917 EC, Tahsas 1.
              </colophon>


              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                          <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">ii + 130</measure>
                           <dimensions type="outer" unit="mm">
                              <height>153</height>
                              <width>126</width>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="22 25">
                         <locus from="1r" to="119v" facs="003">Fols 1r–119v</locus>
                       </layout>
                       <layout columns="2" writtenLines="22 25">
                         <locus from="120r" to="130r" facs="122">Fols 120r–130r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                 <handDesc><handNote xml:id="h1" script="Ethiopic">Takla Giyorgis</handNote></handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc>crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#130r" facs="130">Fol. 130r</locus><desc>crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#130v" facs="131">Fol. 130v</locus><desc>crude drawings of faces</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#131v" facs="132">Fol. 131v</locus><desc>crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/> drawn from <term key="scabbard" ana="#scabbard"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#Inside back cover" facs="133">Fols. Inside,, </locus><desc>crude drawing of a man</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r #1v" facs="001 002"> f. 1r–1v (written upside down)</locus>
                    <desc>
                    Concluding prayer to be recited after the Praises of Mary, including appeals to Mary to intercede for members of the family of the owner of the book,
                    <foreign xml:lang="gez">ቀጸላ ጊዮርጊስ</foreign>. Written in an untrained hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    <desc type="OwnershipNote">
                    <q>This psalter belongs to Memher <foreign xml:lang="gez">ቀጸላ፡ አላምነህ</foreign></q>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#59v" facs="060"> f. 59v, top margin</locus>
                    <desc type="OwnershipNote">
                    This psalter belongs to Lij <foreign xml:lang="gez">ቀጸላ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#132v" facs="133">Fol. 132v</locus>
                    <desc>
                    pen trials, based on the opening prayer of the Psalter
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#103v #104" facs="104">Fols. 103v, 104</locus>
                    <desc>
                    Missed shot
                    </desc>
                    </item>
                    
                    <item xml:id="e3">
                      <locus target="#54v" facs="55">Fol. 54v</locus>:
                      <desc>Marks the midpoint of the Psalms with a marginal symbol</desc>
                    </item>
                  </list>
                </additions>
                 
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
                 <legend>
                   <desc>
                     The book is accompanied by a letter dated November 22, 1930, from Richard Gottheil of Columbia University in which he describes the contents and date of the manuscript, though the report is marred by several errors
                   </desc>
                 </legend>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1924-12-10">1917 EC, Tahsas 1 = December 10, 1924 (<locus target="#130v" facs="133">fol. 130v</locus>).</origDate>
                  </origin>
                 <provenance>F. 1v, 59v contain notes of ownership: "This psalter belongs to Memher Qaṣalā ʼAlāmenah (ቀጸላ አላምነህ) and “This psalter belongs to Lij Qaṣalā (ቀጸላ).”
                   Gift of Henry Fletcher, 1947.
                 </provenance>
               </history>
            </msDesc>
         </sourceDesc>

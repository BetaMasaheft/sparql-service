      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እምጥበብከ፡ ስፉሕ፡ ወእምጸጋከ፡ ረቂቅ፨</l>
                  <l n="2">እንተ፡ ተበጽዐ፡ ፈድፋደ፡ በአፈ፡ ኅሩያን፡ ደቂቅ፨</l>
                  <l n="3">እስጢፋኖስ፡ ክፍለኒ፡ በሥምረተ፡ ሰላም፡ ወጽድቅ፨</l>
                  <l n="4">አሠረከ፡ እትሉ፡ እግዚኦ፡ ወፍኖተከ፡ በጻሕቅ፨</l>
                  <l n="5">እስመ፡ ጸጋ፡ ዘንቱ፡ ይትበደር፡ እምብሩር፡ ወወርቅ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ሆህያተ፡ አሌፍ፡ እምጥንቱ፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ወለገጽከ፡ በደመ፡ ውግረት፡ ሠርጐ፡ ትርሲቱ፨</l>
                  <l n="3">እስጢፋኖስ፡ መምህር፡ ወሊቀ፡ ዲያቆናት፡ ሰባዕቱ፨</l>
                  <l n="4">አርትዕ፡ ሊተ፡ እግዚኦ፡ ልዕላኤ፡ አፉየ፡ ዝንቱ፨</l>
                  <l n="5">ውዳሴ፡ ዚአከ፡ ከመ፡ አንብብ፡ ቦቱ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለቀራንብቲከ፡ ወለአዕይንቲከ፡ ምስለ፡ አእዛን፨</l>
                  <l n="2">ወለመላትሒከ፡ ቀይሕ፡ አምሳለ፡ ሮማን፨</l>
                  <l n="3">እስጢፋኖስ፡ ዲያቆን፡ ወሠዋዔ፡ ሐዲስ፡ ቍርባን፨</l>
                  <l n="4">ቤዛ፡ ይኩነኒ፡ ለወልድከ፡ ውስተ፡ ዐውደ፡ አይሁድ፡ መካን፨</l>
                  <l n="5">ውግረተ፡ ዚአከ፡ በብዝኅ፡ አእባን፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ አፅምከ፡ ዘተረክበ፡ እምተከብቶ፨</l>
                  <l n="2">አመ፡ ፲ወ፭፡ ለወርኀ፡ መስከረም፡ ቲቶ፨</l>
                  <l n="3">ተወኪፈከ፡ እስጢፋኖስ፡ መሥዋዕተ፡ ሰላምየ፡ በኢያስትቶ፨</l>
                  <l n="4">ምስሌየ፡ ግበር፡ እግዚኦ፡ ለሠናይትከ፡ ትእምርቶ፨</l>
                  <l n="5">ናሁ፡ ለውዳሴከ፡ ርኢኩ፡ ማኅለቅቶ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">እስጢፋኖስ፡ አእላፍ፡ አመ፡ ኃጥኡከ፡ በሞት፨</l>
                  <l n="2">ከመ፡ በከዩ፡ ፈድፋደ፡ እምኍልቈ፡ አርብዓ፡ ዕለት፨</l>
                  <l n="3">በእንተ፡ ጌጋይየ፡ ኢትትኀየይ፡ እስጢፋኖስ፡ ሰማዕት፨</l>
                  <l n="4">እመሰ፡ ተሐየይከ፡ እምገቢረ፡ ብዙኅ፡ ጸሎት፨</l>
                  <l n="5">ተስፋ፡ ድኅነተ፡ ነፍስ፡ አልብየ፡ በአፍአ፡ ወቤት፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">በየማነ፡ አምላክ፡ ለወልድ፡ ከመ፡ ነጸርከ፡ በግርማ፨</l>
                  <l n="2">አመ፡ ተልዕለ፡ ዐይንከ፡ መንገለ፡ ልዑል፡ ራማ፨</l>
                  <l n="3">ዐይነ፡ ሕሊናየ፡ ክሥት፡ እስጢፋኖስ፡ ለባሴ፡ ፃማ፨</l>
                  <l n="4">እትሉ፡ ፍና፡ ዚአሁ፡ ለጸዊረ፡ መስቀል፡ ባማ፨</l>
                  <l n="5">ወተግሣጻቲሁ፡ እትወከፍ፡ ለብፁዕ፡ በርሶማ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#3v">Fol. 3v</locus><desc>Ewostatewos</desc>
                     </decoNote>
                     <decoNote xml:id="d2" type="miniature"><locus target="#4v">Fol. 4v</locus><desc>Takla Haymanot</desc></decoNote>
                     <decoNote xml:id="d3" type="miniature"><locus target="#5r">Fol. 5r</locus><desc>Gabra Manfas Qeddus</desc></decoNote>
                     <decoNote xml:id="d4" type="miniature"><locus target="#5v">Fol. 5v</locus><desc>Die Gehorsame mit ihrem geliebten Sohn</desc></decoNote>
                     <decoNote xml:id="d5" type="miniature"><locus target="#6v">Fol. 6v</locus><desc>Wie ֿEfrֿem der Syrer und Sem'on von Amd (=Amid) an ihren Lehrer Yā'qob von 
                        Neṣebin (=Niisbis) Fragen richteten</desc></decoNote>
                     <decoNote xml:id="d6" type="miniature"><locus target="#8v">Fol. 8v</locus><desc>Wie Addām und Hֿewān durch den Rat der Schlange sündigten und wie sie der Lichtbekleidung entkleidet wurden</desc></decoNote>
                     <decoNote xml:id="d7" type="miniature"><locus target="#10r">Fol. 10r</locus><desc>Wie unsere Herrin Māryām unseren Herrn in Bethlehem gebar</desc></decoNote>
                     <decoNote xml:id="d8" type="miniature"><locus target="#11v">Fol. 11v</locus><desc>Wie der heilige ֿEfrem unsere Herrin Māryām am Montag u. Dienstag lobte</desc></decoNote>
                     <decoNote xml:id="d9" type="miniature"><locus target="#13v">Fol. 13v</locus><desc>Wie Yā'qob die Engel auf einer Leiter in den Himmel hinauf- und auf die Erde heruntersteigen sah</desc></decoNote>
                     <decoNote xml:id="d10" type="miniature"><locus target="#14r">Fol. 14r</locus><desc>Wie Musֿe auf dem Berge Sinā (= Sinai) das Feuer mit Blüten ohne (daß diese) Schaden (nahmen) vereint sah</desc></decoNote>
                     <decoNote xml:id="d11" type="miniature"><locus target="#16r">Fol. 16r</locus><desc>Wie Musֿe die Gesetzestafeln empfing</desc></decoNote>
                     <decoNote xml:id="d12" type="miniature"><locus target="#18v">Fol. 18v</locus><desc>Wie der heilige ֿEfrem unsere Herrin Māryām am Mittwoch lobte</desc></decoNote>
                     <decoNote xml:id="d13" type="miniature"><locus target="#23v">Fol. 23v</locus><desc>Wie der Prophet Ḥezqe'ֿel unsere Herrin Māryām mit einer verschlossenen Tür verglich</desc></decoNote>
                     <decoNote xml:id="d14" type="miniature"><locus target="#24v">Fol. 24v</locus><desc>Wie der heilige ֿEfrֿem unsere Herrin Māryām am Donnerstag lobte</desc></decoNote>
                     <decoNote xml:id="d15" type="miniature"><locus target="#28v">Fol. 28v</locus><desc>Wie Ḫewān aus der Rippe Addāms geschaffen wurde</desc></decoNote>
                     <decoNote xml:id="d16" type="miniature"><locus target="#29r">Fol. 29r</locus><desc>Wie Gott Vater aus der Rippe Addāms Ḫֿewān erschuf</desc></decoNote>
                     <decoNote xml:id="d17" type="miniature"><locus target="#31r">Fol. 31r</locus><desc>Wie man dem König Dāwit Wasser brachte, als er durstig war, und wie er das Wasser weggoß</desc></decoNote>
                     <decoNote xml:id="d18" type="miniature"><locus target="#33r">Fol. 33r</locus><desc>Wie der heilige ֿEfrֿem unsere Herrin Māryām am Freitag lobte</desc></decoNote>
                     <decoNote xml:id="d19" type="miniature"><locus target="#34v">Fol. 34v</locus><desc>Wie Abbā Gabra Madḫen zum Bild unserer Herrin Māryām Zuflucht nahm</desc></decoNote>
                     <decoNote xml:id="d20" type="miniature"><locus target="#35r">Fol. 35r</locus><desc>Wie unsere Herrin Māryām ihrem Sohn die Brust gab</desc></decoNote>
                     <decoNote xml:id="d21" type="miniature"><locus target="#37v">Fol. 37v</locus><desc>Wie der heilige ֿEfrֿem unsere Herrin Māryām am Samstag lobte</desc></decoNote>
                     <decoNote xml:id="d22" type="miniature"><locus target="#41r">Fol. 41r</locus><desc>Wie Yā'qob die goldene Leiter sah, als der Sohn Gottes auf ihr (war)</desc></decoNote>
                     <decoNote xml:id="d23" type="miniature"><locus target="#42r">Fol. 42r</locus><desc>Wie sie den heiligen ֿEfrֿem, als er in Trunkenheit schlief, weckte, damit er sie am Sonntag lobte ...</desc></decoNote>
                     <decoNote xml:id="d24" type="miniature"><locus target="#42v">Fol. 42v</locus><desc>Wie der heilige ֿEfrֿem unsere Herrin Māryām am Sonntag lobte</desc></decoNote>
                     <decoNote xml:id="d25" type="miniature"><locus target="#50v">Fol. 50v</locus><desc>Wie die Magier Geschenke brachten</desc></decoNote>
                     <decoNote xml:id="d26" type="miniature"><locus target="#51v">Fol. 51v</locus><desc>Wie Mikāֿ'el und Gabre'ֿel Māryām zwölf Jahre lang Brot und Becher (d.i. Trank) brachten</desc></decoNote>
                     <decoNote xml:id="d27" type="miniature"><locus target="#53v">Fol. 53v</locus><desc>Wie Gabre'ֿel Māryām die Botschaft brachte</desc></decoNote>
                     <decoNote xml:id="d28" type="miniature"><locus target="#60v">Fol. 60v</locus><desc>Wie unsere Herrin Māryām den heiligen ֿEfrֿem segnete</desc></decoNote>
                     <decoNote xml:id="d29" type="miniature"><locus target="#88v">Fol. 88v</locus><desc>Heiliger Georg</desc></decoNote>
                     
                  </decoDesc>

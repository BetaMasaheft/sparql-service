                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="2r" to="67v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1119DossierQMQ">The life of  Gabra Manfas Qǝddus</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ etc. ንወጥን፡ ገድሎ፡ ለቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS4306GabraMa"><roleName type="title">አባ፡ </roleName> ገብረ፡ መንፈስ፡ ቅዱስ፡ </persName>
                                ጽሙድ፡ መስተጋድል፡
                                ኮከበ፡ ገዳም፡ ዘዝክሩ፡ ክቡር፡ ወርስእናሁ፡  ብፁዕ፡  ወኄር፡ <persName ref="https://betamasaheft.eu/PRS4306GabraMa"><roleName type="title">አባ፡ </roleName> ገብረ፡ መንፈስ፡ ቅዱስ፡ </persName>
                               ገዳማዊ፡ ዘሠረቀ፡ ለነ፡ እምሀገረ፡  ንሒሳ፡
                               መትሕተ፡ ምድር፡ ወእደቡበ፡ (sic) <placeName ref="https://betamasaheft.eu/LOC2804Egypt">ግብጽ።</placeName> ወነበረ፡ ውስተ፡  
                                ገዳም፡  ፩፭፻ዓመት፡ ወወፂኦ፡ እምህየ፡ ዔለ፡ ገዳማተ፡ <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">ኢትዮጵያ፡</placeName>   ወነበረ፡
                                በ<placeName ref="https://betamasaheft.eu/LOC6480Zeqwal">ዝቋላ፡</placeName> በኀቤሃ፡ 
                                ለምድረ፡  ካብድ፡ ፪፻፷፪ዓመት።</incipit>
                            <colophon xml:id="coloph1" xml:lang="gez">
                              <locus target="#67v"/>
                                <q xml:lang="gez">ተፈጸመ፡ መጽሐፈ፡ ገድሉ፡ ለ<persName ref="https://betamasaheft.eu/PRS4306GabraMa"><roleName type="title">አባ፡</roleName> ገብረ፡ መንፈስ፡ ቅዱስ።
                                </persName> በዘመነ፡ <persName ref="https://betamasaheft.eu/PRS3429DawitII">ዳዊት፡ <roleName type="title">ንጉሥ፡</roleName></persName>  ምሉአ፡ ጸጋ፡ ወሞገስ።
                                </q>
                            </colophon>
                            
                            
                            

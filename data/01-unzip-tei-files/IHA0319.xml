               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1v">1r-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0675IHA">ترتيب السلوك الى ملك الملوك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسملة٬ حمدلة٬ والصلى الله \ على سيدنا محمد خاتم النبيين وعلى اله وصحبه اجمعين وعلى التابعين لهم باحسان \ الى يوم الدين اما بعد فهذه نبذة في ترتيب السلوك الى ملك الملوك جل وعلا مشتملة \ على مقدمة وثلاثة فصول وخاتمة فالمقدمة فى حقيقة الوصول الى الله تعالى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>ولا يزال يتبرقى فلا يدركه من فوقه ولا يدركه من تحته اوليك الذين يدعون يبتغون \ الى ربهم الوسيلة ايهم اقرب والسابقون السابقون اوليك المقربون وفي ذلك فليتنافس المتنافسون
</explicit>
                     <note>Loose folio
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="4v">2r-4v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0670IHA">كتاب الفرائض للأوسام الساختي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>اونوت إِمْ عُجْبِ رِحَاقُوْت عِلْمِ تَلمذو جِرْ يَلمدو جِرْ قُرَان \ أَقريَانُو جِرْ أَحَتَّ فُونِ جِبَأوت الله خَادوا تقرارحُوت \ ذكرزوا بعرات ألفافوت تَوبَت دَحدِجُوت استغفار \ أَبزحوت نَبِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>نيت اوشوت زنيت حكم شيشين سن ترتاي فرض \ ارتاي زنيت ادرتيت صفت زوا اوشوت زنيت ارتاي \ كعوتن ميا اج كف كلتلا بلب نيت اوشوت ه ه \ تمت بحمد الله تعلى بمنه وفضله وكرمه امين \ هذا كتاب الفرائض بكلام الحبش اخرجه بن عبد الله \ عمر بن جبرايل الاوسام الساحتي رضي الله عنه
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="4v" to="69r">4v-69r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0176IHA">تخميس الوترية</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسملة \ بَدَاتُ بِذَكْرِ اَللهِ مَدْحًا مُقَدَمَا \ وَأُثني بِحَمْدِ اللهِ شُكْرًا مُعَظَمًا \ وَأُختِمُ قَوْلِي بِأَلصَّلَأةِ وَإِنَّمَا \ أصَلِّيْ صَلَاةً تَمْلَاءُ الأَرْضُ وَالسَّمَا عَلَى مَنْ لَهُ أعْلَى العلا مُتبوأ
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#69r">-69r</locus>وَجَأيزَني يَوْمَ القِيَمةِ قُرْبَهُ \ نَعْم أَنَّ بِالاِسْلَامِ أَنْعَم رَبُّهُ \ يَمِينًا بِرَيى اِنِّ قَلْبِي يُحِبُّه وَذَلكَ رَجَإِيْ فِي المماتِ وفِي المَحيَا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="70v" to="73r">70v-73r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0563IHA">استغفارالامام الختم</title>
                     <incipit xml:lang="ar">
                        <locus target="#70v">-70v</locus>بسملة \ استغفر الله ليس الامر مخفيا \ استغفر الله بل في الكتب مرويا \ استغفر الله بل في العين مريا \ استغفر الله وغد الله ماتياه ولامحيص لنا من ان نلقاه
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#73r">-73r</locus>استغفر الله في بوسي ونعماي \ استغفر الله في جهري واخفاي \ استغفر الله من ذنب غلا داي وهل طيبُ لهذا الَّنب اَلاهُ
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="73v" to="75v">73v-75v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0679IHA">دعاء سبحان الله مخترع الأشياء إنشاء</title>
                     <incipit xml:lang="ar">
                        <locus target="#73v">-73v</locus>سبحان الله مخترع الانشا انتا \ سبحان الله محبي الثري بالغيث احيا \ سبحان الله من علم الانسان السماء \ سبحان الله باريه اشلا واعظا وشق في الوجه منه السمع والبصرا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#77v">-77v</locus>سبحان الله من كلف الانسان  من عمل \ سبحان الله من شعل الانسان بالامل \ سبحان الله من الانسان بالبخل اعطى قلم ايدر ما اعطي وما لا شكرا
</explicit>
                     <note/>
                     <note/>
                  </msItem>

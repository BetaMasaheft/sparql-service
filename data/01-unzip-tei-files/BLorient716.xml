                        <msContents>
                            <summary/>
                            <msItem xml:id="ms_i1">
                                <title ref="https://betamasaheft.eu/LIT6172DossierGeorge">Hagiographic Dossier of St George of Lydda</title>
                                <msItem xml:id="ms_i1.1">
                                    <locus from="11r" to="20r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1287Dersan">The discourse of Theodotus Ancyra on the commemoration of St George</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                                <msItem xml:id="ms_i1.2">
                                    
                                    
                                    <locus from="20r" to="76r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1455GadlaG">Gadla Giyorgis (Lydda)</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                                <msItem xml:id="ms_i1.3">
                                    
                                    <locus from="77r" to="98r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT4006Taamme">The miracles of St George, 80 in number</title>
                                    <textLang mainLang="gez"/>
                                </msItem>
                                <msItem xml:id="ms_i1.4">
                                    <locus from="98r" to="101v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT5781MashafaAnkero">Maṣḥafa ʾAnkǝro</title>
                                </msItem>
                                <msItem xml:id="ms_i1.5">
                                    <locus from="101v" to="165r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT5481MashafaAhbero">Maṣḥafa ʾAḫbǝro</title>
                                </msItem>
                                <msItem xml:id="ms_i1.6">
                                    <locus from="165r" to="172v"/>
                                    <title>Hymns to St George</title>
                                    <msItem xml:id="ms_i6.1">
                                        <locus from="165r" to="166v"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2744RepCh28">Malkǝʾ-hymn to St George</title>
                                        <incipit xml:lang="gez">  ሰላም፡ ለሥርፀትከ፡ ለአቅሌስያ፡  እምጒንደ።</incipit>
                                    </msItem>
                                    
                                    <msItem xml:id="ms_i6.2">
                                        <locus from="166v" to="168r"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2837RepCh121">Malkəʾa Giyorgis</title>
                                        <incipit xml:lang="gez"> ሰላም፡ ለዝክረ፡ ስምከ፡ ሞገስ፡ ዘቦ።</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i6.3">
                                        <locus from="166v" to="168r"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2942RepCh223">Malkǝʾ-hymn to St George</title>
                                        <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ጊዮርጊስ፡ ንብለከ፡ እንዘ፡ ንጼውዕ፡ ስመከ። </incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i6.4">
                                        <locus from="168v" to="169v"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2858RepCh140">Malkǝʾ-hymn to St George</title>
                                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ድሉል።</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i6.5">
                                        <locus from="169v" to="172r"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT3074RepCh354">Hymn to St George</title>
                                        <incipit xml:lang="gez">እንዘ፡ እነብር፡ ፅሩዓ፡ ወእትሀከይ፡ ዘልፈ። ምንተ፡ እረሲ፡ እስመ፡ ወርኀ፡ ማዕረር፡ ኅለፈ። </incipit>
                                    </msItem>
                                    
                                    <msItem xml:id="ms_i6.6">
                                        <locus from="172"/>
                                        <title type="complete" ref="https://betamasaheft.eu/LIT2961RepCh242">Baḥāka Giyorgis</title>
                                        <incipit xml:lang="gez">በሃከ፡ ጊዮርጊስ፡ በሃከ፡ ወሬዛ፡ ኃይል፡ ከመ፡ አንበሳ፡ ውኩል። </incipit>
                                    </msItem>
                                </msItem>
                                
                            </msItem>
                            
                            

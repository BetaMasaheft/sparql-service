               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="5r" to="27v">5r-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1201IHA">هداية الاذكياء الى طريق الاولياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>بسم الله الرحمن الرحيم.
الحمد لله الموفق للعلل حمدا يوافى بره المتكاملا ثم الصلاة على الرسول المصطفى والأل مع صحب وتباع ولا تقوى له مدر كل سعادة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27v">-27v</locus>هذا الذى أوصى الشيوخ الكمل الله وفقنا له متفضلا والحمد للباقى الرؤف مصليا أعلى الصلاة على الرسول محوقلا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="29r" to="37v">29r-37v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1204IHA">صلاة الفتن</title>
                     <incipit xml:lang="ar">
                        <locus target="#29r">-29r</locus>صلاة الفتن في المر والعلن؟؟؟<note>Disrupted</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#37v">-37v</locus>صلاة تعيدنا بها من كل بروفاجة؟؟؟<note>Disrupted</note>
                     </explicit>
                     <note>Disrupted</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="38v" to="40v">38v-40v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1200IHA">ورد الاستغفار المنظوم</title>
                     <incipit xml:lang="ar">
                        <locus target="#38v">-38v</locus>ورد الاستغفار المنظوم وهو هذا.
أستغفر الله منشينا من العلق| وخالقا فى شغاف القلب من علق</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#40v">-40v</locus>والأل والصحب والاتباع قاطبت ما عاف مخراق حرب شربة الصفق أو قال لما هفا البكرى ملى تفا أستغفر الله منشينا من العلق</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="42v" to="56r">42v-56r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0136IHA">ملحة الاعراب</title>
                     <incipit xml:lang="ar">
                        <locus target="#42v">-42v</locus>تعلّموا العربية وعلمها الناس [حديث شريف] بسم الله الرحمن الرحيم.
اقول من بعد افتتاح القول بحمد ذى الطول شديد الحول| وبعده فافضل السلام| على النبي سيد الأنام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#56r">-56r</locus>واله الأفاضل الأخيار | ما انسلخ الليل من النهار| ثم على أصحابه وعترته| وتابعى مقاله وسنّته</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="60r" to="83r">60r-83r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2210IHA">شراب الظمآن</title>
                     <incipit xml:lang="ar">
                        <locus target="#60r">-60r</locus>ارجع الي ربك راضية مرضية فادخلي في عبادي وادخلي جنتي فالنفس المهملة نفس الاوليا لقوله تعالي فالهمها فجورها وتقواها [...] وقيل الي العلوم الاربعة علم الناسوت وعلم الملكوت وعلم الجبروت وعلم اللاهوت <note>سورة الفجر</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#83r">-83r</locus>والحمد لله رب العالمين الحمد هو الثنا بالجميل على جهة التعظيم تمت وقد سميته شراب الظلامان في معرفة وجلأ عميان في معرفة صفات الملك الديان وصلي الله على سيدنا محمد وعلي اله وصحبه وسلم تمت الكتاب بعون الله وحسن توفيقه والحمد لله رب العالمين </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="84r" to="89r">84r-89r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1199IHA">تنبيه الجهال في توحيد الافعال</title>
                     <incipit xml:lang="ar">
                        <locus target="#84v">-84v</locus>بسم الله الرحمن الرحيم. قل هذه سبيلي ادعو بها الى الله على بصيرة انا ومن اتبعنى وسبحان الله عن الشرك والشركاء وما انا من المشركين فاعلم ان الايمان بالقضاء والقدرهما نظام التوحيد والايتم التوحيد الابهما والقضاء حكم الله فى الاشياء قبل وجودها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#89r">-89r</locus>ونحن انت وانت هو والكل فى هو هو فاسئل عمن وصل والله يقصل لحق وبينه بلسان عبيده وهو يهدى السبيل بهم والله الموفق لمن يشاء وصلى الله وسلم على سيدنا محمد مدلا الوجود وسبب الموجود وعلى اله وصحبه اهل الوفا بالعهود وعلى التابعين لهم بالاحسان الى يوم الورود  . تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

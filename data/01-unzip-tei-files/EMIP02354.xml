                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    A rectangular mirror niche is visible in the inside front cover
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc type="RecordReconciliation">
                    <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                    a notice of reconciliation, including a list of witnesses
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#118r" facs="119">Fol. 118r</locus>
                    a calendar of months and days
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#49v" facs="051">Fol. 49v</locus>
                    The midpoint of the Psalms is marked with a small ornamental band in the right margin and the text <foreign xml:lang="gez">መንፈቅ፡</foreign> ʿhalfʾ
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#12 #45 #59 #85 #90 #105" facs="013 046 060 086 091 106">Fols. 12, 45, 59, 85, 90, 105</locus>
                    white string stitched into fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#100" facs="101">Fol. 100</locus>
                    red string stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    Numbered quires: quires 2–4
                    </desc>
                    </item>
                  <item xml:id="e7">
                  <desc>
                    words of text are written interlinearly (<locus target="#2r #11r #13r #15v #19r" facs="003 012 014 017 020">folss. 2r, 11r, 13r, 15v, 19r, </locus>, etc.);
                    lines of text are written interlinearly (<locus target="#21r #93v #94r #106r" facs="022 095 107">21r, 93v, 94r, 106r, </locus>);
                    lines of text are written in the upper margin with a symbol (+) marking the location where the text is to be inserted (<locus target="#45r #73r #79v #89r #107r" facs="046 074 081 091 108">45r, 73r, 79v, 89r, 107r, </locus>), and in another case where the symbol (┴) is used (<locus target="#112v" facs="114">112v, </locus>);
                    erasure markings are visible (<locus target="#10v #32r #50v #51v #56r" facs="012 033 052 053 057">10v, 32r, 50v, 51v, 56r, </locus>, etc.);
                    text has been removed (<locus target="#16r #17v #35r #38r #38v" facs="017 019 036 039 040">16r, 17v, 35r, 38r, 38v</locus>, etc.)
                  </desc>
                  </item>
                </list>
                </additions>

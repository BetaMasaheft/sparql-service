               <msContents>
                  <summary/>

                 <msItem xml:id="ms_i0">
                    <title ref="https://betamasaheft.eu/LIT1008DossierTH">Hagiographic Dossier of St Takla Hāymānot</title>
                    <textLang mainLang="gez"/>

                    <msItem xml:id="ms_i1">
                    <title type="complete" ref="https://betamasaheft.eu/LIT4114GadlaT">Gadla Takla Hāymānot - Dabra Libānos, first
          sub-recension</title>
                    <textLang mainLang="gez"/>

                    <note>The <foreign xml:lang="gez">gadl</foreign> is preceded by an introduction and a homily.</note>
                    <note>The genealogies of ʾAzaryas and the kings of Ethiopia are missing.</note>
                    <note>There are no chapter divisions.</note>

                    <listBibl type="secondary">
                        <bibl corresp="http://zotero.org/groups/358366/items/6S5RB4AJ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Nosnitsin2003Felsatu"/><title level="a">Mäṣḥafä fǝlsätu lä-abunä Täklä Haymanot: a Short Study</title><title level="j">Aethiopica</title><author><forename>Denis</forename><surname>Nosnitsin</surname></author><date>2003</date><biblScope unit="volume">6</biblScope><biblScope unit="page">137-167</biblScope><note type="url">http://journals.sub.uni-hamburg.de/aethiopica/article/view/374</note><note type="tags"><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Philology</note><note type="tag">Hagiography</note><note type="tag">Däbrä Libanos</note><note type="tag">bm:Nosnitsin2003Felsatu</note><note type="tag">Täklä Haymanot</note></note><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Philology</note><note type="tag">Hagiography</note><note type="tag">Däbrä Libanos</note><note type="tag">bm:Nosnitsin2003Felsatu</note><note type="tag">Täklä Haymanot</note><citedRange unit="page">145</citedRange><citedRange unit="note">30</citedRange></bibl>
                    </listBibl>

                    <colophon xml:id="coloph1">
                        <locus target="#93r"/>
                        <note xml:lang="en">The colophon is the
                          same as <ref type="mss" corresp="https://betamasaheft.eu/BLadd16257#coloph1">London, British Library, BL Additional 16257: colophon coloph1</ref>. </note>
                    </colophon>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="93vb" to="94vb"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3972Mashaf">Genealogy of Takla Hāymānot from Adam</title>
                     <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i3">
                       <locus from="94vb" to="96va"/>
                        <title type="complete">On the history of the successors of Takla Hāymānot,
                          and the twelve mamhǝrān</title>
                        <textLang mainLang="gez"/>

                     <colophon xml:id="coloph2" xml:lang="gez">
                        <date when="1515"/>
                        <locus from="96vb" to="96vc"/>
                      ወተጽሕፈት፡ ዛቲ፡ መጽሐፍ፡ በ<date>፸፻ወ፯፡ ዓመተ፡ ምሕረት፡</date> በመንግሥተ፡ ገብረ፡ መስቀል፡ መፍቀሬ፡ እግዚአብሔር፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        <note xml:lang="en">The colophon states that the book was written in the <date calendar="world">"year of Grace 7007"</date>, corresponding to <date>1515</date>, under the reign of Gabra Masqal.
                        According to <bibl corresp="http://zotero.org/groups/358366/items/C8NKKM68"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1899Note"/><title level="a">Note per la storia letteraria abissina</title><title level="j">Atti della Reale Accademia dei Lincei, Rendiconti, Classe di scienze morale, storiche e filologiche</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Carlo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Conti Rossini</t:surname></author><date>1899</date><biblScope unit="volume">Serie quinta, 8</biblScope><biblScope unit="page">197–220; 263–285</biblScope><note type="url">http://periodici.librari.beniculturali.it/visualizzatore.aspx?anno=1899&amp;id_immagine=9742962&amp;id_periodico=9056&amp;id_testata=30</note><citedRange unit="page">267</citedRange></bibl>, Gabra Masqal could be identified with <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>.</note>
                    </colophon>
                    </msItem>

                    <msItem xml:id="ms_i4">
                       <locus from="97ra" to="98ra"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT3143Ledata">Lǝdata ʾabaw</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ንዌጥን፡ ልደተ፡ አበዊነ፡ መነኮሳት፡ አባ፡ እምጦንስ፡ ለብሰ፡ ልብሰ፡
                         ምንኩስና፡ በእደ፡ መልአክ፡ ባሕቲቱ፡ አላ፡ በሥምረተ፡ እግዚአብሔር፡ ሎቱ፡ ስብሐት፡ አባ፡ እንጦንስ፡ ወለደ፡
                         ለአባ፡ መቃርስ፡ ዘየዓቢ፡
                       </incipit>
                    </msItem>

                    <msItem xml:id="ms_i5">
                       <locus from="98rb" to="98rb"/>
                       <title type="complete">On the covenant between Takla Hāymānot and King Yǝkʷǝnno ʾAmlak</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez"/>
                    </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="98va" to="106ra"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1929Mashaf">Maṣḥafa fǝlsatu la-Takla Hāymānot</title>
                     <textLang mainLang="gez"/>
                     <note>The text starts with the story about the last days of Moses,
                       <bibl corresp="http://zotero.org/groups/358366/items/6S5RB4AJ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Nosnitsin2003Felsatu"/><title level="a">Mäṣḥafä fǝlsätu lä-abunä Täklä Haymanot: a Short Study</title><title level="j">Aethiopica</title><author><forename>Denis</forename><surname>Nosnitsin</surname></author><date>2003</date><biblScope unit="volume">6</biblScope><biblScope unit="page">137-167</biblScope><note type="url">http://journals.sub.uni-hamburg.de/aethiopica/article/view/374</note><note type="tags"><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Philology</note><note type="tag">Hagiography</note><note type="tag">Däbrä Libanos</note><note type="tag">bm:Nosnitsin2003Felsatu</note><note type="tag">Täklä Haymanot</note></note><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Philology</note><note type="tag">Hagiography</note><note type="tag">Däbrä Libanos</note><note type="tag">bm:Nosnitsin2003Felsatu</note><note type="tag">Täklä Haymanot</note></bibl>.
                          </note>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <locus from="106v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3971Taamme#HomilyBirth">Homily on the birth of
                       Takla Hāymānot</title>
                     <textLang mainLang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i8">
                     <title type="complete" ref="https://betamasaheft.eu/LIT3971Taamme">Taʾammǝra Takla Hāymānot</title>
                     <textLang mainLang="gez"/>
                  </msItem>
              </msItem>
               </msContents>


               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="116v">1r-116v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0020IHA#s5IHA">منهاج الطالبين, From the beginning of kitāb
                    al-waṣāyā to kitāb ummahāt al-awlād (second half) 2/2</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم .كتاب الوصايا يا يصح وصية مكلفٍ حرٍ وان كان كافرا او كذا محجور عليه لسفه على المذهب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#116v">-116v</locus>لا يعتقون بموت السيد وله بيعهم وعتق المستولدة من راس المال وبالله التوفيق واليه المرجع والماب
</explicit>
                     <note>Some of the words are divided into two different lines</note>
                     <note/>
                  </msItem>
               </msContents>

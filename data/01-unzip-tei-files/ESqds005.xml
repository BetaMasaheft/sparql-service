               <msContents>
                  <summary>I) Haymanotä ʾabaw “Faith of the Fathers” (fols. 4r-104r).</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>- Quire A was probably added later.</note>
                     <note>- A few bifolios have shorter upper and/or lower margins, e.g., 2r-3v,
                        31r-32v.</note>
                     <note>- The scribe does not always pay attention to the ruling lines.</note>
                  </msItem>
               </msContents>

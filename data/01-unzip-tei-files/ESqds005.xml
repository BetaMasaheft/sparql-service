                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, slightly left-sloping</seg>
                        <seg type="ink">Black; red (vivid to strong red; vivid to strong
                           crimson)</seg>
                        <date>19th century (?)</date>
                        <seg type="rubrication">Nomina sacra; 1st, 2nd, 8th , 9th, 15th and 16th
                           line of the incipit page; two or three initial lines of sub-sections;
                           Gǝʿǝz names of ordinal numerals followed by the word tǝʾǝzaz on fol.
                           103v; elements of punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Coloured thread is inserted in the upper right
                              corner: fols. 11, 17, 59, 88. - Names of some feasts are written, by
                              secondary hands, in the upper margin of fols. 11vc, 17v, 40rc, 41rac,
                              44va, 59vc, 67va.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Tämälläs sign (in the shape of +) indicating the place where an omission, written in the upper margin, belongs: <locus target="#36vc">fol.  36vc</locus> l.21.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards (the front board is broken and
                           repaired; the back board is cracked). 
 Remnants of turn-ins and
                           textile inlays visible in the back board.
 Two pairs of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                           <material key="textile"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two rows of small holes visible on the
                           spine fold of the quires.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the brown turn-ins (one tool
                           was used: triple line fillet).</decoNote>
                     </binding>
                  </bindingDesc>

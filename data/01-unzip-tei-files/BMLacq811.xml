                    <msContents>
                        <summary/>
               <msItem xml:id="ms_i1">
                   <locus from="1" to="151"/>
                   <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                        <msItem xml:id="ms_i1.1">
                            <locus from="1" to="114r"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Psalms beginning with the last line of Psalm 14.</title>
                            <note>Pseudoepigraphical Psalm no. 151 attached at the end at <locus from="113v" to="114r"/></note>
                            <note>Written with black ink; red ink for incipits, sometimes divine names and the scribe's name.</note>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                            <locus from="114" to="127" type="complete"/>
                            <title ref="https://betamasaheft.eu/LIT1828Mahale">15 Songs of the Prophets</title>
                            <note>From the description in <bibl><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Marrassini1986Laurenziana"/><title level="a">I manoscritti etiopici della Biblioteca Medicea Laurenziana di Firenze</title><title level="j">Rassegna di Studi Etiopici</title><author><forename>Paolo</forename><surname>Marrassini</surname></author><date>1984</date><biblScope unit="volume">30</biblScope><biblScope unit="page">81-116</biblScope><note type="url">http://www.jstor.org/stable/41299683</note><note type="tags"><note type="tag">bm:Marrassini1986Laurenziana</note></note><note type="tag">bm:Marrassini1986Laurenziana</note><citedRange unit="page">101</citedRange></bibl>, it is not clear whether the work is complete or whether the Third Song of the Three Youths in the Furnace - usually no. 10 in the 15 Songs 
                                of the Prophets is missing here.</note>
                            <msItem xml:id="ms_i1.2.1">
                                <locus from="114" to="115r"/>
                                <title ref="https://betamasaheft.eu/LIT2277salotu">The Prayer of Moses</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.2">
                                <locus from="115" to="117r"/>
                                <title ref="https://betamasaheft.eu/LIT2278salota">Second Prayer of Moses</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.3">
                                <locus from="117" to="118"/>
                                <title ref="https://betamasaheft.eu/LIT2703salota">The Third Prayer of Moses</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.4">
                                <locus from="118v" to="119"/>
                                <title ref="https://betamasaheft.eu/LIT2257salota">The Prayer of Hannah, mother of Samuel the Prophet</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.5">
                                <locus from="119v" to="120"/>
                                <title ref="https://betamasaheft.eu/LIT2258salota">The Prayer of Hezekiah, King of Judah</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.6">
                                <locus from="120v" to="121"/>
                                <title ref="https://betamasaheft.eu/LIT2265salota">The Prayer of Manasseh</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.7">
                                <locus from="121v" to="122r"/>
                                <title ref="https://betamasaheft.eu/LIT2274salota">The Prayer of Jonah</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.8">
                                <locus from="122" to="123r"/>
                                <title ref="https://betamasaheft.eu/LIT2250salota">Ṣalota Dānǝʾel nabiy sǝbḥat za-ʾǝm-ʾAzāryā</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.9">
                                <locus from="123v" to="124"/>
                                <title ref="https://betamasaheft.eu/LIT2271salota">Ṣalota śalastu daqiq</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.10">
                                <locus from="124v" to="126r"/>
                                <title ref="https://betamasaheft.eu/LIT2251salota">Ṣalota ʿƎnbāqom nabiyy</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.11">
                                <locus from="126" to="127r"/>
                                <title ref="https://betamasaheft.eu/LIT2259salota">Song of Isaiah</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.12">
                                <locus from="127r" to="127v"/>
                                <title ref="https://betamasaheft.eu/LIT1827Magnif">Magnificat</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.13">
                                <locus from="127v" to="128r"/>
                                <title ref="https://betamasaheft.eu/LIT2275salota">Song of Zachariah</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2.14">
                                <locus target="#128r"/>
                                <title ref="https://betamasaheft.eu/LIT2272salota">Now you dismiss</title>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                            <locus from="128" to="136r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                            <note>Song of Songs, divided in five sections.</note>
                            <incipit xml:lang="gez">መሐልየ፡ መሐልይ፡ ዘውእቱ፡ ዘሰሎሞን፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.4">
                            <locus from="136" to="147r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                            <note>Praise of Mary, divided by the days of the week.</note>
                            <incipit xml:lang="gez">ውዳሴሃ፡ ለእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.5">
                            <locus from="147" to="151"/>
                            <title ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                            <incipit xml:lang="gez">ወእምዝ፡ ንጽሕፍ፡ ዝክረ፡ ውዳሴሃ፡ ለእግዝእትነ፡ ማርያም፡</incipit>
                        </msItem>
                        </msItem>

                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3179Revela">Revelation of John</title>
                            <textLang mainLang="gez"/>
                            <colophon xml:id="coloph1">
                                <locus target="#85v"/>
                                <note>In the colophon, the names of <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName> and <persName ref="https://betamasaheft.eu/PRS2682BerhanM">Walatta Giyorgis</persName> have
                                been subsequently inserted.</note>
                            </colophon>
                        </msItem>
                        

                        <msItem xml:id="ms_i2">
                            <locus from="87r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1690ActsofJohn">Acts of St John son of Zebedee</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis" resp="PRS10171Wright"/>
                                ዝንቱ፡ ፍኖቱ፡ ለቅዱስ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ወንጌላዊ፡ ኄር፡ ወፍልሰቱ፡ እምዝንቱ፡ ዓለም፡ ኀበ፡ እግዚአብሔር፡ ዘጸሐፎ፡ አብርኮሮስ፡ 
                                ቅዱስ፡ ዘመዱ፡ ለብፁዕ፡ እስጢፋኖስ፡ ሊቀ፡ ዲያቆናት፡ ወቀዳሜ፡ ሰማዕት፡ ፩እም፯ላእካን፡ እለ፡ ዓቀምዎሙ፡ ሐዋርያት፡ ለመልእክተ፡ ነጋድያን፤
                                በሰላመ፡ አበ፡ አሜን። ወኮነ፡ እምድኅረ፡ ዕርገት፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ውስተ፡ ሰማያት፡ ተጋብኡ፡ ሐዋርያት፡ ኀበ፡ መቃብራ፡ ለማርያም፡
                                ወይቤሎሙ፡ ጴጥሮስ፡ አንትሙ፡ ተአምሩ፡ ኦአኃውየ፡ ኵሎ፡ ዘአዘዘነ፡ እግዚእነ፡ <sic resp="DR">አ</sic>'፡ ክ'፡ ከመ፡ ንምሀር፡ አሕዛበ፡ አሚነ፡ ወናጥምቆሙ፡ በስመ፡
                                አብ፡ ወወ'፡ ወመ'፡ ቅ'።</incipit>
                            </msItem>
                        
                        
                        <msItem xml:id="ms_i3">
                            <locus from="87r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3539DeathJohn">The Death of St John son of Zebedee</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አበ፡ <gap reason="ellipsis" resp="PRS10171Wright"/>
                                ዝንቱ፡ መጽሐፈ፡ ዕረፍቱ፡ ለቅዱስ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ረድኡ፡ ወፍቁሩ፡ ለእግዚእነ፡ ኢ'፡ ክ'፤ ድንግል፡ ወንጹሕ፡ ወንጌላዊ፡ ኄር፡
                                ዘይትናገር፡ ላዕለ፡ መለኮት፡ ወፍልሰቱ፡ እምዝንቱ፡ ዓለም። ወኮነ፡ በውስተ፡ ደሴት፡ ዘፍጥሞ፡ አመ፡ ፬ለወርኃ፡ ጥር፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4"> 
                            <locus from="114r"/>
                            <title type="complete">Hymn composed by the scribe of the manuscript</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ወዛቲ፡ ድርሱት፡ ዓርኬ፡ ይእቲ፡ ዘደረስክዋ፡ አነ፡ ጸሓፌ፡ ዝንቱ፡ መጽሐፍ። ኢታርእየኒ፡ ዮሐንስ፡ 
                                ሞተ፡  <del rend="erasure"/>፡ <add place="inline">
                           <persName ref="https://betamasaheft.eu/PRS5617IyasuII">አያሱ፡</persName>
                        </add> ክሡተ። 
                                በከመ፡ ርኢኮ፡ ቀዳሚ፡ ለዘ፡ ዲበ፡ መስቀል፡ ሞተ። ከመ፡ ሞተ፡ እግዚእ፡ ይጸንዕ፡ አምጣነ፡ ተአምር፡ አንተ።
                                ኀበ፡ ፈርሃ፡ ግርማ፡ ኃዘን፡ መዓልተ፡ ወሌሊተ። እንዘ፡ ይብል፡ ይጼሊ፡ ዘጸሐፌ፡ ዘንተ።</incipit>
                        </msItem>
                    </msContents>


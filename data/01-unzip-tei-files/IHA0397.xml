                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="9v">1r-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0767IHA">عقائد المساكين</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسملة \ الحمد لله والصلوة والسلام على رسول الله صلى الله عليه وسلم اعلم \ ان احكام الشريعة خمسة واجب ومندوب وحرام ومكروه ومباح \ وقواعد السلام خمسة التوحيد والصلاة والزكوة والصّوم والحج \ واركان الايمان ستة الايمان بالله والايمان بالرسل والايمان بالمليكة \ والايمان بالكتب السماوية  والايمان باليوم الاخر والايمان بالقدر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>والاحتمال الاوّل هو الاحتياط \ الذي ينبغي لكلّ عاقل ان يعضّ عليه بالنواجذ والاحتمال الثاني لا يرضى \ به الّا دواهمّة دنية ونفس دريّة وطبيعة شنيّة وبصيرة عميّة \ نسئل الله ان يرزقنا احسن الإعتقاد ويختم لنا بالخير انّه كريم جواد \ روؤ رحيم . انتهى . والله اعلم . \ وصلى الله على سيدنا محمد واله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="10r" to="83r">10r-83r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0768IHA">تخميس القصيدة الإياضية</title>
                     <incipit xml:lang="ar">
                        <locus target="#10v">-10v</locus>أَذُوْبُ اشْتِياقاً وَالْفُؤَادُ بِحَسْرَةٍ \ وَفِيْ طَيِّ أحْشَائِيْ تَوَقُّدُ جَمْرَةٍ \ مَتَى تَرْجِعُ الأَحْبَابُ مِنْ طُولٍ سَفْرَةٍ \ أَحِبَّةَ قَلْبي عَلّلُوني بِنَظْرَةٍ فَدَائي جَفَاكُمْ وَالْوِصَالُ دَوَائي \ رَحَلْتُمْ وَخَلَّفْتُمْ فُؤَادِي مُعَذَّبَا \ يَهيمُ بِكُم بَيْنَ الْمَرَاتعِ والرُّبَا \ وَفي كَبِدِي نَارٌ تَزِيدُ تَلَهُّبَا \ أَحِنُّ إلَيْكُمْ كُلَّما هَبَّتِ الصَّبا فَيَزْدَادُ شَوْقي نَحْوَكُمْ وَعَنَاءِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#83r">-83r</locus>مَدَدْتُّ إِلَي الرَّحْمَنِ مَنْ فَاقَتي يَدِىْ \ وَأجْهَدْتُ نَفْسِيْ اَرْتَجى الفَوْذَ فِيْ غَدِى \ لِمَا نَالَ قَلْبِيْ مَنْ جَوَيْ مُتَصَعِّدِىْ \ يّهِيْجُ غَرَامِيْ عِنْدَ ذِكْرِي لِلأَحْمَدِ كَأَنِّيْ مَلْسُوغٌ وَقَدْ عَدَمَ الرُّقْيَا
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="84r" to="84v">84r-84v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3726IHA">قصيدة المنفرجة للغزالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#84r">-84r</locus>بسملة \ الشِدّةُ أَودَتْ بِالمُهَجِ٬ يَا رَبِّ فَعَجِل بِالفَرَجِ٬ وَأَنْفُسُ أَمْسَتْ فِي حَرَجِ \ وَبِيَدِكَ تَفْرِيجُ الهَرَجِ٬ هَاجَتْ لِدُعَاكِ خَوَاطِرُنَا \ وَالوَيْلُ لَهَا إِنْ لَمْ تَهِجِ٬ يَا مَنْ عَوَّدْتَ اللُّطْفَ أَعِدْ \ عَادَاتِكَ بِاللُّطْفِ البَهِجِ٬ وَاغْلِقْ ذَا الضَّيقَ وَشِدَّتِهِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#84v">-84v</locus>يَا رَبِّ بِهِمْ وَبِآَلِهِمْ٬ عَجِّلْ بِالْنَّصْرِ وَبِالْفَرَجِ \ وَاخْتِمْ عَمَلِي بِخَوَاتِمِهَا٬ وَمُصَنِّفَهَا يَعْلُوْا دَرْجِ٬ تم بحمد الله وعونه وحسن توفيقه</explicit>
                     <note>Text written also on the margins in orthogonal direction
  </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="85r" to="91v">85r-91v</locus>
                     <title ref="https://betamasaheft.eu/LIT0001IHA">كتاب الفرائض للعراشي</title>
                     <incipit xml:lang="ar">
                        <locus target="#85r">-85r</locus>بسملة \ اللهم صلّ وسَلّم عَلّى سيّدنا محمد وسلّم تسليمًا \ صُومَنْ يِبُوْ جِرْ تِمِسْتِنْ حَالٍ يُبُؤْ تَعَسِّرْ اَنَ حَالٍ بِبُوْءْ أوَّلْ جِرْ \ إِبْلِيْسْ مَلْدَوْمَا زَأجَدُلُوْا سُوْتْ جَنَّتْ بَرْعِوْا زِكَفَتُلُوْا \ سَعْتِ عَذَابْ بَرِعِوْا زَقُوْفَلُ لُوْا زُلْعِيْوُمْ
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#91v">-91v</locus> أَحَدْتَّ نُجْدَ يِجَبْعِ بَخُ جرْاُوْدُشَا أَبُوْشْ مِنْ نَاشُ تِلُمَ \ تِتْحِيْرَ حَاخُوَ جَمِّعْ مَخْلُوْقْ إِيَ وْاِمَلْ حِرْجِ اِرَزْقِ بَازَخْ قُدْرَ \ إِوْاَطْمَمْتُنْ اللهُ إِيْ بَاي اللهم صل وسلم على سيدنا محمد وعلى ال \ محمد وسلم تسليما \ هذا كتب الفرايض بكلام الوزى [كذا ولكن ممكن الهرري] ا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="91v" to="104r">91v-104r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT0669IHA">كتاب الفرائض للوناجي الصدري</title>
                     <incipit xml:lang="ar">
                        <locus target="#91v">-91v</locus>بسملة \ جَنَّتْمَا يَرَجِبُوْا إِمْ إِسَاتُخْ يِسَلْطُبُوْا اُللهُ خَادُوْا أَجْدِ رُوْتْ \ زَاللهُ لَالُ اِنَّاخْ بلاوْت بِرَحَسِن بِإِنِسْتِنْ بِجَافَانْبِوَلَبَانْ أَوَّلْ \ بِجَافِ زَارَدُوْا فَرْضِ اللهُ خَادُوْا عُقُوْتْ عُقُوْنْ زُوْخْ ايْكُنْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#104r">-104r</locus>هَرعَةٍ إِسْلَامْ خُنُوْتْ عَاقِلْ خُنُوْتْ بَالِغْ خُنُوْتْ زِنِية أَرْتَايَ بِنِيْةْ أُشُوْتْ زِنِيْة \ حكم شِئَشْت سُنَّ أَرْتَايْ فرْضِ أَرْتَايْ زِيْنَةْ أَرْتَايَ بِ \ صِفَةْ دُوْا أَشُوْتْ زِنِيْة أَرْتَاي كُعُتٍ مَياْإِجْ كَفّ كَالتِدَابَلَ بِ \ نِيْةْ شُوْتٍ  تم الفرائض المعتقدات بحمد الله وعونه \ وكرمه وحسن توفيقه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="104v" to="105r">104v-105r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0771IHA">عقيدة البنوفرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#104v">-104v</locus>شهدت معتقدا جزما بغير مرءا أن لا إله سوى الله الذي قهرا \ ربّ غني عن الأشيإ أجمعها وكل شي إلى إحسانه افتقرا \ موجود باق قديم ذو مخالفة لخلفه ولما في البال قد خطرا
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#105r">-105r</locus>مسلّما وعلى ال ومن صحبوا مهما رقي  قارئ القرآن خير قرا\ والتابعين وأتباع لهم وعلى من للعقيدة هذي نظم الدررا</explicit>
                     <note/>
                     <note/>
                  </msItem>

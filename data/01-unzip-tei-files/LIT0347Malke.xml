         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ኣዐትብ፡ ገጽየ፡ በስመ፡ ሥሉሳን፡ አጋእዝትየ፨</l>
                  <l n="2">ወበስመ፡ ማርያም፡ ድንግል፡ ዘተመሰለት፡ ሰማየ፨</l>
                  <l n="3">ስብሐተ፡ መልክእከ፡ እንብብ፡ እንዘ፡ እከሥት፡ አፉየ፨</l>
                  <l n="4">ገብረ፡ መስቀል፡ ቅላዕ፡ ባሕቱ፡ መንጦላዕተ፡ ግዙፍ፡ ልብየ፨</l>
                  <l n="5">ወተናበበኒ፡ ቀዊመከ፡ ዝየ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ መአድመ፡ ዜና፡ እምወይን፨</l>
                  <l n="2">ዓዲ፡ እምናብሊስ፡ እንተ፡ ይሔውዞ፡ ለእዝን፨</l>
                  <l n="3">ገብረ፡ መስቀል፡ ላዕሌከ፡ አመ፡ ተዐውቀ፡ ብርሃን፨</l>
                  <l n="4">ተበሀሉ፡ መምህራኒከ፡ እለ፡ ነጸሩ፡ በዐይን፨</l>
                  <l n="5">ዕበያተ፡ አምላክ፡ ንዋ፡ ላዕለዝ፡ ሕፃን፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለሕፅንከ፡ ወለአእዳዊከ፡ እለ፡ ይረብባ፨</l>
                  <l n="2">ምስለ፡ መዛርዕ፡ ለጸሎት፡ እለ፡ ያስተርክባ፨</l>
                  <l n="3">ገብረ፡ መስቀል፡ አቡነ፡ ለገዳመ፡ ዋሊ፡ ኮከባ፨</l>
                  <l n="4">እፎኑመ፡ እንዘ፡ ሕፃን፡ ዘኢያፍቀርከ፡ ሐሊባ፨</l>
                  <l n="5">ለመንፈሳዊት፡ እምከ፡ ዘርኅሩኅ፡ ልባ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ ለአቡክሙ፡ በአስተሐምሞ፡ ወጻህቅ፨</l>
                  <l n="2">ከመ፡ ንጉሠ፡ ምድር፡ አኮ፡ አምኃ፡ ብሩር፡ ወወርቅ፨</l>
                  <l n="3">ጻድቃነ፡ ለጋሶ፡ ወጕትማን፡ ወንጌላውያን፡ አዕጹቅ፨</l>
                  <l n="4">አመ፡ ይረፍቁ፡ በቤተ፡ መርዓ፡ ምስለ፡ ኢየሱስ፡ ሊቅ፨</l>
                  <l n="5">አርፍቁኒ፡ ምስሌክሙ፡ በሐዳስ፡ ምርፋቅ፨</l>
               </lg>
            </div>
         </div>
      </body>

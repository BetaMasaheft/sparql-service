               <t:persName xml:lang="gez" xml:id="n1">ደቂቀ፡ ኤዎስጣቴዎስ፡</t:persName>
               <t:persName xml:lang="gez" type="normalized" corresp="#n1">daqiqa ʾEwosṭātewos</t:persName>
               <t:persName xml:lang="en">ʾEwosṭāteans</t:persName>
               <t:floruit notBefore="1300" precision="medium">The ʾEwostāteans are a religious movement and network of monasteries going back to <t:persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</t:persName>. They originated
                  in Eastern <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName> and were widely involved in the Christianization of the Northern Ethiopian provinces in the <t:date>14th and 15th century</t:date>.
               </t:floruit>
            </t:personGrp>
            
         </t:listPerson>
         

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: fine; hand b: careful; hand c: fine and
                           careful</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Second half of the 18th century.</date>
                        <seg type="rubrication">Nomina sacra; 1st, 3rd, 5th, 6th, 16th and 17th
                           lines in the incipit page; titles of the paragraphs, chapters, discourses
                           and prayers; the 1st and 3rd line of the prayer on fol. 2r; elements of
                           the punctuation signs.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="3r" to="23v">3r-23v</locus>, 135v-149r. Letters with pronounced serifs, slanted at
                        somewhat different angles.
                        </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="24r" to="134r">24r-134r</locus>. "Squeezed", thick
                        letters.</handNote>
                     <handNote xml:id="h4" script="Ethiopic"> Hand c:
                        rubricator</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">Decorated quire marks on fols.: 3r, 13r,
                        23r, 33r, 43r, 53r, 63r, 73r, 83r, 93r, 103r.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2r">f. 2r</locus>
                           <desc>: Scribe's exhortation to the Lord.</desc>
                           <quote xml:lang="gez">
                              <locus target="#2r">2r</locus>: ለዛቲ፡ ብርዕየ፡ ዘወጠንክዋ፡ አሥምራ፡ እግዚኦ፡ ወአሠንያ፡
                              ወአፈጽመኒ፡ በዳህና፡ ወበሰላ[ም] </quote>
                           <quote xml:lang="en">This pen of mine which I have begun [to use], accept
                              it o Lord and beautify it and help me finish it [my work] in wellness
                              and peace.</quote>
                           <note> The note is written in hand a. The first and the last lines are
                              rubricated. </note>
                        </item>
                        <item xml:id="e1">- The title of the work is written on the front
                           board.
 - Tamallas-signs: <locus target="#3rb">3rb</locus> l.1, 6vb
                           l.3. 
 - The name አቡነ ገብረ ጻድቅ is written on <locus target="#149rb">149rb</locus>.
 - Omitted letters, words, lines or passages are
                           written in the margins on <locus target="#3r">3r</locus>, 6v, 13v, 74r,
                           106r, 108v, 123r, 132v.
 - Minor notes, writing exercises in Amharic
                           and Gǝʿǝz, doodles (mostly in the bottom margin): <locus target="#1r">1r</locus>, 9r, 15r, 31v, 35r, 52rv, 55r, 65r, 66r, 68v, 73r, 76r,
                           79v, 88v, 89v, 90v, 91v, 93r, 101r, 111r, 118v, 123r, 125r, 127v-128r,
                           131r, 135r, 150rv.</item>
                        <item xml:id="e2">Shelfmark C3-IV-244 (<locus target="#3r">3r</locus>)</item>

                        <item xml:id="e3">Shelfmark 294 (<locus target="#1r">1r</locus>)</item>
                     </list>
                  </additions>

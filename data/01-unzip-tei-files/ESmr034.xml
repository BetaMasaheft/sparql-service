                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre; the same hand as MR-007.</seg>
                        <seg type="ink">Black; reddish brown.</seg>
                        <date>Late 19th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ or ካ፡ for ይቤ፡ ካህን</item>
                           <item>ይዲ፡ or ዲ፡ for ይቤ፡ ዲያቆን</item>
                           <item>ይሕ፡ or ሕ፡ for ይቤ፡ ሕዝብ፡</item>
                           <item>ዕማ፡ or እማ፡ for ዕማሬ፡</item>
                        </list>
                        <seg type="rubrication">First words or lines of constituent texts (sometimes
                           alternating lines in black and reddish brown); name of the Virgin Mary;
                           name of the reigning monarch; names of the persons mentioned at the
                           beginning of the Anaphoras; abbreviations; the word ዕማሬ፡ (እማሬ፡); elements
                           of the punctuation signs; elements of Ethiopic figures.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The text on <locus target="#20">20</locus> is written by a different, finer
                        hand.</handNote>
                  </handDesc>

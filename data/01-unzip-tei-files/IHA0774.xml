                  <summary>ff. 34v-35v blank</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2v">1r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="af">Afar</textLang>
                     <title ref="https://betamasaheft.eu/LIT1939IHA#s157IHA">Madḥ al-Nabī "Li-Llāh al-ḥamd bi-sm Allāh li-Llāh al-šukr bi-sm Allāh"</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسملة  \ لِلهِ الْحَمْدُ بِسْمِ اللهِ لِلهِ الْشُكْرُ بِسْمِ اللهِ \ لِلهِ الْأَشْيَا بِسْمِ اللهِ بِعَدِّ الْأَشْيَا بِسْمِ اللهِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>حُوْرُ الْعَيْنِ كِنْ عُلُهُ بِلَانَا لِلهِ الْحَمْدُ إِيَّانَهْ دِݣْرَانَا \ نَبِيْ لِّهْ يَلِّهْ عَرْسَهْ مَبُلْ ݣِيَانَا كِنْ حُرْ مَتَلْ ݣُيْتَوْ غُفْرَانَا \ بَرْكَتْ كِيْ خَيْرِيْكِيْرَوْحِ رِيْحَانَا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="5r">2v-5r</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1939IHA#s158IHA">Madḥ al-Nabī "Ḥamdu li-Llāh mar ḥak"</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>حَمْدُ لِلهْ مَرْ حَكْ دُودَّلْ يَبْنَا مَا  نَبِيْ ذِكْرِيْ عِيْرُ مَلِيْ مَيَامَا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>دُوْدَّلِيْ رَبِّيْ فَيْرِكَاهْ أَبَامَا حَتُكْ مَكَّابَا أَحْمَدَ لْ مَوَانَا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5r" to="11r">5r-11r</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1939IHA#s159IHA">Madḥ al-Nabī "Al-ḥamdu li-Llāh niwālā wa-lā ḥawlā wa-lh quwwa mafālā"</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>بسملة \ بِسْمِ الله وَالْحَمْدُ لِلهْ نِوَالَا وَلَا حَوْلَا وَلَا قُوَّة مَفَالَا \ دّيِّ نِعْمَة نِفَالَا يَحِهْ كَلَا حِنَهْ يَحِيْ كَيْ حَالَا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>أّبْلِوِنْ أَحْوَهْ ݣِيْتُلْ نَفْرِحِيْمِ نِهْ أَبِيْ ݣُيْتَوْكُلْ فَنِّهْ نَرْحِيْمِ \ رَحْمَةْ ݣِيْتَيْ نَبِيْ أُمَّتَا تَكِّيْمِ بِيْ لِّهْ مَرْتِمْ مَرِوَيْتِمْ دَائِمِ </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="11r" to="14r">11r-14r</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1939IHA#s160IHA">Madḥ al-Nabī "Ḥamdu li-Llāh niʻmat gīṯal"</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>بسملة \ حَمْدُ لِلهْ نِعْمَتْ ݣِيْثُلْ يَبْنَا مَا يِحِيْ مَرْحَ دُدَّلْ حُلْلَاَّمَا \ نِعْمَتْ ݣِيْتُلْ شُكْرِيَلَّه يَبْنَامَا مَرْحَهْ حُلْسَلْ ݣِيْتُوْيَلَّلْ فَنَّامَا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>صَلَاةْ أَبْنِهْ سَلَامَتَلْ نِيْ فَادِسِيْ كُلِّمْ لِمْ كُوْنِهْ تَيْشِيْمِ نِهْتَارِݣِيْ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="14v" to="22v">14v-22v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1951IHA">مدح النبي بالعفرية يِنَبْيُوْ نُوْرُوْنِيْ</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>سلام عليك يا محمد [۲] \ أحمد نبي مثال ملي [۲] \ يِنَبْيُوْ نُوْرُوْنِيْ إِلِيْلِيْ يَلِّهْ كَمِّكْ نِيْ ݣَمِيْلِيْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22v">-22v</locus>كَالِهْ كُوْعَرْ سَانِيْ بُلِّيْ رَحْمَةْ بِلَلْ \ كَلْ بِيْ بِلِيْ نِنَبِلْ خَيْرِ نِهْ تِيْلِيْ كُلِّ شَرِّ نِكْ دَبِّالِيْ \ يَلَّوْ رَحْمَةْ نَىِلْ عُلِيْ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="23r" to="25r">23r-25r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1952IHA">مدح النبي أشرق البدر الأبطاحي</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>لأَلْفَيْ صَلَّى اللهُ عَلَيْكَ يَا مُحَمَّدْ صَلَوَاتُ اللهْ عَلَيْكَ نَبِيْ مُحَمَّدْ \ يَا نَبِيْ سَلَامُ عَلَيْكَ يَا رَسُوْلُ سَلَامُ عَلَيْكَ [...] \ أَشْرَقَ الْبَدْرُ الْأَبْطَاحِيْ بِ [كذا] الْفَلَاحِ وَصَلَاحِيْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25r">-25r</locus>إِرْحَمْ يَا إِلَهِ وَغْفِرْ وَسْتُرْ وَعْفُ لِلْمُصَنِّفْ \ مَعْ جَمِيْعِ الْمُسْلِمِيْنَ وَخْتِمْ بِا [كذا] الْإِيْمَانِ حَسْبِيْ \ تمن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="25v" to="34r">25v-34r</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1953IHA">صلاة على النبيب العفرية مُحَمَّدْ عَرْمِعِيْ كَيْ
                    يَابْ</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>مُحَمَّدْ عَرْمِعِيْ كَيْ يَابْ دَعَمْمِعِيْ كَا حُسَانَمْ مِعِيْ يَلَّوْكَالْ بِهْ مِعِيْ يَلَّوْ كَالْ نِيْمِعِيْ \ نِخَاتِمَا إِيْمِيْعِيْ \ إِسْمُ الْأَعْظَمْ مَا عِيْ اللهْ مِݣَعْ مَعِيْ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34r">-34r</locus>إِسْلَامَنِنَّا إِلِّ تَيْثِنَّلْ دَݣِنَّمْ مِعِ أرَبَلْ عَرْكِنْتِ \ شَهَدْ يِيِّيْعيْ يَا بِوَيْتِمْ كَهْ يَا بِسِيْمِلْ كَابِلِيْ</explicit>
                     <note/>
                     <note/>
                  </msItem>

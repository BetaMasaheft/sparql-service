               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="74v">2v-74v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0102IHA">عمدة السالك وعدة الناسك</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم قال الشيخ العلم العلامة شهاب الدين احمد بن نقيب الشافعي رضي الله عنه ورحم سلفه بمنه وكرمه امين الحمد لله رب العالمين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم اجمعين هذ مختصر على مذهب الامام الشافعي رحمه الله اقتصرت فيه على الصحيح من المذهب عند الرافعي والنووي ادا حد هماد قد اذكر فيه خلافا وذلك اذا اختلف تصحيحهما مقدما لتصحيح النوووي فيكون مقابله تصحيح الرافعي وسميته عمدة السالك وعدة الناسك والله اسال ان ينفع به وهو حسبي ونعم الوكيل. كتاب الطهارة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#74v">-74v</locus>تم هذا الكتاب بعون الله وحسن توفيقه والحمد لله رب العالمين حمدا يوافي نعمه ويكافئ مزيده وصلى الله علي سيدنا محمد واله وصحبه وسلم امين</explicit>
                     <note>Some of the words are divided into two different lines
</note>
                     <note/>
                  </msItem>

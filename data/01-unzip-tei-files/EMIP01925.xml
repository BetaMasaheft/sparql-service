               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="66r" facs="003">Fols 1r–66r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1459GadlaH">Gadla Habta
                                                  Māryām</title>
                      <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="11v" facs="003">Fols 1r–11v</locus>
                        <title>For Monday</title>
                        <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ አብ፡ ዘይሬኢ፡ ወኢያስተርኢ፡ ወበስመ፡ እግዚአብሔር፡ ወልድ፡ ለቤዛ፡ አዳም፡ ተሠዋዒ፡ ወበስመ፡ እግዚአብሔር፡ መንፈስ፡ ቅዱስ፡ ለፈጽሞ፡ ገድል፡ መጽንዒ፡  <gap reason="omitted"/> (1v) ንጽሕፍ፡ ገድሎ፡ ለአቡነ፡ ክቡር፡ ጻድቅ፡ ወኄር፡ ትሩፈ፡ ኵሉ፡ ምግባር፡ ዘወጽአ፡ ስሙአቱ፡ ምልዓ፡ አናስር፡ ዘውእቱ፡ ሶል፡ ሀብተ፡ አብ፡ ሀብተ፡ ወልድ፡ ሀብተ፡ መንፈስ፡ ቅዱስ፡ አባ፡ ሀብተ፡ ማርያም፡ ብእሲ፡ ሰማያዊ፡ ወመልአክ፡ ምድራዊ።  <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="11v" to="23r" facs="014">Fols 11v–23r</locus>
                        <title>For Tuesday</title>
                        <incipit xml:lang="gez">ወሀብተ፡ ማርያምሰ፡ እንዘ፡ ኢየአምር፡ ኵሎ፡ ዘኮነ፡ ላዕለ፡ አቡሁ፡ ሖረ፡ ወበጽሐ፡ እንተ፡ ስማ፡ እፉር፡ ወኃደረ፡ ኀበ፡ መነኮስ፡ ኄር፡ ዘስሙ፡ ሳሙኤል።  <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="23r" to="34r" facs="025">Fols 23r–34r</locus>
                        <title>For Wednesday</title>
                        <incipit xml:lang="gez">ንግባእኬ፡ እንከሰ፡ ኀበ፡ ጥንተ፡ ነገር፡ ዘእሙ፡ ዘብህልናክሙ፡ በርእሰ፡ መጽሐፍ፡ ወኄር፡ ውናሃሰ፡ ብዙኃ፡ ድኅረ፡ ንነግረክሙ፡ ወባሕቱ፡ ናቀድም፡ ዘከመ፡ ነበረት፡ ውስተ፡ ዓለም፡ አብጻሕነ፡ ለክሙ፡ ህላዌሃ፡ ውስተ፡ ዓለም።  <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.4">
                        <locus from="34r" to="43r" facs="036">Fols 34r–43r</locus>
                        <title>For Thursday</title>
                        <incipit xml:lang="gez">ወእምድኅረዝ፡ መጽአ፡ ካልዕ፡ ዘይትቀሐወኒ፡ ወይቤለኒ፡ አነ፡ እቀድመከ፡ ቀዊመ፡ ቅድመ፡ እግዚአብሔር፡ ወዘእንበለ፡ አግብር፡ ሎቱ፡ ቃለ፡ መጽአ፡ ኀቤየ፡ እምዐውደ፡ መንበር፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus from="43r" to="51v" facs="045">Fols 43r–51v</locus>
                        <title>For Friday</title>
                        <incipit xml:lang="gez">ወከመዝ፡ ይብል፡ መጠነ፡ ፳ወ፫ ጊዜ፡ ወእምዝ፡ ይነብብ፡ በከመ፡ አንበቦ፡ መንፈስ፡ ቅዱስ፡ ወነገረ፡ ትንቢተሰ፡ ሀሎ፡ ውስተ፡ ካልእ፡ መጽሐፍ። ወይትጋብዑ፡ ብዙኃን፡ ቅዱሳን፡ እለሂ፡ እምሥራቅ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.6">
                        <locus from="52r" to="60v" facs="054">Fols 52r–60v</locus>
                        <title>For Saturday</title>
                        <incipit xml:lang="gez">ወበአሐዱ፡ እመዋዕል፡ ቦአ፡ አቡነ፡ ሀብተ፡ ማርያም፡ ለቅዳሴ፡ ቍርባን፡ ሚካኤል፡ ወገብርኤል፡ ወረዱ፡ ለተራድኦቱ፡ ማካኤል፡ ጸለሎ፡ በክነፊሁ፡ መልዕልተ፡ ርእሱ፡ ወገብርኤል፡ ኮነ፡ ይሰውቆ፡ እንዘ፡ ይነብብ፡ ወንጌለ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.7">
                        <locus from="60v" to="66r" facs="063">Fols 60v–66r</locus>
                        <title>For Sunday</title>
                        <incipit xml:lang="gez">ወካዕበ፡ ይቤሎ፡ እግዚእነ፡ ኦፍቁርየ፡ ሀብተ፡ ማርያም፡ ናሁ፡ በጽሐ፡ ፍልሰትከ፡ እምፃማ፡ ዕረፍት፡ ጊዜ፡ ገሚድ፡ በጽሐ፡ ወትፍሥሕት፡ ተሰፍሐ፡ ነአ፡ ረድ፡ ደብረ፡ ሊባኖስ፡ እመ፡ ትትቀበር፡ በህየ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                    </msItem>
                    <msItem xml:id="ms_i2">
                      <locus from="66v" to="71v" facs="069">Fols 66v–71v</locus>
                      <title>Image of Abuna Häbtä Maryam, <foreign xml:lang="gez">መልክአ፡ አቡነ፡ ሀብተ፡ ማርያም፡</foreign></title>
                      <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ አብ፡ እምቅድመ፡ ዓለማት፡ ዘሀሎ፡</incipit>
                      <note>written in a different hand</note>
                  </msItem>
               </msContents>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script"/>
                        <seg type="ink">Black; red (vermillion).</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ተዘ፡</abbr> for <expan>ተዘከር፡ </expan> (<locus target="#5r">5r</locus>)</item>
                           <item>
                              <abbr>ኦወ፡/ኦ፡ ወ፡</abbr> for <expan>ኦወልድየ፡ </expan> (e.g., <locus target="#6v">6v</locus>, 7v)</item>
                           <item>
                              <abbr>እም፡/እምህ፡</abbr> for <expan>እምህለከ፡ </expan> (e.g. <locus target="#7r">7r</locus>, 8r)</item>
                           <item>
                              <abbr>መ፡ ለ፡/መሐ፡ ለ፡</abbr> for <expan>መሐልኩ፡ ለኪ፡ </expan> (e.g., <locus target="#29v">29v</locus>, 30v, 31r, 32r)</item>
                           <item>
                              <abbr>መሐል፡</abbr> for <expan>መሐልኩ፡ ለኪ፡ </expan> (<locus target="#31r">31r</locus>)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra, two groups of lines on the incipit
                           page of Text I alternating with black lines; two lines on the incipit
                           page of Text II; the words täzäkkär, ʾamǝḥǝläkä, ʾǝmma-hi, mäḥalku or
                           their abbreviations in Text I, the initial letters of the word fäṣṣimo in
                           Text I; first word or initial letters of the first word of each
                           subsection in Text II; elements of the punctuation signs and Ethiopic
                           numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The words እግዚኦ፡ and እግዚአብሔር፡ are
                        usually written with ligature (e.g., <locus target="#3r">3r</locus>,
                        5r).</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#3r">3r</locus> (incipit page of Text I): coloured (vivid
                        vermilion, brilliant amber, outlined in black) ornamental band; interlaces,
                        geometric motifs.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- Tämälläs-sign, in the shape of a cross (+), indicating the place where the omission, written in the upper margin, belongs: <locus target="#12r">fol.  12r</locus>. - Omitted letters or words inserted interlineally: e.g., fols. 6v, 12r, 15r, 22r, 43r. - Erasure on <locus target="#30r">fol.  30r</locus>. - Immediate correction marked by thin lines above and below the letter: <locus target="#27r">fol.  27r</locus>. - Letters written in a secondary hand in blue pen over writing illegible due to humidity: e.g., fols. 31r, 33r, 34v, 36v, 40r. - Illegible notes in pencil on fols. 1r, 45r.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards. Three sewing stations.</decoNote>

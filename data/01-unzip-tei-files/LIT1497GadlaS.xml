               </t:ab>
            </t:div>
            <t:div type="textpart" subtype="explicit" xml:lang="gez">
               <t:ab>
                  ወአዕረፈሰ፡ አቡነ፡ ሳሙኤል፡ ከዊኖ፡ ወልደ፡ ፻ዓመት። ጸሎቱ፡ <t:gap reason="omitted"/> ወአሜን።
               </t:ab>

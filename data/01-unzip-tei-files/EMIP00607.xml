               <msContents>
                  <summary>Canticle of the Flower, ማሕሌተ፡ ጽጌ፡</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="83v" facs="003">Fols 2r–83v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                  <incipit xml:lang="gez">ጽጌ፡ አስተርአየ፡ ሠሪፆ፡ እም፡ አፅሙ፡
                  ለዘአምኃኪ፡ ጽጌ፡ ለገብርኤል፡ ምስለ፡ ሰላሙ፡
                  ወበእንተዝ፡ ማርያም፡ ሶበ፡ ኃወዘኒ፡ መዓዛ፡ ጣዕሙ፡
                  ለተአምርኪ፡ ጽጌ፡ አሃሊ፡ እሙ፡
                  ማኅሌተ፡ ጽጌ፡ ዘይሰመይ፡ ስሙ፡
                  </incipit>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>(<locus target="#4r #4v #5r #5v" facs="005 006 007">fols. 4r, 4v, 5r, 5v</locus> are written in a different hand on an inserted leaf), arranged for the days of the week. In each case a piece of thread has been sewn into the upper fore edge.
                </note>
                  <msItem xml:id="ms_i1.1"><locus from="2r" facs="003">Fols 2r and following</locus><title>Monday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="12v" facs="014">Fols 12v and following</locus><title>Tuesday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="25r" facs="026">Fols 25r and following</locus><title>Wednesday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="37r" facs="038">Fols 37r and following</locus><title>Thursday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="50v" facs="052">Fols 50v and following</locus><title>Friday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.6"><locus from="63r" facs="064">Fols 63r and following</locus><title>Saturday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.7"><locus from="73r" facs="074">Fols 73r and following</locus><title>Sunday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                </msItem>

      <t:body>
         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" xml:id="FethaNagastChapter38" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet122#ms_i1">
               <t:ab>
                                    
                  <t:title ref="https://betamasaheft.eu/LIT1395Fethan#Chapter38">Fǝtḥa nagaśt: Chapter 38: On exchanging</t:title>
                  
                  
                  
                  አንቀጽ፡ ፴ወ፯፡ በእንተ፡ ፍኖት፡ ወመራኅብት፡ ወአስኳት፡ ወሐድሶተ፡ ሕንፃ፡ ወሙሐዘ፡ ማያት፡ ወአፍላገ፡ ገዳማት፡ ዘተነግረ፡ በአብጥሊስ፡ ፴ወ፰፡ በእንተ፡ 
                  ሕንፃ፡ ዘባቲ፡ ሱቱፋን፤ ኢይከውኖ፡ ለ፩፡ <t:supplied reason="undefined" resp="PRS10747Zotenbe">እም</t:supplied>እለ፡ ይመልክዎሙ፡
                  ለአብያተ፡ ተሳትፎ፡ ከመ፡ ይሢም፡ ላዕሌሃ፡ ላዕካነ፡ ዘእንበለ፡ በምክረ፡ ቢጹ። ወሐፁርኒ፡ በተሳትፎ፡ ኢይከውኖ፡ ለ፩፡ ከመ፡ ይንስቶ፡ 
                  <t:supplied reason="undefined" resp="PRS10747Zotenbe">አው፡ ከመ፡ ይሕንጾ፡ ዘእንበለ፡ በምክረ፡ ሱታፌሁ፡ ወኢይደልዎ፡ ለ፩ሂ፡ ከመ፡ ይግበር፡ እቶነ፡</t:supplied>
                  አው፡ ምንዳደ፡ እሳት፡ በገቦ፡ ሐፁር፡ ዘተሳተፎ፡ ወዘይረ ክቦ፡ ኅሱመ፡ እምእሳት። ወለእመ፡ ገብረ፡ ፩፡ ምንዳደ፡ ዘየዓርግ፡ ጢሰ፡ ለአሕስሞቶሙ፡ ለእለ፡ ይነብሩ፡
                  ውስተ፡ አብያት፡ ልዑላት፡ ናሁ፡ አብሖሙ፡ ሕግ፡ ከመ፡ ይክልእዎሙ፡ ፈንዎተ፡ ጢስ፡ ላዕሌሆሙ፡ ዘእንበለ፡ ለእመ፡ ኮነ፡ ሎቱ፡ ክፍለ፡ ለፈንዎቱ። ወከማሁ፡
                  ኢይደልዎሙ፡ ለእለ፡ ይነብሩ፡ በማኅደር፡ ልዑላ<t:supplied resp="PRS10747Zotenbe" reason="undefined">ዊ</t:supplied>ት፡
                  ከመ፡ ይክዓው፡ ማየ፧ አው፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ዕፀዋተ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ዕዳዋተ፡</t:corr>
                  </t:choice> ለአስማተ፡  ሰብአ፡ አዕፃድ፡ እለ፡ ይነብሩ፡ በታሕቲሆሙ፡
                  <t:choice>
                     <t:sic resp="PRS10747Zotenbe">እለ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">አላ፡</t:corr>
                  </t:choice>
                  ይከልእዎሙ፡ ዘንተ። ኢይከውኖ፡ ለሰብእ፡ ከመ፡ ይግበር፡ ውስተ፡ ማኅደሩ፡ ዘይከውን፡ ኅሱመ፡ በአግዋሪሁ። ወከመዝ፡ ነገሩ፡ በምክረ፡ ኀሣር።
                  ወናሁ፡ ብውህ፡ ከመ፡ ያቅም፡ ሰብአ፡ ሰዋስወ፡ በገቦ፡ ዓረፍት፡ ነዊኅ፡ ለእመ፡ ኮነ፡ ኢይረክቦ፡ ኅሱም፡ ላዕለ፡ ዓረፍት። ወለመካን፡ ሐፂር፡ ኢይከውኖ፡
                  ለመኑሂ፡ ይክላእ፡ አንኆቶ። ወአኮ፡ ሠናይ፡ ከመ፡ ይክላእ፡ ፩፡ በጎረ፡ ዚአሁ፡ ከመ፡ ያርኁ፡ ሐሰተ፡ 
                  <t:supplied resp="PRS10747Zotenbe" reason="explanation">ኆኅተ፡</t:supplied> 
                  ዘይወስድ፡ ኀበ፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ውላጣይ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ውሳጣይ፡</t:corr>
                  </t:choice>
                  እንዘ፡ ኢየሐስም፡ ላዕለ፡ ፍኖት። <t:hi resp="PRS10747Zotenbe">ምዕራፍ፡</t:hi> በእንተ፡ ምጣኔ፡ ፍትሕ፡ ማእከለ፡ ሕንፃ፡ ወአትክልት። 
                  ወለእመ፡ ፈቀደ፡ ብእሲ፡ ይሕንጽ፡ ሐፁረ፡ ይርኀቅ፡ እምካልኡ፡ መጠነ፡ አሐቲ፡ ምስጋረ፡ እግር። ወለእመ፡ ቤት፡ ፯፡ ምስጋረ።
                  ወለእመ፡ ኮነ፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ግቡ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ግብ፡</t:corr>
                  </t:choice>
                  አው፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ስርየተ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ክርየተ፡</t:corr>
                  </t:choice>
                 በአምጣነ፡ ዕመቁ። ወለእመኒ፡ ዓዘቅት፡ ፭፡ ፩ባዕለ፡ ለእመ፡ ኢኮነ፡ ዘአግዋሪሁ፡ እምቀዲሙ፡ ወይትገኀሥ፡ እምዘ፡ ከመዝ፡ ግብር። 
                 ወለእመ፡ ዘይት፡ ዕፀ፡ አው፡ ዕፀ፡ በለስ፡ ፱፡ ሰኰና፡ እግር፡ ይርኀቅ፡ እምዕፀ፡ ካልእ፧ ወእምዝ፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ይትከሀል፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ይትክል፡</t:corr>
                  </t:choice>
                  <t:supplied reason="undefined" resp="PRS10747Zotenbe">
                     <t:gap reason="lost" extent="unknown"/>
                  </t:supplied>
                  ወለእመ፡ ኮነ፡ ዕፀ፡ በመርኅባ፡ ዓፀዱ፡ ለጎር፡ ወሰፍሐ፡ ስረዊሃ፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">እስመ፡</t:sic>
                     <t:corr resp="PRS10747Zotenbe"> እስከ፡</t:corr>
                  </t:choice>
                  መሠረቱ፡ ለሐፁር፡ ካልእ፡ <t:choice>
                     <t:sic resp="PRS10747Zotenbe">ወአሕሰመ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">ወአሕሰሞ፡</t:corr>
                  </t:choice>
                  ይደልዎ፡ ለመኰንን፡ ከመ፡ ይምትራ። ወለእመ፡ ኮነ፡ ፪፡ አብያት፡ ዘይትናጸሩ፡ ይኩን፡ ማእከሌሆሙ፡ መጠነ፡ ፲ወ፪፡ ሰኰና፡ እግር፡ ያቀውም፡
                  <t:choice>
                     <t:sic resp="PRS10747Zotenbe">መሠረተ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">እመሠረተ፡</t:corr>
                  </t:choice>
                  ሕንፃ፡ እስከ፡ ላዕሉ፡ በ፩፡ ህላዌ። ወለእመ፡ ኖኃ፡ ሕንፃ፡
                  <t:supplied resp="PRS10747Zotenbe" reason="undefined">ይደልዎ፡ ለ፩፡ ከመ፡ ያልዕል፡ እስከ፡ ፍጻሜ፡ ሕንፃሁ፡</t:supplied>
                  ወይግበር፡ ውስቴቱ፡ መስኮተ፡ ዘሐዲስ፡ ሕንፃ፡ አው፡ የሐድሶ፡ ለዘበልየ። ወለእመ፡ ተቃሥሦ፡ ፩፡ ብእሲ፡ በስፍሐ፡ ፲ወ፪፡ ሰኰና፡ እግር፡ ኢይከውን፡ 
                  ከመ፡ ይእትት፡ ምሕዋጸ፡ ጎሩ፡ ለእመ፡ ኮነ፡ ዘይሔውፅ፡ ኀበ፡ ባሕር፡ እመካን፡ ስፉሕ፡ 
                  <t:choice> 
                     <t:sic resp="PRS10747Zotenbe">እለ፡</t:sic> 
                     <t:corr resp="PRS10747Zotenbe">አላ፡</t:corr>
                  </t:choice>
                  ይከውኖ፡ ለዝንቱ፡ ከመ፡ የሐውፅ፡ ቀዊመ፡ አው፡ ነቢሮ፡</t:ab>
            </t:div>
         </t:div>
      </t:body>

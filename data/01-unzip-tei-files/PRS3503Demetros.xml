      <t:body>
         <t:listPerson>
            <t:person sex="1">
               
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ድሜጥሮስ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n1" type="normalized">Dǝmeṭros</t:persName>
               <t:persName type="alt">Demetrius</t:persName>
             
                  
                  <t:persName>
                  <t:roleName type="title">rās</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  <t:occupation type="political">governor</t:occupation>
           
               <t:floruit notBefore="1689" notAfter="1711">He was a governor of <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName> who apprehended a rebel 
                  who had sought refuge in 
                  <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName> among the Tulama <t:persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</t:persName>. He was
                  a confidant of 
                  <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">
                     <t:roleName type="title">ʾaṣe</t:roleName> ʾIyāsu I</t:persName>
                  helping a plan attacks on <t:persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</t:persName> and participating in his campaigns into 
                  <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName>. By the <t:date>1693</t:date>, he held the title of 
                  <t:persName ref="https://betamasaheft.eu/PRS3503Demetros">
                     <t:roleName type="title">ṣahafe lam</t:roleName>
                  </t:persName>; 
                  he was also <t:persName ref="https://betamasaheft.eu/PRS3503Demetros">
                     <t:roleName type="title">daǧǧāzmāč</t:roleName>
                  </t:persName>. By the end of the decade, however,  he had lost a favour at the court. But 
                  he had regained the governorship of <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName>, and from mid <t:date>1709</t:date> to mid 
                  <t:date>1711</t:date> he held the position of <t:persName ref="https://betamasaheft.eu/PRS3503Demetros">
                     <t:roleName type="title">rās</t:roleName>
                  </t:persName> under <t:persName ref="https://betamasaheft.eu/PRS9449Tewoflos">Tewoflos</t:persName>
                  </t:floruit>
                  
               </t:person>
               
         </t:listPerson>

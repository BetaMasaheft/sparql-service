                        <locus from="3r" to="3v" facs="0009">5-6</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer (general record)</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" extent="unknown"/> ህቡዕ፣ ስሙ፡ ለእግዚአብሔር፡ አስማተ፡ ኃይላት፡ ኢያኤል፡ አፍናኤል፡ አስናኤል፡ አትናኤል፡ ስንኰራኵኤል፡ ፍዳኤል፡ አፍናኤል፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ እቀቦ፡ ለግብርከ፡ <del rend="erasure"/></incipit>
                      </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="4r" to="26r" facs="0011">7-51</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">Hymn to Jesus Christ</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" extent="unknown"/> ጸሎት፡ በእንተ፡ ልሳነ፡ ሰብእ፡ ዘመድ፡ ወባዕድ፡ መቀኛ፡ ወተንኰለኛ፡ ቡዳ፡ ወእደ፡ ሰብእ። ናሁ፡ ተማኅፀንኩ፡ በኆኅያተ፡ ስምከ፡ ካፍ። ወበቀዳማይ፡ የውጣ፡ ዘጥንተ፡ ፊደሉ፡ አሌፍ፡ ከመ፡ ታድኅነኒ፡ ክርስቶስ፡ <gap reason="ellipsis" extent="unknown"/></incipit>
                        <explicit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ በዝንቱ፡ ኃይለ፡ መለኮትከ፡ አድኅነኒ፡ እምልሳነ፡ ሰብእ፡ ወቡዳ፡ ወመቀኛ፡ ወዓይነ፡ ሰብእ፡ ለገብርከ፡ <space/> ለዓለመ፡ ዓለም።</explicit>
                      </msItem>


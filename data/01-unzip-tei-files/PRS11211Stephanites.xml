      <t:body>
         <t:listPerson>
            <t:personGrp>
               <t:persName xml:lang="gez" xml:id="n1">ደቂቀ፡ እስጢፋ ፡</t:persName>
               <t:persName xml:lang="gez" type="normalized" corresp="#n1">daqiqa ʾƎsṭifā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2">ፀረ ፡ ማርያም፡</t:persName>
               <t:persName xml:lang="gez" type="normalized" corresp="#n2">ḍara Māryām</t:persName>
               <t:persName xml:lang="gez" xml:id="n3">ደቂቀ፡ እስጢፋኖስ ፡</t:persName>
               <t:persName xml:lang="gez" type="normalized" corresp="#n3">daqiqa ʾƎsṭifānos</t:persName>
               <t:persName xml:lang="en">Stephanites</t:persName>
               <t:occupation type="ecclesiastic"/>
               <t:faith type="Orthodox"/>
               <t:floruit notBefore="1400" precision="medium">The Stephanites or <t:foreign xml:lang="gez">daqiqa  ʾƎsṭifānos</t:foreign> were a religious movement 
                  within Ethiopian monasticism named after their
                  founder and spiritual leader 
                  <t:persName ref="https://betamasaheft.eu/PRS3894estifano">
                     <t:roleName type="title">ʾabbā</t:roleName> ʾƎsṭifānos</t:persName>. 
                  The movement rose to prominence in the 15th century and continued until the 16th century. 
                  They were persecuted under the order of 
                  
                  <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY"> 
                     <t:roleName type="title">ʾaṣe</t:roleName> Zarʾa Yāʿqob</t:persName>. 
                  The Stephanites contributed considerably to the literary production in medieval Ethiopia.
               </t:floruit>
            </t:personGrp>
            
         </t:listPerson>
         
         

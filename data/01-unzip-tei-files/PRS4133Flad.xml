      <body>
         <listPerson>
            <person sex="1" sameAs="Q93086916">
               <persName>
                  <t:forename>Johann</t:forename>
                     <t:forename>Martin</t:forename>
                  <t:surname>Flad</t:surname>
               </persName>
               <t:occupation type="ecclesiastic">missionary</t:occupation>
               <faith type="Protestantism"/>
               <t:birth when="1831"/>
               <t:floruit notBefore="1855" notAfter="1894"> He was one of the most prominent
                  Protestant missionaries to <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</placeName> in
                  the nineteenth century, making numerous trips there between 1855 and 1894 and
                  being among the captives at <placeName ref="https://betamasaheft.eu/LOC4547Maqdal">Maqdalā</placeName> freed by the
                     <persName ref="https://betamasaheft.eu/PRS7484Napier">Robert Cornelis Napier</persName> expedition. He was active in Bible work,
                  promotion of Christianity among <persName ref="https://betamasaheft.eu/ETH1274Betaes">
                 Beta ʾƎsrāʾel
               </persName> and,
                  occassionally, purchase of manuscripts. </t:floruit>
               <t:death when="1915"/>

            </person>
            
         </listPerson>

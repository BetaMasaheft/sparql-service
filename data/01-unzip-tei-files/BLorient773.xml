                    <msContents>
                        <summary/>
                      <msItem xml:id="ms_i1">
                        <locus from="2r"/>
                        <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan">The 12 homilies of Severus on
                        Christian doctrine</title>
                        <textLang mainLang="gez"/>

                        <msItem xml:id="ms_i1.1">
                          <locus from="2r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev1OnThreeNatures">On the three
                          natures of God and their Union</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ቀዳማይ፡ በእንተ፡ ፍካሬ፡ ፫ ህላዌሁ፡ ለእግዚአብሔር፡ ወተዋሕደቶሙ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus from="15v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev2OnIncarnation">On the
                          Incarnation of the Son and His Crucifixion</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ደግማይ፡ በእንተ፡ ከሢተ፡ ትስብእቱ፡ ለወልደ፡ እግዚአብሔር፡ ወስቅለቱ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                          <locus from="43v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev3OnPentateuch">On various passages
                          of the Pentateuch and Joshua, which demonstrate the glory of the Christian Faith</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ሣልሳይ፡ በእንተ፡ ትርጓሜ፡ ብዙኀ፡ ነገር፡ እምኦሪት፡ ወኢያሱ፡ ወልደ፡ ነዌ፡ ያጤይቅ፡ ክብረ፡
                          ሃይማኖተ፡ ክርስቲያን፡ ርትዕት።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.4">
                          <locus from="55v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev4OnPassover">On the Passover (the Lord's
                            Supper)</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ራብዕ፡ በእንተ፡ ከሢተ፡ ትርጓሜ፡ ፍሥሕ፡ ወበግዕ፡ ወእፎ፡ ይከውን፡ ኀብስት፡ ወወይን፡ ሥጋሁ፡
                          ወደሙ፡ ለክርስቶስ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.5">
                          <locus from="64v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev5OnDemons">On the Warring of Demons
                          against the Faithful, and how they may be conquered</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ኃምስ፡ በእንተ፡ ከሢተ፡ ፀብእ፡ ዘይፀብኡ፡ ቦቱ፡ ሰይጣናት፡ ለመሃይምናን፡ በእፎ፡
                          ይመውእዎሙ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.6">
                          <locus from="79v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev6OnSunday">On the Glory of the First Day
                            (Sunday)</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ሳድስ፡ በእንተ፡ ከሢተ፡ ክብሩ፡ ለዕለተ፡ እሑድ፡ ወፍጻሜሁ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.7">
                          <locus from="87v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev7OnWednesday">On the Fast of Wednesday and
                          Friday</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ሳብዕ፡ በእንተ፡ ከሢተ፡ ምክንያተ፡ ጾም፡ ፪ ዕለተ፡ ረቡዕ፡ ወዓርብ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.8">
                          <locus from="95v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev8OnFasting">On Fasting</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ሳምን፡ በእንተ፡ ከሢተ፡ ጾም፡ ምንት፡ ውእቱ፡ እፎ፡ ይደሉ፡ ከመ፡ ይኩን።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9">
                          <locus from="103v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev9OnDeath">On the Death which God
                          conquered on the Cross, and refutation of the opinion that an Angel had been appointed by God to slay men</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ታስዕ፡ በእንተ፡ ከሢተ፡ ውእቱ፡ ሞት፡ ዘሞአ፡ እግዚአብሔር፡ በዲበ፡ መስቀል፡ ወያበጥል፡ ቃሎ፡
                          ለዘይቤ፡ ከመ፡ ውእቱ፡ መልአክ፡ እምኀበ፡ እግዚአብሔር፡ ሥሩዕ፡ ያሙቶሙ፡ ለሰብእ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.10">
                          <locus from="114r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev10OnJacobiteFaith">On the Stability of the
                          orthodox Jacobite Faith, and on the other Faiths</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ዓሥር፡ በእንተ፡ ከሢተ፡ ጽንዓ፡ ሃይማኖት፡ ርትዕት፡ ያዕቆባዊት፡ ወይከሥት፡ ኲሉ፡ ሃይማኖት፡ ውሉጣት።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.11">
                          <locus from="125r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev11OnMoses">Exposition of the Songs
                          of Moses and of Miriam, of Pss. cxxxv. and cl., of the fourth Vision of Daniel,
                        and of the Song of the three holy Children</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ፲ወ፩ በእንተ፡ ትርጓሜ፡ ስብሐት፡ ሙሴ፡ ወማርያም፡ እኅተ፡ ሙሴ፡ ወመዝሙር፡ ዘ፻፴፭
                          ወዘ፻ወ፶ ወርእዩ፡ ራብዕ፡ ዘዳንኤል፡ ወስብሐተ፡ ፫ ደቂቅ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.12">
                          <locus from="141v"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1299Dersan#Sev12OnConsolation">On the Consolation
                          of Believers under afflictions</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ድርሳን፡ ዓሠርቱ፡ ወክልኤቱ፡ በእንተ፡ ኑዛዜ፡ መሃይምናን፡ ወትዕግሥቶሙ፡ ለእለ፡ ኅዘናት።</incipit>
                        </msItem>
                      </msItem>
                      <msItem xml:id="ms_i2">
                        <locus from="148r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4974Prayer">Concerning the prayer of Longinus</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          ጸሐፍነ፡ በእንተ፡ ጸሎቱ፡ ለለንጊኖስ፡ ቅዱስ። <gap reason="ellipsis"/>
                          ወበውእቱ፡ መዋዕል፡ ኮነ፡ ፈነወ፡ ንጉሥ፡ መርቅያኖስ፡ ዘእምታሕቴሁ፡ ኀበ፡ እለ፡ እስክንድርያ፡ መልእክተ፡ ጦማረ፡ ልዮን፡ ዓላዊ።
                          ወአዘዘ፡ ከመ፡ ይግበሩ፡ ፈቃደ፡ ሀገረ፡ እለ፡ እስክንድርያ። ወፈድፋደሰ፡ መነኮሳት፡ እለ፡ ይነብሩ፡ ውስተ፡ ደብረ፡ ማኅው። ወከሠተ፡
                          እግዚአብሔር፡ ዘንተ፡ ግብረ፡ ለአብ፡ ቅዱስ፡ አባ፡ ለንጊኖስ፡ እምቅድመ፡ ፫ አውራኅ። ወአዘዘ፡ ከመ፡ ይትጋብኡ፡ ኲሎሙ፡
                          መነኮሳት፡ ዘደብረ፡ ማህው፡ በእንተ፡ ራእይ፡ ዘተከሥተ፡ ሎቱ፡ ከመ፡ ይንግሮሙ፡ ዘይብውን። ወይኤዝዞሙ፡ ከመ፡ ኢይትዌከፉ፡
                          ውእቱ፡ ጦማረ፡ ርኩሰ፡ ፍጹመ። ወኢይኅበሩ፡ ምንትኒ፡ እምነገር፡ ዘውስተ፡ ውእቱ፡ ጦማር፡ ምኑን። ወእምዝ፡ አስተጋብኦሙ፡ አቡነ፡
                          ቅዱስ፡ አባ፡ ለንጊኖስ፡ ለኲሎሙ፡ እለ፡ የኃድሩ፡ ውስተ፡ ደብረ፡ ማኅው፡ ወዜነዎሙ፡ ዘአቅደመ፡ እግዚእ። ወዜነዎ፡ ቦቱ፡ በራእይ፡
                          ወአዘዞሙ፡ ከመ፡ ይዕቀቡ፡ ትእዛዛተ፡ እግዚእ፡ ዘበጸናዔ፡ ወከመ፡ ይትጋደሉ፡ ላዕለ፡ ሃይማኖተ፡ ክርስቲያን፡ እስከ፡ ለሞት፤
                        </incipit>
                      </msItem>
                      <msItem xml:id="ms_i3">
                        <locus from="150v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4826GadlaBa">Gadla ʾabuna māri ʾabbā Barsomā</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">እጽሕፍ፡ ገድለ፡ አቡነ፡ ቅዱስ፡ ማሪ፡ አባ፡ በርሶማ፡ ሶርያዊ፡ ዘደብረ፡ በስሙል።</incipit>
                      </msItem>
                      <msItem xml:id="ms_i4">
                        <locus from="164r"/>
                        <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT4975Dersan">Homily of Cyril of Jerusalem
                        on St Simeon receiving our Lord</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">አመ፡ ሰሙነ፡ እምነ፡ ወርኃ፡ የካቲት። ድርሳን፡ ዘደረሰ፡ ቅዱስ፡ ጌርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘኢየሩሳሌም፡
                        ዘከመ፡ ተወክፎ፡ ስምዖን፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወጾሮ፡ ኪያሁ፡ ላዕለ፡ መዝራዕቱ፡ ወአዖዶ፡ ኀበ፡ ምሥዋዕ፡ በከመ፡ ልማደ፡ ሕግ።
                      ይቤ፡ ጥንተ፡ ነገሩ፡ ተፈሥሒ፡ ፈድፋደ፡ ኦወለተ፡ ጽዮን፡ ወስብኪ፡ ኃሤተ፡ ኦወለተ፡ ኢየሩሳሌም፡ ተጋብኡ፡ ኀቡረ፡ እለ፡ ትነብሩ፡ ሀገረ፡
                    እግዚአብሔር። አንቀልቀለት፡ ምድር፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i5">
                        <locus from="167r"/>
                        <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1804Lifeof">
                          <certainty locus="value" match="../@ref" cert="low"/>
                            The Life of Severus of Antioch,
                         by one Athanasius</title>
                         <textLang mainLang="gez"/>
                         <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis"/> ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወበሠናይ፡
                         ሥርዓቱ፡ ጽሒፈ፡ ዘተረክበ፡ እመነ፡ ገድሉ፡ ለአብ፡ ክቡረ፡ ሳዊሮስ፡ ሊቀ፡ ጳጳሳት፡ ዘአንጾኪያ፡ ዘተጋደለ፡ በእንተ፡ ሃይማኖት፡

                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="5v" to="96v">5v-96v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0152IHA">رائحة الجنة بشرح اضاءة الدجنة</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله الرحمن الرحيم الحمد لله الذي أضاء جنة الشرك بنور التوحيد واضاع ا جنة الحفر بفساد الحمل والتوليد
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#96v">-96v</locus>وان يطلق بنا وباخواننا المسلمين والمسلمات والمؤمنين والمؤمنات الى وقت الممات ويحفظ لنا من الخطاء والخطل في القول والأعتقاد والعمل وان يجعلنا من اهل رضوانه وينعمنا وسائر اخواننا في دار جنانه بمنه وكرمه وجوده امين وصلى الله وسلم على سيدنا محمد وعلى اله واصحابه والتابعين الى يوم الدين
</explicit>
                     <note>Some of the words are divided into two different lines
</note>
                     <note/>
                  </msItem>

<msItem xml:id="ms_i2.1">
<locus from="136r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">To Michael</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስም፡ ልዑል፡ ዘተሳተፈ። ወልደ፡ ያሬድ፡ ሄኖክ፡ በከመ፡ ጸሐፈ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.2">
<locus from="144r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2849RepCh131">To Raphael</title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ተጸውዖ፡ ዘቀደመ። በአፈ፡ አምላክ፡ አዳም፡ እንበለ፡ ይሰመይ፡ ስመ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.3">
<locus from="149r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">To Gabriel</title>
<incipit xml:lang="gez">በሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአዕረፈ። ከመ፡ እዜኑ፡ ኅዳጠ፡ ወአኮ፡ ትሩፈ።</incipit>
<textLang mainLang="gez"/>
</msItem>


      <body>
         <listPerson>
            <person sex="2">
               <persName xml:lang="gez" xml:id="n1" type="birth">መለኮታዊት፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Malakotāwit</persName>
               <persName>
                  <roleName type="title">ʾǝtege</roleName>
               </persName>
                 
                  
                  <occupation type="political">queen</occupation>
                  
               <floruit notBefore="1658" notAfter="1708">She was one of the concubines of the <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</persName>  
                  and the mother of his son and successor <persName ref="https://betamasaheft.eu/PRS9152TaklaHa">Takla Hāymānot I</persName>. She craved for power and wanted to take her chance 
                  when  <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</persName> abdicated and <persName ref="https://betamasaheft.eu/PRS9152TaklaHa">Takla Hāymānot I</persName> assumed power. 
                  Thus, she organized the assassination of <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</persName>
                  by the hand of her brother <persName ref="https://betamasaheft.eu/PRS3530Dermen">Dǝrmǝn</persName>in <date>1706</date>. 
               </floruit>
               <death when="1708">she was hanged on a pole in the central square of <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName>. </death>
                  
               </person>
               
         </listPerson>
         
         
         

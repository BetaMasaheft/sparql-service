                  <msContents>
                     <summary/>
                     <msItem xml:id="p2_i1">
                        <locus from="5r" to="7r"/>
                        <title type="complete">A short text concerning Incarnation, in Amharic</title>                              
                        <textLang mainLang="am"/>
                        <incipit xml:lang="am">ከ፫አካላት፡ ማን፡ ሥጋ፡ <add place="margin">ነስቶ</add>ለበሰ፡ ትለኝ፡ እንደ፡ ሆን፡ አካለ፡ ወልድ፡ ከ፪ተለይቶ፡ <add place="margin">ን</add>
                           አንሶን<add place="interlinear">ም</add>፡ ተዋርዶን<add place="interlinear">ም</add>፡ ኅፃን፡ ወጽቶበትን<add place="margin">n</add>፡ አይደለውም፡</incipit>
                        <note>In the beginning the text shows some slight similarity to 
                           <ref type="work" corresp="https://betamasaheft.eu/LIT1097Ammest#Incarnation">Five Pillars of Mystery: Mystery of Incarnation</ref>.</note>
                     </msItem>
                        
                        <msItem xml:id="p2_i2">
                        <locus from="7r" to="8v"/>
                           <title type="complete">A short text concerning Trinity, in Amharic</title>                                        
                           <textLang mainLang="am"/>
                           <incipit xml:lang="gez"><add place="interlinear">አደሩ፡ ሶስቱም፡ ሶስቱም፡</add>
                              ሶስቱም፡ አነፁ፡ አዋሐዱ፡ አደሩ፡ ብል፡ የአክል፡ ኀድረት፡ አይደለውም፡ አብ፡ ለማጽናት፡ መንፈስ፡ ቅዱስ፡ ለማንፃት፡ ነው፡ እንጂ፡ ንጽሕና፡ ማለት፡ ምንድር፡ ነው፡ ትለኝ፡ እንደ፡ ሆነ፡</incipit>
                        </msItem>                                            
                                                      

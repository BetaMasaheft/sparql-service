                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="15v" facs="0002"/>
                     <title type="incomplete">Collection of excerpts from the <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur">Psalms</ref>
                     </title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="11v" facs="0002"/>
                        <title type="incomplete">Readings on the word <foreign xml:lang="gez">ቃል፡</foreign>
                        </title>
                        <incipit xml:lang="gez">
                           ቦ፡ ነበበ፡ ዘኢተሰም<orig>...</orig>ሙ፨ ከመ፡ 
                              <sic>እስመዕ፡</sic>
                            
                           <supplied reason="lost">ቃለ፡</supplied> 
                           <supplied reason="lost">ስ</supplied>ብሐቲከ፡ ስምዓኒ፡ እ<supplied reason="lost">ግዚኦ፡</supplied> ቃልየ፡ ዘሰአልኩ፡ ኃቤከ፡ ስምዓኒ፡ እግዚኦ፡ ቃልየ፡ 
                           ዘፀራሕኩ፨ ሐቤከ፨
                        </incipit>
                        <note>The beginning is missing. The section of the readings containing the word <foreign xml:lang="gez">ቃል፡</foreign> terminates on 
                           <locus target="#5v" facs="0007"/> with the words: <q xml:lang="gez">ወበቃለ፡ እግዚአብሔር፡ ጸንዓ፡ ሰማያት፨</q>. Then follow the readings on the action of God on the 
                           mankind. This section begins without division signs, as follows: <q xml:lang="gez">እግዚአብሔር፡ ይመይጥ፡ ምክሮሙ፡ ለሕዝቡ፨ እግዚአብሔር፡ የዓቅብ፡ 
                              
                                 <sic>ኩሉ፡</sic>
                               አዕጽምቲሆሙ፨</q>.</note>
                        <explicit xml:lang="gez">
                           <locus target="#11v" facs="0014"/>
                           እስመ፡ አኮ፡ በመስፈርት፡ ዘይሁብ፡ እግዚአብሔ፨ አቅሞ፡ ለገብርከ፡ ዘነበበ፡ ውስተ፡ 
                              <sic>ነቢበከ፨</sic>
                            
                           <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           
                              <sic>ምለእ፡</sic>
                            
                           <supplied reason="omitted">አ</supplied>ፉየ፡ ስብሐቲከ፡ ከመ፡ 
                              <sic>እሴብሕ፡</sic>
                            
                           
                              <sic>እከቴትከ፨</sic>
                            ለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="11v" to="14r" facs="0014"/>
                        <title type="complete">Readings in which Jerusalem is quoted</title>
                        <incipit xml:lang="gez">
                           በጽዮን፡ በደብረ፡ መቅደስ፨ ከመ፡ እን<supplied reason="omitted">ግ</supplied>ር፡ 
                              <sic>ትእዘዞ፡</sic>
                            ለእግዚአብሔር፡ በቅድመ፡ 
                           
                              <sic>ኩሉ፡</sic>
                            ሕዝብ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ከመ፡ ጠለ፡ እርሞንኤም፡ ዘይወርድ፡ ዲበ፡ 
                              <sic>አድበረ፡</sic>
                            ጽዮን፨ ለትዕርግ፡ ስእለትየ፡ ቅድሜከ፡ ከመ፡ ጽንሐሐ፡ 
                              <sic>ቁርበን።</sic>
                            
                           ወከመ፡ 
                              <sic>መዓዘ፡</sic>
                            
                           
                              <sic>ዕጠን፡</sic>
                            
                           
                              <sic>ዘሱረፌል፡</sic>
                            ሊተ፡ 
                           ለገብ<supplied reason="omitted">ር</supplied>ከ፡ ያዕቆብ፡ 
                              <sic>ወታክለ፡</sic>
                            ማርያም፨ አሜን፨ 
                        </explicit>
                        <note>The owner of the book, <persName role="owner" ref="https://betamasaheft.eu/PRS11228Yaeqob">Yāʿqob</persName> or Takla Māryām, is mentioned in the 
                           supplication formula at the end of the section.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="14r" to="15v" facs="0018"/>
                        <title type="complete">Prayer for the enlightment of the spirit</title>
                        <incipit xml:lang="gez">
                           ይኩን፡ በእንተ፡ 
                              <sic>ሥገሁ፡</sic>
                            ቅዱስ፡ ሕብስተ፡ <supplied reason="lost">አምልኮ፡</supplied> 
                           <supplied reason="lost">ር</supplied>ሱን፨ ወበእንተ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           ደሙ፡ ክቡር፡ ወይነ፡ አምልኮ፡ አክራጦን፨ እስመ፡ አንተ፡ 
                              <sic>ተበርህ፡</sic>
                            
                           
                              <sic>መሀቶትየ፡</sic>
                            እግዚኦ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ዘገብረ፡ ብርሃናት፡ ዐበይተ፨
                        </explicit>
                        </msItem>

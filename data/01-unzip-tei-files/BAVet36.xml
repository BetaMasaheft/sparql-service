                  <msItem xml:id="ms_i3">
                     <locus from="16v" to="46v" facs="0022"/>
                     <title>Prayers and readings for the Pentecost</title>
                     <incipit xml:lang="gez">
                        
                           <sic>ዘ<add place="inline">
                                 <supplied reason="omitted">እም</supplied>
                              </add>ስኖዶስ፡</sic>
                         
                        
                           <sic>ቀድሕ፡</sic>
                         
                        ወእንዘ፡ ይነግሮሙ፡ ጴጥሮስ፡ ዘንተ፡ ወናሁ፡ ሰምዑ፡ ድምፀ፡ ከመ፡ 
                           <sic>ደምጽ፡</sic>
                         
                        
                           <sic>ነፈስ፡</sic>
                         ወዓውሎ፨ 
                        
                           <sic>ወአጼነዎ፡</sic>
                         ጼና፡ ጥዑም፡ 
                           <sic>ዘኢይአምሩ፡</sic>
                         በውስተ፡ ዓለም፨ ወአስተርአየ፡ ማእከሎሙ፨ ልሳናት፨ 
                        
                           <sic>ዘእሰት፡</sic>
                         ዘይወርድ፡ ላዕለ፡ ፩፩፡ እምኔሆሙ፨ ወአሐዙ፡ 
                           <sic>ይትነገሩ፡</sic>
                         
                        
                           <sic>በልሰን፡</sic>
                         
                        ኃዲስ፨ 
                           <sic>ከመሁ፡</sic>
                         ክስት፡ 
                           <sic>ለግብርከ፡</sic>
                         ያዕቆብ፡ 
                           <sic>ወታክለ፡</sic>
                         ማርያም፡
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#46v" facs="0060"/>
                        ይኩን፡  
                           <sic>ከመሁ፡</sic>
                         ይኩን፡  
                           <sic>ለዕለ፡</sic>
                         ገብርከ፡ ያዕቆብ፡ ወተክለ፡ ማርያም፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን።
                     </explicit>
                     <note>The name of <persName role="owner" ref="https://betamasaheft.eu/PRS11228Yaeqob">Yāʿqob</persName> or Takla Māryām is mentioned in the supplication formulas at 
                        the beginning and at the end of the text.</note>

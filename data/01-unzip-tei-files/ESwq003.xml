                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Very irregular.</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Late 19th century – early 20th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ፍ፡ ረ፡ ለ፡ በ፡ በ፡</abbr> for <expan>ፍቱሕ፡ ረስዮ፡ ለዝንቱ፡ በድን፡ በአፈ፡
                              </expan> (e.g. 13rb, 13vab)</item>
                           <item>
                              <abbr>ይ፡ ሕ፡</abbr> for <expan>ይበሉ፡ ሕዝብ፡ </expan> (e.g., <locus target="#22rb">22rb</locus>, 98rab)</item>
                           <item>
                              <abbr>ይ፡ ዲ፡</abbr> for <expan>ይበል፡ ዲያቆን፡ </expan> (e.g., <locus target="#22rb">22rb</locus>, 98rb)</item>
                           <item>
                              <abbr>ይ፡ ካ፡</abbr> for <expan>ይበል፡ ካሕን፡ </expan> (e.g., <locus target="#22rb">22rb</locus>, 38ra)</item>
                           <item>
                              <abbr>ን፡ እ፡ ወ፡ በ፡</abbr> for <expan>ንስእለከ፡ እግዚኦ፡ ወናስተበቍዓከ፡ በእንተ፡
                              </expan> (e.g., <locus target="#91va">91va</locus>b, 92vab)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; the names of the donors; a few lines
                           on the incipit page of the Text, alternating with black lines; incipit of
                           each section of the text; names of Hebrew letters in Ps. 118 (e.g., fols.
                           20vb, 23ra); abbreviations; elements of Ethiopic numerals; elements of
                           the punctuation signs and text dividers; some other words, e.g.,
                           wa-yǝbälu (e.g., fols. 10rb, 12ra), qǝdmä wängel (e.g., fols. 17ra,
                           25ra), wa-kāʿǝba (e.g., fols. 22ra, 23va), ṣällǝyu (e.g., fols. 25vb,
                           27ra), ʾǝgäle (e.g., fols. 79ra, 90va), wa-ʾǝmzǝ (e.g., fol. 91ra).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Some vowel markers and left and right
                        pointing elements have forked
                        shapes.</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#4r">4r</locus> (incipit page of the Text): uncoloured
                        ornamental band; anthropomorphic motifs (face).</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Coloured threads have been inserted in the upper
                              corner or in the outer margin of fols. 34, 37, 53, 64, 70, 78, 93,
                              98.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Erasures: fols. 25rab, 89rb. - Corrections written over erasures: fols. 21ra, 29vb. - Omitted letters or words written interlineally: e.g., fols. 9rb, 10rb, 25ra, 47vb, 72rb. - Scribbles and doodles: e.g., fols. 14v, 15r, 18r, 18v, 20r.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards (both broken and repaired). Two
                           pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible on the spine fold
                           of the quires close to the head and tail of the codex.</decoNote>
                     </binding>
                  </bindingDesc>

                            <additions>
                                <list>
                                    <item xml:id="a2">
                                        <desc type="ScribalSupplication"/>
                                        <locus from="41r" to="41v"/>
                                        <q xml:lang="gez">ዘንተ፡ መጽሐፈ፡ አጥረዩ፡ አባ፡ <persName role="patron" ref="https://betamasaheft.eu/PRS14418Nob">ኖብ፡</persName>
                                                ወ<persName role="scribe" ref="https://betamasaheft.eu/PRS14573HaraKrestos">ሐራ፡ ክርስቶስ፡ </persName> ይኩኖሙ፡ ተዝካረ፡ እስከ፡ ለዓለም፡ ወመርሐ፡
                                            ለመንግሥተ፡ ሰማያት፡ አሜን። ዘንተ፡ መጽሐፈ፡ ዘጸሐፎ፡ ወዘአጽሐፎ፡ ወለ፡ ዘአንበቦ፡
                                            ወለዘተርጐሞ፡ ወዘሰምዐ፡ ቃላቲሁ፡ ይምሐሮሙ፡ እግዚአብሔር፡ ወይስረይ፡ ኃጢአቶሙ፡
                                            በጸሎታ፡ ለማርያም፡ እመ፡ ብርሃን። ወበጸሎቶሙ፡ ለሩፋኤል፡ ወመልከጼዴቅ፡ ወይክፍለነ፡
                                            ምቅዋመ፡ በሐዳስ፡ ንድቅ፡ እግዚአብሔር፡ እግዚእ፡ መኰንነ፡ ጽድቅ፡ ለዓለመ፡ ዓለም፡
                                            አሜን፡ ወአሜን።</q>
                                    </item>

                                    <item xml:id="a3">
                                        <desc type="ScribalSupplication"/>
                                        <locus target="#55r"/>
                                        <q xml:lang="gez">ዛቲ፡ መጽሐፍ፡ ዘጸሐውክዋ፡ አነ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS14573HaraKrestos">ሐራ፡

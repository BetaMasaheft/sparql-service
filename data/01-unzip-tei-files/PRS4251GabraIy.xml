                  <persName ref="https://betamasaheft.eu/PRS8595SayfaAr">
                     <roleName type="title">ʾaṣe</roleName> Sayfa ʾArʿad</persName> and 
                 
                  <persName ref="https://betamasaheft.eu/PRS3429DawitII"> 
                     <roleName type="title">ʾaṣe</roleName> Dāwit II</persName>.
                  He received his monastic habit from<persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭatewos</persName>.</floruit>
                  
               </person>  
               

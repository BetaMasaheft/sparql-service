                        <msItem xml:id="ms_i1">
                          <locus from="4r" to="77r"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2715John">ብስራተ፡ አብ፡ ቅዱስ፡ ትሩፍ፡ ረድእ፡ ተናጋረ፡ በመለኮት፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡</title>
                          <textLang mainLang="gez"/>
                          <note> The text is divided according to week days. The name of the last owner <persName role="owner" ref="https://betamasaheft.eu/PRS12681WaldaT">Walda Tǝnśāʾe</persName> is
                          mentioned on <locus target="#77r #77v"/>, it is written twice over the name of the previous owner <persName role="owner" ref="https://betamasaheft.eu/PRS12682GabraH">Gabra Ḥǝywat</persName>.
                          The name of the scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS12683WaldaG">Walda Gabrǝʾel</persName> is mentioned on <locus target="#77r"/>.
                          </note>
                        </msItem>

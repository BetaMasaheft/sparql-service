         <t:listPerson>
            <t:person sex="1">
               <t:persName>
                  
                  <t:forename>Jacques</t:forename>
                  <t:surname>Faitlovitch</t:surname> 
               </t:persName>
               
               <t:occupation type="academic">scholar</t:occupation>
               <t:nationality type="Poland"/>
               <t:faith type="notSpecified"/>
               <t:birth when="1881"/>
               <t:floruit notBefore="1904" notAfter="1955">He was a scholar and activist on behalf of <t:persName ref="https://betamasaheft.eu/ETH1274Betaes">ቤተ፡ እስራኤል፡</t:persName>. 
                  He studied Oriental languages in <t:placeName ref="https://www.wikidata.org/entity/Q142">France</t:placeName> under <t:persName ref="https://betamasaheft.eu/PRS5012Halevy">Joseph Halévy</t:persName>
                  who stimulated his interest on <t:persName ref="https://betamasaheft.eu/ETH1274Betaes">ቤተ፡ እስራኤል፡</t:persName>.   </t:floruit>             
                  <t:death when="1955">He died at <t:placeName ref="https://www.wikidata.org/entity/Q33935">Tel Aviv</t:placeName> in <t:date>1955</t:date>. </t:death>
            </t:person>
            
         </t:listPerson>
         
         

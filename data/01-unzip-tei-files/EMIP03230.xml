                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is rubricated</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#139v" facs="140">Fol. 139v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#140r" facs="140">Fol. 140r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, with two guardian angels</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#140v" facs="141">Fol. 140v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1092SacrificeIsaac">The Sacrifice of Isaac</ref> with captions <q><foreign xml:lang="gez">ዘከመ፡ ሦአ፡ አብርሃም፡ ይስሐቅሃ።</foreign> How Abraham sacrificed Isaac, and <foreign xml:lang="gez">ዘከመ፡ ወረደ፡ በግ[..]፡ቤዛ ይስሐቅ</foreign> How the Ram came down for a substitute for Isaac</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#142r" facs="142">Fol. 142r</locus><desc>Jacab’s Ladder with caption <q>How Jacob saw the ladder on the road to Luz, which is the type of Our Lady</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#141v" facs="142">Fol. 141v</locus><desc>Table (11 x 13 boxes) for calculating the feast days of the year</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Despite the label on the inside cover, the Weiner collection number should be 458 and not 455
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title> begin with opening prayer from the Canticle of the Virgin
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#51v" facs="052">Fol. 51v</locus>
                    <desc>
                    Marks the midpoint of the Psalms in a very unique way, with a small portrait of a saint in a box in the right margin, next to the midpoint strophe
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps118">Psalms of
                                                  David, Psalmus 118</title> employs the new, simple system
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps150">Psalms of
                                                  David, Psalmus 150</title> and the tenth biblical canticle have the columetric rubrication
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps151">Psalms of
                                                  David, Psalmus 151</title> has all four of the elements that make up the long version
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    Fourth <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title> is Prayer of Hana, mother of Samuel, prophet
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title> begin on Monday
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

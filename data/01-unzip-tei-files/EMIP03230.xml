               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="1r" to="139r" facs="001">Fols 1r–139r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="1r" to="106v" facs="001">Fols 1r–106v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="107r" to="118v" facs="107">Fols 107r–118v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Fifteen Biblical Canticles</note>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="118v" to="124v" facs="119">Fols 118v–124v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>common edition</note>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="125r" to="135r" facs="125">Fols 125r–135r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="135r" to="139r" facs="135">Fols 135r–139r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>the last three lines were added in red ink in the lower margin</note>
                  </msItem>
                </msItem>
               </msContents>

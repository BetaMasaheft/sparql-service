                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7255Secrets">Prayer and prescription for receiving a revelation of secret
          things (partly Amharic)</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ አብ፡ ዘኢይትገሠሥ፡ እሳት፡ ወበስመ፡ እግዚአብሔር፡ ወልድ፡ ዘያደነግፅ፡ <sic>መብርቅ፡</sic> ወበስመ፡ እግዚአብሔር፡
                                መንፈስ፡ ቅዱስ፡ <sic>ዘያውዔ፡</sic> ዕንቈ፡ ባሕርይ፡ ብርሃነ፡ ታዴስ፡ ፯ጊዜ፡ አኔዎስ፡ ፫ጊዜ፡ <gap reason="ellipsis"/> በዝአስማት፡ ክሥት፡ ሊተ፡</incipit>
                            <explicit xml:lang="gez"><expan><abbr>ለገ</abbr><ex>ብርከ</ex></expan>፡ 
                                <expan><abbr> እገ</abbr><ex>ሌ</ex></expan>። ቀለምሲስ፡ ዮሐንስ፡ ወንጌል፡ እምጥንቱ፡ እስከ፡ ተፍጻሜቱ፡ በአውጥ፡ ቅፀል፡ ጸሒፈከ፡ 
                                በዕፍራን፡ ቀለም፡ ለአጽንየ፡ በሐዲስ፡ ቆባ፡ ማር፡ ፯ቀን፡ ድግም፡ በዘኢያገድፍ፡ በጥቁር፡ ገብስ፡ ድፍድፍ፡ ፯ቀን፡ ድቅም።</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7259Mestir">Prayer and prescription for receiving a revelation of secret
          things</title>
                            <note>Possibly the continuation of <ref target="#ms_i1"/>.</note>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ በል፡ ጸሎት፡ በእንተ፡ ምስጢር፡ አድፍኤል፡ ፯ <expan><abbr>ጊ</abbr><ex>ዜ</ex></expan>፡ 
                                ወጢሙር፡ ፯ <expan><abbr>ጊ</abbr><ex>ዜ</ex></expan>፡</incipit>
                            <explicit xml:lang="gez">ክሥት፡ ለገብርከ፡ እገሌ፡ ምስለ፡ ጸሎተ፡ ኤፍሬም፡ ወዓምደ፡ ብርሃን፡ በ፵፱ዘቢብ፡ በስም፡ ጽዋዕ፡ ፯ቀን፡ ድግም፡ ለንባብ፡ በሽንብራ፡ ቂጣ፡
                                ጽሒፈከ፡ በነጭ፡ ዶሮ፡ መረቅ፡ ፈትፍተሕ፡ አብልዖ፡ ለሕፃን።</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4005Salota">Prayer against hail</title>
                            <note>With the addition of ʾasmāt in the incipit and considerably shorter in the end as in
                                <ref type="mss" corresp="https://betamasaheft.eu/EMIP02338#a1">Portland, Ethiopic Manuscript Imaging Project, Weiner Codex 306, fol. ir</ref>
                                and <ref type="mss" corresp="https://betamasaheft.eu/EMIP00447#ms_i12">Portland, Ethiopic Manuscript Imaging Project, Kaleab Addis Project 47, fols 94v-95r </ref>.</note>
                            <incipit xml:lang="gez">በስመ<supplied reason="omitted">፡</supplied> አብ፡ በል፡ ጸሎተ፡ በረድ፡ ምስማኤል፡ ምምኤል፡</incipit>
                            <explicit xml:lang="gez">ኢታውርድ፡ በረደ፡ ዘእንበለ፡ ጽሩይ፡ ማይ፡ በሃገረ፡ <expan><abbr>እገ</abbr><ex>ሌ</ex></expan>፡</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7260PPKumael">Prayer for terrifying devils</title>
                            <incipit xml:lang="gez">ኩማኤል፡ ፫ጊዜ፡ ኽኤል፡ ፫ <expan><abbr>ጊ</abbr><ex>ዜ</ex></expan>፡ ውርዝያል፡ ሠነገ፡ ባሕር፡ 
                                ዘትትሜሰል፡ ሰብእ፡ ምስለ፡ ሰብእ፡ ነዓ፡ ኀቤየ፡ መደንግፀ፡ ጋኔን፡ ለአነ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7261PPThieves">Prayer against thieves</title>
                            <incipit xml:lang="gez"> በስመ፡ አብ፡ በል፡ ያቁም፡ ያፍዝዝ፡ ወያደንግዝ፡ እስር፡ ወከንትር፡ ለሌባ፡ ማሽ፡ ከመ፡ ኢይግባዕ፡ እምቤተ፡ እገሌ፡ ዕብነ፡ ኃይል፡ ዕብነ፡ 
                                አቤኔዜር፡</incipit>
                            <explicit xml:lang="gez">ከማሁ፡ እስሮሙ፡ ለሌባ፡ ወለቀመኛ፡ ወለጉድጓድ፡ ማሽ፡ ከመ፡ ኢይግባዕ፡ እምቤተ፡ እገሌ፡ ወኢይንሣእ፡ ንዋይየ፡ ወጥሪትየ፡ 
                                <expan><abbr>ለገ</abbr><ex>ብረ</ex></expan>፡ <expan><abbr> እገ</abbr><ex>ሌ</ex></expan>፡</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7256PPAndarabbi">Ba-sǝma Sayṭān wǝluda (!) Qǝrṭǝṭāʾel Maržiži</title>
                            <incipit xml:lang="gez"> በስመ፡ ሰይጣን፡ ውሉደ፡ ቅርጥጣኤል፡ መርዢዢ፡ <gap reason="ellipsis"/> ለዝሰይጣን፡ ወለዝ፡ አንደረቢ፡ ለዝ፡ ጋኔን፡ 
                                ወለዝ፡ ብእሲ፡ ዘርዝር፡</incipit>
                            <explicit xml:id="gez">አስተፃብዖ፡ በእብን፡ ምስለ፡ ዕብን፡ ሑር፡ ብሎ፡ ቅትሎ፡ አውዕዮ፡ በእሳት፡ ጌት፡ ዘባሕር፡ ዕብን፡ ጸሊም፡ ግበር፡</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7257Lightning">Prayer for producing lightning and thunder when it is
          raining</title>
                            <incipit xml:lang="gez">ፍልጵስዮስ፡ ዮስጳታ፡ <gap reason="ellipsis"/> ያውርድ፡ መብረቀ፡ በጊዜ፡ ዝናም፡ ይትነሣእ፡ ወከመ፡ መብረቅ፡ ያንጉድጕድ፡ 
                                በገበያ፡ በቤት፡ በጉረቤት፡ በዲለት፡ <expan><abbr>ለገ</abbr><ex>ብረ</ex></expan>፡ 
                                <expan><abbr> እገ</abbr><ex>ሌ</ex></expan>፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7267PrHarm">Prayer to harm somebody</title>
                            <incipit xml:lang="gez">ያስኤርር፡ ፯ጊዜ፡ መልዕልተ፡ ልቡ፡ አንገፍግፍ፡ ልቡ፡ አንቀጥቅጥ፡ ልቡ፡ ኅሊናሁ፡ ወዕፁ፡ ጕርዔሁ፡</incipit>
                            <explicit xml:lang="gez">ከመ፡ አድግ፡ ይትራገፁ፡ ወከመ፡ ቶራ፡ ይትራወፁ፡ <expan><abbr>ለገ</abbr><ex>ብረ</ex></expan>፡ 
                                <expan><abbr> እገ</abbr><ex>ሌ</ex></expan>። ለዓመትከ፡ እገሊት<supplied reason="omitted">።</supplied></explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7273PPEntering">Prayer against entering the house</title>
                            <incipit xml:lang="gez">የአዩ፡ አልአዚነ፡</incipit>
                            <explicit xml:lang="gez">አግብኦ፡ ወመልሶ፡ <expan><abbr>ለገ</abbr><ex>ብረ</ex></expan>፡ እገሌ፡ 
                                ውስተ፡ ቤተ፡ <expan><abbr> እገ</abbr><ex>ሌ</ex></expan>፡</explicit>
                            <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>

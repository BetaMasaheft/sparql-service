               <msContents>
                  <summary/>
                     
                     <msItem xml:id="ms_i1">
                        <locus from="2r">Fols 2r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                        <textLang mainLang="gez"/>
                        <notatedMusic>
                           <desc>Profuse musical notation.</desc>
                        </notatedMusic>
                        <note>The manuscript seems to be largely identical with <ref type="mss" corresp="https://betamasaheft.eu/BLorient585">London, British Library, BL Oriental 585</ref>, but contains apparently many hymns not found
                           in <ref type="mss" corresp="https://betamasaheft.eu/BLadd16195">London, British Library, BL Additional 16195</ref> and <ref type="mss" corresp="https://betamasaheft.eu/BLorient585">London, British Library, BL Oriental 585</ref>.</note>
                        
                        <msItem xml:id="ms_i1.1">
                           <locus target="#2r">Fol. 2r</locus>
                           <title type="complete">Introductory notes</title>
                           <textLang mainLang="gez"/>
                           <note>The introductory notes, extending over the larger part of <locus target="#2r">fol. 2r</locus>,
                              also reveal the date of this manuscript, the 12th year of the reign of <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas I</persName>, 
                       <date>1767</date>.</note> 
                          
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2">
                           <locus target="#67r">Fol. 67r</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Haleta">Table of Halleluyahs</title>
                           <textLang mainLang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.3">
                           <locus from="120r">Fols 120r and following</locus>
                           <title type="complete">Second part of the Dǝggʷā</title>
                           <textLang mainLang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.4">
                           <locus target="#183r">Fol. 183r</locus>
                           <title type="complete">Table of Halleluyahs</title>
                           <textLang mainLang="gez"/>
                        </msItem>
                        
                     </msItem>
                  </msContents>
                     

                           <locus target="#89r">-89r</locus>
                           <q xml:lang="ar">كمل النصف بحمد الله</q>
                           <note/>
                        </item>
                        <item xml:id="a7_5197">
                           <locus target="#168v">-168v</locus>
                           <q xml:lang="ar">ختم [شعبان؟] ٢١ سنه ه ١٣٩٩</q>
                           <note>The note is pasted on the page. The text is written with blue ball-point pen.</note>
                           <note/>
                        </item>

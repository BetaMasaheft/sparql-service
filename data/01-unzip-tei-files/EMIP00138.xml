                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                    <seg type="rubrication">
                      <ref target="#ms_i1.4 #ms_i1.5"/>
                      <foreign xml:lang="gez">እግዚአብሔር፡</foreign>
                      <ref target="#ms_i1.4 #ms_i1.5"/>
                      <foreign xml:lang="gez">ማርያም፡</foreign>
                      <desc>Columetric layout of text: <locus target="#110v #111r" facs="115">fols. 110v, 111r</locus> <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps150"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps150</span></ref>;
                      <locus target="#119v #120r" facs="124">119v, 120r</locus> <ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa#ThreeYouths3"><span xmlns="" class="w3-tag w3-red">No item: LIT1566hababa#ThreeYouths3</span></ref></desc>
                    </seg>
                    </handNote>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ወሃቢ፡ እምዕለ፡ መዝገቡ፡ ፍጡነ፨</l>
                  <l n="2">ለጽሙማን፡ አእዛነ፡ ወለበሐማን፡ ልሳነ፨</l>
                  <l n="3">አባ፡ ምልአኒ፡ ዘመንፈስ፡ ቅዱስ፡ ኪነ፨</l>
                  <l n="4">ዘመልክእከ፡ ውዳሴ፡ እንተ፡ አኀዝኩ፡ ወጢነ፨</l>
                  <l n="5">ለፈጽሞቱ፡ ኢይኩን፡ ስኡነ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሐዋዝ፡ ጣዕሙ፨</l>
                  <l n="2">እመዐዛ፡ ጽጌ፡ ዘኮል፡ ወለአስካለ፡ ወይን፡ እመ፡ ደሙ፨</l>
                  <l n="3">ሠርጸ፡ ጴጥሮስ፡ ንጹሕ፡ ሱታፌ፡ መላእክት፡ ኵሎሙ፨</l>
                  <l n="4">ተበሀሉ፡ በእንቲአከ፡ ነቢያተ፡ እስራኤል፡ ቀዲሙ፨</l>
                  <l n="5">ዕፍረተ፡ መዐዛ፡ ቅድው፡ ዘትሰውጠ፡ ስሙ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለማዕተበ፡ እዴከ፡ ለአንጽሖ፡ ሕማም፡ ወለምጽ፨</l>
                  <l n="2">እንተ፡ እምኔሁ፡ ተክዕወ፡ ሐፈ፡ ተአምር፡ ወራኅፅ፨</l>
                  <l n="3">ሠርጸ፡ ጴጥሮስ፡ ፀሓይ፡ ጽዱለ፡ መልክእ፡ ወገጽ፨</l>
                  <l n="4">በትርከ፡ ይቅሥፍ፡ እድዋንየ፡ ወመስቀልከ፡ ዘዕፅ፨</l>
                  <l n="5">አምሳለ፡ አሕዛብ፡ ተቀሥፈ፡ ወኀልቁ፡ በግብጽ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ አፅምከ፡ እንተ፡ አውረደ፡ እሳተ፨</l>
                  <l n="2">በቤተ፡ ብእሲ፡ መነኮስ፡ ዘተቀብሎቶ፡ አስተተ፨</l>
                  <l n="3">ሠርጸ፡ ጴጥሮስ፡ ዕጉሥ፡ በእንተ፡ ጽድቅ፡ ሰደተ፨</l>
                  <l n="4">መኑ፡ ከማከ፡ መምህርየ፡ እንዘ፡ ይገብር፡ ኀይላተ፨</l>
                  <l n="5">በአፅሙ፡ እምድኅረ፡ ሞት፡ ዘኮነ፡ ሰማዕተ፨</l>
               </lg>
               <lg type="stanza" n="55">
                  <l n="1">ለፊላታዎስ፡ ብፁዕ፡ እንዘ፡ ፍናዊሁ፡ ይተሉ፨</l>
                  <l n="2">ወየሐውር፡ ዘልፈ፡ ለሚካኤል፡ በፍና፡ ሣህሉ፨</l>
                  <l n="3">ሶበ፡ እምዓለም፡ አዕረፈ፡ ሠርጸ፡ ጴጥሮስ፡ መምህረ፡ ኵሉ፨</l>
                  <l n="4">እነግር፡ ጽድቀ፡ ዘርኢኩ፡ በዘይረትዕ፡ ወይደሉ፨</l>
                  <l n="5">እወ፡ እወ፡ ማየ፡ አንብዕ፡ አውሐዘ፡ መስቀሉ፨</l>
               </lg>
            </div>
         </div>
      </body>

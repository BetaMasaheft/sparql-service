                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#18r" facs="021">Fol. 18r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref>and <persName ref="https://betamasaheft.eu/PRS12861Daratewos">Darātewos</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#26v" facs="030">Fol. 26v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref> and the three youths in the fiery furnace</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#34v" facs="038">Fol. 34v</locus><desc>A poor man holding a knife and fish. Corresponds to the miracle on the facing page</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#40v" facs="044">Fol. 40v</locus><desc><persName ref="https://betamasaheft.eu/PRS8469Samson">Samson</persName> killed the Philistines by the jawbone of a donkey. This is a modern interpretation with Samson and the Philistines also carrying rifles.</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#58v" facs="062">Fol. 58v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref> and Bäläʿam the magician</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#67v" facs="071">Fol. 67v</locus><desc>An image of a miracle of the archangel Michael. A woman sleeps under a tree next to a mesob. A man with a sword stands over her</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#72r" facs="075">Fol. 72r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref> rescuing <persName ref="https://betamasaheft.eu/PRS3337Daniel">Daniel</persName> in the lionsʾ den</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#86v" facs="090">Fol. 86v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref> spears a demon while ʾÄfomya stands nearby</desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#93r" facs="096">Fol. 93r</locus><desc><persName ref="https://betamasaheft.eu/PRS5330Hezekiah">
                  Hezekiah
               </persName> and <ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#98r" facs="101">Fol. 98r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref>and <persName ref="https://betamasaheft.eu/PRS3175Constant">
                  Constantine I
               </persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#104r" facs="107">Fol. 104r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1077ArchangelMichael"><span xmlns="" class="w3-tag w3-red">No item: AT1077ArchangelMichael</span></ref>ends <persName ref="https://betamasaheft.eu/PRS5584Isaiah">Isaiah</persName> the prophet</desc></decoNote>
                    <decoNote type="miniature" xml:id="d12"><locus target="#111r" facs="114">Fol. 111r</locus><desc><persName ref="https://betamasaheft.eu/PRS8478Samuel">Samuel</persName> the prophet anoints <persName ref="https://betamasaheft.eu/PRS3417David">David</persName></desc></decoNote>
                    <decoNote type="frame" xml:id="d13">
                      Decorative designs:
                      <locus target="#1r #17v #18v #27r #35r #40r #41r #68r #72v #87r #93v #97v #98v #103v #110v" facs="004 021 022 030 038 043 044 071 076 090 097 101 102 107 114">fols. 1r, 17v, 18v, 27r, 35r, 40r, 41r, 68r, 72v, 87r, 93v, 97v, 98v, 103v, 110v</locus> (ornamental band);
                      lines of alternating red and black dots as well as multiple full stops are used as section dividers throughout</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc>Likely produced in the government scriptorium</desc></item>
                      <item xml:id="e2"><desc><locus target="#ir #iv #iir #iiv #iiir #iiiv #25v #26r #86r #111v #112r #112v #113r #113v #114r #114v #115r #115v #116r #116v #117r #117v #118r #118v" facs="001 002 003 004 029 089 115 116 117 118 119 120 121">Fols. ir, iv, iir, iiv, iiir, iiiv, 25v, 26r, 86r, 111v, 112r, 112v, 113r, 113v, 114r, 114v, 115r, 115v, 116r, 116v, 117r, 117v, 118r, 118v</locus> blank</desc></item>
                      <item xml:id="a1"><desc><locus target="#4r" facs="007">f. 4r and passim</locus> the name Satan, <foreign xml:lang="gez">ሰይጣን፡</foreign> is written upside down</desc></item>
                      <item xml:id="e3"><desc><locus target="#5r" facs="008">f. 5r and passim</locus> space for the name of the owner is often left blank</desc></item>
                      <item xml:id="a2"><desc type="ScribalSignature"><locus target="#17r" facs="020">f. 17r and passim</locus> mention the scribe Wäldä ʾIyasus, <foreign xml:lang="gez">ወልደ፡ ኢያሱስ፡</foreign></desc></item>
                      <item xml:id="a3"><desc><locus target="#17v" facs="021">Fol. 17v</locus> mentions Wäldä ʾIyasus <foreign xml:lang="gez">ወልደ፡ ኢያሱስ፡</foreign> and the soul of his father Wäldä Giyorgis <foreign xml:lang="gez">ወልደ፡ ጊዮርጊስ፡</foreign></desc></item>
                      <item xml:id="a4"><desc type="OwnershipNote"><locus target="#23v" facs="027">Fol. 23v</locus> mentions an owner (?), Wäldä Sänbät <foreign xml:lang="gez">ወልደ፡ ሰንበት፡</foreign></desc></item>
                      <item xml:id="a5"><desc><locus target="#63v" facs="067">f. 63v and passim</locus> the word devil <foreign xml:lang="gez">ዲያብሎስ፡</foreign> is written upside down</desc></item>
                      <item xml:id="a6"><desc><locus target="#85v">Fol. 85v</locus> a prayer to establish ʾAskalä Maryam <foreign xml:lang="gez">አስካለ፡ ማርያም፡</foreign>, whose regnal name was <persName ref="https://betamasaheft.eu/PRS10671Zawditu">Zawditu</persName> over the kingdom of <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</persName></desc></item>
                      <item xml:id="a7"><desc type="ScribalSignature"><locus target="#97v">Fol. 97v</locus> mentions the given name of the scribe, Wäldä ʾIyasus ʾIyaqem <foreign xml:lang="gez">ወልደ፡ ኢየሱስ፡ ኢያቄም፡</foreign>, and also the soul of his father Wäldä Giyorgis <foreign xml:lang="gez">ወልደ፡ ጊዮርጊስ፡</foreign></desc></item>
                      <item xml:id="e4"><desc>Scribal intervention: words of text are written interlinearly (ff. 2v, 3r, 6v, 30r, 54v, etc.); text has been removed (ff. 6v, 41v, 43r, 63v, 80v, etc.)</desc></item>
                    </list></additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with tooled leather, rebound in disorder, fabric visible between the turn-ins, headband and tailband visible.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                        <material key="textile"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1916" notAfter="1930"><locus target="#85v" facs="086">Fol. 85v</locus> mentions ’Äskalä Maryam, whose regnal name was Zäwditu.</origDate>
                  </origin>
               </history>
            </msDesc>

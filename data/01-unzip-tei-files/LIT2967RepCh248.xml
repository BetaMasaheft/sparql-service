         <t:div type="edition" xml:lang="gez">
            <t:div type="textpart" xml:id="malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">በሰማይ፡ ወበምድር፡ አልብየ፡ ባዕደ፨</t:l>
                  <t:l n="2">አበ፡ ወእመ፡ እኅተ፡ ወውሉደ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ እትአመነኪ፡ ገሀደ፨</t:l>
                  <t:l n="4">ኪያኪ፡ ተስፋ፡ ኪያኪ፡ መፍቅደ፨</t:l>
                  <t:l n="5">ኪያኪ፡ ዐውቀ፡ ኪያኪ፡ ዘመደ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">በሰማይ፡ ወበምድር፡ እንዘ፡ ሀሎክኒ፡ ረድኤተ፨</t:l>
                  <t:l n="2">ምንትኑ፡ ያፈርሀኒ፡ ሊተ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ እትአመነኪ፡ ክሡተ፨</t:l>
                  <t:l n="4">ኪያኪ፡ ልዕልና፡ ኪያኪ፡ ሢመተ፨</t:l>
                  <t:l n="5">ኪያኪ፡ ርስተ፡ ኪያኪ፡ አብያተ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="12">
                  <t:l n="1">አልብየ፡ እመ፡ በኵሉ፡ መዋዕል፨</t:l>
                  <t:l n="2">ስምዕየ፡ ሊተ፡ እግዚአብሔር፡ ልዑል፨</t:l>
                  <t:l n="3">እትአመነኪ፡ ፈድፋደ፡ ማርያም፡ ድንግል፨</t:l>
                  <t:l n="4">ፍቅርኪ፡ ጽሙና፡ ፍቅርኪ፡ ገድል፨</t:l>
                  <t:l n="5">ፍቅርኪ፡ ትርሲት፡ ፍቅርኪ፡ አክሊል፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="13">
                  <t:l n="1">ኢትኅድግኒ፡ ዐቂበ፡ ኵሎ፡ መዐልተ፡ ወሌሊተ፨</t:l>
                  <t:l n="2">ኀበ፡ ሖርኩ፡ በፍና፡ ወኀበ፡ ኀደርኩ፡ ቤተ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘትመግቢ፡ ነፍሳተ፨</t:l>
                  <t:l n="4">በልብስ፡ ወበሲሳይ፡ ኢታርእይኒ፡ ንዴተ፨</t:l>
                  <t:l n="5">እስመ፡ ቍር፡ ወርኀብ፡ ያረስዕ፡ ጸሎተ፨</t:l>
               </t:lg>
            </t:div>
         </t:div>
         
      </t:body>

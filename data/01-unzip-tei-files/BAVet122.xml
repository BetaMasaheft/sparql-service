                     <msItem xml:id="ms_i1.1">
                        <locus from="5r" to="9r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">ኪዳን፡ ዘነግህ፡</title>
                        <incipit xml:lang="gez">
                           ንወጥን፡ በረድኤተ፡ <choice><sic>እግዚአብሒር፡</sic><corr resp="bm:GrebTiss1935Codices">እግዚአብሔር፡</corr></choice> ጽሒፈ፡ 
                           <sic>ቅደሴ፡</sic> በ፮ ይእቲ፡ ማርያም፡ እምነ፡ በ፨ ይትፌሣሕ፡ ልብኪ፡ በል፨ እግዚኦ፡ መሐ<supplied reason="explanation">ረነ</supplied>፡ ክርስቶስ፡ በል፡ 
                           ፱ ጊዜ፡
                        </incipit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="9r" to="11r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</title>
                        <note>
                           The prayer for the offerers is omitted.
                        </note>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.3">
                        <locus from="11v" to="15r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2605Zayena">Za-yǝnaggǝś</title>
                        
                        <incipit xml:lang="gez">
                           ንዜከር፡ ዘይነግሥ፡ ዘአቡነ፡ ያሬድ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ዘዓይን፡ ኢርዕየ፨ ወዕዝን፡ ኢሰምዓ፡ ውስተ፡ ልበ፡ ሰብእ፡ ዘኢተሀለየ፡ ወጠነ፡ አስተዳሎከ፡ አንተ፡ እግዚአብሔር፡ ለእለ፡ ያፈቅሩከ፡ መናህየ፡ ወመናዝዘ፡
                           ለሰብኦሙ፡ ፈኑ፡ ከዊነ፡ ክፍል፡ በ፩ ወልድከ፡ ዘቦቱ፡ ለከ፡ በል፨ 
                        </explicit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.4">

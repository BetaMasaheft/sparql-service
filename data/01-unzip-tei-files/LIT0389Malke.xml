         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አሐዱ፡ አምላክ፡ ሠራዒ፨፨</l>
                  <l n="2">ሥነ፡ ሠርጐ፡ ሰማይ፡ ወምድር፡ ወስእለተ፡ ኵሉ፡ ሰማዒ፨</l>
                  <l n="3">መልአከ፡ ዑቃቤ፡ ዘትሬኢ፡ ወዘኢታስተርኢ፨</l>
                  <l n="4">ይትመላህ፡ ቅድመ፡ ገጽየ፡ ሰይፈ፡ እዴከ፡ በላዒ፨</l>
                  <l n="5">ዘንተ፡ ርእዮ፡ ለይኅፍር፡ ጸላኢ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለተፈጥሮትከ፡ ከመ፡ ነገረ፡ ቃለ፡ መጽሐፍ፨</l>
                  <l n="2">ዘኢይትነገር፡ ኩነቱ፡ ወክዋኔሁ፡ ዘዘልፍ፨</l>
                  <l n="3">መልአከ፡ ዑቃቤየ፡ አጽድል፡ ገጸ፡ ዚአየ፡ በክንፍ፨</l>
                  <l n="4">ከመ፡ በብርሃን፡ አጽደለ፡ ሥነ፡ ገጸ፡ ሙሴ፡ ግዙፍ፨</l>
                  <l n="5">እስከ፡ ነጽሮቶ፡ ኢክህሉ፡ እስራኤል፡ አእላፍ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ድሉል፨</l>
                  <l n="2">ወለርእስከ፡ ሰላም፡ ተቀጻሊ፡ ብሩህ፡ አክሊል፨</l>
                  <l n="3">መልአከ፡ ዑቃቤየ፡ ነዓ፡ እንዘ፡ ትረውጽ፡ በኀይል፨</l>
                  <l n="4">አመሐልኩከ፡ በጸሎታ፡ ለማርያም፡ ድንግል፨</l>
                  <l n="5">ከመ፡ ትዕቀበኒ፡ እመንሱት፡ ወሀጕል፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለአጻብዒከ፡ ወለአጽፋሪከ፡ ጽዕድዋን፨</l>
                  <l n="2">ወለቆምከ፡ ዓዲ፡ ሠናየ፡ መልክእ፡ ወሥን፨</l>
                  <l n="3">መልአከ፡ ዑቃቤ፡ ምስሌየ፡ እንዘ፡ ትቀውም፡ በይምን፨</l>
                  <l n="4">አብሰረኒ፡ ብስራተ፡ ጽድቅ፡ እንተ፡ አልቦቱ፡ ኀዘን፨</l>
                  <l n="5">ለዘካርያስ፡ ከመ፡ አብሰርኮ፡ ብስራተ፡ በእዝን፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ ለመልክእከ፡ ክሡተ፨</l>
                  <l n="2">ለለ፡ አሐዱ፡ አሐዱ፡ እንዘ፡ አተሉ፡ ክልኤተ፨</l>
                  <l n="3">መልአከ፡ ዑቃቤየ፡ ነዓ፡ እንዘ፡ ትተሉ፡ ድኅሪተ፨</l>
                  <l n="4">ወኢትትፈለጥ፡ እምኔየ፡ መዓልተ፡ ወሌሊተ፨</l>
                  <l n="5">አምጣነ፡ ምክሕየ፡ ወተስፋየ፡ አንተ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ከመ፡ ጠለ፡ አርሞንኤም፡ ዘይወርድ፡ እምአድባረ፡ ጽዮን፡ ላዕላዊት፨</l>
                  <l n="2">ጠለ፡ ፍቅረ፡ ዚአየ፡ ይረድ፡ ዲበ፡ ልበ፡ ኵሉ፡ ፍጥረት፨</l>
                  <l n="3">መልአከ፡ ዑቃቤ፡ ቅብአኒ፡ ቅብአ፡ ቀርነ፡ ሐዋዝ፡ ዕፍረት፨</l>
                  <l n="4">በከመ፡ ቀብኦ፡ ሳሙኤል፡ ሊቀ፡ ካህናት፨</l>
                  <l n="5">ቅብአ፡ ፯ቱ፡ ሀብታት፡ ለንጉሥ፡ ዳዊት፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
                    <history>
                        <origin>
                            <origDate notBefore="1380" notAfter="1450">1380-1450</origDate>
                            <note>According to <bibl corresp="http://zotero.org/groups/358366/items/RSEA4WPK"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1978BritishLibrary"/><title level="m">Catalogue of Ethiopian Manuscripts in the British Library acquired since the Year 1877</title><author><forename>Stefan</forename><surname>Strelcyn</surname></author><pubPlace>London</pubPlace><publisher>British Museum</publisher><date>1978</date><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note><citedRange unit="page">53-55</citedRange></bibl> from the 15th century, according to <bibl corresp="http://zotero.org/groups/358366/items/QH84X4T8"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:KarlssonEtAl2023Handlist"/><title level="a">A Handlist of Illustrated Early Solomonic Manuscripts in British Public Collections</title><title level="j">Aethiopica</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Jonas</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Karlsson</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Jacopo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Gnisci</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Sophia</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dege-Müller</t:surname></author><date>2023</date><biblScope unit="volume">26</biblScope><biblScope unit="page">159-225</biblScope><note type="url">https://journals.sub.uni-hamburg.de/aethiopica/article/view/2106</note><citedRange unit="page">209</citedRange></bibl> from <date notBefore="1380" notAfter="1450">1380-1450</date>
                                based on palaeography and visual evidence.</note>
                        </origin>
                        <provenance>The name of the owner was <persName role="owner" ref="https://betamasaheft.eu/PRS14396Hezqeel">Ḥǝzqǝʾel</persName>
                            as indicated on several folios (cf. <locus target="#88v #90r"/>) where it was partly erased as well as by the presence of
                            <ref target="#d4">the miniature of his patron saint</ref>. 
                            The name of the scribe was <persName role="scribe" ref="https://betamasaheft.eu/PRS14395Abunafer">ʾAbunāfǝr</persName> as 
                            indicated by <ref target="#d8">the miniature of his patron saint</ref>. 
                            On <locus target="#119r"/> two other persons are named together with 
                            <persName role="scribe" ref="https://betamasaheft.eu/PRS14395Abunafer">ʾAbunāfǝr</persName>:
                            <persName ref="https://betamasaheft.eu/PRS14397GabraIyasus">Gabra ʾIyāsus</persName>
                            and <persName ref="https://betamasaheft.eu/PRS14398Zakaryas">Zakāryās</persName>.
                            This manuscript came to Great Britain via Italy, as shown by notes written in what 
                            <persName ref="https://betamasaheft.eu/PRS8999Strelcyn">Stefan Strelcyn</persName> calls "Italianate Latin" (cf. <ref target="#e2 #e3 #e4 #e5 #e6"/>). 
                            They indicate that the manuscript was in <placeName ref="https://betamasaheft.eu/LOC4963Naples">Naples</placeName> in <date when="1618">1618</date> and
                            belonged to <persName role="owner" ref="https://betamasaheft.eu/PRS14394PersioVitale">Doctor Persio Vitale</persName>.
                        </provenance>
                    </history>

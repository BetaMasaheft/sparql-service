                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                        <desc>
                           <locus target="#20r #20v #21r #21v" facs="022 023 024">Fols. 20r, 20v, 21r, 21v</locus> columentric layout of the Trinitarian Formula
                         </desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/>
                        </desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d2">
                        <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref> surrounded by the Holy Trinity</desc>
                     </decoNote>
                     <decoNote type="frame" xml:id="d3">
                       Decorative designs:
                       <locus target="#1r #50v" facs="003 053">folss. 1r, 50v, </locus> (haräg);
                       <locus target="#20r" facs="022">20r</locus> (multiple full stops)
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#50r #50v" facs="052 053">Fols. 50r, 50v</locus>
                           <desc type="Asmat">
                              Asmat prayer against fear and nightmare, <foreign xml:lang="gez">ጸሎተ፡ ድንጋፄ፡ Here called ጸሎት፡ በእንተ፡ ድንናጋዝ፡</foreign>, written in a later hand
                            </desc>
                        </item>
                        <item xml:id="e1">
                          ‎<locus target="#iv(erso)" facs="002">fol. iv(erso)</locus>
                          <desc type="OwnershipNote">Notes of secondary ownership, written in pencil and in ‎red ink in the upper margin</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#iiv(erso)" facs="002">Fol. iiv(erso)</locus>
                           <desc>
                              blank
                            </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#1v" facs="003"> f. 1v and passim</locus>
                           <desc type="OwnershipNote">
                              the name of the owner is Gäbrä Śǝllase. Secondary owners are also named, Gäbrä Maryam and Wäldä Täklä
                            </desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#3v #4r" facs="006">Fols. 3v, 4r</locus>
                           <desc>
                              mentions <persName ref="https://betamasaheft.eu/PRS3259CyrilV">Cyril V</persName> and <persName ref="https://betamasaheft.eu/PRS6876Matewos">Mātewos X</persName>
                           </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>
                             Identified in the insurance hand list as Liturgical 9
                           </desc>
                        </item>
                        <item xml:id="e4">
                           <desc>
                             Numbered quires: quire 5
                           </desc>
                        </item>
                        <item xml:id="e5">
                          <locus target="#19v #22v" facs="022 025">Fols. 19v, 22v</locus>
                           <desc>
                            words of text are written interlinearly
                          </desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with a double-pocket fabric cover.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="textile"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

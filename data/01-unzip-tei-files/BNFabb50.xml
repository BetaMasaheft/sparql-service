                                <locus from="110v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#FirstPart">Lǝfāfa ṣǝdq, First part: revelation of the powerful names of Jesus</title>
                                <textLang mainLang="gez"/>
                            </msItem>

                            <msItem xml:id="ms_i4.2">
                                <locus from="111v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#SecondPart">Lǝfāfa ṣǝdq,  SecondPart</title>
                                <textLang mainLang="gez"/>

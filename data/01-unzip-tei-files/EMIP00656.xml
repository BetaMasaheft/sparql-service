               <msContents>
                  <summary>Andǝmta to Faith of the Fathers: Text (Gǝ‘ǝz) and Commentary (Amharic), Haymanotä Abaw, ሃይማኖተ፡ አበው፡, Part Two</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="150v" facs="003">Fols 1r–150v</locus>
                    <title>&gt;Text (Gǝ‘ǝz) and Commentary (Amharic), Haymanotä Abaw, <foreign xml:lang="gez">ሃይማኖተ፡ አበው፡</foreign>, Part Two</title>
                    <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz and Amharic</textLang>

                    <msItem xml:id="ms_i1.1">
                      <locus from="1r" to="121r" facs="003">Fols 1r–121r</locus>
                      <title>Commentary on The Homilies of the Fathers, (beginning with chapter 50 of Haymanotä Abaw), section two</title>
                      <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz and Amharic</textLang>
                    </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="121r" to="135v" facs="123">Fols 121r–135v</locus>
                    <title>Anathemas</title>
                    <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz and Amharic</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="135v" to="150v" facs="138">Fols 135v–150v</locus>
                    <title>Commentary on The Testimony of the Fathers on the Incarnation</title>
                    <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz and Amharic</textLang>
                  </msItem>

                  <colophon xml:id="coloph1">
                  <locus target="#151r" facs="153">Fol. 151r</locus>
                  Copied by Taräqäñ Gälanäh, native of Gondar, baptismal name Gäbrä Ǝgzi’abǝher.
                  <q>I began the copying of this book on Mayazia 1,
                  1957 EC and finished it on Genbot 13, 1958 EC</q>
                </colophon>

                </msItem>
               </msContents>

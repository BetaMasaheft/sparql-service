        <body>
            <div type="bibliography">
                
                <listBibl type="editions">                    
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>
            </div>
            <div type="edition" xml:lang="gez">
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">ጐሥዐ፡ ልብየ፡ ቃለ፡ ማሕሌት፡ ወይባቤ፨</l>
                        <l n="2">ከመ፡ ድኁኃን፡ አድባር፡ እለ፡ ደብረ፡ ከርቤ፨</l>
                        <l n="3">ሰማዕተ፡ ጰራቅሊጦስ፡ ጻድቃን፡ ሐውጹኒ፡ በከርሠ፡ ኑቤ፨</l>
                        <l n="4">ከመ፡ እቤ፡ ለለ፡ ሶቤ፤ ርድኡኒ፡ እምንዳቤ፨</l>
                        <l n="5">ከመ፡ ታዕርፉኒ፡ ሊተ፡ ኀበ፡ ቦ፡ ይባቤ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ዘርአ፡ ገራህቱ፡ ቅድስት፡ ከመ፡ ዘይሴፎ፡ ሐረሳዊ፨</l>
                        <l n="2">እንዘ፡ ይትዔገስ፡ ጸኒሐ፡ በጊዜ፡ ማእረር፡ እስከ፡ ትሰዊ፨</l>
                        <l n="3">እሴፈወክሙ፡ አንሰ፡ ሰማዕተ፡ ጰራቅሊጦስ፡ ማሕየዊ፨</l>
                        <l n="4">በረከትክሙ፡ ሀቡኒ፡ ሰማያዊ፨</l>
                        <l n="5">ከመ፡ ባረኮ፡ ያዕቆብ፡ ለሌዊ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለልደትክሙ፡ እምቤተ፡ ክህነት፡ ወመንግሥት፨</l>
                        <l n="2">እስራኤላውያን፡ ዘይት፨</l>
                        <l n="3">ሰማዕተ፡ ጰራቅሊጦስ፡ ጻድቃን፡ ዘለለ፡ ዕለት፡ ወዓመት፨</l>
                        <l n="4">ሀቡኒ፡ ዐስበ፡ ሰማይ፡ ወሀብተ፡ ቡራኬ፡ ፍጽምት፨</l>
                        <l n="5">ወበረከታ፡ ለኑኃሜት፤ ዘነሥአት፡ ሩት፨</l>
                    </lg>
                    <lg type="stanza" n="4">
                        <l n="1">ሰላም፡ ለፀአትክሙ፡ በከመ፡ ሰማዕክሙ፡ ዜና፨</l>
                        <l n="2">እንበይነ፡ መና፡ በገዳመ፡ ሲና፨</l>
                        <l n="3">እነግረክሙ፡ ገሃደ፡ በስብሐት፡ ወበቃለ፡ ጕሕና፨</l>
                        <l n="4">ፍቅረ፡ ጰራቅሊጦስ፡ ከመ፡ ዘቀሊል፡ ደመና፨</l>
                        <l n="5">ዘእንበለ፡ እግር፡ አርወጾሙ፡ ፍና፨</l>
                    </lg>
                    <lg type="stanza" n="5">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ እምነ፡ ጸቃውዕ፡ ጥዑም፨</l>
                        <l n="2">ሚሠናይ፡ ወጥቀ፡ አዳም፨</l>
                        <l n="3">ሰማዕተ፡ ጰራቅሊጦስ፡ ናር፡ እለ፡ ቅቡኣን፡ በደም፨</l>
                        <l n="4">አንትሙ፡ አጋእዝትየ፡ ተናበቡኒ፡ ሰላም፡ በሰላም፨</l>
                        <l n="5">በጺሐክሙ፡ በገሀድ፡ ወሕልም፨</l>
                    </lg>
                    <lg type="stanza" n="6">
                        <l n="1">ሰላም፡ ለብሔርክሙ፡ ምርፋቀ፡ ጸቃውዕ፡ ሐዲስ፨</l>
                        <l n="2">አመ፡ ዕርገቱ፡ ለሬስ፨</l>
                        <l n="3">አስተማስልክዎ፡ አንሰ፡ በልሳነ፡ ሥጋ፡ ወነፍስ፨</l>
                        <l n="4">እሕተ፡ ዮርዳኖስ፤ ካልእተ፡ ሳሌም፡ መቅደስ፨</l>
                        <l n="5">ጥብርያዶስ፡ ጥብርያዶስ፤ ለጻድቃን፡ መርስ፨</l>
                    </lg>
                    <lg type="stanza" n="7">
                        <l n="1">ሰላም፡ ለሥዕርትክሙ፡ በቅብአ፡ መንፈስ፡ ዘጠለ፨</l>
                        <l n="2">ወለድምድማክሙ፡ ሰላም፡ እማየ፡ ናጌብ፡ ዘበቈለ፨</l>
                        <l n="3">ሰማዕተ፡ ጰራቅሊጦስ፡ ናር፡ ለክብርክሙ፡ ተብህለ፨</l>
                        <l n="4">ንስረ፡ ኢትዮጵያ፡ አመ፡ ይግብር፡ በዓለ፨</l>
                        <l n="5">መንጰለ፡ ወአንጰልጰለ፡ መስቀለ፨</l>
                    </lg>
                    <lg type="stanza" n="99">
                        <l n="1"/>
                    </lg>
                </div>
            </div>
            

               <msContents>
                  <summary>Antiphonary for the Fast of Lent, ጾመ፡ ድጓ፡</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="102r" facs="005">Fols 1r–102r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="16v" facs="005">Fols 1r–16v</locus>
                    <title>First Week: The Descent, <foreign xml:lang="gez">ዘወረደ፡</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="16v" to="27r" facs="021">Fols 16v–27r</locus>
                    <title>Second Week: Holiness, <foreign xml:lang="gez">ቅድስት፡</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="27r" to="38r" facs="031">Fols 27r–38r</locus>

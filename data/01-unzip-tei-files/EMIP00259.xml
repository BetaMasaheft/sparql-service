                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.5">
                    <locus from="47v" to="63r" facs="052">Fols 47v–63r</locus>
                    <title>Fifth Week: The Mount of Olives, <foreign xml:lang="gez">ደብረ፡ ዘይት፡</foreign></title>

            <t:div type="edition">
                <t:div type="textpart" xml:lang="am">
                 <t:ab>   
                     <t:lb/>አምኃርኛ።
                     <t:lb/><t:add place="margin">1</t:add> ይድረስ፡ ከጌታየ፡ <t:persName ref="https://betamasaheft.eu/PRS7812Peterman"><t:roleName type="title">ዶክትር፡</t:roleName> ጰይትር
                     <t:lb/>መን፡ ዩልዩስ፡ ሃይንረኽ።</t:persName>
                     <t:lb/>እንዴት፡ ነዎ፡ እጅጉን። ወንዶች፡ እሴ
                     <t:lb/>ቶች፡ ልጆችዎ፡ የቤትዎ፡ ሰዎች፡ ሁሉ፡ 
                     <t:lb/><t:add place="margin">5</t:add> እንዴት፡ ናቸው። እኔ፡ እግዚአብሔር፡
                     <t:lb/>ይመስገን፡ ደኅና፡ ነኝ፡ በ<t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">ሸዋ፡</t:placeName> ተቀ
                     <t:lb/>ምጨ፡ አለሁ። ከዚህ፡ በፊት፡ ፫ ወረ
                     <t:lb/>ቀት፡ ላክሁ፡ ይድረስልዎ፡ አይድረስ
                     <t:lb/>ልዎ፡ አላውቅም። ወሬዎን፡ በማጣ
                     <t:lb/><t:add place="margin">10</t:add> ቴ፡ እጅግ፡ እጨነቅአለሁ።
                     <t:lb/>ኪዚህም፡ በኁላ፡ እግዚአብሔርን፡
                     <t:lb/>እለምንአለሁ፡ የርስዎን፡ የደብዳቤ፡
                     <t:lb/><t:add place="margin">13</t:add> ምላሽ፡ እንዲአሰማኝ።
                    <t:cb n="a"/>
                     <t:lb/>የተላከ፡ ከሎሌዎ፡			
                     <t:lb/><t:persName ref="https://betamasaheft.eu/PRS13996KidanaM">ኪዳነ፡ ማርያም፡</t:persName>
                     <t:cb n="b"/>
                     <t:lb/>ወር፡ <t:date ref="1876">በግንቦት፡
                     <t:lb/> ፳፰ በአመት፡
                     <t:lb/>፲፰፻፸፮</t:date></t:ab>

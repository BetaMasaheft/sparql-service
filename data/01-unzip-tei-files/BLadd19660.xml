                                <textLang mainLang="gez"/>
                            </msItem>

                            <msItem xml:id="ms_i1.7">
                                <locus from="126r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa malāʾǝkt la-Māryām</title>
                                <textLang mainLang="gez"/>
                            </msItem>

                            <msItem xml:id="ms_i1.8">
                                <locus from="128r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2731RepCh15">Hymn to God</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">መኃልይ፡ ለእግዚአብሔር፡ ዐቢይ። በዕዝል፡ ፫፡ ጊዜ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ። ለአዳም፡ አቡነ፡ ዘለሐኮ፡ በአርአያከ።
                                እግዚአብሔር፡ ርድአነ፡ መርዔተከ። ሃሌ፡ ሉያ፡ ሃ፡ ሃ፡ ለአቤል፡ ቅቱል፡ ዘነጸርከ፡ ቍርባኖ። ይእዜኒ፡ ስምዓነ፡ ለአድኅኖ።</incipit>
                            </msItem>
                        </msItem>




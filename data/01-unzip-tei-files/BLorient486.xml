                        <additions>
                            <list> 
                                <item xml:id="a1">
                                <locus target="#95r"/>
                                    <desc type="OwnershipNote"/>
                                
                                    <q xml:lang="gez">ዝመጽሐፍ፡ ዘአቦራ፡ ቅዱስ፡ ጊዮርጊስ፡ ዘወሀቦ፡ ዘሚካኤል፡ አሳዮ።</q>
                            </item>
                                
                                
                                <item xml:id="a2">
                                    <locus target="#116v"/>
                                    <desc type="OwnershipNote">The note at the end of item 3 giving the name of the owner, 
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS11361Kanafera">Kanāfǝra Krǝstos</persName>.</desc>
                                    <q xml:lang="gez">ተፈጸመ፡ በዝየ፡ መጽሐፈ፡ ጥበቡ፡ ለኢያሱ፡ ወልደ፡ ሲራክ። ጸሎቱ፡ 
                                        ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ። <persName role="owner" ref="https://betamasaheft.eu/PRS11361Kanafera">ከናፍረ፡ ክርስቶስ።</persName> 
                           </q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#162v"/>
                                    <desc type="OwnershipNote">Similar to note on f. 116v, giving the name of the owner 
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS11361Kanafera">Kanāfǝra Krǝstos</persName>.</desc>
                                    
                                </item>
                                
                            </list>
                        </additions>
                        

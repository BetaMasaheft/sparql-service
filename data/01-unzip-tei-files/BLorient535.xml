                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus from="1r" to="3r"/>
                                    <desc type="GuestText"><title ref="https://betamasaheft.eu/LIT2876RepCh157">Malkǝʾ-hymn to ʾAbib (Bulā)</title></desc>
                                    <q xml:lang="gez">
                                        <seg part="I">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዓ፡ በእልፍ፡ ወለሥዕርትከ፡ ኪሩብ፡ ዘይጼልሎን፡ በክንፍ። ኢትፍልጠኒ፡ አቢብ፡ እምከብካበ፡
                                            መርዓ፡ ጽሑፍ።</seg>
                                        <seg part="F"><seg type="supplication">ኦአምላከ፡ አቢብ፡ አድኅነኒ፡ እምኵሉ፡ እኩይ፡ ለገብረ፡ እግዚአብሔር፡ <add place="overstrike"><persName ref="https://betamasaheft.eu/PRS12926Giyorgis">ጊዮርጊስ፡</persName></add> ለአቡሁ፡
                                            <persName ref="https://betamasaheft.eu/PRS12927ArayaK">አርዓያ፡ ክርስቶስ፡</persName> ወለእሙ፡ <persName ref="https://betamasaheft.eu/PRS12928Orni">ኦርኒ።</persName></seg></seg>
                                        </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus from="3v"/>
                                    <desc type="GuestText"><title ref="https://betamasaheft.eu/LIT2851RepCh133">Malkəʾa Kiros</title></desc>
                                    <q xml:lang="gez"><seg part="I">ሰላም፡ ለዝክረ፡ ስምከ፡ ኀበ፡ ዓምደ፡ ወርቅ፡ ዘተጽሕፈ። ምስለ፡ ስመ፡ ኄራን፡ አበው፡ እንዘ፡ ይከውን፡ ሱቱፈ።
                                        ጻድቅ፡ ኪሮስ፡ እንተ፡ ታገኒ፡ አእላፈ።</seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus from="225v"/>
                                    <desc type="GuestText"><title ref="https://betamasaheft.eu/LIT5868Hymn">Mawaddǝs hymn to Demetrius</title></desc>
                                    <q xml:lang="am"><seg part="I">መወድስ፡ ዘዘማርያም፡ የስንዴ፡ ዛላ፡ ወሪቅ፡ ድሜጥሮስ፡ ድሜጥሮስ፡ ለጋ፡ የዶግ፡ ድሜጥሮስ፡ ለምለምለም፡ 
                                        ስንደዶ፤ በክሮ፡ ሎሚ፡ ድሜጥሮስ፡ የመጌዶ፤</seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a4">
                                    <locus from="226r"/>
                                    <desc type="MagicText"><title ref="https://betamasaheft.eu/LIT4619Prayer">Ṣalot baʾǝnta ḥǝmāma bāryā wa-legewon</title></desc>
                                    <q xml:lang="gez"><seg part="I">ጸሎት፡ በእንተ፡ ባርያ፡ ወሌጌዎን፡ ዘይሰልብ፡ ልበ፡ ሰብእ፡ ወያጸልም፡ አዕይንተ፡</seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a5">
                                    <locus from="226r"/>
                                    <desc type="GuestText"><title ref="https://betamasaheft.eu/LIT6040PrayerBirth">Baʾǝnta ṣǝnusāt soba yaʿāṣṣǝbon la-walid</title></desc>
                                    <q xml:lang="gez"><seg part="I">በእንተ፡ ጽኑሳት፡ ሶበ፡ የዓጽቦን፡ ለወሊድ፡</seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a6">
                                    <locus from="226r"/>
                                    <desc><title ref="https://betamasaheft.eu/LIT2947RepCh228">Hymn to Our Lady Mary</title></desc>
                                    <q xml:lang="gez"><seg part="I">ሰአ<sic resp="PRS10171Wright">ለ</sic>፡ ለነ፡ ጥዕምተ፡ ስም፡ ስአሊ፡ ለነ፡ አምጻኢተ፡ ሰላም፡ ሰአሊ፡ ለነ፡ ሠኣሪተ፡ መርገም፡ ስአሊ፡ ለነ።</seg>
                                    </q>
                                </item>
                                
                                <item xml:id="a7">
                                    <locus target="#231"/>
                                    <desc type="MagicText"><title ref="https://betamasaheft.eu/LIT6041HemamaKars">Ṣalota ḥǝmāma karś</title></desc>
                                    <q xml:lang="am"><seg part="I">ጸሎተ፡ ሕማመ፡ ከርሥ፡</seg></q>
                                </item>
                                
                                <item xml:id="a8">
                                    <locus target="#231"/>
                                    <desc type="MagicText"><title ref="https://betamasaheft.eu/LIT4705MagicPr">Ṣalot baʾǝnta ḥǝmāma wǝgʿāt</title></desc>
                                    <q xml:lang="am"><seg part="I">ጸሎተ፡ በእንተ፡ ሕማመ፡ ውግዓት።</seg></q>
                                </item>
                                
                                <item xml:id="a9">
                                    <locus target="#231v"/>
                                    <desc type="Inventory"/>
                                    <q xml:lang="gez"><seg part="I">ንዋየ፡ ቤተ፡ ክርስተያን፡ ዘወጽአ፡ ብር፡ ፲፯ብር፡</seg></q>
                                </item>
                                
                                <item xml:id="a10">
                                    <locus target="#5r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript
                                        belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ዳዊት፡ ዘቅዱስ፡ <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">መድኃኔ፡ ዓለም።</placeName></q>
                                </item>
                                
                                <item xml:id="e1">
                                    <desc>One name mentioned in the manuscript was <persName ref="https://betamasaheft.eu/PRS13039SaqawaD">Saqoqāwa Dǝngǝl</persName>. This and the other
                                          names originally mentioned in the manuscript have been erased everywhere and substituted by those of
                                        <persName ref="https://betamasaheft.eu/PRS13040Mikael">Mikāʾel</persName> and, in one instance, <persName ref="https://betamasaheft.eu/PRS12926Giyorgis">Giyorgis</persName> (<locus target="#229r"/>).</desc>
                                </item>
                                
                                <item xml:id="e2">
                                    <locus target="#219r"/>
                                    <desc>It is not clear from the catalogue description whether this supplication at the end of
                                        <ref target="#ms_i1.3"/> is a later addition.</desc>
                                    <q xml:lang="gez"><seg type="supplication">ዕቀበዮ፡ ለገብርኪ፡ <persName ref="https://betamasaheft.eu/PRS13040Mikael">ሚካኤል።</persName></seg></q>
                                </item>
                            </list>
                            
                        </additions>
                        

                  <msItem xml:id="ms_i4">
                     <locus from="91r">Fols 91r and following</locus>
                     <title type="complete">A short prayer for <persName ref="https://betamasaheft.eu/PRS11683SayfaM">Sayfa Mikāʾel</persName>,
                        <placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</placeName>
                     and others.</title>
                     <textLang mainLang="gez"/>
                     <t:note xmlns:t="http://www.tei-c.org/ns/1.0">It appears that the manuscript was written for <persName role="owner" ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</persName> and his son
                        <persName role="owner" ref="https://betamasaheft.eu/PRS5205haylaMa">Ḫāyla Malakot</persName>, which would date it about <date>1840</date>.</t:note>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="91v" to="96v">Fols 91v–96v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4551Salam">Salām-hymn to Lālibalā</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">አዚዝ፡ <hi rend="rubric">ላሊበላ፡</hi> ዓለመ፡ ዘትቀኒ።
                        ሰላም፡ ለዝክረ፡ ስምከ፡ ከመ፡ ቃለ፡ ማዕነቅ፡ ድምፅ።</incipit>
                     <t:note xmlns:t="http://www.tei-c.org/ns/1.0">beginning with stanza 2 of <ref type="work" corresp="https://betamasaheft.eu/LIT4551Salam">Salām-hymn to Lālibalā</ref> as it appears in modern collections</t:note>
                  </msItem>
                  

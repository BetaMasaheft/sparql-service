                  <msItem xml:id="ms_i1">
                     <locus from="5r">Fols 5r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1469GadlaK">Gadla Krǝstos Śamrā</title> 
                        <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/>
                     ሥሉስ፡ ዘኢይሴደቅ፡ ጥንተ፡ ሀልዎቱ፡ ዘኢይትዓወቅ፡ ወዓመታቲሁ፡ ዘኢየሐልቅ። ዘሰቀሎ፡ ለሰማይ፡
                     ከመ፡ ቀመር፡ እንበለ፡ ሰዋቅ።</incipit>
                     
                     
                     

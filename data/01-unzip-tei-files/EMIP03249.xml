               <msContents>
                  <summary>Psalter, Angels Praise Her, with Nine Illuminations</summary>
                  <msItem xml:id="ms_i1"><locus from="3r" to="172r" facs="003">Fols 3r–172r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="3r" to="132v" facs="003">Fols 3r–132v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> from the common new system</note>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has only, <foreign xml:lang="gez">ወአድኃነኒ</foreign>, the first of the four plusses that make up the long version</note>
                      <msItem xml:id="ms_i1.1.1">
                        <locus target="#3r" facs="003">Fol. 3r</locus>
                        <title>Opening prayer from <title type="incomplete" ref="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</title></title>
                      </msItem>
                    </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="133r" to="145v" facs="133">Fols 133r–145v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note>The fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>The Prayer of Hana, mother of Samuel, prophet</q></note>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="146r" to="153r" facs="146">Fols 146r–153r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">, common version</title>
                    <note><locus target="#153r" facs="153">Fol. 153r</locus>, concludes with a doxology text</note>
                  </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="154r" to="164v" facs="154">Fols 154r–164v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">, arranged for the days of the week</title>
                    <note>Laid out beginning on Monday and culminating on Sunday</note>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="167r" to="172r" facs="167">Fols 167r–172r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.5.1">
                      <locus target="#172r" facs="172">Fol. 172r</locus>
                      <title>Concluding prayer for one <foreign xml:lang="gez">ወልደ ክርስቶስ</foreign>, original owner(?)</title>
                      <incipit xml:lang="gez">
                        ጸሎት፡ ለማርያም፡ ወስእለታ፡ ለወልደ፡ ክርስቶስ፡ ያድኅኖ፡ እምዓተ፡ ወልደ።
                      </incipit>
                    </msItem>
                  </msItem>
                </msItem>
                <msItem xml:id="ms_i2"><locus from="172r" to="173r" facs="172">Fols 172r–173r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>

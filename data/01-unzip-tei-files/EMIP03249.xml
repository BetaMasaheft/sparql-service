                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                    <seg type="rubrication">
                      <ref target="#ms_i.1.1 #ms_i.1.2 #ms_i.1.3"/>
                    <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                    </seg>
                    <desc>The word for God is rubricated in the first three works</desc>
                    <desc><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps150"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps150</span></ref> employs columetric rubrication</desc>
                    <desc>The tenth biblical canticle employs columetric rubrication</desc>
                    </handNote>
                    </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>, surrounded by the four living creatures with caption <q><foreign xml:lang="gez">ሥሉስ ቅዱስ</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#1v" facs="002">Fol. 1v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> with caption <q><foreign xml:lang="gez">ቅዱስ ጊዮርጊስ </foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#2r" facs="002">Fol. 2r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s with caption <q><foreign xml:lang="gez">ሚካኤል, ገብርኤል</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#2v" facs="003">Fol. 2v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref> with caption <q><foreign xml:lang="gez">ብሥራተ ገብርኤል</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#165r" facs="165">Fol. 165r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1025NativityJesus">Nativity of Jesus</ref> with caption <q><foreign xml:lang="gez">ልደተ ክርስቶስ</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#165v" facs="166">Fol. 165v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1016Flight">Flight into Egypt</ref> with caption <q><foreign xml:lang="gez">ስደት</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#166r" facs="166">Fol. 166r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref> with caption <q><foreign xml:lang="gez">ዘከመ አንገሥዋ ለእግዝእትነ ማርያም</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#166v" facs="167">Fol. 166v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1038Baptism">Baptism of Jesus</ref> with caption <q><foreign xml:lang="gez">ጥምቀተ እግዚእ</foreign></q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#173v" facs="174">Fol. 173v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> and <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> with caption <q><foreign xml:lang="gez">እግዚእነ ምስለ እሙ</foreign></q></desc></decoNote>
                    <decoNote type="frame" xml:id="d10">Complete set of penciled-in harags at every tenth Psalm</decoNote>

                  </decoDesc>

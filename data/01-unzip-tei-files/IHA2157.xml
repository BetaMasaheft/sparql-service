                  <msItem xml:id="ms_i0">
                     <locus from="1" to="93">p. 1-93</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1964IHA">تحفة المشتاق فى الصلاة على عروس حضرة الملك الخلاق</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>بسم الله الرحمن الرحيم. اللهم صل وسلم وبارك على سيدنا ومولانا محمد وعلى أل سيدنا محمد ألف أول تألف موجودات البارى وسين سره السارى فى مكنونات جميع الاطوار

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 93">-p. 93</locus>فى عباك الصالحين رب اغفر وارحم وأنت خير الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين تمت

</explicit>
                     <note/>
                     <note/>
                  </msItem>

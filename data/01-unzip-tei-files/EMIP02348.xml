                    <textLang mainLang="am">Amharic</textLang>
                    <incipit>
                      <foreign xml:lang="gez">ወይኩንል፡ ዓቢይ፡ አርምሞ፡ ወአልቦ፡ ዘይትናግር፡</foreign>
                      <foreign xml:lang="am">አርምምን፡ ታላቅ፡ ዝምታን፡ ያድርጉ፡ ከሟነብባ፡ ከኒተረጉም፡ በቀር፡ አለ፡ ዝም፡ ብሎ፡ ሁ<add place="above">ሉ</add>፡ ያድምፅ፡
                      <gap reason="ellipsis"/>
                      መጽሐፈ፡ ተአምሯንስ፡ ቆሞ፡ ያደመፀና፡ ተቀምጦ፡ ያደመፀና፡ ክብሩ፡ እንዴት፡ ነው፡</foreign>
                    </incipit>

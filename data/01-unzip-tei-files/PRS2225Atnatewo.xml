      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">አትናቴዎስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAtnātewos</persName>
               <persName>
                  <roleName type="title">ʾabuna</roleName>
               </persName>
               <occupation type="ecclesiastic">metropolitan</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
             
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> 
               </residence>
               
               <floruit notBefore="1867" notAfter="1876">He was the metropolitan of 
                  Ethiopian Orthodox Church who was consecrated by <persName ref="https://betamasaheft.eu/PRS3500Demetriu">Demetrius II of Alexandria</persName> 
                  in <date>1867</date>.
                  He was the immediate successor of ʾabuna <persName ref="https://betamasaheft.eu/PRS8388SalamaI">Salāmā III</persName>.
                  He was consecrated through the official request of 
                   
                  <persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                     <roleName type="title">ʾaṣe</roleName> 
                     Yoḥannǝs IV</persName> whom he consecrated as King of Kings of Ethiopia in <date>1872 </date> at 
                  <placeName ref="https://betamasaheft.eu/LOC1311AksumS">ʾAksum Ṣǝyon</placeName>.
                  Following the conflict between 
                  <persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                     <roleName type="title">ʾaṣe</roleName> 
                     Yoḥannǝs IV</persName>
                  and Egyptian, he leaned towards his land. 
                  This situation created a hostile relation between the two and later he formed an alliance with the strong rival of 
                  
                  <persName ref="https://betamasaheft.eu/PRS10378Yohanne"> 
                     <roleName type="title">ʾaṣe</roleName> Yoḥannǝs IV
                  </persName> King <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk II</persName>.
                  
               </floruit>
               <death when="1876"> He died on <date>1876</date> and was buried at 
                  <placeName ref="https://betamasaheft.eu/LOC1264Adwa">ʿĀdwā</placeName>.</death>
            </person>
            
         </listPerson>

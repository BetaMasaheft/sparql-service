         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q44258">
              
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ባስልዮስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Bāsǝlyos</t:persName>
               <t:persName xml:lang="en" xml:id="n2" type="main">Basil of Caesarea</t:persName>
               <t:persName xml:lang="en" xml:id="n3">Basil the Great</t:persName>
               <t:nationality type="Greece"/>
               <t:faith type="Greek"/>
               
                  <t:birth notBefore="0329" notAfter="0330"/>
                  <t:floruit notBefore="0350" notAfter="0379">A  saint and doctor of the church, he was an important figure in the 4th century strife against 
                     Arianism, an organizer of the monastic life and a prolific writer.
                     Excerpts of his works are extant in Ethiopic. 
                     <t:persName ref="https://betamasaheft.eu/PRS2546Basilth">Basil the Great</t:persName> came
                     from a deeply Christian Greek family, many members of which are venerated as saints.
                     He visited all of the most important monastic 
                     centres in <t:placeName ref="https://betamasaheft.eu/LOC5833Syria">Syria</t:placeName> and <t:placeName ref="https://betamasaheft.eu/LOC4797Mesopo">Mesopotamia</t:placeName>, 
                     <t:placeName ref="https://betamasaheft.eu/LOC5068Palest">Palestine</t:placeName> and 
                     <t:placeName ref="https://betamasaheft.eu/LOC2804Egypt">Egypt</t:placeName>.</t:floruit>
               <t:death when="0379"/>
                  
               </t:person>  
               
         </t:listPerson>
  

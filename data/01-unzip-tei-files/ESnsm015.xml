                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>- Miracles of Text I are not numbered.</note>
                  </msItem>
               </msContents>

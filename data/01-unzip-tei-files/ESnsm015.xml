                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>First half of the 20th century</date>
                        <seg type="rubrication">Nomina sacra; names of the donor and his relatives;
                           name of the protagonist; incipit of miracles in Text I; the word "salām"
                           in Text II; elements of the punctuation signs; elements of Ethiopic
                           numerals.
 On the incipit page of Texts I-II, a few lines are
                           rubricated (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>

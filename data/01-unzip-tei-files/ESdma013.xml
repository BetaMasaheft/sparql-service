                                 <dim unit="leaf">4</dim>
                                 <locus from="15r" to="18v"/> III(4/fols. 15r-18v) </item>
                              <item xml:id="q4">
                                 <dim unit="leaf">1</dim>
                                 <locus target="#19"/> IV(1; s.l.: 1, stub after 1/fol. 19) </item>
                              <item xml:id="q5">
                                 <dim unit="leaf">1</dim>
                                 <locus target="#20"/> V(1; s.l.: 1, stub after 1/fol. 20) </item>
                              <item xml:id="q6">
                                 <dim unit="leaf">10</dim>
                                 
                                 <locus from="21r" to="30v"/> {VI(10/fols. 21r-30v)} </item>

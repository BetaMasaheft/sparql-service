               <msContents>
                  <summary>I) Maṣḥafa ʾaślǝṭi, Lectionary for the entire year (fols. 1r-36v), most
                     probably incomplete (incipit is missing)</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="36v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1917Mashaf#year">Maṣḥafa ʾaślǝṭi, Lectionary for the entire year</title>
                     <textLang xml:lang="gez"/>
                     <note>most
                        probably incomplete (incipit is missing)</note>
                     <incipit xml:lang="gez"><locus target="#1ra">1ra</locus> ... መጽሐፈ፡ አስልጢ፡ ...<note>The text is called ʾaslǝṭi in the incipit. </note></incipit>
                     
                  </msItem>
                  
                  
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">38.0</measure> folios, in <measure unit="quire">7.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">160</height>
                              <width unit="mm">130</width>
                              <depth unit="mm">20</depth>
                           </dimensions>
                        </extent>

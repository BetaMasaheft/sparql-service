         <t:listPerson>
            <t:person sex="1">
            
                  
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ፈንታ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Fantā</t:persName>
               <t:persName>
                  <t:roleName type="title">dabtarā</t:roleName>
               </t:persName>
               
                  
              
                 <t:faith type="EOTC"/>
                  
                  
                 <t:occupation type="literary">secretary</t:occupation>
            
                  
               <t:floruit notBefore="1830" notAfter="1860">He was known to the missionary of <t:persName ref="https://betamasaheft.eu/PRS4722Gobat">Samuel Gobat</t:persName> and the travellers 
                  <t:persName ref="https://betamasaheft.eu/PRS4089Ferret">Pierre Victor Adolphe Ferret</t:persName> and <t:persName ref="https://betamasaheft.eu/PRS4444Galinier">Joseph Germain Galinier</t:persName> and particularly as correspondent of the French traveller and scholar
                  <t:persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d’Abbadie [d’Arrast]</t:persName>. As a secretary at the court of <t:persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</t:persName> in <t:date>1848</t:date> he wrote several letters to
                  <t:persName ref="https://betamasaheft.eu/PRS4722Gobat">Samuel Gobat</t:persName>, then Anglican Bishop of <t:placeName ref="https://betamasaheft.eu/LOC3957Jerusa">Jerusalem</t:placeName>, seeking his intervention on behalf of the Ethiopian monks in the Holy city.
                  Between <t:date>1853</t:date> and <t:date>1854</t:date>he wrote five letters to <t:persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d’Abbadie [d’Arrast]</t:persName> containing valuable news about contemporary Ethiopian Politics.
               </t:floruit>
             
                  
               </t:person>
               
               
         </t:listPerson>
         
            
            
            

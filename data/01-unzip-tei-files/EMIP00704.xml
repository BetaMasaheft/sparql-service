                  <decoDesc>
                  <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  multiple full stops are used as section dividers throughout;
                  <locus target="#38v #39r #39v" facs="039 040">fols. 38v, 39r, 39v</locus> (line of alternating red and black dots)
                  </decoNote>
                </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#39r" facs="039">Fol. 39r</locus>
                    <desc>
                    Commissioned by Sǝbǝḥat Läkǝrstos. The note is written in the original hand, though the name may have been changed
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#39v" facs="040">Fol. 39v</locus>
                    <desc type="OwnershipNote">
                    Note of ownership, erased and replaced with the name of a secondary owner, Mäzgäbä Śǝllase, along with the names of his wife and children
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#40r" facs="040">Fol. 40r</locus>
                    <desc>
                    Pen trial, in a later hand
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#40v" facs="041">Fol. 40v</locus>
                    <desc>
                    Pen trail, writing exercise, based on the Trinitarian formula
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#41r #41v #42r #42v" facs="041 042 043">Fols. 41r, 41v, 42r, 42v</locus>
                    <desc>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    Many of the folios have come loose from the quires and are now stab-stitched into the codex
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#31v #32r" facs="032">Fols. 31v, 32r</locus>
                    <desc>
                    words of text are written interlinearly;
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#8v #26r #39r" facs="009 026 039">Fols. 8v, 26r, 39r</locus>
                    <desc>
                    text has been removed
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

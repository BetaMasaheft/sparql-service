                    <msItem xml:id="ms_i7">
                    <locus from="91v"/>
                    <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1651Homily">Homily of <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName>
                    on the four beasts (<date ref="ethiocal:Hedar8">8th of Ḫǝdār</date>)</title>
                        <incipit xml:lang="gez">ድርሳን፡ ዘብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡ ሊቀ፡ ጳጳሳት፡ ዘቈስጠንጢንያ፡ በእንተ፡ ፬፡ እንስሳ፡ ዕበይት፡ መንፈሳዊያን፡ አመ፡ ሰሙኑ፡ ለኅዳር፡ ዘይትነበብ፡ በሰላመ፡ እግዚአብሔር፡ አሜን።</incipit>
                    <textLang mainLang="gez"/>
                    </msItem>

                    <msItem xml:id="ms_i8">
                    <locus from="106r"/>
                    <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6174Severus318">Treatise of <persName ref="https://betamasaheft.eu/PRS8788Severos">Severus (of Ašmunayn)</persName> on the Council of the 318 Fathers (at Nicaea)</title>
                    <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ነገር፡ በእንተ፡ ማኅበር፡ ሠለስቱ፡ ምእት፡ ዐሠርቱ፡ ወሰመንቱ፡ ዘአባ፡ ሳዊሮስ፡ አመ፡ ፱፡ ለኅዳር፡ በጽሐ፡ መልእክትከ፡ እኁየ፡ መሀይምን፡ ወብፁዕ፡ ይዕቀብከ፡ እግዚአብሔር፡ ለቅኔሁ፡
                    ወይርድእከ፡ ለሥምረቱ፡ ወይመግብከ፡ በዓቂቦቱ፡ ተዝካር፡ አንብቦትከ፡ መጽሐፈ፡ ዘጽሐፎ፡ ስዒድ፡ ወልደ፡ ጰጥሪቅ፡ ወሰመዮ፡ መጽሐፈ፡ ሓሳብ፡ ወትካዙ፡ ዘውስተ፡ ልብከ፡ በእንተ፡ ዘነበበ፡ ዕረፍተ፡

                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ኖብ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Nob</t:persName>

               <t:persName>
                  <t:roleName type="title">nǝbur ǝd, ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">abbot of Dabra Dāmmo</t:occupation>

               <t:floruit when="1450">He was a monk from the monastery of
                  <t:placeName ref="https://betamasaheft.eu/LOC2241DabraB">Dabra Bakʷǝr</t:placeName> who was appointed
                  as <t:persName ref="https://betamasaheft.eu/PRS7596Nob">
                     <t:roleName type="title">nǝbura ʾǝd</t:roleName> Nob</t:persName> of <t:placeName ref="https://betamasaheft.eu/INS0105DD">Dabra Dāmmo ʾAbuna ʾAragāwi</t:placeName> in <t:date>1450</t:date>.
                  However, soon after <t:date>1450</t:date>
                  <t:persName ref="https://betamasaheft.eu/PRS7596Nob">Nob</t:persName> fell out
                  of the favour with
                  <t:persName ref="https://betamasaheft.eu/PRS10626ZaraY">
                     <t:roleName type="title">ʾaṣe</t:roleName> Zarʾa Yāʿqob</t:persName>
                  and demoted from <t:persName ref="https://betamasaheft.eu/PRS7596Nob">
                     <t:roleName type="title">nǝbura ʾǝd</t:roleName>Nob</t:persName>.</t:floruit>

               </t:person>
               
         </t:listPerson>

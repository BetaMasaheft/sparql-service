      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0438</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ እምከርሥ፨</l>
                  <l n="2">እምቅድመ፡ ትትወለድ፡ ዘኀረየከ፡ ኢየሱስ፡ ክርስቶስ፨</l>
                  <l n="3">ዐርከ፡ ኤልያስ፡ ሄኖክ፡ ቢጸ፡ እንጦንስ፡ ወመቃርስ፨</l>
                  <l n="4">ባርኮ፡ ባረኩ፡ መላእክተ፡ ሰማይ፡ ሐዳስ፨</l>
                  <l n="5">ዘቦሙ፡ መዘምራን፡ ዘባጥያተ፡ ከበሮ፡ ለተውዳስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለህላዌከ፡ እም፡ ገዳም፡ ውስተ፡ ገዳም፨</l>
                  <l n="2">ወእምነ፡ በዐት፡ ወጾላዕት፡ ወአእባን፡ ኅቱም፨</l>
                  <l n="3">ሄኖክ፡ ስምከ፡ ንቡረ፡ ቅድስት፡ ጽርሐ፡ አርያም፨</l>
                  <l n="4">ኣእሚረከ፡ በለብዎ፡ ህልፈተ፡ ዛቲ፡ ዓለም፨</l>
                  <l n="5">ምስለ፡ አናብስት፡ ወአናምርት፡ ነበርከ፡ በሰላም፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘደመና፡ ሰማይ፡ ትርጓሜሁ፨</l>
                  <l n="2">ወጼና፡ ስኂን፡ ጼና፡ መዐዛሁ፨</l>
                  <l n="3">ቢጸ፡ ዕዝራ፡ ወሚሳኤል፡ ሄኖክ፡ በህላዌሁ፨</l>
                  <l n="4">ነዓ፡ ነዓ፡ እምህላዌከ፡ ጽርሑ፨</l>
                  <l n="5">ይባርከነ፡ በስፉሕ፡ እዴሁ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ማእከለ፡ ሠላስ፡ አድባር፨</l>
                  <l n="2">ወውሒዘ፡ ማይ፡ ምሥጢር፨</l>
                  <l n="3">ሄኖክ፡ ለባዊ፡ ወበፍኖተ፡ ጽድቅ፡ ማእምር፨</l>
                  <l n="4">ኀይለ፡ ጸሎትከ፡ ያድኅን፡ እምፀር፨</l>
                  <l n="5">ወእምነ፡ ጸላኢ፡ ዘግብሩ፡ መሪር፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ ዘአፈጸመነ፡ ለተናብቦ፨</l>
                  <l n="2">ለሰሚዐ፡ እዝን፡ አስተዐጽቦ፨</l>
                  <l n="3">በእዝን፡ ለሰሚዕ፡ መኑ፡ ከማከ፡ ቃለ፡ ኪዳን፡ ዘተውህቦ።፡</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">አባ፡ አባ፨</l>
                  <l n="2">ጸሎትከ፡ አባ፨</l>
                  <l n="3">ለሀገሪትነ፡ አድኅና፡ እም፡ ዐጸባ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ኦብእሴ፡ እግዚአብሔር፡ ዕዝራ፡፡</l>
                  <l n="2">ወቡሩከ፡ አምላክ፡ ወሰብአ፡ ማኅበራ፨</l>
                  <l n="3">ማእከለ፡ ሰማዕት፡ ወጻድቃን፡ ዘሐነጹ፡ ማኅደራ፡፨</l>
               </lg>
            </div>
         </div>
      </body>

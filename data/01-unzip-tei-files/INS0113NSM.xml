               <t:placeName xml:lang="gez" corresp="#n1" type="normalized">Nǝḥbi Qǝddus Mikāʾel</t:placeName>
               <t:placeName xml:lang="gez" xml:id="n2" type="alt">ደብረ፡ ሰላም፡ ቅዱስ፡ ሚካኤል፡ ንሕቢ፡</t:placeName>
               <t:placeName xml:lang="gez" corresp="#n2" type="normalized">Dabra Salām  Qǝddus Mikāʾel Nǝḥbi</t:placeName>

               
               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>
               
               <t:settlement type="province" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</t:settlement>
               <t:settlement from="2010-11-25" to="2010-11-26" type="warada" ref="https://betamasaheft.eu/LOC3293GantaA">Gāntā ʾAfašum</t:settlement>
               <t:settlement from="2010-11-25" to="2010-11-26" type="tabiya" ref="https://betamasaheft.eu/LOC7204Bekot">Bǝkot Nǝḥbi Māy ʾĀbʾā</t:settlement>
               <t:settlement from="2010-11-25" to="2010-11-26" type="qushat" ref="https://betamasaheft.eu/LOC4986Nehbi">Nǝḥbi</t:settlement>
               

               <t:location>
                  <t:geo>14.262 39.487683</t:geo>
                  <t:height unit="m">2510.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1400" notAfter="1500">1400-1500</t:date>
                  <t:desc type="foundation">The church may be an Aksumite foundation. Aksumite remains (a massive stone bowl, pillar) are found in the church compound. 
                     Local tradition does not specify the time of the foundation, but tells that <t:persName ref="https://betamasaheft.eu/PRS10340Yeshaq">Yǝsḥaq</t:persName>, the founder of <t:placeName ref="https://betamasaheft.eu/INS0005Gund">Gunda Gunde</t:placeName> and adherent of the Stephanite movement, 
                     established the monastic community at the church of Nǝḥbi before going to the area where he founded later <t:placeName ref="https://betamasaheft.eu/INS0005Gund">Gunda Gunde</t:placeName> (The <t:ref type="work" corresp="https://betamasaheft.eu/LIT4810GadlaYe">Vita of Yǝsḥaq</t:ref> tells 
                     only that he was a native of Nǝḥba in ʿAgāma). 
                     As other churches and monasteries of the area, the monastic community of 
                     Nǝḥbi was favored by <t:persName ref="https://betamasaheft.eu/PRS8265Sabagadi">Dağğāzmāč Sabāgādis</t:persName>, in the early 19th cent., but it declined in the early 20th cent.  
                     During the Italian period another church dedicated to <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10618ZaraB">Zarʾā Buruk</t:persName> was established nearby under the administration of Nǝḥbi Mikāʾel, but it declined in the early 20th cent.</t:desc>
                  <t:ab type="history">Gadām. It is considered a monastery, but currently there are no monks.
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/NSM.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>
                     18 Mss. photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm001">NSM-001</t:ref> "The Faith of the Fathers"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm002">NSM-002</t:ref> "The Rite of the Holy Week"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm003">NSM-003</t:ref> "Four Gospels"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm004">NSM-004</t:ref> "Homily of St. Michael"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm005">NSM-005</t:ref> "Vita of Gäbrä Mänfäs Qǝddus"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm006">NSM-006</t:ref> "The Book of the Funeral Rite"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm007">NSM-007</t:ref> "Miracles of Mary"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm008">NSM-008</t:ref> "Vita of Täklä Haymanot"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm009">NSM-009</t:ref> "The Book of the Matrimony Rite"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm010">NSM-010</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm011">NSM-011</t:ref> "Prayer of Incense"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm012">NSM-012</t:ref> "Synaxarion (March)"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm013">NSM-013</t:ref> "Synaxarion (September)"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm014">NSM-014</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm015">NSM-015</t:ref> "Vita of Zarʾa Buruk"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm016">NSM-016</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm017">NSM-017</t:ref> "Vita of Kiros"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESnsm018">NSM-018</t:ref> "Prayer of Mary". Objects.</t:ab>
       
                  <t:ab type="tabot">
                     <t:measure quantity="5"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7000MenasM">Minās</t:persName> (marble), two of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Baʾata Māryām</t:persName> (?), 
                     <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10618ZaraB">Zarʾā Buruk</t:persName> (in additional small church).</t:ab>
               </t:note>

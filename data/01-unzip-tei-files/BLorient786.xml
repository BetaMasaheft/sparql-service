            </desc>
            <q xml:lang="gez">ርቱዓ፡ ሃይማኖት፡ ዘቅዱስ ፡ መድኃኔ፡ ዓለም።</q>
        </item>

<item xml:id="e1">
<locus target="#168r"/>
<desc type="MixedNote"/>
<q xml:lang="am">ደብተራ፡ ወልደ፡ ኢየሱስ፡ ቁም፡ ጾመ፡ ድጓ፡ ተጉለቲ፡ ድጓ፡ ወደዱ። መምሬ፡ ገብረ፡ ማርያም፡ ባለምዕራፍ፡ ጾመ፡ ድጓ፡ ወሰዱ።</q>
</item>

        </list>
    </additions>


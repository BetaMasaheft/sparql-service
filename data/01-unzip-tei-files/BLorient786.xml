<msContents>

  <msItem xml:id="ms_i1">
  <locus from="5r" to="167v"/>
  <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2222RetuaH">Rǝtuʿa Hāymānōt, or "the Orthodox", a collection of homilies for various occasions</title>
  <textLang mainLang="gez"/>

<msItem xml:id="ms_i1.1">
<locus from="5r" to="10v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6799RHintro">Introduction</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.2">
<locus from="10v" to="24v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2113OntheB">On the birth of our Lord of the blessed Virgin Mary</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#10v"/>ድርሳን፡ ዘርቱዐ፡ ሃይማኖት፡ በእንተ፡ ልደተ፡ አምላክ፡ እማርያም፡ እምቅድስት፡</incipit>
</msItem>


<msItem xml:id="ms_i1.3">
<locus from="24v" to="40r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2095OnHowO">On the baptism of our Lord</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#24v"/>በእንተ፡ ዘከመ፡ ተጠምቀ፡ አምላክነ፡ ክርስቶስ፡ በፈለገ፡ ዮርዳኖስ፡ በዕደ፡ ዮሐንስ፡</incipit>
</msItem>

<msItem xml:id="ms_i1.4">
<locus from="40r" to="47r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6060BeginningOfLent">For the beginning of Lent </title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#40r"/>ዘይትነበብ፡ በቀበላ፡ ጾም፡</incipit>
</msItem>

<msItem xml:id="ms_i1.5">
<locus from="47r" to="51r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6049SundayRetuaH">For the (first) Sunday of Lent </title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#47r"/>ድርሳን፡ ዘይትነበብ፡ በቅድስት፡ ጾም፡ ሰንበተ፡ ክርስቲያን፡ በእንተ፡ ጾም፡ እመ፡ ኵሉ፡ ምግባራት፡</incipit>
</msItem>

<msItem xml:id="ms_i1.6">
<locus from="51r" to="54v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6050SundayRetuaH">For the second Sunday of Lent </title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#51r"/>ድርሳን፡ ዘይትነበብ፡ በካዕብ፡ ሰንበተ፡ ጾም፡ በዕለተ፡ ቦአ፡ እግዚእነ፡ ምኵራበ፡ ወመሐረ፡ በእንተ፡ ጾም፡ እንተ፡ ይእቲ፡ እመ፡ ኵሉ፡ ምግባራት፡</incipit>
</msItem>

<msItem xml:id="ms_i1.7">
<locus from="54v" to="57r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6061SundayRetuaH">For the third Sunday of Lent </title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#54r"/>ድርሳን፡ ዘሣልስ፡ ሰንበተ፡ ጾም፡ ዘይትነበብ፡ በመጻጉዕ፡ በእንተ፡ ጾም፡ እንተ፡ ይእቲ፡ እመ፡ ኵሉ፡ ምግባራት፡</incipit>
</msItem>

<msItem xml:id="ms_i1.8">
<locus from="57r" to="72r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6045SerataSegdat">Services for the close of Lent</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#57r"/>ሥርዓተ፡ ስግደት፡ በተፍጻሜተ፡ በዓለ፡ ቅድስት፡</incipit>
</msItem>

<msItem xml:id="ms_i1.9">
<locus from="72r" to="88v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2097OnHowt">On the incarnation of the Word</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#72v"/>በከመ፡ ተሠገወ፡ ቃለ፡ እግዚአብሔር፡ እመንፈስ፡ ቅዱስ፡ ወእማርያም፡</incipit>
</msItem>

<msItem xml:id="ms_i1.10">
<locus from="88v" to="92v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6048OnPalmSundayRetuaH">For Palm Sunday</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#88v"/>ዘይትነበብ፡ በዕለተ፡ ሆሣዕና፡</incipit>
</msItem>

<msItem xml:id="ms_i1.11">
<locus from="92v" to="109v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2149OntheW">On our Lord washing the feet of his disciples, and on the Last Supper</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#92v"/>በእንተ፡ ዘከመ፡ ሐፀበ፡ እግረ፡ አርዳኢሁ፡ ወዘከመ፡ ወሀበ፡ ኅብስተ፡ ወወይነ፡ እምድኅረ፡ ድራር፡ ለአርዳኢሁ፡</incipit>
</msItem>

<msItem xml:id="ms_i1.12">
<locus from="109v" to="124v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2118OntheD">On the death of our Lord</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#109v"/>በእንተ፡ ሞቱ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ጊዜ፡ ፱ሰዓት፡ በዲበ፡ ዕፀ፡ መስቀል፡
ወበእንተ፡ ፈያታዊ፡ ዘየማን፡ ወበእንተ፡ ሞት፡ ወሰይጣን፡ ዘከመ፡ ተበሃሉ፡</incipit>
</msItem>

<msItem xml:id="ms_i1.13">
<locus from="125r" to="132v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2109OntheA">On the ascension of our Lord</title>
<textLang mainLang="gez" xml:lang="gez"/>
<incipit xml:lang="gez"><locus target="#125r"/>ድርሳን፡ በእንተ፡ ዘከመ፡ ዓርገ፡ እግዚእነ፡ ውስተ፡ ሰማያት፡ መልዕልተ፡ ኵሉ፡ ስም፡ ወነበረ፡ በየማነ፡ ኃይል፡</incipit>
</msItem>

<msItem xml:id="ms_i1.14">
<locus from="132v" to="148v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2137OntheP">On the Trinity in unity</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#132v"/>ርድአኒ፡ ወልደ፡ እግዚአብሔር፡ ከመ፡ እትናገር፡ በእንተ፡ ህሉና፡ መስልሥትከ፡ በተዋህዶትከ፡ </incipit>
</msItem>

<msItem xml:id="ms_i1.15">
<locus from="148v" to="153v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT6047On12ApostlesRetuaH">On the twelve apostles</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#148v"/>በእንተ፡ ፲ወ፪ሐዋርያት፡ ዘይትነበብ፡ አመ፡ ፭ሐምሌ፡ gez፡</incipit>
</msItem>

<msItem xml:id="ms_i1.16">
<locus from="154r" to="160v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2145OntheT">On the transfiguration of our Lord</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#154r"/>ድርሳን፡ ዘደብረ፡ ታቦር፡ ዘከመ፡ ተወለጠ፡ ራዕዩ፡ ለእግዚእነ፡ በውስተ፡ ደብረ፡ ታቦር፡</incipit>
</msItem>

<msItem xml:id="ms_i1.17">
<locus from="160v" to="167v"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2124OntheF">On the four beasts</title>
<textLang mainLang="gez"/>
<incipit xml:lang="gez"><locus target="#160v"/>ድርሳን፡ ዘ፬እንስሳ፡ ክቡራን፡</incipit>
</msItem>

<colophon xml:id="coloph1" xml:lang="gez">
        <locus from="167v"/>
        ዝመጽሐፍ፡ ዘእራስ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS8346sahlase">ሣህለ፡ ሥላሴ፡</persName>
         ወአቡሁ፡ <persName ref="https://betamasaheft.eu/PRS10076WasanS">ወልደ፡ ጊዮርጊስ፡ ወሰን፡ ሰገድ፡</persName>
        ወእሙ፡ <persName ref="https://betamasaheft.eu/PRS10604Zannaba">ኢያሲሜር፡ ዘነመ፡ ወርቅ፡</persName> ወጸሐፊሁ፡
        ኃጥእ፡ ወድኩም፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13030AsbaGiyorgis">አስበ፡ ጊዮርጊስ</persName>።
            </colophon>

</msItem>

               <msContents>
                  <summary>Amharic Commentary on Our Father, የአቡነ፡ ዘበሰማያት፡ ትርጓሜ፡, Notes on orders of the rite of baptism and the Mass, in Amharic</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="41v" facs="002">Fols 1r–41v</locus>
                     <textLang mainLang="am" otherLangs="gez">Amharic and Gǝ‘ǝz</textLang>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5934CommOurFather">Amharic
                                                  Commentary on the Our Father</title>
                     <incipit xml:lang="am">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ ብሎ፡ መጽሐፍ፡ እንዲጀምር፡ ጌታችን፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ አንትሙሰ፡ ሶበ፡ ትጸልዩ፡ ከመዝ፡ በሉ፡ አለ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="41v" to="42v" facs="043">Fols 41v–42v</locus>
                      <title>Notes on orders of the rite of baptism and the Mass, in Amharic</title>
                      <textLang mainLang="am" otherLangs="gez"/>
                      <incipit xml:lang="gez">እጽሕፍ፡ ሥርዓተ፡ ቤተ፡ ክርስቲያን፡ ቀዳሽ፡ ቢታጣ፡ ጥምቀት፡<gap reason="omitted"/></incipit>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf"> i + 44 </measure>
                           <measure unit="quire">6</measure>
                           <dimensions type="outer" unit="mm">
                              <height>103</height>
                              <width>72</width>
                              <depth>28</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Quire descriptions: quires 2, 3, 5, 6 balanced; quires 1, 4 unbalanced. Navigation system: brown yarn sewn into corners of <locus target="#1 #9 #16 #24 #42" facs="002 011 018 026 044">fols. 1, 9, 16, 24, 42</locus> to mark the location of miniatures.</note>
                          <list>
                              <item xml:id="q1" n="1">
                                 <dim unit="leaf">9</dim>
                                 <locus from="i" to="8" facs="001">Fols i–8</locus>
                                 <note>A photographic image is apparently missing in the first quire.</note>
                              Quire 1:
                              1, no stub
                            </item>
                              <item xml:id="q2" n="2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="9" to="16" facs="010">Fols 9–16</locus>
                              Quire 2
                            </item>
                              <item xml:id="q3" n="3">
                                 <dim unit="leaf">8</dim>
                                 <locus from="17" to="24" facs="018">Fols 17–24</locus>
                              Quire 3
                            </item>
                              <item xml:id="q4" n="4">
                                 <dim unit="leaf">9</dim>
                                 <locus from="25" to="33" facs="026">Fols 25–33</locus>
                                 <note>A folio stub is visible between <locus target="#26 #27" facs="028">fols. 26, 27</locus>.</note>
                              Quire 4:
                              7, stub after 2
                            </item>
                              <item xml:id="q5" n="5">
                                 <dim unit="leaf">9</dim>
                                 <locus from="34" to="42" facs="035">Fols 34–42</locus>
                                 <note>A folio stub is visible between <locus target="#35 #36" facs="037">fols. 35, 36</locus>.</note>
                              Quire 5:
                              7, stub after 2
                            </item>
                              <item xml:id="q6" n="6">
                                 <dim unit="leaf">2</dim>
                                 <locus from="43" to="44" facs="044">Fols 43–44</locus>
                              Quire 6
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">8</dim>
                              <dim type="bottom">27</dim>
                              <dim type="right">11</dim>
                              <dim type="left">8</dim>
                           </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="11">
                           <locus from="1r" to="42v" facs="002">Fols 1r–42v</locus>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <summary>Miniatures, all in the late twentieth-century hand of the “speckled garment artist,” over the top of text</summary>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                        <desc>
                           <persName ref="https://betamasaheft.eu/PRS6902Matthew">Matthew</persName>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1014Evangelists">Evangelists</ref> with caption <q><foreign xml:lang="gez">ቅዱስ፡ ማቴዎስ።</foreign></q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#8v" facs="010">Fol. 8v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#9r" facs="010">Fol. 9r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> brandishing a <term key="sword" ana="#sword"/></desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#17r" facs="018">Fol. 17r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#25r" facs="026">Fol. 25r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1093TakingRobeofJesus">Taking off the Robe of Jesus</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#43r" facs="044">Fol. 43r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#43v" facs="045">Fol. 43v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> holding orb (or possibly <term key="globe" ana="#globe"/>)
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d8">
                        <locus target="#44r" facs="045">Fol. 44r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/></desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <desc>
                              <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus> Note that the manuscript is on the interpretation of Our Father</desc>
                        </item>
                        <item xml:id="a2">
                           <desc type="OwnershipNote">Note of ownership by <foreign xml:lang="am">አቶ፡ ያዘው፡ ገበየ፡</foreign>, <locus target="#ir(ecto)" facs="001">fol. ir(ecto)</locus>
                           </desc>
                        </item>
                        <item xml:id="a3">
                           <desc>
                              <locus target="#18v #44v" facs="020 046">Fols. 18v, 44v</locus> blank, save for the expression <foreign xml:lang="gez">በስመ፡</foreign> on <locus target="#18v" facs="020">18v</locus>
                           </desc>
                        </item>
                        <item xml:id="a4">
                           <desc>Overlooked words of text are written interlinearly (<locus target="#15v" facs="017">fol. 15v</locus>)</desc>
                        </item>

                        <item xml:id="e1">
                           <desc>Copied in a beautiful hand, but the text is erased in several places to make room for the forged pictures</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>In the images, a photographic image seems to be missing in quire one</desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1800" notAfter="1899">nineteenth century</origDate>
                  </origin>
               </history>

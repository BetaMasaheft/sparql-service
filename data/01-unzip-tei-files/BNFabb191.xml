                                              <history>
                                                 <origin>
                                                   <origDate when="1647">1647</origDate>
                                                  According to <ref target="#coloph1">Colophon 1</ref>, at least a part of the manuscript 
                                                    can be dated to 1647 CE (=1328 according to the Era of Alexander the Great).
                                                    In the present condition of the manuscript, it is difficult to establish whether the parts corresponding to 
                                                   <ref target="#ms_i1.1"/>, <ref target="#ms_i1.2"/> and <ref target="#ms_i1.3"/> 
                                                   were conceived as one manuscript and one unit of circulation, and not as two or even three
                                                   (of what the blank leaves in the midst of the volume might be suggestive). 
                                                 </origin>
                                                 <acquisition>The manuscript entered the <placeName ref="https://betamasaheft.eu/INS0303BNF">Bibliothèque
                                               nationale de France</placeName> in
                                               <date>1902</date>.
                                               </acquisition>
                                              </history>


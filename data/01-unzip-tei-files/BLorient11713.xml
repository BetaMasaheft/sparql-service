                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7321InfantsSus">Baʾǝnta ʾasassǝlo dawe ʾǝm-ḥǝḍānāt</title>
                            <note>Magic prayer for protecting suckling infants and pregnant women, containing an enforcement referring to the 
                                <ref type="work" corresp="https://betamasaheft.eu/LIT1763Legend">legend of Susǝnyos</ref>.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> በስመ፡ ለእግዚአብሔር፡ ሕያው፡ ፈጣሪ፡ ወተናጋሪ፡ ወነባቢ፡ 
                                <sic resp="PRS8999Strelcyn">ጸሎት፡</sic> <choice resp="CH"><sic>፩</sic><corr>ለ</corr></choice> 
                                ቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS9038Susenyos">ሱ<sic resp="PRS8999Strelcyn">ሱ</sic>ንዮስ፡</persName> በእንተ፡ አሰስሎ፡ ደዌ፡
                                እምኵሎሙ፡ ሕፃናት፡ ዕለ፡ ይጠበው፡ ጥበ፡ ወይበቍዕ፡ ዓዲ፡ 
                                ለብ<supplied reason="undefined" resp="PRS8999Strelcyn">እ</supplied>ሲት፡ ፅንስት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7323BaryaCross">Prayer against the pain of Bāryā and Legewon by the virtue
          of the names of the nails of the Cross</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ርኩስ፡ ወርጉም፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4602MagicPr">Magic prayer against various evils</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/>
                                በ<supplied reason="omitted" resp="PRS8999Strelcyn">ቅ</supplied>ድስት፡ ሥላሴ፡ እንዘ፡ አአምን፡ ወእትመኃጸን፡ እክህደከ፡ ሰይጣን፡
                                <choice><sic>በክርኩስ፡</sic><corr>ወቡዳ፡ ርኩስ፡</corr></choice> አርዌ፡ 
                                ቅዳማ<choice><sic resp="PRS8999Strelcyn">ዋ</sic><corr resp="CH">ዊ</corr></choice>፡ ፀረ፡ አቡነ፡ አዳም፡ አንተ፡ 
                                ሰይጣን፡ ለዘሀሎከ፡ ወእንዘ፡ ኢሀሎከ <gap reason="ellipsis"/> አጋንንት፡ ወመናፍስተ፡ ርኩሳን፡ ባርያ፡ ቀይሓን፡ ወባርያ፡ ጸሊማን፡ ወቡዳ፡ መሠርያን፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4604Salot">Ṣalot baʾǝnta ḥǝmāma qʷǝrṣat</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ቍርፀት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7046PrayerColic">Prayer against colic</title>
                            <note>Prayer against stomachache with some variation using <foreign xml:lang="gez">ከርሥ፡</foreign> and 
                                <foreign xml:lang="gez">ሥጋ፡</foreign> instead of <foreign>ቍርፀት፡</foreign> (stomachache).</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ከርሥ፡ ዘይትዋነይ፡ በውስተ፡ ማኅጸን፡ እንዘ፡ ይበጸብፅ፡ ከርሠ፡
                                ወይፈነቅል፡ ቍልፊት፡ ወይጠዊ፡ ኃንጀተ፡ ወአማዑተ፡ ወይደጕፅ፡ ጉበዋተ፡ እምኵሉ፡ ሕማመ፡ ሥጋ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4697MagicPr">Ṣalot baʾǝnta māʾśaromu la-ʾagānǝnt</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ማዕሰሮሙ፡ 
                                ለአጋንንት<supplied reason="omitted" resp="PRS8999Strelcyn">።</supplied> ሰላም፡ ለከ፡ ሰዳዴ፡ አጋንንት፡ ፋኑኤል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7325FourCorners">Ṣalot baʾǝnta maftǝḥe śǝrāy ʾǝlla yǝgabbǝru śǝrāya
          4-maʿāzǝna ʿālam</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡ እለ፡ ይገብሩ፡ ሥራየ፡ ፬መዓዝነ፡ ዓለም፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7327InvocCross">Invocation of the Cross</title>
                            <incipit xml:lang="gez">መስቀል፡ መግረሬ፡ ፀር፡ መስቀል፡ ነሳቴ፡ ፀር፡</incipit>
                        </msItem>
                    </msContents>

         <listPerson>
            <person sex="1" sameAs="wd:Q752011">
               
               <persName xml:lang="gez" xml:id="n1">ሚካኤል፡ ዓሊ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Mikāʾel ʿĀli</persName>
               <persName xml:lang="gez" corresp="#n2" type="alt">ሚካኤል፡ አሊ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Mikāʾel ʾAli</persName>
               <persName xml:lang="gez" xml:id="n3" type="birth">መሐመድ፡ አሊ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Maḥammad ʾAli</persName>
               <persName xml:lang="gez" xml:id="n4" type="horse">አባ፡ ሻንቆ፡</persName>
               <persName xml:lang="gez" corresp="#n4" type="normalized">ʾAbbā Šānqo</persName>
               <persName xml:lang="gez" xml:id="n5" type="baptismal">ሚካኤል፡</persName>
               <persName xml:lang="gez" corresp="#n5" type="normalized">Mikāʾel</persName>
               <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾimām</t:roleName>
               </persName>
               <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">nǝguś</t:roleName>
               </persName>
               <occupation type="ruler">king</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC2575Dase">Dase</placeName>
               </residence>

               <birth notBefore="1847" notAfter="1850">He was born at 
                  <placeName ref="https://betamasaheft.eu/LOC6242WarraH">Wärrä Himäno</placeName> between<date>1847–1850</date>.</birth>
               <floruit notBefore="1870" notAfter="1916">He was an important ruler of <placeName ref="https://betamasaheft.eu/LOC6185Wallo">Walloo</placeName> and 
                  the entire northern Ethiopia. 
                  He was born Muslim and later converted to Christianity after the council of <placeName ref="https://betamasaheft.eu/LOC1980BoruMe">Boru Meda</placeName> in <date>1878</date>, adopting the baptismal name Mikaʾel. 
                  He maintained an alliance with <persName ref="https://betamasaheft.eu/PRS10378Yohanne">ʾaṣe Yoḥannǝs IV</persName> until the emperor’s death in <date>1889</date> at the battle of 
                  <placeName ref="https://betamasaheft.eu/LOC4637Matamm">Matammā</placeName>. 
                  After <persName ref="https://betamasaheft.eu/PRS10378Yohanne">Yoḥannǝs’s</persName> death
                  he declared his submission to <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</persName>
                  to whom he was loyal till the end of his reign. He was one of the military commanders at the 
                  battle of <placeName ref="https://betamasaheft.eu/LOC1264Adwa">ʿAdwā</placeName>.

               </floruit>
               <death when="1916">He was killed at the battle of <placeName ref="https://betamasaheft.eu/LOC5446Sagale">Sagale</placeName> in
                     <date>1916</date>. </death>
            </person>
            
         </listPerson>

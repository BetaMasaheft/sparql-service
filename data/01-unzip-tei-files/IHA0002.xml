               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2r">1r-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0719IHA">نظم إنا نسألك بحق ذاتك العلية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم
                                                  الله الرحمن الرحيم نا نسألك بحق ذاتك العلية
                                                  وبصفاتك السنية وبافعالك المرضية وارزقنا فوز
                                                  الابدية </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>ستر
                                                  الله مسبول علينا وعين الله ناظرة اينا ببركة بسم
                                                  الله الرحمان الرحيم الحمد لله رب العالمين لا اله
                                                  الا الله محمد رسول الله صلى الله عليه و سلم بسم
                                                  الله حرزنا بسم الله كنزنا بسم الله نصرنا نطلب
                                                  ببركة بسم الله الرحمن الرحيم الحمد لله رب العالمين
                                                  لا اله الا الله محمد رسول الله صلى الله عليه وسلم
                                                  اول اخر ظاهر باطن خاتمة بسم الله الرحمن الرحيم
                                                  الحمد لله رب العالمين لا اله الا الله محمد رسول
                                                  الله صلى الله عليه وسلم</explicit>
                     <note>Fol. 1v is blank.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="4r">2v-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0720IHA">مدح النبي ونحمد مولانا على عظم شأنه</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم
                                                  الله الرحمن الرحيم ونحمد مولانا على عظم سأنه/ونثنى
                                                  عليه ان هدانا لدينه؛ ببعث النبي الهاشمي محمد/بأفضا
                                                  ملة وأقوم شرعه ان فاسمعو أني مشير اليكم/بنار قليل
                                                  من معانى كماله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>كذلك
                                                  الاصحاب اصول فرعه/بحق جميع الرسل صفوة خلقه؛ وسلم
                                                  عموم المسلمين بأسرهم/مما يوجب الدخول دار انتقامه؛
                                                  ووفق عموم المسلمين باسرهم/مما يوجب الخلود دار
                                                  سلامه; </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="5r" to="164r">5r-164r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>باب فى
                                                  فضل الصلاة على النبي صلى الله عليه وسلم [...]
                                                  اَللَّهُ عَظَّمَ قَدْرَ جَاهِ مُحَمَّدٍ
                                                  وَأَنَالَهُ فَضْلًا عّلَيْهِ عَظِيْمًا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#164r">-164r</locus>العارف بالله ابو عبد الله محمد بن علي الاسدي
                                                  المعروف بالبلاع صاحب الكرمات المشهورة وكان ملقب
                                                  بالمعمر لانه عمر ماية وثمنين سنة على ما قيل واصلهم
                                                  من قبيلة يقال لهم الخالد مكنهم بنواحي جازان من ارض
                                                  اليمن</explicit>
                     <note>Frequent lexicographic marginal notes;
                                                  marginal notes marking every hundred prayers and
                                                  the completion of half of the text.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="164v" to="165v">164v-165v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0592IHA">قصيدة سفينة النجا لسيد بشرى</title>
                     <incipit xml:lang="ar">
                        <locus target="#164v">-164v</locus>وبسر
                                                  ذاتك يا سيدي وبنور قدسك البهج بوحدة الذات التى
                                                  ظهرت بشئون مختلف مزج</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#165v">-165v</locus>ما
                                                  تلا تال يا ذا الفرج/عجل بالنصر وبالفرج ؛ ما دعا
                                                  داع يا ذا الفرج /رب نجنا من الهرج</explicit>
                     <note/>
                     <note/>
                  </msItem>

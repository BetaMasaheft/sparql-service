               <msContents>
                  <summary/>
                  
                     <msItem xml:id="ms_i1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT4578MagicPr">ጸሎት፡ በእንተ፡ ሱስንዮስ፡ ዘያሰስል፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ወበእንተ፡ መጋኛ፡ ወጉሥምት፡</title> 
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሱስንዮስ፡ ዘያሰስል፡ ሕማ<supplied reason="undefined" resp="PRS9622Ullendor">መ</supplied>፡ 
                           ባርያ፡ ወሌጌዎን፡ ወበእንተ፡ መጋኛ፡ ወጉሥምት፡</incipit>
                     </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title> 
                     
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሱስንዮስ፡ በእንተ፡ አሰስሎ፡ ደዌ፡ እምሕፃናት፡</incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4579MagicPr">ጸሎት፡ በእንተ፡ ሕማመ፡ በሽታ፡ አበስኢሎን፡</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ በሽታ፡ አበስኢሎን፡</incipit>
                     <note>The prayer is followed by other magical words.</note>
                  </msItem>
                  </msContents>
                     

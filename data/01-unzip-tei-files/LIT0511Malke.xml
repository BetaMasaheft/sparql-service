      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0511</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እዌጥን፡ እንከ፡ ነገረ፡ ህላዌከ፡ በአምኆ፨</l>
                  <l n="2">ከመ፡ ስብሐቲከ፡ ይነግር፡ አፈ፡ ዚአየ፡ በከልሆ፨</l>
                  <l n="3">ኢያቄም፡ አቡነ፡ ዘልማድከ፡ ተራኅርኆ፨</l>
                  <l n="4">ዕቀብ፡ ፍቁራኒከ፡ በዘዚአከ፡ የውሆ፨</l>
                  <l n="5">እስመ፡ እምእዴከ፡ ይትረከብ፡ ዘሰማይ፡ መርሖ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምከ፡ ቅዱስ፨</l>
                  <l n="2">ለሥዕርተ፡ ርእስከ፡ ካዕበ፡ ወለርእስከ፡ ውዱስ፨</l>
                  <l n="3">ኢያቄም፡ አንተ፡ ዘእምዘርአ፡ ዳዊት፡ ንጉሥ፨</l>
                  <l n="4">በሎሙ፡ ለአብያጺከ፡ እለ፡ ሀለዉ፡ በነፍስ፨</l>
                  <l n="5">ለሐውጾ፡ ዐርክየ፡ ንዑ፡ በዛቲ፡ መቅደስ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በልብሰ፡ ሰንዱናት፡ ሠናያን፨</l>
                  <l n="2">እንተ፡ ገነዝዎ፡ ጥቀ፡ ካህናተ፡ ብሌት፡ ኄራን፨</l>
                  <l n="3">ወመቃብሪከ፡ ዘኮነ፡ በምድረ፡ ዮፍኒ፡ መካን፨</l>
                  <l n="4">በከዩ፡ ወለሐዉ፡ ሕዝበ፡ እስራኤል፡ ጻድቃን፨</l>
                  <l n="5">በጊዜ፡ ሞትከ፡ ኢያቄም፡ ወረደ፡ ብርሃን፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ተወከፍ፡ ዘአቅረብኩ፡ ስብሐተ፡ አምኃ፨</l>
                  <l n="2">ህየንተ፡ አፍቅሮትየ፡ ባሕቱ፡ እስመ፡ ኢኮነ፡ ብዙኀ፨</l>
                  <l n="3">ኢትግድፍ፡ ወኢታንትግ፡ ዘስብሐቲከ፡ ረባሐ፨</l>
                  <l n="4">ሀበኒ፡ ዐስበ፡ ጻማየ፡ ለጸማድከ፡ ፍሩህ፨</l>
                  <l n="5">ወሃቤ፡ ሕይወት፡ ኢያቄም፡ ሰርከ፡ ወነግሀ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ኦኢያቄም፡ ኦኢያቄም፡ ኦመተንብል፨</l>
                  <l n="2">በዓለ፡ ሞገስ፡ ዘኮንከ፡ እምኀበ፡ ክርስቶስ፡ ልዑል፨</l>
                  <l n="3">ይዕቀበነ፡ ወትረ፡ ትንብልናከ፡ ለለ፡ መዋዕል፨</l>
                  <l n="4">በእንተ፡ ማርያም፡ ወለትከ፡ ሰውረነ፡ እምሀጕል፨</l>
                  <l n="5">ወአድኅን፡ ነፍሳተነ፡ እመንሱት፡ ኀያል፨</l>
               </lg>
            </div>
         </div>
      </body>

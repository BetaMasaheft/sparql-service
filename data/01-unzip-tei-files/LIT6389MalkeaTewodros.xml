            <div type="bibliography"><listBibl type="editions">
                <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl></div>
            
            <div type="edition" xml:lang="gez"><note>from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">በስመ፡ እግዚአብሔር፡ ወሃቤ፡ ጥበብ፡ ለጠቢባነ፡ ምድር፡ ኵሉ፨</l>
                        <l n="2">ወምሥጢረ፡ ስብሕት፡ ዘይከሥት፡ ለኃይላተ፡ ብርሃን፡ ዘላዕሉ፨</l>
                        <l n="3">ቅድመ፡ ጉቡኣን፡ አነብብ፡ መልክአ፡ ቴዎድሮስ፡ በበ፡ አምሳሉ፨</l>
                        <l n="4">እንተ፡ ተለወ፡ ድኅሬሁ፡ በአሰረ፡ ቅዱስ፡ መስቀሉ፨</l>
                        <l n="5">ለዋሕድ፡ ወልዱ፡ ጥበቡ፡ ወቃሉ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሆህያቲሁ፡ ኃምስ፨</l>
                        <l n="2">ወለሥዕርትከ፡ ሰላም፡ ወለርእስከ፡ ውዱስ፨</l>
                        <l n="3">ቴዎድሮስ፡ ኀያል፡ ዘዲበ፡ ሠራዊት፡ ርእስ፨</l>
                        <l n="4">አንጽሐኒ፡ እግዚእየ፡ እምደነሰ፡ ሥጋ፡ ወነፍስ፨</l>
                        <l n="5">በማየ፡ ደምከ፡ ማየ፡ ጸጋ፡ ዘመንፈስ፡ ቅዱስ፨</l>
                    </lg>
                    <lg type="stanza" n="27">
                        <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ኅሩያን፡ ካህናት፨</l>
                        <l n="2">ወለመቃብሪከ፡ ሰላም፡ ምልእተ፡ በረከት፨</l>
                        <l n="3">ቢጸ፡ ምሥራቃዊ፡ ቴዎድሮስ፡ ዘእምሠራዊት፨</l>
                        <l n="4">አስተዳሉ፡ መካነ፡ ብዕል፡ ኀበ፡ ተርኅወ፡ ገነት፨</l>
                        <l n="5">ለፍቁራኒከ፡ ዘጸገወ፡ ሀብት፨</l>
                    </lg>
                    <lg type="stanza" n="28">
                        <l n="1">አምጣነ፡ ብየ፡ ኅዳጠ፡ አቅረብኩ፡ ለከ፡ ስባሔ፨</l>
                        <l n="2">በጽዋዐ፡ ስምከ፡ አፈወ፡ ርኄ፨</l>
                        <l n="3">ቴዎድሮስ፡ ፍትው፡ ወጥዑመ፡ ዝክር፡ ውስተ፡ ኵለሄ፨</l>
                        <l n="4">ተወከፍ፡ ማሕሌትየ፡ ቅድመ፡ ገጸ፡ አምላክ፡ ኤሎሄ፨</l>
                        <l n="5">ከመ፡ መሥዋዕተ፡ ኖኅ፡ ውኩፍ፡ ወጻድቅ፡ ማኑሄ፨</l>
                    </lg>
                </div>
            </div>
            
            <div type="edition">
              <note>the text follows <ref type="mss" corresp="https://betamasaheft.eu/EMIP00764">Ḉäläqot, Č̣alaqot Śǝllāse, Chelekot Silasie 23</ref> ff. 92r-94r</note>
              <div type="textpart" subtype="incipit" xml:lang="gez">
                <ab>
                  በስመ፡ እግዚአብሔር፡ ወሀቤ፡ ጥበብ፡ ለጠቢባነ፡ መድር፡ ኵሉ።
                  ወምሥጢረ፡ ስብሕት፡ ዘይከሥት፡ ለኃያላተ፡ ብርሃን፡ ዘላዕሉ።
                  ቅድመ፡ ጉቡኣን፡ አነብብ፡ መልክአ፡ ቴዎድሮስ፡ በበአምሳሉ።
                  እንተ፡ ተለወ፡ ድኅረኢሁ፡ በአሰረ፡ ቅዱስ፡ መስቀሉ።
                </ab>
              </div>
              <div type="textpart" subtype="explicit" xml:lang="gez">
                <ab>
                  ቴዎድሮስ፡ ፍትው፡ ወጥዑመ፡ ዝክር፡ ውስተ፡ ኵለሄ።
                  ተወከፍ፡ ማኅሌትየ፡ ቅድመ፡ ገጸ፡ አምላክ፡ ኤሎሄ።
                  ከመ፡ መሥዋዕተ፡ ኖኅ፡ ውኩፍ፡ ወጻድቅ፡ ማኑሄ።
                </ab>
              </div>
            </div>
          
        </body>
    </text></TEI>
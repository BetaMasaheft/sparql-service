         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ጐሥዐ፡ ልብየ፡ ቃለ፡ ሠናየ፨</l>
                  <l n="2">ከመ፡ እዜኑ፡ ግብረከ፡ ሊቃኖስ፡ አቡየ፨</l>
                  <l n="3">እስመ፡ ፍቅርከ፡ ሐፀነኒ፡ እምከርሠ፡ እምየ፨</l>
                  <l n="4">ሢም፡ እግዚኦ፡ ዐቃቤ፡ ለአፉየ፨</l>
                  <l n="5">ወማዕፆ፡ ዘዐቅሞ፡ ለከናፍርየ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተሴረከ፡ ፊደሉ፨</l>
                  <l n="2">በጽላተ፡ ሰማይ፡ ዘላዕሉ፨</l>
                  <l n="3">ሊቃኖስ፡ ቅዱስ፡ መትልወ፡ ቅዱሳን፡ ኵሉ፨</l>
                  <l n="4">መፍትው፡ ዘልፈ፡ ደቂቅከ፡ በእንቲአከ፡ ይብሉ፨</l>
                  <l n="5">ዝክረ፡ ጻድቅ፡ ለዓለም፡ ይሄሉ፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ኣየድዕ፡ አንሰ፡ ዘምስለ፡ ግናይ፡ ለክሳድከ፡ ሰላማ፨</l>
                  <l n="2">ወበአፈ፡ ለብየ፡ እስዕማ፨</l>
                  <l n="3">ሊቃኖስ፡ አንተ፡ ለማኅቶትየ፡ ተቅዋማ፨</l>
                  <l n="4">ፌማ፡ ፌማ፡ ሶበ፡ አፍቀረከ፡ ፌማ፨</l>
                  <l n="5">በክሳድከ፡ ወደየ፡ አስኬማ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ኦአቡየ፡ ሊቃኖስ፡ ለአብራኪከ፡ ሰላም፡ እብሎሙ፨</l>
                  <l n="2">ዕሥራ፡ ዓመተ፡ ወኀምስቱ፡ እለ፡ በእንተ፡ ጽድቅ፡ ደክሙ፨</l>
                  <l n="3">ንጉሠ፡ እስራኤል፡ ዳዊት፡ በከመ፡ ይቤ፡ ቀዲሙ፨</l>
                  <l n="4">እንዘ፡ እግዚአብሔር፡ በኀይለ፡ መንፈሱ፡ ያጸንዖሙ፨</l>
                  <l n="5">ለጻድቃን፡ ብዙኅ፡ ሕማሞሙ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ወለዝኅርከ፡ ሐዲስ፨</l>
                  <l n="2">ዐፀደ፡ ፍሥሓ፡ ወሞገሥ፨</l>
                  <l n="3">ሊቃኖስ፡ ጠቢብ፡ ሊቀ፡ ደናግል፡ ኃምስ፨</l>
                  <l n="4">ጸግወኒ፡ አባ፡ በረከተ፡ አስማት፡ ሠላስ፨</l>
                  <l n="5">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ኀበ፡ ተቀብረ፡ ሥጋሁ፡ ለክርስቶስ፡ ቃል፨</l>
                  <l n="2">ከመ፡ ኢተረክበ፡ ዐፅሙ፡ እምድኅረ፡ ሠላስ፡ መዋዕል፨</l>
                  <l n="3">እንበለ፡ ዳዕሙ፡ መግነዙ፡ ወሰበነ፡ ርእሱ፡ ጥብሉል፨</l>
                  <l n="4">በድነ፡ ሥጋከ፡ ከማሁ፡ ሊቃኖስ፡ ኮል፨</l>
                  <l n="5">ኢትረክበ፡ በውስተ፡ ዝኅር፡ ለከሢተ፡ መንክር፡ ወኀይል፨</l>
                  <l n="6">እስመ፡ እምኀበ፡ አብ፡ ኮነ፡ ሕይወትከ፡ ጠል፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ስብሐት፡ ለእግዚአብሔር፡ ፈጽሞ፡ ዘአክሀለኒ፨</l>
                  <l n="2">በኀይለ፡ መንፈሱ፡ ቅዱስ፡ እንዘ፡ ይረድአኒ፨</l>
                  <l n="3">ሊቃኖስ፡ ምልክያስ፡ ዘካዕበተ፡ ስምከ፡ ተምዐኒ፨</l>
                  <l n="4">ውዳሴ፡ መልክእከ፡ ዝንቱ፡ እምነ፡ ኵሉ፡ ዘይሤኒ፨</l>
                  <l n="5">መባአኒ፡ ወቍርባነኒ፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ኣእኵቶ፡ ለእግዚአብሔር፡ ወዘልፈ፡ እባርኮ፨</l>
                  <l n="2">በሰጊድ፡ ወአስተባርኮ፨</l>
                  <l n="3">እስመ፡ ድልወ፡ ረስየኒ፡ ለነቢብ፡ ወሴርኮ፨</l>
                  <l n="4">ዜና፡ ዝክርከ፡ ሊቃኖስ፡ እምልበ፡ አእሩግ፡ ዘሠወርኮ፨</l>
                  <l n="5">እስከ፡ በአፉየ፡ ይትከሠት፡ ሠመርኮ፨</l>
               </lg>
               <lg type="stanza" n="55">
                  <l n="1">ስብሐት፡ ለእግዚአብሔር፡ ዘአክሀለኒ፡ ፈጽሞ፨</l>
                  <l n="2">ዜና፡ ዝክርከ፡ ዘወጠንኩ፡ በጽሒቅ፡ ወአስተሐምሞ፨</l>
                  <l n="3">ሊቃኖስ፡ ጠቢብ፡ መዝገበ፡ ትዕግሥት፡ ወአርምሞ፨</l>
                  <l n="4">ለቃለ፡ አፉየ፡ ውስተ፡ ልብከ፡ ሕትሞ፨</l>
                  <l n="5">ከመ፡ ቃለ፡ ነጐድጓድ፡ ሐተመ፡ ዮሐንስ፡ በፍጥሞ፨</l>
               </lg>
            </div>
         </div>
         
      </body>
   </text></TEI>
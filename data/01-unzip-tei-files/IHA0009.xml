                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="1v">1v-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0017IHA">كشف الكروب بمناجاة الحبيب والتوسل بالمحبوب</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>||بسم الله الرحمن الرحيم|| يا اكرم الخلق ودق ضاقت بي السبل |ورق عظمي وغابت عني الحيل
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>صلى علينا لهم دائما ابدا| ما ان تعاقبت الضحوات والاصل|| والك الغر والصحب الْكرام كذا| مسلما والسلام الطيب الحفل</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="192v">2v-192v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0014IHA">شرح القاري على تخميس الوترية</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم رب انعمت فزد يا كريم الحمدلله الوتر الفرد الواحد الاحد الصمد الذي لم يلد ولم يولد ولم يكن له كفوا احد القديم الباقي في الازد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#192r-192v">-192r-192v</locus>تمت فرغ على يد مولفه الراجي كرم ربه البارئ على بن سلطان محمد الهروي القارئ عاملهما الله باطفة الحقي وكرمه الوفي يوم الاثنين منتصف شهر شعبان المعظم من سلك شهور عام تسع بعد الهجرة النبي المعظم والرسول المكرم وذلك بمكة المكرمة تجاه الكعبة المعظمة والحمد لله الذي بنعمته تتم الصالحات وانتهى الحاجات والمرادات الحمد لله رب العالمين  </explicit>
                     <note>
- The folios 30v and 31v are blurred.
</note>
                     <note/>
                  </msItem>

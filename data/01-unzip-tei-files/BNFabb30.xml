                             <locus from="3ra" to="47rc"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT1340EnochE">Henok</title>
                             <incipit xml:lang="gez"><hi rend="rubric">ዘሄኖክ፡ ነቢይ፡ ቃለ፡ በረከት፡</hi> ዘከመ፡ ባረከ፡
                               ኅሩ<hi rend="rubric">ያነ፡ ወጻድቃነ፡ እለ፡ ሀ</hi>ለዉ፡ ይኩኑ፡ በዕለተ፡ ም<hi rend="rubric">
                               ንዳቤ፡ ለአሰስሎ፡ ኲሎ፡</hi> እኩያን፡ ወረሲዓን፨</incipit>
                             <explicit xml:lang="gez">ወየሐውሩ፡ እሙንቱሂ፡ በኀበ፡ ተጽሕፈ፡ ሎሙ፡ መዋዕል፡ ወአዝማን፨</explicit>

                             <note>The division into parts is indicated by the word <foreign xml:lang="gez">ክፍ</foreign> or

                             <foreign xml:lang="gez">ክፍል</foreign>, rubricated, without any number.
                             </note>
                                </msItem>


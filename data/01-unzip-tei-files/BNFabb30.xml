                            <msItem xml:id="ms_i2.1">
                            <locus from="47ra" to="67va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2195Prover">Proverbs</title>



                            <msItem xml:id="ms_i2.1.1">
                            <locus from="47ra" to="63vc"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3927Messale">Mǝssālǝyāta Salomon</title>
                            <incipit xml:lang="gez"><hi rend="rubric">ምሳልያተ፡ ሰሎሞን፡ ወ</hi>ልደ፡ ዳዊት፡ ዘነግሠ፡
                            ለ<hi rend="rubric">እስራኤል፡ በኢየሩሳሌ</hi>ም፨ ክፍል፩፡ ለአእምሮ፡ ተመይጦ፡ ቃል፡</incipit>
                            <explicit xml:lang="gez">ፍታሕ፡ ለነዳይ፡ ወለሕሙም፨</explicit>
                            <note>Proverbs of Solomon. The division into parts is indicated by the rubricated
                             word<foreign xml:lang="gez">ክፍል</foreign> followed by the numbers 1 to 50.</note>
                            </msItem>

                              <msItem xml:id="ms_i2.1.2">
                              <locus from="63vс" to="67rc"/>
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2396Tagsas">Tagśāṣa Salomon</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                              <hi rend="rubric">ተግሣጸ፡ ሰሎሞን፡ እሉ፡ እንበለ፡
                               ኑፋቄ፡ ዘጸሐፉ፡</hi> አዕርከቲሁ፡ ለሕዝቅያስ፡
                              ንጉሠ፡ ይሁዳ፨ ክፍል፩፡ ክብረ፡ እግዚአብሔር፡ የሀብእ፡ ነውረ፡
                              ወስብሐተ፡ ንጉሥ፡ ያከብር፡ ገብረ፡ ወየሐትት፡ ነገረ፨
                              </incipit>
                              <explicit xml:lang="gez">ሀብዋ፡ እምፍሬ፡ ከናፍሪሃ፡ ወይትአኰት፡ በአናቅጽ፡ ምግባራ፨</explicit>
                              <note>Admonition of Solomon. The division into parts is indicated by the rubricated word
                              word <foreign xml:lang="gez">ክፍል</foreign> followed
                                by the numbers 1 to 7.
                            </note>
                            </msItem>


                            <msItem xml:id="ms_i2.2">
                            <locus from="67va" to="81ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2516Wisdom">Ṭǝbaba Salomon</title>
                            <incipit xml:lang="gez"><hi rend="rubric">ጥበበ፡ ሰሎሞን፡ ወልደ፡ ዳዊት፡ ዘነግሠ፡
                             ለ፳ኤል፡ አፈቅርዋ፡ ለጽድቅ፡ </hi>መኳንንተ፡ ምድር። ወሐልዩ፡ ኃይለ፡ እግዚአብሔር፡</incipit>
                            <explicit xml:lang="gez">በኵሉ፡ ጊዜ፡ ወበኵሉ፡ መካን፡ እንተ፡ ትሄሉ፡ ህየ፨
                            </explicit>

                            <note>The division in parts is indicated by the rubricated

                            word <foreign xml:lang="gez">ክፍል</foreign> followed by the numbers 1 to 18.</note>
                            </msItem>

                            <msItem xml:id="ms_i2.3">
                              <locus from="81vb" to="88vc"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1320Eccles">Ecclesiastes</title>
                              <incipit xml:lang="gez"><hi rend="rubric">ክፍል፡ ይቤ፡ መክብብ፡ ወልደ፡ ዳዊት፡ ዘነግሠ፡
                              ለእስ፡</hi>ራኤል፡ በኢየሩሳሌም፡ ከንቱ፡ ከንቱ፡ ከንቱ፡ ኵሉ፡ ይቤ፡ መክብብ፡
                              ኵሉ፡ ከንቱ፡ ምንት፡ ፍድፋዴሁ፡ ለሰብእ፡</incipit>
                              <explicit xml:lang="gez">እመሂ፡ ሠናየ፡ ወእመሂ፡ እኩየ፨
                              </explicit>

                              <note>The division into parts is indicated  by the
                              rubricated word <foreign xml:lang="gez">ክፍል</foreign> followed by the numbers 1 to 11. Fol. 88v
                              is left blank.</note>
                            </msItem>
                          </msItem>



                             <msItem xml:id="ms_i3">
                              <locus from="89ra" to="111vc"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1688Job">Book of Job</title>
                              <incipit xml:lang="gez"><hi rend="rubric">ወሀሎ፡ ፩ብእሲ፡ በብሔረ፡</hi> አውሲጢድ፡ ዘስሙ፡
                              ኢዮ<hi rend="rubric">ብ፡ ወውእቱ፡ ብእሲ፡ ራትዕ፡ </hi>ወንጹሕ፡ ወጻድቅ፡ ወፈራ<hi rend="rubric">ሄ፡
                              እግዚአብሔር፨</hi></incipit>
                            <explicit xml:lang="gez">ወእለ፡ መጽኡ፡ አዕርከቲሁ፡ ዘእምደቂቀ፡ ኤሳው፡ ኤልፍዝ፡ ንጉሠ፡ ቴማን፡
                            ወበልዳዶስ፡ አውኬናዊ፡ መስፍን፡ ወሳፍር፡ ንጉሠ፡ አሜናዊ፨ </explicit>
                            <colophon xml:lang="gez" xml:id="coloph1">
                              <locus target="#111vc"/>
                            ዝንቱ፡ መጽሐፍ፡ ተተርጐመ፡ በሶርያ፤ ተፈጸመ፡ ዘኢዮብ፡ ነቢይ፡ ስብሐት፡ ለእግዚአብሔር፡ አሜን፨</colophon>
                          <note>The division into parts is indicated  by the rubricated word <foreign xml:lang="gez">ክፍል</foreign> followed by
                          numbers 1 to 43.</note>
                          </msItem>

                          <msItem xml:id="ms_i4">
                           <locus from="112ra" to="147vc"/>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT1315Dodeka">Daqiqa nabiyāt</title>


                            <msItem xml:id="ms_i4.1">

                           <locus from="112ra" to="118rb"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT3144Hosea">Book of Hosea</title>
                              <incipit xml:lang="gez"><hi rend="rubric">ቃለ፡ እግዚአብሔር፡ ዘኮ</hi>ነ፡ ኀበ፡ ሆሴአ፡ ወልደ፡ ቦኤር<hi rend="rubric">ም፡ በመዋዕለ፡ ዖዝያን፡ ወ</hi>ዮአታም፡ ወአከዝ፡ 
                                ወሕዝ<hi rend="rubric">ቅያስ፡ ነገሥተ፡ ይሁዳ፡ ወ</hi>በመዋዕለ፡ ኢዮርብአም፡ ወልደ፡ ዮአስ፡</incipit>
                              <explicit xml:lang="gez">ለእግዚአብሔር፡ ጻድቃን፡ የሐውርዎን፡ ወኃጥአንስ፡ ይሰዕንዎን፡፡
                        </explicit>
                          <colophon xml:lang="gez" xml:id="coloph2">
                            <locus target="#118rb"/>
                            ተፈጸመ፡ ዘሆሴዕ፡ ነቢይ፨ በረከተ፡ አምላኩ፡ ትኩን፡ ምስለ፡ ገብሩ፡ <hi rend="rubric">መዝራዕተ፡ ክርስቶስ፡</hi>
                            ለዓለመ፡ ዓለም፨
                          </colophon>

                          <note>Only one indication to the part division,

                            <locus target="#115rb"/>.</note>

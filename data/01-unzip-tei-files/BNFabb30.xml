                        <msItem xml:id="ms_i4.2">
                         <locus from="118rb" to="123rb"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT3145Amos">Book of Amos</title>
                     <incipit xml:lang="gez"><hi rend="rubric">ዘአሞጽ፡ ነቢይ፡ ቃለ፡ እግዚአብሔር፡ ዘኮነ፡ ላዕለ፡ አሞጽ፡ ዘአቃሬም፡ ዘቴቅሑ፡</hi>
                     ዘርእየ፡ በእንተ፡ እስራኤል፡ በመዋዕለ፡ ዖዝያን፡</incipit>
                        <explicit xml:lang="gez">እንተ፡ ወሀብከዎሙ፡ አነ፡ ይቤ፡ እግዚአብሔር፡ አምላክ፡ ዘኵሎ፡ ይመልክ፨
                        </explicit>
                        <colophon xml:lang="gez" xml:id="coloph3">
                          <locus target="#123rb"/>
                        ተፈጸመ፡ ዘአሞጽ፡ ነቢይ፨ በረከተ፡ አምላኩ፡ ትኩን፡ ምስለ፡ ዓመቱ፡ <hi rend="rubric">ምልእተ፡ ጸጋ፡</hi>
                        ለዓለመ፡ ዓለም፨
                        </colophon>

                        <note>The division into parts is indicated  by the rubricated word <foreign xml:lang="gez">ክፍል</foreign> followed by

                        numbers 1 to 19.</note>
                      </msItem>

                      <msItem xml:id="ms_i4.3">
                       <locus from="123rb" to="127ra"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT3146Micah">Book of Micah</title>
                         <incipit xml:lang="gez"><hi rend="rubric">ወኮነ፡ ቃለ፡ እግዚአብሔር፡ ኀበ፡ ሚክያስ፡ ወልደ፡
                     ሞራት።</hi> በከመዋእለ፡ ኢዮአታም፡ ወአካዝ፡ ወሕዝቅያስ፡ ነገሥተ፡ ይሁዳ፡</incipit>
                      <explicit xml:lang="gez">በከመ፡ መሐልከ፡ ለአባዊነ፡ በመዋዕለ፡ ታካት፨
                      </explicit>
                      <colophon xml:lang="gez" xml:id="coloph4">
                        <locus target="#123rb"/>
                      ተፈጸመ፡ ዘሚክያስ፡ ነቢይ፨ በረከተ፡ አምላኩ፡ የሃሉ፡ ምስለ፡ ገብሩ፡ <hi rend="rubric">መዝራዕተ፡ ክርስቶስ፡</hi>
                      ለዓለመ፡ ዓለም፨
                      </colophon>

                      <note>The division into parts is

                        indicated by the rubricated word <foreign xml:lang="gez">ክፍል</foreign> followed by
                      numbers 1 to 12.</note>
                      </msItem>

                    <msItem xml:id="ms_i4.4">
                     <locus from="123rb" to="129rb"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1689Joel">Book of Joel</title>
                       <incipit xml:lang="gez"><hi rend="rubric">ቃለ፡ እግዚአብሔር፡ ዘኮነ፡ ኀበ፡ ኢዮኤል፡ ወልደ፡
                   ባ</hi>ቱኤል፡ ስምዑ፡ ዘንተ፡ ሊቃውንተ፡ ቤተ፡ እስራኤል፡ ወአጽምዑ፡ ኵልክሙ፡</incipit>
                    <explicit xml:lang="gez">እስመ፡ አነ፡ እግዚአብሔር፡ ዘአኃድር፡ ውስተ፡ ጽዮን፨
                    </explicit>
                    <colophon xml:lang="gez" xml:id="coloph5">
                      <locus target="#129rb"/>
                    ተፈጸመ፡ ዘኢዮኤል፡ ነቢይ፨</colophon>


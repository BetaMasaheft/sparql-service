            <person sex="1" sameAs="wd:Q1344575">
               <persName>
                  
                  <forename>Francisco</forename>
                  <surname>Alvares</surname>
               </persName>
               
               
               
         
               <occupation type="ecclesiastic">a priest</occupation>
               <nationality type="Portugal"/>
               <faith type="Catholicism"/>
               <birth when="1460"/>
               <residence>He was in the court of King <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName> 
                  for six years</residence>
               <floruit notBefore="1520" notAfter="1542">. He wrote a lengthy account 
                  of his eventual six year stay <date> 1520-1526 </date> in highland Ethiopia, the first comprehensive original work.
              </floruit>
               <death> He died before <date>1542</date>
               </death>
            </person>
            

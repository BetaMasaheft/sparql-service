      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0515</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለክሙ፡ እለ፡ ደብረ፡ ዴጐ፡ ቅዱሳን፨</l>
                  <l n="2">አንትሙ፡ ውእቱ፡ ዘመንፈስ፡ ቅዱስ፡ አስከሬን፨</l>
                  <l n="3">ማእከሌክሙ፡ ረፈቀ፡ እሳተ፡ መለኮት፡ ርሱን፨</l>
                  <l n="4">ዜና፡ ዕረፍትክሙ፡ ምዕዘኒ፡ ከመ፡ ወግረ፡ ስኂን፨</l>
                  <l n="5">መዐዛክሙ፡ ጥዕመኒ፡ ከመ፡ ዘሴሬቅ፡ ወይን፨</l>
                  <l n="6">ትንባሌክሙ፡ ይኩነኒ፡ ምዕዳወ፡ እምደይን፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ያመጽኡ፡ አምኃሁ፡ እምናቤዎን፡ ሐርጌ፨</l>
                  <l n="2">ለዘቤተ፡ ልሔም፡ ተወልደ፡ እምድንግል፡ ጽጌ፨</l>
                  <l n="3">ሊቃውንት፡ ዘበክብር፡ አዕማደ፡ እግዚኡ፡ ለሐጌ፨</l>
                  <l n="4">አምሰጡ፡ በትዕግሥቶሙ፡ እምነ፡ ዘሰይጣን፡ ዝንጓጌ፨</l>
                  <l n="5">ወለማኅበሮሙ፡ አልቦቱ፡ ኑታጌ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘሐዋዝ፡ ጥቀ፨</l>
                  <l n="2">ለዘይሰምዕ፡ በእዝኑ፡ ወበኅሊናሁ፡ ጥንቁቀ፨</l>
                  <l n="3">ጻድቃን፡ ዘዴጐ፡ ዕበይክሙ፡ ተአውቀ፨</l>
                  <l n="4">እመ፡ በትሕትና፡ ማእከሌክሙ፡ ረፈቀ፨</l>
                  <l n="5">ሊቀ፡ ጠቢባን፡ ክርስቶስ፡ ዘይሜህር፡ ጽድቀ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለቆምክሙ፡ ለዕፀ፡ በቀልት፡ አምሳሉ፨</l>
                  <l n="2">ወለመልክእክሙ፡ ሰላም፡ ዘፍትው፡ በኀበ፡ ኵሉ፨</l>
                  <l n="3">ጻድቃን፡ ዘዴጐ፡ በእንቲአነ፡ ሰአሉ፨</l>
                  <l n="4">በአስተሐምሞ፡ አልባቢክሙ፡ አልዕሉ፨</l>
                  <l n="5">ወልብክሙ፡ በሰማይ፡ የሀሉ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">እግዚአብሔር፡ አምላክነ፡ አመ፡ ሐወጸ፡ እምሰማይ፨</l>
                  <l n="2">ማእከሌክሙ፡ ረፈቀ፡ በአምሳለ፡ ብእሲ፡ ነዳይ፨</l>
                  <l n="3">ጻድቃን፡ ዘዴጐ፡ ለወልድክሙ፡ ሐካይ፨</l>
                  <l n="4">ሥረዩ፡ ኀጢአትየ፡ ወብዝኀ፡ እኪት፡ ጌጋይ፨</l>
                  <l n="5">እስመ፡ ይኄይስ፡ ፍቅርክሙ፡ እምብዙኅ፡ ንዋይ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ሰላም፡ እንዘ፡ እብል፡ ኪያክሙ፨</l>
                  <l n="2">ብርሃናተ፡ ዓለም፡ ጽዱላን፡ እኤምኀክሙ፨</l>
                  <l n="3">ጻድቃን፡ ዘዴጐ፡ እለ፡ ጻመውክሙ፡ በእንተ፡ ስሙ፨</l>
                  <l n="4">ምስለ፡ አቤል፡ መምህረ፡ ሕግ፡ ዘማሕተመ፡ ኂሩት፡ ማሕተሙ፨</l>
                  <l n="5">አፍቀረነ፡ እግዚእ፡ ወሊባኖስ፡ ለብርሃን፡ ተቅዋሙ፨</l>
               </lg>
            </div>
         </div>
      </body>

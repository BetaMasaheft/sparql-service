         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ኣቀድም፡ እንዘ፡ እተሉ፡ አእኵቶ፨</l>
                  <l n="2">እስመ፡ አብዝኀ፡ ላዕሌኪ፡ ወአፈድፋደ፡ ስብሐቶ፨</l>
                  <l n="3">ጸበለ፡ ማርያም፡ እስብክ፡ ዜና፡ ውዳሴኪ፡ በኢያስትቶ፨</l>
                  <l n="4">ሥመሪ፡ ቃለ፡ አፉየ፡ ወተወከፉ፡ ሰእለቶ፨</l>
                  <l n="5">አምኃ፡ ሰላም፡ ዘይሁበኪ፡ ኢይኩን፡ ከንቶ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ በዜና፡ ቃለ፡ ጽድቅ፡ ዘተባየጾ፨</l>
                  <l n="2">ለስመ፡ ማርያም፡ ድንግል፡ ዘኢረከባ፡ ተዐቅጾ፨</l>
                  <l n="3">ጸበለ፡ ማርያም፡ እንግር፡ ስብሐቲከ፡ በኢያሕጽጾ፨</l>
                  <l n="4">ጸግውኒ፡ ብዕለ፡ ጥበብ፡ ወሐውጽኒ፡ ሐውጾ፨</l>
                  <l n="5">ለግዘዘ፡ ጌጋይ፡ ዘልብየ፡ ጻማኪ፡ ይቅፍጾ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለቆምኪ፡ ወለመልክእኪ፡ በበ፡ ፍቅዱ፨</l>
                  <l n="2">በሥርጐ፡ ሰማያት፡ ወሥን፡ እለ፡ ተሠርገዋ፡ ለለ፡ አሐዱ፨</l>
                  <l n="3">ለእግዚአብሔር፡ ጸባኦት፡ ጸበለ፡ ማርያም፡ ታቦተ፡ ወልዱ፨</l>
                  <l n="4">ለነፍስየ፡ ሶበ፡ አጽሀባ፡ ለቀላየ፡ ጌጋይ፡ ሞገዱ፨</l>
                  <l n="5">ውስተ፡ መንገለ፡ ዛህን፡ ወመርስ፡ በክንፍኪ፡ ዕዱ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስኪ፡ ዘጽፍሮሁ፡ ነኪር፨</l>
                  <l n="2">ወለርእስኪ፡ ድሉል፡ በቅብአ፡ ሃይማኖት፡ ደብር፨</l>
                  <l n="3">ጸበለ፡ ማርያም፡ ጠባብ፡ ከአ፡ አርዌ፡ ምድር፨</l>
                  <l n="4">ወዓዲ፡ ከመ፡ ርግብ፡ ጸወሪተ፡ ክሥራት፡ መጾር፨</l>
                  <l n="5">በክንፈ፡ ምግባራት፡ ከመ፡ ትስርሪ፡ ውስተ፡ ዖፍ፡ ዘፍቅር፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">እማኀፈደ፡ ሥጋ፡ ጊዜ፡ ትወፅእ፡ ጸበለ፡ ማርያም፡ ነፍስኪ፡ እንበለ፡ ጻዕር፨</l>
                  <l n="2">ከመ፡ በስብሐት፡ ትንበር፡ ለዝሉፋ፡ ውስተ፡ ሰማያዊት፡ ሀገር፨</l>
                  <l n="3">ከመ፡ እሌኒ፡ ጸዊራ፡ መስቀለ፡ ሞታ፡ ክቡር፨</l>
                  <l n="4">እንዘ፡ ይብሉ፡ ተቀብለዋ፡ ላእካነ፡ ክርስቶስ፡ በኵር፨</l>
                  <l n="5">ይትባረክ፡ እግዚአብሔር፡ በአፈ፡ ኵሉ፡ ፍጡረ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ እብል፡ ለበድነ፡ ሥጋኪ፡ ቅድው፨</l>
                  <l n="2">እንተ፡ ቦ፡ ላዕሌሁ፡ ዘመንፈስ፡ ቅዱስ፡ ልብው፨</l>
                  <l n="3">ጸበለ፡ ማርያም፡ ክድነንኒ፡ በአክናፍኪ፡ ምንትው፨</l>
                  <l n="4">ኢይኩን፡ ጽጌ፡ ገድልኪ፡ በሐሩረ፡ ፀሓይ፡ ዘምጽልው፨</l>
                  <l n="5">ወኢያጻምዋኒ፡ ፍናዋት፡ ዘበድው፨</l>
                  <l n="6">ወመንክር፡ ዘዐቀባ፡ እምስውር፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለመቃብርኪ፡ ዘትስመይ፡ ንህበት፨</l>
                  <l n="2">እንተ፡ ይእቲ፡ ኀይከል፡ ለዕፀ፡ መድኃኒት፨</l>
                  <l n="3">ምዕዝተ፡ ምግባር፡ እምኮል፡ ጸበለ፡ ማርያም፡ ቅድስት፨</l>
                  <l n="4">የማነ፡ ኪዳንኪ፡ ጽዱቅ፡ ወጸሎትኪ፡ ውክፍት፨</l>
                  <l n="5">ዐቃቤ፡ ትኩነነ፡ በኵሉ፡ ሰዓት፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለኅሩያንኪ፡ ዘምስለ፡ ቶማስ፡ ቀሲስ፨</l>
                  <l n="2">ጸበለ፡ ጊዮርጊስ፡ ወአቢብ፡ ወቴዎድሮስ፨</l>
                  <l n="3">እሉ፡ እሙንቱ፡ ንጹሓነ፡ ምግባር፡ ውዱስ፨</l>
                  <l n="4">ጸበለ፡ ማርያም፡ ትንባሌኪ፡ እንዘ፡ ትትኴነነ፡ ለዘኵልነ፡ ነፍስ፨</l>
                  <l n="5">ወለጸሓፉሁ፡ ደመ፡ ክርስቶስ፡ ትዕቀቦ፡ እምባእስ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለኪ፡ ጸበለ፡ ማርያም፡ ተሐራሚት፨</l>
                  <l n="2">እምእክለ፡ መዐዛ፡ ወእክለ፡ ወርዙት፨</l>
                  <l n="3">ተውላጠ፡ ሕማምኪ፡ በሥጋ፡ መጠነ፡ ብዙኀ፡ ዓመታት፨</l>
                  <l n="4">በገነተ፡ ጽጌ፡ ኀበ፡ ተነጽፈ፡ ዕረፍት፨</l>
                  <l n="5">ከመ፡ ንባእ፡ አኃውኪ፡ አስተብቍዖ፡ እኅት፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
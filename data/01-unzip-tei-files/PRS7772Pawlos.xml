      <body>
         <listPerson>
            <person sex="1">
                  <persName xml:lang="gez" xml:id="n1" type="monastic">ጳውሎስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Ṗāwlos</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">monk, writer</occupation>
                  <birth when="1510"/>
                  <residence/>
               <floruit notBefore="1530" notAfter="1578"> He was a sixteenth century 
                  Ethiopian monk who composed his personal as well as political life from
                  <date>1531</date> to <date>1578</date>. 
                  He received a monastic habit in <date>1531/32</date> 
                  in the monastery of <placeName ref="https://betamasaheft.eu/LOC2228DabraA">Dabra ʿAbbāy</placeName>. 
                  After  travelling around different places  including 
                  <placeName ref="https://betamasaheft.eu/LOC1310Aksum">ʾAksum</placeName> and 
                  <placeName ref="https://betamasaheft.eu/LOC2254DabraD">Dabra Dāmmo</placeName>, 
                  he settled in the monastery of <placeName ref="https://betamasaheft.eu/LOC1634Ayda">ʿAydā</placeName>.
                  His account provides important historical details about  the war of <persName ref="https://betamasaheft.eu/PRS1500Ahmad">ʾAḥmad</persName>, 
                  the capture of <persName ref="https://betamasaheft.eu/PRS7102Minas">Minās</persName>, 
                  the death of <persName ref="https://betamasaheft.eu/PRS4121Fiqtor">Fiqṭor</persName>, 
                  the incursion of <persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</persName>, 
                  the death of <persName ref="https://betamasaheft.eu/PRS4406Gaewa">Gāʿǝwā</persName> 
                  and the campaign of <persName ref="https://betamasaheft.eu/PRS5043hamalmal">Ḥamalmāl</persName>
               </floruit>
                  
                  <death when="1578"/>
               </person>  
               
         </listPerson>

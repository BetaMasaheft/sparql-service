                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_5255">
                           <locus target="#1v">-1v</locus>
                           <q xml:lang="ar">هخميس ٢ ربيع ٢ سنه ١٣٨٣ هجريه الله صل وسلم على سيدنا محمد واله وصحبه عدد ما فى علم الله دائمين بدوام ملك الله واغفر لنا ما كان وما يكون واذمع بيننا وبين سيدنا محمد المصتفى فى الدنيا والآخره انك على كل شىى قدير وسلام على المرسلين وال همد لله رب العالمين
</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_5257">
                           <locus target="#3r">-3r</locus>
                           <q xml:lang="ar">اه ٢ ربيع ٢ سنه ١٣٨٣ اه هذا ١٩٤٦ امت</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#3v">-3v</locus>
                           <q>جمعه ٩ صفر ص ا ح ت ا ل ط ي و ر ١٣٨٥ ... شعير ٣ كبيس ٥ باقمين ص ا ح ت ا ى ض ا</q>
                           <note>Different calculations made after a long series of numbers.</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#3v">-3v</locus>
                           <desc>Adʻiya / doxologies</desc>
                           <q>Invocation to God through the intercession fo the Companions.</q>
                           <note/>
                        </item>
                     </t:list>

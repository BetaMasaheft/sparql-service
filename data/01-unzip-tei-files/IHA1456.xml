               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="5v">1v-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3251IHA">دعاء البشير المبشر</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم اللهم صل وسلم على سيدنا محمد ن البشيرالمشر للمؤمنين بما قال لله العظيم وبشر المؤمنين وان لله لا يضيع أجر المؤمنين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5v">-5v</locus>واجر عظيم وأن ليس للاانسان الا ما سعى وان سعيه سوف يرى ثم يجزاه لجزاء لأوفى وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم تسليما كثيرا والحمد لله رب العالمين تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6r" to="6v">6r-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3252IHA">منهاج القيوم</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>اللهم إنى أسألك موجبات تحمتك وعزائم مغفرتك والسلامة من كل إثم والغنيمة من كل بر والفوز بالجنة والنجاه من النار </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>ربنا تقبل منا إنك أنت السميع العليم وتب علينا إنك أنت التواب الرحيم سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين أه منهاج القيوم ممم<note>The text is followed by a "magic" square, with various annotations in Arabic.</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="7r" to="7v">7r-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT3253IHA">رسالة الباجوري في التوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين والصلاة والسلام على رسول الله صلى عليه وسلم وبعد فيقول فقير رحمة ربه الخبير البصير إبراهيم الباجورى ذو التقصير طلب مني بعض الاخوان صلح الله لى ولهم الحال والشأن ان كتب له رسالة لطيفة تشتمل على صفات المولى واضدادها</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="8r" to="8v">8r-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0457IHA">صلاة الشيخ عبد السلام بن مشيش</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>هذه صلاة سيدى عبد السلام ابن مشيش رحمه الله تعلى ولها فضيلة عمن واظب على قراءتها بالنية الخالصة يكعن من اهل الحظوة بسم الله رحمن الرحيم اللهم صل على من منه انشقت الاسرار وانفلقت الانوار وفيه ارتقت الحقائق </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus> يا أيها الذين ءامنو صلوا عليه وسلموا تسليما صلوات الله وسلامه وتحيته ورحمته وبركاته على سيدنا محمد عبك ونبيك ورسولك النبي الامى وعلى ءاله وصحبه وسلم عدد الشفع والوتر وعدد كلمات الله التامات المباركات سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين تم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="9r" to="10v">9r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1393IHA">خريدة البهية في علم التوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>فهو الجليل والجميل والولى والطاهر القدوس | منزه عن الحلول والجه والاتصال والانفصال وسفه | ثم المعانى سبعة للراى أي علمه المحيط للاشياء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>من سر الابهى النويل؟ للعمى وانتم بخير يا رحيم يا رحما | والحمد لله على الاتمام وافضل الصلاة والسلام | على النبى الهاشمى الخاتم ... وصحبه الاكام [...] | تمت هذه المنظومة اول الاعصر هب لكاتبه بركته </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="1" to="212">p. 1-212</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3256IHA">تؤيلات القرآن</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/QZQER5U7"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook697"/><title level="m">Tafsīr al-šayḫ al-akbar</title><author><name>al-Qāšānī, ʻAbd al-Razzāq</name></author><pubPlace>al-Qāhira</pubPlace><publisher>Maṭbaʻa al-Maymaniyya - Muṣṭafā al_Bābī al-Ḥalabī</publisher><date/><note type="tags"><note type="tag">bm:IHABook697</note></note><note type="tag">bm:IHABook697</note></bibl>

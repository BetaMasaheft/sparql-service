               <msContents>
                  <summary>Art roll produced for the tourist industry with icons of the burial of Jesus, Saint Michael rebuking the devil, and captions written in an artist's hand.</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" facs="002">Fols 2r and following</locus><title>“How they prepared Our Lord for burial, and dressed him with garments. He suffered and died and was buried for us.”</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>Lines of Text: “How they prepared Our Lord for burial, and dressed him with garments. He suffered and died and was buried for us.”</note>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="4r" facs="004">Fols 4r and following</locus><title>How Saint Michael rebuked the devil in the name of Our Lord</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="6r" facs="006">Fols 6r and following</locus><title>“Peter and John, Sons of Zebedee.”</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
               </msContents>

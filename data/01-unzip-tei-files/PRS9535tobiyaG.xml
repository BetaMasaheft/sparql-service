        <t:listPerson>
          <t:person sex="1">
            <t:persName xml:lang="gez" xml:id="n1">ጦቢያ፡ ጊዮርጊስ፡ ገብረ፡ እግዚአብሔር፡</t:persName>
            <t:persName xml:lang="gez" type="normalized" corresp="#n1">Ṭobiyā Giyorgis Gabra ʾƎgziʾabǝḥer</t:persName>
            <t:persName xml:lang="lat" corresp="#n1">Tobias Georgius Gheraghzer</t:persName>

            <t:birth when="1755">
              He was born in <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName> on <t:date>19 June 1755</t:date>.
            </t:birth>
            <t:faith type="Catholicism"/>
            <t:nationality type="Ethiopia"/>
            <t:occupation type="ecclesiastic" from="1788" to="1801">Titular Archbishop of Adulis</t:occupation>
            <t:floruit notBefore="1782" notAfter="1801">
              He served as a collector of manuscripts under the patronage of Cardinal <t:persName ref="https://betamasaheft.eu/PRS2853Borgia">Stefano Borgia</t:persName>. In <t:date>1788</t:date>, he was appointed titular Archbishop of Adulis and Apostolic Vicar of Ethiopia.
            </t:floruit>
            <t:death when="1801">
              He died in <t:placeName ref="https://betamasaheft.eu/LOC2085Cairo">Cairo, Egypt</t:placeName> on <t:date>7 May 1801</t:date>.
            </t:death>
          </t:person>

          
        </t:listPerson>


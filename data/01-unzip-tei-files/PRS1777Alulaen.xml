      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አሉላ፡ እንግዳ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAlulā ʾƎngǝdā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ ነጋ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbā Naggā</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="nick">ወዲ፡ ቁቢ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Waddi Qubbi</t:persName>
               
               
               <t:persName>
                  <t:roleName type="title">rās</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">governor</t:occupation>
               <t:birth when="1847"/>
               
               <t:floruit notAfter="1870" notBefore="1897">He was one of the most important Ethiopian national heroes. 
                  He started as an aškar in the court of <t:persName ref="https://betamasaheft.eu/PRS2010Arayas">Arʾaya Śǝllase</t:persName>
                  and was transferred to the service of <t:persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                     <t:roleName type="title">dāǧǧāzmāč</t:roleName>
                      Kāśā Mǝrč̣ā</t:persName> after 
                  <t:persName ref="https://betamasaheft.eu/PRS2010Arayas">Arʾaya Śǝllase</t:persName> was imprisoned by 
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName>. 
                  After Kāśā captured power as 
                  <t:persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                     <t:roleName type="title">ʾaṣe</t:roleName> 
                  </t:persName>
                  he had become his favourite administrator and chief soldier.
                  He then started making his name as a brilliant military tactician in the battles 
                  of <t:placeName ref="https://betamasaheft.eu/LOC3655Gundat">Gundät</t:placeName> in <t:date>1875</t:date> and <t:placeName ref="https://betamasaheft.eu/LOC3660Gura">Guraʿ</t:placeName> in <t:date>1876</t:date> against the invading Egyptian expeditions. 
                  For the next 20 years he played a major role in Ethiopia's history from social obscurity to political prominence. </t:floruit>
               
               <t:death when="1897">He died at <t:placeName ref="https://betamasaheft.eu/LOC1310Aksum">ʾAksum</t:placeName> in <t:date>1897</t:date>.</t:death>
            </t:person>
            
         </t:listPerson>

                                 <dim unit="leaf">8</dim>
                                 <locus from="17" to="24" facs="017">Fols 17–24</locus>
                                 <note>
                                    <locus target="#20 #21" facs="020 021">Fols. 20, 21</locus> make up one sheet. Each folio is approximately 1.5 cm narrower than the other folios.</note>
                              Quire 3
                            </item>
                              <item xml:id="q4" n="4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="25" to="32" facs="025">Fols 25–32</locus>
                              Quire 4

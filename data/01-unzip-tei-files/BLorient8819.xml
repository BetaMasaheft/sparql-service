                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="4r" to="78r"/> 
                            <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions">Discourses on the Passion of our Lord Jesus Christ for Holy Week</title>  
                            <msItem xml:id="ms_i1.1">
                                <locus from="4r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#Introduction">Dǝrsāna madḫāne ʿālam: Introduction (same as https://betamasaheft.eu/LIT6616HomilyPassionIntro)</title>
                                <note>Rhyming</note>
                                <incipit xml:lang="gez">
                                    በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘእንበለ፡ ቀዲም፡ ወተድኅሮ። 
                                    በግጻዌሁ፡ ይትረአይ፡ ዘአስተዋሐደ፡ ምክሮ።
                                    በጠፈረ፡ በረድ፡ ወነድ፡ ዘሐነጸ፡ ማኅደሮ።
                                    ወበአርእስተ፡ ኪሩቤል፡ ርቱዓ፡ ዘአማዕዘነ፡ መንበሮ።</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="6v"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#Monday">Dǝrsāna madḫāne ʿālam: Homily for Holy Monday (same as https://betamasaheft.eu/LIT6617PassionsHomilyMonday)</title>
                                <incipit xml:lang="gez">ናንቅሕ፡ ርእሰ፡ ሕሊናነ፡ ወናስተሐውስ፡ አስራወ፡ ልሳንነ፡ ንክሥት፡ አፉነ፡ ወናስተናብብ፡ ከናፍሪነ። ከመ፡ ንንግር፡ ዜና፡ ሕማማቲሁ፡ 
                                    ለመድኅኒነ፡ እንዘ፡ ኃያል፡ ዘኢየሐምም፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="17r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyTuesdayOther">Homily for Tuesday</title>
                                <note>According to <bibl corresp="http://zotero.org/groups/358366/items/RSEA4WPK"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1978BritishLibrary"/><title level="m">Catalogue of Ethiopian Manuscripts in the British Library acquired since the Year 1877</title><author><forename>Stefan</forename><surname>Strelcyn</surname></author><pubPlace>London</pubPlace><publisher>British Museum</publisher><date>1978</date><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note><citedRange unit="page">92</citedRange></bibl>, this part is the homily for Tuesday, but in <ref type="mss" corresp="https://betamasaheft.eu/BNFet116">Paris, Bibliothèque nationale de France, BnF Éthiopien 116</ref> this homily is not attested.</note>
                                <incipit xml:lang="gez">ወእምድኅረዝ፡ እንዘ፡ ሀሎ፡ በቤተ፡ ስምዖን፡ ዘከመ፡ አቅረቡ፡ ድራረ፡ ወዘከመ፡ ወሀበ፡ ሥጋሁ፡ ወደሞ፡ ለአርዳኢሁ፡ ወዘከመ፡ ሐፀበ፡
                                    እገሪሆሙ፡ ወዘከመ፡ አውተረ፡ ጸልዮ፡ ኵሉ፡ ጽሑፍ፡ ሀሎ፡ ውስተ፡ ወንጌል።</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="24r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyTuesday">Homily for Wednesday</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ንግባዕኬ፡ ከመ፡ ንፈጽ<pb n="24v"/>ም፡ ዜና፡ ሕማሙ፡ ለመድኃኒነ፡ ወአንግሁ፡
                                    ይአተ፡ ዕለተ፡ ኵላ፡ ሌሊተ፡ እንዘ፡ ይዘብጥዎ፡ ወይጸፍእዎ። </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="36v"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyWednesday">Homily for Thursday</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረ፡ ወበጊዜ፡ ፱ሰዓት፡ ተከሥተ፡ ፀሐይ፡ በዓውደ፡ ሰማይ።</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.6">
                                <locus from="50r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyThursday">Homily for Friday</title>
                                <incipit xml:lang="gez">ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረ፡ ዘ፱ሰዓት። ወይእተ፡ ጊዜ፡ ሶበ፡ ርእዩ፡ ነቢያት፡ ቀደምት፡ ወአበው፡ ቀደምት፡ ሞቶ፡ ለመድኃኒነ፡ ጸርሑ፡
                                    ኀቤሁ፡ </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.7">
                                <locus from="62r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyFriday">Homily for Saturday</title>
                                <incipit xml:lang="gez">ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረ፡ ዘምሴተ፡ ዓርብ። እስመ፡ ይቤ፡ ዘካርያስ፡ ይእቲ፡ ዕለ<pb n="62v"/>ት፡ እምርት፡ ይእቲ፡ በኀበ፡
                                    እግዚአብሔር፡ ኢኮነት፡ መዓልተ፡ ወሌሊተ፡ ወፍና፡ ሠርከ፡ ይበርህ፡ ብርሃን፡ </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.8">
                                <locus from="70r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilySaturday">Homily for Sunday</title> 
                                <incipit xml:lang="gez">ንንግርኬ፡ ኅዳጠ፡ ዜናሁ፡ ለፀልቦ፡ መድኃኒነ፡ መስቀል፡ ዘከመ፡ ሀሎ፡ ምስለ፡ እግዚአብሔር፡ እምቅድመ፡ ኵሉ፡ ፍጡር፤ ወእምቅድመ፡
                                    ኵሉ፡ ግቡር፤ ትእምርተ፡ መስቀል፡ ክቡር፤ እምቅድመ፡ ነገር፤ ትእምርተ፡ መስቀል፡ አርአያሁ፡ ለእግዚአብሔር። </incipit>  
                            </msItem>
                            <msItem xml:id="ms_i1.9">
                                <locus from="75r"/> 
                                <title ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilySunday">Final chapter</title>
                                <incipit xml:lang="gez">ንግባዕኬ፡ ከመ፡ ንስብሖ፡ ለእግዚአብሔር፡ ወንወድሶ፡ እንዘ፡ ንብል፡ ጥዑመ፡ ስም፡ መድኀኒነ፡ ለሊሁ፡ ንጉሥ፡ ወእሙ፡ መቅደስ፤ 
                                    ወመስቀሉ፡ አትሮንስ። </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.10">
                                <locus from="77v"/> 
                                <title>Final benediction</title> 
                                <incipit xml:lang="gez">ዘጸሐፎ፡ ወለዘአጽሐፎ፡ ለዝንቱ፡ ድርሳን፡ እግዚአብሔር፡ ይጽሐፍ፡ ስሞሙ፡ በዓምደ፡ ብርሃን፡ ወያርፍቆሙ፡ በደብረ፡ ጽዮን፡ መካን፤
                                    በሥላሴሁ፡ አመ፡ ይመጽእ፡ መድኅ<pb n="78r"/>ን፡ ምስለ፡ መላእክቲሁ፡ ትጉሃን፤ ለዓለመ፡ ዓለም። ለዘጸሐፋ፡ ለዛቲ፡ ተውዳስ፤ ወትረ፡ የሃሉ፡ በሞገስ፤ በሥጋ፡
                                    ወነፍስ፤ እንበለ፡ ንዴት፡ ወተጽናፍስ፤ ወዘእንበለ፡ ሐተታ፡ ወሙቃስ፤፡ ኅዙነ፡ ለቡና፡ ወለተ፡ ጊጋር፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፡ ለይኩን፤ ለይኩን። </incipit>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="78v" to="83r"/> 
                            <title ref="https://betamasaheft.eu/LIT4035SenkessarDL#Mask27SalEwostatewos">Sǝnkǝssār (Second revision, Dabra Libānos
          recension): Salām-hymn to ʾEwosṭātewos</title>
                            <incipit xml:lang="gez">
                                ሰላም፡ ለሥቃይከ፡ ለለ፩፩፤
                                እምሴተ፡ ሐሙስ፡ ዘኮነ፡ እስከ፡ ምሴተ፡ ዓርብ፡ የዓዱ።
                                ኢየሱስ፡ ክርስቶስ፡ ተስፋ፡ ኤዎስጣቴዎስ፡ ወውሉዱ።
                                ዘበእንቲአሁ፡ ሶበ፡ በውስቴቱ፡ ወረዱ፤
                                ለእሳተ፡ ጤገን፡ ዘብርት፡ አብሰሎሙ፡ ነዱ።
                            </incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="84r" to="98r"/> 
                            <title ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our Lady Mary</title>
                            <note>With interspersed stanzas containing praises to Jesus Christ.</note>
                            <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡</incipit>
                        </msItem>

               <msPart xml:id="p1">
                  <msIdentifier/>
                  <msContents>
                     <summary/>
                        
                     <msItem xml:id="p1_i1">
                        <locus target="#1">Fol. 1</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1560Gospel">Fragment of a Gospel</title>

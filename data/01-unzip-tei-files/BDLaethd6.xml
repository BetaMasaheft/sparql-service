                     </objectDesc>
                     
                     <handDesc>
                        <handNote xml:id="h5" script="Ethiopic">
                           <seg type="script">Written in a poor hand. Largely illegible.</seg>
                        </handNote>
                     </handDesc>
                     
                     <additions>
                        <list>
                           <item xml:id="e2">
                              <desc>The name of the owner was <persName role="owner" ref="https://betamasaheft.eu/PRS11533GabraM">Gabra Mikāʾel</persName>.</desc>
                           </item>
                        </list>
                     </additions>
                  </physDesc>
                  

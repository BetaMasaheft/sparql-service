         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘእምቅድመ፡ ፀሓይ፡ ህልው፨</l>
                  <l n="2">ለርእስከ፡ ሰላም፡ ወለሥዕርትከ፡ ጽዕድው፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ለአድኅኖ፡ ዓለም፡ ፍንው፨</l>
                  <l n="4">በጥብሕከ፡ ተማሕፀንኩ፡ ወበደምከ፡ ክዕው፨</l>
                  <l n="5">ከመ፡ ትናዝዘኒ፡ ለብእሲ፡ ልሕው፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለፍጽምከ፡ ወለገጽከ፡ ፍርቃን፨</l>
                  <l n="2">ለቀራንብቲከ፡ ሰላም፡ ወለአዕይንቲከ፡ ብርሃን፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ዘአመተ፡ ወንጌል፡ ቍርባን፨</l>
                  <l n="4">በጥብሕከ፡ ተማሕፀንኩ፡ ወበደመ፡ ገቦከ፡ ወይን፨</l>
                  <l n="5">ከመ፡ ታዕድወኒ፡ እምጸፍዱ፡ ለደይን፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ወለበድነ፡ ሥጋከ፡ ጥብሉል፨</l>
                  <l n="2">ለግንዘትከ፡ ሰላም፡ ወለትንሣኤከ፡ በኀይል፨</l>
                  <l n="3">ለዕርገትከ፡ ሰማየ፡ ለፈጽሞ፡ ዝንቱ፡ አምሳል፨</l>
                  <l n="4">በጥብሕከ፡ ተማሕፀንኩ፡ ወበደምከ፡ ጥሉል፨</l>
                  <l n="5">ከመ፡ ያጥዕየኒ፡ ለብእሲ፡ ቍስል፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ዝንቱ፡ ኅብስተ፡ ሕይወት፡ ዘወረደ፡ እምላዕሉ፨</l>
                  <l n="2">ወዝኒ፡ ጽዋዕ፡ ዘኢይትከዐው፡ ጣሕሉ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ለአብ፡ ቀዳሜ፡ ቃሉ፨</l>
                  <l n="4">አመ፡ ተፈድዮ፡ በከመ፡ ምግባሩ፡ ለኵሉ፨</l>
                  <l n="5">ከመ፡ ትምሐረኒ፡ ሊተ፡ በፍትሕከ፡ አድሉ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ስብሐት፡ ለአቡከ፡ ስብሐት፡ ለመንፈስከ፨</l>
                  <l n="2">ወስብሐት፡ ለከ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ዘእንበለ፡ መስፈርት፡ ሣህልከ፨</l>
                  <l n="4">ጸሎተ፡ ኵሉ፡ ዘሥጋ፡ ዘመጽአ፡ ኀቤከ፨</l>
                  <l n="5">በእንተ፡ ማርያም፡ ወላዲትከ፡ ኢይኩን፡ በከ፨</l>
               </lg>
            </div>
         </div>
      </body>

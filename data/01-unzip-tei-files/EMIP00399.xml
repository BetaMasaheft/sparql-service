               <msContents>
                  <summary>Gospel of John, Wängel zä-Yoḥanǝs, ወንጌል፡ ዘዮሐንስ፡</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="77r" facs="001">Fols 1r–77r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>incomplete at the end, covered by an illumination. Arranged for days of the week</note>
                  <msItem xml:id="ms_i1.1"><locus from="17v" facs="018">Fols 17v and following</locus><title>Saturday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="21v" facs="022">Fols 21v and following</locus><title>Tuesday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="31v" facs="032">Fols 31v and following</locus><title>Tuesday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="36v" facs="037">Fols 36v and following</locus><title>Saturday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="43v" facs="044">Fols 43v and following</locus><title>Wednesday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.6"><locus from="49v" facs="050">Fols 49v and following</locus><title>Sunday</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                </msItem>
              </msItem>

                  <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref><persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName></desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/></desc> with lions and leopards. A bird is pecking his eye</decoNote>
                  <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>

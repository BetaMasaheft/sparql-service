                  <decoNote type="miniature" xml:id="d7"><locus target="#97r" facs="101">Fol. 97r</locus><desc>An <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with a <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/></desc></decoNote>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="2r" to="148v" facs="002"/><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1"><locus from="2r" to="126v" facs="002"/><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note>In the margins of many of the Psalms, there are calculation marks (looking like a ligature fusing ዝ and የ with number lines above) marking ten lines</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref>, only the letter names given in the original hand</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151">Mazmura Dāwit, Psalmus 151</ref> is the short version</note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="127r" to="140v" facs="127"/><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah">The Prayer of Hannah, mother of Samuel the Prophet,  Hannah</ref> <q>"Song of Hana, mother of Samuel.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="140v" to="147v" facs="141"/><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <note>Common version</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="148r" to="155v" facs="148"/><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                      <msItem xml:id="ms_i1.4.1"><locus from="148r" facs="148"/><title>Monday</title></msItem>
                      <msItem xml:id="ms_i1.4.2"><locus from="148v" facs="149"/><title>Tuesday</title></msItem>
                      <msItem xml:id="ms_i1.4.3"><locus from="149v" facs="150"/><title>Wednesday</title></msItem>
                      <msItem xml:id="ms_i1.4.4"><locus from="151r" facs="151"/><title>Thursday</title></msItem>
                      <msItem xml:id="ms_i1.4.5"><locus from="152v" facs="153"/><title>Friday</title></msItem>
                      <msItem xml:id="ms_i1.4.6"><locus from="153v" facs="154"/><title>Saturday</title></msItem>
                      <msItem xml:id="ms_i1.4.7"><locus from="154v" facs="155"/><title>Sunday</title></msItem>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="156v" to="159r" facs="157"/><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                      <note>Notice concerning St. Sebastian for the 25th of Terr (= 2nd of February)</note>
                    </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2"><locus from="159r" to="159v" facs="159"/><title type="complete" ref="https://betamasaheft.eu/LIT2375Synaxa">Sǝnkǝssār (General record)</title></msItem>
                </msContents>

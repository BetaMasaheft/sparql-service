                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                    <desc>The word for God is unrubricated in <ref target="#ms_i1.1"/></desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                      <locus target="#1r" facs="001"/>
                      <desc>the contents of the manuscript, written in faint pencil, in English</desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#102r" facs="102"/>
                      <desc><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref> of the new common system in a later hand</desc>
                    </item>
                    <item xml:id="a3">
                      <locus target="#147" facs="148"/>
                      <desc type="OwnershipNote">The name of the owner has been deleted; it may have been Yosef</desc>
                    </item>
                    <item xml:id="a4">
                      <locus target="#160v" facs="161"/>
                      <desc>Prayer in Ge'ez, only partially legible, apparently for the healing of a wound</desc>
                    </item>
                    <item xml:id="a5">
                      <desc>The same prayer as <ref target="#a4"/> is found upside down on <locus target="#160r" facs="160"/></desc>
                    </item>
                    <item xml:id="a6">
                      <locus target="#160v" facs="161"/>
                      <desc>Note in Amharic, mostly illegible</desc>
                    </item>
                    <item xml:id="a7">
                      <desc>Same note as <ref target="#a6"/> upside down on <locus target="#160r" facs="160"/></desc>
                    </item>
                    <item xml:id="a8">
                      <locus target="#160v" facs="161"/>
                      <desc>Beginning of a recipe for a medical ointment in Ge'ez. Also upside down on <locus target="#160r" facs="160"/></desc>
                    </item>
                    <item xml:id="a9">
                    <desc>
                    This entry employs some information from Macomber, William F. “Catalogue of oriental manuscripts in the library of Seabury-Western Theological Seminary, Evanston, Illinois.” Le Muséon 92 (1979) 369–386
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment. Wooden boards, carefully covered in tooled Moroccan leather.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

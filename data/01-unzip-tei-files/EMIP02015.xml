               <msContents>
                  <summary>Gospel of John, ወንጌል፡ ዘዮሐንስ፡; On the Benefits of Reading the Gospel of John</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="67v" facs="001">Fols 1r–67v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                     <note>Arranged for the days of the wee</note>
                    <msItem xml:id="ms_i1.1">
                        <locus target="#1r" facs="001">Fol. 1r</locus>
                        <title>Monday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.2">
                        <locus target="#13r" facs="013">Fol. 13r</locus>
                        <title>Saturday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.3">
                        <locus target="#16v" facs="017">Fol. 16v</locus>
                        <title>Tuesday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.4">
                        <locus target="#29r" facs="029">Fol. 29r</locus>
                        <title>Saturday</title>
                     </msItem>

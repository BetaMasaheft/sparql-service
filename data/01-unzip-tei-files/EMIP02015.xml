                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                           <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                        </seg>
                        <desc>Occasionally, the word Jesus is rubricated in alternating red and ‎black letters (e.g., <locus target="#3v #4r" facs="004">folss. 3v, 4r, </locus>). The same is done with the word God ‎‎(e.g., <locus target="#4v" facs="005">4v</locus>)‎</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#1r" facs="001">fols. 1r, </locus> (haräg);
                      <locus target="#1r" facs="001">1r, </locus> (line of alternating red and black dots);
                      <locus target="#53v #61r #61v #62r #68r #69r" facs="054 061 062 068 069">53v, 61r, 61v, 62r, 68r, 69r</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#70v #71r" facs="071">Fols. 70v, 71r</locus>
                           <desc>
                              Days of the Week and Feast Days, Supplements, used for Computus, <foreign xml:lang="gez">የዕለታት፥ የአጽዋማትና የበዓላት፡ ተውሳክ፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#1r" facs="001">Fol. 1r</locus>
                           <desc type="OwnershipNote">
                              Opening prayer that mentions the original owner, Gäbrä Mäsqäl
                            </desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#67v #68r" facs="068">Fols. 67v, 68r</locus>
                           <desc>
                              The scribe is mentioned, Märqorewos
                            </desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#69v #70r #71v" facs="070 072">Fols. 69v, 70r, 71v</locus>
                           <desc>
                              blank
                            </desc>
                        </item>
                        <item xml:id="e2">
                           <desc>
                             Identified in the insurance hand list as Gospel of John 8
                           </desc>
                        </item>
                        <item xml:id="e3">
                          <locus target="#13 #16 #35" facs="013 016 035">Fols. 13, 16, 35</locus>
                           <desc>
                             red string is sewn into the fore edge as navigation system
                           </desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#28r #44r #45r #52r #53v" facs="028 044 045 052 054">Fols. 28r, 44r, 45r, 52r, 53v</locus>
                           <desc>
                             (etc.) words of text are written interlinearly;
                           </desc>
                           </item>
                           <item xml:id="e5">
                          <locus target="#63r" facs="063">Fol. 63r</locus>
                          <desc>
                          text has been removed
                           </desc>
                           </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with a double-pocket fabric cover.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="textile"/>

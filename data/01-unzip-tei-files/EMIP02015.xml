                        <title>Thursday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.7">
                        <locus target="#53v" facs="054">Fol. 53v</locus>
                        <title>Friday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.8">
                        <locus target="#61v" facs="062">Fol. 61v</locus>
                        <title>Sunday</title>
                     </msItem>
                    <msItem xml:id="ms_i1.9">
                      <locus target="#67v" facs="068">Fol. 67v</locus>
                      <title>Concluding statement</title>
                      <incipit xml:lang="gez">መልዓ፡ ጽሕፈተ፡ብስራቱ፡ ለዮሐንስ፡ ሐዋርያ፡ ወልደ፡ ዘብዴዎስ፡ ፩፡ እመ፲ወ፪፡ ሐዋርያት፡ ዘጸሐፎ፡ በዮናኒ፡ ለሰብአ፡ ሀገረ፡ ኤፌሶን፡ እምድኅረ፡ ዕርገቱ፡ ለእግዚእነ፡<gap reason="omitted"/></incipit>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="68r" to="69r" facs="068">Fols 68r–69r</locus>
                     <title>On the benefits of reading the Gospel of John</title>
                  </msItem>

                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="8v" facs="0002"/>
                     <title type="incomplete">Malkǝʾ-hymn to Our Lady Mary</title>
                     <note>The beginning is missing, the text begins abruptly.</note>
                     <incipit xml:lang="gez">
                        
                           <sic>ከነ፡</sic>
                         ዘይሰምያ፡ ነገ<gap extent="unknown" reason="lost"/> ኃቤ<gap extent="unknown" reason="lost"/> 
                        ዘነገደ፡ ይረ<gap extent="unknown" reason="lost"/> ዘ<gap extent="unknown" reason="lost"/> 
                        
                           <sic>ሰለም፡</sic>
                         
                        ለአዕ<supplied reason="lost">ይ</supplied>ንት<gap extent="unknown" reason="lost"/> ርግብየ፡ ሰሎሞን፡ አንቲ፡ ውእቱ፡ 
                        ዘኢ<supplied reason="lost">ተ</supplied>ኵሕላ፡ 
                           <sic>በእሞን፡</sic>
                         አማን፡ በአማን፡ ምስካይ፡ ወግዕዛን። 
                           <sic>ሰለም፡</sic>
                         
                        ለማር<supplied reason="lost">ያ</supplied>ም፡ እንተ፡ በክልኤ፡ ድንግል፡ ወለቶሙ፡ አንቲ፡ ለእስራኤል፡
                     </incipit>
                     <explicit xml:lang="gez">
                        እስእለኪ፡ ማርያም፡ ዕፅውት፡ 
                           <sic>ሕሕውት፡</sic>
                         አኮ፡ ዘእስእለኪ፡ ከመ፡ ደቅስዮስ፡ ሲመተ፡ ዳእሙ፡ ኢታርእይኒ፡ ዘሲኦል፡ 
                           <sic>ፍኖት፡</sic>
                        
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="9r" to="21r" facs="0010"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2937RepCh218">Malkǝʾ-hymn to Our Lady Mary</title>
                     <note>The text was composed by  
                        <persName ref="https://betamasaheft.eu/PRS2334BaedaM">
                           <roleName type="title">ʾaṣe</roleName> Baʾǝda Māryām</persName>.
                     </note>
                     <incipit xml:lang="gez">
                        
                           <sic>ሰለም፡</sic>
                         
                        
                           <sic>ሰለም፡</sic>
                         ለኵሎን፡ መልክዕኪ፡ እመ፡ እግዚአብሔር፡ እምየ፡ እግዝእትየ፡ ማርያም። ዓዲ፡ ሰላም፡ 
                        ለክልኤ፡ ማሕተመ፡ ድንግልናኪ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        
                           <sic>ሰለም፡</sic>
                         
                        
                           <sic>ሰለም፡</sic>
                         ለኵሎን፡ መልክዕኪ፡ እምቅድመ፡ ዓለም፡ ወልደ፡ 
                           <sic>አምለክ፡</sic>
                         
                        ለከዊነ፡ እሙ፡ <add place="inline">
                           <supplied reason="omitted">ኃረየኪ፡</supplied>
                        </add> እምውሉደ፡ ሰብእ፡ አልቦ፡ ከማኪ፡ ማርያም፡ ድንግል፡ 
                        
                           <sic>በሕልናኪ፡</sic>
                         ወስጋኪ፡ አባግዓ፡ ወንጌል፡ ሕዝብኪ፡ ባርኪ። <add place="inline">
                           <supplied reason="omitted">በእዴኪ።</supplied>
                        </add>
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="21v" to="25r" facs="0023"/>
                     <title type="incomplete">Malkǝʾ-hymn to St Peter and St Paul</title>
                     <note>The beginning is missing; the text begins abruptly.</note>
                     <incipit xml:lang="gez">
                        ደቂቀ፡ እስራኤል፡ ለእግዚአብሔር፡ ተማከሩ፡ በእኪቶሙ፡ 
                           <sic>ነዊሕ፡</sic>
                         ዓንቀፀ፡ ደናግል፡ ሰበሩ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        እምድንግል፡ እመስቀል፡ አይኑ፡ ይከብር፡ ድንግልኒ፡ ወላዲቱ፡ መስቀልኒ፡ ዓራተ፡ ሞቱ፡ እስመ፡ ክልኤሆሙ፡ 
                           <sic>ዕሩየን፡</sic>
                         
                        
                           <sic>እሞንቱ፡</sic>
                         
                        በከመ፡ ይቤ፡ ነቢይ፡ በአውታር፡ ዓሰርቱ፡ አሓዜ፡ ዓለም፡ ዝንቱ፡ ባሕቲቱ፡ እፎኬ፡ ባሕቲቱ፡ ከመ፡ ሰብእ፡ ሞቱ።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="25v" to="69r" facs="0027"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4298Taamho">Taʾammǝḫotā la-Māryām</title>
                     <explicit xml:lang="gez">
                        ወሊተኒ፡ ለገብርኪ፡ ተክለ፡ ብርሃን፡ 
                           <sic>ረስዪኒ፡</sic>
                         እኩን፡ ድርገተ፡ ምስሌሆሙ፡ ምስለ፡ ኄራን፡ መሃይምናን፡ ለዓለመ፡ ዓለም። አሜን፡ አሜን፡ ወአሜን። ለይኩን፡ 
                        ለይኩን። ለይኩን።
                     </explicit>
                     <note>The name of the owner of the book <persName role="owner" ref="https://betamasaheft.eu/PRS11475TaklaBe">Takla Bǝrhān</persName> (perhaps the same as 
                        <persName ref="https://betamasaheft.eu/PRS11229TaklaBe">Takla Bǝrhān Walda Qʷayyaṣā</persName>) is written in the supplication formula at the end of the text.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="69r" to="70r" facs="0070"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4138Prayer">Untitled prayer</title> 
                     
                     <explicit xml:lang="gez">
                        በዝንቱ፡ ኅቡእ፡ ስሙ፡ ተማሕፀንኩ፡ 
                           <sic>አና፡</sic>
                         ገብርከ፡ <del rend="erasure">
                           <supplied reason="lost">ተ</supplied>ክለ፡ ብርሃን፡</del> 
                        ክርስቶ
                     </explicit>
                     <note>The text ends abruptly. The name of the owner of the book <persName role="owner" ref="https://betamasaheft.eu/PRS11475TaklaBe">Takla Bǝrhān</persName> (perhaps the same as 
                        <persName ref="https://betamasaheft.eu/PRS11229TaklaBe">Takla Bǝrhān Walda Qʷayyaṣā</persName>) is written and erased in the supplication formula at the end of the text.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus from="71r" to="73r" facs="0072"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4137Prayer">Protective prayer against the demon ʾAnāse</title> 
                     <note>The beginning is missing, the text begins abruptly.</note>
                     <incipit xml:lang="gez">
                        <supplied reason="omitted">አ</supplied>ምላኪየ፡ አምላኪተ፡ ለምንት፡ ሐደገኒ፡
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i7">
                     <locus from="74r" to="82v" facs="0075"/>
                     <title type="complete">Rhymed praise to Our Lady Mary</title>
                     <note/>
                     <incipit xml:lang="gez">
                        በእንቲአኪ፡ ለሙሴ፡ ዘተናበቦ፡ በእንቲአኪ፡ ለሙሴ፡ በደብረ፡ ሲና፡ ዘተናበቦ፡ በእንቲ<supplied reason="lost">አ</supplied>ኪ፡ ለሙሴ፡ ዕላተ፡ ሕግ፡ ወሀቦ፡ ማርያም፡ ድንግል፡ መቅለሊት፡ ለዘ፡ 
                        ዓጸቦ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ለእለ፡ ነአምን። መንግሥታ። ለእለ፡ 
                           <sic>ንሰብሕ።</sic>
                         ስብሓታ። ይርከበነ። በረከታ። ትመግበነ። በረድኤታ። አመ። ይከውን። ቅስት። ወሐተታ። ለዓለመ። ዓለም።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i8">
                     <locus target="#83r" facs="0084"/>
                     <title type="incomplete">Excerpt of a rhymed invocation</title>
                     <incipit xml:lang="gez">
                        <choice>
                           <sic>ሱባዔ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ስባሔ፡</corr></choice>
                         ወኢዝንጋዔ።
                     </incipit>
                    </msItem>
                  
                  <msItem xml:id="ms_i9">
                     <locus target="#83v" facs="0085"/>
                     <title type="incomplete">Excerpt of the rhymed story of St George's miracle</title>
                     <incipit xml:lang="gez">
                        ቢሮታዊት፡ ወለት፡ ኪያከ፡ ተአሚና፡ ልደራጎን፡ አርዌ፡ ሰሐበቶ፡ ዲበ፡ ዘባና፡
                     </incipit>
                     <explicit xml:lang="gez">
                        አንሰ፡ አአምን፡ ገሃደ፡ ጊዮርጊስ፡ አቡየ፡ ከ
                     </explicit>
                     <note>The end is missing, the text terminates abruptly.</note>
                  </msItem>

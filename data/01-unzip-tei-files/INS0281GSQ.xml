      <t:body>
         <listPlace>
            <t:place type="church monastery gadam" subtype="institution">
               <t:placeName>Gʷāḥtarāt Qirqos</t:placeName>
               <t:placeName type="alt">Gʷāḥtarāt Dabra Ṣaḥāy Qǝddus Qirqos</t:placeName>
               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>

               <t:settlement type="province" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</t:settlement>
               <t:settlement type="warada" from="2014-01-29" to="2014-02-07" ref="https://betamasaheft.eu/LOC4047Kelett">Kǝlǝtta ʾAwlāʿlo</t:settlement>
               <t:settlement type="tabiya" from="2014-01-29" to="2014-02-07" ref="https://betamasaheft.eu/LOC7259MahbaraWayni">Māhbara Wayni</t:settlement>
               <t:settlement from="2014-01-29" to="2014-02-07" type="qushat" ref="https://betamasaheft.eu/LOC7260Gwahtarat">Gwāḥtarāt</t:settlement>

               <t:location>
                  <t:geo>13.653472 39.500889</t:geo>
                  <t:height unit="m">1942.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1400" notAfter="1500">1400-1500</t:date>
                  <t:desc type="foundation">Local tradition tells that the church is ancient; the monastery was established here in the time of <t:persName ref="https://betamasaheft.eu/PRS10378Yohanne">King Yoḥannǝs IV</t:persName>, by <t:persName ref="https://betamasaheft.eu/PRS1873AmlasuA">wayzāro ʾAmlāsu</t:persName>, a wife of the King's general <t:persName ref="https://betamasaheft.eu/PRS1777Alulaen">rās ʾAlulā ʾƎngǝdā</t:persName> (d. <t:date>1897</t:date>).</t:desc>
                  <t:ab type="history">Gadām. Currently, there are no monks, the monastic community declined after 1970s. The church compound is adjacent to the area of the traditional school, with the huts of the students (up to 20).
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/GSQ.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>15 Mss. photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq001">GSQ-001</t:ref> “Four Gospels”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq002">GSQ-002</t:ref> “1. Orit zä-lelawǝyan 2. Orit zä-fǝträt( fols. 7-18) 3. Tǝmhǝrtä didǝsqǝlya (fols. 19-36) 4. Proverts (fols. 37-40) 5. Orit zä-däʿat (fols. 51-53) 6. Mäṣḥafä Henok (fols. 51-79) 7. MäṣḥafäṬobit (fols. 80-85) 8. Mäṣḥafä ʾṮsayǝyyas (fols.86-94) 9. ʿƎrgätä ʾṮsayǝyyas (94-95) 10. Tägśaš zä-solomon (<t:ref type="mss" corresp="https://betamasaheft.eu/ES100101">100-101</t:ref>) 11. Mäṣḥafä ʿƎzra (1<t:ref type="mss" corresp="https://betamasaheft.eu/ES03vc108">03vc-108</t:ref>)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq003">GSQ-003</t:ref> “Psalter”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq004">GSQ-004</t:ref> “Miracles of Qirqos. Image of Qirqos.”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq005">GSQ-005</t:ref> “1. story of the Fathers 2. Mar Yǝshaq 3. Paradise of montes”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq006">GSQ-006</t:ref> “Faith of the Fatheres ”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESsq007">SQ-007</t:ref> “Vita of Kiros”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq008">GSQ-008</t:ref> “2. Antiphonary for feusts and funeral service”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq009">GSQ-009</t:ref> “Horologium for the Night and the Morning Hours”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq010">GSQ-010</t:ref> “Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq011">GSQ-011</t:ref> “Miracles of Mary”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq012">GSQ-012</t:ref> “Book of the Funeral Rite”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq013">GSQ-013</t:ref> “Vita of Täklä Haymanot; Miracles of Täklä Haymanot”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq014">GSQ-014</t:ref> “Synaxarion (The second half of the year)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESgsq015">GSQ-015</t:ref> “Dǝggwa; Ṣomä dǝggwa“.</t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="5"/>Tābots of 2 of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>, 2 of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS3249Cyriacus">Qirqos</t:persName>, one unidentified marble.</t:ab>
               </t:note>

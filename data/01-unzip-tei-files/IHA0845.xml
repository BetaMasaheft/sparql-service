                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_2931">
                           <locus target="#15r">-15r</locus>
                           <q xml:lang="ar">صدق الله العظيم وبلغ الرسول النبي الكريم ونحن على ذالك من الشاهدين والحمد لله رب العلمين امين</q>
                           <note>Written by a different hand.</note>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#44r">-44r</locus>
                           <desc>Marginalia</desc>
                           <q>يا نيابيع الامتنان الموصلة الى الرضى فالرضوان</q>
                           <note>In the margin</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#171r">-171r</locus>
                           <desc>Chronology</desc>
                           <q>مات شيخان احمد ابن عمر سنة ١٣٧٢</q>
                           <note/>
                        </item>
                        <item xml:id="a3">
                           <locus target="#3r">-3r</locus>
                           <desc>Title</desc>
                           <q>كتاب تنبيه الانام  في بيان علو مقام نبينا محمدعليه الصلاة والسلام تأليف العالم العلامة سيدناعبد الجليل بن عظوم المرادي الفقيرواني المضربي نفعنا الله به وبعلومه امين</q>
                           <note/>
                        </item>
                        <item xml:id="a4">
                           <locus target="#169v-170r">-169v-170r</locus>
                           <desc>Chronology</desc>
                           <q>بسم الله الرحمن الرحيم
مات شيخان احمد ابن عمر سنة ١٠٣٥٢
اليوم مات يوم ثلاث فسعت لبلا ١٣ شهر رجب ٠٧ او دفن يوم الرابع في خمس سعة 
[...] 
طاعون ١٠٣٣٦ 
موت ابا جفار ١٠٣٥٣
دخول طاليان جما ١٠٣٥٥
دخول شيخنا دنبي جما ١٠٣٥٨ 
[...]
مات شيخنا الشيخ ابراهيم ١٠٣٦١
[...]
مات الشيخ على التجاني ابن براحيم ١٣١۰ \ مات يوم الاحد فى تسع سبة وشهر جماد الاول فى تسع ايام ودقن يوم الثلاثاء ثماني سعاة الله يرحمه</q>
                           <note>Death records and other important dates. The entry of the Italians in Ǧimmā is dated in 1355 H.</note>
                        </item>
                        <item xml:id="a5">
                           <locus target="#3r">-3r</locus>
                           <desc>Waqf</desc>
                           <q>بسم الله الرحمن الرحيم الحمد لله الذي [جمل] الوقت من اقرب القربات والصلاة والسلام على خير بالسدات وعلى اله واصحابه ذوى الدرجات اما بعد الله اعلم أ يعنى ابا سمل ابا سرب ان هذه الكتاب موقوف على جميع المسلمين ان كانوا اهلا في وصية [...] خلما مات ابن ءادم انقطع عمله الا في ثلاث اشياء وولد صالح [...] له وعلم نافع وصدقة جارية وضر الجمهور بالوقف وناظره لشيخ حسين يسن بن ابا [...] ابن الشيخ عبد الرحمان مدة حياته ثم لاولاده ثم لاولاد اولاده ما تأسلوا فمن بدله الاية</q>
                           <note/>
                        </item>
                        <item xml:id="a6">
                           <locus target="#1v-2r">-1v-2r</locus>
                           <q>,بسم الله الرحمن الرحيم \ الحمد لله الذي زين السماء الاذكار بالصلاة على النبي المختار, واطلع من سنا انوارها مطلع , الشموس والاقمار [...] وبعد فانه لما كانت الصلاة على النبي الاكرم , والرسول المعظم صلى الله عليه وسلم , وشرف وكرم , ومجد وعظم , وافاض عليه من خزائن وانعم , من اشرف القربات , وافضل الاعمال الصالحات [...] واختصرتها اختصار الواعظ ليسهل خفظها على الحفاظ فكانت تذكرة للاسلام في الصلاة على خير الانام وارتفعت بها الاصوات في المجالس وطردت بها الشياطين والابالس [...] وسميتها تنبيه الانام في بيان علو مقام نبينا محمد عليه افضل الصلاة وازكى السلام . وربما ايضا سميتها شفاء الاسقام , ومحو الاثام [...] الشفيع في العصاة , انه ولي ذلك , والقادر عليه , ولا حول ولا قوة الا بالله العلي العظيم , وصلى الله على سيدنا محمد وعلى آله وصخبه وسلم تسليما كثيرا طيبا مباركا جزيلا</q>
                           <note/>
                        </item>
                     </t:list>

                        <msItem xml:id="ms_i1">
                            <locus from="4r" to="112va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT7419HagDosME">Hagiographic dossier of Madḫānina ʾƎgziʾ</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="4ra" to="67rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1476GadlaM">Gadla Madḫānina ʾƎgziʾ</title>
                                <incipit xml:lang="gez">
                                    <locus target="#4ra"/>
                                    በስመ፡ እግዚአብሔር፡ አዶናይ፡ ዓቢየ፡ ምክር፡ ወብሑተ፡ ዕበይ። ምስለ፡ ወልዱ፡ ወምስለ፡ መንፈስ፡ ቀዱስ፡ ዕሩይ። ወበስመ፡ እግዚአብሔር፡ ወልድ፡ ባሕርይ፡
                                    ዘእምባሕርይ። ተዋሕዶተ፡ ስሙ፡ ምስለ፡ አብ፡ ወምስለ፡ መንፈስ፡ ቅዱስ። እምቅድም፡ ዓለም፡ ፀሐይ፡ ዘለብሰ፡ ሥጋ፡ መለኮቱ፡
                                    ዘኢይትረዓይ። <gap reason="ellipsis"/></incipit>
                                <incipit xml:lang="gez">
                                    <locus from="5va" rendition="5vb"/>
                                    ንዌጥን፡ በረድኤተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዜና፡ ገድል፡ ዘአቡነ፡ መደኃኒነ፡ እግዚእ፡ እስመ፡ ተወልደ፡ በሀገረ፡ እንተ፡ ስማ፡ ቢሐት፡ ስመ፡ አቡሁ፡ ሰንበት፡
                                    ተ<cb n="b"/>ስፋነ፡ ወስመ፡ እሙ፡ ኅሪት፡ ማርያም፡ ወአቡሁሰ፡ ዓቢይ፡ ካህን፡ ውእቱ።</incipit>
                                
                                <colophon xml:id="coloph1" xml:lang="gez">
                                    <note>The colophon states that the manuscript was commissioned by
                                        the Italian government.</note>
                                    <locus target="#67rb"/>
                                    ዛቲ፡ መጽሐፍ፡ ዘአጽሐፋ፡ መንግሥተ፡ ኢጣልያ፡ 
                                </colophon>
                           </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="67va" to="78vb"/>
                                <locus from="80va" to="106ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7420MirME">Taʾammǝra Madḫānina ʾƎgziʾ</title>
                                
                                <msItem xml:id="ms_i1.2.1">
                                    <locus from="67va" to="71rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7435MMESamuel">Miracle of Madḫānina ʾƎgziʾ: Miraculous vision of the death
          of ʾAbuna Madḫānina ʾƎgziʾ by his student Sāmuʾel through the Holy Spirit, and other
          miracles that took place when Sāmuʾel arrived at the tomb of his spiritual father on the
          fortieth day after his death</title>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ ለአቡነ፡ መድኃኒነ፡ እግዚእ፡ ዘኮነ፡ በዝህሩ፡ እምድኅረ፡ ሞቱ፡ <gap reason="ellipsis"/> ወአቡነ፡ ሳሙኤል፡ 
                                        ፀሐይ፡ ወልዱ፡ ማዕምረ፡ ኅቡዓት፡ ርእየ፡ በመንፈስ፡ ቅዱስ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ሳፍ፡ ሞቶ፡ ለአቡነ፡ በከየ፡ በባሕቲቱ፡ ወዓንብአ፡ ወይቤ፡ ወይሌ፡ ዘይቀሥፍ፡ ልበ። 
                                        ወባሕቱ፡ ተፈሥሐ፡ ሶበ፡ ርእየ፡ እንዘ፡ ያዓርፎ፡ እግዚእነ፡ በክብር፡ ወበስብሐት፡ ለአቡነ፡ ውስተ፡ ታዕካሁ፡ ዘብርሃን። ደቁቁ፡ ለአቡነ፡ መድኃኒነ፡ እግዚእ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.2">
                                   <locus from="71rb" to="75ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7438MMEGabraKr">Miracle of Madḫānina ʾƎgziʾ: Miraculous visions at the
          tomb of Madḫānina ʾƎgziʾ by his student Gabra Krǝstos, and other miracles that took place
          on his tomb</title>
                                    <incipit xml:lang="gez">ወካዕበ፡ ስምዑ፡ ዘገብረ፡ ተአምረ፡ ካልአ፡ ዘኮነ፡ ወሀሎ፡ እስከ፡ ይእዜ፡ በዝህሩ፡ ለአቡነ፡ መድኃኒነ፡ 
                                        እግዚ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">እ፡</t:supplied>
                                        በከመ፡ ርእዮ፡ ኄር፡ ገብረ፡ ክርስቶስ፡ ወልዱ። በአሐቲ፡ እምነ፡ መለያልይ፡ እስመ፡ ሖረ፡ ይጼሊ፡ በከመ፡ ልማዱ።
                                        ልማዱ። ይቤ፡
                                        ሶበ፡ በጻሕኩ፡ ቅሩበ፡ አንቀጽ፡ ርኢኩ፡ ቤተ፡ ክርስቲያን፡ ርኅወ፡ ኃዋኅዊሐ። ወኵለንታሃ፡
                                        ብርህት፡ ከመ፡ ፀሐይ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.3">
                                    <locus from="75ra" to="78ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7439MMEAhmad">Miracle of Madḫānina ʾƎgziʾ: Miracles worked by Madḫānina
          ʾƎgziʾ during the invasion of ʾAḥmad Grāññ</title>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ስምዑ፡
                                        አበዊነ፡ ወአሐዊነ፡ እለ፡
                                        በክርስቶስ፡ ሀሎክሙ፡ ሐዲስ፡ ተአምሪሁ፡ ለአቡነ፡ መድኃኒነ፡ እግዚእ፡ <gap reason="ellipsis"/>
                                        ሀለወክሙ፡ ጽሑፈ፡ በዜና፡ ገድሉ፡ ባሕቱ፡ ንነግር፡ ዘኮነ፡ ይእዜ፡ በመ<cb n="b"/>ዋዕሊነ፡ እንዘ፡ ንጉሥነ፡ ሠርፀ፡ ድንግል፡ ወመኰንንነ፡ ይስሐቅ፡ ወአበ፡
                                        መንፈስነ፡ ዕንባቆም፡ ገሪማ፡ <gap reason="ellipsis"/> ወኮኑ፡ ይመጽኡ፡ ኵሎ፡ አሚረ፡
                                        አረማውያን፡ ዘውእቶሙ፡ ትርኵ፡ ለነሲተ፡ ደብሩ፡ ቅድስት።</incipit>
                                   </msItem>
                                
                                <msItem xml:id="ms_i1.2.4">
                                    <locus from="78rb" to="78vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7442MMEHealing">Miracle of Madḫānina ʾƎgziʾ: Healing of a sick boy</title>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ወሀሎ፡
                                        ካዕበ፡ ፩ ወልድ፡ ሕሙም፡ ውስተ፡ እግረ፡ ደብሩ፡ ለአቡነ፡ ወነበረ፡ እንዘ፡ የሐምም፡ ጕንዱየ፡
                                        መዋዕለ፡ <pb n="78v"/><cb n="a"/> ወእምብዝኃ፡ ደዌሁ፡ ብህመ፡ ልሳኑ፡ ወጸመ፡ እዘኒሁ፡ ወኮነ፡ ከመ፡ ዕብን፡ ውጉረ።</incipit>
                                    
                                   </msItem>
                                
                                <msItem xml:id="ms_i1.2.5">
                                    <locus from="80va" to="88vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7443MMEFasiladas">Miracle of Madḫānina ʾƎgziʾ: Miracles worked by ʾAbuna
          Madḫānina ʾƎgziʾ after an order by King Fāsiladas to plant beautiful trees around the
          cathedral of ʾAksum during its reconstruction</title>
                                    <incipit xml:lang="gez">ስምዑ፡ ዘንተ፡ ኵልክሙ፡ አሕዛብ፡ ወአጽምዑ፡ ኵልክሙ፡ እለ፡ ትነብሩ፡ ውስተ፡ ዓለም፡ 
                                        <gap reason="ellipsis"/><pb n="81r"/><cb n="a"/> <gap reason="ellipsis"/> ተአምሪሁ፡ ለአቡነ፡ መድኃኒነ፡ እግዚእ፡ ሠናየ፡ 
                                        ዝክር፡ ረድኤተ፡ ጸሎቱ፡ ይዕቀበነ፡  <gap reason="ellipsis"/><cb n="b"/><gap reason="ellipsis"/>
                                        ወአመ፡ ፳ወ፫፡ ዓመተ፡ መንግሥቱ፡ ለመፍቀሬ፡
                                        እግዚአብሔር፡ ንጉሥ፡ ፋሲለደስ፡ ወፅዓ፡ ቃለ፡ ትእዛዝ፡ ዓቢይ፡ እምእግዚእናሁ፡ ክቡር፡ ላዕለ፡
                                        ኵሎሙ፡ አንጋድ፡ ወበሐርተ፡ ሢመታት፡ ፵ወ፬
                                        መኳንንት፡ ዘትግሬ። ወመሳፍንቲሃ፡ ሥሉጣን፡ ወዓበይተ፡ መዓርግ፡ <gap reason="ellipsis"/>
                                        ከመ፡ ይት<add place="below">ሐነጽ</add>፡ ሐዲስ፡ እምነ፡ ብልየት፡ በእደ፡ ኵሎሙ፡ በከመ፡ ልማድ። መቅደሰ፡ ጽዮን፡ ታቦተ፡ አምላከ፡ ፳ኤል። ወገበዘ፡ አክሱም፡
                                        ሀገር፡ ዓባይ።
                                    </incipit>
                                    
                                     </msItem>
                                
                                <msItem xml:id="ms_i1.2.6">
                                    <locus from="88vb" to="90va"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7446MMESayfaA">Miracle of Madḫānina ʾƎgziʾ: Meetings of Sayfa ʾArʿad with
          ʾAbuna Madḫānina ʾƎgziʾ before and after expeditions against his enemies and other
          miracles</title>
                                    <incipit xml:lang="gez">ተአምረ፡ ኃይል፡ ዘመንክር፡ ጥቀ፡ ወመድምም፡ በህቁ፡ ዘገብረ፡
                                        ሎቱ፡ ለአቡነ፡ መድኃኒነ፡ እግዚእ፡ ክቡረ፡ ስም፡ ወጻድቅ፡ በኃይለ፡ አምላኩ፡ ከሐሌ፡ ኵሉ።
                                        ለፍቁረ፡ ነፍሱ፡ ንጉሥነ፡ ሰይፈ፡ አርአድ። 
                                        እምብሔረ፡ ትዕይንቱ፡ ምድረ፡ ሸዋ፡ በአስጋብኦ፡ ሠራዊቱ፡ ዘሀገረ፡ መንግሥቱ፡ እምጽንፍ፡
                                        እስከ፡ ጽንፍ፡ እስከ፡ ኮነ፡ ብዝኆሙ፡ ለእሉ፡ ከመ፡ 
                                        ኆፃ፡ ባሕር፡ ዘኢይትኌለቍ፡ ከመ፡ ይሁር፡ ወይመርር፡ ውስተ፡ ብሔረ፡ 
                                        አጽራር፡ ርኁቃን፡ እለ፡ ይሰመዩ፡ ሳባ፡ ኖባ፡ ከመ፡ ይፅብኦሙ፡ ለእሉ፡
                                        በእንተ፡ ሰብአ፡ ናግራን።
                                    </incipit>
                                       </msItem>
                                
                                <msItem xml:id="ms_i1.2.7">
                                    <locus from="99va" to="100ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7448MMEBlind">Miracle of Madḫānina ʾƎgziʾ: Healing of a blind
          person</title>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ወበ፩
                                        እመዋዕል፡ መጽኣ፡ ፩ዱ፡ ዕዉር፡ ምስለ፡ ብእሲ፡ ዘይመርሖ። እንዘ፡ ይፈቅድ፡ ዓሪገ፡ ውስተ፡
                                        ደብረ፡ በንኰል፡ ቅድስት፡ ለተማፅኖ፡ ኀበ፡ መቃብሩ፡ ለአቡነ፡ <cb n="b"/>መድኃኒነ፡
                                        እግዚእ፡ ከመ፡ ያብርህ፡ ሎቱ፡ ዑረተ፡ አእይንቲሁ።</incipit>
                                  </msItem>
                                

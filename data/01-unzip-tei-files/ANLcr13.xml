                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ወአመ፡
                                        ተሐድሶ፡ ሕንፄሃ፡ ዘቅድም<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied>
                                        ለመቅደሰ፡ ደብረ፡ ዓባይ፡ ደብረ፡ በንኰል፡ በከመ፡ ተሐደሰት፡ ቅድመ፡ ኢየሩሳሌም፡ መቅደስ። እምግብረ፡ ኅንፃሐ፡ ዘቅድም፡ በእደ፡ ሄሮድስ፡ ንጉሥ። 
                                        ወልደ፡ አንዳፊር። እስመ፡ ለዛቲ፡ መቅደስ፡ ደብረ፡ <pb n="b"/> ዓበይ፡ ኮኑ፡ ራግዛተ፡
                                        አናቅፂሃ፡ ወዓረፍታተ፡ ኅንፃሃ፡ እለ፡ ተሐንጹ፡ ቀዳሚ፡ በእደ፡ አበው፡ ቀደምት፡ ቅዱሳን፡
                                        ወሐፄራነ፡ አምጣን፡ ወትሑታነ፡ ዓቅም፡ በህቁ።</incipit>
                                </msItem>
                                
                                <colophon xml:id="coloph2" xml:lang="gez">
                                    <locus from="106ra" to="106rb"/>
                                    <note>The colophon states that the manuscript was commissioned
                                        in 1938, under the Italian government, during the tenure of
                                        the Patriarch of Alexandria <persName ref="https://betamasaheft.eu/PRS5714JohnXIX">John XIX</persName>, the
                                        Metropolitan of Ethiopia <persName ref="https://betamasaheft.eu/PRS14840Abreham">ʾAbrǝhām</persName>, the ʾƎč̣č̣age
                                        <persName ref="https://betamasaheft.eu/PRS14841TaklaH">Takla Hāymānot</persName>, the abbot of the
                                        convent of Bankʷal
                                        <persName ref="https://betamasaheft.eu/PRS14844GabraK">Gabra Kidān</persName>, and the governor of Aksum <persName ref="https://betamasaheft.eu/PRS14839Carbone">Adriano Carbone</persName> (‘residente’) .</note>
                                    <gap reason="ellipsis"/>
                                    በ፸፻ወ፬፻ ዓመት፡ እምፍጥረተ፡ ዓለም። ወእም፡ ፲ወ፫ አቅማረ፡ ዓመታት፡ ወ፬፻፡ ፺ወ፫ ተረፈ፡ ቀመር፡
                                    ወእምዓመተ፡ ሥጋዌ። በ፲፻ ወ፺፻ወ፴ ዓመት፡ እምዓመተ፡ ወንጌላውያን፡ ወመጋቤ፡ ዘመን፡ ማርቆስ፡
                                    ወንጌላዊ።
                                    <gap reason="ellipsis"/>
                                    በመንግሥተ፡ ኢጣልያ። በ፫ቱ፡ ዓመት፡ እምዘ፡ አሐዙ፡ ኢትዮጵያ። እንዘ፡ ሊቀ፡ ጳጳሳት፡ <cb n="b"/> ዘእስክንድርያ፡ አባ፡ ዮሐንስ፡ ወሊቀ፡ ጳጳሳት፡ ዘኢትዮጵያ፡ አባ፡ አብርሃም፡
                                    ወጳጳስ፡ ዘአክሱም፡ አባ፡ ማርቆስ። ወእንዘ፡ መምህረ፡ ኢትዮጵያ፡ እጨጌ፡ ተክለ፡
                                    ሃይማኖት<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> ዘነበረ፡ በመንበረ፡ ተክለ፡
                                    ሃይማኖ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">ት</t:supplied>፡ ወበሢመተ፡ መምህር፡ ገብረ፡
                                    ኪዳን፡ ዘደብረ፡ በንኰል። ወገበዘ፡ ጽዮን፡ ዘአክሱም፡ ቄስ፡ ገበዝ፡ ተክለ፡ ሃይማኖት፡

                            <msItem xml:id="ms_i1.4">
                                <locus from="106va" to="107ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7462SalMadEg">Salām to Madḫānina ʾƎgziʾ</title>
                                <incipit xml:lang="gez">ምረረ፡ ኃዘንከ፡ አባ፡ አመ፡ አድግከ፡ ተቀትለ።
                                    በሰዓተ፡ ሞቱ፡ ለአቤል፡ ኀዘነ፡ አዳም፡ መሰለ። ወአመ፡ ጸዋዕኮ፡ በሐቅል፡ ድኅረ፡ ምዉተ፡ <cb n="b"/> ወዓለ። አንበሳ፡ በልዓኒ፡ ብሂሎ፡ እንዘ፡ ይጸርህ፡ ልዑለ። መንፈቀ፡ ሥጋሁ፡
                                    ለአድግ፡ ነበበከ፡ ቃለ። ሰላም፡ በቃለ፡ ስብሐት፡ ወይባቤ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.5">
                                <locus from="107ra" to="112ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT0412Malke">LIT0412Malke</title>
                                <incipit xml:lang="gez">ናሁ፡ ልብየ፡ በእደ፡ ኅሊናየ፡ አስተሐመመ፡ <sic>ወዳሴ፡</sic>
                                    መልክዕከ፡ ይጽሐፍ፡ እንዘ፡ ይእ<cb n="b"/>ኅዝ፡ ቀለመ። መድኃኒነ፡ እግዚእ፡ ባርክ፡ ከመ፡
                                    ቃለ፡ ነቢይ፡ ቅድመ። እስመ፡ አንተ፡ ዘባረካሁ፡ ይትባረክ፡ ፍጹመ። ወዘረገምኮ፡ ይከውን፡ ርጉመ። ሰላም፡ ለዝክረ፡ ስምከ፡ በሰሌዳ፡ መንፈስ፡ ሲራክ፡</incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <locus from="112ra" to="112va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7463SalMadEg">Salām to Madḫānina ʾƎgziʾ</title>
                                <incipit xml:lang="gez">ሰላም፡ ለከ፡ መድኃኒነ፡ እግዚእ፡
                                    ዕንባቆም፡<surplus>፡</surplus> እንዘ፡ ወይነ፡ ትንቢት፡ ትፈሪ። ወአመ፡ ምጽአቱ፡
                                    እምቴማን፡ ለዘመን፡ ደኃሪ። ዘሰማዕከ፡ ድምፀ፡ ፈጣሪ። ሰላም፡ ለከ፡ መድኃኒነ፡ እግዚእ፡ ፋኑኤል፡
                                    ዘልማድከ፡ ትንባሌ።</incipit>

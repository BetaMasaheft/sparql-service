                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Late 19th – early 20th century (?)</date>
                        <seg type="rubrication">Divine names; name of the owner; two groups of lines
                           on the incipit page of Text I; one or two lines in the incipit of every
                           prayer; Ethiopic numerals or their elements; elements of the punctuation
                           signs.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">

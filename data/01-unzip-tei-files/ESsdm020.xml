                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus from="1r" to="4v">ff. 1r-4v</locus>
                           <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT1824Mafteh">Maftǝḥe śǝrāy “Undoing of Charms”:
                              1 protective prayer</title></desc>
                           <q xml:lang="gez">
                              [ጸሎ]ት፡[በእ]ንተ፡ መፍትሔ፡ ሥራይ፡ ዓለመ፡ ነሺራህ፡
                              ለከ፡… </q>
                          <note>Written in the same crude hand as Additio 2. Ink
                           faded and abraded on <locus target="#1r">1r</locus>
                           . </note>
                        </item>
                        <item xml:id="a2">
                           <locus from="39v" to="41v"/>
                           <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT1824Mafteh">Maftǝḥe śǝrāy “Undoing of Charms”:
                              1 protective prayer</title></desc>
                           <q xml:lang="gez">
                               ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡ የዓል፡ ዮወሊ፡
                              ወማሐሙቱ፡ አሐልያሊ፡ አክልያያኤል፡…</q>
                           
                           <note> Written in the same crude hand as Additio 1. </note>
                        </item>
                        <item xml:id="e1"><desc>Scribbles and crude notes: <locus target="#5r">5r</locus>, 9r, 11r, 16r, 23r, 30ar, 35r.</desc> </item>
                        <item xml:id="e2"><desc>pen trial on <locus target="#39v">39v</locus>:<foreign xml:lang="gez"> ጽጌ፡ ማርያም፡ መዝንበ፡ ጥበብ፡ ወእኪን። ፈቲነ፡ ብፈር፡ ዘአለቃ፡
                           አፈወርቅ</foreign>።</desc></item>
                       <item xml:id="e3"><desc>Donor/owner Gabra Kidāne Ṭǝrunah is mentioned in the
                           supplication formulas (<locus target="#26r">26r</locus>, 38r).</desc></item>
                     </list>
                  </additions>

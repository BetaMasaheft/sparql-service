                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="73v"/>
                            <title ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                            <incipit xml:lang="gez">ብስራተ፡ አብ፡ ትሩፍ፡ ረድእ፡ ተናጋሪ፡ በመለኮተ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ፍቁረ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ጸሎቱ፡ ወበረከቱ፡
                                የሀሉ፡ ምስለ፡ ፍቁሩ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS14329WaldaMikael">ወልደ፡ ሚካኤል፡</persName> ለዓለመ፡ ዓለም፡ አሜን፡</incipit> 
                        </msItem>    
                    </msContents>

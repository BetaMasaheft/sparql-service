      <body>
         <div type="bibliography">
            
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">አፉየ፡ ተርኅወ፡ ወልሳንየ፡ ተፈትሐ፨</l>
                  <l n="2">በሰጊድ፡ ወተጋንዮ፡ ሶበ፡ ስመከ፡ ስብሐ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ትጸግወኒ፡ ርስተ፡ ፍሥሓ፨</l>
                  <l n="4">መልዕልተ፡ መስቀል፡ ደመ፡ ገቦከ፡ አንበሐብሐ፨</l>
                  <l n="5">በርግዘትከ፡ አበሳየ፡ ነጽሐ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምዝክረ፡ አማልክት፡ ልዑል፨</l>
                  <l n="2">ዘኢይረክቦ፡ አምሳል፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ዘአብ፡ ቃል፨</l>
                  <l n="4">ኃጥኣነ፡ ከመ፡ ትቤዙ፡ ዐሪገከ፡ ዲበ፡ መስቀል፨</l>
                  <l n="5">ለንጊኖስ፡ ረገዘከ፡ በኲናት፡ ስሁል፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ እምነ፡ ሐሊብ፡ ጸዐዳ፨</l>
                  <l n="2">ወንጹሕ፡ ጥቀ፡ ለሰልሞን፡ እምበረዳ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ሰራዬ፡ ኀጢአት፡ ፈዳዬ፡ እዳ፨</l>
                  <l n="4">ረስየኒ፡ ሰርዌ፡ ቤትከ፡ እንተ፡ ትሰመይ፡ ሳይዳ፨</l>
                  <l n="5">በአምሳለ፡ ያቁም፡ ወበለዝ፡ ለሳሌም፡ አዕማዳ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ እምከርሠ፡ መቃብር፡ ሕቱም፨</l>
                  <l n="2">ድኅረ፡ መተርዎ፡ በጕድብ፡ ከመ፡ ትንሣኤ፡ ዕፅ፡ ወአም፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ትንሣኤ፡ መዋቲ፡ አዳም፨</l>
                  <l n="4">አንሥአኒ፡ በትንሣኤከ፡ አመ፡ ጊዜ፡ ክቡድ፡ ንዋም፨</l>
                  <l n="5">ወቁመተ፡ የማን፡ ክፍለኒ፡ ኢይቁም፡ በፅግም፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ሰላም፡ ለዕርገትከ፡ በፍቅደ፡ ዕለታት፡ አርብዓ፨</l>
                  <l n="2">ድኅረ፡ ተንሣእከ፡ እሙታን፡ ከመ፡ ቃለ፡ መጽሐፍ፡ አይድዐ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ እንተ፡ ታጸድቅ፡ ኃጥአ፨</l>
                  <l n="4">ኣአምን፡ አንሰ፡ ሥላሴከ፡ ወከዊኖተከ፡ ሰብአ፨</l>
                  <l n="5">በጊዜ፡ ፈቀድከ፡ ትቤዙ፡ በግዐ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ሰላም፡ ለመጽአትከ፡ በተጽዕኖ፡ ልዕልት፡ ደመና፨</l>
                  <l n="2">እምፀሓይ፡ ወወርኅ፡ ዘይበርህ፡ ጸዳለ፡ ሥና፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ለዓለም፡ ጊዜ፡ ትኴንና፨</l>
                  <l n="4">አንብረነ፡ ወአሕቅፈነ፡ ለኢየሩሳሌም፡ በሕፅና፨</l>
                  <l n="5">ከመ፡ እንተ፡ ብእሲት፡ መትሕተ፡ ሕፅና፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ ዘለለ፡ ዕለቱ፡ ወዓሙ፨</l>
                  <l n="2">እስመ፡ ረስየ፡ ኪያየ፡ ከመ፡ እፈጽም፡ ስብሐተ፡ ስሙ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ለደቂቀ፡ አዳም፡ ኵሎሙ፨</l>
                  <l n="4">በዝማሕሌተ፡ ስምከ፡ ሶበ፡ ጸለዩ፡ ወኖሙ፨</l>
                  <l n="5">አበሳቲሆሙ፡ ኅድግ፡ ወአስተሥሪ፡ ሎሙ፨</l>
               </lg>
               <lg type="stanza" n="55">
                  <l n="1">ስብሐት፡ ለከ፡ አምላኪየ፡ በኈልቈ፡ ዕለታት፡ ወዓመታት፨</l>
                  <l n="2">ስብሐት፡ ለከ፡ አምላኪየ፡ በኈልቈ፡ ጊዜያት፡ ወሰዓት፨</l>
                  <l n="3">ስብሐት፡ ለከ፡ አምላኪየ፡ በኈልቈ፡ ኵሉ፡ ፍጥረት፨</l>
                  <l n="4">ስብሐት፡ ለከ፡ አምላኪየ፡ በኈልቈ፡ ፍቅደ፡ ረምል፡ ወከዋክብት፨</l>
                  <l n="5">ስብሐተ፡ ሥላሴከ፡ መልአ፡ በዓለም፡ ርብዕት፨</l>
               </lg>
            </div>
         </div>
         
      </body>

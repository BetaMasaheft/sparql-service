               <t:persName xml:lang="gez" xml:id="n1" type="monastic">ተክለ፡ ሃይማኖት፡</t:persName>
               
               <t:persName xml:lang="gez" corresp="#n1">Takla Hāymānot</t:persName>
               <t:persName xml:lang="en" corresp="#n1">"plant of the
                  faith"</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ፍሥሐ፡ ጽዮን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Fǝśśǝḥa Ṣǝyon</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾǝč̣č̣age</t:roleName>
               </t:persName>

               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">abbot</t:occupation>
               <t:birth when="1215"> He was born at a place called 
                  <t:placeName ref="https://betamasaheft.eu/LOC5652Sellal">Ṣǝllāliš</t:placeName> in <t:date>1215</t:date>.
               </t:birth>
               <t:floruit notBefore="1230" notAfter="1313">He was the most celebrated religious figure
                  in medieval Ethiopia who is credited with evangelizing the vast regions of
                  central and southern Ethiopia. He was the founder of the monastery of 
                  <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName> at the beginning of the 14th century. </t:floruit>
               <t:death when="1313"/>
            </t:person>

            

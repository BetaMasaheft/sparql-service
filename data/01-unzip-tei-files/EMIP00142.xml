                  <decoDesc>
                    <summary>(partial-margin artist)</summary>
                    <decoNote type="miniature" xml:id="d1"><locus target="#ivv(erso)" facs="004">Fol. ivv(erso)</locus><desc>Seated figure holding in one hand a staff with a <term key="cross" ana="#cross"/> on the tip and, in the other, a book</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#59r" facs="063">Fol. 59r</locus></decoNote>
                    <decoNote type="frame" xml:id="d3">
                      Decorative designs: <locus target="#1r" facs="005">fols. 1r, </locus> (haräg); <locus target="#59r" facs="063">59r</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="a1">
                      <desc>
                      <locus target="#ivr(ecto) #ivv(erso)" facs="004 005">Fols. ivr(ecto), ivv(erso)</locus>: Beginning of <title type="incomplete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                      </desc>
                      </item>
                      <item xml:id="a2">
                      <desc type="Asmat">
                      <locus target="#59r" facs="063"> f. 59r, col. 2</locus>: Asmat prayer for help in learning.
                      <foreign xml:lang="gez">አስማተ፡ ድርሰት፡ ኩና፡ ፫፡ [ጊዜ፡] በል፡...</foreign>
                      </desc>
                      </item>
                      <item xml:id="a3">
                      <desc type="Asmat">
                      <locus target="#60v #61r" facs="065">Fols. 60v, 61r</locus>: Asmat prayer against fire and theft (written without word dividers).
                      <foreign xml:lang="gez">አግማኤል፡ ጸሎተ፡ ሙሴ፡ አምላከ፡ አናንያ፡ ወአዛርያ፡ ወሚሳኤል፡...</foreign>
                      </desc>
                      </item>

                      <item xml:id="e1">
                      <desc>
                      <locus target="#ir(ecto) #iv(erso)" facs="001 002">Fols. ir(ecto), iv(erso)</locus> scrawls
                      </desc>
                      </item>
                      <item xml:id="a4">
                      <desc type="OwnershipNote">
                      Secondary owner, Wäldä Arägawi and Wäldä Iyäsus
                      </desc>
                      </item>
                      <item xml:id="e2">
                      <desc>
                      <locus target="#59v #60r #61v #62r #62v" facs="064 066 067">Fols. 59v, 60r, 61v, 62r, 62v</locus> blank save for a few letters and pen trials
                      </desc>
                      </item>
                      <item xml:id="e3">
                      <desc>
                      words of text are written interlinearly (<locus target="#6v #7v #12v #25r" facs="011 012 017 029">folss. 6v, 7v, 12v, 25r, </locus>);
                      and lines of text are written interlinearly (ff. <locus target="#6v #8r #9r" facs="011 012 013">6v, 8r, 9r, </locus>);
                      and in the upper margin with a symbol (+) marking the location where the text is to be inserted (<locus target="#12v" facs="017"> f. 12v, col. 1, line 7</locus>; <locus target="#12v" facs="018"> f. 12v, col. 2, line 14</locus>);
                      erasure markings are visible (<locus target="#7v" facs="012">7v, </locus>)
                      text has been removed (e.g., <locus target="#29r #36r" facs="033 040">29r, 36r</locus>)
                      </desc>
                      </item>

                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 194 x 167 x 45 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, headband and tailband.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

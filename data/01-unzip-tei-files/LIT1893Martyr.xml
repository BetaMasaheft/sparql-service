         <t:div type="bibliography">
            <t:listBibl type="editions">
               <t:bibl corresp="http://zotero.org/groups/358366/items/7X73H4I5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Pereira1907Acta"/><title level="m">Acta Martyrum</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><author><forename>Franciscus Maria</forename><surname>Esteves Pereira</surname></author><pubPlace>Romae</pubPlace><publisher>Excudebat Karolus de Luigi</publisher><date>1907</date><series><title level="s">Corpus Scriptorum Christianorum Orientalium</title><biblScope unit="volume">Series Altera 28</biblScope></series><biblScope unit="volume">Series Altera 28</biblScope><note type="url">https://archive.org/details/actamartyrum01este</note><note type="tags"><note type="tag">bm:Pereira1907Acta</note></note><note type="tag">bm:Pereira1907Acta</note><t:citedRange>1-67</t:citedRange></t:bibl>
            </t:listBibl>
            <t:listBibl type="secondary">

               <t:bibl corresp="http://zotero.org/groups/358366/items/9MWQV2EZ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Graf1944GCALI"/><title level="m">Geschichte der christlichen arabischen Literatur&lt;hi rend="italics"&gt;, I:&lt;/hi&gt; Die Übersetzungen</title><title level="s">Studi e Testi</title><author><forename>Georg</forename><surname>Graf</surname></author><pubPlace>Città del Vaticano</pubPlace><publisher>Biblioteca Apostolica Vaticana</publisher><date>1944</date><series><title level="s">Studi e Testi</title><biblScope unit="volume">118</biblScope></series><biblScope unit="volume">I</biblScope><biblScope unit="volume">118</biblScope><note type="url">https://archive.org/details/GGrafGeschichte</note><note type="tags"><note type="tag">bm:Graf1944GCALI</note></note><note type="tag">bm:Graf1944GCALI</note><t:citedRange unit="page">516</t:citedRange></t:bibl>
            </t:listBibl>
            
         </t:div>
         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Prologue">
               <t:label>Prologue</t:label>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab> ዝንቱ፡ ገድል፡ ወጻማ፡ ወስምዕ፡ ዘቅዱስ፡ ሊቀ፡ ሐራ፡ <t:gap reason="omitted" extent="unknown"/>
                     ወአውሥአ፡ ሊቀ፡ ጳጳሳት፡ ወይቤሎሙ፡ ሠናይ፡ ምጽአትክሙ፡ </t:ab>
               </t:div>
            </t:div>
            <t:div type="textpart" subtype="chapter" n="2" xml:id="MainPart">
               <t:label>Main part</t:label>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab> ዝንቱ፡ ፋሲለደስ፡ ሊቀ፡ ሐራ፡ ወልደ፡ አውዶኪዮስ፡ እኍሁ፡ ለሲድራኮስ፡ </t:ab>
               </t:div>
               <t:div type="textpart" subtype="explicit" xml:lang="gez" xml:id="Taamer" corresp="https://betamasaheft.eu/LIT6692MirFasiladas">
                  <t:label>Taamer</t:label>
                  <t:ab> ወኮነ፡ እምኔሃ፡ ተአምራት፡ ዐበይት። ወይእዜኒ፡ ናሁ፡ አጠየቁክሙ፡ ኦአሕዛብ፡ <t:gap reason="omitted" extent="unknown"/> ውስተ፡ በተ፡ መርዓዊ፡ ሰማያዊ፡ በኢየሩሳሌም፡ ሰማያዊት፡ ዘለእግዚእነ፡ <t:gap reason="omitted" extent="unknown"/> ለይኩን። </t:ab>
               </t:div>
               <t:div type="textpart" subtype="explicit" xml:lang="gez" xml:id="hymn">
                  <t:label>Hymn</t:label>
               </t:div>

               <t:div type="textpart" subtype="colophon" xml:lang="gez">
                  <t:ab> ተተርጉመ፡ ዝንቱ፡ መጸሐፍ፡ እምልሳነ፡ ቅብጢ፡ ኀበ፡ ግዕዝ፡ እምዓመት፡ ፷፻ወ፰፻፹ወ፱ለፍጥረተ፡ ዓለም። አምዓመተ፡
                     ስማዕታት፡ ጻድቃን፡ <t:date>፲፻ወ፪፻ወ፴</t:date>። ዘተርጐሞ ፡ ለዝንቱ፡ መጽሐፍ፡ አባ ፡ ስምዖን፡ ወአዕለዎ፡ እምልሳነ፡
                     ግብጽ፡ ኀበ፡ ልሳነ፡ ግዕዝ፡ ካህን፡ መነኮስ፡ ዘእምደብረ፡ እንጦንዮስ፡ </t:ab>
               </t:div>
            </t:div>
         </t:div>
      </t:body>
   </t:text></TEI>
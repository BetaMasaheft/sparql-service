                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="45r" to="67r" facs="045">Fols 45r–67r</locus>
                    <title>Prayer for the journey to heaven, part of the <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                     </title>
                  </msItem>

                                <textLang mainLang="gez"/>
                                <note>Only the beginning is present.</note>
                            </msItem>
                            
                            <msItem xml:id="p2_i3">
                                <locus from="179" to="181">Fols 179–181</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT4518Hymn">Hymn to Jesus Christ</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                                    <lb n="1"/>አምላኪየ፡ አምላኪየ፡ ነጽረኒ፡ ወትረ፡ ወኢትኅድገኒ፡ ዘልፈ።
                                    <lb n="2"/>ከመ፡ አንተ፡ ትቤ፡ እንዘ፡ ትከሥት፡ አፈ።
                                    <lb n="3"/>ትፈጽም፡ እንተ፡ ተጽሕፈ።
                                    <lb n="4"/>  ስብሐት፡ ለከ።
                                </incipit>
                            </msItem>
                            
                            

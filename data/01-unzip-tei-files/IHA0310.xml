               <msContents>
                  <summary>Litograph print</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="1">p. 1-1</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0954IHA">دعاء رب اني اعوذ بك</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>رب اني اعوذ بك ان اسئلك ما ليس لي [به] علم والا تغفر لي وترحمني اكن من الخسرين رب اغفر لي ولاخي وادخلنا فى رحمتك وانت ارحم الراحمين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>رب انزلني منزلا مباركا وانت خير المنزلين رب لا تجعلني فى القوم الظلمين امين</explicit>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/4HRHD42Z"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook904"/><title level="m">al-Qur'ān al-karīm (3)</title><editor><name>Mawlawī Fatḥ Muḥammad</name></editor><editor><name>Mawlawī ʻAbd al-Salām</name></editor><editor><name>Ḥafīẓ Masʻūd Aḥmad Ḫān Aʻẓamī</name></editor><editor><name>Muḥammad ʻAbd al-Ḫāliq Šāh Abādī</name></editor><pubPlace>Bombay</pubPlace><publisher>Maṭbaʻ Muḥammadī</publisher><date>1372</date><note type="tags"><note type="tag">bm:IHABook904</note></note><note type="tag">bm:IHABook904</note></bibl>
                        </listBibl>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="1">p. 1-1</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3873IHA">دعاء رب اغفر وارحم وانت خير الراحمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>رب اغفر وارحم وانت خير الراحمين رب هب لي حكما والحقنى بالصالحين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 1">-p. 1</locus>ربنا اغفر لنا ذنوبنا واسرافنا في امرنا وثبت اقدامنا وانصرنا على القوم الكفرين</explicit>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/4HRHD42Z"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook904"/><title level="m">al-Qur'ān al-karīm (3)</title><editor><name>Mawlawī Fatḥ Muḥammad</name></editor><editor><name>Mawlawī ʻAbd al-Salām</name></editor><editor><name>Ḥafīẓ Masʻūd Aḥmad Ḫān Aʻẓamī</name></editor><editor><name>Muḥammad ʻAbd al-Ḫāliq Šāh Abādī</name></editor><pubPlace>Bombay</pubPlace><publisher>Maṭbaʻ Muḥammadī</publisher><date>1372</date><note type="tags"><note type="tag">bm:IHABook904</note></note><note type="tag">bm:IHABook904</note></bibl>
                        </listBibl>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2" to="609">p. 2-609</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 2">-p. 2</locus>بسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ

الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ

الرَّحْمَنِ الرَّحِيمِ

مَالِكِ يَوْمِ الدِّينِ

إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ

اهدِنَا الصِّرَاطَ الْمُسْتَقِيمَ

صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلاَ الضَّالِّينَ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 609">-p. 609</locus>بسم الله الرحمن الرحيم

قُلْ أَعُوذُ بِرَبِّ النَّاسِ

مَلِكِ النَّاسِ

إِلَهِ النَّاسِ

مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ

الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ

مِنَ الْجِنَّةِ وَالنَّاسِ</explicit>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/4HRHD42Z"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook904"/><title level="m">al-Qur'ān al-karīm (3)</title><editor><name>Mawlawī Fatḥ Muḥammad</name></editor><editor><name>Mawlawī ʻAbd al-Salām</name></editor><editor><name>Ḥafīẓ Masʻūd Aḥmad Ḫān Aʻẓamī</name></editor><editor><name>Muḥammad ʻAbd al-Ḫāliq Šāh Abādī</name></editor><pubPlace>Bombay</pubPlace><publisher>Maṭbaʻ Muḥammadī</publisher><date>1372</date><note type="tags"><note type="tag">bm:IHABook904</note></note><note type="tag">bm:IHABook904</note></bibl>
                        </listBibl>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="609" to="614">p. 609-614</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4124IHA">دعاء ختم القران ربنا تقبل منا انك انت السميع</title>
                     <incipit xml:lang="ar">
                        <locus target="#305r">-305r</locus>صدق الله صدق الله العلي العظيم وصدق رسوله النبي الكريم ونحن على ذلك الشهيدين والشكرين والحمد لله رب العلمين ربنا تقبل منا انك انت السميع العليم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#308v">-308v</locus>اللهم ارزقنا اداء بالقلب وحب الخير والسعادة والبشارة من الايمان اللهم صل على محمد وعلى ال محمد وصحبه بعدد ما فى جميع القران حرفا وبعدد كل حرف الفا الفا</explicit>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/4HRHD42Z"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook904"/><title level="m">al-Qur'ān al-karīm (3)</title><editor><name>Mawlawī Fatḥ Muḥammad</name></editor><editor><name>Mawlawī ʻAbd al-Salām</name></editor><editor><name>Ḥafīẓ Masʻūd Aḥmad Ḫān Aʻẓamī</name></editor><editor><name>Muḥammad ʻAbd al-Ḫāliq Šāh Abādī</name></editor><pubPlace>Bombay</pubPlace><publisher>Maṭbaʻ Muḥammadī</publisher><date>1372</date><note type="tags"><note type="tag">bm:IHABook904</note></note><note type="tag">bm:IHABook904</note></bibl>
                        </listBibl>
                     </note>
                     <note/>

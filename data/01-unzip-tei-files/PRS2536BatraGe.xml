               <t:persName xml:lang="gez" xml:id="n1" type="birth">በቴርጌላ፡ ማርያም፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Batergelā Māryām</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">ቤቴርጌላ፡ ማርያም፡</t:persName>

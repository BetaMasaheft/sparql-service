         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አስፋ፡ ወሰን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAsfā Wasan</t:persName>
                 <t:persName>
                  <t:roleName type="title">marǝd ʾazmāč</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  <t:occupation type="political">ruler</t:occupation>
              
               <t:floruit notBefore="1775" notAfter="1808">He was the fifth ruler of the kingdom of 
                  <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">
                  Šawā </t:placeName> from about <t:date>1775</t:date> to <t:date>1808</t:date>,
                  succeeding his father 
                  <t:persName ref="https://betamasaheft.eu/PRS1878AmmehaI">
                     <t:roleName type="title">marǝd ʾazmāč</t:roleName> ʾAmmǝḫā ʾIyasus</t:persName>. 
                  His reign was remarkable for the expansion of the  Šawān kingdom to include the 
                  <t:placeName ref="https://betamasaheft.eu/LOC6568Amhara">ʾAmhārā</t:placeName> 
                  regions <t:placeName ref="https://betamasaheft.eu/LOC3389Gedem">Gǝdǝm</t:placeName>, 
                  <t:placeName ref="https://betamasaheft.eu/LOC3440Gesse">Gǝšše</t:placeName>, 
                  <t:placeName ref="https://betamasaheft.eu/LOC2794Efrata">ʾƎfrātā</t:placeName>, 
                  <t:placeName ref="https://betamasaheft.eu/LOC1474AnSoki">ʾAnṣokiyā</t:placeName>, 
                  <t:placeName ref="https://betamasaheft.eu/LOC4578Marhab">Marḥābete</t:placeName> and 
                  <t:placeName ref="https://betamasaheft.eu/LOC4865Morat">Morat</t:placeName>.
                  His reign is also attributed to the introduction of tax on land and royal monopoly in such 
                  precious items as gold and ivory as well as the production of ṭaǧǧ.
               </t:floruit>
                  
            
               </t:person>
               
         </t:listPerson>

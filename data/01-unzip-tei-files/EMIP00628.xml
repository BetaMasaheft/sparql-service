                  <origin>
                     <origDate notBefore="1929" notAfter="1950">Early twentieth century (<locus target="#4r #6r" facs="008 010">fols. 4r, 6r</locus> mention Abba Qerǝlos).</origDate>
                  </origin>
               </history>

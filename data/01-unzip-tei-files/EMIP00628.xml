                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word Mary is rubricated</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1025NativityJesus">Nativity of Jesus</ref> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with caption <q>“Flowers from the Holy Land Placed on the Holy Sepulcher” </q> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1067LastSupper">The Last Supper</ref> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#ivv(erso)" facs="005">Fol. ivv(erso)</locus><desc>a printed card of the Holy Family has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#49r" facs="053">Fol. 49r</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#50r" facs="054">Fol. 50r</locus><desc>a printed card of <ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref> has been pasted onto the folio</desc></decoNote>
                    <decoNote type="frame" xml:id="d8">
                    Decorative designs:
                    <locus target="#1r #51r #71r" facs="005 055 075">folss. 1r, 51r, 71r, </locus> (ornate, colorful ḫarägs);
                    <locus target="#48v" facs="053">48v, </locus> (lines of red and black dots);
                    <locus target="#60r #72v" facs="064 077">60r, 72v</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r #36v" facs="005 041">Fols. 1r, 36v</locus>
                    <desc>
                      Title <q>Monday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#6v" facs="011">Fol. 6v</locus>
                    <desc>
                      Title <q>Tuesday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#9v" facs="014">Fol. 9v</locus>
                    <desc>
                      Title <q>Wednesday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#18v" facs="023">Fol. 18v</locus>
                    <desc>
                      Title <q>Thursday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#25v" facs="030">Fol. 25v</locus>
                    <desc>
                      Title <q>Friday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#29v" facs="034">Fol. 29v</locus>
                    <desc>
                      Title <q>Saturday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#32v" facs="037">Fol. 32v</locus>
                    <desc>
                      Title <q>Sunday</q> for readings for the days of the week
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <locus target="#1v" facs="006">Fol. 1v</locus>
                    <desc type="OwnershipNote">
                    name of the second owner, Abäbä Täklä Ṣadǝq, is written over the name of the original owner which is erased. The original owner appears to have been someone with the second name of Abära; cf. <locus target="#73r">Fol. 73r</locus>
                    </desc>
                    </item>
                    <item xml:id="a9">
                    <locus target="#4r #6r" facs="008 010">Fols. 4r, 6r</locus>
                    <desc>
                    mention Abba Qerǝlos (2 June 1929–22 October 1950)
                    </desc>
                    </item>
                    <item xml:id="a10">
                    <locus target="#48v" facs="053">Fol. 48v</locus>
                    <desc>
                    name of the scribe: Täklä Haymanot
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    The manuscript has been foliated in Gǝ‘ǝz numbers by a later hand
                    </desc>
                    </item>
                    <item xml:id="a11">
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    <desc>
                    “1938, twentieth of Yäkkatit, at night, he was born.”
                    </desc>
                    </item>
                    <item xml:id="a12">
                    <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                    <desc>
                    “The date Abäbä Čärǝnät was born was 1917 EC, sixteenth of Mäskäräm on the [feast of] Mercy of the Covenant, at Arero Bedegon. His baptismal name was Täklä Ṣadǝq”
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#ivr(ecto) #49v #74v" facs="004 054 079">Fols. ivr(ecto), 49v, 74v</locus>
                    <desc>
                    blank
                    </desc>
                    </item>
                    <item xml:id="a13">
                    <locus target="#60r" facs="064">Fol. 60r</locus>
                    <desc>
                    the scribe wrote two mistaken lines, which he then erased, and over which he placed 10 parallel lines per line of text to indicate the error
                    </desc>
                    </item>
                    <item xml:id="a14">
                    <locus target="#73r" facs="077">Fol. 73r</locus>
                    <desc type="DonationNote">
                    Note of gift of the manuscript: “On 1941 EC, the first of Mäskäräm this prayer book was given to Lǝj Abäbä Čärǝnät from [illegible] Abära
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#73v #74r" facs="078">Fols. 73v, 74r</locus>
                    <desc>
                    erased notes in various hands and inks
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    The workmanship, quality of parchment, tooled leather, trimmed paste downs and, especially, the colorful ḫärags, point to the government scriptorium as the place of production for this codex
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#51v #52r #54r" facs="056 058">Fols. 51v, 52r, 54r</locus>
                    <desc>
                    words of text are written interlinearly
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, three Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, covered with tooled leather.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>

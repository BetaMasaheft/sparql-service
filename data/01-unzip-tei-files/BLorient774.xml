                                <msItem xml:id="ms_i30">
                                    <locus from="148r"/>
                                    <title ref="https://betamasaheft.eu/LIT5863JohnRome">The history of John of Rome</title>

                                    <incipit xml:lang="gez" type="inscriptio">ዜናሁ፡ ለኄር፡ አቡነ፡ ቅዱስ፡ ዮሐንስ፡ ዘአፕረየ፡ ወንጌለ፡ ዘወርቅ።</incipit>
                                    <note>On the margin: <foreign xml:lang="gez">አመ፡ ፲ወ፫፡ ለግንቦት፡ ም፡</foreign></note>
                                    <incipit xml:lang="gez">ወሀሎ፡ ፩ብእሲ፡ በሀገረ፡ ሮሜ፡ እማዓበይተ፡ ንጉሥ፡ ዘስሙ፡ ክስስኖፎስ፡ ወበእሲቱኒ፡ ስማ፡ እንድሮና።
                                        ወባዕል፡ ውእቱ፡ በእሲሁ፡ ፈድፈደ፡ ወብዙኅ፡ ብዋዩ፡ ወቦ፡ ፫ደቂቀ፡ ፪እምኔሆሙ፡ ልሂቃን፡ ወየሓውሩ፡ ምስሌሁ፡ ኅበ፡ ንጉሥ፡ ኩሎ፡
                                        አሚር። ወዘይነስ፡ ወልዱ፡ ዮሐንስ፡ ስሙ፡ ወያፊቅሮ፡ አቡሁ፡ እምነ፡ አኃቂሁ፡
                                    </incipit>
                                </msItem>

                                <msItem xml:id="ms_i31">
                                    <locus from="152v"/>
                                    <title ref="https://betamasaheft.eu/LIT2144OntheT">John Chrysostom on the Ten Virgins</title>
                                    <incipit xml:lang="gez">በእንተ፡ ዐሥሩ፡ ደናግል፡</incipit>
                                    <note>On the margin: <foreign xml:lang="gez">አመ፩፡ ለነሓሲ፡ ም፡</foreign></note>
                                </msItem>

                                <msItem xml:id="ms_i32">
                                    <locus from="158r"/>
                                    <title ref="https://betamasaheft.eu/LIT5864OnTransfiguration">Anastasius Sinaita, on the Transfiguration</title>
                                    <incipit xml:lang="gez">ድርሳን፡ ዘቅዱስ፡ ወብፁዕ፡ አንስጣስዮስ፡ አበ፡ ምኔት፡ ዘደብረ፡ ሲና፡ ዘተበእንተ፡ ዘከመ፡
                                        ተወለጣ፡ ራእዩ፡ ለኢየሱስ፡ በደብረ፡ ታቦር።</incipit>
                                    <note>On the margin: <foreign xml:lang="gez">አመ፩፡ ፲ወ፫፡ ለነሓሲ፡ ም፡</foreign></note>
                                </msItem>

                                <msItem xml:id="ms_i33">
                                    <locus from="165v"/>
                                    <title ref="https://betamasaheft.eu/LIT1634Homily">Jacob of Serug, on the words of the Angel to Zacharias, when he announced the birth of S. John</title>
                                    <incipit xml:lang="gez">በእንተ፡ ዘዜነዎ፡ መልአክ፡ ለዘካርያስ፡ በእንተ፡ ልደቱ፡ ለዮሐንስ፡ መጥምቅ።</incipit>
                                    <note>On the margin: <foreign xml:lang="gez">በበዓለ፡ ስምዖን፡ ምንባብ፡ </foreign></note>
                                </msItem>



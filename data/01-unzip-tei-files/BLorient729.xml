                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="78r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4845Martyr#Gadle">Gadl wa-sǝmʿ za-qǝddus Fiqṭor za-hagara ʾAnṣokiyā: Gadle</title>
                            <textLang mainLang="gez"/>
                            
                            <incipit xml:lang="gez">በስመ፡ አብ፡ etc. ድርሳን፡ ዘደረሰ፡ አቡነ፡ ቅዱስ፡ ስቡሕ፡ 
                                ወክቡር፡ በኲሉ፡ ምግባረ፡ ሠናይ፡  <persName ref="https://betamasaheft.eu/PRS3251Cyriacus"><roleName type="title">አባ፡</roleName> ህርያቆስ፡</persName> 
                                ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ብህንሳ። 
                                ብሂሎ፡ በእንተ፡ ስባሔ፡ ወክብር፡ ዘመስፍን፡ ፅኑዕ፡ ዓቢይ፡ መኰንን፡ ኅሩይ፡ ለባሴ፡ 
                                መዊእ፡ ክቡር፡  ሰማዕት፡ ቅዱስ፡ ድንግል፡ <persName ref="https://betamasaheft.eu/PRS9744Victor"> <roleName type="title">ማር፡ </roleName> ፊቂጦር፡</persName> 
                                ወልደ፡ ህርማኖስ፡ መኰንን። ወዘከመ፡ ሰአለት፡ ወአስተብቈዓት፡ (sic) ቅድመ፡ ሥዕለ፡ እግዚእትነ፡ ማርያም፡  ወላዲተ፡  አምላክ፡  ወዘከመ፡
                                ሰምዓታ፡ አውያቲሃ፡ ወተወክፈታ፡ ስእለታቲሃ፡ ወበእንተ፡ ዓራዚኒ፡ ዘውእቱ፡ ልብሰ፡ ወርቅ። ወናሁ፡ ተናገረ፡
                                ውስቴቱ፡ እምአመ፡ ተወልደ፡ ዝንቱ፡ ቅዱስ፡ እስከ፡ ፍጻሜ፡ ሰምዑ፡ ዘፈጸመ፡ ገድሎ፡ ሠናየ። አመ፡ ፳ወ፯፡  ለወርኃ፡ 
                                ሚያዝያ፡ በሰላመ፡ እግዚአብሔር፡ አብ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1">
                            <locus target="#78r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4845Martyr#Taamer">Gadl wa-sǝmʿ za-qǝddus Fiqṭor za-hagara ʾAnṣokiyā: Miracles</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ etc. ድርሳን፡ ዘደረሰ፡ አብ፡ ቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS12749Demetrius">ድሜጥሮስ፡</persName> 
                                ሊቀ፡ ኤጴስ፡ ቆጶሳት፡ ዘ<placeName ref="https://betamasaheft.eu/LOC1481Antioc">አንጾኪያ፡</placeName> ዘሤሞ፡
                                ቀሲሰ፡ ለቅዱስ፡ ዮሐንስ፡ ልሳነ፡ ወርቅ፡ በእንተ፡ ክብሩ፡ ወልዕልናሁ፡ ለሰማዕት፡ ፅኑዕ፡ ድንግል፡ ወንጹሕ። ዘተዓገሠ፡ ዘዘ፡ 
                                ዚአሁ፡ ኲነኔ፡ በእንተ፡ ስመ፡ እግዚእነ፡  ኢየሱስ፡ ክቡር፡ ወዘለፈ፡ ነገሥተ፡ ከሓድያነ፡ ዘእንበለ፡ ፍርሃት፡ ወኢድንጋፄ፡ 
                                ወኢግጋፄ፡ ሰማዕት፡ <persName ref="https://betamasaheft.eu/PRS9744Victor"> <roleName type="title">ማር፡ </roleName> ፊቂጦር፡</persName> 
                                ወልደ፡ ህርማኖስ፡ መኰንን፡ ዓቢይ፡ ዘንጉሥ። </incipit>
                        </msItem>
                        
                        
                    </msContents>
                    
                    
                    
                    
                    
                    

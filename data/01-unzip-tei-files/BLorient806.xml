                        <additions>
                            <list>
                        <item xml:id="a1">
                                <locus target="#3r"/>
                                <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                    <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                <q xml:lang="gez">ፍትሐ፡ ነገሥት፡  ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ አለም።</placeName>
                           </q>
                            </item>
                                <item xml:id="a2">
                                    <locus target="#144r"/>
                                    <desc>a copy of a deed of gift of King <persName ref="https://betamasaheft.eu/PRS9153TaklaHa">Takla Hāymānot II</persName> to <placeName ref="https://betamasaheft.eu/LOC2389DabraT">Däbrä Ṭǝbäb</placeName>
                           </desc>
                                </item>
                                
                                <item xml:id="e1">
                                    <locus target="#2r"/>
                                    <desc> The name of the owner of the manuscript was <persName role="owner" ref="https://betamasaheft.eu/PRS12670Anstasyos">ʾAnsṭāsyos</persName>.
                                        
                                        
                                    </desc>
                                    
                                    
                                </item>
                                        
                                
                                <item xml:id="e2">
                                    <locus target="#143v"/>
                                    <desc> The name of the scribe of the manuscript was most probably <persName role="scribe" ref="https://betamasaheft.eu/PRS12671WaldaMikael">Walda Mikāʾel</persName>.
                                        
                                        
                                    </desc>
                                    
                                    
                                </item>
                                
                                
                                
                            </list>
                            
                            
                            
                        </additions>

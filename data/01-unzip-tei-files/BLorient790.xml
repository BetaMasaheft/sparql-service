                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="2r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#PartI">
                              The first part of Gubāʿe mǝśṭirāta zamanāt</title>
                            <textLang mainLang="gez"/>
                            <note><ref type="mss" corresp="https://betamasaheft.eu/BLorient791">London, British Library, BL Oriental 791</ref> contains the second part.</note>

                            <msItem xml:id="ms_i1.1">
                              <locus from="2r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#IntroductionI">Maṣḥafa madbal: Introduction to the first part</title>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis"/> ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወንጽሕፍ፡ መጽሐፈ፡ መድበል፡
                                ዘበትርጓሜሁ፡ጉባዔ፡ ምሥጢራተ፡ ዘመናት፡ ዘገብረ፡ እግዚአብሔር፡ በበጊዜሁ፡ቅድመ፡ በዘመነ፡ ብሉይ፡ እስከ፡ ይመጽእ፡ ዘመነ፡ ሐዲስ፡</incipit>
                        </msItem>

                        <msItem xml:id="ms_i1.2">
                            <locus from="3r" to="184v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#OldTestament">Maṣḥafa madbal: The Old Testament and its Apocrypha in verses</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ እብል፡ ለተዋኅዶ፡ ቅድስት፡ ሥላሴ። ቀዊምየ፡ ቅድመ፡ ሥላሴ። እንበለ፡ ናፍቆ፡ አአምን፡ ህላዌ፡
                              ሥላሴ። ግጻዌሆሙ፡ ሥላሴ፤ ወአካሎሙ፡ ሥላሴ። ወቅዳሴሆሙ፡ ከማሁ፡ ሥላሴ።
                            </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.3">
                          <locus from="184v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#HistoryOfMary">Maṣḥafa madbal: Nagara Māryām</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <colophon xml:id="coloph1">
                    <locus target="#192v"/>
                            አግርሩ፡ ፀሮ፡ ታሕተ፡ እገሪሁ፡ ዕቀቡ፡ ንግሦ፡ ወሠራዊቶ፡ ለ<persName ref="https://betamasaheft.eu/PRS2377Bakaffa"><roleName type="title">ንጉሥ</roleName>ነ፡
                            በካፋ፡</persName>
                            <add><persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName>
                            <gap reason="ellipsis"/>ስብሐት፡ ለክሙ፡
                            ሥላሴ፡ በኍልቈ፡ ኵሉ፡ ሥእርትየ።</add><gap reason="omitted"/>
                            <note>The colophon has been much altered by erasure.</note>
                        </colophon>
                        </msItem>


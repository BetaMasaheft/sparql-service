                     <idno>Platonov cat. III.109</idno>
                  </altIdentifier>
               </msIdentifier>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="1r">Fols 1r and following</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT5837PrayerJesus">Prayer to Jesus Christ</title>
                     <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ወኢበዝ፡ ቃል፡</incipit>
                    <note>The beginning of the text is missing.</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <title type="complete" cert="medium" ref="https://betamasaheft.eu/LIT2993RepCh274">Hymn to Jesus Christ</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ቀዳማዊ፡ ዘእንበለ፡ ትማልም፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <title type="complete" ref="https://betamasaheft.eu/LIT4963Naahabeya">Naʿā ḫabeya ʾo-ʾǝgziʾǝya ʾIyasus Krǝstos</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ነዓ፡ ኀቤየ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5838PrayerJesus">Prayer to Jesus Christ</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ወይእዜኒ፡ ንስአሎ፡ ከመ፡ ይስረይ፡ ለነ፡ ኃጣውኢነ፡</incipit>
                    <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12876HaylaS">Ḫayla Śǝllāse</persName> has been added with another hand at the end of the text.</note>
                  </msItem>
                  <msItem xml:id="ms_i5">
                    <locus from="5r" to="8v">Fols 5r–8v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                    <textLang mainLang="gez"/>
                    <note>The end of the text is missing.</note>
                    <explicit xml:lang="gez">አኮ፡ በዝንቱ፡ ከናፍር፡ ውዱዳት፡ ወአኮ፡ በልሳነ፡ ሥጋ፡ ዘባቲ፡ ድድቅ፡ ወሐሰት፡ ይወጽእ፡</explicit>
                  </msItem>
               </msContents>

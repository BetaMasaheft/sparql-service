                  <decoDesc>
                    <decoNote xml:id="d1" type="ornamentation">
                      <locus target="#1v">Fol. 1v</locus>
                      <desc>A crude ornamental band with an image of a human face within a checked frame. The legend reads <foreign xml:lang="gez">
                        <persName ref="https://betamasaheft.eu/PRS10774Paraq">መንፈስ፡ ቅዱስ፡</persName></foreign>.</desc>
                    </decoNote>
                    <decoNote xml:id="d2" type="miniature">
                      <locus target="#4v">Fol. 4v</locus>
                      <desc>A miniature of the <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> in wich <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> is surrounded by
                    <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and <persName ref="https://betamasaheft.eu/PRS5720JohnChr">John Chrysostom</persName>.</desc>
                    </decoNote>
                  </decoDesc>

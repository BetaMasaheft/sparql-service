                    <msContents>
                      <summary/>

                      <msItem xml:id="ms_i1">
                        <locus from="1r1" to="1v8"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                        <msItem xml:id="ms_i1.1">
                          <locus from="1r1" to="1r8"/>
                          <title type="incomplete">Prologue</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ንጽሕፍ<supplied reason="omitted">፡</supplied> በረድኤተ፡ እግዚአብሔር፡ 
                            መጽሐፈ፡ ልፋፈ፡ ጽድቅ፡ ጸሎተ፡ መድኃኒት፡ ዘጸሐፈ፡ አብ፡ በእደዊሁ፡ ቅዱሳት፡ እም<surplus>፡</surplus>ቅድመ፡ 
                            ይትፈጠሩ፡ ሰማያት፡ ወምድር፡ እም<surplus>፡</surplus>ቅድመ፡ ነፋሳት፡ ወእሳት፡ እም<surplus>፡</surplus>ቅድመ፡ ማያር፡
                            <choice><sic>ወጸልመት፡</sic><corr resp="bm:GrebTiss1935Codices">ወጽልመት፡</corr></choice> 
                          </incipit>
                          <note>
                            The text contains several theological observations on the Trinity, among which (<locus from="1r5" to="1r6"/>):
                            <q xml:lang="gez">
                              አብ፡ ብርሃን፡ ወልድ፡ ብርሃን፡ እስመ፡ <choice><sic>ተወልድ፡</sic><corr resp="bm:GrebTiss1935Codices">ተወልደ፡</corr></choice> 
                              እም<surplus>፡</surplus>ብርሃን፡ ወመንፈስ፡ ቅዱስ፡ ብርሃን፡ እስመ፡ ሠረፀ፡ እም<surplus>፡</surplus>ብርሃን፡ ወ፫ቲሆሙ፡ ፩ ብርሃን፡
                              ዘኢይጠፍዕ፡ አብ፡ ይቤሎ፡ ለወልዱ፡ ወልድየ፡ ወልድኒ፡ ይቤሎ፡ ለአብ፡ አቡየ፡ ወለመንፈስ፡ ቅዱስኒ፡ ይቤልዎ፡ አብ፡ ወወልድ፡ ሕይወትነ፡
                            </q>.
                            The text concludes abruptly.</note>
                          <explicit xml:lang="gez">
                            ሮልያ፡ ማሙታ፡ ድብእያል፡ እሎንተ፡ አስማቲሁ፡ ነገራ፡ ለ<gap reason="illegible"/> ያከብሩ<supplied reason="omitted">፡</supplied> ለጻድዋን፡ 
                            በውስተ፡ ገነ<surplus>ጋ</surplus>ተ፡ ትፍሥሕት፡ ወኃ <supplied reason="lost">ሤት፡ ወይ</supplied>ነብሩ፡ ኃጥአን፡ 
                            <supplied reason="lost">ውስተ፡</supplied> ሥቃይ<supplied reason="omitted">፡</supplied>
                          </explicit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus from="1v1" to="1v3"/>
                          <title type="complete">Prayer for the heavenly journey</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ መንገድ፡ ሰማይ፡ በደኃሪት፡ መዋዕል፡ በህየ፡ ይነሥኡ፡
                            መላእክት፡ ማዕጠንታተ፡ <choice><sic>ወየዓርጉ፡</sic><corr resp="bm:GrebTiss1935Codices">ወያዓርጉ፡</corr></choice> በእንተ፡
                            ምሕረተ፡ ሰብእ፡ ወያበርህ፡ ማኅቶተ፡
                            </incipit>
                          <explicit xml:lang="gez">
                            እንዘ፡ ይሰደዱ፨ አጋንንት፨ ወፃዕረ፡ <choice><sic>ሞተ፡</sic><corr resp="bm:GrebTiss1935Codices">ሞት፡</corr></choice>
                            ከማሁ፡ ስድድ፡ ሠራዊተ<supplied reason="omitted">፡</supplied> ዲያብሎስ፡ ፀርየ፡ ለገብርከ፡                            
                          </explicit>
                        </msItem>
                        <msItem xml:id="ms_i1.3">
                          <locus from="1v3" to="1v8"/>
                          <title type="incomplete">Seventh section</title>
                          <textLang mainLang="gez"/>
                          <note>The text contains the seventh section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">81 l. 2-83 l. 15</citedRange></bibl>. It concludes abruptly.</note>  
                          <explicit xml:lang="gez">
                            ከማሁ፡ <sic>አዕድውኒ፡</sic> ለገብርከ<supplied reason="omitted">፡</supplied> እምባሕረ፡ እሳት፡ <space reason="owner" unit="chars"/>
                            ግሩም፡ ውስተ፡ መንግሥተ፡ ሰማያት፡ ወነቂሆ፡ እምንዋሙ፡ <sic>አእምሩ፡</sic> ከመ፡ በጽሐ፡ ውስተ፡ ኃዋኅዊሃ፡ ለይእቲ፡ ሀገረ፡ 
                            በላ<supplied reason="omitted">ዕ</supplied>ተ፡ ሰብእ፡ ወሶቤሃ፡ <sic>በጽሑ፡</sic> ውስተ፡ ሞቅሕ፡ ጸልዩ፡ በእሉ፡ አስማት። ዙር፡
                          </explicit>
                        </msItem>
                      </msItem>
                    </msContents>
                  

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine and careful</seg>
                        <seg type="ink">Black, red (strong red)</seg>
                        <date>18th century (?)</date>
                        <seg type="rubrication">Nomina sacra; name of the protagonist; names of the
                           donors; 1st, 2nd, 5th, 6th, 17th and 20th line in the incipit page of
                           Text I; 1st and 2nd line of the incipit page of Text II; one, two or
                           three initial lines of the sections of Text I; the word ሰላም “peace” and
                           its abbreviation in Text II; some words in Text II; elements of the
                           punctuation signs; Ethiopic numerals and/or their elements.</seg>
                     </handNote>

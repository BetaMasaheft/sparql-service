                     <textLang mainLang="ti" otherLangs="gez"/>
                     <incipit xml:lang="ti" type="inscriptio">ጸሎተ፡ ንስሐ። ናይ፡ ንስሐ፡ ጸሎት።</incipit>
                     <incipit xml:lang="ti">ዎ፡ ንዓለም፡ ኵሉ፡ ዝኀዝካ፡ ጐይታና፡ እግዚአብሔር፡ አብ፡
                             ናይ፡ ነፍስናን፡ ናይ፡ መንፈስናን፡ ናይ፡ ሥጋናን፡ ቍስሊ፡ እትፍውሶ፡ ንስኻ፡ እኻ።
                           </incipit>
                     <explicit xml:lang="ti">
                                ብጐይታና፡ ብኢየሱስ፡ ክርስቶስ፡ ምስኡ፡ አብኡ፡ ዘሎ፡ ክብርን፡
                                 ስብሐትን፡ ጽንዓትን፡ ነአኻ፡ ይግባእ፡ ምስኡን፡ ምስ፡
                             መንፈስ፡ ቅዱስን፡ ሎምን፡ ንኵሉ፡ ጊዜን (ንወትሩ፡ መዓልትን፡) ንዘለዓለምን።
                             ሕዝቢ፡ አሜን።
                     </explicit>

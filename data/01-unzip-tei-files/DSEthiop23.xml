                     <textLang mainLang="ti"/>

                     <incipit xml:lang="ti">
                        <locus target="#1r">Fol. 1r</locus>
                        ብአቦ፡  ስም፡  ብወዲ፡  ስምን፡ ብመንፈስ፡  ቅዱስ፡  ስምን፡
                           ሐደ፡  አምላክ፡  አሜን። በስመ፡  አብ፡  ወወልድ፡  ወመንፈስ፡  ቅዱስ፡   አሐዱ፡  አምላክ፡  አሜን።
                           እግዚኦ፡  ነመስግነከ፡  አሎና፡  እግዚኦ፡  ነክብረካ፡  አሎና፡  እግዚኦ፡  ብአኻ፡  ንእመን፡  አሎና።
                     </incipit>

                     <explicit xml:lang="ti">
                              <locus target="#9r">Fol. 9r</locus>
                           ከምቲ፡  ነቦታትና፡  ንአብርሃምን፡  ንዘርዑን፡  ዝነገሮም፡  ክሳዕ፡  ዘለዓለም፡  ምሕረቱ፡  እናዘከረ፡
                                    ንእስራኤል፡  ባርያኡ፡  ተቀበሎ። (ብሥራተ፡  ሉቃ፡  1፡  46-55።)
                                    ካብ፡  እዙይ፡  ንደኀር፡  ዘሎ፡  ከአ፡  እቲ፡  ጸሎታት፡  እዩ። ሰለ፡  እዚ፡  ባህልን፡  እምነትን፡  ፍቅሪ፡  ዓድና፤ ሎሚ፡  ግዝእቲ፡  ጽባሕ፡  ሐራ፡  እትከውን፡
                                    ኤርትራ፡  ከይትርስዑ፡  ኢለ፡  እነሄ፡  ጽሐፈልኩም፡  አሎኩ፡  ኤርትራዊ፡  አቦኩምን፡  ሐውኩምን፡  አባ፡  ጴጥሮስ፡  ገብረ፡  ሥላሴ።

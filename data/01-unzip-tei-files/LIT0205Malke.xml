      <body>
         
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘተበፅዐ፡ ወተወደሰ፨</l>
                  <l n="2">በአፈ፡ መላእክት፡ ወሰብእ፡ እለ፡ አጥረዩ፡ ሞገሰ፨</l>
                  <l n="3">አምኃ፡ ጊዮርጊስ፡ ወጽጌ፡ ድንግል፡ ዘታልሕቁ፡ ንኡሰ፨</l>
                  <l n="4">ምርሑኒ፡ ፍኖተክሙ፡ ዐቅመ፡ ልብየ፡ ዘኀሠሠ፨</l>
                  <l n="5">ኀበ፡ መካኑ፡ ለወልድ፡ ዘተበጽሕ፡ ነፍስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስክሙ፡ እምሥዕርተ፡ ግብራት፡ ዘይሤኒ፨</l>
                  <l n="2">አምጣነ፡ ተቀብዐ፡ ደመ፡ አምላክ፡ ኰናኒ፨</l>
                  <l n="3">አምኃ፡ ጊዮርጊስ፡ መቃሪ፡ ወጽጌ፡ ድንግል፡ እንጦኒ፨</l>
                  <l n="4">ዘጸንዐ፡ ድካምክሙ፡ እምኀይለ፡ ዓለም፡ ማሳኒ፨</l>
                  <l n="5">ለለ፡ ማሕተመ፡ ሞት፡ ይትፈታሕ፡ ትንሣኤ፡ ይኩነኒ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋክሙ፡ እመካነ፡ ዓለም፡ ግብጽ፨</l>
                  <l n="2">መንገለ፡ መካኑ፡ ዘቅድም፡ ጊባኤ፡ ምእመናን፡ አብያጽ፨</l>
                  <l n="3">አምኃ፡ ጊዮርጊስ፡ ወጽጌ፡ ድንግል፡ መገብተ፡ ተግሣጽ፨</l>
                  <l n="4">ሱቁኒ፡ በበትረ፡ ተስፋ፡ ጊዜ፡ ትንታኔ፡ ወዳኅፅ፨</l>
                  <l n="5">ወገቦ፡ ስብእናየ፡ ይንድፍ፡ ፍቅርክሙ፡ ሐጽ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ኀበ፡ ታቀርብ፡ ለክሙ፡ ዘንተ፡ አምኃ፨</l>
                  <l n="2">እስራኤላዊት፡ ነፍስየ፡ ዘኢኅርገት፡ ደብረ፡ ንስሓ፨</l>
                  <l n="3">አምኃ፡ ጊዮርጊስ፡ ወጽጌ፡ ድንግል፡ ለዘመን፡ ከዋክብቲሃ፨</l>
                  <l n="4">እስመ፡ ጽልመታተ፡ ብርሃንክሙ፡ አብርሃ፨</l>
                  <l n="5">ትሴብሐ፡ ለእግዚአብሔር፡ ስቡሕ፡ ዘተሰብሐ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                     <locus from="1r">Fols 1r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1850Malkea">Malkǝʾa gubāʾe</title>
                     <textLang mainLang="gez"/>
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r">Fols 1r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2941RepCh222">ዘበአታ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ ባቍዕ።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.2">
                        <locus from="13r">Fols 13r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2842RepCh125">ዘመስቀል፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ስብሐት፡ ለዝክረ፡ ስምከ፡ ዘመጽሔተ፡ መስቀል፡ ዘተለክዓ።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.3">
                        <locus from="27r">Fols 27r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4347Hymn">ዘልደታ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለልደትኪ፡ መንፈሳዊ።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.4">
                        <locus from="35r">Fols 35r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3097RepCh377">ዘሊባኖስ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኦክርስቶስ፡ ዘተወለድከ፡ እምድንግል።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.5">
                        <locus from="46r">Fols 46r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2868RepCh149">ዘአንጦን<supplied reason="undefined" resp="PRS9622Ullendor">ዮ</supplied>ስ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘቀለመ፡ አሌፍ፡ ፊደሉ፡</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.6">
                        <locus from="52r">Fols 52r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4348Hymn">ዘአፍቀረነ፡ <sic resp="DR">አ</sic>ግዚእ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">እለ፡ ይሤለሱ፡ ለገጽ፡ ወይትወሀዱ፡ በኃይል።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.7">
                        <locus from="65r">Fols 65r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2999RepCh279">ዘዮሐንስ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ እግዚብሔር፡ እሳት፡ በሐቅለ፡ ሕሊና፡ ነዳዲ፡</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.8">
                        <locus from="76v">Fols 76v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2851RepCh133">ዘኪሮስ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ኀበ፡ ዓምደ፡ ወርቅ፡ ዘተጽሕፈ፡</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.9">
                        <locus from="86r">Fols 86r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2849RepCh131">ዘሩፋኤል፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ተጸውዖ፡ ዘቀደመ፡</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.10">
                        <locus from="97r">Fols 97r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3001RepCh281">Hymn to Walatta Ṗeṭros</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ዘሀሎ፡ አመ፡ ኢሀሎ፡ ዘመን።</incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.11">
                        <locus from="109r">Fols 109r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2888RepCh169">Malkǝʾ-hymn to St Mercurius</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ገብረ፡ ኢየሱስ፡ ብሂል።</incipit>
                     </msItem>
                  </msItem>
                  
                  </msContents>
                     

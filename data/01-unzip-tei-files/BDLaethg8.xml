               <msContents>
                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4597Prayer">Prayer against various women's complaints; 
                     also against demons</title> 
                     <textLang mainLang="gez" otherLangs="am"/>
                  </msItem>
                  
                     <msItem xml:id="ms_i2">
                        <title type="complete">Magical letters</title> 
                        <textLang mainLang="gez" otherLangs="am"/>
                        <note>Magical letters arranged in small squares in crossword-like manner.</note>
                     </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4598Salot">ጸሎት፡ በእንተ፡ ሶታላይ፡</title> 
                     <textLang mainLang="gez" otherLangs="am"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሶታላይ፡</incipit>
                     <note>Prayer against infertility and abortion</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <title type="complete">Magical letters</title> 
                     <textLang mainLang="gez" otherLangs="am"/>
                     <note>Another arrangement of magical letters.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4598Salot">Continuation of the prayer against abortion</title> 
                     <textLang mainLang="gez" otherLangs="am"/>
                     <note>Continuation of prayer against abortion.</note>
                     <note>A <foreign xml:lang="gez">ጋኔን፡</foreign> is believed to cause this affliction, and the prayer is
                     directed against him.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <title type="complete">Magical letters</title> 
                     <textLang mainLang="gez" otherLangs="am"/>
                     <note>Another set of magical letters.</note>
                  </msItem>
                  
                  </msContents>
                     

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ ሥሉስ፡ ቅዱስ፡ አጋእዝተ፡ ጥንት፡ ወፍጻሜ፨</l>
                  <l n="2">ስብሐቲሆሙ፡ ኮነ፡ መኰንነ፡ ኵሉ፡ ሱላሜ፨</l>
                  <l n="3">ኪሩባውያን፡ እንስሳ፡ ጸግዉኒ፡ በዕለተ፡ ትርጓሜ፨</l>
                  <l n="4">እትናገር፡ በበ፡ ጾታሁ፡ ሰላመክሙ፡ ቀዋሜ፨</l>
                  <l n="5">ዘይሠሪ፡ ኀጢአተ፡ ወይዌስክ፡ ዕድሜ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለተፈጥሮትክሙ፡ እምሕርየ፡ እሳት፡ ወነፋስ፨</l>
                  <l n="2">በትእዛዘ፡ ቃሉ፡ ሥሉጥ፡ ለሥሉጠ፡ ትእዛዝ፡ ንጉሥ፨</l>
                  <l n="3">አርባዕቱ፡ እንስሳ፡ መዛግብተ፡ ልብ፡ ሐዲስ፨</l>
                  <l n="4">በበዓልክሙ፡ ልደተ፡ ኢየሱስ፡ ክርስቶስ፨</l>
                  <l n="5">ወርቀ፡ ተጋንዮ፡ ሥሙረ፡ ታበውእ፡ ተርሴስ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ፊደለ፡ ጥበብ፡ ወአእምሮ፨</l>
                  <l n="2">በቀለመ፡ ወርቅ፡ ትጽሕፈ፡ ዲበ፡ ሰሌዳ፡ አብ፡ አንበሮ፨</l>
                  <l n="3">አርባዕቱ፡ እንስሳ፡ ምስለ፡ ሕዝበ፡ ሰላም፡ ወተፋቅሮ፨</l>
                  <l n="4">እገይስ፡ በፍቅርክሙ፡ ዐጸደ፡ በቋኢ፡ አእምሮ፨</l>
                  <l n="5">ወበእደ፡ ስብሐት፡ እዘብጥ፡ ክበሮ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለቀራንብቲክሙ፡ እለ፡ ተኰላ፡ ነበልባለ፨</l>
                  <l n="2">ሐዲሳነ፡ ምኑነ፡ ሠርጐ፡ ዓለም፡ ኵሕለ፨</l>
                  <l n="3">እምነ፡ አርያም፡ ኪሩቤል፡ እለ፡ ትለብሱ፡ ኀይለ፨</l>
                  <l n="4">በሉኒ፡ ለገብርክሙ፡ አስተደሉ፡ ብዕለ፨</l>
                  <l n="5">እስመ፡ በኀቤከ፡ ንገብር፡ ፋሲካ፡ በዓለ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለክሳድክሙ፡ ማእከለ፡ ጽዮን፡ ልቡና፨</l>
                  <l n="2">ዘምዝግናሁ፡ ተብህለ፡ መብረቀ፡ መዊእ፡ ኅሊና፨</l>
                  <l n="3">አርባዕቱ፡ እንስሳ፡ አርእስተ፡ ንጉሥ፡ ምልክና፨</l>
                  <l n="4">ይሩጹ፡ አእጋሪክሙ፡ በሰረገላ፡ ብርሃን፡ ጥዒና፨</l>
                  <l n="5">ወውስተ፡ ራኅበ፡ ነፍስየ፡ ሳሌም፡ ዘበልየ፡ መካና፨</l>
               </lg>
               <lg type="stanza" n="47">
                  <l n="1">ሰላም፡ ለመልክእክሙ፡ ጸዳለ፡ ብርሃን፡ ዘከለሎ፨</l>
                  <l n="2">ዲበ፡ ሰሌዳሁ፡ ብርሃን፡ እስመ፡ እደ፡ ብርሃን፡ ሰአሎ፨</l>
                  <l n="3">ኪሩባውያን፡ እንስሳ፡ እስእለክሙ፡ በተወክሎ፨</l>
                  <l n="4">ዘይሔሊ፡ ሕይወተ፡ ቢጹ፡ እስመ፡ ውስተ፡ ዓለም፡ ሀሎ፨</l>
                  <l n="5">ሐልዩ፡ ለፍሥሓ፡ ሕይወትየ፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለሕይወትክሙ፡ ሐፀ፡ አእምሮ፡ ለሊሁ፨</l>
                  <l n="2">ዘአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አፍላጊሁ፨</l>
                  <l n="3">ኪሩባውያን፡ እንስሳ፡ ለቃለ፡ ሰዳክያል፡ ምሥጢራቲሁ፨</l>
                  <l n="4">ከማክሙ፡ አጋእዝት፡ ናሁ፨</l>
                  <l n="5">አልቦ፡ በኤዶም፡ ዘዐብየ፡ ጸጋሁ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ሰላም፡ ለመንበርክሙ፡ ዘሥዕለ፡ በግዕ፡ ትርሲቱ፨</l>
                  <l n="2">ወለአክሊልክሙ፡ ብሩህ፡ ዘኢያሰጲድ፡ ጸላሎቱ፨</l>
                  <l n="3">ኪሩባውያን፡ ምስሌክሙ፡ እስመ፡ ከማሁ፡ ሥርዓቱ፨</l>
                  <l n="4">ለውእቱ፡ ሥዕለ፡ በግዕ፡ ካህና፡ ስፉሕ፡ መንግሥቱ፨</l>
                  <l n="5">ዕሥራ፡ ወርብዕ፡ ይስግዱ፡ ሎቱ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለህላዌክሙ፡ ዘስብሐተ፡ ልዑል፡ አንቀጹ፨</l>
                  <l n="2">ኪሩባውያን፡ እንስሳ፡ ጊዜ፡ መንበረ፡ ክብር፡ ትሔውጹ፨</l>
                  <l n="3">ኀበ፡ ቀዳማዊ፡ አንጸረ፡ እንዘ፡ ኢይትረአይ፡ ገጹ፨</l>
                  <l n="4">ኵሎሙ፡ ሐራ፡ ሰማይ፡ በሰረገላ፡ ይረውጹ፨</l>
                  <l n="5">ወስብሐቲሆሙኒ፡ ዘመፍርህ፡ ድምፁ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">አምኃ፡ ኀሠሣ፡ ኢይትዔረየክሙ፡ በገሢሠ፡ እሳት፡ እለ፡ ቆም፨</l>
                  <l n="2">ትሩፈ፡ ምግባር፡ ኪሮስ፡ ወጻድቃን፡ እለ፡ ንኑም፨</l>
                  <l n="3">ዕፀዋቲሁ፡ ኪሩቤል፡ ለመንበረ፡ ልዑል፡ ገዳም፨</l>
                  <l n="4">እንዳኢ፡ ዮሐንስ፡ ዘረፈቀ፡ ውስተ፡ ሕፅነ፡ እሳት፡ ግሩም፨</l>
                  <l n="5">ወሰምዖን፡ አረጋዊ፡ ዘጾሮ፡ ለፍሕም፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ለተክልክሙ፡ ኢያማሰነኒ፡ ሦከ፡ ሰቆቃው፡ ጽኑዕ፨</l>
                  <l n="2">በኀዘነ፡ ሥርው፡ ወዐጽቀ፡ ፍሬሁ፡ አንብዕ፨</l>
                  <l n="3">ኦቀብተ፡ ቅምሕ፡ እንስሳ፡ ዘብክሙ፡ መልክአ፡ ሰብእ፨</l>
                  <l n="4">አስተናጽሑኒ፡ በማዕደ፡ ዐባይ፡ ግፍዕ፨</l>
                  <l n="5">ወማየ፡ ጸጋክሙ፡ ላዕሌየ፡ ከዐዉ፡ አርባዕ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ለእግዚአብሔር፡ ስብሐት፡ እምኀቤኪ፡ ማርያም፨</l>
                  <l n="2">ወእምኀበ፡ ኵልነ፡ ዮም፨</l>
                  <l n="3">እስመ፡ ነበርኪ፡ በኅሊና፡ አምላክ፡ እምቅድም፨</l>
                  <l n="4">ወፈጠረ፡ እንበለ፡ ሥጋ፡ ገጸ፡ ሰብእ፡ ወገጸ፡ አንበሳ፡ ምስለ፡ ገጸ፡ ላህም፨</l>
                  <l n="5">ወገጸ፡ ንስርሂ፡ ዘዐውሎ፡ ወፍሕም፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ዜና፡ ስብሐቲክሙ፡ መልአ፡ ወተፈጸመ፡ በዝየ፨</l>
                  <l n="2">ለጽጌ፡ ዘካርያስ፡ ፍቅዱ፡ እንዘ፡ ይከውን፡ ዕሩየ፨</l>
                  <l n="3">ኪሩባውያን፡ እንስሳ፡ ህየንተ፡ ዝንቱ፡ ጻማየ፨</l>
                  <l n="4">እምኀበ፡ ሥላሴ፡ አስተደልዉ፡ ዐስብየ፨</l>
                  <l n="5">ወበእዝነ፡ ልብ፡ ሰምዕዎ፡ ለዝንቱ፡ ቃልየ፨</l>
               </lg>
            </div>

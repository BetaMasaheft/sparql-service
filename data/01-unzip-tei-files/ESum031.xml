                              <item xml:id="q5">
                                 <dim unit="leaf">15</dim>
                                 <locus target="#15"/>
                                 <locus from="47r" to="61v"/> V(15/fols. 47r-61v) </item>
                              <item xml:id="q6">
                                 <dim unit="leaf">10</dim>
                                 <locus target="#10"/>
                                 <locus from="62r" to="71v"/> VI(10/fols. 62r-71v) </item>

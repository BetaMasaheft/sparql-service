               <msContents>
                  <summary>I) Mazmura Dāwit “Psalms of David” (fols. 1r-81v), fragment (Pss. 61-147,
                     parts of Ps. 35 and Ps. 36).</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>- Only P<locus target="#61">61</locus> to 147 and parts of P<locus target="#35">35</locus> and 36 are present in the Ms.</note>
                     <note>- Traditional titles of the Psalms are missing.</note>
                  </msItem>
               </msContents>

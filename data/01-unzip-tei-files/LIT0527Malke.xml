      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0527</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ወጠንኩ፡ ለመልክእከ፡ ሰላሞ፨</l>
                  <l n="2">በብዙኅ፡ ጽሂቅ፡ ወአስተሐምሞ፨</l>
                  <l n="3">እስትንፋሰ፡ ክርስቶስ፡ ሕሩም፡ እምበቀል፡ ወተቀይሞ፨</l>
                  <l n="4">አንጠብጥብ፡ በላዕሌየ፡ ለስብሐቲከ፡ ቀለሞ፨</l>
                  <l n="5">ከመ፡ ሠናይተ፡ እንብብ፡ ወእክሀል፡ ፈጽሞ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ አምሳለ፡ ጸቃውዕ፡ ጣዕሙ፨</l>
                  <l n="2">ወሞገስ፡ ጥቀ፡ ለገብረ፡ መንፈስ፡ ቅዱስ፡ ከመ፡ ስሙ፨</l>
                  <l n="3">እስትንፋሰ፡ ክርስቶስ፡ መምህር፡ አበ፡ ቅዱሳን፡ ኵሎሙ፨</l>
                  <l n="4">ሰማዕታተ፡ ዘመልክእከ፡ በበ፡ መሌሊቱ፡ ወዐቅሙ፨</l>
                  <l n="5">በሰሌዳ፡ ልብየ፡ ረሲ፡ ጠቢባን፡ ይቅልሙ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለዕርገትከ፡ መንግሥተ፡ ሰማያት፡ ትትዋረሱ፨</l>
                  <l n="2">ዘዐይነ፡ መዋቲ፡ ኢርእየ፡ ወዘኢኀለየ፡ መንፈሱ፨</l>
                  <l n="3">አበ፡ አእላፍ፡ አንተ፡ እስትንፋሰ፡ ክርስቶስ፡ ምስለ፡ ወልድከ፡ ኢያሱ፨</l>
                  <l n="4">ወምስለ፡ ኵሎሙ፡ እለ፡ ገድለከ፡ ኀሠሡ፨</l>
                  <l n="5">ወእለ፡ ምስሌከ፡ ህላዌ፡ ቀደሱ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ስብሐት፡ ለእግዚአብሔር፡ ዘአጽሀቀኒ፡ በፈቃዱ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እጽሐፍ፡ ለለ፡ አሐዱ፨</l>
                  <l n="3">እንዘ፡ ጊጉየ፡ ልብ፡ አነ፡ እምእለ፡ በዝኁ፡ ወውኅዱ፨</l>
                  <l n="4">ለአብ፡ ኢተወላዲ፡ እስትንፋሰ፡ ወልዱ፨</l>
                  <l n="5">አኮኑ፡ ለእግዚእከ፡ ምሕረት፡ ልማዱ፨</l>
               </lg>
               <lg type="stanza" n="36">
                  <l n="1">እመ፡ ኢፈደዮሙ፡ ሰርከ፡ ለገባዕተ፡ መፍርህ፡ ዘሐቅል፨</l>
                  <l n="2">እስመ፡ ይከውኖ፡ ኀፍረተ፡ ለበዓለ፡ ገራህት፡ ባዕል፨</l>
                  <l n="3">እስትንፋሰ፡ ክርስቶስ፡ ጸግወኒ፡ ዕሤተ፡ ቡራኬ፡ በቃል፨</l>
                  <l n="4">ተዘኪረከ፡ እግዚኦ፡ በመጽሐፈ፡ ዳግም፡ ክፍል፨</l>
                  <l n="5">ለዐሳብ፡ ዐስቦ፡ ኢታዕቢ፡ ዘይብል፨</l>
               </lg>
            </div>
         </div>
      </body>

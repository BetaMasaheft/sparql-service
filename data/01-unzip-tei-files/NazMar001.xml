                    <msItem xml:id="ms_i1.10">
                        <locus from="87vb" to="89vb">Fols 87vb–89vb</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4925HagMir2">How the river swallowed Lālibalā's honey and then spit it
     out</title>
                      <note><title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4925HagMir2">
                        <locus target="#87vb">Fol. 87vb</locus>
                     </title></note>
                      <incipit xml:lang="gez">
                        ወኮነ፡ በ፩ እመዋዕል፡ እንዘ፡ ያመጽኡ፡ ጸባሕቶ፡ ለገብረ፡ መስቀል፡ ነጋሢ፡ ዘከመ፡ ይደልዎ፡ ለንጉሥ፡ ከመ፡ የሀቡ፡ ወያወፍዩ፡ ግብሮሙ፡ ዘይረክቦሙ፡ ነሥኡ፡ ብዙኃ፡ መቃጽወ፡ እለ፡ ምሉዓን፡ መዓረ፨ ወፀዊሮሙ፡ በጽሑ፡ ኀበ፡ ሐይቀ፡ ፈለግ፡ ዘይወርድ፡ በኃይል፡              </incipit>
                        <explicit xml:lang="gez">
                    በከመ፡ ዐቀቦ፡ ለዮናስ፡ በውስተ፡ ከርሠ፡ አንበሪ፨ ወከማሁ፡ ዓቀቦን፡ ለእማንቱ፡ ግምዔተ፡ መዓር፡ በኃይለ፡ ጸሎቱ፡ ለላሊበላ፡ </explicit>
                  </msItem>
                  <msItem xml:id="ms_i1.11">
                      <locus from="89vb" to="90vb">Fols 89vb–90vb</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT4926HagMir3">How Lālibalā became like a poor person</title>
                    <note><title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4926HagMir3">
                        <locus target="#89vb">Fol. 89vb</locus>
                     </title></note>
                    <incipit xml:lang="gez">
                    ወኮነ፡ ካዕበ፡ በ፩ እመዋዕል፡ ተርእየ፡ መንክር፡ ትሕትና፡ በላዕለ፡ ገብረ፡ መስቀል፡ እንዘ፡ ንጉሥ፡ ውእቱ፡ ዘተመሰለ፡ ነዳየ፨                    </incipit>
                      <explicit xml:lang="gez">
                     ወገብረ፡ መስቀልሰ፡ እንዘ፡ ሀሎ፡ ውስተ፡ መንበረ፡ መንግሥት፡ ኢበልዓ፡ ወኢሰትየ፡ ለፍትወተ፡ ሥጋሁ፡ ከመ፡ ይኩን፡ ፍግዓሁ፡ ፍጹመ፡ በእደ፡ መርዓ፡ ዘኢየኃልፍ፡ በሰማያት፨ <space reason="owner" unit="chars" quantity="7"/> ለዓለመ፡ ዓለም፡ አሜን።                       </explicit>

                  </msItem>
                  <msItem xml:id="ms_i1.12">
                    <locus from="91ra" to="92vb">Fols 91ra–92vb</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4927HagMir4">Lālibalā and a rebel</title>
                     <note><title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4927HagMir4">
                        <locus target="#91ra">Fol. 91ra</locus>
                     </title></note>
                     <incipit xml:lang="gez">
              ወዓዲ፡ ኮነ፡ ፩ እመዋዕል፡ ወሀሎ፡ ውስተ፡ አሐቲ፡ ሀገር፡ እምአህጉራተ፡ መንግሥቱ፡ ፩ ዓላዊ፡ ዘዐለዎ፡ ለገብረ፡ መስቀል፡ ንጉሠ፡ መሢሐውያን፨                      </incipit>
                    <explicit xml:lang="gez">
                    በእንተዝ፡ ሞተ፡ እስመ፡ ጸአለነ፨ ርእዩኬ፡ ኦፍቁራንየ፡ ዘከመዝ፡ መድምመ፡ ዘተገብረ፡ በኃይለ፡ ጸሎቱ፡ ለገብረ፡ መስቀል፡ ወራእየሂ፡ ዘርእየ፡ እንዘ፡ ሀሎ፡ ርኁቀ፨ እስመ፡ በከመ፡ ይሬኢ፡ አምላኮሙ፡ ይሬእዩ፡ መምለክያኒሁ፨ እስመ፡ መንፈስ፡ ቅዱስ፡ ዘላዕሌሆሙ፡ ይከሥት፡ ሎሙ፡ ኵሎ፡ ኅቡዓተ፨               </explicit>
                  </msItem>
                  <msItem xml:id="ms_i1.13">
                     <locus from="92vb" to="93rb">Fols 92vb–93rb</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4928HagMir5">How a prayer to Lālibalā saved a rich woman</title>
                     <note><title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4928HagMir5">
                        <locus target="#92vb">Fol. 92vb</locus>
                     </title></note>
                     <incipit xml:lang="gez">

                  ወአሐተኒ፡ ዕለተ፡ <choice resp="GA"><sic>ዘአርአርአየ፨</sic><corr>ዘአርአየ፨</corr></choice> መንክራቲሁ፡ ገብረ፡ መስቀል፡ እፈቅድ፡ እንግርክሙ፨ ወሀለወት፡ አሐቲ፡ ብእሲት፡ ብዕልት፡ ወእንዘ፡ ትዴረር፡ ወትበልዕ፡ ሥጋ፡ እንስሳ፡ አኀዘት፡ ትብላዕ፡ ሥጋ፡ ሰብእኒ፡ ዘበሐሜት፨                 </incipit>

                     <explicit xml:lang="gez">
                    ወዘንተ፡ እንዘ፡ ትቤ፡ ወፅአ፡ ውእቱ፡ ምታረ፡ ሥጋ፡ ምስለ፡ ደመ፡ ጕርዔሃ፡ ወወድቀ፡ ውስተ፡ ምድር፨  </explicit>
                  </msItem>
                  <msItem xml:id="ms_i1.14">
                     <locus from="93rb" to="94ra">Fols 93rb–94ra</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4929HagMir6">How a prayer to Lālibalā saved a man</title>
                     <note><title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4929HagMir6">
                        <locus target="#93rb">Fol. 93rb</locus>
                     </title></note>
                              <incipit xml:lang="gez">

                ወካዕበ፡ አሐተ፡ ዕለተ፡ አኀዘ፡ ይጽርፍ፡ ሎቱ፡ ፩ ብእሲ፡ ለላሊበላ፡ እንዘ፡ የሐምዮ፨ ወብእሲቱሰ፡ ለውእቱ፡ ብእሲ፡ ትቤሎ፡ <choice resp="GA"><sic>ኢጽርፍ፨</sic><corr>ኢትጽርፍ፨</corr></choice> ላዕለ፡ ገብረ፡ እግዚአብሔር፡ ወመሢሐ፡ እግዚአብሔር፡ <choice resp="GA"><sic>ወእቱ፨</sic><corr>ውእቱ፨</corr></choice> ዓዲ፡                 </incipit>

                     <explicit xml:lang="gez">
                   ያድኅነነኬ፡ እግዚአብሔር፡ እምዘከመዝ፡ ልማድ፨ እስመ፡ ጳውሎስኒ፡ ይሜህረነ፡ ከመ፡ ኢንርግም፡ እስከ፡ ለሰይጣን፡ አኮ፡ ለሰይጣን፡ ኀዚኖ፡ ዘይሜህር፡ ከመዝ፨ አላ፡ ከመ፡ ኢንልክፎ፡ ጥቀ፡ ለመርገም፡ በልሳንነ፡ ከመ፡ ኢንድኃፅ፡ ላዕለ፡ እኁነ፡                    </explicit>
                          </msItem>
                  <msItem xml:id="ms_i1.15">

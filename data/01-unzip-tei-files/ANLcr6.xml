                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="3ra" to="11ra">pps 3ra–11ra</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2341serata">Śǝrʿāta mangǝśt
                                                  (general record)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ <gap reason="ellipsis"/> 
                                ንጸሕፍ፡ ዘንተ፡ ሕገ፡ ወሥርዓተ፡ ቤተ፡ መንግሥት፡ ዘወፅአ፡ እምኢየሩሳሌም፡ ምስለ፡ ዕብነ፡ ሐኪም፡ ወልደ፡ ሰሎሞን።
                                ዘው<supplied reason="omitted">እ</supplied>፡ ምኒልክ፡ ፩ ምዕ<supplied reason="omitted">ራፍ</supplied>። 
                                    ወሶበ፡ ነግሥ፡ በጽሐ፡ ኀበ፡ ብሔረ፡ አክሱም፡ እንዘ፡ ይፄዓን፡ ፈረሰ፡ ወይመልሕ፡ ሰይፈ።
                                    እንዘ፡ ይበትክ፡ አውታረ፡ ፈትል፡ ዘገብረት፡ ብእሲቱ፡ በዓልተ፡ ሕግ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="11ra" to="43va">pps 11ra–43va</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2352ShortC">Short
                                                  Chronicles</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i2.1">
                                <locus from="11r">pps 11r and following</locus>
                                <title>Genealogy of the kings of Israel</title>
                                <incipit xml:lang="gez">
                                    በስመ፡ <gap reason="ellipsis"/> ንጽሕፍ፡ ዜና፡ ልደቶሙ፡ ለነገሥታት፡ እምአዳም፡ እስከ፡ ይእዜ። ወዝ፡ ውእቱ፡ አዳም፡ ወለዶ፡ ለሴት፤ 
                                    ወሴት፡ ወለዶ፡ ለሄኖክ፤ ወሄኖክ፡
                                    ወለዶ፡ ለቃይናን፤
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i2.2">
                                <locus from="11vb">pps 11vb and following</locus>
                                <title ref="https://betamasaheft.eu/LIT3854KingList">King list B</title>
                            </msItem>
                            
                            <msItem xml:id="ms_i2.3">
                                <locus from="13rb">pps 13rb and following</locus>
                                <title>The Zāgʷe</title>
                            </msItem>
                            
                            <msItem xml:id="ms_i2.4">
                                <locus from="13vb">pps 13vb and following</locus>
                                <title>Restitution of the Solomonic dynasty up until Mǝnilǝk II</title>
                                <explicit xml:lang="gez">
                                    <locus from="43rb" to="43va">pps 43rb–43va</locus>
                                    <gap reason="ellipsis"/> ምዕራ<supplied reason="omitted">ፍ</supplied>፡ ወእምዝ፡ በ፲፻ወ፰፻፹ወ፪ ዓመተ፡ ምሕረት፡ በዘመነ፡
                                    ማርቆስ፡ ወንጌላዊ፡ ሠረቀ፡ መስከረም፡ ሠሉስ፡ እንዘ፡ ዓበ<supplied reason="omitted">ቅቴ</supplied>፡ 
                                    ፱ መጥ<supplied reason="omitted">ቅዕ</supplied>፡ ፳ወ፩ ወአመ፡ ፳ሁ፡ ለጥቅምት፡ አብጽሐ፡ ሥርዓተ፡ መንግሥት፡ 
                                    ዳግማዊ፡ <persName ref="https://betamasaheft.eu/PRS7006Menilek">ምኒልክ፡</persName> ንጉሠ፡ ነገሥት፡ ዘኢትዮጵያ፡ ከመ፡ <pb n="43v"/><cb n="b"/><surplus>ከመ፡</surplus> 
                                    ሥ<supplied reason="omitted">ር</supplied>ዓተ፡ አበዊሁ፡ ወሥ<supplied reason="omitted">ርዓተ</supplied>፡ መንግሥቱ፤ 
                                    ሞዓ፡ አንበሳ፡ እምነገደ፡ ይሁዳ። ዳግማዊ፡ <persName ref="https://betamasaheft.eu/PRS7006Menilek">ምኒልክ፡</persName> ንጉሠ፡ ነገሥት፡ ዘኢትዮጵያ። ። ። ።
                                </explicit>
                            </msItem>
                        </msItem>
                    </msContents>
                    

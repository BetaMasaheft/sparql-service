               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="33r">1v-33r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1274IHA">سرد الاوراد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم \ الحمد لله الذى وفق من شاء لمراقبة اوقاته [...] وبعد فهذه سرد الاوراد التى فى طريقة مشايخنا رضى الله عنهم بعد المكتوبات الخمس سألنيها غير مرة من لا يسعنى الا موافقته ولا يسوغ لى مخالفته من اكابر الاخوان اسبل الله علي وعليه ذيل الامان</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33r">-33r</locus>اذ قيل كم من زيف صحيحا لاجل كون فهم قبيحا \ الحمد لله الذى هدانا لهذا ومالنا لنهتدي لولا ان هدانا الله وصلى الله على سيدنا محمد الذى اوضح احكام الشريعة للعلمين وشيد اركان الطريقة للسائرين ورمز الى علوم الحقيقة للعارفين واله وصحبه اجمعين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="33v" to="38v">33v-38v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1115IHA">طيارة للعالم الربانى والقطب الفردانى</title>
                     <incipit xml:lang="ar">
                        <locus target="#33v">-33v</locus>بسم الله الرحمن الرحيم \ الحمد لله الرحمن بالايجاد الرحيم بالامداد الموفق من شاء للاقبال والاستعداد [...] وبعد فاقول قد طلب منى بعض من اظن فيه الخير والصلاح وارجو له القبول والفوز والفلاح من الاولاد ان اكتب له شيئا مما لا بد له فى سلوك الطريق</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#38v">-38v</locus>فيدخله الى حضرته بسبب او بغير سبب فعليك به فى كل وقت ان كنت تروم مرام الرجال والترقى عن عالم الوهم والخيال هذا والسلام خير الكلام ما قل ودل لا طال وامل ارباب الاحوال اذ الشان فى الزبدة والصفوة لا فى كثر المقال  </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="39v" to="46v">39v-46v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1277IHA">رسالة في زلزلة الارض</title>
                     <incipit xml:lang="ar">
                        <locus target="#39v-40r">-39v-40r</locus>بسم الله الرحمن الرحيم \ الحمد لله الذى وجب له الوجود والقدم واوجد هذا الموجود من العدم [...] وبعد فاعملوا ايها الاخوان اننا فى هذا الزمان وهذا المكان بين همج الهمج والنسناس وقد ذهب الناس الا طائفة قليلة تلوح عليهم لوائح العلم والايمان مغمورة فى بحار الجهل والضلال مع ذلك قد حدث فى وقتنا هذا حادث لم يكن معهودا قبل فيما وهو تكرار الزلزلة علينا وهذا من اشد المخوفات واعظم الدلالة على غضب البارئ على اهل معصية من اهل الارض</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#46r">-46r</locus>وقد نبه عليها القرطبي وافردها بالتاليف الشيخ قطب الدين القسطلاني فى كتاب جمل الايجاز فى الاعجاز بنار الحجاز فاتى فيه بحقائق من رقائق الحقائق بالعجب العجاب انتهى ملخصا من المواهب اللدينية للعلامة القسطلانى رحمه الله تعلى تمت الرسالة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="47r" to="54r">47r-54r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1156IHA">لمعة النورانية فى ذكر رب البرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#47r">-47r</locus>بسم الله الرحمن الرحيم \ الحمد لله الذى عظم فضل ذكره على سائر الطاعات وجعل [افضل] احوال العبد حال ذكر رب العالمين [...] وبعد فاعلم يا اخى ان افضل الطاعات بعد اداء الفرائض واجتناب المحرمات ذكر الله تعلى الملك على التوالى والدوام سواء كان باللسان او بالقلب [...] فاذا علمت ذلك فها انا اورد لك الادلة الواردة فى فضل الذكر والذاكرين مع ذكر فوائده وعوائده وشئ من شروطه

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#54r">-54r</locus>وقد ذكرنا فى كتابنا المذكور ما جاء فى الترهيب من ترك الصلاة عليه صلى الله عليه وسلم عند ذكر اسمه الشريف وما له تعلق بها مما يطلب من المصلى عليه فليقف عليه من شاء تمت</explicit>
                     <note>Words divided into two lines.</note>
                     <note/>
                  </msItem>

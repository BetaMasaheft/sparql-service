      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ስምዖን፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Sǝmʿon</persName>
               <persName xml:lang="en" xml:id="n2" type="birth">Simam (in Portuguese sources)</persName>
               <persName>
                  <roleName type="title">ʾabuna</roleName>
               </persName>
               <occupation type="ecclesiastic">metropolitan</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
             
               
               <floruit notBefore="1607" notAfter="1617">He was a  metropolitan of the Ethiopian Orthodox Church who succeeded  ʾAbuna
                  <persName ref="https://betamasaheft.eu/PRS7829Petros">Ṗeṭros III</persName>in <date>1607</date> during the reign of  
                  King <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>. He anointed <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>  
                  on <date> 28 March 1609</date> as King of Ethiopia in <placeName ref="https://betamasaheft.eu/LOC1311AksumS">ʾAksum Ṣǝyon</placeName>. 
           
               </floruit>
               <death>He died on <date>11 May 1617</date> at <placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</placeName>
               </death>
            </person>
            
         </listPerson>
         

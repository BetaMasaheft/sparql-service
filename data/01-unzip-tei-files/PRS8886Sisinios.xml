         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሱስንዮስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Susǝnyos</t:persName>
               <t:persName xml:lang="en" corresp="#n1" type="main">Sisinnius</t:persName>
               <t:persName xml:lang="it" corresp="#n1">Sisinio</t:persName>
               <t:persName xml:lang="ger" xml:id="n2" type="alt">Susinius</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">Sisinios</t:persName>
              
               
               
               
               <t:floruit notBefore="0284" notAfter="0316">St Sisinnius was one of the so-called equestrian saints, 
                  died as a martyr in <t:placeName ref="https://betamasaheft.eu/LOC1481Antioc">Antioch</t:placeName>
                  during the persecution of <t:persName ref="https://betamasaheft.eu/PRS3581Diocleti">Diocletian</t:persName> from <t:date>284 </t:date> to <t:date>316</t:date>. 
                  His martyrdom is commemorated on 26 Barmūdah in the Coptic calendar = <t:date type="diesNatalis" ref="ethiocal:Miyazya26">26 Miyāzyā</t:date>.
                  In the Ethiopic narrative (following the Coptic) the 4th-century martyr is conflanted with the legendary (first to second century CE) figure of the Byzantine folklore of the same name, who combatted a female demon (<t:persName ref="https://betamasaheft.eu/PRS10134Werzely">Wǝrzǝlyā</t:persName>)
                  St Sisinnius is frequently depicted on the walls of churches and in manuscripts alongside other holy riders. </t:floruit>
               <t:death notBefore="0284" notAfter="0316"/>
               
               
            </t:person>
            
            
         </t:listPerson>
         

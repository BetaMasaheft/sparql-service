         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አፈወርቅ፡ ገብረ፡ ኢየሱስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAfawarq Gabra ʾIyasus</t:persName>
               <t:persName xml:lang="it" xml:id="n2" type="alt">Afevork Ghevre-Jesus</t:persName>
               
               
               <t:persName>
                  <t:roleName type="title">naggādrās</t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               
               <t:occupation type="literary">writer</t:occupation>
               <t:birth when="1868">He was born at <t:placeName ref="https://betamasaheft.eu/LOC6411Zage">Zage</t:placeName> in <t:date>1868</t:date>. </t:birth>
               
               
               <t:floruit notBefore="1889" notAfter="1947">He was a painter, novelist, grammarian, poet, 
                  educator and public servant, is considered the pioneer of Amharic prose fiction.
                  He received traditional education from his grandfather <t:persName ref="https://betamasaheft.eu/PRS3515Denqe">Dǝnqe</t:persName> at
                  <t:placeName ref="https://betamasaheft.eu/LOC6307WerraK">Wǝrrā Kidāne Mǝḥrat</t:placeName>
                  Monastery in <t:placeName ref="https://betamasaheft.eu/LOC6411Zage">Zage</t:placeName>. 
                  He also studied in <t:placeName ref="https://www.wikidata.org/entity/Q38">Italy</t:placeName> from <t:date>1887-1889</t:date>. When 
                 
                  <t:persName ref="https://betamasaheft.eu/PRS6554Makwanne">  
                     <t:roleName type="title">rās </t:roleName>
                  </t:persName> was in his diplomatic mission to 
                  <t:placeName ref="https://www.wikidata.org/entity/Q38">Italy</t:placeName> ʾAfawarq Gabra ʾIyasus served him as an interpreter,
                  and returned with him to <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>.
                  He served the Imperial government in various positions: in <t:date>1922</t:date>
                  Custom Director to <t:placeName ref="https://betamasaheft.eu/LOC2658DerreD">Dǝrre Dāwā</t:placeName> with 
                  <t:persName ref="https://betamasaheft.eu/PRS1451Afawarq">
                     <t:roleName type="title">naggādrās </t:roleName>
                  </t:persName>, in <t:date>1924</t:date> President of the Special Arbitration Court,  in <t:date>1932</t:date> 
                  <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> representative in <t:placeName ref="https://www.wikidata.org/entity/Q38">Italy</t:placeName>. 
                  When Ethiopia was liberated in <t:date>1941</t:date>, 
                  he was accused of treason for siding with the Italians during the war 
                  and was arrested later sentenced to death. But 
                  <t:persName ref="https://betamasaheft.eu/PRS5226haylase">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                  </t:persName>
                  commuted the sentence to life imprisonment.</t:floruit>
               
               <t:death when="1947"/>
               
            </t:person>
            
            

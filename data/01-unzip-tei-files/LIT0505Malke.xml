      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0505</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ሥላሴ፡ ቅድስት፨</l>
                  <l n="2">እንዘ፡ መሠረታ፡ እገብር፡ በዘተውህበኒ፡ ሀብት፨</l>
                  <l n="3">ፍሬ፡ ከርሠ፡ ወልዱ፡ ዮስጢኖስ፡ ለዮሐንስ፡ ከማ፡ ሰማዕት፨</l>
                  <l n="4">ከመ፡ ትኩን፡ እምነ፡ ጻማ፡ ዕረፍተ፡ ሥሩሓን፡ አግብርት፨</l>
                  <l n="5">ናሁ፡ ወጠንክዋ፡ ለክብርከ፡ ቤት፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ በኅሊና፡ አምላክ፡ እለ፡ ተሐቱ፨</l>
                  <l n="2">ወለርእስከ፡ ሰላም፡ ዘጾረ፡ መስቀለ፡ ሞቱ፨</l>
                  <l n="3">ዮስጢኖስ፡ አብርሃም፡ መፍቀሬ፡ አጋእዝት፡ ሠለስቱ፨</l>
                  <l n="4">ለውዳሴከ፡ ዘወጠንክዋ፡ እስመ፡ ፈጽሞታ፡ እፈቱ፨</l>
                  <l n="5">መንፈሰ፡ ረድኤትከ፡ ፈኑ፡ ከመ፡ እንብብ፡ ቦቱ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ ወለመቃብሪከ፡ ደብተራ፨</l>
                  <l n="2">አዕጽምተ፡ መሬት፡ ሥጋከ፡ አመ፡ ውሳጤሃ፡ ተገምራ፨</l>
                  <l n="3">ለሕምምተ፡ ማሕፀን፡ ዮስጢኖስ፡ ዐይነ፡ ምሕረትከ፡ አመ፡ ነጸራ፨</l>
                  <l n="4">ሶበ፡ ተቀብአት፡ እምጸበልከ፡ ከመ፡ ተሐዩ፡ አእሚራ፨</l>
                  <l n="5">በትፍሥሕት፡ ምስለ፡ ወልዳ፡ አተወት፡ ብሔራ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለምኔትከ፡ ወለማኅበርከ፡ አእላፍ፨</l>
                  <l n="2">ከመ፡ ኢይርስዑኒ፡ ሊተ፡ በጸጋሆሙ፡ ትሩፍ፨</l>
                  <l n="3">አርዘ፡ ንጽሕና፡ ዮስጢኖስ፡ ምጽላለ፡ ኃጥኣን፡ አዕዋፍ፨</l>
                  <l n="4">እስመ፡ ሰክረ፡ ልበ፡ ዚአየ፡ በፍቅረ፡ ኀጢአት፡ ፃዕፍ፨</l>
                  <l n="5">ጊዜ፡ አንብቦታ፡ ወጠንኩ፡ ለዛቲ፡ መጽሐፍ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ለመንግሥተ፡ ሰማይ፡ መርዓት፡ ዮስጢኖስ፡ መርዓዊሃ፨</l>
                  <l n="2">መንሥኤ፡ ሙታን፡ ቀርን፡ አመ፡ ለጸውዖ፡ ተነፍሐ፨</l>
                  <l n="3">ማኅደረ፡ ነፍስየ፡ ግበር፡ መንገለ፡ ሀሎ፡ ፍሥሓ፨</l>
                  <l n="4">በጽባሕ፡ ወበምሴት፡ ለአቅርቦ፡ ዘንቱ፡ አምኃ፨</l>
                  <l n="5">እስመ፡ ብእሴ፡ እበድ፡ ገብርከ፡ ጻመውኩ፡ ብዙኀ፨</l>
               </lg>
            </div>
         </div>
      </body>

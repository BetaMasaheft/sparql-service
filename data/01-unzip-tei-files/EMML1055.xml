                     <layoutDesc>
                        <layout columns="1" writtenLines="18"><note>1 col. (fff. 2-204) and 2 cols. (ff. 205-225), 18 lines (ff. 2-177, 202-225) and 19 lines (ff. 178-201)</note></layout>
                        <layout columns="2" writtenLines="18 19"/>                        
                     </layoutDesc>
                  </objectDesc>
                  <additions><list><item xml:id="a1">Texts in secondary hands: Pentrial on the Mazmura dengel, fol. 1v; Weapons transaction, fol. 1v; Asmāt prayer on prayers for the feast, fol. 177v; Image of Jesus, incomplete at the end, Chaîne Repertoire number 123, fol. 225v
                     
                  </item><item xml:id="e1">Seal of Qeddest Śellāsē Cathedral, fol. 2r, 225v; Seal of Makāna Śellāsē Church, fol. 202v</item></list></additions>
                  <bindingDesc><binding><decoNote xml:id="b1">Stamped leather over wood boards</decoNote></binding></bindingDesc>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>First half of the 20th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; directives to the
                           ministers and their abbreviations; titles of the books to be read;
                           elements of the punctuation signs; elements of Ethiopic numbers. 
 On
                           the incipit page of Text I (fol. 3r), two first lines of the two columns
                           are rubricated.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#3r">3r</locus> (incipit page of Text I): Coloured (vivid
                        red, black) ornamental band; interlaces motifs.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Titles of two books to be read written in red,
                              between two lines of black and red dots, in the upper margin of fols.:
                              ዘጴጥሮስ፡ ሐዋርያ: <locus target="#23v">fol. 23v</locus>. ግብረ፡ ሐዋርያ፡ ይል:
                                 <locus target="#24v">fol. 24v</locus>.</desc>
                        </item>
                     </list>
                  </additions>

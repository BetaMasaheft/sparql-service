         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ዘለዓለም፡ ወልድ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ስቡሐ፡ ኵለንታ፡ በፍቅድ፨</l>
                  <l n="3">ኢየሱስ፡ ክርስቶስ፡ ሥርግወ፡ ሐመልማል፡ ነድ፨</l>
                  <l n="4">ሥመር፡ ሊተ፡ እግዚኦ፡ በሥምረትከ፡ ዋሕድ፨</l>
                  <l n="5">ስብሐተ፡ ዕርገትከ፡ ደብረ፡ እትናገር፡ በዐውድ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለርእስከ፡ ለአካለ፡ ዓለም፡ ርእሱ፨</l>
                  <l n="2">ወለገጽከ፡ በታቦር፡ ዘተሰብሐ፡ ሞገሱ፨</l>
                  <l n="3">ለንጉሠ፡ ኬብሮን፡ ክርስቶስ፡ ቅድመ፡ ትትወለድ፡ እምከርሡ፨</l>
                  <l n="4">አንበርከ፡ እምድኅረ፡ ሙሴ፡ ለወልደ፡ ነዌ፡ ኢያሱ፨</l>
                  <l n="5">ተሰምዮተ፡ መድኅን፡ ስምከ፡ ዘኢዮር፡ መቅደሱ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ ርእሰ፡ አባላት፡ ሙታን፨</l>
                  <l n="2">ወለዕርገትከ፡ ክርስቶስ፡ በደመና፡ ስፉሕ፡ ብርሃን፨</l>
                  <l n="3">ለንብረትከ፡ ዓዲ፡ በዘአቡከ፡ የማን፨</l>
                  <l n="4">ደመና፡ ዕርገት፡ ባሕቱ፡ ወደብረ፡ ታቦር፡ መካን፨</l>
                  <l n="5">የኀብሩ፡ ሥነ፡ ይቤሉ፡ ኄራን፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለምጽአትከ፡ በግርማ፡ መለኮት፡ መፍርህ፨</l>
                  <l n="2">ለግብረ፡ ኵነኔ፡ ወፍትሕ፨</l>
                  <l n="3">ውስተ፡ አየርከ፡ ክርስቶስ፡ ንጉሠ፡ ታቦር፡ መካሕ፨</l>
                  <l n="4">ምሥጠነ፡ ግብተ፡ አሜሃ፡ በደመናከ፡ ብሩህ፨</l>
                  <l n="5">ከመ፡ ንትቀበልከ፡ በስብሐት፡ ብዙኅ፨</l>
               </lg>
            </div>
         </div>
      </body>

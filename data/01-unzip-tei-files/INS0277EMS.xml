                     <t:measure quantity="2"/>Tābot of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6951Mazgaba">Mazgaba Śǝllāse</t:persName>.</t:ab>
               </t:note>
            </t:place>

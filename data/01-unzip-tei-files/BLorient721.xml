                        <additions>
                            <list>
                        <item xml:id="e1">
                               <locus target="#6r #181v #200r"/>
                                <desc>The name of the owner of the manuscript is mentioned in the legends to images as <persName role="owner" ref="https://betamasaheft.eu/PRS12569Abraneyos">ʾAbrāniyos</persName> 
                           </desc>
                               
                                   </item>
                                <item xml:id="e2">
                                  
                                    <desc>The manuscript was written for  <persName role="owner" ref="https://betamasaheft.eu/PRS12498WaltaTaklaHayamnot">Walatta Takla Hāymānot</persName> 
                                    </desc>
                                 
                                </item>
                                
                                <item xml:id="e3">
                                    <locus target="#2 #4"/>
                                    <desc type="CommemorativeNote">contain a notice of the death by violence of 
                                        <persName ref="https://betamasaheft.eu/PRS12570Niqolawos">
                                 <roleName type="title">ʾabbā</roleName>Niqolāwos</persName>, 
                                        <persName ref="https://betamasaheft.eu/PRS12571Asfakresto">
                                 <roleName type="title">ʾabbā</roleName>ʾAṣfa Krǝstos</persName>,
                                        <persName ref="https://betamasaheft.eu/PRS12572Awsegnyos">
                                 <roleName type="title">ʾabbā</roleName>ʾAwsǝgnyos</persName>
                                        and others on the 3rd of Miyāziyā with account of events connected therewith in the reigns of  <persName ref="https://betamasaheft.eu/PRS10375Yohanne">Yoḥannǝs I</persName>,
                                        <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ʾIyāsu I</persName> and <persName ref="https://betamasaheft.eu/PRS2377Bakaffa">Bakaffā</persName> in whose reign this page seems to have been written.</desc>
                                    
                                </item>
                                <item xml:id="e4">
                                    <locus target="#211r"/>
                                    <desc>Documents of the reigns of <persName ref="https://betamasaheft.eu/PRS4661Gigar">Gigār</persName> and <persName ref="https://betamasaheft.eu/PRS8344sahlaDe">Śāhlu</persName>
                           </desc>
                                </item>
                                <item xml:id="a1">
                                    <locus target="#6r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ገድለ፡ ተክለ፡ ሃይማኖት፡  ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                                    </q>
                                </item>
                                
                                    
                            
                            </list>
                            

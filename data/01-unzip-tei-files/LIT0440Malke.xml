         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በኀይል፨</l>
                  <l n="2">እለ፡ ኅቡራን፡ እሙንቱ፡ ሊሉያነ፡ ግጽው፡ አካል፨</l>
                  <l n="3">ተፈጥሮተ፡ አዳም፡ እጽሕፍ፡ ወሥነ፡ መልክዑ፡ ሥዑል፨</l>
                  <l n="4">ባርኪ፡ ሊተ፡ ባሕቱ፡ በበረከተ፡ እድ፡ ወቃል፨</l>
                  <l n="5">ንግሥተ፡ ሰማያት፡ ወምድር፡ ማርያም፡ ድንግል፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለተፈጥሮትከ፡ እምባሕርየ፡ ግብራት፡ አርባዕቱ፨</l>
                  <l n="2">ዘኢይትረአይ፡ አሐዱ፡ ወዘይትረአዩ፡ ሠለስቱ፨</l>
                  <l n="3">በግእዘ፡ እንስሳ፡ አዳም፡ ከመ፡ ኢትሙት፡ በከንቱ፨</l>
                  <l n="4">ላዕሌከ፡ ነፍሐ፡ ፈጣሪ፡ ዘእምቅድመ፡ ዓለም፡ መንግሥቱ፨</l>
                  <l n="5">መንፈሰ፡ ሕይወት፡ ዘተሐዩ፡ ቦቱ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለተፈጥሮትከ፡ ክቡረ፡ ጽዋዔ፡ እምኵሉ፨</l>
                  <l n="2">ለእግዚአብሔር፡ አምላክ፡ እስመ፡ ውእቱ፡ አምሳሉ፨</l>
                  <l n="3">መልአከ፡ ፍጥረታት፡ አዳም፡ እለ፡ በታሕቱ፡ ወላዕሉ፨</l>
                  <l n="4">በጽሑፍ፡ ተፈጥሮትከ፡ ውዳሴ፡ መልክዕከ፡ አትሉ፨</l>
                  <l n="5">ተራድኦትየ፡ ሥመር፡ ወምስሌየ፡ ሀሉ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለተፈጥሮትከ፡ በአርአያ፡ አምላክ፡ ዘኮነ፨</l>
                  <l n="2">እምድኅረ፡ ይቤ፡ ለሊሁ፡ እግዚአብሔር፡ አነ፨</l>
                  <l n="3">ወልደ፡ ጠባዕያት፡ አዳም፡ እንተ፡ ወለድከ፡ ኪያነ፨</l>
                  <l n="4">እመ፡ ኢተፈጠርከሰ፡ በአርአያ፡ አምላክ፡ እሙነ፨</l>
                  <l n="5">አምሳለ፡ እንስሳ፡ ግእዝከ፡ እምኀጥአ፡ ግእዛነ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርትከ፡ ዘከብረ፨</l>
                  <l n="2">እምፀምረ፡ መስፍን፡ ጌዴዎን፡ ዘአቅርንተ፡ አፅራር፡ ሰበረ፨</l>
                  <l n="3">ንጉሠ፡ ፍጥረታት፡ አዳም፡ ዘምልክናከ፡ ተነግረ፨</l>
                  <l n="4">ውዳሴከ፡ እንብብ፡ እግዚኦ፡ ኀበ፡ ልበ፡ አምላክ፡ ሠምረ፨</l>
                  <l n="5">ምስለ፡ ዐፅመ፡ ገቦከ፡ ሔዋን፡ ሐውጸኒ፡ ወትረ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ በከመ፡ ተብህለ፡ ወተነግረ፨</l>
                  <l n="2">በዐተ፡ መዛግብት፡ ቅድመ፡ ወኢየሩሳሌም፡ ድኅረ፨</l>
                  <l n="3">እምግብርናተ፡ ሞት፡ አዳም፡ አመ፡ ቤዝዎትከ፡ ሠምረ፨</l>
                  <l n="4">በህላዌ፡ ግቡር፡ ሥጋከ፡ ኮነ፡ ገብረ፨</l>
                  <l n="5">እግዚአብሔር፡ ንጉሥ፡ ዘይነግሥ፡ ወትረ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">እንዘ፡ ዲበ፡ መስቀል፡ በሥጋ፡ ርደተ፡ መለኮት፡ በነፍስ፨</l>
                  <l n="2">ውስተ፡ ነደ፡ እሳት፡ መፍርህ፡ በዕለተ፡ መስቀል፡ ቅዱስ፨</l>
                  <l n="3">መንገለ፡ ተደለወ፡ ለከ፡ ሀገረ፡ ብርሃን፡ ሐዲስ፨</l>
                  <l n="4">ኪያከ፡ ያወፅእ፡ አኮኑ፡ አዳም፡ ንጉሥ፨</l>
                  <l n="5">ወሰራዊትከ፡ እምሲኦል፡ መብእስ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">እምኀበ፡ ዘሎቱ፡ አምላክ፡ ተድላ፡ ሰማያዊ፡ መንክር፨</l>
                  <l n="2">ወኵለንታ፡ ዓለም፡ ካዕበ፡ መከየደ፡ እግር፨</l>
                  <l n="3">ዕሥየኒ፡ አዳም፡ ዕሤተ፡ ስብሐት፡ ወክብር፨</l>
                  <l n="4">ግብረ፡ ውዳሴከ፡ እስመ፡ ፈጸምኩ፡ በግብር፨</l>
                  <l n="5">ምስለ፡ እለ፡ ኪያከ፡ አበ፡ ጸውዑ፡ በምድር፨</l>
               </lg>
            </div>
         </div>
      </body>

                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <seg type="script">Mid-18th-/first half of the 19th-century script.</seg>
                                <seg type="ink">Black, red.</seg>
                                <desc>Careful, but rushed, somewhat irregular; by a good scribe. Written in a pen with thin nib, some letters have long 'hairlines'.
                                    The handwriting shows some similarity to the one attested 
                                    in <ref type="mss" corresp="https://betamasaheft.eu/ESakm007">Gulo Maḵadā, ʾAmbasat Kidāna Mǝḥrat, AKM-007</ref>, to the hand of <persName ref="https://betamasaheft.eu/PRS10513Zadenge">Zadǝngǝl</persName> or <persName ref="https://betamasaheft.eu/PRS13750RamhaS">Ramḥa Sǝllāse</persName>
                                    of <ref type="mss" corresp="https://betamasaheft.eu/ESum028">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy, ʿUrā Qirqos, UM-028</ref>. The signs ድ and ጥ follows the ancient pattern. 
                                    </desc>
                            </handNote>
                        </handDesc>
                        <decoDesc>
                            <decoNote xml:id="d1" type="miniature">
                                <desc>Amuletic picture in the upper part of the scroll.</desc>
                            </decoNote>
                            <decoNote xml:id="d2" type="miniature">
                                <desc>Amuletic picture.</desc>
                            </decoNote>
                            <decoNote xml:id="d3" type="miniature">
                                <desc>Amuletic picture.</desc>
                            </decoNote>
                            <decoNote xml:id="d4" type="miniature">
                                <desc>Amuletic picture at the end of the scroll.</desc>
                            </decoNote>
                        </decoDesc>
                        <additions>
                        </additions>
                        <bindingDesc>
                            <decoNote xml:id="b1"/>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin>
                            <origDate notBefore="1750" notAfter="1849" evidence="lettering"/>
                            The owner of the scroll was <persName ref="https://betamasaheft.eu/PRS14028HabtaMikael">Habta Mikāʾel</persName>, whose name is written in red,
                            over erasures, but probably in the main hand.
                        </origin>
                        <acquisition>The scroll was acquired by <persName ref="https://betamasaheft.eu/PRS14027ChristianBarth">Christian Gottlob Barth</persName> from an unknown seller 
                            (possibly a missioner), and later 
                            entered the collection of the Basler Mission. In <date when="1980">1980</date> the scroll was donated to 
                            <placeName ref="https://betamasaheft.eu/INS1001MusKulBasel">Museum of Cultures at Basle</placeName>.
                        </acquisition>
                    </history>

                </msDesc>


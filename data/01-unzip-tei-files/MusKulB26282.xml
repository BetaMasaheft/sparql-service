                    </msIdentifier>
                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>                            
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ ለአብ፡ ወስሙ፡ ለወልድ፡ በስሙ፡ ለመንፈስ፡ ቅዱስ፡ ታአ</hi>ስ፡ አስያስ፡ ማዕያስ፡ አቅዴፌር፡ በስመ፡ ሐራጉን፡ ሐራፋንከር፡ ዘበጠጁን፡ ዘሐጁን፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አልፋ፡ አልፋ፡ አልፋ፡ ፃ</hi>ዕ፡ ፃዕ፡ ወወጺአከ፡ ኢትግባ<gap reason="lost" unit="chars" quantity="1"/>፡ ይቤለከ፡ 
                            እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወዝክረ፡ ስምከ፡ ይደምሰስ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5920JohnBeg">Beginning of the Gospel of John</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">ወንጌል፡ ዘዮሐንስ፡ ቀዳሚሁ፡</hi> ቃል፡ ውእቱ፡ ቃል፡ ኀበ፡ እግዚአብሔር፡ ውእቱ፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመ</hi>ንፈስ፡ ቅዱስ፡ ፩አምላክ፤ አላ<hi rend="rubric">ሁማ፡ ይትአወዚ፡ እልመላኪ፡</hi> ተዋራ፡ ወአሬ፡ ሐሽማርጅን፡ ተላጅኅዮ</incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez"><hi rend="rubric">ምድምያስ፡ ምድምያስ፡ ምድ</hi>ምያስ፡ ምድምያስ፡ </incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><hi rend="rubric">አዴር፡ ርአሆር፡ አሆር፡ </hi></incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i7">
                            <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">Protective prayer with ʾasmāt</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ በእንተ፡ <sic resp="DN">ለጌዎን፡ </sic> ወደስክ፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i8">
                            <title type="complete">Prayer 'I denounce you, Satan...'</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ አክህደከ፡ ሰይጣን፡ 
                                የዓየር፡ አጋንንት፡ ንጉሠ፡ ኖባ፡ የባሕር፡ አጋንንት፡ ንጉሠ፡ አጋን፡ የወጀድ፡ አጋንንት፡ ንጉሠ፡ አፍጋሞ፡ የዛፍ፡ አጋንንት፡ ንጉሠ፡ አዜብ፡ የባደል፡ አጋንንት፡</incipit>
                        </msItem>
                    </msContents>
                    <physDesc>
                        <objectDesc form="Scroll">
                            <supportDesc>
                                <support>
                                    <material key="parchment"/>
                                </support>

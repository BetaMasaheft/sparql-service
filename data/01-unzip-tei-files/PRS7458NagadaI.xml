         <t:listPerson>
            <t:person sex="1">
             
                  
                  
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ነገደ፡ ኢየሱስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Nagada ʾIyasus</t:persName>
                  
                  
                  
               <t:persName>
                  <t:roleName type="title">ʿaqqabe saʿat</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
                  <t:occupation type="ecclesiastic">abbot</t:occupation>
             
                  
                  
                  
                  
                  
               <t:floruit notBefore="1508" notAfter="1534">He was  
                  
                     <t:persName ref="https://betamasaheft.eu/PRS7458NagadaI">
                     <t:roleName type="title">ʿaqqābe saʿāt</t:roleName>
                  </t:persName> during the reign of <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</t:persName>.  
                  He was a contemporary of the Portuguese mission and met <t:persName ref="https://betamasaheft.eu/PRS1778Alvares">Francisco Alvares</t:persName> 
                  in the court of  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</t:persName>. 
                  He held also a high position at the royal court and <t:persName ref="https://betamasaheft.eu/PRS1778Alvares">Francisco Alvares</t:persName> 
                  reports that one of Nagada ʾIyasus's sons married the Emperor 's sister 
                  <t:persName ref="https://betamasaheft.eu/PRS11767RomanaWarq">Romāna Warq</t:persName> 
                  </t:floruit>
               <t:death when="1534">He was killed by <t:persName ref="https://betamasaheft.eu/PRS1500Ahmad">ʾAḥmad</t:persName>'s soldiers  
                  in <t:date>1534</t:date>.</t:death>
                  
                  
               </t:person>
               
         </t:listPerson>
         
         
         

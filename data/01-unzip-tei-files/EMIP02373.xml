                        <msItem xml:id="ms_i1.3.1">
                          <locus from="122r" facs="125"/>
                            <title>Hymn To Christ with Song of Songs</title>
                            <incipit xml:lang="gez">
                              <hi rend="ruric">ቤተ፡ ክረስቲያን፡ ወርዓት፡ ትመስል፡፡ጎሐ።</hi>
                              እንዘ፡ ክርስቲያን፡ ትሔውጽ፡ ኪያከ፡ ወልደ፡ እኁሃ።
                              እስመ፡ ተሠርተወት፡ ይእቲ፡ ስንዲነ፡ ሃይማኖት፡ ንጹ<supplied reason="lost">ሐ።</supplied>
                              <hi rend="rubric">ክርስቶስ፡</hi> አምላኪየ፡ አሠርግወኒ፡ ከማሃ።
                              ልብሰ፡ ቅድስና፡ ወጸጋ፡ ብሩሃ።
                            </incipit>
                        </msItem>

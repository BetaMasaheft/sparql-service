                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: mediocre., hand b: fine</seg>
                        <seg type="ink">Black, red (vivid red, luminous vivid red).</seg>
                        <date>19th century; <locus from="2r" to="3v">2r-3v</locus> 18th
                           century.</date>
                        <seg type="rubrication">Nomina sacra; the name of the donor of Text I; the
                           1st and 3rd line oo the incipit page of Text I; two lines oo the incipit
                           page of Text II, alternating with black lines; initial words of each
                           strophe of Text I; two initial lines of texts other than I; two initial
                           lines of sections of Text II; elements of punctuation signs; elements of
                           Ethiopic numerals.
 
 In Text I rubrication is done with vivid
                           red; in Text II rubrication is done with luminous vivid red.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="2r" to="3v">2r-3v</locus>; characterized by thick vertical lines, hair lines (cp. ፈ፣
                        ነ፣ ከ፣ኀ፣ ራ), bifurcated elements (cp. ተ፣ ቊ፣ ድ፣ ዮ፣
                        ጽ).</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="5r" to="76r">5r-76r</locus>
                        
                     </handNote>

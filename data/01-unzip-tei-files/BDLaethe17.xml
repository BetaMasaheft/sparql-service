               <msContents>
                  <summary/>
                     
                     <msItem xml:id="ms_i1">
                        <locus from="1r">Fols 1r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4331Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">አኰቴተ፡ አብ፡ ወወልድ፡ ቃለ፡ መደንግፅ፡ አምላክ።</incipit>
                        <note>The second verse begins with: <foreign xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምኪ፡ በስመ፡ ማርያም፡ ዘተጸውዓ፤</foreign>. 
                        All verses are introduced by <foreign xml:lang="gez">ሰላም፡</foreign>
                     </note>
                        <note>The 22nd verse on <locus target="#4r">fol. 4r</locus> was rubbed out and subsequently rewritten, in an apparently
                        expanded form, so that the letters are less than half the normal size.</note>
                     </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="5r">Fols 5r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4332Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ጠባብ፡ መጽሔተ፡ ደናግል፡ ኃምስ።</incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="6r">Fols 6r and following</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4333Salam">Malkǝʾ-hymn to John the Evangelist</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ቀዳሚሁ፡ ቃል፡ ውእቱ፡ ቃል። <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/>
                     ሰላም፡ ለዝክረ፡ ስምከ፡ ለመጽሐፈ፡ ትፍሥሕት፡ ምሥጢራ።</incipit>
                     <note>There are often feminine suffixes, as the scribe is used to hymns to <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>.</note>
                     <note>The end is missing. The hymn breaks off in the middle of a verse.</note>
                  </msItem>
                  
                  </msContents>
                     

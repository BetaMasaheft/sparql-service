                     <msItem xml:id="p1_i1">
                        <locus from="1" to="6" cert="low"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2300Sebhat"> ዝንቱ፡ ስብሐተ፡ ፍቁር፡
                           ዘያትመሀለሉ፡ ቦቱ፡ ክርስቲያን፡ በጊዜ፡ ምንዳቤሆሙ።</title>
                        
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኦብእሲ፡ ክርስቲያናዊ፡ ክርስቶሳዊ፡ ለእመ፡ ረከብከ፡ ቤተ፡ ክርስቲያነ፡ ተማህለል፡
                           ቦቱ፡ በምሥዋዕ፡</incipit>
                        <note>The following is the beginning of the hymn, sung in <foreign xml:lang="gez">ʿǝzǝl</foreign> mode, after the introduction: <q xml:lang="gez">
                              <hi resp="PRS10747Zotenbe">ሃ፡</hi> ንዑ፡ ንስግድ፡ ለባሕቲቱ፡ እንዘ፡ ፩፫፡ እስመ፡
                              መፍቀሬ፡ ሰብእ፡ ውእቱ።</q>
                        </note>
                     </msItem>

                     <msItem xml:id="p1_i2">
                        <locus from="7r" to="8" cert="low"/>
                        <locus from="42" to="49" cert="low"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2731RepCh15">
                           <certainty locus="value" match="../@ref" cert="low"/> መኃልይ፡ ለእግዚአብሔር፡
                           ዓቢይ፡ በ፫፡ ዕዝል፡ <hi resp="PRS10747Zotenbe">ሃ</hi>፡ </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ለአዳም፡ አቡነ፡ ዘለሐኮ፡ በአርአያከ፡ እግዚአብሔር፡ ርድአነ፡ ለሕዝብከ። <hi resp="PRS10747Zotenbe">ሃ</hi>፡ ለአቤል፡ ቅቱል፡ ዘነጽርከ፡ ቍርባኖ፡</incipit>
                     </msItem>



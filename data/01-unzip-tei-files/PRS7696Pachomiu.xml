      <t:body>
         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q298698">

               <t:persName xml:lang="gez" xml:id="n1" type="birth">ጳኵሚስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Ṗākʷǝmis</t:persName>
               <t:persName xml:lang="en" xml:id="n2" type="main">Pachomius</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Egypt"/>
               <t:faith type="Coptic"/>
               
               <t:birth when="0294"/>
               <t:floruit> He was the founder of cenobitic monasticism. He was born of pagan parents
                  in Upper <t:placeName ref="https://betamasaheft.eu/LOC2804Egypt">Egypt</t:placeName>. His first contact with
                  Christianity occurred in <t:date>312</t:date>, when he was a conscript in the Roman
                  army. Then, <t:persName ref="https://betamasaheft.eu/PRS7696Pachomiu">Pachomius</t:persName> came into contact
                  with several well known ascetics and decided to pursue that path under the
                  guidance of the hermit named <t:persName ref="https://betamasaheft.eu/PRS7703Palamon">Palamon</t:persName>.
                  Finally, he established his own monastery in <t:date>between 318 and 323</t:date>. </t:floruit>
               <t:death when="0356"/>
            </t:person>
            
         </t:listPerson>



               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="6v">2r-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1259IHA">منظومة شي لله يا جمال الاني</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>شى لله يا بحور سيدى يا بحور المدد ٢  \ يا جمال الاني ابا عبد الصمد \ راجيكم واقف بابكم طالبا \ نفحة جودكم يا ارباب المدد \ يا بواب الحضرة يا ابا البركة \ ارحموا باكيا نحوكم قد قصد \ قد طالت عليه امور صعبة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>كالحاج صالح فى شعب الجبل قاعد \ وغيرهم من قطب النساويا \ من امر القضايا دونكم لا توجد \ ادركونى جمعا بحق المصطفى \ صلى الله بالوفا عليه الال سجد</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="7r" to="14r">7r-14r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1260IHA">منظومة شي لله يا ابا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#7r">-7r</locus>شى لله شى لله ٣ شى لله يا أبا محمد \ شى لله شي لله يا أبا محمد سيدي يا بحر المدد \ يا سيدى يا أبا محمد \ يا حامل رايات المدد [...] أيا شهاب الدين الدانى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>وحصول الامن والسلام \ آمين آمين آمين يا الله يا مولى الانام آمين يا مبدى \ تم</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="14v" to="15r">14v-15r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1261IHA">رسالة في تفسير الرؤيا</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>بسم الله الرحمن الرحيم \ فى تفسير الرؤيا ونقل عن تفاسير الائمة ان محمد بن هوازن جمع من كان تحت قبضته ومملكته من العلماء التفسير الرؤيا على غاية الاختصار تكون فى ورقة واحدة لا يفارقها فى سفره وحضره فاجتمعوا كلهم فالوه هذه المقدمة التى ما سمع مثلها قط على حروف الهجائية وهي اذا رء النائم شياء فياخذ اول الحروف الذى رأه واذا رءا ماء فياخذ حروف الميم واذا رء انه ركب الفرس فياخذ الفاء وهكذا الى اخر الحروف<note>The name هوازن is a corruption of خوارزم شاه Ḫwarizm Šāh.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus>و تدل على فضاء الخوائج بتعب كثير \ 
هى تدل على تعب القلب من جهة السلطان \ لا تدل على شغل القلب من افعاله \ ي تدل على كثرة الطاعات والله اعلم بمراده</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="16r" to="25v">16r-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1267IHA">منظومة شي لله يا بحر المدد سيد ابا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>شي لله شي لله شي لله \ [شي] لله يا بحر المدد ٣ [.؟.] شي لله يا بحر المدد سيد ابا محمد \ [وت] نحوكم عاشقا  \ [.؟.] بكم مطرقا \ عساكم تجود باللقا<note>Parts of the page is torn off. </note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>مدة الليالى والايام \ ورضي الله عن مشايخه الكرام رضوانا [.؟.] العدد<note>Part of the text torn off.</note>
                     </explicit>
                     <note>Vocalized. Parts of the text worn off.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="27v" to="95v">27v-95v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1269IHA">منظومة حياة جميع العالم</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>صلى الله على محمد , حياة جميع العالم \ قد لاح سر مكتم , آفاق قلب المتيم \ تجلى البدر المعظم , ملفوفا بنور الختام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#95v">-95v</locus>مخازن علوم الله , أمناء اسرار الله \ ومجلس حضرة الله , ومفرش بساط الله \ ومغفر فيضات الله , ومكنز زخرة الله \ تمت</explicit>
                     <note>Vocalized. The vowel marks are added with a blue ball-point pen.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="96r" to="102r">96r-102r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1270IHA">منظومة شي لله يا ابا احمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#96r">-96r</locus>شي لله شي لله شي لله ٣ يا أبا احمد شي لله شي لله شي لله \ يا ابا احمد يا ميز اب فيض المدد \ احمد مولاي الصمد \ اشكره مدا [الابد] \ اخدم مولانا السند \ مربى المريد سيدي أبى احمد شمس الدين الفرد الامجد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#102r">-102r</locus>فى كل بكر والاصال مع الايام والليال دوما مسرمد \ جائتنى يا أهل الحبيه \ بفضل ذى الوصف العليه \ وبسر خير البريه \ هذه الداليه فى مدح الدينية , سنة رمز غشنحد \ ١٣٦٢<note>The abjad numerals ġ-š-n-d give the year 1354. The numerals 1362 are added below the line with a blue ball-point pen.</note>
                     </explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>

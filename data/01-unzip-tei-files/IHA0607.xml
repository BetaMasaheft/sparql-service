                        <item xml:id="a0_1618">
                           <locus target="#15r">-15r</locus>
                           <q xml:lang="ar">١٣٩٩ بيد كاتبها يم الاثم عبد السلام الاسم </q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_1616">
                           <locus target="#6v">-6v</locus>
                           <q xml:lang="ar">من اله سنة ١٣٩٤ بيد \ موسى بن عمر بن علي الدووى ناحية القادري طريقة</q>
                           <desc>Colophon</desc>
                           <note>Nāhiya: <placeName ref="https://betamasaheft.eu/LOC0162IHA">Dawway</placeName>
                           </note>
                        </item>
                        <item xml:id="a0_1616">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">منظومة [.؟.] \ هذه المنطومة ملك محمد رياض شيخ سراج \ صحح \ رياض</q>
                           <desc>Ownership</desc>
                           <note>
                              <p>
                                 Owned by
                              : <persName ref="https://betamasaheft.eu/PRS0901IHA">محمد رياض شيخ سراج</persName>

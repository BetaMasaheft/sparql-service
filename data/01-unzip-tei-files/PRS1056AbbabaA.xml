      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አበበ፡ አረጋይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAbbaba ʾAragāy</t:persName>
                  <t:persName>
                  <t:roleName type="title">rās</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
               <t:occupation type="military">patriot</t:occupation>
                  
                  <t:birth when="1903"/>
                  
                  
                  
               <t:floruit notBefore="1930" notAfter="1960">He was one of the outstanding Ethiopian patriots 
                  during the Italian occupation, <t:date>1935-1941</t:date>. 
                  He was a native of <t:placeName ref="https://betamasaheft.eu/LOC3433Jerru">Ǧǝrru</t:placeName> in <t:placeName ref="https://betamasaheft.eu/LOC6574NorthSawa">North Šawā Zone</t:placeName>. 
                  ʾAbbaba ʾAragāy 
                  joined the city guards of <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> 
                  when they were established in <t:date>1930</t:date>. 
                  Following the Italians triumphant entry into the capital,<t:date>1936</t:date>, 
                  he organized a center of  armed resistance in his native district and soon emerged as the leader of patriotic forces in <t:placeName ref="https://betamasaheft.eu/LOC6574NorthSawa">North Šawā Zone</t:placeName>.
                  He participated in the ill coordinated offensive of July <t:date>1936</t:date>. 
                  He was promoted to the rank of <t:persName ref="https://betamasaheft.eu/PRS1056AbbabaA">
                     <t:roleName type="title">rās</t:roleName> 
                  </t:persName>by 
                  <t:persName ref="https://betamasaheft.eu/PRS6575Malaka">
                     <t:roleName type="title">nǝguś</t:roleName>
                  </t:persName> who had been elected 
                  by the patriots of <t:placeName ref="https://betamasaheft.eu/LOC2008Bulga">Bulga</t:placeName>. 
                  He was also made honorary chairman of the Association of the patriots of Old Ethiopia, 
                  created for the purpose of fostering unity among the disperate patriotic groups. 
                  He welcomed the triumphant entry of <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</t:persName> at the head of 15,000 troops in <t:date>1941</t:date>. 
                  He was soon appointed as mayor of <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName>. 
                  He served also the Imperial government as Minister of Defence and Minister of Interior.
                   </t:floruit>
               <t:death when="1960">He was one of the ministers and dignitaries killed in the 
                  course of the abortive Coup d'état in <t:date>1960</t:date>.</t:death>
                  
                  
               </t:person>
               
         </t:listPerson>
         
         
         

                  <additions>
                     <list>

                        <item xml:id="a1">
                           <desc type="Asmat"/>
                           <locus target="#1v"/>
                           <q xml:lang="gez">ር፡ ያሚጥ፡ ሚጤሽ፡ <gap reason="omitted"/> አድኃኖ፡ ለገብርከ፡ እገ፡</q>
                        </item>

                        <item xml:id="a2">
                           <desc type="CalendaricNote">A table of the shadows' length.</desc>
                           <locus target="#2v"/>
                           <q xml:lang="gez"/>
                        </item>

                        <item xml:id="a3">
                           <desc type="Supplication"/>
                           <locus target="#11v"/>
                           <q xml:lang="gez">እግዝእትየ፡ ማርያም፡ አድኀነኒ፡ እመከራ፡ ስጋ፡ ወነፍስ፡ ለገብርኪ፡ ኃይለ፡ ማርያም።</q>
                        </item>

                        <item xml:id="a4">
                           <desc type="GuestText"/>
                           <locus from="38r" to="38v"/>
                           <note>Following is the incipit</note>
                           <q xml:lang="gez">ዘረተስአ፡ ፀሐፍነ፡ መጽሐፈ፡ ሐውልት፡ ሠረቀ፡ መስከረም፡ በ፩ በርተ፡ ሎሜዎስ፡</q>
                        </item>

                        <item xml:id="a5">
                           <desc type="MagicFormula"/>
                           <locus from="39r" to="39v"/>
                           <note>Following is the incipit</note>
                           <q xml:lang="gez">ግልል፡ ምልል፡ ምዝርር፡ ከመ፡ ኢይርሳእ፡ ቃለ፡ እግዚአብሔር፡</q>
                        </item>
                     </list>
                  </additions>


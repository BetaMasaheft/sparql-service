                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="3r" to="22v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2246salotz">ጸሎት፡ ዘጸለየት፡ እግዚእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ እሙ፡ ለብርሃን፡ እንተ፡ ጸሐፈ፡ አብሮኮርስ፡ ረድእ፡ ዮሐንስ። ጸሎት፡ ዘጸለየት፡ አመ፡
                          ፳ወ፩ ለወርኃ፡ ሰኔ፡ በደብረ፡ ጎልጎታ፡</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <locus from="22v" to="37v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2444Temher">በእንተ፡ ትምህርተ፡ ኅቡአት፡ </title>
                          <textLang mainLang="gez"/>
                          <explicit type="supplication" xml:lang="gez">
                            ኦእግዚእየ፡ ኢየሱስ፡ ክርስ፡ ክር፡ ዕቀበኒ፡ ለገብርከ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS12672Kebraa">ክብረ፡ አብ፡</persName>
                            ወአቡሁ፡ <persName ref="https://betamasaheft.eu/PRS12673SayfaG">ሠይፈ፡ ገብርኤል፡</persName> ወእሙ፡ <persName ref="https://betamasaheft.eu/PRS12674SehinaM">ሥሂነ፡ ማርያም።</persName>። ወጸሐፊሁኒ፡
                            <persName role="scribe" ref="https://betamasaheft.eu/PRS12675WaldaTH">ወልደ፡ ተክለ፡ ሃይማኖት፡</persName> ዘቦራ።።
                          </explicit>
                        </msItem>


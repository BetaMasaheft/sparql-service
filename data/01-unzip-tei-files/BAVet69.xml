                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1" to="18"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4065Prayer">Prayer of thanksgiving for the offering of the incense</title>
                     <incipit xml:lang="gez"> በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወእምዝ፡ ይጼሊ፡ ቀሲስ፡
                        ጸሎተ፡ 
                           <sic>አኰቴተ፡</sic>
                         ወያዓርግ፡ 
                           <sic>ዕጣን፡</sic>
                         እንዘ፡ ይብል፨ ተወከፍ፡ እምኔየ፡ እግዚኦ፡</incipit>
                     <explicit xml:lang="gez">በአማኑኤል፡ ስምከ፡ ዘኢይትመዋእ፡ ለፀር፡ በኢየሱስ፡ ክርስቶስ፡ ስምከ፡ ተማኅፀንኩ፡ አነ፡ ገብርከ፡ ተንሥአ፡ ክርስቶስ። ዘርአ፡ ጽዮን። ታቦተ፡ ማርያም። ቅድስት።
                     ማርያም፡ ሠምረ<supplied reason="omitted">ት</supplied>፡ እምይእዜ፡ ወእስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨ = ፨</explicit>
                     <note>Several names are mentioned in the supplication formula at the end of the text: those of <persName ref="https://betamasaheft.eu/PRS11538TanseaKr">Tanśǝʾa Krǝstos</persName>,
                        <persName ref="https://betamasaheft.eu/PRS11539ZaraSe">Zarʾa Ṣǝyon</persName>, <persName ref="https://betamasaheft.eu/PRS11540TabotaMa">Tābota Māryām</persName>,
                        <persName ref="https://betamasaheft.eu/PRS11541QMSamrat">Qǝddǝst Māryām Śamrat</persName>, possibly owners of the book.</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="18" to="28v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">Kidān za-nagh</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="28v" to="47v"/>
                     <title>Prayers of the morning</title>
                     <incipit xml:lang="gez">ወካዕበ፡ <supplied reason="omitted">ና</supplied>ስተበቍዕ፡ ዘኵሎ፡ ይእኅዝ፡ እግዚአብሔር፡ አብ፡ ለእግዚእ፡ ወመድኀኒነ፡ ኢየሱስ፡
                        ክርስቶስ፨ በእንተ፡ ሰላም፡ ለቅድስት፡ አሐቲ፡ እንተ፡ 
                           <sic>ለዕለ፡</sic>
                         ኵሉ፡ ቤተ፡ ክርስቲያን፡</incipit>
                     <explicit xml:lang="gez"> ኵሎ፡ ደዌ፡ <supplied reason="omitted">ወ</supplied>ኵሎ፡ 
                           <sic>ሕማም፡</sic>
                         ስድድ፡
                        
                           <sic>እምለዕሌሆሙ፡</sic>
                         ወእምላዕለ፡ ኵሉ፡ ሕዝብከ፡ ወተረፈ፡ 
                           <sic>ሌሊተኒ፡</sic>
                         በኵሉ፡ ሰላም፡
                        
                           <sic>ወጢዒና፡</sic>
                        
                        
                           <sic>ይረስያነ፡</sic>
                         ነሀሉ፡ በክርስቶስ፨ በአሐዱ፡ ወልድከ፡ ዘቦቱ፡ ለከ፡
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                     </explicit>
                     <note>The text begins with an invocation for the peace of the Church and terminates with <ref type="work" corresp="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</ref>.</note>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="47v" to="59v"/>
                     <title type="complete">Miracles of Mary, two in number</title>
                     <msItem xml:id="ms_i4.1">
                        <locus from="47v" to="50v"/>
                        <title>Introductory texts to the miracles of Mary</title>
                        <msItem xml:id="ms_i4.1.1">
                           <title ref="https://betamasaheft.eu/LIT4270Salota">
                              
                                 <sic>ጸሎተ፡</sic>
                               ህየንተ፡ ወንጌል፡</title>
                        </msItem>
                        <msItem xml:id="ms_i4.1.2">
                           <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1693John">Gospel of John</ref> 19:25-27</title>
                           <note>The excerpt is followed by an untitled prayer in <foreign xml:lang="gez">ʿǝzl</foreign>-tone, cp. <ref type="item" corresp="https://betamasaheft.eu/BAVet54#p3_i1.8"><span xmlns="" class="w3-tag w3-red">No item: BAVet54#p3_i1.8</span></ref>.</note>
                        </msItem>
                        <msItem xml:id="ms_i4.1.3">
                           <title ref="https://betamasaheft.eu/LIT4614Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                           <incipit xml:lang="gez">
                              ሰላም፡ ለማርያም፡ ንግሥ<supplied reason="omitted">ት</supplied>፡ ወዐጸድ፡ ዘበ፡ አማን፡ ዘኢተገበርዋ፡ ተረክበ፡ 
                                 <sic>አስከለ፡</sic>
                              
                              ሕይወት፡ ህየ፨
                           </incipit>
                           <explicit xml:lang="gez">
                              
                                 <sic>ዘቲ፡</sic>
                               ይእቲ፡ 
                                 <sic>ጸዮን፡</sic>
                              
                              
                                 <sic>ሐደስ፡</sic>
                               ሀገረ፡ አምላክነ፡ ዘኃደረ፡
                              
                                 <sic>ለዕሌሃ፡</sic>
                              
                              
                                 <sic>ፍሥሐ፡</sic>
                               ኵሎሙ፡ ነቢያት፡ 
                                 <sic>ቅዱሰን፨</sic>
                              
                           </explicit>
                        </msItem>
                     </msItem>
                     <msItem xml:id="ms_i4.2">
                        <locus from="50v" to="53v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3613Miracle">
                           
                              <sic>ተስዕ፡</sic>
                            ተአምሪሃ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ ማርያም፡ ማሪሃም፡ 
                              <sic>ወለዲተ፡</sic>
                            አምላክ፡
                        </title>
                        <incipit xml:lang="gez">ተብህለ፡ ከመ፡ ሀሎ፡ ፩ዲያቆን፡ ውስተ፡ አሐቲ፡ መካን፡ ዘያፈቅሮ፡ ለእግዚአብሔር፡ ልዑል፡ ፈድፋደ፡ ወያፈቅራ፡ ለእግዝእትነ፡ ቅድስት፡
                           
                              <sic>ደንግል፨</sic>
                            ማርያም፡ ማሪሃም፡</incipit>
                        <explicit xml:lang="gez">ወፅአት፡ ነፍሱ፡ እምሥጋሁ፡ ወዐርገት፡ ምስለ፡ እግዝእትነ፡ ቅድስት፡ ድንግል፨ ማርያም፡ ማሪሃም፨ ወቦአት፡ ውስተ፡ ትፍሥሕት፡ ዘለዓለም፨ በትንብልናሃ፡
                           ለእግዝእትነ፡ ቅድስት፡ ድንግል፨ መስተሣህልት፡ ወእመ፡ ምሕረት፡ ጸሎታ፡ ወበረከታ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i4.3">
                        <locus from="53v" to="59v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3928Miracle">Miracle of Mary: Another version of the story of Nathan the
          monk</title>
                         <incipit xml:lang="gez">፵፱፡ ተአምሪሃ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወሀሎ፡ ብእሲ፡ ዘስሙ፡
                           ናታን፡ በደብረ፡ ሰራብዮን፡ ኀበ፡ መነኮሳት፡ ዘይእቲ፡ ደብር፨ ወውእቱ፡ መጋቢ፡ የዐቅብ፡ 
                              <sic>መዘግብተ፡</sic>
                            ዘቤተ፡ ክርስቲያን፡</incipit>
                        <explicit xml:lang="gez">ወሠረፀ፡ ፍቅራ፡ ውስተ፡ ልቡ፡ 
                              <sic>ወሐረ፡</sic>
                            ፍኖተ፡ 
                              <sic>ርቱዕ፡</sic>
                            ወነበረ፡ በኵሉ፡
                           መዋዕለ፡ ሕይወቱ፡ እንዘ፡ ይትቀነ<supplied reason="omitted">ይ</supplied>፡ ወይትለአክ፡ እስከ፡ አመ፡ አፅረፈ፡ በሰላም። ወቦአ፡ ውስተ፡ መንግሥተ፡ ሰማያት፨ ስእለታ፡
                           <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="59v" to="60"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4615Salam">Malkǝʾ-hymn to the Cross, John the Evangelist, and the Apostles</title>
                     <incipit xml:lang="gez">ለመስቀልከ፡ እግዚኦ፡ ንፌኑ፡ ስብሐተ፡ ሃሌሉያ፡ ሰ<add place="inline">
                           <supplied reason="omitted">ላ</supplied>
                        </add>ም፡ ለከ፡
                        ዮሐንስ፡ ወልደ፡ ነጐድጓድ፨ ሰላም፡ ለከ፡ ዮሐንስ፡ አቡ፡ ቀለ<supplied reason="omitted">ም</supplied>ሲስ፨ ሰላም፡ ለከ፡ ዮሐን<supplied reason="omitted">ስ</supplied>፡
                        ቴዎጎሎስ፨</incipit>
                     <explicit xml:lang="gez">ሉቃስ፡ ወማርቆስ፨ ወያዕቆብ፨ ኤጲስ፨ ቆጶስ፨ ለደቂቅክሙ፡ ባርኩነ፡ በቅዱስ፡ መንፈስ፨</explicit>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="60" to="87"/>
                     <title>Ordinary of the Mass and Anaphora of the Apostles</title>
                     <msItem xml:id="ms_i6.1">
                        <title ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddase">Ordinary of the mass</title>
                     </msItem>
                     <msItem xml:id="ms_i6.2">
                        <title ref="https://betamasaheft.eu/LIT1104Anapho">Anaphora of the Apostles</title>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="106v" to="116v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">Anaphora of Our Lord Jesus Christ</title>
                     <note>The anaphora is followed by a prayer after the eucharist and a prayer for the imposition of the hands, which begins as follows:
                        <q xml:lang="gez">አንብሮ፡ እድ፡ እምድኅረ፡ 
                              <sic>ነሣአ፡</sic>
                            እግዚአብሔር፡ ዘለዓለም፡ ዘኵሎ፡ ትእኅዝ፡ አብ፡ ለእግዚእ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡
                           ባርክ፡ አግብርቲከ፡ ወአእማቲከ፨ ክድን፡ ወርዳእ፡ ወሠርሕ፨</q>.
                     </note>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="117" to="121v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer">Prayers of the imposition of the hands in the daily office</title>
                     <msItem xml:id="ms_i8.1">
                        <locus from="117r" to="117v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#Morning">Prayer for the office of the morning</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፨ ዘንግህ፡ እግዚአብሔር፡ ዘለዓለም፡ ዘጸዋዕከነ፡ 
                              <sic>በጽዋዐ፡</sic>
                            ቅድሳት፡ ወአሰፎከነ፡ በረከታተ፨ ሀበነ፡ እግዚኦ፡
                           ልበ፡ ንጹሐ፡</incipit>
                        <explicit xml:lang="gez">ዕቀበነ፡ በሣህሉ፡ ለኢየሱስ፡ ክርስቶስ፡ ዘይነብር፡ ዲበ፡ ሰረገላ፡ ኪሩቤል፡ ዘኵሉ፡ ይርዕድ፡ በቃለ፡ ኃይሉ፡ ቅዱስ፡ ወውዱስ፡ በኵሉ፡ ዓለም፡ አሜን፨ = ፨</explicit>
                     </msItem>
                     <msItem xml:id="ms_i8.2">
                        <locus from="117v" to="118r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#ThirdHour">Prayer for the office of the third hour</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፡ ዘ፫፡ ሰዓት፡ እግዚአብሔር፡ ኄር፡ አምላክነ፡ ነጽር፡ ዲበ፡ 
                              <sic>እላ፡</sic>
                            ውስተ፡ 
                              <sic>ንስሐ፡</sic>
                           
                           
                              <sic>ተሣህሎሙ፡</sic>
                            በከመ፡ ዕበየ፡ ሣህልከ፡ ወበከመ፡ ብዝኀ፡ ምሕረትከ፡</incipit>
                        <explicit xml:lang="gez">በሞገሱ፡ ወበምሕረቱ፡ ወበአፍቅሮቱ፡ ሰብአ፡ በአሐዱ፡ ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i8.3">
                        <locus from="118r" to="119r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#SixthHour">Prayer for the office of the sixth hour</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፡ ዘ፮ሰዓት፨ ቅዱስ፡ 
                              <sic>ዘተዓርፍ፡</sic>
                            ውስተ፡ ቅዱሳን፡ ልዑል፡ እምልዑላን፡</incipit>
                        <explicit xml:lang="gez">ሀቦሙ፡ ወወስኮሙ፡ አሚነ፡ ወኂሩተ፡ ወሀቦሙ፨ ውስተ፡ ዘይሤኒ፡ ምግባር፡ 
                              <sic>ይትልው፡</sic>
                            ወተማሕፀኖሙ፡ በየማንከ፡ ቅዱስ፡ በእግዚእነ፡
                           ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i8.4">
                        <locus from="119r" to="120r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#NinthHour">Prayer for the office of the ninth hour</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፡ ዘ፱ቅዱስ፡ 
                              <sic>በቅዱሰን፨</sic>
                           
                           
                              <sic>ዘተዓርፍ፡</sic>
                           
                           
                              <sic>በልዑለን፡</sic>
                           
                           ዘተኃድር፨ 
                              <sic>ለዝሉፋ፡</sic>
                            ዘኢይትነሰት፡ መንበርከ፡ 
                              <sic>ወኢይትዓር፡</sic>
                            መንግሥትከ፨ ለከ፡ አትሐቱ፡ ርእሶሙ፡
                           ሕዝብከ፡ መሃይምናን፡</incipit>
                        <explicit xml:lang="gez">ዕቀብ፡ ውሉደ፡ ሕዝብከ፡ ወአልህቅ፡ ወአሠኒ፡ ግዕዞሙ፡ ወአብጽሖሙ፡ ውስተ፡ መስፈርተ፡ 
                              <sic>አከል፡</sic>
                            ወኵልነ፡ እንከ፡ በአተነ፡
                           ወጸአተነ፡ በሰላም፡ ዕቀበነ፡ በአሐዱ፡ ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i8.5">
                        <locus from="120r" to="120v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#Twilight">Prayer for the office of the twilight</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፡ ዘሰርክ፡ ለከ፡ ኵልነ፡ አትሐትነ፡ 
                              <sic>አእግዚኦ፡</sic>
                            ዘውስተ፡ ልዑላን፡ ተኃድር፡ ወመትሕተ፡ ትሬኢ፡</incipit>
                        <explicit xml:lang="gez">አድኅነነ፡ እምፍርሃተ፡ ሌሊት፡ እስመ፡ ተሰብሐ፡ ስምከ፡ ቅዱስ፡ ለዐለመ፡ ዓለም፡ አሜን፨</explicit>
                     </msItem>
                     <msItem xml:id="ms_i8.6">
                        <locus from="120v" to="121r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#Night">Prayer for the office of the night</title>
                        <incipit xml:lang="gez">ንብረተ፡ እድ፡ ዘሌሊት፡ እግዚአብሔር፡ መስተሣህል፡ ዘባሕቲትከ፡ ታድኀን፡ ወትክል፡ ባርኮ፡ ባርክ፡ 
                              <sic>እላ፡</sic>
                            አትሐቱ፡ ርእሶሙ፡ እለ፡
                           ይጸንሑ፡ ዘእምኃቤከ፡ 
                              <sic>በረከትከ፡</sic>
                            ወኵሎ፡ ዕቀብ፡ በሣህልከ፡ ክርስቶስ፡ እስመ፡ 
                              <sic>ለካ፡</sic>
                            እኂዝ፡ ወመንግሥት፡
                           ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ለዓለመ፡ ዓለም፡ አሜን፨</incipit>
                     </msItem>
                     <msItem xml:id="ms_i8.7">
                        <locus from="121r" to="121v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4617Prayer#Forever">ንብረተ፡ እድ፡ ዘለዓለም፡</title>
                        <note>
                           <q xml:lang="gez">ብርሃነ፡ ሕይወት፡ ወሀብከ፡ እግዚኦ፡ ለአግብርቲከ፡ ጽንዕተ፡ 
                                 <sic>ወዕቀበተ፡</sic>
                               ወዘሀሎ፡ ዕለታተ፡ ወለያልየ፡ እንዘ፡
                           ተዐቅብ፡ በሰላም፡ ባርክ፡ በዘ፡ ይእዜኒ፡ 
                                 <sic>ወዋዕል፨</sic>
                               ወበዘ፡ እምድኅረ፡ 
                                 <sic>እለ፡</sic>
                               እግዚእነ፡
                           
                                 <sic>አየሱስ፡</sic>
                               ክርስቶስ፡ ምስሌሁ፡ ለከ፡ ኅቡረ፡ ወምስለ፡ ውዱስ፡ መንፈስ፡ ስብሐት፡ ወእኂዝ፡ ይእዜ፡ ወዘልፈኒ፡ 
                                 <sic>ወለዓላመ፡</sic>
                              
                           ዓለም፡ አሜን፨</q>
                        </note>
                     </msItem>

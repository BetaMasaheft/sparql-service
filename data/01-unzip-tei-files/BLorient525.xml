                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1r"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</title>
                            <textLang mainLang="gez"/> 
                            <note>It is not clear from the catalogue description whether the text of <ref type="work" corresp="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</ref>
                            is contained in this manuscript in its entirety.</note>
                        
                        <msItem xml:id="ms_i1.1">
                            <locus from="1r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Monday">Sayfa Śǝllāse: Praise for Monday</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አአምን።
                                በስመ፡ አብ፡ <gap reason="omitted" resp="PRS10171Wright"/>
                            እትማኃፀን። አአትብ፡ ገጽየ፡ በማእዘረ፡ ገጹ፡ ለእግዚአብሔር፡ ዘኢያንቃዕደወ፡ ኀበ፡ ገጸ፡ ካልእ።
                            አአትብ፡ አዕይንትየ፡ በማእዘረ፡ አዕይንቲሁ፡ ለእግዚ'፡ ዘያርእዮ፡ ኀበ፡ ነጸረ።</incipit>
                            <note>The text seems to start in the middle of the prayer for Monday, see
                                <ref type="mss" corresp="https://betamasaheft.eu/ESktm012">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy, Kadiḥ Dabra Tawāḥǝdo Qǝddǝst Māryām, KTM-012</ref>, f. 10va.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2">
                            <locus from="2r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#SalamMonday">Sayfa Śǝllāse: div SalamMonday</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">ሰላም፡ ለአብ፡ ነቅዓ፡ ዘይት፡ ምሕርት፡ ጥሉል። ሰ'፡ ለወልድ፡ ነ'፡ ዘ'፡ ም'፡ ጥ'።
                                ሰ'፡ ለመንፈስ፡ ቅዱስ፡ ነ'፡ ዘ'፡ ም'፡ ጥ'፡ ፫ፈልፈል።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.3">
                            <locus from="3r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#PrayerMonday">Sayfa Śǝllāse: div PrayerMonday</title>
                            <textLang mainLang="gez"/> 
                            <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted" resp="PRS10171Wright"/>
                            መለኮተ፡ ሥላሴ፡ ፍጽምት፡ አሐቲ፡ ስምረት፡ ወሠለስቱ፡ <del rend="erasure"/>
                                አካል፡ በዋህድ፡ ጽምረት፡ ፩መንበር፡ በ፩ህላዌ፡ <del rend="erasure"/>
                            በትሥልስት፡ ወበ፩መንግሥት፡ ወሥሉስ፡ እንበለ፡ ፍልጠት፡ ዕሩይ፡ እንበለ፡ ሐፀት። ኅብረት፡ ወአሐቲ፡
                            ፍትወት፡ ሥላሴ፡ ምጥቅት፡ እምሰማየ፡ ሰማያት። ሥላሴ፡ ምጥቅት፡ እምሰማየ፡ ሰማያት። ሥላሴ፡ እኃዜያት።
                            ሥላሴ፡ ድምርት፡ በስልጣን፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ መልዕልት፡ በመልዕልተ፡ መልዕልት፡
                            ወመትሕተ፡ መትሕት። ። ።</incipit>
                        </msItem>
                        </msItem>
                        

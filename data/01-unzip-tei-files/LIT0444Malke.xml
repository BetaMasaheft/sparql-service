      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0444</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ እማሕፀን፨</l>
                  <l n="2">በእሳት፡ ሠናይ፡ ወበሣህላዊ፡ ዘመን፨</l>
                  <l n="3">ሕፃነ፡ ኢያሱ፡ ንጉሥ፡ ወልደ፡ ሩፋኤል፡ መስፍን፨</l>
                  <l n="4">ተደለውከ፡ ለአሠንዮ፡ ሕንጻ፡ ቤተ፡ ክርስቶስ፡ መድኅን፨</l>
                  <l n="5">በብሩር፡ ወወርቅ፡ ዘአልቦ፡ ወሰን፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘበኀበ፡ ኵሉ፡ ተጸውዐ፨</l>
                  <l n="2">ወበውስተ፡ ኵሉ፡ ተሰምዐ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ መርዓዊ፡ ዘነበርከ፡ በቤተ፡ መርዓ፨</l>
                  <l n="4">ነዓ፡ ነዓ፡ ውስተ፡ ቤተ፡ አምላክ፡ ነዓ፨</l>
                  <l n="5">ለደቂቀ፡ ዛቲ፡ ደብርከ፡ ትኩነነ፡ መርድዐ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለገጽከ፡ ዘቅብአ፡ መንፍሥት፡ ቅቡእ፨</l>
                  <l n="2">ወያስተፌሥሕ፡ ለሰብእ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ አቤል፡ ሠዋዔ፡ ምጽዋት፡ በግዕ፨</l>
                  <l n="4">ዕቀበኒ፡ በኪዳንከ፡ ለብእሲ፡ ኃጥእ፨</l>
                  <l n="5">ኀይለ፡ ኪዳንከ፡ አምላካዊ፡ አኮኑ፡ ጽኑዕ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለአፉከ፡ ዘጣዕመ፡ ነገሩ፡ ውዱስ፨</l>
                  <l n="2">እንዘ፡ ቅድመ፡ ኵሉ፡ ይትናገር፡ ነገረ፡ ኅድአት፡ ወመርስ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ ዮሐንስ፡ ፍቁረ፡ እግዚእ፡ ክርስቶስ፨</l>
                  <l n="4">ለኵሎሙ፡ እለ፡ ሀለዉ፡ በኢትዮጵያ፡ ሐዳስ፨</l>
                  <l n="5">አንተ፡ መኰንን፡ ወአንተ፡ ንጉሥ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ሰላም፡ ለኵልያቲከ፡ ፍጹመ፡ እለ፡ ተፈትኑ፨</l>
                  <l n="2">ለእሳተ፡ ጥበብ፡ በርስኑ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ ዘአንተ፡ ለኢትዮጵያ፡ መስፍኑ፨</l>
                  <l n="4">መኑ፡ በኂሩትከ፡ ዘይመስለከ፡ መኑ፨</l>
                  <l n="5">እንበለ፡ ቀዳማይ፡ አብርሃም፡ ዘነዊኅ፡ ዘመኑ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ መቃብረ፡ አበው፡ ነገሥት፨</l>
                  <l n="2">ውስተ፡ ደብረ፡ ቍስቋም፡ ቅድስት፨</l>
                  <l n="3">እንዘ፡ መቃብሪከ፡ ዝየ፡ ውስተ፡ ቀራንዮ፡ ሕንጽት፨</l>
                  <l n="4">መፍትው፡ ለነ፡ ትትመየጠነ፡ ዐይነ፡ ሥጋከ፡ ብርህት፨</l>
                  <l n="5">እግዚእነ፡ በጸሎትከ፡ ዘአልቦ፡ ጽልሁት፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ እምሀገረ፡ ከሃ፡ ኀቤነ፨</l>
                  <l n="2">ከመ፡ ተሰፈውነ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ ዘኮንከ፡ እንዘ፡ ወላዲ፡ መካነ፨</l>
                  <l n="4">ኢህለወ፡ ዐፅመ፡ ሥጋከ፡ ዘያመጽእ፡ ለነ፨</l>
                  <l n="5">ባሕቱ፡ ቃለ፡ ፈጣሪ፡ ኢነአምር፡ ንሕነ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ስብሐት፡ ለአብ፡ ዘአፈጸመነ፡ በአቅም፨</l>
                  <l n="2">ድርሳነ፡ መልክእኡ፡ ለኄር፡ ወልደ፡ ሩፋኤል፡ ቃውም፨</l>
                  <l n="3">ወስብሐት፡ ለወልድ፡ መድኃኔ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="4">ወስብሐት፡ ልወሕይወቶሙ፡ ዘምስለ፡ ማርያም፡ እም፨</l>
                  <l n="5">ለመስቀልኒ፡ በሰጊድ፡ ሰላም፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ስብሐት፡ ለእግዚአብሔር፡ መኅዳኔ፡ ዓዸም፡ ኵላ፨</l>
                  <l n="2">ለሰንበተ፡ ክርስቲያን፡ እንተ፡ አልዐላ፨</l>
                  <l n="3">ወልደ፡ ሩፋኤል፡ መሲሕ፡ ዘበርእስከ፡ ቀጸላ፨</l>
                  <l n="4">አዝዝ፡ ለነ፡ እግዚኦ፡ በቃለ፡ ጽኑዕ፡ መሐላ፨</l>
                  <l n="5">ዘከማከ፡ ይከውነነ፡ ሕፃነከ፡ ተድላ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ወልደ፡ ሩፋኤል፡ ወይን፨</l>
                  <l n="2">እንተ፡ ሤሙከ፡ በቀርን፨</l>
                  <l n="3">መገብተ፡ ኵሉ፡ ፍጥረት፡ ሥላሴ፡ ኄራን፨</l>
                  <l n="4">ታጸግብ፡ ዘልፈ፡ ከርሠ፡ ነዳያን፡ ወታረዊ፡ ለጽሙኣን፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለከ፡ ወልደ፡ ሩፋኤል፡ መጽሐፍ፨</l>
                  <l n="2">ዘከሠቱከ፡ አእላፍ፨</l>
                  <l n="3">ወዘአንበቡከ፡ በልሳን፡ ወአፍ፨</l>
                  <l n="4">እንዘ፡ ይብሉ፡ ቀታሌ፡ እልፍ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለከ፡ ወልደ፡ ሩፋኤል፡ ዳግመ፡ ለቤተ፡ ክርስቲያን፡ ሰአላ፨</l>
                  <l n="2">እንዘ፡ ታክብራ፡ ወታሌዕላ፨</l>
                  <l n="3">ከመ፡ ቀዳሚሃ፡ በጥንተ፡ አካላ፨</l>
                  <l n="4">ወግበር፡ ዲበ፡ ርእሳ፡ እንተ፡ ወርቅ፡ ቀጸላ፨</l>
               </lg>
            </div>
         </div>
      </body>

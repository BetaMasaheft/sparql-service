               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="40v"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2230Saatat">ጸሎታተ፡
                      ሰዓታት፡ ዘመዓልት፡ ወሌሊት፡
                </title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አሐዱ፡ አምላክ፡ ንወጥን፡ በረድኤተ፡
                     እግዚአብሔር፡ ሎቱ፡ ስብሐት፡ በእንተ፡ ጽሒፈ፡ ጸሎታት፡ ዘመዐልት፡ ወሌሊት፡ </incipit>
                     <msItem xml:id="ms_i1.1">
                        <locus from="2r" to="11r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3125Saatat">ነግህ</title>
                        <note>Prayers of the first hour.</note>
                        <incipit xml:lang="gez">ወትብል፡ ዘንተ፡ ጸሎተ፡ ጊዜ፡ ነግህ፡</incipit>
                         </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="11r" to="12v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3126Prayer">Ṣalot ba-3 saʿāt</title>
                        <note>Prayers of the third hour.</note>
                        <incipit xml:lang="gez"> በስመ፡ ሥሉስ፡ ቅዱስ፡ ጸሎት፡ በ፫ሰዓት፡ ወትብል፡ አቡነ፡ ዘበ፡ ሰማያት። </incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="13r" to="15r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3127Prayer">Ṣalot ba-6 saʿāt</title>
                        <note>Prayers of the sixth hour.</note>
                        <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ ቅዱስ፡ ጸሎት፡ በ፮ሰዓት፡ ወትብል፡ አቡነ፡ ዘበሰማያት።</incipit>
                                         </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="15v" to="17v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3128Prayer">Ṣalot ba-9 saʿāt</title>
                        <note>Prayers of the ninth hour.</note>
                        <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ውዱስ፡ ጸሎት፡ በ፱፡ ሰዓት፡ ወትብል፡ አቡነ፡ ዘበሰማያት።</incipit>

                           </msItem>

                     <msItem xml:id="ms_i1.5">
                        <locus from="17v" to="20v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3129Prayer">Ṣalot ba-12 saʿāt ba-gize sark</title>
                        <note>Evening prayers.</note>
                        <incipit xml:lang="gez"> በስመ፡ ሥሉስ፡ ቅዱስ፡ ጸሎት፡ በሰርክ፡ ወትብል፡ አቡነ፡ ዘበሰማያት፡</incipit>
                            </msItem>

                     <msItem xml:id="ms_i1.6">
                        <locus from="21r" to="24v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3130Prayer">Ṣalot ba-3 saʿāta lelit ba-gize nǝwām</title>
                        <note>The great evening prayers.</note>
                        <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ ጸሎት፡ በጊዜ፡ ንዋም፡ ወትብል፡ አቡነ፡ ዘበሰማያት፡</incipit>

                     </msItem>

                     <msItem xml:id="ms_i1.7">
                        <locus from="25r" to="40r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3131Prayer">Ṣalot za-manfaqe lelit</title>
                        <note>Noctural service.</note>
                        <incipit xml:lang="gez"> በስመ፡ ሥሉስ፡ ቅዱስ፡ ጸሎት፡ በመንፈቀ፡ ሌሊት፡ ወትብል፡ አቡነ፡ ዘበሰማያት፡</incipit>

                     </msItem>
                  </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="41r" to="43v"/>
                      <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3307Hymn">Hymns to Jesus Christ</title>
                      <note>Chants praising the Saviour for the first three days of the week starting from Sunday,
                        to be read before
                        Wǝddāse Māryām.</note>
                        <incipit xml:lang="gez">  ዘምሮ፡ ዘእግዚእነ፡ ወመድኃኒነል ኢየሱስ፡ ክርስቶስ፡ ዘይትነበብ፡ በእኁድ፡
                          ቅድመ፡ ውዳሴ፡ ማርያም።</incipit>

                    </msItem>



                     <msItem xml:id="ms_i3">
                        <locus from="44r" to="66r"/>
                      <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5639WeddaseMaryamTergwame">Wǝddāse Māryām</title>
                      <note>A peculiar version of Wǝddāse Māryām with chants and commentaries.</note>
                      <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አሐዱ፡ አምላክ። ውዳሴሃ፡ ለማርያም፡
                      ዘይትነበብ፡ በሰንበተ፡ ክርስቲያን፡ ጸሎታ፡ የሃሉ፡ ምስሌነ፡ አሜን።</incipit>
                        </msItem>

                    </msContents>



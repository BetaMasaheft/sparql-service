                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="2r"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2598Yosipp">መጽሐፈ፡ ሥርው፡</title>
                            <textLang mainLang="gez"/>

                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ዋሕደ፡ ለሊሁ፡ ዘሥሉስ፡ በግጻዌሁ። ንወጥን፡ ተፀዊነነ፡ በኃይሉ፡
                              በጽሒፈ፡ ዜና፡ አይሁድ፡ ውስተ፡ ቤተ፡
                                መቅደስ፡ ዘይዘወ<choice><orig>ግ</orig><corr>ጎ</corr></choice>፡ ለዮሴፍ፡ ወልደ፡ ኮርዮን።
                                ወዝክረ፡ ዜናሆሙ፡ ወዜና፡ ነገሥቶሙ፡ ወዘኮነ፡ በመዋዕሊሆሙ፡ እምአሜ፡ ሕንጸተ፡ ቤት፡ ወግብአቶሙ፡ ኀቤሁ፡ እስከ፡
                                ተነሥተ፡ ወተፄወው፡ እምኔሁ።
                                ወናሁ፡ አስተጋብአ፡ ኵሎ፡ መጻሕፍተ፡ በ፰፡ ክፍል። እስመ፡ በዐለ፡ መጽሐፍ፡ ዝኮነ፡ ይጽሕፍ፡ ዜና፡ በጊዜ፡ ኩነታ፡
                                 ዘመነ፡ እምድኅረ፡ ዘመን፡ እስከ፡ ማኅለቅተ፡ ነገር፡ ወበእግዚአብሔር፡ ስንእ።
                            </incipit>

                        <msItem xml:id="ms_i1.1">
                            <locus from="2r" to="22r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl1">Josippon: ክፍል፡ ቀዳማዊ።Kǝfl 1, starting with Adam and mainly treating Persian history.</title>
                            <textLang mainLang="gez"/>

                            <msItem xml:id="ms_i1.1.1">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section1">Josippon: section: Section1</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.2">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section2">Josippon: </title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.3">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section3">Josippon: </title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.4">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section4">Josippon: </title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.5">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section5">Josippon: section: Section5</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.6">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section6">Josippon: section: Section6</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.7">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section7">Josippon: section: Section7</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.8">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section8">Josippon: section: Section8</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.1.9">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Section9">Josippon: section: Section9</title>
                              <textLang mainLang="gez"/>
                            </msItem>

                            <explicit xml:lang="gez" type="subscriptio"><locus target="#22r"/>
                            ተፈጸመ፡ ክፍል፡ ቀዳማዊ፡ እመጽሐፈ፡ ሥርው፡ ወንወጥን፡ ክፍለ፡ ዳግማየ፡ ወበእግዚአብሔር፡ ስንእ።</explicit>
                            <note>The first part brings the history of the Jews down to the death of
                            <persName ref="https://betamasaheft.eu/PRS1666Alexande">Alexander</persName> and the translation of the Old
                          Testament into Greek by the order of king <persName ref="https://betamasaheft.eu/PRS7984Ptolemy">Ptolemy</persName>.</note>
                          <note>The division into the first and second chapters in this manuscript differs from
                          that in <bibl corresp="http://zotero.org/groups/358366/items/3KAZECS2"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Murad1938ZenaAyhud"/><title level="m">Des Josef ben Gorion (Josippon) Geschichte der Juden ዜና፡ አይሁድ። (Zenā ʾAyhud) nach den Handschriften in Berlin, London, Oxford, Paris und Strassburg</title><author><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Murad Kamil</t:name></author><pubPlace>New York</pubPlace><publisher>J. J. Augustin Publisher</publisher><date>1938</date></bibl>.</note>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                           <locus from="22r" to="43r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl2">Josippon: Kǝfl 2</title>
                              <textLang mainLang="gez"/>
                              <note>The second chapter begins with king Antiochus
                                  and ends with the reign of <persName ref="https://betamasaheft.eu/PRS13236AlexanderJ">Alexander</persName>, the
                                  son of <persName ref="https://betamasaheft.eu/PRS13237JohnHyrcanus">Hyrcanus</persName></note>
                              </msItem>

                        <msItem xml:id="ms_i1.3">
                            <locus from="43r" to="63r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl3">Josippon: Kǝfl 3</title>
                            <textLang mainLang="gez"/>
                            <note>The third chapter continues the history of
                              <persName ref="https://betamasaheft.eu/PRS13236AlexanderJ">Alexander Hyrcani</persName>
                                and concludes with the rebellion of
                                <persName ref="https://betamasaheft.eu/PRS13239Antigonus">Antigonus</persName> the son of
                                <persName ref="https://betamasaheft.eu/PRS13238Aristoboulos">Aristobulus</persName>.</note>
                        </msItem>
                        <msItem xml:id="ms_i1.4">
                            <locus from="63r" to="83v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl4">Josippon: Kǝfl 4</title>
                            <textLang mainLang="gez"/>
                            <note>The fourth chapter brings the narrative down to the plot of
                              <persName ref="https://betamasaheft.eu/PRS13240Antipater">Antipater</persName>, the son of
                              <persName ref="https://betamasaheft.eu/PRS5299Herod">Herod</persName>, against his father.</note>
                        </msItem>

                        <msItem xml:id="ms_i1.5">
                            <locus from="83v" to="88v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl5">Josippon: Kǝfl 5</title>
                            <textLang mainLang="gez"/>
                            <note>The fifth chapter finishes the history of
                            <persName ref="https://betamasaheft.eu/PRS13240Antipater">Antipater</persName>, and narrates
                            the death of <persName ref="https://betamasaheft.eu/PRS5299Herod">Herod</persName>.</note>
                        </msItem>

                        <msItem xml:id="ms_i1.6">
                            <locus from="88v" to="103v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl6">Josippon: Kǝfl 6</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ዜናሁ፡ ለዮካናን፡ ገሊላዊ፡ ወውእቱ፡ ዳግም፡ እምእለ፡ ያርብኅ፡
                            እለ፡ ኮኑ፡ ምክንያተ፡ ለንስተተ፡ መቅደስ፡ ወድምሳሴ፡ ሕዝብ፡ በዘ፡ ገብርዎ፡ በሮም።</incipit>
                            <note>The sixth chapter begins with <persName ref="https://betamasaheft.eu/PRS13241Archelaus">Archelaus</persName>,
                              the son of <persName ref="https://betamasaheft.eu/PRS5299Herod">Herod</persName>,
                              and ends with John the Galilean</note>
                              <msItem xml:id="ms_i1.6.1">
                                <locus from="90r"/>
                                <title type="complete" xml:lang="en">Unit regarding
                                  <persName ref="https://betamasaheft.eu/PRS5741Johnthe">St John the Baptist</persName>.</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ወዓዲ፡ ቀተሎ፡ ለዮሐኖን፡ ወልደ፡ ዘካርያስ፡ ካህን፡ እስመ፡ ውእቱ፡
                                ዘለፎ፡ እንዘ፡ ይብል፡ ኢይደልወከ፡ ትንሣእ፡ ብእሲተ፡ እኁከ፡ እንዘ፡ ሀሎ፡ ሕያወ፡ ወወለደ፡ እምኔሃ፡
                              ክልኤ፡ ውሉደ፡ ወዮሐኖንሰዝ፡ ውእቱ፡ ዘይሰመይ፡ ይሕያ፡ ወልደ፡ ዝካርያ፡ ወበዘመነ፡ አንጥፊስ፡ ወልደ፡
                            ሄሮድስ፡ ሞተ፡ አውግስጦስ፡ ቄሳር፡ ወነግሠ፡ ጤባርዮስ፡ ቄሳር፡ ወኮነ፡ ብእሴ፡ እኩየ፡ ምግባር፡</incipit>
                              </msItem>
                        </msItem>
                        <msItem xml:id="ms_i1.7">
                            <locus from="103v" to="122v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl7">Josippon: Kǝfl 7</title>
                            <textLang mainLang="gez"/>
                            <note>The seventh chapter narrates the events of the siege
                              of <placeName ref="https://betamasaheft.eu/LOC3957Jerusa">Jerusalem</placeName> by
                              <persName ref="https://betamasaheft.eu/PRS9533Titus">Titus</persName>.</note>
                        </msItem>
                        <msItem xml:id="ms_i1.8">
                            <locus from="122v" to="136r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl8">Josippon: Kǝfl 8</title>
                            <textLang mainLang="gez"/>
                            <note>The eighth chapter brings the history of the siege to its close.</note>


                        </msItem>
                        <msItem xml:id="ms_i1.9">
                          <locus target="#136r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Colophon">Josippon: colophon: Colophon</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ተፈጸመ፡ መጽሐፈ፡ ዮሴፍ፡ ወልደ፡ ኮርዩን፡ ካህን፡ ዘያየድዕ፡ ዜና፡ አይሁድ፡ ውስተ፡
                            ቤት፡ ዳግማዊ፡ ወዝክረ፡ ነገሥቶሙ፡ ወነገርኒ፡ ዘኮነ፡ በመዋዕሊሆሙ፡ እምአሜ፡ ሕንፀተ፡
                            ቤት፡ ዳግማዊ፡ ወግብአቶሙ፡ ኀቤሁ፡ እስከ፡ ተነሥተ፡ ወተፄወዉ፡ እምኔሁ። ስብሐት፡ ወአኰቴት፡
                          </incipit>
                        </msItem>
                        </msItem>


      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ተወጥነ፡ ለመልክእኪ፡ ውዳሴሁ፨</l>
                  <l n="2">እንዘ፡ ይረድአኒ፡ ክርስቶስ፡ ዘዋሕድ፡ ህላዌሁ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ቅድስት፡ ለኂሩት፡ ማኅደረ፡ ጸርሑ፨</l>
                  <l n="4">ትውልደ፡ ትውልድ፡ ያስተበፅዑኪ፡ ናሁ፨</l>
                  <l n="5">በቃለ፡ አሚን፡ ርቱዕ፡ ወሐዋዝ፡ ዜማሁ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ በልሳነ፡ ኵሉ፡ ዘተሥዕለ፨</l>
                  <l n="2">ወለሥዕርትኪ፡ ካዕበ፡ ዘአክሊለ፡ ክርስቶስ፡ ተቀጸለ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ እምነ፡ ይስእሉኪ፡ ስኢለ፨</l>
                  <l n="4">ደቂቅኪ፡ በሃይማኖት፡ ኀበ፡ ረሰዩ፡ መድበለ፨</l>
                  <l n="5">እምጸጋ፡ ዚአኪ፡ ትፈንዊ፡ ሣህለ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለመቃብርኪ፡ ኀበ፡ እዴኪ፡ ዘሐነጻ፨</l>
                  <l n="2">በደሴተ፡ ሰላሞ፡ ሬማ፡ እንተ፡ ትጸልእ፡ ግብረ፡ ዐመፃ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ርስትየ፡ ዘነሣእክዋ፡ በዕፃ፨</l>
                  <l n="4">ከመ፡ ይኩነኒ፡ በቋዔ፡ ቱሱሐ፡ ርኅራኄ፡ ተግሣጻ፨</l>
                  <l n="5">ወጊዜ፡ ጽምዕየ፡ ከመ፡ ማየ፡ ያርውየኒ፡ ገጻ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ናስተበፅዓ፡ ለማርያም፡ እስመ፡ ከፈለተኒ፡ ቃለ፨</l>
                  <l n="2">ከመ፡ እወድስኪ፡ ቦቱ፡ ወእስእለኪ፡ ስኢለ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ገድልኪ፡ እምገድለ፡ ቅዱሳን፡ ተልዕለ፨</l>
                  <l n="4">ሲሳይኪ፡ ሐመደ፡ እክል፡ እንዘ፡ ትሜንኒ፡ እክለ፨</l>
                  <l n="5">እስከ፡ በዝንቱ፡ አጥረይኪ፡ ምሕረተ፡ ወሣህለ፨</l>
               </lg>
            </div>
         </div>
      </body>

                                 <dim unit="leaf">10</dim>
                                 <locus from="40" to="49" facs="042">Fols 40–49</locus>
                              Quire 5
                            </item>
                              <item xml:id="q7" n="6">
                                 <dim unit="leaf">10</dim>
                                 <locus from="50" to="59" facs="050">Fols 50–59</locus>

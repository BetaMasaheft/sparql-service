                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                        <desc>
                        Crude drawing of human-like figure
                        </desc>
                        </decoNote>
                      <decoNote type="miniature" xml:id="d2">
                        <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                        <desc>
                          Crude drawing of human and flower/<term key="cross" ana="#cross"/>
                          </desc>
                        </decoNote>
                      <decoNote type="miniature" xml:id="d3">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc>
                          Crude drawing of faces peering from behind long slim items
                          </desc>
                          </decoNote>
                      <decoNote type="miniature" xml:id="d4">
                        <locus target="#79v" facs="081">Fol. 79v</locus>
                        <desc>
                          Crude drawing of face peering from behind a small horse-like animal
                          </desc>
                          </decoNote>
                      <decoNote type="miniature" xml:id="d5">
                        <locus target="#80v" facs="082">Fol. 80v</locus>
                        <desc>
                          Crude drawing of face peering from behind a small animal
                          </desc>
                          </decoNote>
                          <decoNote type="frame" xml:id="d6">
                            <desc>
                            Decorative designs: <locus target="#79v" facs="082">fols. 79v, </locus> (dotted line using alternating black and red);
                            <locus target="#38v #79v" facs="041 082">38v, 79v</locus> (line of full-stop symbols)
                            </desc>
                          </decoNote>

                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                          <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>Asmat prayer against thieves and robbers, <foreign xml:lang="am">ሌባ፡ ወቀማኛ፡</foreign>, insufficiently legible
                           <desc type="Asmat">
                        </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#38v #39r" facs="041 041">Fols. 38v, 39r</locus> List of the Archangel Michael’s twelve feast days of the year, with the reasons for their celebrations
                           <desc>
                        </desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#39r #39v" facs="041 042">Fols. 39r, 39v</locus> Reward, in quantity of fruits, for praying certain prayers, e.g. The Our Father, and for performing certain good deeds
                           <desc>
                        </desc>
                        </item>
                        <item xml:id="a4">
                          <locus target="#39v" facs="042">Fol. 39v</locus> Greeting letter, in Amharic in a crude hand in pencil
                           <desc>
                        </desc>
                        </item>
                        <item xml:id="a5">
                          <locus target="#79r" facs="081">Fol. 79r</locus>
                        <desc type="PurchaseNote">Record of purchase of the manuscript, <date calendar="ethiopian" when="1940" when-custom="1948" evidence="internal">፲፱፻፵፡ ዓመተ፡ ምሕረት፡ መጋቢት፡ ፪ቀን፡</date> (March 11, 1948 CE)</desc>
                        </item>
                        <item xml:id="a6">
                          <locus target="#ir(ecto) #iiv(erso) #80v" facs="001 003 083">Fols. ir(ecto), iiv(erso), 80v</locus> The Gǝ‘ǝz version of “In the name of the Father and the Son and the Holy Spirit,” in a crude hand
                           <desc>
                        </desc>
                        </item>
                        <item xml:id="a7">
                          <locus target="#11v #24r #32v #36v #38r" facs="014 026 035 039 040">Fols. 11v, 24r, 32v, 36v, 38r</locus>)
                           <desc>Overlooked lines of text have been added interlinearly</desc>
                           <locus target="#21r #25v #33r #59v #68r" facs="023 028 035 062 070">21r, 25v, 33r, 59v, 68r</locus>)
                           <desc>
                        and with text written in the upper margin and a symbol (┴) to indicate where the text should be inserted
                      </desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#80r" facs="082">Fol. 80r</locus>
                           <desc>
                              Scrawls and addition of the number of folios of the two parts, 38+42=80, in pencil
                        </desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Four repaired Coptic chain stitches attached with bridle attachments to repaired rough-hewn boards (segment of back board missing).</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

                  <decoDesc>
                    <decoNote xml:id="d1" type="drawing">
                      <locus target="#1r"/>
                      <desc>Drawing of two <term key="cross" ana="#cross">crosses</term>
                    enframed by a geometric pattern. The drawing is executed in black, red,
                  yellow and blue colors.</desc>
                    </decoNote>
                    <decoNote xml:id="d2" type="drawing">
                      <locus target="#1r"/>
                      <desc>
                        Drawing of two <term key="angel" ana="#angel">angels</term> separated by a frame. The wings of the
                        <term key="angel" ana="#angel">angels</term> are done in a sketchy way. Three traditional
                        houses or churches are depicted above their heads. The drawing is executed in black, red,
                      yellow and blue colors. According to <bibl corresp="http://zotero.org/groups/358366/items/TZGTZS6C"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Chernetsov1975Svitki"/><title level="a">Opisanie ėfiopskix rukopisnyx amuletov ("magičeskix svitkov") iz sobranija MAĖ</title><title level="m">Iz kulturnogo nasledija narodov Ameriki i Afriki</title><title level="s">Sbornik MAĖ</title><author><forename>Sevir</forename><surname>Černecov</surname></author><editor><forename>D.</forename><surname>Ol'derogge</surname></editor><editor><forename>R.</forename><surname>Kinžalov</surname></editor><pubPlace>Leningrad</pubPlace><publisher>Nauka</publisher><date>1975</date><series><title level="s">Sbornik MAĖ</title></series><biblScope unit="volume">31</biblScope><biblScope unit="page">208-226</biblScope><note type="tags"><note type="tag">bm:Chernetsov1975Svitki</note></note><note type="tag">bm:Chernetsov1975Svitki</note><citedRange unit="page">224-225</citedRange></bibl> the <term key="angel" ana="#angel">angles</term> are depicted to have legs instead of arms.
                      </desc>
                    </decoNote>
                    <decoNote xml:id="d3" type="drawing">
                      <locus target="#1r"/>
                      <desc>
                        Two depictions of the the <persName ref="https://betamasaheft.eu/PRS11330Devil">devil</persName>'s face separated by a geometric frame. The drawing is executed in black, red,
                      yellow and blue colors.
                      </desc>
                    </decoNote>
                    <decoNote xml:id="d4" type="frame">
                      <locus target="#1r"/>
                      <desc>
                        The text is enframed by a yellow frame.
                      </desc>
                    </decoNote>
                  </decoDesc>

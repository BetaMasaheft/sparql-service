                        </msItem>
                        <msItem xml:id="ms_i1.4">
                          <locus from="16r" to="22r"/>
                          <title type="complete">Third section</title>
                          <textLang mainLang="gez"/>
                          <note>The text contains the second part of the third section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">68 l. 10-71 l. 3</citedRange></bibl>.</note>  
                        </msItem>
                        <msItem xml:id="ms_i1.5">
                          <locus from="22v" to="25r"/>
                          <title type="complete">First prayer for the heavenly journey, entitled ጸሎት፡ በእንተ፡ መንገደ፡ ሰማይ፡</title>
                          <textLang mainLang="gez"/>
                          <note>The text contains the last part of the third section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">71 l. 8-72 l. 7</citedRange></bibl>.</note>  
                        </msItem>
                        <msItem xml:id="ms_i1.6">
                          <locus from="25v" to="27v"/>
                          <title type="complete">Second prayer, entitled ጸሎት፡ በእንተ፡ መንገደ፡ ሰማይ፡</title>
                          <textLang mainLang="gez"/>
                          <note> The text contains the second part of the fourth section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">74 l. 6-75 l. 5</citedRange></bibl>.</note>  
                        </msItem>
                        <msItem xml:id="ms_i1.7">
                          <locus from="27v" to="28v"/>
                          <title type="complete">Third prayer, entitled ጸሎት፡ በእንተ፡ መንገደ፡ ሰማይ፡</title>
                          <textLang mainLang="gez"/>
                          <note>The text contains part of the fifth section of E.A.W. Budge's edition, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">77 ll. 26-33</citedRange></bibl>.</note>  
                        </msItem>
                        <msItem xml:id="ms_i1.8">
                          <locus from="28v" to="30r"/>
                          <title type="complete">Fourth prayer</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ዘመንገደ፡ ሰማይ፡ እቀበኒ፡ ክርስቶስ፡ ከመ፡ ኢ<add place="above">ያ</add>እቅፍዋ፡
                            <choice><sic>ነብፍየ</sic><corr resp="bm:GrebTiss1935Codices">ነፍስየ፡</corr></choice> መላእክተ፡ ጽልመት፡
                            <choice><sic>ለሐዳሳት፡</sic><corr resp="bm:GrebTiss1935Codices">በሐዳሳት፡</corr></choice> ምኵራብ፡ አመ<supplied reason="omitted">፡</supplied>
                            ይነግሥ<supplied reason="omitted">፡</supplied> ሎሙ<supplied reason="omitted">፡</supplied> ክቡር፡ ንጉሥ፡ በይእቲ፡ ዕለት፡ መሐረኒ፡
                            </incipit>
                          <explicit xml:lang="gez">
                            ወኢያእምርዋ፡ መላእክት፡ ጸዋጋን፡ ወኢ<supplied reason="omitted">ይ</supplied>ነጽርዋ፡ በመዓት፡ ዕቀብ፡ ዘንተ፡ ቃለ፡ ከመ፡ ይእቀብከ<supplied reason="omitted">፡</supplied>
                            እግዚአብሔር፡ እ<supplied reason="omitted">ም</supplied>ኵሉ፡ እኩይ<supplied reason="omitted">፡</supplied> በደኃሪ፡ መዋ<supplied reason="omitted">ዕ</supplied>ል<supplied reason="omitted">፡</supplied>
                            ወከማሁ፡ ወኃረኒ፡ <choice><sic>ወተሠሐለኒ፡</sic><corr resp="bm:GrebTiss1935Codices">ወተሣሐለኒ፡</corr></choice> ለ<add resp="#h2">አመትከ፡ 
                              ወለተ፡ ሕይወት፡</add>
                          </explicit>
                          <note>The name of <persName role="owner" ref="https://betamasaheft.eu/PRS14664WalattaHe">Walatta Ḥǝywat</persName>, presumably an owner, has been added in a secondary hand 
                            in the concluding supplication formula.                          
                          </note>
                        </msItem>
                        <msItem xml:id="ms_i1.9">
                          <locus from="30r" to="31r"/>
                          <title type="complete">Fifth prayer</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ <supplied reason="omitted">፡</supplied>መንገደ<supplied reason="omitted">፡</supplied> 
                            ሰማይ፡ <sic>አስማት<supplied reason="omitted">፡</supplied></sic> መስቀሉ<supplied reason="omitted">፡</supplied> ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ እበሳየ፡ 
                            እናሕሲ፡ ወ<supplied reason="omitted">ኀ</supplied>ጢአትየ፡ አስተስሪ፡
                          </incipit>
                          <explicit xml:lang="gez">
                            እስመ፡ እንተ፡ ቀዳማዊ፡ ወአነ<supplied reason="omitted">፡</supplied> ደኃራዊ፡ ኢታርእየኒ፡ እሳተ፡ ገሃነም፡ ዘበልአ<supplied reason="omitted">፡</supplied> 
                            ሥጋየ፡ ወሰትየ፡ ደምየ፡ የሐዩ፡ ዘለዓለም፡ ሕይወተ፡ ሥጋከ። ወ<add resp="#h2" place="below">ለአመትከ፡ ወለተ<supplied reason="omitted">፡</supplied> 
                              <del rend="effaced">ሕይወት፡</del> <choice><sic>መርያም፡</sic><corr resp="bm:GrebTiss1935Codices">ማርያም፡</corr></choice></add>
                          </explicit>
                          <note>A later hand added the name of <persName role="owner" ref="https://betamasaheft.eu/PRS14665WalattaMa">Walatta Māryām</persName> in the concluding supplication formula, 
                            and indicated her as "your servant". 
                            The name of the previous owner <persName role="owner" ref="https://betamasaheft.eu/PRS14664WalattaHe">Walatta Ḥǝywat</persName> is still legible in the same supplication, after being washed out.
                          </note>
                        </msItem>
                        <msItem xml:id="ms_i1.10">
                          <locus from="31r" to="35r"/>

                      <msItem xml:id="ms_i1">
                        <locus from="3r" to="36r"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                        <msItem xml:id="ms_i1.1">
                          <locus from="3r" to="9r"/>
                          <title type="complete">Prologue</title>
                          <note>The prologue is longer than that in <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">61</citedRange></bibl>.</note>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ንዌጥን፡ በረድኤተ<supplied reason="omitted">፡</supplied> እግዚአብሔር፡ 
                            መጽሐፈ፡ ሕይወት፡ ወመድኃኒት፡ ልፋፈ<supplied reason="omitted">፡</supplied> ጽድቅ፡ ዘጸኃፋ፡ አብ፡ በእዴሁ፡ ወወኃባ፡ ለማርያም፡ 
                            ዘነበረት<supplied reason="omitted">፡</supplied> እምቅድመ፡ ሰማይ<supplied reason="omitted">፡</supplied> ወምድር፡ ወእምቅድመ፡ ይትፈጠሩ፡ መላእክት፡
                          </incipit>
                          <explicit xml:lang="gez">
                            ፫ አስማት፡ ወ፩ መንግሥት፡ ፩ ባሕርይ፡ ወ፩ ፈቃድ፡ ወበእንተዝ፤ ንበል፨ መላእክት፡ ወሰብዕ<supplied reason="omitted">፡</supplied> ፩ አምላክ፡ ፩ 
                            እግዚ<supplied reason="omitted">አ</supplied>ብሔር፡ ለአለመ፡ አለም፡ አሜን፡ ንግባእኬ፡ ኃበ፡ ጥ<supplied reason="omitted">ን</supplied>ተ<supplied reason="omitted">፡</supplied>
                            ነገር፡ ዛቲ፡ መጽሐፍ<supplied reason="omitted">፡</supplied> ዘታበውእ፤ ውስተ<supplied reason="omitted">፡</supplied> ፀባብ፡ አንቀጽ፡ ውስተ፤ ህይወት፨ 
                            ወትወስድ፤ ውስተ<supplied reason="omitted">፡</supplied> መንግሥተ፤ ሰማያት፤ መርኅ፤ ለፃድቃን፤ ወዘንተ፤ ነገራ፡ ክርስቶስ፡ ለማርያም፡ እምድሕረ <supplied reason="omitted">፡</supplied>
                            <choice><sic>ተወልድ፤</sic><corr resp="bm:GrebTiss1935Codices">ተወልደ፤</corr></choice> 
                          </explicit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus from="7r" to="13v"/>
                          <title type="complete">First section</title>
                          <textLang mainLang="gez"/>
                          <note>It contains the first section according to the shorter recension, corresponding to <bibl corresp="http://zotero.org/groups/358366/items/NS8WNSR6"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1929"/><title level="m">The Bandlet of Righteousness, an Ethiopian Book of the Dead: The Ethiopic Text of the ልፋፈ፡ ጽድቅ፡ in Facsimile from Two Manuscripts in the British Museum</title><title level="s">Luzac’s Semitic Text &amp; Translation Series</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ernest Alfred Wallis</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Budge</t:surname></author><pubPlace>London</pubPlace><publisher>Luzac &amp; Company</publisher><date>1929</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Luzac’s Semitic Text &amp; Translation Series</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">19</t:biblScope></series><biblScope unit="volume">19</biblScope><citedRange unit="page">61 l. 15-63 l. 6</citedRange></bibl>.</note>  
                        </msItem>

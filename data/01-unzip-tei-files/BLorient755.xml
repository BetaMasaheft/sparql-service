                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">

                            <title type="complete" ref="https://betamasaheft.eu/LIT1948Mashaf">Maṣḥafa Mār Yǝṣhāq</title>
                            <textLang mainLang="gez"/>
                            <colophon xml:id="coloph1" xml:lang="gez"><locus target="#56r"/>
                          ተፈጸመ፡ በዝየ፡ መጽሐፈ፡ ማሪ፡ ይስሐቅ፡ ዘይምዕዶሙ፡ ለመነኮሳት፡ ከመ፡ ያምስጡ፡ ቦቱ፡ እምኃጢአተ፡
                        ጸላኢ፡ ወይመንንዎ፡ ለዝንቱ፡ ዓለም፡ ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ ኃጥእ፡
                        <persName ref="https://betamasaheft.eu/PRS12647WaldaAmlak">ወልደ፡ አምላክ፡</persName> ለዓለመ፡
                      ዓለም፡ አሜን።</colophon>
                        </msItem>

                    </msContents>

                    <physDesc>
                        <objectDesc form="Codex">
                            <supportDesc>
                                <support>
                                    <material key="parchment"/>
                                </support>
                                <extent>
                                    <measure unit="leaf">56</measure>

                                    <dimensions type="outer" unit="in">
                                        <height>11</height>
                                        <width>9.875</width>
                                    </dimensions>
                                </extent>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="2" writtenLines="32">
                                </layout>
                            </layoutDesc>

                        </objectDesc>

                        <handDesc>

                            <handNote script="Ethiopic" xml:id="h1">
                                <desc>The manuscript is written in a fair hand.
                                </desc>
                                <date notBefore="1700" notAfter="1800" resp="PRS10171Wright">Of the 18th century</date>
                            </handNote>

                        </handDesc>
                        <additions>
                            <list>
                              <item xml:id="a1">
                                  <locus target="#1r"/>
                                  <desc type="GuestText">A short notice of <persName ref="https://betamasaheft.eu/PRS5581Isaacof">Isaac of Nineveh</persName> in Amharic,
                                  inaccurately written by a later hand.</desc>
                                  <q xml:lang="am"><seg part="I">የ<persName ref="https://betamasaheft.eu/PRS5581Isaacof"><roleName type="title">ማር፡</roleName>
                                  ይስሐቅ፡</persName> ሀገረ፡ ሙላዱ፡ ብሔረ፡ ነገዱ፡
                                      <placeName ref="https://betamasaheft.eu/LOC5833Syria">ሶርያ፡</placeName> ነው።</seg></q>
                              </item>
                                <item xml:id="a2">
                                    <locus target="#2r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ማር፡ ይስሐቅ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">መድኃኔ፡ ዓለም።</placeName>
                           </q>
                                </item>
                              <item xml:id="a3">
                                <locus target="#56r"/>
                                <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT5833ReadingGospel">On the Reading of the Gospels</title></desc>
                                <q xml:lang="gez"><seg part="I">በስመ፡ አብ፡ <gap reason="ellipsis" resp="PRS10171Wright"/>
                              ይቤሉ፡ አበዊነ፡ ቅዱሳን፡ ዘአርአዮሙ፡ ኅቡአቲሁ፡ አግዚአብሔር፡ አምላኮሙ፡ ከመዝ፡ ውእቱ፡ ፍሬሁ፡ ለ፩ ዳዊት፡ ፺፻፻ ወ ፰፻ ፍሬሁ፡
                            አመ፡ ይዜምሩ፡ በአንብዕ፡ ወበፈሪሃ፡ እግዚአብሔር፡ ወበሠናይ፡ መልእክት፡ ወዘይጼሊ፡ በቤተ፡ ክርስቲያን፡ ዘእንበለ፡ ነጐርጓር፡ ፳፻፼ወ፲፻
                          ፍሬሁ፡ በምሥራቅ፡ ወበምዕራብ፡ በሰሜን፡ ወበደቡብ፡ በበ፩፡</seg></q>
                              </item>
                              <item xml:id="a4">
                                <locus target="#56v"/>
                                <desc type="GuestText"><title type="incomplete" ref="https://betamasaheft.eu/LIT5020Hemamatihu">Ḥǝmāmātihu la-ʾǝgziʾǝna ʾIyasus Krǝstos</title></desc>
                                <q xml:lang="gez"><seg part="I">በስመ፡ አብ፡ <gap reason="ellipsis" resp="PRS10171Wright"/>
                              ዝንቱ፡ ውእቱ፡ ሕማማቲሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ መድኃኔ፡ ዓለም፡ ዘለሊሁ፡ ከሠተ፡ ሎን፡ ለሠላስ፡ ቅዱሳት፡ አንስት፡ እለ፡
                            ይሰመያ፡ ቅድስት፡ <sic resp="PRS10171Wright">መግላዊት፡</sic> ወቅድስት፡ ሰሎሜ፡ ወቅድስት፡ ኤልሳቤጥ፡</seg></q>
                              </item>

                            </list>

                        </additions>

                    </physDesc>

                    <history>
                        <origin>

                            <origDate notBefore="1700" notAfter="1800" evidence="lettering"/>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area,
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.</provenance>

                    </history>


               <msContents>
                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="26v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172"><foreign xml:lang="gez">Malkǝʾa
                        <persName ref="https://betamasaheft.eu/PRS6819Mary">Māryām</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 63 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#4r"/>
                        <pb n="4r"/>
                        <hi rend="rubric">ሰላም፡ ሰላም</hi>፡ ለዝክረ፡ ስምኪ፡ ሐዋዝ፡ እምነ፡ ከል<choice>
                           <sic>ቤ</sic>
                           <corr resp="SH">በ</corr>
                        </choice>ኔ፡ ወቍስጥ፡ ወእምነ፡ ሰንበልት፡ ምዑዝ፡ <hi rend="rubric">ማርያም</hi>፡ ድንግል፡ ባሲተ፡
                        ዓቢይ፡ ትእዛዝ፡ ይስቅየኒ፡ ለለጽባሑ፡ ወይነ፡ ፍቅርኪ፡ አዚ<supplied reason="omitted" resp="SH">ዝ</supplied>፡ ከመ፡ ይሰቅዮ፡ ውኂዝ፡ ለሠናይ፡ አርዝ ፡</incipit>
                     <explicit xml:lang="gez">
                        <locus from="26r" to="26v"/><hi rend="rubric">ስብሐት፡ ለኪ</hi><supplied reason="omitted" resp="SH">፡</supplied> ማርያም፡ <pb n="26v"/>በኍልቈ፡<choice>
                              <sic>ኩ</sic>
                              <corr resp="SH">ኵ</corr></choice>ሎን፡ ሥዕርትየ፡ ስብሐት፡ ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በኍልቈ፡ ኵሎን፡ አእፅምትየ፡ ስብሐት፡ ለኪ፡ ማርያም፡ <sic><hi rend="rubric">ማርያም፡</hi></sic> በ<choice>
                                       <sic>ኁ</sic>
                                       <corr resp="SH">ኍ</corr>
                                    </choice>ልቈ፡ ኵሉ፡ ዘተርእየ፡ ስብሐት፡ ለኪ፡ ንግሥትየ፡ በ<choice>
                                       <sic>ኁ</sic>
                                       <corr resp="SH">ኍ</corr>
                                    </choice>ልቈ፡ ኵሉ፡ ዘኢያስተርአየ፡ ስብሐተ፡ ድንግልናኪ፡ ዘልፈ፡ ይነግር፡ አፉየ።</explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="27r" to="44v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="44v" to="61v"/>
                     <locus from="78r" to="80v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="62r" to="72v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3012RepCh292">Prayer to Mary</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"> ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ብፅእት፡ አንቲ፡ ጽድቅ፡ ዘትሜንኒ፡ </incipit>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="72v" to="77r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4957SebhataF">Sǝbḥāta fǝqur za-Giyorgis</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="77r" to="77v"/>
                     <title type="complete">Invocation to several saints</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="80v" to="87v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3088RepCh368">‘O tender-hearted...’</title>
                     <textLang mainLang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="88r" to="92v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4965Kwellomu">‘All hosts of the angels praise
                        You…’</title>
                     <textLang mainLang="gez"/>
                  </msItem>

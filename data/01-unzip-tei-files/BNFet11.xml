               <msContents>
                  <summary/> 
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="94v" facs="f7"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez"/>
            
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="82r" facs="f7"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <textLang mainLang="gez"/>
                        <note>The following are missing:
              <p>the beginning until Ps. 17:27;</p>
                           <p>Ps. 25:2-Ps. 36:42;</p>
                           <p>Ps. 48:8b-Ps. 49:12;</p>
                           <p>  Ps. 59:1-Ps. 61:1;</p>
                           <p>Ps. 88:41-Ps. 102:2.</p>
                        </note>
                        <note>Several leaves are missing between <locus target="#6" facs="f17"/> and 
                <locus target="#7" facs="f19"/>; one leaf between  <locus target="#14" facs="f33"/> and 
                <locus target="#15" facs="f35"/>;
                one leaf between <locus target="#20" facs="f45"/> and <locus target="#21" facs="f47"/>;
                several leaves between <locus target="#43" facs="f91"/> and <locus target="#45" facs="f95"/>.
                <p>
                              <locus target="#44" facs="f93"/> has to be placed after <locus target="#35" facs="f75"/>.</p>
                        </note>
                     </msItem>
            
                     <msItem xml:id="ms_i1.2">
                        <locus from="82r" to="94v" facs="f169"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                        <textLang mainLang="gez"/>
                        <note>
                           <ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref> 
                is not included after <ref type="work" corresp="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</ref>.</note>
                     </msItem>
                  </msItem>
            
                  <msItem xml:id="ms_i3">
                     <locus from="95r" to="116v" facs="f195"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3946Salotat">Ṣalotāt za-saʿātāt</title>
                     <note>Incomplete from the prayer of the ninth hour,
                <ref type="work" corresp="https://betamasaheft.eu/LIT3128Prayer">Ṣalot ba-9 saʿāt</ref>.</note>
                     <note>These prayers are different from the ones in 
                <ref type="mss" corresp="https://betamasaheft.eu/BNFet9#ms_i3">Paris, Bibliothèque nationale de France, BnF Éthiopien 9:  ms_i3</ref>.</note>
                  </msItem>
               </msContents>
          

         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1">ዮሐንስ፡ ዘደብረ፡ ቢዘን፡</persName>
               <persName xml:lang="gez" type="normalized" corresp="#n1">Yoḥannǝs za-Dabra Bizan</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">abbot</occupation>
                  <birth when="1371"/>
               <floruit notBefore="1404" notAfter="1449">He was the second abbot of <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizan</placeName>, the disciple and successor of 
                  the founder of the monastery of
                  <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizan</placeName>,
               
                  <persName ref="https://betamasaheft.eu/PRS4107Fileppos">   
                     <roleName type="title">ʾabbā</roleName> Filǝṗṗos</persName>.
                  He led the community for 45 years until his death. 
                  He was succeeded by 
                  <persName ref="https://betamasaheft.eu/PRS8537saraqaB">
                     <roleName type="title">ʾabbā</roleName> Śaraqa Bǝrhān</persName>.  
               </floruit>
                  <death when="1449"/>
               </person>  
               
         </listPerson> 

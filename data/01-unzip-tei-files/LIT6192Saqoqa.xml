            <listBibl type="editions">
              <bibl corresp="http://zotero.org/groups/358366/items/WLZGW8A5"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Getatchew2017Lament"/><title level="a">Lamentation of the Soul (Säqoqawä Näfs). EMML 6993 (A), fols 88r-92v; 7121 (B), fols 46r-60r; Abbadie 206 (P)</title><title level="m">Ethiopian Studies in Honour of Amha Asfaw</title><author><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Getatchew Haile</t:name></author><editor><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Getatchew Haile</t:name></editor><pubPlace>New York</pubPlace><publisher>Getatchew Haile</publisher><date>2017</date><biblScope unit="page">225-256</biblScope><note type="url">https://www.researchgate.net/publication/324831896_Lamentation_of_the_Soul_Saqoqawa_Nafs</note></bibl>

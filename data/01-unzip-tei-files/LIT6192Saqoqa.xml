            <div type="edition" xml:lang="gez">
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘነበበ፨</l>
                        <l n="2">በነቢያቲሁ፡ ቅድመ፡ ወበሐዋርያት፡ ካዕበ፨</l>
                        <l n="3">እወጥን፡ አንሰ፡ ሰቆቃወ፡ ነፍስ፡ ዕፁበ፨</l>
                        <l n="4">ኵሎ፡ ሌሊተ፡ እንዘ፡ አርሕስ፡ ምስካበ፨</l>
                        <l n="5">ከመ፡ በአንብዕ፡ ዳዊት፡ ዓራቶ፡ ኀፀበ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሐዋጺሃ፡ ለነፍስ፡ ወናዛዚሃ፡ በሕቁ፨</l>
                        <l n="2">እምነ፡ ሐዘናት፡ አእላፍ፡ እለ፡ ኢይትኌለቁ፨</l>
                        <l n="3">ናዝዘኒ፡ ክርስቶስ፡ ለእግዚአብሔር፡ መልአከ፡ ጽድቁ፨</l>
                        <l n="4">ሰቆቃወ፡ ነፍስ፡ እንዘ፡ ከመ፡ ዖፍ፡ እነቁ፨</l>
                        <l n="5">እስመ፡ ናሁ፡ ገብርከ፡ አኀዝኩ፡ አስቆቁ፨</l>
                    </lg>
                    <lg type="stanza" n="74">
                        <l n="1">እምአፈ፡ መላእክት፡ ብርሃናውያን፡ እለ፡ ይመውኡ፡ ፀሐየ፨</l>
                        <l n="2">ወእምአፈ፡ ጻድቃን፡ ሰብእ፡ ዘኢየአምሩ፡ ጌጋየ፨</l>
                        <l n="3">ወሊተኒ፡ እምአንቀጸ፡ ዝንቱ፡ አፉየ፨</l>
                        <l n="4">ስብሐት፡ ለከ፡ አምላኪየ፡ ወበጸጋ፡ ጥምቀት፡ አቡየ፨</l>
                        <l n="5">እመ፡ አድኀንካ፡ እምሲኦል፡ ለኃጥእት፡ ነፍስየ፨</l>
                    </lg>
                    <lg type="stanza" n="75">
                        <l n="1">በኍልቈ፡ ደቂቁ፡ ለያዕቆብ፡ እለ፡ ወረዱ፡ ምድረ፡ ግብጽ፨</l>
                        <l n="2">ሰቆቃወ፡ ነፍስ፡ ስብኪ፡ በውስተ፡ ኵሉ፡ አናቅጽ፨</l>
                        <l n="3">ኢትፃኢ፡ ነፍስየ፡ እምቤተ፡ ንስሐ፡ ሕኑጽ፨</l>
                        <l n="4">ራትዕ፡ መልአከ፡ ሞት፡ ዘኢያደሉ፡ ለገጽ፨</l>
                        <l n="5">እስመ፡ ይነሥአኪ፡ ግብተ፡ በዘመን፡ ሕፁፅ፨</l>
                    </lg>
                </div>
            </div>
            

          
        </body>

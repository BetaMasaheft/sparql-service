               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>

                  <msItem xml:id="ms_i1"><locus from="1r" facs="003">Fols 1r and following</locus><title>A proverb or saying</title>
                    <incipit xml:lang="gez">መስተሣልቅ: ይስሕቅ: በነውረ: ቢጹ: ይኤብስ: ላዕለ: ፈጣሪ: ፍካሬ: ዘጻድቃን: ወዘኃጥአን: መዝሙር: ዘዳዊት።</incipit>
                    <note>Written before the beginning of the first Psalm</note>
                    </msItem>

                <msItem xml:id="ms_i2"><locus from="1r" to="163r" facs="003">Fols 1r–163r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters</note>
                  </msItem>

                <msItem xml:id="ms_i3"><locus from="164r" to="165r" facs="166">Fols 164r–165r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                <note>incomplete, in a different hand</note>
                </msItem>


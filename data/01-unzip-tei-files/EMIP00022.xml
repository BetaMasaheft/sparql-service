                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#1r #25v #32r #36v #42v #50v #56r #59v #67r #77r #86r #100v" facs="002 027 033 038 044 052 057 061 068 078 087 102">fols. 1r, 25v, 32r, 36v, 42v, 50v, 56r, 59v, 67r, 77r, 86r, 100v</locus>(<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red);

                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="353v">1v-353v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم , الحمد لله رب العالمين , الرحمن الرحيم , ملك اليوم [كذا] الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#353r">-353r</locus>الخناس , الذي يوسوس في صدور الناس , من الجنة والناس</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="354r" to="354r">354r-354r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#354r">-354r</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ اللهم ارحمنا بالقران العظيم وانفعنا بالايت والذكر الحكيم وبارك لنا فى السبع المثاني والقران العظيم

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#354r">-354r</locus>اللهم اشف مرضانا وعاف مبتلانا وارحم موتانا وتمم نعمتك علينا واجعل اجتماعنا ودعائنا وتاميننا بركة لنا في [ديننا] ودنيانا وشفا لنا من كل دا وسقم وفرج عنا من كل هم وغم برحتك يا ارحم الراحمين وصلى الله على سيدنا محمد واله وصحبه وسلم تسليما

</explicit>
                     <note/>
                     <note/>
                  </msItem>

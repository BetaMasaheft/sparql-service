                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_2923">
                           <locus target="#1v">-1v</locus>
                           <q xml:lang="ar">سورة الفاتحة سبع اية مكية</q>
                           <note>Placed within a panel.</note>
                           <note/>
                        </item>
                        <item xml:id="a2_2923">
                           <locus target="#353v">-353v</locus>
                           <q xml:lang="ar">تمت كلمات [ربك] صدقا وعدلا لا مبدل لكلمات الله اه الله سميع عليم انه هو السمىع العليم صدق الله العظيم وبلغ رسوله النبي الكريم صلى الله عليه وسلم وتحر على ما قال ربنا والهنا وسيدنا الذي اليه مصيرنا ومن جعلنا [من؟] الشاهدين</q>
                           <desc>Scribal verses</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_2923">
                           <locus target="#353v">-353v</locus>
                           <q xml:lang="ar">تمت كلمات [ربك] صدقا وعدلا لا مبدل لكلمات الله اه الله سميع عليم انه هو السمىع العليم صدق الله العظيم وبلغ رسوله النبي الكريم صلى الله عليه وسلم ونحن على ما قال ربنا والهنا وسيدنا الذي اليه مصيرنا ومرحعنا من الشاهدين \ وحبنا الله ونعم الوكيل ولا حول ولا قوة الا بالله العلي العظيم وصلى الله على سيدنا ومولانا وحبيبنا وسيدنا وشفيعنا وقرة اعيننا محمد صلى الله عليه وسلم </q>
                           <desc>Scribal verses</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_2923">
                           <locus target="#353v">-353v</locus>
                           <q xml:lang="ar">وكان الفراع من كتابة هذا المصحف الشريف [والتسويد والتنسيخ] نهار [.؟.] [المحرم] نهار خمس وعشرين [الذي] هو من شهور سنة ١٢٨١ من الهجرة النبوية احسن الله عاقبتها وخاتمتها بمحمد واله وعلى اصحابه اجمعين بكتابته فقير رحمة ربه الراجي غفران ذنبه وتفريج كربه وجبر كسره والمعترف بالخطاء والتقصير المشفع بمحمد البشير النذير حاج عبد الله بن احمد بن صالح الهرري الشافعي اصل الله حاله وبلغه من خير الدنيا والاخرة مقاصده وآماله وغفر له ولوالديه ولمن قرا في هذا المصحف</q>
                           <desc>Colophon</desc>
                           <note>The words "wa-al-taswīd wa-al-tansīḫ" written in red between the lines. 
A slip of paper covers an earlier text after the word "nahār".  The name of the month Muḥarram written partly in the margin, in red. the day of the month written on a slip of paper pasted on the line.</note>
                           <note/>
                        </item>
                        <item xml:id="a4_2923">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Red double frame around the text</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a5_2923">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Words ḥizb and ǧuz' as division markers. Some corrections and additions to the text. </q>
                           <desc>Marginalia</desc>
                           <note/>
                        </item>
                        <item xml:id="a6_2923">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Interlinear taǧwīd markers in red.</q>
                           <note/>
                        </item>
                        <item xml:id="a7_2923">
                           <locus target="#1v-2r">-1v-2r</locus>
                           <q xml:lang="ar">Multiple frames and panels with geometric patterns: red, white and black</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>

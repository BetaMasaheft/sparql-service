      <body>
         <div type="bibliography">
            
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
               <bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Marius</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><citedRange unit="item">203</citedRange></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
               <div type="textpart" subtype="stanza" n="1">
                  <lg>
                     <l>ሰላም፡ ለፅንሰትከ፡ በዕለት፡ ዐባይ፨</l>
                     <l>ወለልደትከ፡ ታብዝኅ፡ ውሉደ፡ መንፈስ፡ ወማይ፨</l>
                     <l>ፈዋሴ፡ ነፍሳት፡ ሉቃስ፡ ዐቃቤ፡ ሥራይ፨</l>
                     <l>ወንጌለ፡ ከመ፡ ወሀብኮ፡ ለፍቁርከ፡ ኅሩይ፨</l>
                     <l>ወንጌለ፡ ጥዒና፡ ሀበኒ፡ ለብእሲ፡ ድዉይ፨</l>
                  </lg>
               </div>
               <div type="textpart" subtype="stanza" n="2">
                  <lg>
                     <l>ሰላም፡ ለዝክረ፡ ስምከ፡ ዘአፈ፡ ምእመናን፡ አዕበዮ፨</l>
                     <l>ወለሥዕርትከ፡ ሜላት፡ ዘአካለ፡ ርእስከ፡ ተረስዮ፨</l>
                     <l>ዳዊት፡ ሉቃስ፡ ዘእግዚአብሔር፡ ኀረዮ፨</l>
                     <l>ሰይጣን፡ ሳኦል፡ ኢክህለከ፡ ዘደዌ፡ ሁከት፡ አድወዮ፨</l>
                     <l>እስከ፡ መንፍሥቶ፡ ነሣእከ፡ ወኵሎ፡ ንዋዮ፨</l>
                  </lg>
               </div>

               <div type="textpart" subtype="stanza" n="17">
                  <lg>
                     <l>ሰላም፡ ለሥነ፡ መልክእከ፡ ዘበድንጋጺ፡ ሞት፡ ኢተወለጠ፨</l>
                     <l>ወለፀአተ፡ ነፍስከ፡ በሰይፍ፡ ክሳድከ፡ አመ፡ ተዘብጠ፨</l>
                     <l>ዕፍረተ፡ ሃይማኖት፡ ሉቃስ፡ ዘበአፈ፡ ኵሉ፡ ተሠውጠ፨</l>
                     <l>መዐዛከ፡ አምላካዊ፡ ልቡና፡ አሕተብ፡ መሠጠ፨</l>
                     <l>ወለሕዝበ፡ እከይ፡ ኅሊናሆሙ፡ እምእከይ፡ ሜጠ፨</l>
                  </lg>
               </div>

               <div type="textpart" subtype="stanza" n="19">
                  <lg>
                     <l>ሰላም፡ ለመቃብሪከ፡ መካነ፡ አበው፡ ክልኤቱ፨</l>
                     <l>ውስተ፡ ምድረ፡ ንጉሥ፡ ዘርኅቀ፡ እምእግዚአብሔር፡ ሕይወቱ፨</l>
                     <l>ለበዓለ፡ ቤተ፡ ክርስቶስ፡ ሉቃስ፡ መጋቤ፡ ቤቱ፨</l>
                     <l>ኅበኒ፡ ፈውስ፡ በከንቱ፡ እንተ፡ ነሣእከ፡ በከንቱ፨</l>
                     <l>ከመ፡ ለኂሩትከ፡ ብየ፡ ይትከሠት፡ ኂሩቱ፨</l>
                  </lg>
               </div>
               <div type="textpart" subtype="stanza" n="20">
                  <lg>
                     <l>ሰላም፡ ለዕለተ፡ ሞትከ፡ ድኅረ፡ አምነ፡ እንጦሊ፨</l>
                     <l>ወለትንሣኤለ፡ ደርገ፡ ምስለ፡ በግዕ፡ ወጠሊ፨</l>
                     <l>እንተ፡ ተሰወርከ፡ ሉቃስ፡ እምእደ፡ ንጉሥ፡ ቀታሊ፨</l>
                     <l>ታሕተ፡ ሰይፍ፡ አድነንከ፡ ርእሰከ፡ ከመ፡ አድነነ፡ ጳውሊ፨</l>
                     <l>ክሳደከ፡ ይምትር፡ ዘንጉሥ፡ ወዓሊ፨</l>
                  </lg>
               </div>
               <div type="textpart" subtype="stanza" n="21">
                  <lg>
                     <l>ብእሴ፡ ተምኔት፡ ወልድከ፡ በቃለ፡ ስኢል፡ ወአስተብቍዖ፨</l>
                     <l>እስመ፡ ጸዋዕኩ፡ ስመከ፡ እንበለ፡ እኅሥሥ፡ አጽርኦ፨</l>
                     <l>እምዐራተ፡ ሕማም፡ ሉቃስ፡ ለሰብእናየ፡ ታንሥኦ፨</l>
                     <l>ጸውዐኒ፡ በስምየ፡ አመ፡ እመቃብር፡ አውፅኦ፨</l>
                     <l>ከመ፡ እግዚእነ፡ ለምዉት፡ ጸውዖ፨</l>
                  </lg>
               </div>

            
         </div>
      </body>
   </text></TEI>
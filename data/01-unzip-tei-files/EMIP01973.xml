                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                        <desc>The word God is rubricated in the first three works; the word Mary is rubricated in the final two works. Occasionally, the word God is rubricated in alternating red and black letters (e.g., <locus target="#54v" facs="055">fol. 54v</locus>)</desc>
                        <desc>There is no columetric layout of text</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="miniature" xml:id="d1">
                        <locus target="#73v" facs="074">Fol. 73v</locus>
                        <desc> Crude drawing of a figure</desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d2">
                        <locus target="#135r" facs="135">Fol. 135r</locus>
                        <desc> Crude drawing of a figure with a <term key="prayerstaff" ana="#prayerstaff"/>
                        </desc>
                     </decoNote>
                     <decoNote type="miniature" xml:id="d3">
                        <locus target="#135r" facs="135">Fol. 135r</locus>
                        <desc>A chart of 25 boxes (5 x 5) with faded characters in red ink</desc>
                     </decoNote>
                     <decoNote type="frame" xml:id="d4">
                    Decorative designs:
                    <locus target="#1r #7v #19r #26r #62r #93r #129v" facs="001 008 019 026 062 093 130">folss. 1r, 7v, 19r, 26r, 62r, 93r, 129v, </locus> (haräg);
                    <locus target="#1r #7r #18v #25v #31v #36r #42v #50v #57r #61v #72v #84r #86v #92v #99v #113r" facs="001 007 019 026 032 036 043 051 057 062 073 084 087 093 100 113">1r, 7r, 18v, 25v, 31v, 36r, 42v, 50v, 57r, 61v, 72v, 84r, 86v, 92v, 99v, 113r, </locus> (line of alternating red and black dots);
                    <locus target="#13r" facs="013">13r</locus> (multiple full stops and a line of red and black dots)
                  </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                          <locus target="#134r" facs="134">f. 134r, col. 2–135r</locus>
                           <desc type="Asmat">Asmat Prayer, including Arabic words written in Gǝ‘ǝz characters</desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#135v" facs="136">Fol. 135v</locus>
                           <desc type="Asmat">Asmat Prayer, with talismanic symbol, including Arabic words written in Gǝ‘ǝz characters, with instructions for reciting Psalms for Asmat purposes</desc>
                        </item>
                        <item xml:id="e1">
                           <desc>Identified in the insurance hand list as Psalter 7</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#31" facs="031">Fol. 31</locus>
                           <desc>red string is sewn into the fore edge as navigation system</desc>
                           </item>
                        <item xml:id="e3">
                          <locus target="#84 #93" facs="084 093">Fols. 84, 93</locus>
                          <desc>blue yarn is sewn into the fore edge as navigation system</desc>
                        </item>

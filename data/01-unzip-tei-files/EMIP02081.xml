                        <locus target="#iir(ecto)" facs="003">Fol. iir(ecto)</locus>
                        <desc> Behold the Lamb, <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> with a Lamb and carrying a processional <term key="cross" ana="#cross"/>
                        </desc>
                     </decoNote>

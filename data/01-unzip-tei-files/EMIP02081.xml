               <msContents>
                  <summary>Prayer of Saint Peter, <foreign xml:lang="gez">ጸሎተ፡ ጴጥሮስ</foreign></summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="40v" facs="003">Fols 1r–40v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer">Protective prayers
                                                  for the seven weekdays</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1.1"><locus from="1r" facs="003">Fols 1r and following</locus><title>Monday</title></msItem>
                    <msItem xml:id="ms_i1.2"><locus from="6r" facs="008">Fols 6r and following</locus><title>Tuesday</title></msItem>
                    <msItem xml:id="ms_i1.3"><locus from="11v" facs="014">Fols 11v and following</locus><title>Wednesday</title></msItem>
                    <msItem xml:id="ms_i1.4"><locus from="14r" facs="016">Fols 14r and following</locus><title>Thursday</title></msItem>
                    <msItem xml:id="ms_i1.5"><locus from="20v" facs="023">Fols 20v and following</locus><title>Friday</title></msItem>
                    <msItem xml:id="ms_i1.6"><locus from="25v" facs="028">Fols 25v and following</locus><title>Saturday</title></msItem>
                    <msItem xml:id="ms_i1.7"><locus from="32r" facs="034">Fols 32r and following</locus><title>Sunday</title></msItem>
                    <msItem xml:id="ms_i1.8"><locus from="38r" facs="040">Fols 38r and following</locus><title>The Daily Prayer is “I Beseech You Lest I die Early,” <foreign xml:lang="gez">ተማኅጸንኩ፡ ከመ፡ ኢይሙት፡ ዘእንበለ፡ ጊዜየ፡</foreign></title></msItem>

                    </msItem>
               </msContents>

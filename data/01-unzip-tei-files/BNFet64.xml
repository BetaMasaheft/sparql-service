               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="15r" facs="f9">Fols 2r–15r</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3848Tergwame">
                        <hi rend="rubric">ትርጓሜ፡ ቃላት፡ ዘባረኮሙ፡ ሙሴ፡ ለደቂቀ፡</hi> እስራኤል።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ቃለ፡ ኦሪት፡ ወይቤ፡ እግዚአብ<hi rend="rubric">ሔር፡ እምነ፡ ሲና፡ መጽአ። ትርጓሜ፡ እግዚ</hi>አብሔር፡ እምነ፡ ሲና፡
                  መጽአ፡ ይቤ፡ ሙሴ፡ <hi rend="rubric">ወሄኖክኒ፡ ይቤ፡ ወይቀውም፡ እገሪሁ፡ ው</hi>ስተ፡ ሲና፡ ደብር።</incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="15r" to="33r" facs="f35">Fols 15r–33r</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3849Tergwame">ትርጓሜ፡ ቃላት፡ ዘከመ፡ ባረኮሙ፡ ያዕቆብ፡ ለደቂቁ።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ወቅድምሰ፡ ዘንተ፡ አእምር፡ አምጣነ፡ <persName ref="https://betamasaheft.eu/PRS1269Abraham">አብርሃም</persName>፡ ባሕቱ፡ ዘእንበለ፡
                ይትወለድ፡ <persName ref="https://betamasaheft.eu/PRS5578Isaac">ይስሓቅ</persName>፡ አብርሃም፡
              ይትፌከር፡ በወልድ።</incipit>
                     <note>At the end of the commentary the names of the wives and children
                of <persName ref="https://betamasaheft.eu/PRS5650Jacob">Jacob</persName>'s twelve sons are enumerated.</note>
                     <note>For the prophecy on <persName ref="https://betamasaheft.eu/PRS11097Aser">ʾAser</persName>, see <ref target="#Aser"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="34r" to="57r" facs="f73">Fols 34r–57r</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3850MashafaM">
                        <hi rend="rubric">ዘሄኖክ፡ ነቢይ፡ መጽሐፈ፡ ሚጠተ፡ ብርሃናተ፡ ሰማይ፡ ፩፩በበ፡ ስልጠኖሙ፡
                ወበበ፡ ዘመኖሙ። ወበበ፡ ሕዘቢሆሙ፡ ወበበ፡ ስሞሙ፡</hi> ወሙላዳቲሆሙ፡ ወበበ፡ አውራኂሆሙ፡ ዘጸሐፈ፡ ሄኖክ፡ ወልደ፡ ያሬድ፡ በከመ፡
              አርአዮ፡ ኡራኤል፡ መልአክ።</title>
                     <textLang mainLang="gez"/>
                     <note>For the chapter titled <foreign xml:lang="gez">ኀሳበ፡ ክንትሮሳቲሁ፡ ለፀሓይ፡</foreign> see also <ref target="#Hassaba"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="58r" to="76v" facs="f121">Fols 58r–76v</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3851Hassab">
                        <hi rend="rubric">በስመ ኣብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ። ፩</hi>
                አምላክ፡ ጸሐፍነ፡ በዘንዜከር፡ ኀሳበ፡ ከመ፡ <hi rend="rubric">ኢንደመር፡ ምስለ፡ ከሓድያን። ካህን፡</hi> ወመነኮስ፡
              ዘኢያአምር፡ ኀሳበ፡ ይመስል፡ ከመ፡ <hi rend="rubric">ፈለግ፡ ዘአልቦ፡ ማየ፡ ወከመ፡ ሀገር፡ ዘአል</hi>ቦ፡ ሰብአ።</title>
                     <textLang mainLang="gez"/>
                     <note>The text is followed by a table of thirteen cycles indicating the number of years per cycle.</note>
                     <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/E34B28PN"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1918Comput"/><title level="a">Table de comput et de chronologie</title><title level="j">Revue de l’Orient Chrétien</title><author><forename>Sylvain</forename><surname>Grébaut</surname></author><date>1918</date><biblScope unit="volume">21</biblScope><biblScope unit="page">323-330</biblScope><note type="tags"><note type="tag">bm:Grebaut1918Comput</note></note><note type="tag">bm:Grebaut1918Comput</note><citedRange unit="page">324–326, 329</citedRange></bibl>
                     </listBibl>
                     <listBibl type="translation">
                        <bibl corresp="http://zotero.org/groups/358366/items/E34B28PN"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1918Comput"/><title level="a">Table de comput et de chronologie</title><title level="j">Revue de l’Orient Chrétien</title><author><forename>Sylvain</forename><surname>Grébaut</surname></author><date>1918</date><biblScope unit="volume">21</biblScope><biblScope unit="page">323-330</biblScope><note type="tags"><note type="tag">bm:Grebaut1918Comput</note></note><note type="tag">bm:Grebaut1918Comput</note><citedRange unit="page">326–328, 330</citedRange></bibl>
                     </listBibl>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="78r" to="94v" facs="f161">Fols 78r–94v</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2443Temher">
                        <certainty locus="value" match="../@ref" cert="low"/>
                        <hi rend="rubric">በስመአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አ</hi>ምላክ፡
                ዝንቱ፡ መጽሐፍ፡ ዘይሰመይ፡ ትምህርተ፡ ሃይማኖት፡ ወቃለ፡ በቍዔት፡
              ወረባሕ፡ እንተ፡ ነሐሥሥ፡ ምአምናን፡ ሃይማኖት፡ ኦርቶዶክሳዊት፡ ዘአበዊነ፡ ሐዋርያት፡ በዘንሌቡ፡ ጽምረተ፡ ስላሴ፡ ቅድስት።</title>
                     <textLang mainLang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="94v" to="98r" facs="f194">Fols 94v–98r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5849GenealogyApostles">Genealogy of the Twelve Apostles</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#94r">Fol. 94r</locus>
                          <hi rend="rubric">ዝውእቱ፡ ነገረ፡ ጥበብ፡ በእንተ፡ ፲ወ፪ሐዋር</hi>ያት፡ እም፲ወ፪ነገድ፡ ዘእስራኤል፡
                           አቡሆሙ፡ ለጴጥሮስ፡ ወለእንድርያስ፡ እምቤተ፡ ሮቤል፡ ወእሞሙ፡ እምቤተ፡
                           ስምዖን፨ ወይትኈለቍ፡ ጴጥሮስ፡ ኀበ፡ ሮቤል፨ ወእንድርያስ፡ ኀበ፡ ስምዖን፨
                           ለያዕቆብ፡ ወዮሐንስ፡  አቡሆሙ፡ እምቤተ፡ ሌዊ፡ ወእሞሙ፡ እምቤተ፡
                           ይሁዳ፨ ወይትኈለቍ፡ ዮሐንስ፡ ኀበ፡ ይሁዳ፡ በእንተ፡ እሙ፨ ወያዕቆብ፡ ኀበ፡ ሌዊ፨
                           ወፊልጶስ፡ ወጽአ፡ ዛብሎን፨
                     </incipit>
                     <note>The text has been edited and translated in
                        <bibl corresp="http://zotero.org/groups/358366/items/ZNUHPVWZ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1913Apotres"/><title level="a">Les tribus d’origine des apôtres</title><title level="j">Revue de l’Orient Chrétien</title><author><forename>Sylvain</forename><surname>Grébaut</surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="page">206-208</biblScope><note type="tags"><note type="tag">bm:Grebaut1913Apotres</note></note><note type="tag">bm:Grebaut1913Apotres</note></bibl>.
                  </note>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <locus from="98v" to="99v" facs="f202">Fols 98v–99v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3853KingList">King list A</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">እምቅድመ፡ መንግሥተ፡ አርዌ፡ አልቦ፡ ዘተ</hi>ሰምዐ፡ ስሞሙ፡ ለነገሥተ፡ አክሡም፡ ወነግሠ፡ አርዌ፡ ፬፻፡</incipit>
                     <bibl corresp="http://zotero.org/groups/358366/items/KKKATHSD"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1909Listes"/><title level="a">Les listes des rois d’Aksoum</title><title level="j">Journal Asiatique</title><author><forename>Carlo</forename><surname>Conti Rossini</surname></author><date>1909</date><biblScope unit="volume">Dixième Série, 14</biblScope><biblScope unit="page">263-320</biblScope><note type="tags"><note type="tag">bm:ContiRossini1909Listes</note></note><note type="tag">bm:ContiRossini1909Listes</note><citedRange unit="page">267</citedRange></bibl>
                     <note>The list starts with <persName ref="https://betamasaheft.eu/PRS2073Arwe">Arwe</persName> and ends with
                <persName ref="https://betamasaheft.eu/PRS3417David">David</persName>.</note>
                  </msItem>


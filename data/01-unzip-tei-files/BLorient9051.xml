                    <msPart xml:id="p1">
                        <msIdentifier/>
                        <msContents>
                            <summary/>
                            <msItem xml:id="p1_i1">
                                <locus from="1r" to="10v"/>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT3115RepCh395">Hymn to the Paraclete</title>
                                <note>Composed of thirty strophes of five verses each, beginning generally with 
                                    <foreign xml:lang="gez">እሰግድ።</foreign>. The first two stanzas are partly missing or hardly legible. The beginning of 
                                    the third stanza is legible on <locus target="#2r"/>.</note>
                                <incipit xml:lang="gez"><gap reason="omitted"/><gap reason="illegible"/><pb n="2r"/>
                                   እሰግድ፡ ለርእስከ፡ ርእሰ፡ መላኮት፡ ዝኩ።
                                   ዘነቢያተ፡ ኦሪት፡ ኪያሁ፡ አርድእተ፡ ወንጌል፡ ሰበኩ።
                                    ጵራቅሊጦስ፡ ትቤ፡ ገአረ፡ እስራኤል፡ ሰማዕኩ።
                                    እምቅኔተ፡ ግብጽ፡ አድኅኖሙ፡ ወረደኩ።
                                    ከመ፡ ከማሆሙ፡ ታድኅነኒ፡ ኀቤከ፡ ጸራሕኩ።
                                </incipit>
                            </msItem>
                            <msItem xml:id="p1_i2">
                                <locus from="11r" to="28v"/>
                                <title ref="https://betamasaheft.eu/LIT3067RepCh347">Hymn to the Holy Trinity</title>
                                <incipit xml:lang="gez">እስመ፡ ብዙኃን፡ እሙንቱ፡ አለ፡ አኃዙ፡ ይጽሐፉ።</incipit>
                            </msItem>
                        <msItem xml:id="p1_i3">
                            <locus from="31ra" to="40vb"/>
                            <title ref="https://betamasaheft.eu/LIT2875RepCh156">Malkəʾa Gabrəʾel</title> 
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዓ፡ ቀዲመ። </incipit>
                        </msItem>
                        <msItem xml:id="p1_i4">
                            <locus from="41ra" to="50va"/>
                            <title ref="https://betamasaheft.eu/LIT3082RepCh362">Malkǝʾa kidāna mǝḥrat</title> 
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ አብ፡ ወሀቤ፡ ብርሃን፡ ዘይሤለስ፡ በአካሉ።
                                እንዘ፡ ተዋሕዶ፡ ያጸንዕ፡ በመለኮቱ፡ ወኃይሉ።
                                ዓይነ፡ ልቡናየ፡ ይብራኅ፡ በማኅቶተ፡ ጥበብ፡ ስነ፡ ጸዳሉ።
                                ከመ፡ ይርአይ፡ ገጸ፡ ነገር፡ ለኪዳንኪ፡ ዘይደሉ።
                                ማርያም፡ እግዝእተ፡ ኵሉ፡ ዘታሕቱ፡ ወላዕሉ።
                                ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘአስተማስልዋ፡ በኮከብ።
                                ሶበ፡ ብርሃኖ፡ ተከድኑ፡ ጽልመታነ፡ ራእይ፡ ሕዝብ።
                                ኪዳነ፡ ምሕረት፡ ማርያም፡ ወተስፋ፡ መድኃኒት፡ ዘዓርብ።
                                ተናዘዘ፡ በኪዳንኪ፡ ሕሊና፡ ቀዳማይ፡ አብ።
                                አመ፡ እምገነቱ፡ ተሰደ፡ በኀዘን፡ ዕፁብ።
                            </incipit>
                        </msItem>
                        <msItem xml:id="p1_i5">
                            <locus from="50r" to="61v"/>
                            <title ref="https://betamasaheft.eu/LIT3042RepCh322">Malkəʾa Sāmuʾel za-Wāldǝbbā</title> 
                            <incipit xml:lang="gez">አሐዝኩ፡ አንሰ፡ ለልብየ፡ እምሐኬት።</incipit>
                        </msItem>
                        <msItem xml:id="p1_i6">
                            <locus from="61v" to="74v"/>
                            <title ref="https://betamasaheft.eu/LIT2846RepCh129">Malkəʾa ʾUrāʾel</title> 
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ።</incipit>
                        </msItem>
                        <msItem xml:id="p1_i7">
                            <locus from="75r" to="84v"/>
                            <title ref="https://betamasaheft.eu/LIT4274AkkonuB">ʾAkko-nu bǝʾsi</title> 
                            <incipit xml:lang="gez">አኮኑ፡ ብእሲ፡ ሶበ፡ ሐኒጸ፡ ቤተ፡ አፍተዎ፤</incipit>
                        </msItem>

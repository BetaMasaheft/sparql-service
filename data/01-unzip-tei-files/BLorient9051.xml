                        <additions>
                            <list> 
                                <item xml:id="a1">
                                    <locus target="#28v"/>
                                    <desc type="GuestText">Fragment of a prayer.</desc>
                                    <q xml:lang="gez">ተጋብኦታ፡ ለዛቲ፡ ምግባር፡ ጥንቁቀ። <gap reason="ellipsis"/></q>
                                </item>
                                <item xml:id="a2">
                                    <locus from="29r" to="30v"/>
                                    <desc type="GuestText">Fragment of a prayer.</desc>                              
                                    <q xml:lang="gez">ወበፀጋሙ፡ ወምስሴዖሙ፡ ኁሉቅ፡ ዝንቱ፡ ዘፍጥረቱ፡ ክርዳድ። ዘምስለ፡ ሥርናይ፡ ድሙር፡ ይሁዳ፡ ዘአግብአ፡ 
                                        <gap reason="ellipsis"/></q>
                                </item>
                                <item xml:id="a3">
                                    <locus from="50vb" to="54v"/>
                                    <desc type="GuestText">Fragment of a <ref type="work" corresp="https://betamasaheft.eu/LIT5069Prayer">prayer</ref>.</desc>
                                    <q xml:lang="gez">ሰአልናከ፡ መሐሪ፡ ሰአልናከ፤ ሰአልናከ፡ ገባሪ፡ ሰአልናከ። ሰአልናከ፡ ፈጣሪ፡ ሰአልናከ።<gap reason="ellipsis"/></q>
                                </item>
                                <item xml:id="a4">
                                    <locus from="85r" to="86r"/>
                                    <desc type="GuestText">Fragment of a prayer.</desc>      
                                    <q xml:lang="gez"><gap reason="illegible"/>በገጽ፡ ናጥሪ፡ እንከ፡ አፍቅሮ፡ ምስለ፡ ትሕትና፡ ከመ፡ ሐዋርያት፡ እስመ፡ አፍቀርዎ፡ ለእግዚኦ፤
                                        ወወሀቦሙ፡ ሥልጣነ፡ ዘከማሁ፡ ይእስሩ፡ ወይፍትሑ፡ ኵሉ፡ ማዕሠረ፡ አመፃ፤ <gap reason="ellipsis"/></q>
                                </item>  
                                <item xml:id="e1">
                                    <desc>The back cover is lined with a piece of linen bearing a note:</desc>
                                    <q xml:lang="en">Presented by <persName role="bequeather" ref="https://betamasaheft.eu/PRS14430Stubbs">
                                        <roleName type="title">Commander</roleName>E. Stubbs.</persName>.  
                                        <date when="1922-06-10">10 June 1922</date></q>
                                </item>
                            </list>
                        </additions>

                            <msItem xml:id="p2_i1">
                                <locus from="87r" to="94v"/>
                                <title>A fragment of a prayer to Jesus Christ</title>
                                <incipit xml:lang="gez">ዘለምስኪናን፡ ወለልሕዋን፡ ይናዝዞሙ፡ <sic>ወለእጻመው፡</sic> ለመስቀሉ፡ ይባልህ፡ ኵሉ፡ መዓተ፡ ይመይጥ። 
                                    ወያሰስል፡ እምኔነ፡ ላእለ፡ ቦቱ፡ ተወከልነ።</incipit>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ወጠንኩ፡ ሰላመ፡ መልክእከ፡ ዝንቱ፨</l>
                  <l n="2">ዘተበፅዐ፡ ሥነ፡ ርእየቱ፨</l>
                  <l n="3">መምህረ፡ ኀይለ፡ ቃል፡ ኩነኒ፡ መዝገበ፡ ሥላሴ፡ ባሕቱ፨</l>
                  <l n="4">ወማኅቶተ፡ ጸጋ፡ በተቅዋመ፡ ልብየ፡ አኅቱ፨</l>
                  <l n="5">ከመ፡ ገጸ፡ ነገር፡ እርአይ፡ ወእነጽር፡ ቦቱ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ሰላም፡ ለዝክረ፡ ጥዑም፡ ስምከ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ጥሉል፡ በጠለ፡ አርያም፡ ተስፋከ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ ቄርሎስ፡ ምክሐ፡ እስክንድርያ፡ ዘኮንከ፨</l>
                  <l n="4">ባርከኒ፡ አብ፡ ለወልድከ፡ ዘወለደኒ፡ ጸጋከ፨</l>
                  <l n="5">ከመ፡ ርእሰ፡ ወልዱ፡ አብርሃም፡ ቀዳሚ፡ ባረከ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በአፅፈ፡ ትሩፋት፡ ወገድል፨</l>
                  <l n="2">ወለመቃብሪከ፡ ባቲ፡ እንተ፡ ያስተርኢ፡ ኀይል፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ መምህር፡ ዘስብከትከ፡ ወንጌል፨</l>
                  <l n="4">አንብር፡ ብየ፡ ረድኤተከ፡ አምጻኤ፡ በረከት፡ ወሣህል፨</l>
                  <l n="5">ከመ፡ ዲበ፡ ካህን፡ ዮሴዕ፡ አንበረ፡ አክሊል፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ለዕበይከ፡ ንጉሥ፡ አምኃ፡ ሰላም፡ አቅረብኩ፨</l>
                  <l n="2">መጥዐነ፡ ክህልኩ፨</l>
                  <l n="3">መዝገበ፡ አጋእዝት፡ ሥላሴ፡ እለ፡ ይትመለኩ፨</l>
                  <l n="4">ተወከፍ፡ ሊተ፡ ባሕቱ፡ እንዘ፡ ትብል፡ ሠመርኩ፨</l>
                  <l n="5">ጸሪቀ፡ መበለት፡ ከመ፡ ተወክፈ፡ ወልደ፡ አብ፡ ዝኩ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ መዝገበ፡ ሥላሴ፡ ዋሕደ፨</l>
                  <l n="2">ዘይሰበኩ፡ ገሀደ፨</l>
                  <l n="3">ሀብተ፡ ወልድናሁ፡ አፈድፈደ፡ መጠነ፡ ፈቀደ፨</l>
                  <l n="4">እምጸጋከ፡ ለዘተወልደ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለከ፡ መዝገበ፡ ሥላሴ፡ መልአክ፡ አመ፡ ያሌዕል፡ ማዕፅዶ፨</l>
                  <l n="2">ውሉደከ፡ ዕቀብ፡ በተዋሕዶ፨</l>
                  <l n="3">እምጾታ፡ ፍልጠት፡ ወተባዕዶ፨</l>
                  <l n="4">እስመ፡ አብ፡ የዐቅብ፡ ውሉዶ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
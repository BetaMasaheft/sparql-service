               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="9r" to="69"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer">Protective prayers for the seven weekdays</title>
                     
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="9r" to="17v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Monday">Protective prayer for Monday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>  ጸሎቱ፡ ለጴጥሮስ፡ ዝውእቱ፡ ዘየዓቢ፡ እምሐዋርያቲሁ፡
                           ዘኀረዮ፡ ክርስቶስ፡ እ<supplied reason="omitted">ም</supplied>ቅድመ፡ ኵሎሙ፡ ሐዋርያቲሁ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ 
                              <sic>ወጸወዖሙ፡</sic>
                           
                           ለኵሎሙ፡ ሐዋርያቲሁ፡ ወነበረ፡ ምስሌሆሙ፡ ወባረኮሙ፡ ወይቤሎሙ፡ አንትሙ፡ አርዳእየ፡ አንትሙ፡ አኃውየ፡ አንትሙ፡ አዕርክትየ፡ ሰላም፡ ለክሙ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           እስመ፡ አእመረ፡ ስምየ፡ ይጸውዓኒ፡ ወእሰጥዎ፡ ወሀሎኩ፡ ምስሌሁ፡ አመ፡ ምንዳቤሁ፤ አድኅኖ፡ ወእሴብሖ፡ ለነዋህ፡ መዋዕል፤ አጸግቦ፡ ወአርእዮ፡ አድኅኖትየ፡
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="17v" to="21v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday1">Protective prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ መልከ፡ ጼዴቅ፡ ወበእንተ፡ ጰራቅሊጦስ፡
                           መንፈሰ፡ ጽድቅ፡ ወጸሎት፡ በእንተ፡ እግዚአብሔር፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                        ወበጽሐ፡ እንድርያስ፡ ሀገረ፡ በላዕተ፡ ሰብእ፡ ወጸውአ፡ ዘንተ፡ አስማተ፡ ወስዕነ፡ ቀሪቦታ፡ ፊልጶስ፡ በህየ፡ ወአጽንእዎ፡ በኅርየተ፡ መንፈስ፡ ቅዱስ፡ መኒኖሙ፡ ዘንተ፡ 
                              <sic>አላመ፡</sic>
                           
                           
                              <sic>ኃላፈ፡</sic>
                            ወአብዲኖሙ፡ ክርስቶስ፡ 
                              <sic>በሕይውቶሙ፡</sic>
                            ከማሁ፡ አሕይወኒ፡ ለገብርከ።
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="21v" to="22v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday2">Other protective prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           በስመ።አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           
                              <sic>ጸሎት፡</sic>
                           
                           ምሕረት፡ ዘጸለዩ፡ መላእክት፡ 
                              <sic>ወሰማ<supplied reason="omitted">ዕ</supplied>ተት፡</sic>
                            ጳጳሳት፡ ወካህናት፡ ወመነኮሳት፡ እድ፡ ወአንስት፡
                           ወኵሎሙ፡ ተጋቢዖሙ፡ ጸለዩ፡ ዘንተ፡ ጸሎተ፡ ኀበ፡ እግዚአብሔር፡ መሐረነ፡ መዋኤ፡ ፀር፡ በዝንቱ፡ 
                              <sic>አስማተ፡</sic>
                            አትዱናጥል። አርፌል፤ ወርኤል፤
                        </incipit>
                        <explicit xml:lang="gez">
                           ተማኅፀንኩ፡ እስመ፡ አምላኪየ፡ ኢየሱስ፡ ናዝራዊ፡ በውእቱ፤ ስምከ፤ በብሔርኪዮስ፤ በፍርኪዮስ፤ ስምከ፡ በቀነናዊ፤ ስምከ፡ ተማኅፀንኩ፡ አነ፡ ገብርከ፡
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="22v" to="23r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday3">Other protective prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ ፩አምላክ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ዘኢይቀርበከ፡ ሰይጣን፡ ዘንተ፡ ድግም፤ ወበል፤
                           አስማተ፤ አስናኤል፤ አቅናኤል፡ ወበርሰያሄል፤
                        </incipit>
                        <explicit xml:lang="gez">
                           በዝንቱ፡ አስማቲከ፡ አድኅነኒ፡ ለገብርከ፡ ገብረ፡ ሰንበት፡
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11676GabraSa">Gabra Sanbat</persName> is mentioned in the supplication formula at
                        the end of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="23r" to="24v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday4">Other protective prayer for Tuesday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ክርስቶስ፡ መሐረኒ፡ ክርስቶስ፡ ተሣሃለኒ፡ ክርስቶስ፡ አድኅነኒ፡
                           ለገብርከ፡ ገብረ፡ ሰንበት፡
                        </incipit>
                        <explicit xml:lang="gez">
                           እግዚአብሔር፡ ይዕቀብከ፡ በንግደትከ፡ ወበእትወትከ፡ እምይእዜ፡ ወእስከ፡ 
                              <sic>ለአላም፡</sic>
                            ስብሐት፡ ለአብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11676GabraSa">Gabra Sanbat</persName> is mentioned in the supplication formula at
                           the beginning of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="24v" to="29r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Wednesday1">Protective prayer for Wednesday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ 
                              <sic>መድኃነት፡</sic>
                           
                           አስማተ፡ መድኃኒት፡ ወኃይላት፡ ዘወረደ፡ እምሰማያት። ዘወሀቦ፡ ለቶማስ፡ ረድእ፤
                        </incipit>
                        <explicit xml:lang="gez">
                           ይነጽሑ፡ እምሐጢአቶሙ፡ ወኢ<supplied reason="omitted">ይ</supplied>ወድቅ፡ ውስተ፡ ኵነኔ፡ ለእመ፡ <choice>
                              <sic>ይባዎ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ይቤልዎ፡</corr>
                           </choice>
                           ለዝንቱ፡ <add place="below">፯</add>አስማት፡ በበጊዜ፤ እንዘ፡ 
                              <sic>ይብለ፡</sic>
                            በዓውድ፡ አውላካኤል፡ ወይቤሎሙ፡ ኪዳነ፡ ለገብርከ፡ ገብረ፡ ሰንበት፡
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11676GabraSa">Gabra Sanbat</persName> is mentioned in the supplication formula at
                           the end of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="29v" to="36r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Wednesday2">Other protective prayer for Wednesday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወይቤልዎ፡ መላእክት፡ ታስ<supplied reason="omitted">ተ</supplied>ሐፍሮሙኑ፡
                           ለእመ፡ ይገምዎ፡ ለዝንቱ፡ አስማት፡ በበጊዜሁ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           
                              <sic>ኣግዚኦ፡</sic>
                            አምላኪየ፡ እገኒ፡ ለከ፡ ለዓለም፡ ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አድኅኖ፡ ለገብርከ። ገብረ፡ <supplied reason="omitted">ሰንበት፨</supplied>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus from="36r" to="42r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Thursday">Protective prayer for Thursday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ለነ፡ ለሐዋርያት፡ ወሀበነ፡ ዘንተ፡ አማተ፡ በደብረ፡ ዘይት፡ ወምስለ፡
                           እሙ፡ አመ፡ ዕለተ፡ ዕ<add place="overstrike">ርገ</add>ቱ፡ ውስተ፡ ሰማያት፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወይሁቦሙ፡ እግዚአብሔር፡ ኃይለ፡ ለነገሥት፡ እግዚአብሔር፡ <add place="above">ይባ<supplied reason="omitted">ር</supplied>ኮሙ፡</add> ለሕዝቡ፡ በሰላም፡
                           ኦአምላከ፡ ዳዊት፡ ዕቀቦ፡ ወአድኅኖ፡ ለገብርከ፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus from="42r" to="49r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Friday">Protective prayer for Friday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ይቀድሰነ፡ አስማቲሁ፡ ለክርስቶስ፡ ሴድላዊ፡ ቢድጋዊ፡ ብድሮፋ፡
                           ፈቃዱን፡ ገደላኤል፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ኢትመጥወኒ፡ ለእለ፡ ይሣቅዩኒ፡ <choice>
                              <sic>ጽንንሖ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">አጽንዖ፡</corr></choice>
                            ለገብርከ፡ ውስተ፡
                           ሠናይ፡ ወ<supplied reason="omitted">ኢ</supplied>ይትዓገሉኒ፡ ዕቡያን፡ ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈ<supplied reason="omitted">ስ</supplied>፡ ቅዱስ፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="49r" to="55v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Saturday">Protective prayer for Saturday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎተ፡ ስርየት፡ እምነቶ<supplied reason="omitted">ሙ</supplied>፡
                           ለሐዋርያት፡ ወለኵሎሙ፡ ፸ወ፪አርድ<supplied reason="omitted">እ</supplied>ት፡ ከማሁ፡ ይቤሎሙ፡ እግዚአብሔር፡ ለአርዳኢሁ፡ አንትሙ፡ ውእቱ፡ ዓእርክትየ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ይድፍኖሙ፡ <supplied reason="omitted">ኢ</supplied>ይደቅ፡ ላዕሌሆሙ፡ አፍሐመ፡ እሳት፡ ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="55v" to="59r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Sunday">Protective prayer for Sunday</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ብርናኤል፡ እጉዳ፡ አግፍላላኤል፡ ዘንተ፡
                           
                              <sic>አስመተ፡</sic>
                            ዘወሀቦሙ፡ እግዚአብሔር፡ ለአናንያ፡ ወአዛርያ፡ ወሚሳኤል፡
                        </incipit>
                        <explicit xml:lang="gez">
                           እስዕለከ፡ 
                              <sic>ወአስተበቁዓከ፡</sic>
                            ከመ፡ ትፈኑ፡ መንፈሰ፡  ቅዱስ፡ ዲበ፡ ኃጥእ፡ ገብርከ፡
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="59r" to="63r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Andrew">Prayer on the names that Jesus Christ revealed to Andrew the apostle</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ዝንቱ፡ አስማት፡ ነገሮ፡ እግዚእነ፡ ለቅዱስ፡ እንድርያስ፡ ረድዕ፡
                           ወሐዋርያ፡ ወሰማ<supplied reason="omitted">ዕ</supplied>ት፡ በረከቱ፡ የሃሉ፡ ምስለ፡ ገብሩ፡ ገብረ፡ ሰንበት፡ ወይቤሎ፡ ሑር፡ ሀገረ፡ በላዕተ፡ ሰብእ፡ ኀበ፡ ሀሎ፡ እኁከ፡ ማትያስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወሀበት፡ ፍሬሃ፡ ወይባርከነ፡ እግዚአብሔር፡ ወይፈርህዎ፡ ኵሎሙ፡ አጽናፈ፡ ምድር፡ <choice>
                              <sic>ኦአምላክ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ለአምላክ፡</corr>
                           </choice>
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11676GabraSa">Gabra Sanbat</persName> is mentioned in the supplication formula at
                           the beginning of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.13">
                        <locus from="63r" to="65r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Daily">Daily prayer</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ተማኅፀንኩ፡ ከመ፡ 
                              <sic>ኢይመውት፡</sic>
                           
                           ዘእንበለ፡ ጊዜየ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ በእንተ፡ ዝንቱ፡ ዕቀበኒ፡ እገብርከ፡ በዝ፡ ዓለም፡ ወበዘይመጽእ፡ ዓለም፡ አድኅነኒ፡ እም<supplied reason="omitted">እ</supplied>ሳተ፡ ገሃነም፡ ውዑይ፡
                           ሊተ፡ ለገብርከ፡ ገብረ፡ ሰንበት፡
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11676GabraSa">Gabra Sanbat</persName> is mentioned in the supplication formula at
                           the end of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.14">
                        <locus from="65r" to="68v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Enoch">Prayer on the names that the angels revealed to Enoch</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           
                              <sic>አስማተ፡</sic>
                           
                           ዘነገርዎ፡ መላእክት፡ ለሄኖክ፡ <supplied reason="omitted">ወ</supplied>መሐርዎ፡ ወይቤልዎ፡ ሶበ፡ መጽአ፡ ድልቅ፡ ልቅ፡ በረድ፡ 
                              <sic>ወጸዓዓ፡</sic>
                           
                           ረኀብ፡ ለብሔር፡ ከመዝ፡ በል፡ እግዚአብሔር፡ 
                              <sic>ጉንዱየ፡</sic>
                            መዓት፡ ወብዙኃ፡ ምሕረት፡ ወጻድቅ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           
                              <sic>እግዚአ፡</sic>
                            በኃይልከ፡ ንሴብሕ፡ ወንዜምር፡ 
                              <sic>ለጸንዕከ፨</sic>
                            ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                           ለዓለም፡ ወለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፨
                        </explicit>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="69r" to="72r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2858RepCh140">Malkǝʾ-hymn to St George</title>
                     <incipit xml:lang="gez">
                        ሰላም፡ ለዝክረ፡ ስምከ፡ ወለስዕ<supplied reason="omitted">ር</supplied>ትከ፡ ድሉል፡
                     </incipit>
                     <explicit xml:lang="gez">
                        እስመ፡ እምሀቤከ፡ ይትፌጸማ፡ ስእለታት፡ አእላፍ። ሰላም፡ ለከ፡ ጊዮርጊስ፡ ኅሩይ፡ ሰላ<supplied reason="omitted">ም</supplied>፡
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ሰላ<supplied reason="omitted">ም</supplied>፡  ሰ፡
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>  ሰ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                     </explicit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="72r" to="75r"/>
                     <title type="complete">Litany told by the deacon before the anaphora</title>
                     <incipit xml:lang="gez">
                        በእ<supplied reason="explanation">ንተ</supplied>፡ ቅድስት፡ ሰማ<supplied reason="omitted">ያ</supplied>ዊት፡ 
                           <sic>ሰላመ፡</sic>
                        
                        ናስተበቍዕ፡ ከመ፡ እግዚአብሔር፡ ያስተሳልመነ፡ በሳህለ፡ ዚአሁ፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ንስዕል፡ ወናስተበቍዕ፡ በመንፈሰ፡ ሰላመ፡ ይክድነነ፤ ወይጸግወነ፡ ንቅረብ፡ ወንስአሎ፡ ለእግዚአብሔር፡ ከመ፡ ተሰጢዎ፡ ጸሎተነ፡ ይትወከፍ፡
                     </explicit>
                     <note>
                        The litany contains invocations for the faith, the Church, the prophets, the apostles, the martyrs, the patriarchs and the bishops, the priests, the deacons,
                        the readers, the vidows, the virgins, the catechumens, the king, the rulers, the world, the pilgrims, the sleepers, the sick, the fathers and the brothers who
                        committed sin, the rain, the fruits of the earth.
                     </note>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="75r" to="82v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">Anaphora of Our Lord Jesus Christ</title>
                     <explicit xml:lang="gez">
                        ወስክ፡ ሎሙሂ፡ ወሎንሂ፡ ሃይማኖተከ፡ 
                           <sic>ወፈሬ<supplied reason="omitted">ሆ</supplied>ተከ፡</sic>
                         በ፩ወልድከ፡ ዘቦቱ፡
                        በል፡ ወእኂዝ፡ ወለዝሉ<supplied reason="explanation">ፉ፡</supplied> ለአለመ፡ ዓለም፡
                     </explicit>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="83r" to="104r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">Anaphora of Our Lady Mary</title>
                     <incipit xml:lang="gez">
                        
                           <sic>አኰቴተ፡</sic>
                         ቍርባን፡ ዘደረሰ፡ አባ፡ ሕራይቆስ፡ በእንተ፡ እግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i6">

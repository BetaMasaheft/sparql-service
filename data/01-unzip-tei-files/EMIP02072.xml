                  <msItem xml:id="ms_i5.1">
                     <locus from="50r" to="61r" facs="053">Fols 50r–61r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Trinity">ʾAmmǝstu
                                                  ʾaʿǝmāda mǝśṭir, Mystery of the Trinity (ምሥጢረ፡
                                                  ሥላሴ፡)</title>
                     <incipit xml:lang="gez">‎በማን፡ ታምናለህ፡ በእግዚአብሔር፡ እግዚአብሔር፡ ስንትነው፡ ‎‎አንድም፡ ነው፡ ሶስትም፡ ነው፡ ሶስትነቱ፡ በምንነው፡ በአካል፡ በስም፡ ‎‎በግብር፡ አካል፡ ማለት፡ ምን፡ ማለት፡ ነው፡ ቁመት፡ ማለት፡ ነው፡ ‎‎የእግዚአብሔር፡ ቁመቱ፡‎ <gap reason="omitted"/>
                     </incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i5.2">
                     <locus from="61r" to="76r" facs="064">Fols 61r–76r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Incarnation">ʾAmmǝstu
                                                  ʾaʿǝmāda mǝśṭir, Mystery of the Incarnation (ምሥጢረ፡
                                                  ሥጋዌ፡)</title>
                     <incipit xml:lang="gez">‎ከ፫ቱ፡ አካላት፡ ሥጋን፡ ሥጋ፡ ለበሰ፡ አካለ፡ ወልድ፡ ምነው፡ አንሶን፡ ‎‎እጻንወጥበት፡ አይዶለውም፡ ፩ወጽበት፡ አይዶለውም፡ አብ፡ ሥጋ፡ ‎‎ቢለብስ፡ አብም፡ ወልድም፡ ይባል፡‎<gap reason="omitted"/>
                     </incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i5.3">
                     <locus from="76r" to="78r" facs="079">Fols 76r–78r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Eucharist">ʾAmmǝstu
                                                  ʾaʿǝmāda mǝśṭir, Mystery of the Eucharist (ምሥጢረ፡
                                                  ቍርባን፡)</title>
                     <incipit xml:lang="gez"><gap reason="omitted"/> ‎ሥጋ፡ የለበሰ፡ ወልድ፡ እንጂ፡ ነው፡ የወልድን፡ ሥጋ፡ እበላለሁ፡ ‎‎ወልድን፡ ቀድሞ፡ ዓረገ፡ አላልኽም፡ ሥጋውንት፡ ጥሎ፡ ዓረገ፡ ‎‎ዳግመኛን፡ ይመፃል፡ አይዶለውም፡‎ <gap reason="omitted"/>
                     </incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i5.4">
                     <locus from="78r" to="79r" facs="081">Fols 78r–79r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Resurrection">ʾAmmǝstu ʾaʿǝmāda mǝśṭir, Mystery ofthe
                                                  Resurrection (ምሥጢረ፡ ትንሣኤ፡)</title>
                     <incipit xml:lang="gez"><gap reason="omitted"/> ‎ከሞትህ፡ ከፈረስህ፡ ከበሰበስህ፡ እንዴት፡ ትነሣለህ፡ ይኸሳ፡ እህል፡ ‎‎ቢዘሩት፡ ፈርሶ፡ በስብሶ፡ አካል፡ ገዝቶ፡ የጥንት፡ ልብሱን፡ ይነሣል፡ ‎‎ከእህልን፡ እብስ፡ እኔም፡ እንዲያ፡ እነሣለሁ‎<gap reason="omitted"/>
                     </incipit>

               <msContents>
                  <summary>I) Bǝsrāta Yoḥannǝs “Gospel of John” (fols. 1ra-47vb).</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">47.0</measure> folios, in <measure unit="quire">6.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">192</height>
                              <width unit="mm">133</width>
                              <depth unit="mm">37</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">8</dim>
                                 <locus from="1r" to="8v"/>I(8/fols. 1r-8v) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="9r" to="16v"/> II(8/fols. 9r-16v) </item>
                              <item xml:id="q3">
                                 <dim unit="leaf">8</dim>
                                 <locus from="17r" to="24v"/> III(8/fols. 17r-24v) </item>
                              <item xml:id="q4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="25r" to="32v"/> IV(8/fols. 25r-32v) </item>
                              <item xml:id="q5">
                                 <dim unit="leaf">8</dim>
                                 <locus from="33r" to="40v"/> V(8/fols. 33r-40v) </item>
                              <item xml:id="q6">
                                 <dim unit="leaf">7</dim>
                                 <locus from="41r" to="47v"/> VI(7; s.l.: 1, no stub/fols.
                                 41r-47v).</item>
                           </list>
                        </collation>
                        <condition key="deficient">The Ms. has been affected by humudity and shows
                           traces of extensive use: many fols. are stained with dirt, wax or
                           humidity. The text on several fols. is partly illegible, e.g., <locus target="#1r">1r</locus> (discoloured), 1v, 2r, 8r, 8v, 9r. The back
                           board has been broken and repaired. The sewing has been damaged and
                           crudely repaired. Both boards seems to have been reused (there are sets
                           of holes on the outer edges). <locus target="#33">33</locus> is of
                           smaller size (damaged by rodents?).</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="18">
                           <dimensions unit="mm">
                              <height>135</height>
                              <width>110</width>
                              <dim type="intercolumn">7</dim>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">15</dim>
                              <dim type="bottom">30</dim>
                              <dim type="right">7</dim>
                              <dim type="left">12</dim>
                              <dim type="intercolumn">7</dim>
                           </dimensions>
                           <note/>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible. </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A-1A-1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are visible.</ab>
                           <ab type="pricking"> Ruling pricks are visible.</ab>
                           <ab type="ruling"> The upper line is written above the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.  The bottom ruled line was not used by the scribe on some fols.,
                              e.g., <locus target="#13r">13r</locus>, 13v, 14r, 14r, 14v, 15r, 42v,
                              43r.</ab>
                        </layout>
                        
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script"/>
                        <seg type="ink">Black, red</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>፪ሆሙ፡</abbr> for <expan>ክልኤሆሙ፡ </expan> (e.g., <locus target="#44rb">44rb</locus>).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; the name of the donor; a few lines on
                           the incipit page of the Text, alternating with black lines; incipit of
                           each chapter of the text; elements of Ethiopic numerals; elements of the
                           punctuation signs.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The handwriting appears very irregular
                        throughout the Ms. Though very unusual, it appears that up to four different
                        scribes were involved in copying. Abrupt changes in the size, shape and
                        density is visible:
                        </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> (Hand a): <locus from="1ra" to="21rb">1ra-21rb</locus>;
                        23va-27va</handNote>
                     <handNote xml:id="h4" script="Ethiopic"> (Hand b): <locus from="21va" to="23rb">21va-23rb</locus>; 27va-43ra; 43vb-44rb;
                        45rb-47vb.</handNote>
                     <handNote xml:id="h5" script="Ethiopic"> (Hand c): <locus from="43ra" to="43vb">43ra-43vb</locus>.</handNote>
                     <handNote xml:id="h6" script="Ethiopic"> (Hand d): <locus from="44va" to="45ra">44va-45ra</locus>.</handNote>
                     <handNote xml:id="h7" script="Ethiopic"> The words እግዚእ፡ (እግዚአብሔር፡)is sometimes
                        written with, sometimes without the ligature (e.g., <locus target="#4va">4va</locus>).</handNote>
                     <handNote xml:id="h8" script="Ethiopic"> Sometimes a change occurs in the
                        middle of a word, coinciding with the end of a column, e.g., <locus from="44rb" to="44va">44rb-44va</locus> (ጴጥሮስ),
                        45ra-b(ማርያም).</handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Readings are indicated with the names of the days
                              written in frames interlineally or in the margin, in red or black ink:
                              ዘሰኑይ፡: <locus target="#1r">fol. 1r</locus> ዘእሑድ: <locus target="#5ra">fol. 5ra</locus> ሠሉስ: <locus target="#13v">fol. 13v</locus> ዘረቡዕ፡:
                                 <locus target="#27v">fol. 27v</locus> ዘቀዳም፡: <locus target="#30r">fol. 30r</locus> ዘእሑድ: <locus target="#30v">fol. 30v</locus> ዘሐሙስ:
                                 <locus target="#32v">fol. 32v</locus> ዘዓርብ፡: <locus target="#39v">fol. 39v</locus> ዘእሑድ: <locus target="#44r">fol.
                              44r</locus>
                           </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Erasures: fols. 28vb, 35vb. - Erasures marked by thin lines: fols. 1rab, 3vb, 8ra, 11ra, 45vb. - Corrections written over erasures: e.g., fols. 5ra, 5va, 26va, 47ra. - Corrections written interlineally: <locus target="#45vb">fol.  45vb</locus>. - Omitted letters, words or passages written interlineally or in the margin: e.g., fols. 2rab, 4ra, 6rab, 7rab, 23rb. - Tämälläs-sign, in the shape of two perpendicular lines (┴): fols. 12v, 13r. - Scribbles and doodles: e.g., fols. 4v, 15v, 25v, 31v, 45v.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards (the back board broken and
                           repaired). 
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Tears on the spine fold of the quires,
                           close to the head and the tail.</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>

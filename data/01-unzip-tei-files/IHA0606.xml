               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="69r">2v-69r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1258IHA">مطالع الشروق في مراعاة الحقوق</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم \ الحمد لله البر الرحيم كثير البر واسع الاءمتنان الامر بالعبد دو الاحسان الذى اوجب علينا مراعاة الحقوق وقرن بطاعته طاعة الوالدين مصلحة لكل انسان [...] وبعد فهذا تعليق لطيف رغبنى فيه بعض الاخوان اصلح الله لى وله الحال واذا قنا حلاوة الاءيمان </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#69r">-69r</locus>وعلى اداء الحقوق الواجبة المذكورة فى هذا الكتاب وعير[ها] ويحترز عن المعاصى كلها الباطنة والظاهرة وليغرا الى لله تعالى بالتوبة كلما وقعت منه عثرة وهفوه وليتضرع الى الله تعلى فى سؤال حسن الخاتمة وفقنا الله لطاعته وحفظنا من معاصيه وختم لنا بحسن الختام بفضله ومنه فانه البر الرحيم امين وصلى الله على سيدنا محمد وعلى اله وصحبه اجمعين والحمد لله رب العلمين تمت</explicit>
                     <note>Words divided into two lines. Some words vocalized.</note>
                     <note/>
                  </msItem>
               </msContents>

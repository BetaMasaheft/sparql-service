               <msContents>
                  <summary>Codex of Artwork, with text from Psalter, ዳዊት፡, every other panel has excerpts from the Psalms</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <msItem xml:id="ms_i1"><locus from="1" facs="003">Fols 1 and following</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title><note>short excerpt</note></msItem>
                  <msItem xml:id="ms_i2"><locus from="2" facs="004">Fols 2 and following</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title><note>short excerpt</note></msItem>
                  <msItem xml:id="ms_i3"><locus from="3" facs="005">Fols 3 and following</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title><note>short excerpt</note></msItem>
                  <msItem xml:id="ms_i4"><locus from="4" facs="006">Fols 4 and following</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title><note>short excerpt</note></msItem>
                  <msItem xml:id="ms_i5"><locus from="5" facs="007">Fols 5 and following</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title><note>short excerpt</note></msItem>
                </msContents>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="33"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Monday">ʾArgānona wǝddāse, for Monday</title>
                        <explicit xml:lang="gez">
                         ሄሮድስ፡ ፈተወ፡ ይጽብጥ፡ ብርሃነ፡ ፀሐይ፡ በእዴሁ፡ በአይቴኬ፡ ይትከሃል፡ ጸቢጠ፡ ብርሃነ፡ ፀሓይ፡ እግዚአብሔር፡ ተአንገደ፡ ውስተ፡ ምድረ፡ ግብጽ፡ ተሐዚሎ፡ በዘባንኪ፨
                      </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="33r" to="66v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Tuesday">ʾArgānona wǝddāse, for Tuesday</title>
                        <incipit xml:lang="gez">
                           ኦእግዝእትየ፡ ቅድስት፡ ድንግል፡ በክልኤ፡ ማርያም፡ ዘበዕብራይስጢ፡ ማሪሃም፡ ተማኅፀንኩ፡ በዝ፡ ተአንግዶ፡ ኣምላክ፡ ምስሌኪ፡ ተዝካረ፡ ጻማኪ፡ በሐዊረ፡ ፍኖት፡ ይቁም፡ ቅድመ፡ ገጹ፡ ለወልድኪ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           አማኅፀንኩኪ፡ ነፍስየ፡ ወሥጋየ፡ ከመ፡ ትዕቀብኒ፡ ወኢትሰስሊ፡ እምኔየ፡ በኵሉ፡ መዋዕለ፡ ሕይወትየ፡ ወኢትሕድግኒ፡ ለዝሉፉ፡ ኢበዝ፡ ዓለም፡ ወኢበዝ፡ ይመጽእ፡ ዓለም፨
                        </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="66v" to="98r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Wednesday">ʾArgānona wǝddāse, for Wednesday</title>
                        <incipit xml:lang="gez">
                           አቀድም፡ አእኵቶቶ፡ ለእግዚአብሔር፡ በእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወበእንቲአኪ፡ እስመ፡ ተሰምዐ፡ ዜና፡ ውዳሴኪ፡ ውስተ፡ ኵሉ፡ ዓለም፨ በከመ፡ ተነበይኪ፡ በመንፈስ፡ ቅዱስ፡ እንዘ፡ ትብሊ፡ ናሁ፡ 
                           እምይእዜሰ፡ ያስተበፅዓኒ፡ ኵሉ፡ ትውልድ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ወዘሰ፡ ይትሜካሕ፡ 
                              <sic>በቅዱስ፡</sic>
                            እስራኤል፡ ወይትዌከል፡ በአማከ፡ ያዕቆብ፨ ወዘይጼወን፡ በጸሎተ፡ እሙ፡ ድንግል፡ ንጽሕት፡ ሠናየ፡ የዓል፡ ወሠናየ፡ ይቢት፡ 
                           ወሠናየ፡ የሃሉ፡ እስከ፡ ለ<del rend="erasure">ዓ</del>ለም፡ አሜን፨
                        </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="99r" to="128r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Thursday">ʾArgānona wǝddāse, for Thursday</title>
                        <incipit xml:lang="gez">
                           ወአንቲሂ፡ ካዕበ፡ ኦእግዝእትየ፡ ቅድስት፡ ማርያም፡ ድንግል፡ በክልኤ፡ ዘበዕብራይስጢ፡ ማሪሃም፡ እሙ፡ ለገባሬ፡ መላእክት፡ ወወላዲቱ፡ ለመስተጽዕነ፡ ኪሩቤል፡ ሰኣሊ፡ በእንቲኣየ፡ ከመ፡ እትባላሕ፡ በጸሎትኪ፡ 
                           እመናስወ፡ ዓለም፡
                        </incipit>
                        <explicit xml:lang="gez">
                          ዛቲ፡ ይእቲ፡ ኣክሊለ፡ ጽድቅ፡ ሠርጐ፡ መሃይምናን፡ ዘኢትበጽሖሙ፡ ለእለ፡ ኢተጠምቁ፡ በስመ፡ ወልዳ፨ ዛቲ፡ ይእቲ፡ መዝገበ፡ ባሕርየ፡ መለኮት፨ ዛቲ፡ ይእቲ፡ ሙዳየ፡ ወርቅ፡ ንጹሕ፡ ብዕሎሙ፡ ለነዳያን፨
                        </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="128r" to="156v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Friday">ʾArgānona wǝddāse, for Friday</title>
                        <incipit xml:lang="gez">
                           ኦእግዝእትየ፡ ቅድስት፡ ድንግል፡ በክልኤ፡ ማርያም፡ ዘበዕብራይስጢ፡ ማሪሃም፡ ወላዲተ፡ ኣምላክ፡ ፍቅርኪ፡ አንሳሕስሖ፡ ለአርጋኖነ፡ ልብየ፡ ወመንፈሰ፡ ትንቢት፡ ሆኮ፡ ለከርሥየ፡ ወነፍስየኒ፡ ስእነት፡ ተዓግሶ፡ 
                           እምአርምሞ፡ ስብሐቲኪ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ኢትትኃሰብ፡ ኦወልድየ፡ 
                              <sic>ኆልቈ፡</sic>
                            ኃጣውኢሁ፡ ወኢትፍድዮ፡ በከመ፡ ኣባሳሁ፡ ወኢትትበቀሎ፡ በእንተ፡ ዘጌገየ፡ እመሂ፡ በሥጋሁ፡ ወእመሂ፡ በሕሊናሁ፡ 
                           ኣነ፡ እፈዲ፡ ኣስተብቍዖ፡ ወጸሎተ፡ በእንተ፡ ዕዳ፡ ዚኣሁ፨ ሣህለ፡ ዚኣከ፡ ወምሕረተ፡ ኣቡከ፡ ወኂሩተ፡ መንፈስ፡ ቅዱስ፡ 
                           ይመግቦ<add place="inline">
                              <supplied reason="omitted">ሙ፡</supplied>
                           </add> በኵሉ፡ ለገብር<del rend="erasure"/>
                        </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="156v" to="170v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Saturday">ʾArgānona wǝddāse, for Saturday</title>
                        <incipit xml:lang="gez">
                           እትጋነይ፡ ለዕበይኪ፡ ኦወለተ፡ ዳዊት፡ ወእሰግድ፡ ታሕተ፡ መከየደ፡ እገርኪ፡ ወእትመሃለል፡ ቅድመ፡ ገጽኪ፡ ኦወለተ፡ ሣህል፨ ግሩር፡ አነ፡ ለንግሠ፡ ወልድኪ፡ ኦወለተ፡ ምሕረት፨ ለይረድ፡ ላዕሌየ፡ ጠለ፡ 
                           ምሕረቱ፡ ለፍቁርኪ፡ ከመ፡ ጠለ፡ ኣርሞንኤም፡ ዘይወርድ፡ ዲበ፡ ኣድባረ፡ ጽዮን፡ ከማሁ፡ ይረድ፡ ላዕሌየ፡ ጠለ፡ ምሕ<supplied reason="omitted">ረ</supplied>ቱ፡ ለወልድኪ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ተፀወንኩ፡ ኪያኪ፡ ከመ፡ እትባላሕ፡ እመናግንቲሆሙ፡ ለእለ፡ ይትቃወምዋ፡ ለፍኖተ፡ ጽድቅ፨
                        </explicit>                     
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="179v" to="183r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1146Argano#Sunday">ʾArgānona wǝddāse, for Sunday</title>
                        <incipit xml:lang="gez">
                           ኣሌዕል፡ እደዊየ፡ ኃበ፡ ወልድኪ፡ ወእጸርኅ፡ እንዘ፡ እብል፡ ረድ፡ እግዚኦ፡ እምጽርኅከ፡ ወእመቅደስከ፡ ከመ፡ ትባልሐኒ፡ እምኵሉ፡ መከራ፡ ወእምኵሉ፡ ምንዳቤ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ሰኣሊ፡ ሊተ፡ በውዑይ፡ ሕሊና፡ በእንተ፡ ጻህቀ፡ ልብየ፡ ወሰርሕኒ፡ ከመ፡ ያዕርፍ፡ ላዕሌየ፡ በረከተ፡ አዳም፡ ወኣቤል፡ ወሴት፡ ወኵሎሙ፡ ኣበው፨ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           
                              <sic>ኆልቍኒ፡</sic>
                            ለወልድኪ፡ ምስለ፡ አግብርቲሁ፡ ወምስለ፡ ፍንዋን፡ ነቢያቲሁ፡ ወላእካን፡ ሐውርያቲሁ፨ ኣመ፡ ትሰፍን፡ 
                           ለወል<supplied reason="omitted">ድ</supplied>ኪ፡ መርዓሁ፨ ሰራዊተ፡ ሰማይ፡ ወምድር፡ በአሐዱ፡ ቃል፡ ኣመ፡ ይሴብሑ፨ ለዓለመ፡ ዓለም፡ አሜን፨ ወአሜን፨ ለይኩን፨ ለይኩን፨ 
                           በእንተ፡ ሥጋሁ፡ ወደሙ፡ ለክርስቶስ፡ ለይኩን፨
                        </explicit>                     
                     </msItem>

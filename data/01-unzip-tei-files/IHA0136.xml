                  <handDesc>
                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA0136#ms_i0"/>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1">
                        <locus target="#">-</locus>
                        <desc>Drawings / decorations</desc>
                        <q>Drawings, numbers, letters</q>
                        <note>Five-tagged stars with letters may be amulets.</note>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#140r">-140r</locus>
                           <desc>Fawā'id / Masā'il</desc>
                           <q>ولو مضى نحل على جماعة من الناس فتيعه رجل واحد منهم بقصد الاصطياد والصياح قندل الله بسبب ذلك على  نحو شجر</q>
                           <note>Note marked "Tuḥfat al-ḥabīb"</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#Throughout all the text">-Throughout all the text</locus>
                           <desc>Marginalia</desc>
                           <q>والاطراف والمكاني والاروش والحكومات في كل سنة ثلث دية فان كانت نصف دية ففي الاولى ثلث وفي الثانية سدس او ثلاثة ارباعها ففى الدولى ثلث وفى الثانية ثلث وفى الثالثة نصف سدس او ديتين ففى ست سنين صح تحفة</q>
                           <note>in the margins</note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#133r">-133r</locus>
                           <desc>Fawā'id / Masā'il</desc>
                           <q>مسلة النحل حرام مثل الباب بكونه من الحشرات وفي دودها [الرمع] العد ففيه بثلاثة اوجه</q>
                           <note>Note marked "Ḥāwī"</note>
                        </item>
                        <item xml:id="a4">
                           <locus target="#1r">-1r</locus>
                           <desc>Title</desc>
                           <q>الجزؤ السابع من تحفه المحتاج بشرح المنهاج للشيخ الامام العالم العلامة عين الجهابذة الاعلام شهاب الدين احمد ابن حجر الهيتمي الانصري نزيل مكة المشروفة اسكنه الله فى جنته ونفع المسلمين ببركته ورحم سلفه وابقى خلفه بخير وعافية ونعمة امين يا رب العالمين</q>
                           <note/>
                        </item>
                        <item xml:id="a5">
                           <locus target="#ii-iv">-ii-iv</locus>
                           <desc>Loose folio</desc>
                           <q>Drawings of five-tagged stars and words in Arabic script but only some form readable words.</q>
                           <note>Loose slips of paper with text and symbols.</note>
                        </item>
                     </t:list>
                  </additions>

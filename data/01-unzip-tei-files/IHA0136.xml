               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="163v">1r-163v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>في الجنة وقصره الذ من صلى عليه الف مرة في يوم لم يمت حتى يبشر بالجنة في اليقظة لا في النوم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#163v">-163v</locus>واغفر اللهم لنا ولعبيدك الفقراء ابائنا وامهاتنا وازواجنا وذرياتنا ولمن حضرنا ولوالديهم ولمؤلف هذه الصلوات البركات على </explicit>
                     <note>Vocalized. Occasionally a line ends with a single letter that is repeated in the beginning of the next line. The text ends abruptly in a middle of a sentence on fol. 163v.</note>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>

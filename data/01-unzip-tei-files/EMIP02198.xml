                    <decoNote type="frame" xml:id="d1">
                    Decorative designs:
                    <locus target="#43v" facs="044">fol. 43v</locus> (line of full stops and a line of alternating red and black dots).
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#7v #28r" facs="008 028">Fols. 7v, 28r</locus>
                    mentions emperor <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#7r" facs="007">Fol. 7r</locus>
                    mentions <persName ref="https://betamasaheft.eu/PRS3258CyrilIV">Cyril IV</persName> and <persName ref="https://betamasaheft.eu/PRS8388SalamaI">Salāmā III</persName>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="OwnershipNote">
                    <locus target="#31r" facs="031"> f. 31r and passim</locus>
                    mentions the owner Wäldä Rufaʾel (<foreign xml:lang="gez">ወልደ፡ ሩፋኤል፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                      words of text are written interlinearly (<locus target="#3v #6r #7r #14r #18v" facs="004 006 007 014 019">folss. 3v, 6r, 7r, 14r, 18v, </locus>, etc.);
                      erasure markings are visible (<locus target="#6v" facs="007">6v, </locus>);
                      text has been removed (<locus target="#14v #16v #20r #22v #23r" facs="015 017 020 023">14v, 16v, 20r, 22v, 23r</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with linen.</decoNote>

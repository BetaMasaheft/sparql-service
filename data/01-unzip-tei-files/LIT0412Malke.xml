      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ናሁ፡ ልብየ፡ በእደ፡ ኅሊናየ፡ አስተሐመመ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ ይጽሐፍ፡ እንዘ፡ ይእኅዝ፡ ቀለመ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ባርክ፡ ከመ፡ ቃለ፡ ነቢይ፡ ቀደመ፨</l>
                  <l n="4">እስመ፡ አንተ፡ ዘባረካሁ፡ ይትባረክ፡ ፍጹመ፨</l>
                  <l n="5">ወዘረገምከ፡ ይከውን፡ ርጉመ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ በሰሌዳ፡ መንፈስ፡ ሲሩክ፨</l>
                  <l n="2">ስም፡ ቅዱስ፡ ወስም፡ ቡሩክ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ሥጋዊ፡ እንዘ፡ ዓዲከ፡ መልአክ፨</l>
                  <l n="4">ለዝክረ፡ ስምከ፡ ስመ፡ ኢየሱስ፡ አምላክ፨</l>
                  <l n="5">ልሳነ፡ ፍጡራን፡ ይገኒ፡ ወይሰግድ፡ ብርክ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ እንተ፡ ኀበ፡ ክርስቶስ፡ አስተርአየ፨</l>
                  <l n="2">እንዘ፡ ይብል፡ ይትሐነጽ፡ መቃብረ፡ ሥጋከ፡ ዝየ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ በሥጋ፡ ህየንተ፡ ዘጾርከ፡ ሥቃየ፨</l>
                  <l n="4">ሥነ፡ ስብሐቲከ፡ እምስብሐተ፡ ጻድቃን፡ ዐብየ፨</l>
                  <l n="5">ወብርሃንከ፡ ያከፍእ፡ ፀሓየ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ንስቲተ፡ ነገርኩ፡ ከመ፡ ኢይኩን፡ ዝንጋዔ፨</l>
                  <l n="2">ስብሐተ፡ መልክእከ፡ አባ፡ ወዝክረ፡ ስምከ፡ በጽዋዔ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ባሕቱ፡ ተወከፍ፡ ቅድመ፡ ጉባኤ፨</l>
                  <l n="4">ሕገ፡ ተወክፈ፡ እግዚእከ፡ ቅድመ፡ ያጠይቅ፡ ትንሣኤ፨</l>
                  <l n="5">እምእደ፡ አሐቲ፡ ብእሲት፡ ጸራይቀ፡ ክልኤ፨</l>
               </lg>
            </div>
         </div>
      </body>

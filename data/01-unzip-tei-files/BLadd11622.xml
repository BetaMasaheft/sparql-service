                            <list>
                                <item xml:id="a1">
                                    <desc type="Doxology">Excerpt of a praise to Our Lady Mary</desc>
                                    <locus from="1" to="2"/>
                                    <note>The beginning and the end are missing.</note>
                                </item>
                                <item xml:id="a2">
                                    <desc type="Poem">Short rhymed poems to Our Lady Mary</desc>
                                    <locus from="3" to="4" cert="unknown"/>
                                </item>
                                <item xml:id="a3">
                                    <desc type="Record"/>
                                    <locus target="#5"/>
                                    <note>The note indicates the number of the words in the <title ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title> is written at the end of the work.
                                    </note>
                                </item>
                                <item xml:id="a4">
                                    <desc type="OwnershipNote"/>
                                    <locus target="#63v"/>
                                    <q xml:lang="gez">ዛቲ፡ መጽሐፍ፡ ዘተክለ፡ ሃይማኖት፡ ዘጸሐፈ፡ መዝገበ፡ ዳዊት፡ በመዋዕለ፡ አጽዋም።</q>
                                    <q xml:lang="en">"This book belongs to Takla Hāymānot. Who wrote [it] is Mazgaba Dāwit during the time of fasting"</q>
                                    <desc>The note states that the owner of the book is <persName role="owner" ref="https://betamasaheft.eu/PRS11112TaklaH">Takla Hāymānot</persName> and the scribe 
                                        is <persName role="scribe" ref="https://betamasaheft.eu/PRS11113MazgabaD">Mazgaba Dāwit</persName>.                                        
                                    </desc>
                                </item>
                            </list>
                        </additions>

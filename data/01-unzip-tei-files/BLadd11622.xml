                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus target="#5"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus target="#5"/>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT1828Mahale#Zachariah">Book of Odes, Song of Zachariah (ጸሎተ፡ ዘካርያስ፡ ካህን፡) (same as LIT2275salota)</title>
                                <note>Only the end, corresponding to <ref type="work" corresp="https://betamasaheft.eu/LIT1812GospelLuke">Wangel za-Luqās</ref> 1:79.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus target="#5"/>
                                <title ref="https://betamasaheft.eu/LIT1828Mahale#Simeon">Book
          of Odes, Song of Simeon, or Nunc Dimittis (ጸሎተ፡ ስምዖን፡ ነቢይ፡) (same as LIT2272salota)</title>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="5v" to="9"/>
                            <title>Prayer to Jesus Christ</title>
                            <incipit xml:lang="gez">
                                <locus target="#9v"/>
                                እግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ልዑል፡ ዲበ፡ ኵሉ፡ ኀይለ፡ ቅዱሳን፡ ሀበነ፡ ረድኤተከ፡ ከመ፡ ንሖር፡ በሕግከ፡ ወበሥርዓትከ፡ ኵሉ፡ መዋዕለ፡ ሕይወትነ፡ 
                                <gap reason="omitted" extent="unknown" resp="PRS4805Grebaut PRS9530Tisseran"/>
                            </incipit>
                            <note>An index of the feasts of the Apostles is added at the end of the text.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="10" to="17"/>
                            <title ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="18" to="42"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                            <note>The seven daily sections start from <ref type="work" corresp="https://betamasaheft.eu/LIT2509Weddas#Sunday"><span xmlns="" class="w3-tag w3-red">No item: LIT2509Weddas#Sunday</span></ref>.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="43" to="52"/>
                            <title ref="https://betamasaheft.eu/LIT4298Taamho">Taʾammǝḫotā la-Māryām</title>
                            <incipit xml:lang="gez">ንቀድም፡ ወንጽሐፍ፡ ተአምኆታ፡ ለማርያም፡ ድንግል፡ ዘከመ፡ አምኅዋ፡ በውስተ፡ ራብዕ፡ ሰማይ፡</incipit>
                            <note/>
                            <msItem xml:id="ms_i5.1">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Everybody">Salutation from everybody</title>
                            </msItem>
                            <msItem xml:id="ms_i5.2">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Priests">Salutation from the priests</title>
                            </msItem>
                            <msItem xml:id="ms_i5.3">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Deacons">Salutation from the deacons</title>
                            </msItem>
                            <msItem xml:id="ms_i5.4">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Martyrs">Salutation from the martyrs</title>
                            </msItem>
                            <msItem xml:id="ms_i5.5">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Righteous">Salutation from the righteous</title>
                            </msItem>
                            <msItem xml:id="ms_i5.6">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Monks">Salutation from the monks</title>
                            </msItem>
                            <msItem xml:id="ms_i5.7">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Virgins">Salutation from the chaste virgins</title>
                            </msItem>
                            <msItem xml:id="ms_i5.8">
                                <title ref="https://betamasaheft.eu/LIT4298Taamho#Believers">Salutation from the faithful</title>
                            </msItem>                       
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="52" to="63"/>
                            <title>Hymns, eight in number</title>
                            
                            
                            <msItem xml:id="ms_i6.1">
                                <locus from="52"/>
                                <title xml:lang="gez">ስብሐተ፡ ፍቁር፡ በዜማ፡ ዕዝል፡ በ፫ሃሌ፡ ሉያ፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.2">
                                <locus from="53"/>
                                <title xml:lang="gez">አስተምህሮ፡ ዘእግዚአብሔር፡ ዘምሮ፡ በ፫ሃሌሉያ፡ ዕዝል።</title>
                            </msItem>
                            <msItem xml:id="ms_i6.3">
                                <locus from="54"/>
                                <title xml:lang="gez">ግናይ፡ ዘእግዚአብሔር፡ አዶናይ፡ በ፪ሃሌ፡ ሉያ፡ ዕዝል፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.4">
                                <locus from="55" to="59"/>
                                <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2731RepCh15">መኃልይ፡ ዘእግዚአብሔር፡ ዐቢይ፡ በ፫ሃሌ፡ ሉያ፡ ዕዝል፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.5">
                                <locus from="59" to="60"/>
                                <title xml:lang="gez">ስብሐተ፡ ሐዲስ፡ ንፈኑ፡ ለክርስቶስ፡ በ፫ሃሌ፡ ሉያ፡ ዕዝል፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.6">
                                <locus from="60" to="61"/>
                                <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3018RepCh298">ተማኅፀንኩ፡ ዮም፡ በማርያም፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.7">
                                <locus from="61" to="62"/>
                                <title xml:lang="gez">ኦክርስቶስ፡ በሥጋ፡ ድንግል፡ ሐማሚ፡</title>
                            </msItem>
                            <msItem xml:id="ms_i6.8">
                                <locus from="62" to="63"/>
                                <title xml:lang="gez" ref="https://betamasaheft.eu/LIT3011RepCh291">ባርኮ፡ ወውዳሴ፡ ለማርያም፡ ስርጉተ፡ ለሥላሴ፡ በ፫ሃሌ፡ ሉያ፡ ዕዝል።</title>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i7">
                            <locus from="63" to="65"/>
                            <title type="incomplete">Malkǝʾ-hymn to Jesus Christ</title>
                            <note>Unspecified work. The end is missing.</note>
                        </msItem>
                    </msContents>
                    

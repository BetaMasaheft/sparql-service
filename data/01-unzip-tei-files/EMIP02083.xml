                     <locus from="43r" to="50v" facs="045">Fols 43r–50v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5690MagicPrayer">Ṣalot baʾǝnta
                                                  ʿayna ṭǝlā wa-ʿayna warq ṣelota nədrā zəwəʾǝtu
                                                  ḥǝmāma ʿayna ʾəkkuy</title>

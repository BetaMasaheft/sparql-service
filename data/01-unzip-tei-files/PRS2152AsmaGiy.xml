         <listPerson>
            <person sex="1">
             
                  <persName xml:lang="gez" xml:id="n1" type="birth">አጽመ፡ ጊዮርጊስ፡ ገብረ፡ መሲሕ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAṣma Giyorgis Gabra Masiḥ</persName>
               <persName xml:lang="gez" xml:id="n2" type="birth">አለቃ፡ አጽሜ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAlaqā ʾAṣme</persName>
               <persName xml:lang="gez" xml:id="n3" type="birth">አለቃ፡ አጥሜ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">ʾAlaqā ʾAṭme</persName>
                  <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾalaqā</t:roleName>
               </persName>
                  <t:nationality xmlns:t="http://www.tei-c.org/ns/1.0" type="Ethiopia"/>
                  <t:faith xmlns:t="http://www.tei-c.org/ns/1.0" type="Catholicism"/>
               
                  <occupation type="literary">writer</occupation>
                  
               <birth when="1850">He was born at <placeName ref="https://betamasaheft.eu/LOC3806HarrAm">Ḥārr ʾAmbā</placeName> in 
                  <placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</placeName> in <date>1820</date>. </birth>
               <t:floruit xmlns:t="http://www.tei-c.org/ns/1.0" notBefore="1850" notAfter="1915">He was one of the most prolific writers of the 
                  <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk II</persName> era. 
                  He wrote a number of works on historical and religious themes but the most famous one is 
                  <ref type="work" corresp="https://betamasaheft.eu/LIT2537Yagall">Yagāllā tārik yašawā mangǝśt</ref>. 
                  He was educated by his father who was a clergyman, as well as by his maternal uncle,
                  the famous church scholar 
                  <persName ref="https://betamasaheft.eu/PRS9198Taklase"> 
                     <t:roleName type="title">ʾalaqā</t:roleName> Takla Ṣǝyon ʾƎnyaw</persName>.
                  Later he came in contact with Catholic missionaries at 
                  <placeName ref="https://betamasaheft.eu/LOC1464Ankoba">ʾAnkobar</placeName> from whom he learnt French and Latin. 
                  He rendered his services to both the Ethiopian government and Catholic Church as a soldier, scribe, judge, 
                  dragoman and teacher. </t:floruit>
               <death when="1915"> He died at <placeName ref="https://betamasaheft.eu/LOC3806HarrAm">Ḥārr ʾAmbā</placeName>. </death>
               </person>  
               
         </listPerson>

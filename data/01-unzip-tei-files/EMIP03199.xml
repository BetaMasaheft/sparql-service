                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word for God is not rubricated</desc>
                  <desc>The manuscript employs columetric rubrication in both Psalm 150 and the tenth Biblical Canticle</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1v" facs="002">Fol. 1v</locus><desc>crude drawing of an <ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#2r" facs="002">Fol. 2r</locus><desc>indecipherable shapes</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc>Prayer in Amharic and Ge'ez for deliverance from various ills</desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#3v #4r" facs="004">Fols. 3v, 4r</locus>
                    <desc>Hymn to Our Lady, "Rejoice, Mary, to Adam's pasch."
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#165r #165v" facs="165 166">Fols. 165r, 165v</locus>
                    <desc type="GuestText"><title type="incomplete" ref="https://betamasaheft.eu/LIT3977Taammer">Taʾammǝra Gabra
                                                  Manfas Qǝddus</title>, one miracle</desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc>pen trial, based on the trinitiarian formula</desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc>crudely written text</desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#4v" facs="005">Fol. 4v</locus>
                    <desc>pen trials</desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#75v" facs="076">Fol. 75v</locus>
                    <desc>The midpoint is marked by a small cross in the gutter margin</desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#148v" facs="149">Fol. 148v</locus>
                    <desc type="OwnershipNote">Secondary note of ownership, <q><foreign xml:lang="gez">ዝ፡ ዘክፍለ፡ ሥላሴ፡ ወብዕደ፡ ማርያም፡</foreign></q>
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <desc>
                    This entry employs some information from Macomber, William F. “Catalogue of oriental manuscripts in the library of Seabury-Western Theological Seminary, Evanston, Illinois.” Le Muséon 92 (1979) 369–386
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment. Wooden boards, covered partially with with tooled leather and partially with blue fabric.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

               <msContents>
                  <summary>Psalter</summary>

                  <msItem xml:id="ms_i1"><locus from="5r" to="166r" facs="005">Fols 5r–166r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1"><locus from="5r" to="149v" facs="005">Fols 5r–149v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note><locus target="#120v" facs="121">Fol. 120v</locus>The spiritual meaning of the Hebrew letters in Psalm 118 is not given; only the names of the letters are rubricated</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has all four plusses that make up the long version of the Psalm. The long plus here is a slightly variant reading of the plus compared to other mss</note>
                    </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="150r" to="160r" facs="150">Fols 150r–160r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note><locus target="#152r" facs="152">Fol. 152r</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> designated as <q>"Prayer of Hana, mother of Samuel, prophet."</q></note>
                    </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="160r" to="165r" facs="160">Fols 160r–165r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <note>Common edition</note>
                    </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="166r" to="174v" facs="166">Fols 166r–174v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                          <msItem xml:id="ms_i1.4.1"><locus from="166r" facs="166">Fols 166r and following</locus><title>Monday</title></msItem>
                          <msItem xml:id="ms_i1.4.2"><locus from="166v" facs="167">Fols 166v and following</locus><title>Tuesday</title></msItem>
                          <msItem xml:id="ms_i1.4.3"><locus from="168r" facs="168">Fols 168r and following</locus><title>Wednesday</title></msItem>
                          <msItem xml:id="ms_i1.4.4"><locus from="169v" facs="170">Fols 169v and following</locus><title>Thursday</title></msItem>
                          <msItem xml:id="ms_i1.4.5"><locus from="171v" facs="172">Fols 171v and following</locus><title>Friday</title></msItem>
                          <msItem xml:id="ms_i1.4.6"><locus from="172v" facs="173">Fols 172v and following</locus><title>Saturday</title></msItem>
                          <msItem xml:id="ms_i1.4.7"><locus from="173v" facs="174">Fols 173v and following</locus><title>Sunday</title></msItem>
                        </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="174v" to="178v" facs="175">Fols 174v–178v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                </msItem>
              </msItem>
               </msContents>

                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus from="1" to="2"/>
                              <desc type="GuestText">
                                Account of the Miracles of the blessed virgin Mary
                              </desc>
                              <q xml:lang="gez"/>
                            </item>
                            <item xml:id="a2">
                                <locus target="#3r"/>
                                <desc type="OwnershipNote">The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                </desc>
                                <q xml:lang="gez">ግንዘት፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኀኔ፡ ዓለም።</placeName></q>
                            </item>
                            <item xml:id="a3">
                              <locus from="113"/>
                              <desc type="GuestText">
                                Short story of the blessed Virgin Mary
                              </desc>
                              <q xml:lang="gez"/>
                            </item>
                            <item xml:id="e1">
                              <desc>In the colophon (<ref target="#coloph1"/>), the
                            scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS13510TaklaS">Takla Śǝllāse</persName> states that
                          he wrote the manuscript at the expense of <persName role="donor" ref="https://betamasaheft.eu/PRS13511KidanaM">Kidāna Māryām</persName>
                        and his brother <persName role="donor" ref="https://betamasaheft.eu/PRS13513WaldaI">Walda ʾIyasus</persName>. The name of
                      <persName ref="https://betamasaheft.eu/PRS13512WalattaH">Walatta Hāymānot</persName> is also mentioned. The manuscript was written
                    for <foreign>ታቦተ፡ አማኑኤል</foreign>, possibly to be identified with
                    <placeName ref="https://betamasaheft.eu/INS0925Amanuel">ʾAmānuʾel</placeName>.</desc>
                            </item>
                          </list>

                        </additions>
                        <bindingDesc>
                            <binding contemporary="true" xml:id="binding">
                                <decoNote xml:id="b1">In the original boards, lined with silk and covered with blind-tooled leather.</decoNote>
                                <decoNote xml:id="b2" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                    <material key="silk"/>
                                </decoNote>
                            </binding>
                        </bindingDesc>

                    </physDesc>

                    <history>
                        <origin>

                            <origDate notBefore="1777" notAfter="1796" evidence="prosopography">The manuscript contains the names of <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis I</persName>,
                          <persName ref="https://betamasaheft.eu/PRS10450YosabI">Yosāb II</persName>, and <persName ref="https://betamasaheft.eu/PRS5713JohnXVI">John XVIII</persName>
                          (<locus target="#179v #180r"/>).</origDate>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area, 
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted 
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.
                        </provenance>

                    </history>


                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Part of the collection of Haroutune Nazarian, who had microfilms made of his Ethiopian manuscripts and the microfilms sent to the Institute of Ethiopian Studies. They were digitized by EMIP workers in Addis Ababa in the first half of 2010
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#Inside cover" facs="001">Fols. Inside, </locus>
                    a name plate indicates this book is “Ex Libris Haroutune Hazarian” and is 287. The microfilm information plate (image 126) indicates that the manuscript was microfilmed in 1982 and assigned the number 100
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc type="RecordTransaction">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    Two record of transaction. The upper record is indecipherable, though one can read the judge and the guarantor.  The lower record is also for an unspecified transaction and lists witnesses, guarantor, and judge
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#55r" facs="055">Fol. 55r</locus>
                    The midpoint of the Psalms is marked with a small text in a box: <foreign xml:lang="gez">መንፈቁ፡ ዝየ፡ ውእቱ</foreign>
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#92v #93r" facs="093">Fols. 92v, 93r</locus>
                    missed shot
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#122r" facs="122">Fol. 122r</locus>
                    directions for the recitation of the Psalms when facing specific situations, e.g., riding a horse, protection from wild animals, and from harmful potion, etc.
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

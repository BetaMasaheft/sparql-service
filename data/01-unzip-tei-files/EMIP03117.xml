         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Hazarian Collection, Ms </repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3117/" n="126" corresp="https://betamasaheft.eu/api/iiif/EMIP03117/manifest">Hazarian Collection, Ms 100</idno>
               </msIdentifier>
               <msContents>
                  <summary>18.5</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="119v" facs="001">Fols 1r–119v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Incomplete, the Book of Song of Songs is missing completely. Gate of Light is missing altogether</note>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="101v" facs="001">Fols 1r–101v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><locus target="#3r #3v #4r #4v #5r #5v" facs="003 004 005 006">Fols. 3r, 3v, 4r, 4v, 5r, 5v</locus> The first few folios of the Psalms contain notes in the upper margin giving directions for the recitation of the Psalms when facing specific situations</note>
                    <note><locus target="#103v" facs="104">Fol. 103v</locus> Psalm 151 has only the first of the plusses and constitutes the short version</note>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="101v" to="111v" facs="102">Fols 101v–111v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note>The original superscription of the fourth canticle is "Prayer of Hana, mother of Samuel.” A second hand has added the word “Prophet" at the end</note>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="112r" to="119v" facs="112">Fols 112r–119v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <note>incomplete at the end, going only through the first part of the reading for Saturday</note>
                    <note>The Praises of Mary are laid out to begin on Monday and culminate on Sunday</note>
                  </msItem>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="122v" to="123r" facs="123">Fols 122v–123r</locus>
                    <title>The list of the spiritual meanings of the Hebrew Letters in Psalm 118. Each superscription is given along with the first line of each section</title>
                  </msItem>
                  </msContents>

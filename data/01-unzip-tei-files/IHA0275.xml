               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="152r">2r-152r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>وما أن سانه الا الشيطان ان اذكره واتخد سبيله في البحر عجبا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#152r">-152r</locus>الذي يوسوس في صدور الناس من الجنة والناس</explicit>
                     <note>The text begins in the middle of verse 18:63 and ends with sūra 114. Most of the sūra headings missing. Catchwords missing. Vocalized. Words divided into two lines.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="152r" to="152v">152r-152v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3815IHA">دعاء ختم القران اللهم انفعنا بالقران العظيم واهدنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#152r">-152r</locus>بسم الله [الرحمن الرحيم] لحمد لله وسلام على ارسول لله صدق لله لعلي لعظيم [...] للهم أنفعنا بالقران العظيم واهدنا بالايات والذكر الحكيم وتقبل منا ختم القران وتجاوز انا كان فى تلاوة العران من خطا او نسيان او زيادة أ نقصان  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#152v">-152v</locus>للهم اغفر لنا ولوالدىنا ولاستاذنا ولمشا[.؟.] ولمن اوها [.؟.] ولاهالنا ولاخواننا ولجميع قرابن</explicit>
                     <note>Poor handwriting</note>
                     <note/>
                  </msItem>
               </msContents>

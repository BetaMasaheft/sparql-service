               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="5r">1r-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0710IHA">تخميس القصيدة المضرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>وأخلصوا دينهم لله فاعتمدوا \ قول النبي بما قد جأهم شهدوا \ وصدقه وما صدوا وما حجدوا \ وجاهدوا معه لله واجتهدوا وهاجروا وله أو واو قد نصروا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>يا رب نسئلك الرضى ومغفرة \ وهب لنا يا إلهي منك عافية \ واجعل صلاة على المختار دائمة \ كذالك الرسل والأملاك قاطبة والأل والصحب والأتباع ما ذكروا تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="5v" to="7v">5v-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0039IHA">حزب ﺍلامام النوﻭﻱ</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>بسملة, بسم الله الله أكبر الله أكبر الله أكبر قول على نفسي وعلى ديني وعلى اهلي وعلى اولادي وعلى مالي وعلى اصحابي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7v">-7v</locus>أللهم عن نفسي \ ما أطيق وما لا أطيق ولا طاقة لمخلوق مع قدرة \ الخالق حسبي الله ونعم الوكيل وصلى الله على سيدنا \ محمد وعلى اله و \ صحبه وسلم ثم تقرأ الفاتحة ۲ \ للمصنف رحمه الله تعالى تقرأ صباحا ومساء بعد الصبح \ مرة وبعد المغرب مرة </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="7v" to="9r">7v-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2941IHA">حزب البحر</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>بسملة \ يا على يا عظيم يا حليم يا عليم انت ربي وعلمك \ حسبي فنعم الرب ربي ونعم الحسب حسبي تنصر \ من تشاء وانت العزيز الرحيم نسئلك العصمة في \\ الحركات والسكنات  

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>ثلثا بسم الله الذي لا يضر مع اسمه شئ في الا \ رض ولا في السماء وهو السميع العليم ثلثا ولا حول \ ولا فوة الا بالله العلي العظظيم وصلى الله على سيدنا محمد وعلئ اله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="9v" to="11r">9v-11r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4051IHA">صلوات منجية</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>اللهم انك اطيتنا اجل ما عندك وهو الايمان من قبل \ مسئلة ولا تحرمنا اقل ما عندك وهو الغفران بعد \ مسئلة  اللهماعطنا أمل الرجاء وفوق الامل يا من نفضله \ نسئل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>صاحب القبضة \ الاصلية والبهجة السنية والرتبة العلية من اندرج \ النبيون تحت لوائه فهم منه واليه وصلى وسلم وبارك وأمت واحييت الى يوم تبعث من أفنيت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="11v" to="12v">11v-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4053IHA">دعاء الحرف الذي مداده من نور ذات الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#11v">-11v</locus>الحرف الذي مداده من نور ذات الله الشكل الذي مدده من كنز مكنون سر الله اللهم همزة ألف البدايات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>اللهم المخاطب بقوله عز وجل قل يايها الناس اني رسول الله اليكم جميعا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="13r" to="131v">13r-131v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT0086IHA">دلائل الخيرات</title>
                     <incipit xml:lang="ar">
                        <locus target="#47v">-47v</locus>بسملة \ وصلى الله على سيدنا محمد وعلى اله وصحبه \ وسلم الحمد لله هدانا للايمان والاسلام \ والصلاة على محمد نبيه الذي استنقذنامن \ عبادة الاوثان والاصنام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28v">-28v</locus>وشبتنا على النور وآخشرنا \ إلى النور فقد قلت في سورة \ النور ومن لم يجعل الله له نورا \ فما له نور وصلى الله على [سيدنا]ا<note>Last lines of the "Duʻāʼ ḫātima" begininng at f. 25v</note>
                     </explicit>
                     <note>The quires are disrupted. Correct order: ff. 47-132; 29-42; 13-28</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="43r" to="46v">43r-46v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4054IHA">انوار المجرد في مدح سيدنا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#43r">-43r</locus>اللهم صل على سيدنا محمد وإله \ اللهم صل على سيدنا محمد وصحبه \ ونحمد مولانا على عظم شانه \ ونثني عليه أن هدانا لدينه \ ببعث النبي الهاشمي محمد \ بأفضل ملة وأقوم شرعه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#46v">-46v</locus>وسلم عموم المسلمين بأسرهم \ مما يوجب الحلول دار انتقامه \ وسلم عموم المومنين بأسرهم \ مما يوجب الحلول دار اشتعاله</explicit>
                     <note/>
                     <note/>
                  </msItem>

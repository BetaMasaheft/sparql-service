                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red (vivid amaranth)</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሚ፡ ወገ፡ ሱ፡ ወኪ፡ ዑ፡ ወሩ፡ ሱ፡ ወፋ፡ አ፡ ወራ፡ ወሳ፡</abbr> for <expan>ሚካኤል፡
                                 ወገብርኤል፡ ሱራፌል፡ ወኪሩቤል፡ ዑራኤል፡ ወሩፋኤል፡ ሱርያል፡ ወፋኑኤል፡ አፍኒን፡ ወራጉኤል፡ ወሳቁኤል።
                              </expan> (<locus target="#12v">12v</locus>)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; a few lines on the incipit page,
                           alternating with black lines; abbreviations; notes indicating readings
                           for parts of the day; elements of the punctuation signs; elements of
                           Ethiopic numerals; some other words, halle luya (fol. 2r), salām (e.g.,
                           fols. 5v, 6r).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="2r" to="12r">2r-12r</locus>
                        
                     </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="12r" to="15v">12r-15v</locus>
                        
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#17r">f. 17r</locus>
                           <desc>: Excerpt of Nägś-hymn.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> In hand A. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#17v">f. 17v</locus>
                           <desc>: Note on the Commissioner.</desc>
                           <quote xml:lang="gez">
                              <locus target="#17v">17v</locus>: ዛቲ፡ መጽሃፍ፡ የጌታየ፡ ሀለቃ፡ ተክለ፡ ሀይማኖት፡
                              ክቡር፡ ወልዑል፡ ዘተሳየጣ፡ በወርቁ፡ ዘትከውን፡ መርሃ፡ ለኵሉ።</quote>
                           <quote xml:lang="en"/>
                           <note> A note in marker mentioning haläqa Takla Hāymānot as the
                              commissioner. </note>
                        </item>
                        <item xml:id="e1">- Immediate correction marked by dashes and thin lines
                           above and below words: <locus target="#2v">2v</locus>, 4r, 7v, 11v.
                           - Correction written interlineally: <locus target="#6r">6r</locus>.</item>
                     </list>
                  </additions>

            <msContents>
              <msItem xml:id="p2_i1">
                <locus from="1r" to="11v"/>
                <title> Magic prayer against cough. </title>
                <textLang mainLang="gez"/>
                <incipit xml:lang="gez">
                  <t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="lost">በሰመ፡</t:supplied>
                  <hi rend="rubric"> አብ፡ ወወልድ፡ ወመንፈስ፡ ቅ</hi> አሐዱ፡ አምላክ። ጸሎት፡ ወ<hi rend="rubric">ስእለት፡ ወአስተብቊዖት፡ <gap reason="lost"/>
                  </hi>ት፡ ዘእግዝእትነ፡ ማርያም፡ </incipit>
              </msItem>
              <msItem xml:id="p2_i2">
                <locus from="15r" to="55r"/>
                <title ref="https://betamasaheft.eu/LIT1201Bartos">Bārtos</title>
                <textLang mainLang="gez"/>
              </msItem>
              <msItem xml:id="p2_i3">
                <locus from="57r" to="65v"/>
                <title> Marian prayer. </title>
                <textLang mainLang="gez"/>
                <incipit xml:lang="gez">
                                    <hi rend="rubric"> በስመ፡ አብ፡ ወወልድ፡ ወመን</hi>ፈስ፡ ቅዱስ፡ አሐዱ፡
                    አምላ<hi rend="rubric"> ክ። ወበውእቱ፡ መዋዕል፡ አን</hi>ሥአት፡ ማርያም፡ ወሖረት፡ <hi rend="rubric">ሓቅለ፡ ወቦአት፡ ቤቶ፡ ለዘ</hi>ካርያስ፡ ደወለ፡ ዐይነ፡ ካርም፡ ደወለ፡ ዛብሎን፡ ወማዕዶተ፡ ሓይቀ፡ ዮርዳኖስ፡ ወጰራልዩ።
                </incipit>
              </msItem>
              <msItem xml:id="p2_i4">
                <locus from="67r" to="81r"/>
                <title ref="https://betamasaheft.eu/LIT6729PrayerWater"> One of the 21 prayers of Mary, prayed over water,
                  oil and images. </title>
                <textLang mainLang="gez"> </textLang>
                <incipit xml:lang="gez">
                                    <hi rend="rubric"> በስመ፡ አብ፡ ወወልድ ወመ</hi>ንፈስ፡ ቅዱስ፡ አሐዱ፡
                    አምላ<hi rend="rubric"> ክ። ለከ፡ ንወጥን፡ በረድኤተ፡ </hi> እግዚአብሔር፡ አምላከነ፡ ሎ<hi rend="rubric">ቱ፡ ስብሐት፡ በእንተ፡ ጽሒፈ፡</hi> ጸሎት፡ ዘእም፳ወ፩ለእግዚእትነ፡ ድንግል፡ ማርያም፡ <gap reason="ellipsis"/> ዘይትነበብ፡ ላዕለ፡ ማይ፡ <gap reason="ellipsis"/> ወጼልዩ፡ ላዕለ፡ ዘይት፡
                </incipit>
              </msItem>
              <msItem xml:id="p2_i5">
                <locus from="82r" to="86r"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT5013Prayer">Magic prayer to Mary</title>
                <textLang mainLang="gez"> </textLang>
              </msItem>
              <msItem xml:id="p2_i6">
                <locus from="86v" to="97r"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                <textLang mainLang="gez"> </textLang>
                <incipit xml:lang="gez">
                                    <hi rend="rubric"> በስመ፡ አብ፡ ወወልድ ወመንፈስ፡ ቅዱስ።</hi> አሐዱ፡ አምላክ።
                    ጸሎት፡<hi rend="rubric"> ዘእግዚእትነ፡ ማርያም። </hi> ዘጸለየት፡ ወትቤ። በርታፍ<hi rend="rubric">ዮስ። ተሐዝልፍዮስ። ዐምድ፡</hi> ወዮስ። ዘቆሮልዮስ። </incipit>
              </msItem>
              <msItem xml:id="p2_i7">
                <locus from="98r" to="108r"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                <textLang mainLang="gez"> </textLang>
                <incipit xml:lang="gez">
                  <hi rend="rubric">አውሎግሶን፡ ኢየሱስ፡ ክርስቶስ፡ ለይኩን፡ ብርሃኑ፡ ለእግዚአብ</hi>ሔር፡ አምላከነ፡ ላዕሌነ፡
                  ወይሰርሕ፡ ለነ፡ ተግባረ፡ እደዊነ። ወእም<hi rend="rubric">ዝ፡ ንጽሐፍ፡ ወንዘከር ውዳሴሃ፡ ለእግዚእትነ፡ ቅድስት፡
                    ማርያም፡</hi> ድንግል። </incipit>
              </msItem>
              <msItem xml:id="p2_i8">
                <locus from="109r" to="142v"/>
                <title> Prayer of supplication, pleading and praise to Mary. </title>
                <textLang mainLang="gez"> </textLang>
                <incipit xml:lang="gez">
                  <hi rend="rubric">ጸሎት፡ ወ</hi>ስእለት፡ ወአስተብቊዖት፡ ወውዳስያት፡ ወተማኅፅኖት፡ ኀበ፡ እግዝእትነ፡ ማርያም፡
                  ድንግል፡ </incipit>
              </msItem>
              <msItem xml:id="p2_i9">
                <locus from="145r" to="161r"/>
                <title ref="https://betamasaheft.eu/LIT1295Dersan#HomilyTimothy">Dǝrsāna Mikāʾel Homily by Timothy
                  (Damātēwos), Patriarch of Alexandria for the 12th of Ḫǝdār.</title>
                <textLang mainLang="gez"> </textLang>
                <incipit xml:lang="gez">
                  <hi rend="rubric">በስመ፡ አብ፡ ወወልድ ወመን</hi>ፈስ፡ ቅዱስ። አሐዱ፡ አምላ<hi rend="rubric">ክ።
                    ድርሳን፡ ነገር፡ ዘቅዱስ፡ አ</hi>ባ፡ ደማቴዎስ፡ ሊቀ፡ ጳጳሳት፡ <hi rend="rubric">ለእስከንድርያ፡ በበዓለ፡
                    ሊቀ፡</hi> መላእክት፡ ሚካኤል፡ </incipit>
              </msItem>
            </msContents>


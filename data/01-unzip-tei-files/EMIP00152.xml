               <msContents>
                  <summary>Harp of Praise, አርጋኖነ፡ ውዳሴ፡; Twenty-one Miracles of Mary, ተአምረ፡ ማርያም፡; Prayer to Jesus. “O Lord Jesus Christ, Son of the Living God, for the sake of Mary, your mother, help me.”</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="129v" facs="002">Fols 2r–129v</locus>
                     <title ref="https://betamasaheft.eu/LIT1344enzira">ʿƎnzirā
                                                  sǝbḥat</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                     <msItem xml:id="ms_i1.1"><locus from="2r" to="19r" facs="002">Fols 2r–19r</locus><title>Monday</title>
                      <msItem xml:id="ms_i1.1.1"><locus from="19r" to="20r" facs="019">Fols 19r–20r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3663Miracle">Miracle of Mary:
                                                  Miracle of a bandit saved by Mary after having
                                                  stolen from churches</title></msItem>
                      <msItem xml:id="ms_i1.1.2"><locus from="20r" to="21v" facs="020">Fols 20r–21v</locus><title type="complete" ref="https://betamasaheft.eu/LIT5658MMKing">Miracle of Mary: A
                                                  king whom the people wants to adore consults a
                                                  wise woman, who has a vision of Mary and
                                                  Christ</title></msItem>
                     <msItem xml:id="ms_i1.1.3"><locus from="21v" to="22v" facs="022">Fols 21v–22v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3919Miracle">Miracle of Mary:
                                                  Miracle of the sinful deacon ʾAstirās whom Mary
                                                  ordered to be buried in the believers'
                                                  graveyard</title></msItem>
                      </msItem>

                     <msItem xml:id="ms_i1.2"><locus from="22v" to="39r" facs="023">Fols 22v–39r</locus><title> Tuesday</title>
                      <msItem xml:id="ms_i1.2.1"><locus from="39r" to="39v" facs="039">Fols 39r–39v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3612Miracle">Miracle of Mary:
                                                  Miracle of the Phoenician evil man called
                                                  Bārok</title></msItem>
                      <msItem xml:id="ms_i1.2.2"><locus from="39v" to="40r" facs="040">Fols 39v–40r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3906Miracle">Miracle of Mary:
                                                  How the Virgin Mary obtained entry to paradise for
                                                  the soul of a monk who had kept her fast
                                                  annually</title></msItem>
                      <msItem xml:id="ms_i1.2.3"><locus from="40r" to="41r" facs="040">Fols 40r–41r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3613Miracle">Miracle of Mary:
                                                  Miracle of Anastasius, a deacon of Rome</title></msItem>
                    </msItem>


                     <msItem xml:id="ms_i1.3"><locus from="41r" facs="041">Fols 41r and following</locus><title>Wednesday</title>
                      <msItem xml:id="ms_i1.3.1"><locus from="58v" to="59v" facs="059">Fols 58v–59v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3726Miracle">Miracle of Mary:
                                                  Miracle of a Jewish boy from Tyrus, saved by Mary
                                                  from the furnace</title></msItem>
                      <msItem xml:id="ms_i1.3.2"><locus from="59v" to="60v" facs="060">Fols 59v–60v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3617Miracle">Miracle of Mary:
                                                  Miracle of a pregnant woman</title></msItem>
                      <msItem xml:id="ms_i1.3.3"><locus from="60v" to="61r" facs="061">Fols 60v–61r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3597Miracle">Miracle of Mary:
                                                  Miracle of Juliana and Barbara from
                                                  Bethlehem</title></msItem>
                    </msItem>

                    <msItem xml:id="ms_i1.4"><locus from="61r" to="81r" facs="061">Fols 61r–81r</locus><title>Thursday</title></msItem>
                      <msItem xml:id="ms_i1.4.1"><locus from="81r" to="82r" facs="081">Fols 81r–82r</locus><title>How the Virgin Mary appeared to reassure an ascetic woman about the purity of her friends, other ascetic women in the monastery (Princeton Ethiopic 8, ff. 19v–21r; Princeton Ethiopic 20, ff. 5v–6r, 31r, and 75rv; MYS 1, ff. 82v–83r)</title></msItem>
                      <msItem xml:id="ms_i1.4.2"><locus from="82r" to="82v" facs="082">Fols 82r–82v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3588Miracle">Miracle of Mary:
                                                  Miracle of a picture of Mary speaking to a
                                                  worker</title></msItem>
                      <msItem xml:id="ms_i1.4.3"><locus from="82v" to="83r" facs="083">Fols 82v–83r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3605Miracle">Miracle of Mary:
                                                  Miracle of George the Younger, who was delivered
                                                  from prison</title></msItem>
                    </msItem>

                     <msItem xml:id="ms_i1.5"><locus from="83v" to="101r" facs="084">Fols 83v–101r</locus><title>Friday</title>
                       <msItem xml:id="ms_i1.5.1"><locus from="101r" to="101v" facs="101">Fols 101r–101v</locus><title type="complete" ref="https://betamasaheft.eu/LIT5008MiracleScorpionSwallowed">Miracle of Mary: Miracle of a sinful woman who
                                                  swallowed a scorpion</title></msItem>
                       <msItem xml:id="ms_i1.5.2"><locus from="101v" to="102r" facs="102">Fols 101v–102r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3652Miracle">Miracle of Mary:
                                                  Miracle of the drunk monk Timotewos (?), saved by
                                                  the Virgin</title></msItem>
                       <msItem xml:id="ms_i1.5.3"><locus from="102r" to="103r" facs="102">Fols 102r–103r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3590Miracle">Miracle of Mary:
                                                  Miracle of the scribe Damianus from
                                                  Philippi</title></msItem>
                     </msItem>

                     <msItem xml:id="ms_i1.6"><locus from="103r" to="113v" facs="103">Fols 103r–113v</locus><title>Saturday</title>
                       <msItem xml:id="ms_i1.6.1"><locus from="113v" to="114r" facs="114">Fols 113v–114r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3915Miracle">Miracle of Mary:
                                                  How the Virgin Mary rebuked a woman who gave up
                                                  fasting at her husband's command</title></msItem>
                       <msItem xml:id="ms_i1.6.2"><locus from="114r" to="114v" facs="114">Fols 114r–114v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3652Miracle">Miracle of Mary:
                                                  Miracle of the drunk monk Timotewos (?), saved by
                                                  the Virgin</title></msItem>
                       <msItem xml:id="ms_i1.6.3"><locus from="115r" to="115v" facs="115">Fols 115r–115v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3921Miracle">Miracle of Mary:
                                                  How the image of the Virgin Mary in a Church bowed
                                                  to the monks</title></msItem>
                     </msItem>

                     <msItem xml:id="ms_i1.7"><locus from="115v" to="123r" facs="116">Fols 115v–123r</locus><title>Sunday</title>
                     <msItem xml:id="ms_i1.7.1"><locus from="123v" facs="124">Fols 123v and following</locus><title ref="https://betamasaheft.eu/LIT3633Miracle">Miracle of Mary:
                                                  Five Pains of the Virgin, Conversation of the
                                                  Virgin and Jesus Christ; promise of salvation to
                                                  those who recite the Paternoster and Ave
                                                  Maria</title></msItem>
                     <msItem xml:id="ms_i1.7.2"><locus from="124r" to="124v" facs="124">Fols 124r–124v</locus><title>How the Virgin Mary spoke through an icon to Abba Kiros; how she commanded him to keep the remains of his father;
                       how she made a covenant with him to effect forgiveness for 300 souls each day</title>
                       <note>This miracle is not in any of the other manuscripts EMIP cataloguers have studied, nor in Budge</note>
                     </msItem>
                     <msItem xml:id="ms_i1.7.3"><locus from="124v" to="126r" facs="125">Fols 124v–126r</locus><title type="complete" ref="https://betamasaheft.eu/LIT5178MiraclePrefect">Miracle of
                                                  Mary: The wrath of St Mary against the prefect of
                                                  a church who tried to stop the priests from making
                                                  a procession while singing hymns to her</title></msItem>
                   </msItem>

                  <msItem xml:id="ms_i3"><locus from="126r" to="129r" facs="126">Fols 126r–129r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3090RepCh370">Hymn to Jesus
                                                  Christ</title></msItem>


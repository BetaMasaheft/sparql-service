               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="19v">1r-19v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0101IHA">شرح الورقات لامام الكاملية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم وبه نستعين الحمد لله رب العالمين والصلاة والسلام على سيدنا محمد سيد المرسلين حبيب الله ابي القاسم صلى الله عليه وسلم وعلى اله وصحبه وسلم اما بعد فهذا تعليق على الورقات المنسوبة لشيخ الامام البحر الرباني عبد الملك امام الحرمين رضي الله عنه وارضاه ونفعني ببركاته . سالني بعض العلماء العاملين في وضعها عليها فلم يمكنني مخالفته فوصعته مستعينا بالله مع قلة البضاعة ما بحصاله مما وقفت عليهم من شروحها وغير ذلك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>لكن لا دلالة فيه لان القضية الشرطية لا تدلّ على وقوع سلمناه لكن الخطا متصور عند القائلين بان كل مجتهد مصيب فيما اذا كان نصّ او اجماع او قياس او ظنّ المجتهد غيره بعد والله اعلم بالصواب واليه المرجع والماب</explicit>
                     <note>Some words are divided into two different lines
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="20r" to="20r">20r-20r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3396IHA">حاشية الصلاة المطلسمة</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>هذه الصلاة للشيخ عبد السلام بن مشيشك يساوي فيما الفضل دلآئل الخيرات سبعين مرة اللهم معناه يا الله والميم بدل من يا  الند اصل معناه عظمة فى الدارين ياعلا ذكره بالمقام المحمود وسلم من كل مكروه ان من المذمومات والافات [...] على المطلسم بكسر الطا وتشديد اللام وفتحها مقلوب مسلوط فكانه سلط على ما ينبغي فتح الكنز فهو الامين على سر الالهية</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20r">-20r</locus>وعلى اله هم بنوا هاشم والمطلب وصحبه وهم من فى زمنه مع الاسلام وسلم \ وصلى الله على سيدنا محمد وأله وصحبه وسلم تسليما كثيرا</explicit>
                     <note/>
                     <note/>
                  </msItem>

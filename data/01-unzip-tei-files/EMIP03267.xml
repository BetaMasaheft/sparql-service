               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="170r" facs="002">Fols 2r–170r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1"><locus from="3r" to="134r" facs="003">Fols 3r–134r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref>, from the old system.  This is a fine example with longer entries than normal</note>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has only the first plus of the longer version, the word <q><foreign xml:lang="gez">ወአድኃኒ፡</foreign></q></note>
                    </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="134r" to="147r" facs="134">Fols 134r–147r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <note>The superscription to <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref>, the fourth biblical canticle is, <q>“Prayer of Hana, mother of Samuel.”</q></note>
                    </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="147r" to="154v" facs="147">Fols 147r–154v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <note>common edition</note>
                    </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="155r" to="165v" facs="155">Fols 155r–165v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <note>arranged for the days of the week, beginning on Monday and culminating on Sunday</note>
                    </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="165v" to="170r" facs="166">Fols 165v–170r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                    </msItem>
              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">171</measure>
                           <dimensions type="outer" unit="mm">
                              <height>150</height>
                              <width>130</width>
                              <depth>73</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="19 20">
                         <locus from="2r" to="154v" facs="002">Fols 2r–154v</locus>
                       </layout>
                       <layout columns="2" writtenLines="19 20">
                         <locus from="155r" to="171v" facs="155">Fols 155r–171v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is unrubricated</desc>
                  <desc>No columetric layout of text in <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps150">Psalms of
                                                  David, Psalmus 150</title> or in the tenth biblical canticle</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1v" facs="002">Fol. 1v</locus><desc>Crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref>, in pencil</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#10v" facs="011">Fol. 10v</locus><desc>Crude drawing of a man with arms upraised, in red and blue inks</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#19v" facs="020">Fol. 19v</locus><desc>Crude drawing of a person’s face above a box, in pencil, highlighted in blue and red ink</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#32v" facs="033">Fol. 32v</locus><desc>Crude drawing of a person’s face above a box, in pencil</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><desc>Several other small crude drawings of crosses and figures are found in various marginal locations throughout the book, written in the blue and red ink</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#154v #155r #155v #156r #156v #157r #157v #158r #158v #159r #159v #160r #160v #161r #161v #162r #162v #163r #163v #164r #164v #165r #165v #166r #166v #167r" facs="155 156 157 158 159 160 161 162 163 164 165 166 167">f. 154v- 167r, top margins</locus>
                    <desc>List of the feast days of the year</desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#170v" facs="171">Fol. 170v</locus>
                    <desc>Remedies for various situations, e.g., when sick, when you have disputes, when you have eye disease, etc., written in a different hand on a folio whose fore-half has been cut off, after the text was written, i.e, destroying half the text</desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#171r" facs="171">Fol. 171r</locus>
                    <desc>Treatment for menstrual bleeding, and other medicinal instructions</desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#171v" facs="172">Fol. 171v</locus>
                    <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT4346Prayer">Ṣalot baʾǝnta ʾǝlla
                                                  nomu</title></desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#1r" facs="001">Fol. 1r</locus>
                    <desc type="OwnershipNote">note of secondary ownership, <foreign xml:lang="gez">መምርየህ፡ ግደይ፡</foreign>, written in purple pen</desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#2r" facs="002"> f. 2r, top</locus>
                    <desc>illegible note on <ref type="work" corresp="https://betamasaheft.eu/LIT3851Hassab">We have written a
                                                  computus that we will remember in order not to
                                                  congregate with apostates...</ref></desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#2r" facs="002">Fol. 2r</locus>
                    <desc type="OwnershipNote">note of secondary ownership, written in purple ink</desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#68v" facs="069">Fol. 68v</locus>
                    <desc>The midpoint of the Psalms is unmarked</desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#66v #67r #67v #68r #68v #69r #69v #70r #70v #71r #71v #72r" facs="067 068 069 070 071 072"> f. 66v-72r, top margins</locus>
                    <desc>Student exercise, copying letters from the Ethiopic syllabary, in pencil</desc>
                    </item>
                    <item xml:id="a13">
                    <locus target="#155r" facs="155">Fol. 155r</locus>
                    <desc type="OwnershipNote">
                    A secondary owner’s name has been added in the beginning text of the Praises of Mary, Walda Yohannes
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#171r" facs="171"> f. 171r, top</locus>
                    <desc>pen trial poem</desc>
                    </item>
                  </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment. Simple wooden boards, the back board is broken and the pieces stitched together with five sewings.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

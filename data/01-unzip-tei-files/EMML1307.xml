               <msPart xml:id="p1">
                  <msIdentifier/>
                  <msContents><summary/>
                  <msItem xml:id="p1_i1">
                     <locus from="3r" to="129r">Fols 3r–129r</locus>
                     <title>Argānona Weddāsē</title>
                     <note>Arranged for the days of the week</note>
                  </msItem>
                     <msItem xml:id="p1_i2">
                        <locus from="129v" to="131r">Fols 129v–131r</locus>
                        <title>Ritual for penitential baptism</title>
                        <incipit xml:lang="gez">ትእዛዝ፡ መቅድመ፡ ቃል፡ ዘመጽሐፈ፡ ቄድር፡ ቀዳሜ፡ ትእዛዝ፡ ዘሠርኡ፡ ነቢያት፡ ወሐዋርያት፡ ፫፻፲ወ፰ርቱዓነ፡ ሃይማኖት፡ በእንተ፡ ዘድኀፀ፡ እምእግር፡ ዘሕግ፡ እምትእዛዝ፡ እግዚአብሔር፡ ዘይጠመቅ።
                        </incipit>
                     </msItem>
                  </msContents>
                  <physDesc>
                     <objectDesc>
                        <supportDesc>
                           <support><material key="parchment"/>
                           </support>
                           <extent>fol. 3r-131v</extent>
                           
                        </supportDesc>
                        <layoutDesc><layout>2 columns, 15-18 lines per page</layout></layoutDesc>
                     </objectDesc>
                     <decoDesc><decoNote xml:id="d1">Ḥarag, fol. 3r</decoNote></decoDesc>
                     <additions><list><item xml:id="a3">Asmāt prayers, fol. 45v and 131v</item></list></additions>
                  </physDesc>
                  <history><origin><origDate>1700-1800</origDate></origin></history>
               </msPart>
               
               <msPart xml:id="p2">
                  <msIdentifier/>
                  <msContents><summary/>
                     <msItem xml:id="p2_i1">
                        <locus from="132r" to="139v">Fols 132r–139v</locus>
                        <title>Hymn to Mary</title>
                        
                        <incipit xml:lang="gez">አዳም፡ ወአቤል፡ ሴት፡ ወሔኖስ፡ ቃይናን፡ ወመላልኤል። ያሬድ፡ ሄኖክ፡ ወማቱሳላ፡ ነዊሃነ፡ መዋዕል።
                        </incipit>
                     </msItem>
                  </msContents>
                  <physDesc>
                     <objectDesc>
                        <supportDesc>
                           <support><material key="parchment"/>
                           </support>
                           <extent>fol. 132r-139v</extent>
                           
                        </supportDesc>
                        <layoutDesc><layout>2 columns, 15-18 lines per page</layout></layoutDesc>
                     </objectDesc>
                     <decoDesc><decoNote xml:id="d2">Ḥarag, fol. 132r</decoNote></decoDesc>
                     <additions><list><item xml:id="a4">A secondary hand has written in the top margin the Anqaṣa hāymānot, አንቀጸ፡ ሃይማኖት, Catechism of the Gate of Faith, fol. 132v-139v; Stanza of Mazmura dengel, fol. 139v
                        
                     </item></list></additions>
                  </physDesc>
                  <history><origin><origDate>1500-1600</origDate></origin></history>
               </msPart>
               
               
               <msPart xml:id="p3">
                  <msIdentifier/>
                  <msContents><summary/>
                     <msItem xml:id="p3_i1">
                        <locus from="140r" to="145v">Fols 140r–145v</locus>
                        <title>Image of the Apostles</title>
                        
                        <incipit xml:lang="gez">ሰላም፡ እብል፡ ለአስማቲክሙ፡ ዝክረ፡ እንተ፡ ይጥዕም፡ መዓረ።</incipit>
                     </msItem>
                     <msItem xml:id="p3_i2">
                        <locus from="145v" to="147r">Fols 145v–147r</locus>
                        <title ref="https://betamasaheft.eu/LIT5343MiraclePlate">Miracle of Mary: The Egyptian woman who lost a silver plate</title>
                        
                        <incipit xml:lang="gez">ወሀለወት፡ አሐቲ፡ ብእሲት፡ በብሔረ፡ ግብጽ፡ ወበአኃቲ፡ ዕለት፡ እምበዐላተ፡ እግዝእትነ፡ ቅድግል፡ በክልኤ፡ ማርያም፡ ሖረት፡ ኀበ፡ ነቅዐ፡ ማይ፡ ዘይሰቅዩ፡ እምኔሁ፡ በለሰነ፡
                        </incipit>
                     </msItem>
                  </msContents>
                  <physDesc>
                     <objectDesc>
                        <supportDesc>
                           <support><material key="parchment"/>
                           </support>
                           <extent>fol. 132r-139v</extent>
                           
                        </supportDesc>
                        <layoutDesc><layout>2 columns, 15-18 lines per page</layout></layoutDesc>
                     </objectDesc>
                     
                     <additions><list><item xml:id="a5">Prayers in a secondary hand, fol. 147rv
                        
                     </item></list></additions>
                  </physDesc>
                  <history><origin><origDate>1600-1700</origDate></origin></history>
               </msPart>
               
            </msDesc>

        <profileDesc>
            <creation/>
            <abstract>
                <p>Medical prescriptions against various diseases of a similar type as <ref type="work" corresp="https://betamasaheft.eu/LIT7543Prescripti">Medico-magic prescriptions in Amharic</ref>, 
                    <ref type="work" corresp="https://betamasaheft.eu/LIT7544Prescr">Medical prescriptions in Amharic</ref> and <ref type="work" corresp="https://betamasaheft.eu/LIT7546MedPrescr">Medical prescriptions in Amharic and Gǝʿǝz</ref>, which are attested in the 
                    same manuscript <ref type="mss" corresp="https://betamasaheft.eu/BLorient12034">London, British Library, BL Oriental 12034</ref>).</p>
            </abstract>
            <textClass>
                <keywords>
                    <term key="AmharicLiterature" ana="#AmharicLiterature"/>
                    <term key="Magic" ana="#Magic"/>
                    <term key="Medicine" ana="#Medicine"/>
                    <term key="Disease" ana="#Disease"/>
                </keywords>
            </textClass>
            <langUsage>
                <language ident="en">English</language>
                <language ident="am">Amharic</language>
            </langUsage>

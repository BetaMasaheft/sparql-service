      <body>
         <div type="bibliography">
            
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
               <bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Marius</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><citedRange unit="item">332</citedRange></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እምሥርወ፡ ዕሤይ፡ እስመ፡ ሠረጽከ፡ ወእማሕፀና፡ ለሩት፨</l>
                  <l n="2">ያስተበፅኡከ፡ በእንተ፡ ዝ፡ በንባበ፡ ኵሉ፡ ስብሐት፨</l>
                  <l n="3">ኦብፁዕ፡ ንጉሠ፡ እስራኤል፡ ዳዊት፨</l>
                  <l n="4">ሶበ፡ ተረክበ፡ ወተከሥተ፡ ባሕርየ፡ ውሳጣይ፡ ሕይወት፨</l>
                  <l n="5">እመዝገበ፡ ከርሣ፡ ለማርያም፡ ለከ፡ ወለት፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ውስተ፡ ረቀ፡ መዝሙር፡ ዘተዋደደ፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ሰላም፡ በቅብአ፡ ትሕትና፡ ዘጽሕደ፨</l>
                  <l n="3">ፍኖተ፡ ሰማይ፡ ዳዊት፡ ጊዜ፡ አርታዕኩ፡ መንገደ፨</l>
                  <l n="4">አስተፋጥን፡ ለቀበላየ፡ እንዘ፡ ታስተናሥእ፡ እደ፨</l>
                  <l n="5">እስመ፡ ፍና፡ ዝንቱ፡ መጽብብ፡ እፈርህ፡ ፈድፉደ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለርእስከ፡ በአክሊለ፡ መንግሥት፡ ዘከብረ፨</l>
                  <l n="2">ወለሥነ፡ ገጽከ፡ እምፀሓይ፡ ዘያበርህ፡ ወትረ፨</l>
                  <l n="3">ፍኖተ፡ ሰማይ፡ ዳዊት፡ ጊዜ፡ አርታዕኩ፡ ሐዊረ፨</l>
                  <l n="4">አስተሣኒ፡ ሊተ፡ መሰንቆ፡ ወአስተዋድድ፡ መዝሙረ፨</l>
                  <l n="5">ከመ፡ ለጻድቃን፡ ታስተዳሉ፡ ወትረ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ዘምዕዝት፡ በዐልው፨</l>
                  <l n="2">በከመ፡ ሕጎሙ፡ ለቀደምት፡ አበው፨</l>
                  <l n="3">ዳዊት፡ ጸሊ፡ ቅድመ፡ ገጸ፡ አምላክ፡ ሕያው፨</l>
                  <l n="4">ከመ፡ እድኀን፡ በጸሎትከ፡ እምንሳዌ፡ እግር፡ ከዋው፨</l>
                  <l n="5">ወእማዕቀፁ፡ ለብእሲ፡ ጽልሕው፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">መጽሐፈ፡ ልደቱ፡ ለክርስቶስ፡ ወልደ፡ ዳዊት፡ ንጉሥ፨</l>
                  <l n="2">ዘይቤ፡ ማቴዎስ፡ በመንፈስ፡ ቅዱስ፨</l>
                  <l n="3">ከመ፡ ኪያከ፡ ይረሲ፡ መልዕልታ፡ ለቍድስ፨</l>
                  <l n="4">ዳዊት፡ ነቢይ፡ ዳዊት፡ ንጉሥ፨</l>
                  <l n="5">ያስተበፅዐከ፡ በእንተ፡ ዝ፡ ኵሉ፡ ዘነፍስ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ቃልየ፡ ስማዕ፡ ወለቡ፡ ጽራኅየ፨</l>
                  <l n="2">ወአጽምዐኒ፡ ቃለ፡ ስእለትየ፨</l>
                  <l n="3">ትስአል፡ ሊተ፡ ዳዊት፡ ኀበ፡ አምላኪየ፨</l>
                  <l n="4">እግነይ፡ ከመ፡ ከማከ፡ በኵሉ፡ ልብየ፨</l>
                  <l n="5">እስመ፡ አልቦ፡ ኃጥእ፡ ዘከማየ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">እምአዳም፡ አበ፡ ዓለም፡ ወሄኖክ፡ አበ፡ ኖኅ፨</l>
                  <l n="2">እምአብርሃም፡ ወሙሴ፡ እስከነ፡ ዳዊት፡ የዋህ፨</l>
                  <l n="3">እምሳሙኤል፡ ካህን፡ ወዘካርያስ፡ ንጹሕ፨</l>
                  <l n="4">ተዘከሩኒ፡ ለለ፡ ጊዜ፡ ቅድመ፡ ገጸ፡ ክርስቶስ፡ መሲሕ፨</l>
                  <l n="5">እስእለክሙ፡ ጊዜ፡ ሰርክ፡ ወነግህ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ድሕንፃ፡ ፍቅርከ፡ ይዝብጥ፡ ለሰብእናየ፡ አውታራ፨</l>
                  <l n="2">ከመ፡ ትሰንቁ፡ ምዑዘ፡ ዋለ፡ ነከራ፨</l>
                  <l n="3">ዳዊት፡ ወላዴ፡ ዕዝራ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለከ፡ ጊዜ፡ ሞትየ፡ ኢትትርፍ፡ በእንተ፡ ማርያም፡ ጳጦስ፨</l>
                  <l n="2">መሰንቆከ፡ ትዝብጥ፡ በዘፈረ፡ ልብስ፨</l>
                  <l n="3">ዳዊት፡ ሙሐዘ፡ ንግሥ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለከ፡ ምዕዝተ፡ ትኩን፡ በአፈ፡ ረቂቅ፡ ኅሊና፨</l>
                  <l n="2">ወእምዕፍረተ፡ ንግሥ፡ ዘጽጌ፡ ሐና፨</l>
                  <l n="3">ሰላምየ፡ ዳዊት፡ ቅቡአ፡ ልቡና፨</l>
                  <l n="4">ሰማያት፡ እስከ፡ ይረስና፨</l>
               </lg>
            </div>
         </div>
      </body>

                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="2r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf">Maṣḥafa gǝṣṣāwe</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="2r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SaturdaySunday">Lectionary for various Festivals</title>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="26r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#Daily">Lectionary for Commemorations</title>
                                </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="40v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4614Salam">Hymn to Our Lady Mary</title>
                            <incipit xml:lang="gez">
                                ዕዝል፡ ፫ጊዜ፡ ሃሌሉ<sic resp="DR">የ</sic>። ንስግድ፡ ለአ<sic resp="DR">ብ</sic>፡ ብርሃናት፡ ወለወልድ፡ ዋሕድ፡
                                ወለመንፈስ፡ ጰራቅሊጣስ፡ ሥሉስ፡ ዕሩይ። ሰላም፡ ለማርያም፡ ንግሥት፡ ወዐፀ<sic resp="PRS10171Wright">ደ</sic>፡ 
                                ዘበአማን፡ ዘኢተገበርዋ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="41v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</title>
                            
                            <msItem xml:id="ms_i3.1">
                                <locus from="41v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3993Miracle">Miracle of Mary: unidentified miracle</title>
                                <note>The number of miracles is not specified.</note>
                                <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእትነ፡ ማርያም፡</incipit>
                            </msItem>
                        
                        
                        <msItem xml:id="ms_i3.2">
                            <locus target="#46r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2717RepCh1">Malkǝʾ-hymn to John the Baptist</title>
                            <incipit xml:lang="gez">ሃሌሉ<sic resp="DR">የ</sic>፡ ሰላም፡ ለከ፡ ዮሐንስ፡ ወልደ፡ ነጐድጓድ። ሰላም፡ ለከ፡ ዮሐንስ፡ ቴዎጎሎስ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i3.3">
                            <locus from="46r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4270Salota">Ṣalota taʾammǝr</title>
                            <incipit xml:lang="gez">እግዚኦ፡ ኢየሱስ፡ ከርስቶስ፡ አምላክነ፡ ዘትቤሎ፡ ለፍቁ<sic resp="DR">ረ</sic>ከ፡ ዮሐንስ፡ እንዘ፡
                                ሀሎ፡ በዲበ፡ ዕፀ፡ መስቀል፡ ቅዱስ።</incipit>
                        </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="48v"/>
                            <title type="incomplete">Part of a prayer</title>
                            <note>The catalogue description does not state clearly whether this prayer, written by the main hand, 
                            has been added later to the manuscript.</note>
                        </msItem>
                    </msContents>
                    

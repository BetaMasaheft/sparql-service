         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q5515488">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ገብረ፡ መንፈስ፡ ቅዱስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gabra Manfas Qǝddus</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">አቦ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbo</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="birth">ጋብር፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Gābǝr</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾAbbā</t:roleName>
               </t:persName>
               <t:nationality type="Egypt"/>
               <t:faith type="EOTC"/>
               
               
               <t:residence>He lived  for a long time in <t:placeName ref="https://betamasaheft.eu/LOC4743MedraK">Mǝdra Kabd ʾAbbo</t:placeName>
               </t:residence>
               <t:floruit notBefore="1300" notAfter="1382">He is  one of the most venerated saints in Ethiopia. 
                  He was Egyptian by origin and came to Ethiopia from a monastery in a district of Lower Egypt.
                  His centre of ascetic life was at <t:placeName ref="https://betamasaheft.eu/LOC4743MedraK">Mǝdra Kabd ʾAbbo</t:placeName>
               </t:floruit>
               <t:death when="1382">He died in around <t:date>1382</t:date>.
               </t:death>
            </t:person>  
            
         </t:listPerson>

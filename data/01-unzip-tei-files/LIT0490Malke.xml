      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0490</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ኀበ፡ ክርስቶስ፡ አምላኪየ፡ ኣቀድም፡ ጸልዮ፨</l>
                  <l n="2">ወኀበ፡ ማርያም፡ እስእል፡ በእንተ፡ ጌጋይየ፡ አስተሥርዮ፨</l>
                  <l n="3">ድርሳነ፡ ሠለስቱ፡ ደቂቅ፡ ከመ፡ እንግር፡ በተጋንዮ፨</l>
                  <l n="4">እደ፡ ኅሊናየ፡ ይጽብት፡ ለመጽሐፍ፡ ቀላዮ፨</l>
                  <l n="5">[This line is missing.]</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">በከመ፡ ድኅንክሙ፡ ቅድመ፡ እምእቶነ፡ እሳት፡ ነዳዲ፨</l>
                  <l n="2">በትእዛዘ፡ አምላክ፡ እብኖዲ፨</l>
                  <l n="3">አናንያ፡ ወአዛርያ፡ ወሚሳኤል፡ ዓዲ፨</l>
                  <l n="4">አድኅኑኒ፡ ወባልሑኒ፡ እመሥገርተ፡ ሰይጣን፡ ረዋዲ፨</l>
                  <l n="5">በቀለ፡ አቡየ፡ ወእምየ፡ እፍዲ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ እብል፡ ለዝክረ፡ ስምክሙ፡ በኢያንትጎ፨</l>
                  <l n="2">ለልብየ፡ መዋቲ፡ ሐብለ፡ ፍቅርክሙ፡ እስመ፡ መዘጎ፨</l>
                  <l n="3">ሲድራቅ፡ ወሚሳቅ፡ ወአብደናጎ፨</l>
                  <l n="4">ከመ፡ ዐቀብክሙ፡ ለልዑል፡ ሕጎ፨</l>
                  <l n="5">ኰነነ፡ ጸሎትክሙ፡ ሰማየ፡ ዐሪጎ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስክሙ፡ ነደ፡ እሳት፡ ዘኢለከፎ፨</l>
                  <l n="2">ወለርእስክሙ፡ ሰላም፡ ርስነ፡ ነበልባል፡ ዘኢቀሰፎ፨</l>
                  <l n="3">ሠለስቱ፡ ደቂቅ፡ ቅጥቀጥተ፡ ርእሱ፡ ለግልፎ፨</l>
                  <l n="4">ገብርኤል፡ መልአክክሙ፡ ነደነክሙ፡ አክናፎ፨</l>
                  <l n="5">ከመ፡ ዘይከድኖ፡ ለንህብ፡ እደ፡ ሰብእ፡ ቀፎ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለመቃብሪክሙ፡ ኀበ፡ ሖርክሙ፡ ምድረ፡ ጽማዌ፨</l>
                  <l n="2">ዳንኤል፡ ነቢይ፡ አመ፡ ቀተሎ፡ ለአርዌ፨</l>
                  <l n="3">ሠለስቱ፡ ደቂቅ፡ ምሉኣነ፡ ጥበብ፡ ወልባዌ፨</l>
                  <l n="4">አድኅኑኒ፡ ወባልሑኒ፡ እመሥገርተ፡ ሕማም፡ ምንሳዌ፨</l>
                  <l n="5">በላዕለ፡ እምየ፡ ዘአምጽአ፡ ደዌ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ይደልዎሙ፡ ብፅዐ፡ ወመሐና፡ ለዘሰመዩ፨</l>
                  <l n="2">ወኪያክሙ፡ ዘፈረዩ፨</l>
                  <l n="3">ሠለስቱ፡ ደቂቅ፡ በእንቲአየ፡ ጸልዩ፨</l>
                  <l n="4">እምልብየ፡ ወእምኅሊናየ፡ ሦከ፡ ኀጢአት፡ ጻሕይዩ፨</l>
                  <l n="5">ከመ፡ በዲቤሁ፡ ኢይፍረይ፡ ለስሕተት፡ ጌጋዩ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">አምኃ፡ ሰላም፡ ወፍቅር፡ መሥዋዕተ፡ ልቡና፡ ወፈውስ፨</l>
                  <l n="2">በዝ፡ ብሔር፡ ወበዝመቅደስ፨</l>
                  <l n="3">ሠለስቱ፡ ደቂቅ፡ ነቢያተ፡ ነነዌ፡ ወፋርስ፨</l>
                  <l n="4">ጸሪቀ፡ መበለት፡ አሐቲ፡ በከመ፡ ተወክፈ፡ ክርስቶስ፨</l>
                  <l n="5">ተወከፍ፡ ጸሎትየ፡ እንተ፡ ባሕር፡ ወየብስ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰማዕታተ፡ አምላክ፡ ልዑል፡ ዘኢሰገድክሙ፡ ለምስል፨</l>
                  <l n="2">ወዘአቍረርክሙ፡ ርስነ፡ ነበልባል፨</l>
                  <l n="3">አናንያ፡ ወአዛርያ፡ ወሚሳኤል፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ለእግዚአብሔር፡ አምላክ፡ በይነ፡ ዘዐቀብክሙ፡ ሕጎ፨</l>
                  <l n="2">በነደ፡ እሳት፡ ተወድዩ፡ በከርሠ፡ ነሪጎ፨</l>
                  <l n="3">ሲድራቅ፡ ወሚሳቅ፡ ወአብደናጎ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">በይነ፡ ዘአቅረብኩ፡ ለክሙ፡ ድርሳነ፨</l>
                  <l n="2">ኵሎ፡ ዕለተ፡ ወዘመነ፨</l>
                  <l n="3">ሠለስቱ፡ ደቂቅ፡ ሀቡኒ፡ ኪዳነ፨</l>
                  <l n="4">ምስሌክሙ፡ ከመ፡ እንበር፡ አነ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
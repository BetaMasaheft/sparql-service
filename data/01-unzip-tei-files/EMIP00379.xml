                    <desc>
                    brown yarn is sewn into the fore edge to mark content as navigation system
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#32 #46" facs="034 048">Fols. 32, 46</locus>
                    <desc>
                    yellow yarn is sewn into the fore edge to mark content as navigation system
                    </desc>
                    </item>

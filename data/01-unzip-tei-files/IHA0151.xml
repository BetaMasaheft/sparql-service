               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="iv" to="175r">iv-175r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0325IHA#s68IHA">كتاب القدوري</title>
                     <incipit xml:lang="ar">
                        <locus target="#iv">-iv</locus>بسم الله الرحمن الرحيم كتاب الطهارة قال الله تعلى ياءيها الذين امنوا الذا قمتم الى الصلوة فاغسلوا وجوهكم وايديكم الى المرافق ومسحوا براوسكم وارجلكم الى الكعبين ففرض الطهارة غسل الاعضاء ثلاثة ومسح الراس والمرفقان والكعبان</incipit>
                     <incipit xml:lang="ar">
                        <locus target="#175r">-175r</locus>وان قال ثلث مالي بين زيد وعمر وزيد ميت كان لعمرو نصف الثلث ومن اوصى بثلث ماله ولا مال له ثم كتسب مالا استحق الوصا له الثلث ما يملكه عند الموت</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#175r">-175r</locus>وان قال ثلث مالي بين زيد وعمر وزيد ميت كان لعمرو نصف الثلث ومن اوصى بثلث ماله ولا مال له ثم كتسب مالا استحق الموصى له الثلث ما يملكه عند الموت </explicit>
                     <note>Words divided into two lines.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="175r" to="176r">175r-176r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0328IHA">دعاء اللهم صل وسلم على سيدنا محمد في الاولين</title>
                     <incipit xml:lang="ar">
                        <locus target="#175r">-175r</locus>بسم الله الرحمن الرحيم اللهم صل وسلم على سيدنا محمد في الاولين وصل وسلم على سيدنا محمد في الاولين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#176r">-176r</locus>وترضون وازيفه في الجنان وكم [.؟.] يا كنان يا منان</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>

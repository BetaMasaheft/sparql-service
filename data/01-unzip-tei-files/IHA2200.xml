                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_7000">
                           <locus target="#60r">-60r</locus>
                           <q xml:lang="ar">اتم .... ايدم اواح ...ردخ وارح محمد  | اللهم انفعنا ببركاته امين</q>
                           <desc>Marginalia</desc>
                           <note>Partially unreadable.</note>
                           <note/>
                        </item>
                        <item xml:id="a0_6995">
                           <locus target="#25v">-25v</locus>
                           <q xml:lang="ar">بسم الله الرحمن الرحيم الله اني اسئلك بحق اسمائك الحسني ... جملة وبالا بسم الحاوي لعدادها جملة اسمك مانح محنا سر اسرارها ... حتى ... لنا الصعاب وتنكشف لنا من بديع انوارها الحجاب [...] العم وكذالك ... امومنين ولا حول ولا قوة الا بالله علي العظيم وصلى الله على سيدنا محمد ... وصحبه وسلم تمت</q>
                           <desc>Marginalia</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_6998">
                           <locus target="#56v">-56v</locus>
                           <q xml:lang="ar">Partially readable annotations in pencil.</q>
                           <desc>Marginalia</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_7009">
                           <locus target="#76r">-76r</locus>
                           <q xml:lang="ar">تمت الصلاة</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#69r-v">-69r-v</locus>
                           <q>بغوث العقيل الربان العارف \ المشاهد الرحمان وفخرن العظيم \ عبدالحاكم يسر لنا امورنا ودوام [...]ا</q>
                           <note>To be recited as tarāwīḥ during the month of Ramaḍān</note>
                        </item>

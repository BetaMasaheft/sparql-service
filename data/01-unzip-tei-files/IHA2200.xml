               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="19v">1r-19v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4268IHA">Devotional poem in Old Harari</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم | سلام على نب سلام على صلى الله على نبوا اماموا | ... سيخلقوا نور ب زخلقوا محمد ديجلني | عرشوا ميخلقوا نور ب زخلقوا محمد ذيجلني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>نحمد الهييا اختم بذكريا بجميع الانبيآ احمدوا اميا | نحمد الهييا اختم بذكريا بصلأ الأليآ احمدوا اميا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="19v" to="25v">19v-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4347IHA">نظم بدأت ببسم الله والحمد أولا</title>
                     <incipit xml:lang="ar">
                        <locus target="#19v">-19v</locus>بسم الله الرحمن الرحيم بدأت ببسم الله والحمد أولا على نعم لم تحصر فيما نزلا ... للإله بنفسه على نفسه اذ ليس يحصيه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>وسلم الاهى كل و ... على المصطفى ازكى سلاما واكملا وبارك إلهى بكرة وعشتة على المصطفى خير الانام المفضلا ... الهى بكرة وعشية على المصطفى ماحر رعد؟ ... على الانبيا والال والصحب ... الله ختما والا؟</explicit>
                     <note>Faded writing, often undreadable.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="76r" to="76r">76r-76r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4291IHA">صلاة الغزنوية</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar">
                        <locus target="#76r">-76r</locus>علي سيد المرسلين وإمام المتقين وقايد الغر ... المحجلين إلي جنات النعيم وشفيع المذنبين سيدنا ومولانا محمد وعلى أله وصحبه وأزواجه وذر... واهل بيته والأيمة الماصين والمشايخ المتقدمين والشهداء والصالحين وأهل طاعتك اجمعين ... السموات وأهل الأرضين وعلينا معهم أجمعين برحمتك أرحمن الراحمينويا اكرم الاكرمين والحمد لله رب العالمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="26r" to="26v">26r-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4266IHA">دعاء لا اله الا الله احد</title>
                     <incipit xml:lang="ar">
                        <locus target="#26r">-26r</locus>بسم الله الرحمن الرحيم | لا اله الا الله احد الا الله احد واحد والله واحد بلا شريك واحد بلا وزير واحد بلا شبيه وحده لا شريك ملكه لا يزول انت مالك الملك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>محمد شفيع الله الحسن ثم الحسين للنبي تفاحتين نورهم كالشمعتين جدهم صلوا عليه فاطمة بنت الرسول وعلي زوج البتول ذ الفقار سيف المسلول صلوات الله عليه </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="27r" to="29r">27r-29r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4267IHA">صلاة على النبي بسم الله نور العالم</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>بسم الله الرحمن الرحيم بسم الله نورا عالم المستورا باعث المنصور | صلى الله عليه بسم الله نور المن عطاه حورا هادى المغرورا صلى الله عليه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29r">-29r</locus>صلى الله عليه واله الاسرار وصحبه الاخيار سادة الابرار | صلى الله عليه تمت المدايحة فى النبي المصطفى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="29r" to="56v">29r-56v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4264IHA">هرري مدح النبي والخلفاء الرشيدين</title>
                     <incipit xml:lang="ar">
                        <locus target="#29r">-29r</locus>بسم الله الرحمن الرحيم | بسم الله قد منا الرحمن خير فرد دلنا | ببسم الله قدمنا الرحمن شر سدد لنا | بسم الله دوآء بسم الله داو شفاء | بسم الله دواء رب الارض والسماء </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#56v">-56v</locus>والله اعلا وذكره واولا | هو الذي يعلم الغيوب فقل | لآ أذكر غير من انزه | يا نايمي فى الراش وغفليه يفعل ما يشآ بقدرته | يحكم ما يريد بعزته | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="57r" to="57v">57r-57v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4269IHA">نظم بحمد الأزلي بدأت نظما</title>
                     <incipit xml:lang="ar">
                        <locus target="#57r">-57r</locus>بسم الله الرحمن الرحيم | اواى عربو اسلام عليه محمد عربو اسلام عليه | بحمد الازلي بدأت نظما وبمدح النبي ختمت فيه | لك الحمد والشكر يا الهى لقد جئت به وصاحبيه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57v">-57v</locus>محمد صلوات الله عليه مع الال كما هدا اليه | مع الهما والتاببعيه مع الانبيآ والصالحين | نبي الحرمين رسول الله نبي الثقلين امين الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="58r" to="60r">58r-60r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4270IHA">نظم بسم الله الاعظم</title>
                     <incipit xml:lang="ar">
                        <locus target="#58r">-58r</locus>بسم الله الاعظما سم خاب نقدما | بسم الله الاعظما اول مقدما | بسم الله الاعظما اخر مختما | ذليلب تاخرا اول مقدما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60r">-60r</locus>ايد ايدوا عالم ايدوا | البورديوا ورخ محمدا | الحمد لله حمد لخلقنا | بسم الله مرحم احمد ... عجيل </explicit>
                     <note>Part of the text is written upside down or in vertical in the space left blank by the preceding verses. The order of the verses is not always clear.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="60r" to="69v">60r-69v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4272IHA">نظم ببسم الله تشأ</title>
                     <incipit xml:lang="ar">
                        <locus target="#60r">-60r</locus>بسم الله الرحمن الرحيم | ببسم الله تشأ تنشيأ | ببسم الله نقد حا &lt;دين اقحا&gt; | ببسم الله نبدأ بارإيا ~ ببسم الله البارأأ بارإيا | | نب عبد البارأ بارإيا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#69v">-69v</locus>سر زجاج ليووا اوحسينوا | حياتخ كشلبييا اوحسينوا | الله بر؟ نزخبييا اوحسينوا | حمد حلاخيار واذنان خانا تمت تمت </explicit>
                     <note>The poem seems to be sibdivided in different section that are marked with a red horizontal stroke and in one case (f. 68r) with a "tammat" not followed by a basmala; part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="70r" to="71v">70r-71v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4280IHA">نظم بل فرجي</title>
                     <incipit xml:lang="ar">
                        <locus target="#70r">-70r</locus>بسم الله الرحمن الرحيم | بل فرجى وداجوا بحياتط | جمط بلى وداجوا بحياتى | رب يسر ولا ما تعسيرا | يسير وايخنلاوي نيليتوا؟</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71v">-71v</locus>تالله يتودان نبيوا دد زخاخى | تالله يصالحن نبيوا دد زخاخى | بادن يبوردن نبيوا دد زخاخى | حمد حلاخيار ازان خانا تمت تمت</explicit>
                     <note>Part of the text is written in vertical in the margins.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="72r" to="73v">72r-73v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4284IHA">نظم اولوا بسم الله اخر حمد نبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#72r">-72r</locus>بسم الله الرحمن الرحيم | اولوا بسم الله أخر حمد نبي | أحمدوا بسم الله امنت بالله رسول الله | احمدوا بسم الله توكلت بالله رسول الله | احمدوا بسم الله ترزقت؟ بالله رسول الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#٧٣ْ">-٧٣ْ</locus>شهاد بن شيلموا احمدي نبوا امت ديوا | انل حرمتا حمدي نبوا امت ديوا | حد جلفتنتى حمدي نبوا امت ديوا | امت دوا ان  خنا نب امتوا ان خنا حمدي | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>

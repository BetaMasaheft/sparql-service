                     <msItem xml:id="p1_i2">
                        <locus from="117r">Fols 117r and following</locus>
                        <title type="complete">Chronology from the creation of the world up to 
                           the death of <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>, ascribed to
                           <persName role="author" ref="https://betamasaheft.eu/PRS4711Giyorgis">Giyorgis Walda ʾAmid</persName>.</title> 
                        
                        <note>While the fact that this list ends with the death of <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>
                        need not necessarily lead us to accept that year as the approximate age of this manuscript, 
                        paleographic and linguistic data, too, make the <date>middle of the 17th century</date> a likely 
                        date for its production.</note>
                        <textLang mainLang="gez"/>
                     </msItem>

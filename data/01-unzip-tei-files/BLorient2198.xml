                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="13r"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT3585Taamme">Taʾammǝra Māryām</title>
                            <note>Numbered from second to seventh miracle. The miracle numbered first and the beginning of the second miracle is 
                                missing.</note>
                                <msItem xml:id="ms_i1.1">
                                    <locus from="1r" to="3r"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT3586Miracle">Miracle of Mary: Miracle of Hildephonsus (Dexius) of
          Toledo</title>
                                    <incipit xml:lang="gez">ወበከመ፡ <gap reason="lost"/> ገብርከ፡ በዓለ፡ ዜናየ፡ ዘዜነወሂ፡ መልአክ፡ ወአስተፈሣሕከ፡ ኵሎ፡ ሰብእ፤ በእንቲአየ፡ 
                                        ወአንሰ፡ እዌስክ፡ <gap reason="ellipsis"/> ወሶበ፡ ተፈጸመ፡ መዋዕለ፡ ሕይወቱ፡ ወገብአ፡ ኀበ፡ ምሕረተ፡ እግዚአብሔር፡ ርእይዋ፡ ለይእቲ፡ ልብስ፡ ውስተ፡ 
                                        መዛግብተ፡ ቤተ፡ ክርስቲያን፡ እንዘ፡ ንጽሕት፡ ፈድፋደ። ወሶበ፡ ተሰይመ፡ እምድኅሬሁ፡ ኤጲስ፡ ቆጶስ፤ ፈቀደ፡ ይልበሳ፡ ለይእቲ፡ ልብስ፡ ወይንበር፡ ዲበ፡ መንበሩ፡ 
                                        ለኤጲስ፡ ቆጶስ፤ ዳቅስዮስ። </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2">
                                    <locus from="3v" to="5v"/>
                                    <title ref="https://betamasaheft.eu/LIT3924Miracle">Miracle of Mary: How the Virgin Mary sent a vision to a young
          man and caused him to embrace the ascetic life</title>
                                    <note>Numbered as Miracle 3</note>
                                    <incipit xml:lang="gez">፫ተአምሪሃ፡ ለአግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ <gap reason="ellipsis"/> ወሀሎ፡ ፩ብእሲ፡ ሠናይ፡ ወያፈቅራ፡
                                        ለእግዝእትነ፡ ማርያም፡ ወይትለአካ፡ በኵሉ፡ ኀይሉ፡ ወሖረ፡ ያመክር፡ <gap reason="lost"/>ሶ፡ ኀበ፡ ደብር፡ ወነበረ፡ ውስቴቱ፡ ፩ዓመት። ወእምድኅረ፡ ዝንቱ፡
                                        ይቤሎ፡ ሊቀ፡ ደብር፡ ኦ<gap reason="lost"/>  ይደሉ፡ ለከ፡ ከመ፡ ትገብር፡ <gap reason="lost"/>ስከ፡ ፩እም፪እመኒ፡ ትነብር፡ ማእከለ፡ አኃው፡ 
                                        ወትሁብ፡ <gap reason="lost"/>ዓተ፡ ለእግዚአብሔር፡ <gap reason="lost"/>ትትለአክ፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.3">
                                    <locus from="5v" to="7r"/>
                                    <title ref="https://betamasaheft.eu/LIT3588Miracle">Miracle of Mary: Miracle of a picture of Mary speaking to a
          worker</title>
                                    <note>Numbered as Miracle 4</note>
                                    <incipit xml:lang="gez">፬ተአምሪሃ፡ ለእግዝእትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡ <gap reason="ellipsis"/> ወሀሎ፡ ፩ብእሲ፡ ገብራዊ፡
                                        ዘኮነ፡ ያወትር፡ ሰላመ፡ እግዝእትነ፡ ማርያም፡ ሰርከ፡ ወነግሀ፡ ወመንፈቀ፡ መዓልት፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.4">
                                    <locus from="7r" to="10r"/>
                                    <title ref="https://betamasaheft.eu/LIT3666Miracle">Miracle of Mary: Miracle of the source caused by Jesus and
          healing by its water</title>
                                    <note>Numbered as Miracle 5</note>
                                    <incipit xml:lang="gez">፭ተአምሪሃ፡ ለእግዘትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡ <gap reason="ellipsis"/> ወኮነ፡ እምድኅረ፡ ወላደቶ፡
                                        ለፍቁር፡ ወልዳ፡ ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ ሀለው፡ በውስተ፡ ቤተ፡ ልሔም፡ አዘዘ፡ ሄሮድስ፡ ይቅትሉ፡ ኵሎ፡ ሕፃናተ፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.5">
                                    <locus from="10r" to="11v"/>
                                    <title ref="https://betamasaheft.eu/LIT3717Miracle">Miracle of Mary: Miracle of a brigand who bathed in "the
          water of the Virgin" and whose soul was saved by Her</title>
                                    <note>Numbered as Miracle 6</note>
                                    <incipit xml:lang="gez">፮ተአምሪሃ፡ ለእግዝእትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡ <gap reason="ellipsis"/> ወእምድኅረ፡ 
                                        አዕር<supplied reason="undefined" resp="PRS8999Strelcyn">ፈ</supplied>ት፡ እግዝእትነ፡ ማርያም፡ መፅአ፡ ፩ፈያታይ፡ ኀበ፡ 
                                        ውእቱ፡ ማይ፡ ዘነቅዐ፡ እምታሕተ፡ እግራ፡ ለማርያም፡ <gap reason="ellipsis"/> ወቀተለ፡ ነፍስ፡ ወትዕፅበ፡ እምብዝኀ፡ ሃፈ፡ ፀሐይ፡ ወኖመ፡ አስተራቲዖ፡
                                        እደዊሁ፡ ወእገሪሁ፡ ኀበ፡ ውእቱ፡ ማይ፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.6">
                                    <locus from="11v" to="13r"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT5183MiracleBrigands">Miracle of Mary: The brigands who killed each other
          at the miraculous spring</title>
                                    <note>Numbered as Miracle 7; a double leaf is missing.</note>
                                    <incipit xml:lang="gez">፯ተአምሪሃ፡ ለእግዝእትነ፡ ማርያም፡ <gap reason="lost" unit="lines" quantity="36"/>ተጽዕነ፡ ላዕሌሁ፡ በከመ፡
                                        ይቤ፡ ኢሳይያስ፡ ነቢይ፡ ኢይነጽሕ፡ ደም፡ ዘእንበለ፡ በደም። ወመጽአ፡ ካልእ፡ ፈያታይ፡ ወነጻራ፡ ለይእቲ፡ ወለት፡ ቀታሊት፡ ፈያት፡ ወወግአ፡ 
                                        በቍ<gap reason="lost"/>ኵናት፡ እምርኁቅ፡ ወሞተ<supplied reason="undefined">ት፡</supplied></incipit>
                                </msItem>
                        </msItem>
                            
                        <msItem xml:id="ms_i2">
                            <locus from="14r" to="20v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5066MiraclesMichael">Miracles of Michael</title>
                            <note>Numbered from first to fifth miracle.</note>
                                <msItem xml:id="ms_i2.1">
                                    <locus from="14r" to="15v"/>
                                    <title ref="https://betamasaheft.eu/LIT7385MirMichael">How the Archangel Michael helped Abba Nob and put a crown of light on his head</title>
                                    <note>Numbered as Miracle 1</note>
                                    <incipit xml:lang="gez">፩ተአምሪሁ፡ ለሚካኤል፡ ሊቀ፡ መላእክት፡ ዘከመ፡ ረድኦ፡ ለአባ፡ ኖብ፡ ሰማዕት፡ ወአንበረ፡ አክሊለ፡ ብርሃን፡ ዲበ፡ ርእሱ፡
                                        <gap reason="ellipsis"/>ወጸለየ፡ ቅዱስ፡ አባ፡ ኖብ፡ በዐቢይ፡ ቃል፡ ወይቤ፡ አየሱስ፡ ክርስቶስ፡ አምላኪየ፡ ዘይሬኢ፡ በአዕይንቲሁ፡ ወይስምዕ፡
                                        በ<supplied reason="undefined">አ</supplied>እዛኒሁ፡ ዘመጽአ፡ ውስተ፡ ዓለም። ስምዓኒ፡ ሊተ፡ ካዕበ፡ ዮም፡ ኦእግዚእየ፡ አንሰ፡ ውስተ፡ ጾማ፡ 
                                        ሀለውኩ፡ በእንተ፡ ስምከ፡  </incipit>
                                </msItem>
                                <msItem xml:id="ms_i2.2">
                                    <locus from="15v" to="16v"/>
                                    <title>How the Archangel Michael expelled the evil spirits which attacked Peter and Thaddaeus</title>
                                    <note>Numbered as Miracle 2</note>
                                    <incipit xml:lang="gez">፪ተአምሪሁ፡ ለሚካኤል፡ ሊቀ፡ መላእክት፡ ካዕበ፡ ዘከመ፡ ረድኦሙ፡ ለጴጥሮስ፡ ወለታዴዎስ። <gap reason="ellipsis"/> 
                                        ወይቤልዎ፡ ጴጥሮስ፡ ለታዴዎስ፡ ተንሥእ፡ ንጼሊ፡ ወንስሎ፡ ለእግዚአብሔር፡ ከመ፡ ይርድአነ። እስመ፡ ናሁ፡ አስሕተ፡ አልባበ፡ ሕዝብ። ወውእቶሙኒ፡ ተንሥኡ፡ 
                                        ኅቡረ፡ ወጸለዬ፡ እንዘ፡ ይብሉ፡ እግዚአብሔር፡ እግዚእ፡ አኃዜ፡ ኵሉ፡</incipit>
                                </msItem>
                               <msItem xml:id="ms_i2.3">
                                    <locus from="17r" to="17v"/>
                                   <title ref="https://betamasaheft.eu/LIT7381MirMichael">How the Archangel Michael helped Theodore the Oriental and gave him a sword</title>
                                    <note>Numbered as Miracle 3</note>
                                    <incipit xml:lang="gez">፫ተአምሪሁ፡ ለሚካኤል፡ ሊቀ፡ መላእክት፡ ዘዘከመ፡ ረድኦሙ፡ ለቴዎድሮስ፡ ምሥራቃዊ፡ ወወሀቦ፡ ሰይፈ፡ ትንብልናሁ፡
                                        <gap reason="ellipsis"/> ወጸውዖሙ፡ ንጉሥ፡ ለቴዎድሮስ፡ በናድልዮስ፡ ንስኦ፡ ለገላውድዮስ፡ ካልእከ፡ ወሖሩ፡ ብሔረክሙ። ወእምድኅረ፡ በጻሕክሙ፡
                                        ብሔረክሙ፡ ፈንውዎ፡ ለወልድየ፡ ኃቤየ፡ ውስተ፡ ጊዜ፡ ትቤ፡ ንግሥት፡ </incipit>
                                </msItem>
                                <msItem xml:id="ms_i2.4">
                                    <locus from="17v" to="18v"/>
                                    <title>How the Archangel Michael resurrected St George</title>
                                    <note>Numbered as Miracle 4</note>
                                    <incipit xml:lang="gez">፬ተአምሪሁ፡ ለሚካኤል፡ ሊቃ፡ መላእክት፡ በከመ፡ ረድኦሙ፡ ለጊዮርጊስ፡ ወአዕረገ፡ አዕፅምቲሁ፡ ወአንሥኦ፡ ድኅረ፡ ሞተ። 
                                        <gap reason="ellipsis"/> ወይቤሎ፡ እግዚአብሔር፡ ለሚካኤል፡ ለከ፡ አብለከ፡ ሚካኤል፡ መልአከ፡ ኪዳንየ፡ ሖር፡ 
                                        ረድ<supplied reason="undefined">እ</supplied>፡ ውስተዝ፡ ውስተዝ፡ ዐዘቅት፡ ወአዕርግ፡ አዕፅምቲሁ፡ ለጊዮርጊስ፡ እስመ፡ ይቤ፡</incipit>
                                </msItem>
                                <msItem xml:id="ms_i2.5">
                                    <locus from="19r" to="20v"/>
                                    <title ref="https://betamasaheft.eu/LIT7382MirMichael">How the Archangel Michael saved Mercurius from the fiery furnace into which Emperor Decius wanted to put
                                        him</title>
                                    <note>Numbered as Miracle 5</note>
                                    <incipit xml:lang="gez">፭ተአምሪሁ፡ ለሚካኤል፡ ሊቀ፡ መላእክት፡ ዘከመ፡ ረድኦ፡ ለመርቆርዮስ፡ ወአድኃኖ፡ እምእቶነ፡ እሳት፡ 
                                        <gap reason="ellipsis"/> ወተምዐ፡ ንጉሥ፡ ደኪዮስ፡ ወፈቀደ፡ ይዝብጦ፡ በጥብጣቤ፡ ፍቱል፡ ወዘበጦ፡ እስከ፡ ይውሕዝ፡ ደሙ፡ ዲበ፡ ምድር። ወወሰድዎ፡

               <msContents>
                  <summary>Bandlet of Righteousness, ልፋፈ፡ ጽድቅ፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="24r" facs="005">Fols 1r–24r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="15v" facs="005">Fols 1r–15v</locus>
                        <title>How Jesus Christ Took Saint Mary to Show her the condition of Sinners</title>
                        <incipit xml:lang="gez">
                    በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/>  መጽሐፈ፡ ሕይወት፡ ወመድኃኒት፡ ልፋፈ፡ ጽድቅ፡ ዘወሀባ፡ አብ፡ ለእግዝእትነ፡ ማርያም፡ እምቅድመ፡ ይትወለድ፡ ክርስቶስ፡ እንተ፡ ታበውእ ውስተ፡ ፀባብ፡ አንቀጽ፡ <gap reason="omitted"/>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="15v" to="19v" facs="020">Fols 15v–19v</locus>
                        <title>Benefits of Reading the Bandlet of Righteousness</title>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="19v" to="22r" facs="024">Fols 19v–22r</locus>
                        <title>Prayers for the journey to heaven, ጸሎት፡ ዘመንገደ፡ ሰማይ።. First prayer (19v–20r), second prayer (20rv), third prayer (20v–21r), fourth prayer (21rv), fifth prayer (21v–22r).</title>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="22r" to="24r" facs="026">Fols 22r–24r</locus>
                        <title>On the Intercession of Angels at the Final Judgment</title>
                        <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted"/>  በደኃሪት፡ ዕለት፡ ይትነሥኡ፡ መላእክት፡ ወ፯መንጦላእት፡ ወበህየ፡ የዓርጉ፡ ጸሎተ፡ በእንተ፡ ምሕረት፡ እንዘ፡ ይብሉ፡ መኑ፡ ሰብእ፡ ዘኢይዔብስ፡ ወመኑ፡ ዕፅ፡ ዘኢይጠይስ፡ <gap reason="omitted"/>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="24v" to="38r" facs="029">Fols 24v–38r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="39r" to="44v" facs="043">Fols 39r–44v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer
                                                  za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
                        <incipit xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡ እግዚአብሔር፡ ዘሥልጣናት፡ እግዚአብሔር፡ ዘአርእስተ፡ መላእክት፡ <gap reason="omitted"/>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="45r" to="50r" facs="049">Fols 45r–50r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2295Sayfam">Sayfa malakot</title>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus from="50r" to="52r" facs="054">Fols 50r–52r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2809RepCh93">Malkǝʾa beta
                                                  krǝstiyān</title>
                        <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ቤተ፡ ክርስቲያን፡ ሎዛ። ቤተ፡ ያዕቆብ፡ ቤተ፡ ወሬዛ፡ <gap reason="omitted"/>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <title>‎Image of the Passion of the Cross, መልክአ፡ ሕማማት።</title>
                        <msItem xml:id="ms_i1.9.1">
                           <locus from="59r" to="90v" facs="063">Fols 59r–90v</locus>
                           <title>Morning, ዘነግህ፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡ ዘመዓዛ፡ አፉኪ፡ ኮል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.2">
                           <locus from="59r" to="62r" facs="063">Fols 59r–62r</locus>
                           <title>The Third Hour, ዘሠለስት፡.‎</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ርግብ፡ ሰማያዊት፡ ወንስር፡ መንፈሳዊት፡ <gap reason="omitted"/>
                           </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.3">
                           <locus from="66r" to="70r" facs="070">Fols 66r–70r</locus>
                           <title>Noon, ዘቀትር፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ውድስት፡ በአፈ፡ ኵሉ፡ ፍጥረት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.4">
                           <locus from="70v" to="73v" facs="075">Fols 70v–73v</locus>
                           <title>The Ninth Hour, ዘሰዓት፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ እክል፡ ሰላም፡ ለኪ፡ መጽዒተ፡ ኃይል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.5">
                           <locus from="74r" to="77v" facs="078">Fols 74r–77v</locus>
                           <title>The Evening, ዘሠርክ፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ድንግል፡ ምልዕተ፡ ጸጋ፡ ምልዕተ፡ ክብር፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.6">
                           <locus from="78r" to="82v" facs="082">Fols 78r–82v</locus>
                           <title>Bedtime, ዘንዋም፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ መንበረ፡ ፀሐይ፡ ሰማይ፡ ዘከዋክብት፡ አክሊላ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.9.7">
                           <locus from="83r" to="90v" facs="087">Fols 83r–90v</locus>
                           <title>Midnight, ዘመንፈቀ፡ ሌሊት፡</title>
                           <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ስብሕት፡ ቀስተ፡ መሐላሁ፡ ለኖኅ፡</incipit>
                        </msItem>
                    </msItem>
                    </msItem>

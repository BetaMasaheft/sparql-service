                        <additions>
                            <list>   
                                <item xml:id="a1" corresp="#h2">
                                    <locus target="#73r"/>
                                    <desc type="GuestText">
                              <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2444Temher">ትምህርተ፡ ኅቡኣት፡</title>,
                                        , the following is the beginning:</desc>
                                    <q xml:lang="gez">በእንተ፡ ትእምርተ፡ ኅቡአት፡ ቅድመ፡ ዘትትነገር፡ እምጵርስፎራ፡ ለምዕመናን፡ ኅቡዓት፡ ትምህርተ፡ ኅቡዓትሰ፡
                                    ከመዝ፡ ንግር፡ ዘቅድመ፡ ሀሎ፡ ወይሄሉ፡ ዘመጽአ፡ ዘሐመ፡ ወሞተ፡ ወተቀብረ፡ ወተንሥአ፡ ፃዕረ፡ ዘሞት፡ ፈትሐ፡ ወእሙታን፡ ተንሥአ።</q>
                                    <notatedMusic>
                                        <desc>Musical notation through interlinear letters and other marks. See the transcription in the catalogue.</desc>
                                    </notatedMusic>
                                </item>
                                
                                <item xml:id="a2" corresp="#h2">
                                    <locus target="#77r"/>
                                    <desc type="GuestText">
                              <title ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>, the following is the beginning:</desc>
                                    <q xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡ እግዚ'፡ ዘሥልጣናት፡ እግዚ'፡ ዘአርእስተ፡ መላእክት፡ እምታሕተ፡ እኂዞትከ፡ ኵሉ፡ 
                                        ፍጥረት፡ ንጉሠ፡ ነገሥት፡ ወእግዚአ፡ አጋዕዝት፡</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus target="#1v"/>
                                    <desc type="MagicText">Protective prayer against all destroyers of the crop.</desc>
                                    <q xml:lang="gez">ጸሎት፡ በእንተ፡ ሰላብያነ፡ እክል፡</q>
                                </item>
                                
                                <item xml:id="a4">
                                    <locus target="#79r"/>
                                    <desc type="PoemArke">
                              <title type="incomplete" ref="https://betamasaheft.eu/LIT2737RepCh21">Hymn to St George</title>, the following is the beginning:</desc>
                                    <q xml:lang="gez">አርኬ፡ ዘቅዱስ፡ ጊዮርጊሰ። ሰላም፡ ለልደትከ፡ አመሰ፪ለጥር። እማኅፀነ፡ ብእሲት፡ ክብርት፡ 
                                        ወእምሐቈ፡ ብእሲ፡ ክቡር። ኮከበ፡ ምድረ፡ ፋርስ፡ ጊዮርጊስ፡ ወፀሐየ፡ ልዳ፡ ሐገር።</q>
                                </item>
                                
                                <item xml:id="a5">
                                    <locus target="#78v"/>
                                    <desc type="Unclear"/>
                                    <q xml:lang="gez">የዕለታት፡ ተውሳክ፡</q>
                                </item>
                                
                                <item xml:id="a6">
                                    <locus target="#78v"/>
                                    <desc type="Unclear"/>
                                    <q xml:lang="gez">ያጽዋማት፡ ተውሳክ።</q>
                                </item>
                                
                                <item xml:id="a7" corresp="#h4">
                                    <locus target="#78v"/>
                                    <desc type="MagicText">Prayer against hail.</desc>
                                    <q xml:lang="gez">ጸሎት፡ በረድ፡</q>
                                </item>
                                
                                
                                
                                <item xml:id="e1">
                                    <desc>The name of the first owner has been erased in <ref target="#ms_i1"/>, names of
                                        later owners were <persName role="owner" ref="https://betamasaheft.eu/PRS11843Gabra">Gabra <gap reason="illegible"/>
                              </persName>
                                        and <persName role="owner" ref="https://betamasaheft.eu/PRS11844EnqwaS">ʿƎnqʷa Śǝllāse</persName>.</desc>
                                </item>
                                <item xml:id="e2">
                                    <locus target="#72v"/>
                                    <desc>The name of the scribe of <ref target="#ms_i1"/> is partially erased, but seems to be
                                        <persName role="scribe" ref="https://betamasaheft.eu/PRS11845Atnatewos">ʾAtnātewos</persName>.</desc>
                                </item>
                                <item xml:id="e3">
                                    <locus target="#78r"/>
                                    <desc>The name of the scribe of <ref target="#a1"/> and <ref target="#a2"/> was
                                        <persName role="scribe" ref="https://betamasaheft.eu/PRS11846Anorewos">ʾAnorewos</persName>.</desc>
                                </item>
                            </list>
                        </additions>
                        

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="187r">1r-187r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>جنت الفردوس نزلا , خلدين فيها لا يبغون عنها حولا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#187r">-187r</locus>الذي يوسوس في صدور الناس . من الجنة والناس</explicit>
                     <note>The text begins with the three last words of verse 18:107 (fol. 1r). Some of the fols bound in wrong order. Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="187v" to="188v">187v-188v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3815IHA">دعاء ختم القران اللهم انفعنا بالقران العظيم واهدنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#187v">-187v</locus>بسم الله الرحمن الرحيم صدق الله العلي العظيم الحي الحليم الحي الكريم الحي الدائم الحي القيوم الحي الذي لا يموت ولايفوت ولا يحول ولا تزول ملكه [...] اللهم انفعنا وارفعنا بالقرءان العظيم واهدنا بالايت والذكر الحكيم وتقبل منا قراتنا ختم القرءان وتجاوز عنا ما كان منا في تلاوة القرءان من خطاء او نسيان</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#188v">-188v</locus>وصلى الله على خير خلقه محمد وعلى ءاله وصحبه اجمعين برحمتك يارحم الرحمين </explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ዘገብረ፡ ተዋሕዶተ፡ ነፍስ፡ በሥጋ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እንብብ፡ ወእዘምር፡ ቅድመ፡ እንግልጋ፨</l>
                  <l n="3">ለቤተ፡ ክርስቲያን፡ ቅድስት፡ ኤዎስጣቴዎስ፡ መጋቤ፡ ሕጋ፨</l>
                  <l n="4">ምላእ፡ አፉየ፡ ስብሐቲከ፡ እንበለ፡ ሕፀፅ፡ ወንትጋ፨</l>
                  <l n="5">እስመ፡ ለኵሉ፡ የአክል፡ ዘዚአከ፡ ጸጋ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ በሥምረተ፡ አምላክ፡ መሐሪ፨</l>
                  <l n="2">ከመ፡ ተጠየቀ፡ ቅድመ፡ እምልሳነ፡ መልአክ፡ አብሳሪ፨</l>
                  <l n="3">ኤዎስጣቴዎስ፡ ነጊሠ፡ አመ፡ ምስለ፡ ክርስቶስ፡ ትዔሪ፨</l>
                  <l n="4">እጸንሐከ፡ እግዚኦ፡ ልደ፡ ቤትከ፡ ነባሪ፨</l>
                  <l n="5">ማኅደረ፡ ሕይወትየ፡ ትሥራዕ፡ በዘመን፡ ደኃሪ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለልደትከ፡ እመንፈስ፡ ቅዱስ፡ ወማይ፨</l>
                  <l n="2">እስመ፡ ተሐደስከ፡ ቦቱ፡ እምልደተ፡ ሥጋ፡ ብሉይ፨</l>
                  <l n="3">ቅብአ፡ ቤተ፡ ክህነት፡ ወንግሥ፡ ኤዎስጣቴዎስ፡ ኅሩይ፨</l>
                  <l n="4">ለምግባረ፡ ጽድቅከ፡ ዕፍረት፡ ዘመዐዛሁ፡ ሠናይ፨</l>
                  <l n="5">ኢይትዔረዮ፡ ናርዶስ፡ ወኵሉ፡ መጽርይ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እንተ፡ ተበፅዐ፡ በሕቁ፨</l>
                  <l n="2">አምሳለ፡ መልከ፡ ጼዴቅ፡ ካህን፡ ዘተአምረ፡ ሞገሰ፡ ጽድቁ፨</l>
                  <l n="3">ኤዎስጣቴዎስ፡ ኤፌሶን፡ ለባሕረ፡ ውቅያኖስ፡ ልጹቁ፨</l>
                  <l n="4">ቀላየ፡ ፍቅርከ፡ ዘኢይሰፈር፡ ዕመቁ፨</l>
                  <l n="5">አካለ፡ ኅሊናየ፡ ያሥጥም፡ በዘይፌጽም፡ ጻህቁ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">እንበይነ፡ ዝንቱ፡ ማሕሌት፡ በዘትትፌሣሕ፡ ነፍስየ፨</l>
                  <l n="2">እንዘ፡ ከመ፡ ዕጣን፡ ትትዌከፍ፡ ስእለተ፡ ልብየ፨</l>
                  <l n="3">ኦመዝገበ፡ ለፅኑሰ፡ ምግባር፡ ብዕልየ፨</l>
                  <l n="4">ኢትመንነኒ፡ ለወልድከ፡ ኤዎስጣቴዎስ፡ አቡየ፨</l>
                  <l n="5">እስመ፡ ሰብአ፡ ዓለም፡ መነኑ፡ ወጸልኡ፡ ነዳየ፨</l>
               </lg>
            </div>
         </div>
      </body>

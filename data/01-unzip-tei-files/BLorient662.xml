                        <handDesc>
                            <handNote script="Ethiopic" xml:id="h1">
                                <date notBefore="1730" notAfter="1755"/>
                                <desc>Written in a fine hand. <persName role="scribe" ref="https://betamasaheft.eu/PRS13733Mikael">Mikāʾel</persName>, 
                                    <persName role="scribe" ref="https://betamasaheft.eu/PRS13734TawaldaM">Tawalda Madḫǝn</persName> and <persName role="scribe" ref="https://betamasaheft.eu/PRS13735WaldaD">Walda Dāwit</persName> are mentioned as scribes in
                                    <ref target="#a2"/> (<locus target="#1ra"/>) and <ref target="#a4"/> (<locus target="#2va"/>). Changes of hand
                                cannot be observed in the manuscript, but cannot be completely excluded. It might also be possible that these notes refer
                                to the production of all four volumes of this Synaxarion, with one scribe being responsible for one quarter of the year.
                                 </desc>
                            </handNote>
                        </handDesc>
                        
                        <additions>
<list>
    
    <item xml:id="a1">
        <locus target="#1rb"/>
        <desc type="OwnershipNote">The note states that the production of the manuscript was sponsored by <persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName>.</desc>
        <q xml:lang="gez">ዝስንክሣር፡ ዘ<persName role="owner" ref="https://betamasaheft.eu/PRS12552NabiyaLeul"><roleName type="title">እራስ፡</roleName> ወልደ፡ ልዑል፡</persName> ዘአጽሐፎ፡ በንዋዩ፡ ከመ፡ ይኩኖ፡ ለመድኃኖተ፡ ሥጋ፡ ወነፍስ፡ አመ፡ በግርማሁ፡ ይመጽእ፡ ክርስቶስ፡ ለቅዱስ፡ ዮሐንስ፡ መጥምቅ፡ ወጸያሔ፡ ፍኖት</q>
    </item>
    
    <item xml:id="a2">
        <locus target="#1ra"/>
        <desc type="OwnershipNote">The note states that the manuscript was copied by <persName ref="https://betamasaheft.eu/PRS13733Mikael">Mikāʾel</persName> and belongs to
            <persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName>,  <persName ref="https://betamasaheft.eu/PRS12553WalataKidan">Walatta Kidān</persName>, and his son.</desc>
        <q xml:lang="gez"><hi rend="rubric"><gap reason="illegible" unit="chars" n="1"/>ጽሐፈ፡ መጽሐፈ፡ ስን</hi>ክሣር፡ ዘጸሐፈ፡ 
            <persName role="scribe" ref="https://betamasaheft.eu/PRS13733Mikael"><roleName type="title">አባ፡</roleName> ሚካኤል፡</persName> ዝመጽሐፍ፡ 
            ዘ<persName role="owner" ref="https://betamasaheft.eu/PRS12552NabiyaLeul">ነቢየ፡ ልዑል፡</persName> ወዘ<persName role="owner" ref="https://betamasaheft.eu/PRS12553WalataKidan">ወለተ፡ ኪዳን፡</persName> ወዘወልዱ፡</q>
    </item>
    
    <item xml:id="a3">
        <locus target="#1rb"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to <persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName>, and mentions after an erasure "his sister" 
            <persName ref="https://betamasaheft.eu/PRS2682BerhanM">Bǝrhān Mogasā</persName> and <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>.</desc>
        <q xml:lang="gez">ዝመጽሐፍ፡ ዘ<persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">ነቢየ፡ ልዑል፡</persName>
           <del rend="erasure"/>
            እኅቱ፡ ንግሥትነ፡ <persName ref="https://betamasaheft.eu/PRS2682BerhanM">ወለተ፡ ጊዮርጊስ፨</persName><cb n="c"/>ወዘንጉሥነ፡ <hi rend="rubric">ኢያሱ፡</hi> መፍቀሬ፡ ሃይማኖት፡ ከመ፡ ቆስጠንጢኖስ፡ ወየጥሕ፡ ከመ፡ ዳዊት፡
        ወጠቢብ፡ ከመ፡ ሰሎሞን፨</q>
    </item>
    
    <item xml:id="a4">
        <locus target="#2va"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to <persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName>, and mentions as scribes
            <persName role="scribe" ref="https://betamasaheft.eu/PRS13734TawaldaM">Tawalda Madḫǝn</persName> and <persName role="scribe" ref="https://betamasaheft.eu/PRS13735WaldaD">Walda Dāwit</persName>.</desc>
        <q xml:lang="gez">ዝስንክሣር፡ ዘ<persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">ነቢየ፡ ልዑል፡</persName> ዘጸሐፍዎ፡
            <persName role="scribe" ref="https://betamasaheft.eu/PRS13734TawaldaM"><roleName type="title">አባ፡</roleName> ተወልደ፡ መድኅን፡</persName>
            ወ<persName role="scribe" ref="https://betamasaheft.eu/PRS13735WaldaD">ወልደ፡ ዳዊት፡</persName> ምሉዓነ፡ አእምሮ፡ ካህናት፡
        ወሠናያነ፡ ምግባር፡ ወሃይማኖት፡</q>
    </item>
    
    <item xml:id="a5">
        <locus target="#2vb"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to <persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName>, <foreign xml:lang="gez">መልአከ፡ ኃይል፡</foreign>
            of <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>.</desc>
        <q xml:lang="gez">ዝመጽሐፍ፡ ዘ<hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul"><roleName type="title">እራስ፡</roleName> ነቢየ፡ ልዑል፡</persName></hi> መልአከ፡ ኃይሉ፡ ለ<persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName> ወልደ፡</q>
    </item>
    
    <item xml:id="a6">
        <locus target="#3r"/>
        <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
            <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
        <q xml:lang="gez">ስንክሳር፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
        </q>
    </item>
    
    <item xml:id="e1">
        <desc><persName ref="https://betamasaheft.eu/PRS12552NabiyaLeul">Nabiya Lǝʿul</persName> and his daughter <persName ref="https://betamasaheft.eu/PRS12553WalataKidan">Walatta Kidān</persName> are mentioned throughout in supplications.</desc>
    </item>
    
    <item xml:id="e2">
        <locus target="#1v"/>
        <desc>Several erased notes.</desc>
    </item>
    
    <item xml:id="e3">
        <locus target="#2rb"/>
        <desc>Pen trial.</desc>
    </item>
    
    <item xml:id="e4">
        <locus target="#3r #44r #80r"/>
        <desc>Decorated name of the month written in the upper margin of the first folium of each month.</desc>
    </item>
    
    <item xml:id="e5">
        <locus target="#1r"/>
        <desc>Stamps and shelfmarks of the library.</desc>
    </item>
</list>

                  <idno n="130" facs="EMIP/Codices/104/" corresp="https://betamasaheft.eu/api/iiif/EMIP00104/manifest">Weiner Codex 18</idno>
               </msIdentifier>
               <msContents>
                  <summary>Image of Mary, መልክአ፡ ማርያም፡; Image of Jesus Christ, መልክአ፡  ኢየሱስ፡; Image of Arägawi/Zä-Mika'el, መልክዐ፡ አረጋዊ፡ /ዘሚካኤል፡;  Image of Gäbrä Mänfäs Qǝddus, መልክአ፡ ገብረ፡ መንፈስ፡ ቅዱስ፡;
                    Image of Michael, መልክአ፡ ሚካኤል፡; Image of Gabriel, መልክአ፡ ገብርኤል፡; Image of Saint George, መልክአ፡ ጊዮርጊስ፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="15v" facs="007">Fols 3r–15v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkǝʾa
                                                  Māryām</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="15v" to="30r" facs="032">Fols 15v–30r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4131Salam">Salām to Jesus
                                                  Christ</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="30r" to="37v" facs="061">Fols 30r–37v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2998RepCh278">Hymn to Za-Mikāʾel
                                                  ʾAragāwi</title>
                    <incipit xml:lang="gez">
                      በስመ፡ እግዚአብሔር፡ እምግብጽ፡ ፍኖተ፡ ግዕዛን፡ ዘመርሖ። ለእግረ፡ እስራኤል፡ ሞቅሆ። እማዕሠረ፡ ቅኔ፡ ዘተፈትሖ።
                    </incipit>
                    </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="27v" to="42r" facs="056">Fols 27v–42r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkǝʾ-hymn to
                                                  Gabra Manfas Qǝddus</title>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="42r" to="52v" facs="085">Fols 42r–52v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa
                                                  Mikāʾel</title>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="52v" to="59v" facs="106">Fols 52v–59v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa
                                                  Gabrǝʾel</title>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="59v" to="60v" facs="120">Fols 59v–60v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾ-hymn to St
                                                  George</title>
                    <incipit xml:lang="gez">
                      ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ። ዘያሜኒ፡ ኵሎ፡ ወያስተሴፉ። ጥዑመ፡ ዜና፡ ጊዮርጊስ፡ ለሐሊብ፡ እጐልት፡ ሱታፉ።
                    </incipit>
                    </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">60</measure>

                                 <dim unit="leaf">12</dim>
                                 <locus from="35" to="46" facs="071">Fols 35–46</locus>
                              Quire 4
                            </item>
                              <item xml:id="q6" n="5">
                                 <dim unit="leaf">10</dim>
                                 <locus from="47" to="56" facs="095">Fols 47–56</locus>
                              Quire 5
                            </item>
                              <item xml:id="q7" n="6">
                                 <dim unit="leaf">4</dim>
                                 <locus from="57" to="60" facs="115">Fols 57–60</locus>
                              Quire 6
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">15</dim>
                              <dim type="bottom">32</dim>
                              <dim type="right">15</dim>
                              <dim type="left">12</dim>
                           </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="15">
                           <locus from="3r" to="60v" facs="007">Fols 3r–60v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <ref target="#ms_i1"/>
                           <note>Lines written in red ink:
                          <locus target="#3r" facs="007"> f. 3r, lines 1, 2, 5 and 6</locus>
                        </note>
                           <ref target="#ms_i5"/>
                           <note>Lines written in red ink:
                          <locus target="#42r" facs="085"> f. 42r, lines 12 and 13</locus>;
                        </note>
                           <ref target="#ms_i6"/>
                           <note>Lines written in red ink:
                          <locus target="#52v" facs="106"> f.52v, lines 11, 12, and 15</locus>
                          <locus target="#53r" facs="107"> f. 53r, line 1</locus>
                        </note>
                           <note>
                          Names of
                          <foreign xml:lang="gez">እግዚአብሔር፡</foreign>,
                          <foreign xml:lang="gez">ማርያም፡</foreign>
                          and angels and saints rubricated throughout
                        </note>
                        </seg>
                      </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#2v" facs="004">Fol. 2v</locus>
                        <desc>
                           <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/>, <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d2">
                      Decorative designs:
                      <locus target="#3r" facs="007">fol. 3r</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red);
                      <locus target="#28r" facs="057">28r, </locus>, (crosshatch lines using red and black);
                      <locus target="#30r #37v #42r #52v" facs="061 076 083 106">30r, 37v, 42r, 52v</locus>, (multiple full-stop symbols used as section dividers)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="e1">
                           <desc>
                              <locus target="#2r" facs="005">Fol. 2r</locus> Pen trial</desc>
                        </item>
                        <item xml:id="a1">
                           <desc type="ScribalNoteCommissioning">Copied for <foreign xml:lang="gez">ወልደ፡ ዜና፡ ማርቆስ፡</foreign>, <locus target="#30r #37r" facs="061 075"> f. 30r, 37r and passim</locus></desc>
                        </item>
                        <item xml:id="e2">
                           <desc>
                          Overlooked words of text are written interlinearly
                          (<locus target="#7r #9r #14r #16r #18v #30v" facs="015 019 029 033 038 062">folss. 7r, 9r, 14r, 16r, 18v, 30v, </locus>, etc.) and with the symbol (┴) marking the location where the text is to be inserted
                          (<locus target="#46r" facs="093">46r, </locus>); and overlooked lines of text are written interlinearly
                          (<locus target="#12v #13v #42r" facs="026 028 085">12v, 13v, 42r, </locus>, ); and in the bottom margin with a symbol (┴) marking the location where the text is to be inserted
                          <locus target="#42r" facs="085"> f. 42r, line 13</locus> and <locus target="#47v" facs="096"> f. 47v, line 14</locus>)
                        </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>
                              <locus target="#1r #1v" facs="003 004">Fols. 1r, 1v</locus> blank</desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 160 x 100–105 x 40 mm, three Coptic chain stitches attached with bridle attachments to rough-hewn boards of (non-traditional) soft wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: fine and careful, by well-trained hand; Hand b:
                           Mediocre.</seg>
                        <seg type="ink">Black (bleak), red (vivid red, strong red)</seg>
                        <date>18th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ወይ፡ ሕ፡</abbr> for <expan>ወይበሉ፡ ሕዝብ፡ </expan> (e.g., <locus target="#12rb">12rb</locus>, 74ra)</item>
                           <item>
                              <abbr>ፍ፡ / ፍ፡ ረ፡</abbr> for <expan>ፍቱሐ፡ ረስዮ፡ ለዝንቱ፡ በድን፡ </expan>
                              (e.g., <locus target="#17vb">17vb</locus>, 18ra, 19rb)</item>
                           <item>
                              <abbr>ይ፡ ካ፡</abbr> for <expan>ይበል፡ ካሕን፡ </expan> (e.g., <locus target="#64ra">64ra</locus>, 73vb, 74ra)</item>
                           <item>
                              <abbr>ይ፡ ዲ፡</abbr> for <expan>ይበል፡ ዲያቆን፡ </expan> (e.g., <locus target="#71vb">71vb</locus>, 73vb, 74ra)</item>
                           <item>
                              <abbr>ምል</abbr> for <expan>ምልጣን </expan> (e.g., <locus target="#110rb">110rb</locus>, 111rb, 112ra)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donors; two groups of
                           lines on the incipit page of the text, alternating with black lines; two
                           initial lines of each section of the text; name of Hebrew letter in Ps.
                           118 (fol. 32ra); abbreviations; elements of the punctuation signs;
                           elements of Ethiopic numerals; some other words, e.g., ṣällǝyu (e.g.,
                           fols. 3vb, 4ra), nǝbäl (e.g., fols. 4rb, 5rb), halle luya (e.g., fols.
                           5vb, 6ra), qǝdmä wangel (e.g., fols. 33rb, 36rb), wa-ʾǝmzǝ (e.g., fols.
                           33vb, 46vb), mǝʿrāf (fol. 49vb).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="3ra" to="113vb">3ra-113vb</locus> (quires I-XIV); the handwriting remains uniform
                        throughout the Ms. and is characterized by finely shaped and slightly
                        right-sloping letters. It shows Gondarine influence.
                        </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="115ra" to="130vb">115ra-130vb</locus> (quires XV-XVII); rounded and small
                        letters.</handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2rb">f. 2rb</locus>
                           <desc>: Excerpt from Mǝʿrāf, “Common of the Office”.</desc>
                           <quote xml:lang="gez">
                              <locus target="#2rb">2rb</locus>: ክርስቶስ፡ ክርስቶስ፡ ክርስቶስ፡ አንተ፡ ወልዱ፡ ለቡሩክ፡
                              ከሣቴ፡ ብርሃን፡ ተሠሃ[ለ]ነ። ጋዳ፡ ጋዳ፡ ጋዳ፡ ለአብ፡ ወወልድ፡…</quote>
                           <quote xml:lang="en"/>
                           <note> The text is excerpted specifically from the part called Sǝbḥāta
                              nagh. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#113vb">f. 113vb</locus>
                           <desc>: Donation note.</desc>
                           <quote xml:lang="gez">
                              <locus target="#113vb">113vb</locus>: ዘአጽሐፎ፡ &lt;…&gt; በዘመነ፡ ንጉሥነ፡
                              &lt;…&gt; ለእመ፡ ነግሡ፡ {በ}፪ዓመት፡ ወ፭አውራኅ፡ ዓመተ፡ መንግሥት፡ ውእቱ፡ እግዚአብሔር፡ ይረሲ፡
                              ሎመ፡[sic] ለመንግሥተ፡ ሰማያት፡ አሜን። ወአሜን። </quote>
                           <quote xml:lang="en"/>
                           <note> The note is written in hand a. Name(s) of the donor(s) and the
                              king have been erased. </note>
                        </item>
                        <item xml:id="e1">- Scribbles and doodles in the margins: <locus target="#33v">33v</locus>, 36r, 49r.
 - Small script is used on
                              <locus from="106rb" to="113vb">106rb-113vb</locus>.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">- Notes in the upper margins referring to the
                              content of the Ms., in the main hand: fols. 24r, 31v, 33r, 38r, 40v,
                              43r, 45r, 54v, 58r, 60r, 62r, 67r, 68v, 71r, 75r, 123r. - Coloured
                              threads have been inserted in the upper and outer margins of fols. 40,
                              47, 48, 61, 84, 123.</desc>
                        </item>
                     </list>
                  </additions>

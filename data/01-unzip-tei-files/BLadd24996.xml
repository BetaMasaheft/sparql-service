                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="1r">Fols 1r and following</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT3945ArdeetBE">Maṣḥafa ʾardǝʾt</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ይትባረክ፡ እግዚአብሔር፡ አምላከ፡ እስራኤል፡ አምላክ፡ ለኵሉ፡ መንፈስ፡ ወለኵሉ፡ ዘሥጋ።
                            ነገር፡ ዘነገሮሙ፡ ለ፲ወ፪ አርድእት፡ ዘከመ፡ ነገሮሙ፡ ለአርዳኢሁ፡ ወከመዝ፡ ትድኅኑ፡
                            እመቅሠፍት፡ ወለእመሂ፡ እነግረክሙ፡ አነ፡ ለዝ፡ ትድኅኑ፡ እመቅሠፍት፡ ወእምኵሉ፡ ኀጢአት፡
                            <sic>እኩየ፡</sic> ዘበምድር፡ ወቀስተ፡ እጓለ፡ እመሕያው፡ በዝ፡ ትድኅኑ፡ እምኵሉ፡
                            አራዊተ፡ ምድር፡ ወእምኵሉ፡ ሕምዝ፡ ዘይቀትል፡
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <locus from="11v">Fols 11v and following</locus>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1802Lifeof">
                            <certainty locus="value" match="../@ref" cert="low"/>
                          </title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ዛቲ፡ መጽሐፍ፡ ኢተጽሕፈ፡ በእደ፡ ሰብእ፡ አላ፡ ለሊሁ፡ መድኃኒነ፡ ጸሐፈ፡ በዕደዊሁ፡ ለእሉኒ፡
                            አንቢበከ፡ ቅዱስ፡ ደሚረከ፡ አንበበ፡ ወይከውነከ፡ ወመግረሬ፡ ፀር፡ ወሞገስ፡ ፍጹመ፡ ወመግረሬ፡
                            ዘይገብር፡ በጸሎት፡ ንነግረክሙ፡ ንሕነ፡ በዘድኅነ፡ ሙሴ፡ እምእዴሁ፡ ለፈርዖን፡ ወጸሎቱ፡ ወስእለቱ፡
                            ዘወሀበ፡ እግዚአብሔር፡ ወመግረሬ፡ ፀር፡ ወቀዲሙሰ፡ ወወረደ፡ ገብርኤል፡ መልአክ፡ ወይቤሎ፡
                            እግዚአብሔር፡ ወኢትፍራህ፡ ሙሴ፡ ተሰምዓ፡ ጸሎትከ፡ ወስእለትከ፡ ኀበ፡ እግዚአብሔር፡
                          </incipit>
                        </msItem>
                    </msContents>


               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="2v">2v-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0692IHA">دعاء اللهم لك الحمد منا ولك الشكر اذ هديتنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>يقرا هذا الدعا قبل القراة عند ارادة قراة القران \ بسم الله الرحمن الرحيم اللهم صل على محمد وعلى ال محمد اللهم لك الحمد منا ولك الشكر اذ هديتنا للايمان وعلمتنا القران</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>اللهم انا نقرا كتابك العزيز لنيل الدرجات العلي ولاسقاط الذنوب ولقضاء الحاجات ولنور القلوب ولطرد الشيطان الرجيم \ ثم ىىدا يقول اعوذ بالله من الشيطان 

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3v" to="261r">3v-261r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ الرَّحْمَنِ الرَّحِيمِ مَالِكِ يَوْمِ الدِّينِ إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#255v">-255v</locus>قُلْ أَعُوذُ بِرَبِّ النَّاسِ مَلِكِ النَّاسِ إِلَهِ النَّاسِ مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ مِنَ الْجِنَّةِ وَالنَّاسِ
</explicit>
                     <note>fol. 2v, 3v-4r simply decorated šamsa and sarlawḥ; decorated ḥizb sections on margins.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="256v" to="257v">256v-257v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0685IHA">دعاء ختم القرآن اللهم اجعلنا بهذا التصديق صادقين</title>
                     <incipit xml:lang="ar">
                        <locus target="#256v">-256v</locus>بسم الله الرحمن الرحيم \ صدق الله العلي الخالق القوي الرازق الذي ليس له والد سابق ولا ولد لاحق ولا شريك موافق ولا معين مرافق [...] اللهم اجعلنا بهذا التصديق صادقين وبهذد الصدق شاهدين وبهذا الشهادة مومنين وبهذا الايمان منبين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#257v">-257v</locus>اغفر لنا ولاخواننا الذين سبقونا بالايمان ولا تعجل فى قلوبنا غلا للذين امنوا ربنا انك روف رحيم واخر دعواهم ان الحمد لله رب العلمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين وصلى الله على سيدنا محمد واله [وصحبه] تسليما</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="257v" to="258r">257v-258r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0688IHA">دعاء ختم القرآن الهمّ اجعلنا لنعمائك شاكرين</title>
                     <incipit xml:lang="ar">
                        <locus target="#257v">-257v</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ اللهم اجعلنا لنعمايك شاكرين , وعن بلايك ناجين , وبما قضيت علينا راضين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#258r">-258r</locus>اللهم اجعل لنا خير الدنيا والاخرة وقنا شر الدنيا والاخرة وبرحمتك يا ارحم الراحمين سبحان ربك رب العزة عما ىصفون وسلام علي المرسلين والحمد لله رب العالمين وصلى الله على سىدىا محمد واله وسلم

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="258r" to="259r">258r-259r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0631IHA">دعاء ختم القرآن لشهاب الدين ابي العباس احمد بن عمر
                    الزيلعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#258r-258v">-258r-258v</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ صدق الله العظيم الجليل الذي لا اله الا هو عالم الغيب والشهادة هو الرحمن الرحيم [...] اللهم صل على سيدنا محمد وعلى ال محمد اللهم كما مننت علينا بتعلم القران العظيم وتعليمه فامنن علينا بحفظه اللهم اعصمنا من الخطا في تلاوته ومن الزلل في فهمه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#259r">-259r</locus>ولمشايخنا فى الدين لعامة المسلمين بفضلك ورحمتك يا ارحم الراحمين سبحان ربك رب العزه عما يصفون وسلام على المرسلين والحمد لله رب العلمين وصلى الله على سىدىا محمد واله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="259r" to="260r">259r-260r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4126IHA">دعاء ختم القران اجعل اللهم له ثواب قراتنا وبركة
                    دعائنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#259r">-259r</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ صدق الله العظيم وصدق رسوله النبي الكريم ونحن على ذلك من الشاهدين والحمد لله رب العلمين صدق الله القديم بالصفات والاسما [...] اجعل اللهم له ثواب قراتنا وبركة دعاينا واستغفارنا لم جمعتنا بسببه  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#260r">-260r</locus>انعم الله عليهم من النبيين والصديقين والشهدا والصلحين وحسن اوليك رفيقا ذلك الفضل من الله كفى بالله عليما دعواهم فيها سبحانك اللهم وتحيتهم فيها سلام واخر دعواهم ان الحمد لله رب العلمين سىحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="260r" to="261r">260r-261r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#260r">-260r</locus>دعا حىم القران العطىم \ بسم الله الرحمن الرحيم \ اللهم ارحمنا بالقران العظيم وانفعنا بالايت والذكر الحكيم وبارك لنا فى السبع المثاني والقران العظيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#260v-261r">-260v-261r</locus>اللهم اشف مرضانا وعاف مبتلانا وارحم موتانا وتمم نعمتك علينا واجعل اجتماعنا ودعانا وتاميننا بركة [لنا] في ديننا ودنيانا وشفا لنا من كل دا وسقم وفرج عنا من كل هم وغم برحمتك يا ارحم الرحمين سىحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين وصلى الله على سيدىا [محمد] واله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="261r" to="261r">261r-261r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0691IHA">دعاء ختم القرآن اللهم اجعل ثواب ما قرأته وبركة ما
                    دعوته</title>
                     <incipit xml:lang="ar">
                        <locus target="#261r">-261r</locus>دعا ختم القران العطىم \ بسم الله الرحمن الرحيم \ اللهم اجعل ثواب ما قراته وبركة ما دعوته فى ساعتي هذه هدية واصلة ورحمة منك نازلة متصله الى الراح والدي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#261r">-261r</locus>اللهم وارحم وارحم جيرانهم من اهل التوحيد وارحم امواتنا واموات المسلمين اجمعين برحمتك يا ارحم الراحمين سىحان ربك الخ</explicit>
                     <note/>
                     <note/>
                  </msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="121v">1v-121v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0002IHA#s89IHA">تنبيه الانام, al-Ǧuz’ al-ṯānī</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>باب فيما اظهره الله من الكرامات الخارقات للعادات اللهم [صل وسلم على سيدنا ومولانا] محمد الذي كلمته ناقته العضبا ونصر بريخ الصبا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#121v">-121v</locus>اللهم بجلالك وسلم وبارك على سيدنا ومولانا محمد خاتم النبيين وامام المرسلين والحمد لله رب العالمين امين تمت </explicit>
                     <note>The text begins with a chapter that according to the printed versions is the beginning of Part 2 (cf. WEINER097 and WEINER191). Vocalized.</note>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>
                        <extent>
                           <measure unit="folio">122</measure>
                                        Pre: <measure unit="folio">2</measure>
                                        Post: <measure unit="folio">0</measure>

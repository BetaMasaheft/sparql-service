               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="77v">2v-77v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0020IHA#s3IHA">منهاج الطالبين, From the beginning of kitāb al-bay‘
                    to the end of kitāb al-ǧi‘āla (second rub‘) 2/4</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>كتاب البيع شرطه الايجاب كبعتك وملكتك وان القبول كاشتريت وتملكت وقيلت ويجوز تقدم لفظ المشتري</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#76v">-76v</locus>وان قال قال زيد من رد عبدى فله كذا وكان كاذبا لم يتحق علي ولا على زيد ولاشترط</explicit>
                     <note>End missing. Some of the words are divided into two different lines</note>
                     <note/>
                  </msItem>
               </msContents>

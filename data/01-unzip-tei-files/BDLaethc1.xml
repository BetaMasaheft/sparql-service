               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                        <locus from="1r" to="206v">Fols 1r–206v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</title>
                        <textLang mainLang="gez"/> 
                     <note>There are numerous variants, duplications, glosses and embellishments as compared with printed versions.</note>
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r">Fols 1r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionGospels">Four Gospels, Introduction to the  Four Gospels (same as LIT2705Introd)</title>
                        <textLang mainLang="gez"/> 
                        
                        <msItem xml:id="ms_i1.1.1">
                           <locus from="1r" to="2r">Fols 1r–2r</locus>
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionGessawe">
                              <hi rend="rubric">ግጻዌ፡ ሥርዓት፡</hi>
                           በእንተ፡ ኅብረተ፡ ቃላት፡ ዘአርባዕቱ፡ ወንጌላት።</title>
                           <note>The last sentence of <ref type="work" corresp="https://betamasaheft.eu/LIT1560Gospel#IntroductionGessawe"><span xmlns="" class="w3-tag w3-red">No item: LIT1560Gospel#IntroductionGessawe</span></ref>
                           on <locus target="#2r">fol. 2r</locus> is copied in a pupil's hand, <ref target="#h2"/>, next to the original.</note>
                           <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.2">
                           <locus from="2r">Fols 2r and following</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1349EpistlEusebius">Epistle of Eusebius to Carpianus (generic  record)</title>
                           <textLang mainLang="gez"/> 

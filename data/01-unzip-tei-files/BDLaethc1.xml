                           <locus from="31r" to="57r">31r–57r</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2711Mark">Bǝsrāta Mārqos</title>
                           <textLang mainLang="gez"/> 
                           <note>
                              <locus from="60r" to="67v">Fols 60r–67v, </locus> contains Mark 1:1-5:20. <locus target="#31r">31r</locus> starts with Mark 5:20.</note>
                           <note>On <locus target="#62v">fol. 62v</locus> there is an erroneous rubricated heading <foreign xml:lang="gez">ማቴዎስ</foreign>
                           </note>
                        </msItem>
                     </msItem>
                     

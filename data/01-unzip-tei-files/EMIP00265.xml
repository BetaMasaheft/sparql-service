                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                  </seg>
                  <desc>The words Mary and Jesus Christ are rubricated</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1v" facs="002">Fol. 1v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#52v" facs="053">Fol. 52v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#53r" facs="053">Fol. 53r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> with arms folded across chest stands before seated man</desc></decoNote>
                    <decoNote type="frame" xml:id="d4">
                    Decorative designs:
                    <locus target="#15v #19r #23v #24v #28v #33v #34r #43v #47v" facs="016 019 024 025 029 034 044 048">folss. 15v, 19r, 23v, 24v, 28v, 33v, 34r, 43v, 47v, </locus> (multiple full stops);
                    <locus target="#52r" facs="052">52r</locus> (a line of alternating red and black dots between lines of full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    The hand is very well trained
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#1r #53v" facs="001 054">Fols. 1r, 53v</locus>
                    blank
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#2v" facs="003"> f. 2v and passim</locus>
                    The archbishop Matewos (1843–1926) and Metropolitan Qerǝlos (Cyril V, 1875–1927) are mentioned
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="OwnershipNote">
                    <locus target="#15v" facs="016">Fol. 15v</locus>
                    Note of ownership, Wäldä Täklä Haymanot. Copied by Amdä Haymanot
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <locus target="#24v" facs="025">Fol. 24v</locus>
                    Prayer for Wäldä Täklä Haymanot, the presumed owner
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#52r" facs="052">Fol. 52r</locus>
                      “Written in 1932 E.C. The scribe is Habtä Maryam Ḫaylu.”
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    <locus target="#52r" facs="052">Fol. 52r</locus>
                    “This book was given to me by Ato Asčännaqi,” written in blue ink
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                      Scribal intervention:
                      words of text are written interlinearly (<locus target="#5v #7v #10r #11v" facs="006 008 010 012">folss. 5v, 7v, 10r, 11v, </locus>, etc.);
                      words of text are written interlinearly with a symbol (┬) marking the location where the text is to be inserted (<locus target="#19v" facs="020"> f.19v, col. 2, line 14</locus>)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 178 x 124 x 30 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1939">1932 E.C. (= 1939/40, <locus target="#52r" facs="052">fol. 52r</locus>)</origDate>
                  </origin>
               </history>

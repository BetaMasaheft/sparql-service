                  <idno n="138" facs="EMIP/Codices/265/" corresp="https://betamasaheft.eu/api/iiif/EMIP00265/manifest">Weiner Codex 88</idno>
               </msIdentifier>
               <msContents>
                  <summary>Anaphora of Our Lady Mary by Cyriacus of Bǝhǝnsa, ቅዳሴ፡ ማርያም፡, and Sword of the Trinity, ሠይፈ፡ ሥላሴ፡, ሠይፈ፡ ሥላሴ፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="2r" to="15v" facs="002">Fols 2r–15v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="16r" to="52r" facs="016">Fols 16r–52r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>arranged for days of the week</note>
                  </msItem>
               </msContents>

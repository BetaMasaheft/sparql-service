      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ በሰሌዳ፡ አምላክ፡ ዘተጽሐፈ፨</l>
                  <l n="2">እንበለ፡ ተጠስዮ፡ የሀሉ፡ ዘልፈ፨</l>
                  <l n="3">አርባዕቱ፡ እንስሳ፡ ዘትመልኡ፡ አጽናፈ፨</l>
                  <l n="4">ክፍሉኒ፡ ምቅዋመ፡ ጽድቅ፡ መጠነ፡ አሐቲ፡ ምዕራፈ፨</l>
                  <l n="5">እምዓለመ፡ ወይሌ፡ እምእንበር፡ ዓመታተ፡ እልፈ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለከተማ፡ ርእስክሙ፡ ዘነደ፡ እሳት፡ አርአያሁ፨</l>
                  <l n="2">አዳም፡ ድላሌሁ፨</l>
                  <l n="3">አርባዕቱ፡ እንስሳ፡ ሐውጹኒ፡ ለለ፡ ጽባሑ፨</l>
                  <l n="4">በእሲ፡ ድሩክ፡ ዘይጸንሐኒ፡ ናሁ፨</l>
                  <l n="5">በአብትረ፡ እሳት፡ መፍርህ፡ ቀጥቀጠ፡ ድማሑ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ሰላም፡ ለኵሎን፡ መልክእክሙ፨</l>
                  <l n="2">እምርእስክሙ፡ እስከ፡ አእጋሪክሙ፨</l>
                  <l n="3">አርባዕቱ፡ እንስኣ፡ ሐውጹኒ፡ ለለ፡ ጌሠሙ፨</l>
                  <l n="4">ከመ፡ ይትኀፈሩ፡ እለ፡ ይብሉ፡ ኵሎሙ፨</l>
                  <l n="5">ማዕዜ፡ ይመውት፡ ወይሠዐር፡ ስሙ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ካህናታውያን፡ እንስሳ፡ እለ፡ ትጸውሩ፡ መንበረ፨</l>
                  <l n="2">ወትሴብሕዎ፡ ክሉ፡ አሚረ፨</l>
                  <l n="3">ኪያክሙ፡ ለዘፈጠረ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለክሙ፡ ኪሩባውያን፡ እንስሳ፡ በከመ፡ ነቢያት፡ ነገሩ፨</l>
                  <l n="2">ለእግዚአብሔር፡ ዐቢይ፡ ወግሩም፡ ግብሩ፨</l>
                  <l n="3">ዘትጸውርዎ፡ ለመቃብሩ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለክሙ፡ ኪሩባውያን፡ እንስሳ፡ ወመንፈሳውያን፡ ማኅበር፨</l>
                  <l n="2">እለ፡ ይሴብሑ፡ በሐዋዝ፡ መዝሙር፨</l>
                  <l n="3">ላዕሌክሙ፡ ዘየኀድር፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለክሙ፡ ለክብርክሙ፡ ስቡሕ፡ ሶበ፡ ኣቄርብ፡ ዘምሮ፨</l>
                  <l n="2">ለመላእክተ፡ ውሂብ፡ ወምሕሮ፨</l>
                  <l n="3">በሉኒ፡ ንሣእ፡ ለክብርነ፡ ክብሮ፨</l>
                  <l n="4">ዘኢቦአ፡ ውስቴቱ፡ አእምሮ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
                      <locus target="#58v #84r #114r" facs="061 086 116">58v, 84r, 114r, </locus> (full stops between lines of alternating red and black dots);
                      <locus target="#79v" facs="082">79v, </locus> (line of black dots);
                      <locus target="#84v" facs="087">84v, </locus> (line of red dots);
                      <locus target="#110v" facs="113">110v</locus> (line of alternating red and black dots)
                     </decoNote>

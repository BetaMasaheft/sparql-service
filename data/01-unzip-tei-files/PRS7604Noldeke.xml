         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q63458">
          
                  <t:persName>
                     <t:forename>Theodor</t:forename>
                     <t:surname>Nöldeke</t:surname> 
               </t:persName>
                  
                  <t:occupation type="academic">scholar</t:occupation>
                  <t:nationality type="Germany"/>
                  <t:faith type="notSpecified"/>
                  <t:birth when="1836"/>
               <t:floruit notBefore="1853" notAfter="1930">He was a scholar of Oriental Studies.
                  He studied classical Philology in 
                  <t:placeName ref="https://www.wikidata.org/entity/Q3033">Göttingen</t:placeName> from <t:date>1853-56</t:date>.
                  Between<t:date>1856-1860</t:date>, he studied Oriental manuscripts 
                  in <t:placeName ref="https://www.wikidata.org/entity/Q2079">Leipzig</t:placeName>, <t:placeName ref="https://www.wikidata.org/entity/Q1741">Vienna</t:placeName>, <t:placeName ref="https://www.wikidata.org/entity/Q43631">Leiden</t:placeName>, <t:placeName ref="https://www.wikidata.org/entity/Q6986">Gotha</t:placeName> and 
                  <t:placeName ref="https://www.wikidata.org/entity/Q64">Berlin</t:placeName>. 
                  He had  several publications in the fileds of Ethiopian studies.</t:floruit>
                  <t:death when="1930"/>
               </t:person>
               
         </t:listPerson>
         
         

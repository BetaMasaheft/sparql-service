         <listPerson>
           
               <person sex="2">
                  
                  <persName xml:lang="gez" xml:id="n1" type="birth">መስታወት፡</persName>
                  <persName xml:lang="gez" corresp="#n1" type="normalized">Mastāwat</persName>
                  <persName xml:lang="gez" xml:id="n2" type="alt">መስታየት</persName>
                  <persName xml:lang="gez" corresp="#n2" type="normalized">Mastāyat</persName>
                  <persName>
                  <roleName type="title">Wayzaro</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="Islam"/>
                  <occupation type="political">ruler</occupation>
                  <birth when="1830"/>
                  
                  <floruit notBefore="1857" notAfter="1885">She is represented as the 
                     queen of <placeName ref="https://betamasaheft.eu/LOC6185Wallo">Wallo</placeName> in the <date>1860s</date>, 
                     a status which does not reflect the reality of her power at that time. 
                     Following  the death of her husband
                     <persName ref="https://betamasaheft.eu/PRS6293LibanAm">Liban ʾAmade Liban</persName> in <date>1857</date>, 
                     in the course of revolt against  
                     <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</persName>, 
                     she acted as a regent for her young son <persName ref="https://betamasaheft.eu/PRS1788AmadeLi">ʾAmade Liban</persName>. 
                     She continued to fight 
                     <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</persName> and captured <placeName ref="https://betamasaheft.eu/LOC4547Maqdal">Maqdalā</placeName> 
                     and sided with the <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition against <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</persName>.
                     <persName ref="https://betamasaheft.eu/PRS6864Mastawat">Mastāwat</persName> was described as a fierce warrior and a charismatic leader.
                     <persName ref="https://betamasaheft.eu/PRS6864Mastawat">Mastāwāt</persName> did not convert to  Christianity, 
                     unlike her son <persName ref="https://betamasaheft.eu/PRS1788AmadeLi">ʾAmade Liban</persName> who was obliged to do so at 
                     <placeName ref="https://betamasaheft.eu/LOC1980BoruMe">Boru Medā</placeName>, receiving the name Ḫāyla Māryām. But she remained loyal to 
                     <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk II</persName> even after the death of her son <persName ref="https://betamasaheft.eu/PRS1788AmadeLi">ʾAmade Liban</persName>.</floruit>
                  
                  <death when="1885"/>
               </person>
               
         </listPerson>
         
         

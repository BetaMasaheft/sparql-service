               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="125v">Fols 3r–125v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <textLang mainLang="gez"/>

                     <incipit xml:lang="gez">
                       <pb n="3r"/>
                       <lb n="1"/>
                        <hi rend="rubric">ፍካሬ፡</hi> ዘጻድቃን፡ ወዘኃጥአን፨
                        <lb n="2"/>መዝሙር፡ ዘዳዊት<hi rend="rubric">፨</hi> ሃሊሉያ<hi rend="rubric">፨</hi>
                        <lb n="3"/>ብፁዕ<supplied resp="DR" reason="omitted">፡</supplied> ብእሲ፡ ዘኢሖረ፡ በምክረ፡ ረሲዓን<hi rend="rubric">፨</hi>
                        <lb n="4"/>ወዘኢቆመ፡ ውስተ፡ መፍኖተ ኃጥአን<hi rend="rubric">፨</hi>
                        <lb n="5"/>ወዘኢነበረ፡ ውስተ፡ መስተሣልቃን<hi rend="rubric">፨</hi>
                     </incipit>
                     <explicit xml:lang="gez">
                        <pb n="125v"/>
                      <lb n="1"/>ወአንሰ፡ ነሣእኩ፡ ዘእምላዕለሁ፡ ሰይፈ
                     <lb n="2"/>ወመተርኩ፡ ርእሶ፡ ለጎልያድ።
                     <lb n="3"/>ወአሰሰልኩ፡ ፅዕለተ፡ እምደቂቀ፡ እስራኤል፨
                     </explicit>

                     <colophon xml:id="coloph1">
                     <note xml:lang="en">According to the colophon, the manuscript was written by <persName ref="https://betamasaheft.eu/PRS11944GabraM">Gabra Māryām</persName>
                           of <placeName ref="https://betamasaheft.eu/LOC4431Mahbar">Māḫbara Sǝllāse</placeName> during the tenure of <persName ref="https://betamasaheft.eu/PRS12955Tawfilus">
                           <roleName type="title"><hi rendition="simple:italic">ʾAnbā</hi></roleName> Ṯāʾufīlus</persName>. The date mentioned, the
                           year 44 according to the Era of Mercy,
                        probably means 1944 <hi rendition="simple:smallcaps">EC</hi> (= 1951/1952 <hi rendition="simple:smallcaps">CE</hi>).
                      In the text, there is a number of mistakes, many word dividers are omitted; the character ስ cannot
                      be well distinguished from ሰ (see below).</note>
                   <foreign xml:lang="gez">  <pb n="125v"/>
                        ዝመጽሐፍ፡ ዘ<persName ref="https://betamasaheft.eu/PRS11944GabraM"><roleName type="title">አባ</roleName>
                        <supplied reason="omitted" resp="DN">፡</supplied>
                           ገብረ፡ <hi rend="rubric">ማርያም</hi><supplied reason="omitted" resp="DN">፡</supplied>
                        </persName> <placeName ref="https://betamasaheft.eu/LOC4431Mahbar">ማኅበረ፡ ሥላሴ<supplied reason="omitted" resp="DN">፡</supplied>
                      </placeName> ጎጃም፡
                          <sic resp="DR">ዘጽሐፎ</sic><supplied reason="omitted" resp="DN">፡</supplied>
                        ለ<placeName ref="https://betamasaheft.eu/INS0478DS">ገዳም፡ ሶርያን፡</placeName> ይጽሐ<supplied reason="omitted" resp="DR">ፍ</supplied>፡
                        ሰሞ፡ <hi rend="rubric">እግዚአብሔር፡</hi> ውሰተ፡ <sic resp="DR">መጽሐፍ፡</sic> ሕይወት፡ <sic resp="DN">በረተ፡</sic>
                        ዳ<cb n="b"/><add place="above"><hi rend="rubric">ዊ</hi></add>ት፡ ይድር፡ 
                      በላዕሌሁ<supplied reason="omitted" resp="DN">፡</supplied> <sic resp="DN">ምሰለአሁ፡</sic> <add place="above">
                           <hi rend="rubric">እንዘ፡</hi>
                        </add> ጳጳሰ<hi rend="rubric">ነ</hi><supplied reason="omitted" resp="DN">፡</supplied>
                      አባ፡ ቴ<add place="above"><hi rend="rubric">ዎ</hi></add>ፍሎስ፡ ዘመንበረ፡ አባ፡ ዮሐንስ፡ ካማ፡
                        ወምስለ፡ ደቂቁ፡ ኵሎሙ፡ ማኅበረ፡ <placeName ref="https://betamasaheft.eu/INS0478DS">
                           <add place="above"><hi rend="rubric">ገዳም፡</hi> </add> ሶርያን፡</placeName> ለዓመ፡ ዓም፡ አሜን። ።
                      <date calendar="ethiopian" when-custom="44" notBefore="1951" notAfter="1952" evidence="internal">፵፬ዓም፡</date> <placeName ref="https://betamasaheft.eu/LOC6126WadinN">Wādī an-Naṭrūn<sic resp="DN">አቄጥሰ</sic></placeName></foreign>
                     </colophon>
                  </msItem>


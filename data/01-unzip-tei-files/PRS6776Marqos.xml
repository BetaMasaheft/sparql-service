      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ማርቆስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Mārqos [III]</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
               <t:occupation type="ecclesiastic">metropolitan</t:occupation>
               <t:nationality type="Egypt"/>
               <t:faith type="Coptic"/>
             
               
               <t:floruit when="1636">He was a metropolitan of the Ethiopian Orthodox Church who succeeded  ʾabuna
                  <t:persName ref="https://betamasaheft.eu/PRS8740Semon">Sǝmʿon</t:persName> in <t:date>1636</t:date> during the reign of  
                  King <t:persName ref="https://betamasaheft.eu/PRS4015Fasilada">Fāsiladas</t:persName>. 
                  He was consecrated in Cairo  in <t:date>1634</t:date> 
                  by the Coptic Patriarch <t:persName ref="https://betamasaheft.eu/PRS6905Matthew">Matthew (Mātewos) III</t:persName> and travelled to Ethiopia accompanied 
                  by <t:persName ref="https://betamasaheft.eu/PRS5324Heyling">Heyling</t:persName>.
                  
               </t:floruit>
               <t:death>He died in <t:date>1647/48</t:date> 
               </t:death>
            </t:person>
            
         </t:listPerson>
         

                    <t:placeName corresp="#n1" xml:lang="gez" type="normalized">Dabra Ḥayq
                        ʾƎsṭifānos</t:placeName>

                    <t:placeName xml:id="n2" xml:lang="gez" type="alt">ደብረ፡ ሐይቅ፡</t:placeName>
                    <t:placeName corresp="#n2" xml:lang="gez" type="normalized">Dabra Ḥayq</t:placeName>

                    <t:placeName xml:id="n3" xml:lang="gez" type="alt">ደብረ፡ እግዚአብኄር፡ አብ፡</t:placeName> 
               

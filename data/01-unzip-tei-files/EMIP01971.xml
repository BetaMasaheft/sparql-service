                  <summary>Psalter, ዳዊት፡</summary>
                    <msItem xml:id="ms_i1">
                     <locus from="1r" to="164r" facs="004">Fols 1r–164r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                    </msItem>
                    <msItem xml:id="ms_i2">
                     <locus from="164r" to="165r" facs="167">Fols 164r–165r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    </msItem>
                    <msItem xml:id="ms_i3">
                     <locus from="165r" to="167v" facs="168">Fols 165r–167v</locus>
                    <title>A very elaborate Concluding Prayer for Praises of Mary, Gate of Light and Angels Praise Her</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <note>with an extensive list of relatives, living and dead, for whom intercessions are made</note>
                    </msItem>
                    <msItem xml:id="ms_i4">
                     <locus from="166r" to="166r" facs="169">Fols 166r–166r</locus>
                    <title>Concluding Table Prayer which is part of the daily prayer</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <incipit xml:lang="gez">ስብሐት፡ ለአብ፡ ስብሐት፡ ለወልድ፡ ስብሐት፡ ለመንፈስ፡ ቅዱስ፡ ይደልዎሙ፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</incipit>
                  </msItem>

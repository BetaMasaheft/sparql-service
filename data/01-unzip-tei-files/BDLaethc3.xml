               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="95r">Fols 4r–95r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1507GadlaT">Gadla Takla Hāymānot (Dabra Libānos recension, general  record)</title>
                        <textLang mainLang="gez"/>
                     <note>
                        <locus target="#4r">Fol. 4r</locus> contains the introduction and chapter 1.</note>
                     <note>Chapter 8 (unnumbered) begins on <locus target="#8r">fol. 8r</locus>.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="95r" to="104v">Fols 95r–104v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1929Mashaf">Maṣḥafa fǝlsatu la-Takla Hāymānot (general  record)</title>
                     <textLang mainLang="gez"/>
                     <note>The introductory note on <locus target="#95v">fol. 95v</locus> is lengthier than in
                        <bibl corresp="http://zotero.org/groups/358366/items/8SCM474J"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1906Taklahaymanot"/><title level="m">The Life of Takla Hâymânôt, in the version of Dabra Lîbanôs, and The miracles of Takla Hâymânôt in the version of Dabra Lîbanôs</title><author><forename>E. A. Wallis</forename><surname>Budge</surname></author><pubPlace>London</pubPlace><publisher>Privately printed for Lady Meux</publisher><date>1906</date><note type="tags"><note type="tag">bm:Budge1906Taklahaymanot</note></note><note type="tag">bm:Budge1906Taklahaymanot</note></bibl>.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="105r" to="122v">Fols 105r–122v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3971Taamme">Taʾammǝra Takla Hāymānot</title>
                     <textLang mainLang="gez"/>
                     <note>18 miracles, which are not identical with those of
                        <bibl corresp="http://zotero.org/groups/358366/items/8SCM474J"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Budge1906Taklahaymanot"/><title level="m">The Life of Takla Hâymânôt, in the version of Dabra Lîbanôs, and The miracles of Takla Hâymânôt in the version of Dabra Lîbanôs</title><author><forename>E. A. Wallis</forename><surname>Budge</surname></author><pubPlace>London</pubPlace><publisher>Privately printed for Lady Meux</publisher><date>1906</date><note type="tags"><note type="tag">bm:Budge1906Taklahaymanot</note></note><note type="tag">bm:Budge1906Taklahaymanot</note></bibl>,
                        but - with the exception of the 18th - largely the same as those in 
                        <ref type="mss" corresp="https://betamasaheft.eu/BNFet343">Paris, Bibliothèque nationale de France, BnF Éth. 343</ref>.</note>
                  </msItem>
                  </msContents>
                     

               <msContents>
                  <summary>Asmat prayer of Peter and of the Disciples and others, arranged for the days of the week</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="38v" facs="004">Fols 1r–38v</locus>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT4668Prayer">Protective prayers
                                                  for the seven weekdays</title>


                  <msItem xml:id="ms_i1.1"><locus from="1r" to="1v" facs="004">Fols 1r–1v</locus><title>Introduction</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>incomplete at the beginning</note>
                  </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="1v" to="5v" facs="005">Fols 1v–5v</locus><title> Monday, Asmat prayer of Peter</title><incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted"/>  ጸሎቱ፡ ለጴጥሮስ፡ ዝውእቱ፡ ዘየዓቢ፡ እምሐዋርያቲሁ፡ ዘኃረዮ፡ ክርስቶስ፡ እምቅድመ፡ ኵሎሙ፡ ሐዋርያቲሁ፡ ለኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው። ወጸውዖሙ፡ ለኵሎሙ፡ ሐዋርያቲሁ፡ ወነበረ፡ ምስሌሆሙ፡<gap reason="omitted"/> </incipit>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="5v" to="10v" facs="009">Fols 5v–10v</locus><title> Tuesday, Asmat prayer of Melkezedeq</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="10v" to="13v" facs="014">Fols 10v–13v</locus><title> Wednesday, Asmat prayer of Thomas</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="14r" to="20v" facs="017">Fols 14r–20v</locus><title> Thursday, Asmat prayer given from the angels to the Disciples</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.6"><locus from="20v" to="25r" facs="024">Fols 20v–25r</locus><title> Friday, Asmat prayer of the Disciples</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.7"><locus from="25r" to="29v" facs="028">Fols 25r–29v</locus><title> Saturday, Prayer of the Disciples for forgiveness of sin, <foreign xml:lang="gez">ጸሎተ፡ ስርየተ፡ ኃጢአት፡</foreign></title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.8"><locus from="30r" to="35r" facs="033">Fols 30r–35r</locus><title> Asmat prayer of the three Israelite Children</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.9"><locus from="35v" to="38v" facs="039">Fols 35v–38v</locus><title> Daily asmat prayer, “I beseech You lest I die early,” <foreign xml:lang="gez">ተማኅጸንኩ፡ ከመ፡ ኢይሙት፡ ዘእንበለ፡ ጊዜየ፡</foreign></title><incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/> ተማኅፀንኩ፡ ከመ፡ ኢይሙት፡ ዘእንበለ፡ ጊዜየ፡ ከመ፡ ሠራቂ፡ ሌሊት፡ ወከመ፡ ቀታሊ፡ መዓልት፡ በመንግሥተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡<gap reason="omitted"/> </incipit>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                </msItem>
               </msContents>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="9v">1v-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1078IHA">نظم طلعت انوار من نواحى الغيب والفجر</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>صل وسلم على خير الورى والال والصحب سادات الكبرى امام الحرام شفيع \ طلعت انوار من نواحى الغيب انوار من نواحى الغيب , والفجر الصادق المزيل للدنيا<note>The last word "lil-dunyā" is uncertain, because only part of the word is visible in the picture. The rhyme in the beginning of the poem is ā.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>ما لعب العشق باهل الوداد , ما حن المريد الى ذلك الوا؟ <note>The last word of the verse remains unclear as it is only partly visible in the picture.</note>
                     </explicit>
                     <note>Partially vocalized: the vowel marks are added with a ball-point pen.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="9v" to="29r">9v-29r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1079IHA">نظم حمد لمن جاد بالقيض والمدد</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>اللهم صل على محمد اللهم صل على محمد \ حمد لمن جاد بالقيض والمدد , لارباب الود ولاوجد والرشد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29r">-29r</locus>قلبى من خلفها ومن امامها ساريها حود الحجاب المؤيد</explicit>
                     <note>Partially vocalized: the vowel marks are added with a ball-point pen. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="95v" to="99r">95v-99r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1089IHA">نظم طلعت انوار من نواحى الغيب فاشرقت</title>
                     <incipit xml:lang="ar">
                        <locus target="#95v">-95v</locus>اللهم صلى على محمد امام الحرم شفيع الورى \ طلعت انوار من نواحى الغيب فاشرقت بها سموات القلب \ طاف طيف الحب حول خيم الصب فابدى فى القلب دفائن الغيب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#99r">-99r</locus>ما طالع السالك نوار اللطائف ورضع العارف ألبان المعارف \ وعلى الاوليا بدرور الامحاد ما حن المريد الى ذاك الوادى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="29v" to="34r">29v-34r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1080IHA">نظم حمدا لذى المنة</title>
                     <incipit xml:lang="ar">
                        <locus target="#29v">-29v</locus>يا رب صل على افضل البرية كللمحة الف الف مرة \ حمدا لذى المنة , وناشر النعمة , وباسط الرحمة \ لكل المملكة هادى الامة له بالمعرفة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34r">-34r</locus>حول نهر المدد , لكل عبد جر بالتحية</explicit>
                     <note>Partially vocalized: the vowel marks are added with a ball-point pen. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="34v" to="61r">34v-61r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1081IHA">نظم الحمد لله الفتاح ذى الكرم</title>
                     <incipit xml:lang="ar">
                        <locus target="#34v">-34v</locus>صلى الله وسلم على النور الاعظم واله وصحبه الاكرم \ الحمد لله الفتاح ذى الكرم \ بديع الحبيب المصطفى المعظم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#61r">-61r</locus>فى مدح عروس تقرب العين \ يسى جماله عقول المصطفين \ ؟ تاريخ جل غبش تم النظم ابياتها قعيد<note>The first word of the last line is uncertain, as it is only partly visible in the picture.</note>
                     </explicit>
                     <note>The poem is written as a taḫmīs. Not vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="61v" to="68r">61v-68r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1082IHA">نظم قفالى بسفح من رامة الكبرى</title>
                     <incipit xml:lang="ar">
                        <locus target="#61v">-61v</locus>اللهم صل على محمد درتك البيضاء اياتك الكبرى شرف الدنيا والاخرة \ فقالى بسفح من رامة الكبرى \ وانظما من لفظ دررا لا تبرى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68r">-68r</locus>وشرح له باليقين صدرا \ ابدع فرد بربه ادرى من النبيين والاملاك طرا \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="68r" to="76r">68r-76r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1084IHA">نظم لما نسائم المحبة هبا</title>
                     <incipit xml:lang="ar">
                        <locus target="#68r">-68r</locus>اللهم صلى على محمد شمس دار طيبا شراب الاحبا \ لما نسائم المحبة هبا \ جندت جيوش الغزو الاحيا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#76r">-76r</locus>وطار اهل الله بجناح الشوق فى وادى المعرفة ووادى المحبة \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="76r" to="82v">76r-82v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1085IHA">نظم لما نهبتنى جنود الاوزار</title>
                     <incipit xml:lang="ar">
                        <locus target="#76r">-76r</locus>اللهم صل على محمد احمد خير الورى عروس الكمال \ لما نهبتنى جنود الاوزار \ صحت مستغيثا بالنبى المختار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#82v">-82v</locus>ما سار ارباب برزخ الفناء الى وادى البقا مقام الكمال \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="83r" to="86v">83r-86v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0618IHA">نظم قد لاح صباح الفتح</title>
                     <incipit xml:lang="ar">
                        <locus target="#83r">-83r</locus>صلى الله على محمد تاج المرسلا صلى الله على محمد قبة الولا \ قد لاح صباح الفتح , افاق قلوب الرجلا \ فحنوا حنين الثكلا , الى المحبوب الاولا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#86v">-86v</locus>ما دامت تخظف العقول , برقات ذلك الجمالا \ ما سبى الباب الاحباب , رونق ذاك الجمالا \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="86v" to="89r">86v-89r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0892IHA">نظم بدر الكمال قد ظهر</title>
                     <incipit xml:lang="ar">
                        <locus target="#86v">-86v</locus>صلى الله على محمد شفيع الورى صلى الله على محمد جمال الحضرى \ بدر الكمال قد ظهر الكون به تنور \ مسك النبوة انتشر الكون به تعطر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#89r">-89r</locus>ما طار السالك شوقا بوادى القرب واللقا \ ما طاف اهل الوصال حول كعبة الكمال \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="89r" to="95r">89r-95r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1088IHA">نظم تبدت شموس القرب افاق سماء القلب</title>
                     <incipit xml:lang="ar">
                        <locus target="#89r">-89r</locus>صلى الله على محمد محبوب الاول صلى اله على محمد النور الاول \ تبدت شموس القرب افاق سماء القلب \ فحن المحب شوقا بوادى القرب واللقا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#95r">-95r</locus>خيل شوقكم ركبنا فى وادى الغيب سافرنا \ سرنا فى ميدان الصفا طالبا جيش المعرفا</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

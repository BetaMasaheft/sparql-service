               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1124Apocal">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ክርስቶስ፡ አምላኪየ፡ ወእግዝእትነ፡ ማርያም፡
                  ትስእል፡ ሊተ። ድርሳን፡ ዘቅዱስ፡ ወብፁዕ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ በእንተ፡ ዕበየ፡ ክብራ፡ ለማርያም፡ ቅድስት፡ ድንግል፡
                  ጸሎታ፡ ወበረከታ፡ የሀሉ፡ ምስሌነ፡ አሜን።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ይቤ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ዘያፈቅሮ፡ እግዚእነ፡ ፈድፋደ፡ በእንተ፡ ንጽሕናሁ፡ ወእግዝእትነ፡
                  ማርያም፡
                  ታፈቅሮ፡ እስመ፡ አፍቀሮ፡ ወልዳ፡ ወአውሥአቶ፡ ወትቤሎ፡ ስማዕ፡ ኦዮሐንስ። አነ፡ እነግረከ፡ ኅቡአ፡
                  <choice>
                           <sic resp="PRS10747Zotenbe">ምሥዉረ፡</sic>
                           <corr resp="PRS10747Zotenbe">ምሥጢረ፡</corr>
                        </choice>
                በልበ፡ ዘኢይታወቅ፡ በሕሊና፡ ዘኢጠነቀቅ፡ ዘከሠተ፡ ሊተ፡ እግዚእየ፡ ወልድየ፡</incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="26v">Fols 26v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279">Hymn to John the
                                                  Baptist</title>
                     <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ እሳት፡ በሐቅለ፡ ሕሊና፡ ነዳዲ። ወበስመ፡ ማርያም፡ ድንግል፡ ወጥበቢተ፡
                ዓለም፡ ዓባዲ።
              ማኅቶተ፡ ፀዳል፡ ዮሐንስ፡ ጽልመተ፡ አበሳ፡ ሳዳዲ።</incipit>
                     <textLang mainLang="gez"/>
                  </msItem>


                  <msItem xml:id="ms_i3">
                     <locus from="32r">Fols 32r and following</locus>
                     <title type="incomplete">Fragment of a Prayer to <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName>
                     </title>
                     <textLang mainLang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="41r">Fols 41r and following</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2075Number">Book of
                                                  Numbers</title>
                     <note>This fragment contains the beginning of Numbers 13.</note>
                     <textLang mainLang="am"/>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus target="#43">Fol. 43</locus>
                     <title type="incomplete" xml:lang="am" ref="https://betamasaheft.eu/LIT3556Fables">የጠቢቡ፡ የለቅማን፡ የአንዓም፡ አባት፡
                የምሳሌው፡ መጻፍ፡ ይህ፡ ነው።</title>
                     <textLang mainLang="am"/>
                     <incipit xml:lang="am">(የጠቢቡ፡ የለቅማን፡ ምሳሌ።) መጀመርያው፡ ምሳሌ። አንበስና፡ ሁለት፡ በሮች።
              አንበሳ፡ አንደግዜ፡ ወጣ፡ በሆለት፡ በሮች፡ ላይ፡ ሁለቱም፡ ባንድ፡ ሆኑ፡ በቀንዳቸውም፡ ይወጉ፡ ጀመሩ፡ በመኻከላቸውም፡</incipit>
                  </msItem>
               </msContents>


                           <bibl corresp="http://zotero.org/groups/358366/items/CJRDF5NJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Platt1830novum"/><title level="m">Novum testamentum domini nostri et servatoris Jesu Christi aethiopice</title><editor><forename>Thomas Pell</forename><surname>Platt</surname></editor><pubPlace>Londini</pubPlace><publisher>Impressit Ricardus Watts</publisher><date>1830</date><note type="url">https://archive.org/details/novumtestamentu00platgoog</note><note type="tags"><note type="tag">Manuscripts</note><note type="tag">New Testament</note><note type="tag">bm:Platt1830novum</note></note><note type="tag">Manuscripts</note><note type="tag">New Testament</note><note type="tag">bm:Platt1830novum</note></bibl>, see <ref target="#LukePrologue"/>.</note>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ለሃይማኖት፡ ርእሳ፨</l>
                  <l n="2">ወለገጽነ፡ ሞገሳ፨</l>
                  <l n="3">ዲዮስቆሮስ፡ መምህር፡ ወነቢየ፡ ልዑል፡ ዘምድረ፡ ሱሳ፨</l>
                  <l n="4">በገድሉ፡ ወጻማሁ፡ እንተ፡ አግነየ፡ አንበሳ፨</l>
                  <l n="5">ወበፍትሐ፡ ጽድቅ፡ ዘቀነየ፡ ነገሥታት፡ ስሳ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ቆብዐ፡ ድንጋሌ፡ ዘተገልበበ፨</l>
                  <l n="2">ወለገጽከ፡ ስቡሕ፡ ዘበደመ፡ ሥቃይ፡ ተሐጽበ፨</l>
                  <l n="3">ዲዮስቆሮስ፡ ዝክርከ፡ ዘያስተፌሥሕ፡ አልባበ፨</l>
                  <l n="4">ቅድመ፡ ገጸ፡ አምላክ፡ ሚመጠነ፡ ረከበ፨</l>
                  <l n="5">ጸጋ፡ ብዙኀ፡ ወሠናየ፡ ዐሥበ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ተዘኪረከ፡ ክርስቶስ፡ ከመ፡ አፈቅሮሙ፡ ጥቀ፨</l>
                  <l n="2">በእንቲአከ፡ ጻድቃን፡ እስመ፡ ተገበሩ፡ ጽድቀ፨</l>
                  <l n="3">ድኩም፡ ሥጋየ፡ ሶበ፡ ተንተነ፡ ወወድቀ፨</l>
                  <l n="4">እስመ፡ በጽሐ፡ ጊዜ፡ ሠዊቅ፡ ወጊዜ፡ አንሥአ፡ አልጸቀ፨</l>
                  <l n="5">እስመ፡ ከመ፡ ከማከ፡ አብ፡ ያነሥእ፡ ጥዩቀ፨</l>
                  <l n="6">ታፈቅር፡ ጽድቀ፡ ለለ፡ ጊዜ፡ ኩነኒ፡ ሠዋቀ፨</l>
               </lg>
            </div>
         </div>

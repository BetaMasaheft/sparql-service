         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ዮሐንስ፡ መደበር፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Yoḥannǝs Madabbar</persName>
               <persName xml:lang="en" xml:id="n2" type="birth">John of Nikiu</persName>
               <occupation type="ecclesiastic">bishop</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>

               <floruit> He was a 7th century bishop of Nikiu in south west-Nile Delta.  He was the author of a universal
                  <ref type="work" corresp="https://betamasaheft.eu/LIT1239Chroni">Chronicle</ref> extending
            from Adām to the end of the Muslim conquest of Egypt. This Chronicle contains important historical details particularly on the final decades
                  of the Byzantine rule over Egypt and the Arabs conquest of Egypt.
               </floruit>
               <death> He died shortly after <date>700</date>
               </death>
            </person>
            
         </listPerson>

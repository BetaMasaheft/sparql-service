                    <msContents>

                      <msItem xml:id="ms_i1">
                        <locus from="2r" to="7v"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ወሰላም፡ ለመቃብሩ፨ ገብረ፡ መንፈስ፡ ቅዱስ፡ አቡየ፡ ለእግዚአብሔር፡ ፍቁሩ፨ ደመናት፡ አንኰርኰሩ፨ አዕዋፈ፡ ሰማይ፡ ዘመሩ፨ በጊዜ፡ ሞትከ፡ መላእክት፡ አንከሩ፨ ኦአምላከ፡ ገብረ፡ መንፈስ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/></explicit>
                        <note>Incomplete at the end.</note>
                      </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="8r" to="17r"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2741RepCh25">Malkǝʾa ḥǝmāmāta masqal</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለአዕዛኒከ፡ ጽርፈተ፡ አይሁድ፡ ዘሰምዓ፨ ወኢተቈጥዓ፨ አርመማ፡ ይፈጽማ፡ ዘነቢያት፡ ስምዓ፨ ተማኅፀን<add place="above">ኩ፡</add> በመስቀልከ፡ መድኃኔ፡ ዓለም፡ ነዓ፨ እምኃይለ፡ ብድብድ፡ ሀበኒ፡ መዊዓ፨</incipit>
                        <explicit xml:lang="gez">ስብሐ<supplied reason="omitted">ት፡</supplied> ለከ፡ አምላኪየ፡ በኈልቈ፡ ጽዱላን፡ ከዋክብት፤ ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ዕለታት፡ ወአዝማናት፤ ስብ<supplied reason="omitted">ሐት፡</supplied> ለከ፡ አምላኪየ፡ ይደሉ፡ ለመስቀልከ፡ ሕይወት፤ እስመ፡ በመስቀልከ፡ ድኅነ፡ ኵሉ፡ ፍጥረት፨</explicit>
                        <note>Incomplete at the beginning.</note>
                      </msItem>

                    </msContents>


         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ሕያው፡ ወማሕየዊ፡ ዘዋሕድ፡ ባሕርይሁ፨</l>
                  <l n="2">ወሥሉስ፡ አካላቲሁ፨</l>
                  <l n="3">አፍቀረነ፡ እግዚእ፡ እንግር፡ ውዳሴ፡ መልክእከ፡ በበ፡ ጾታሁ፨</l>
                  <l n="4">ፈኑ፡ ሊተ፡ ይእዜ፡ አንቀጸ፡ ለብየ፡ ያርኁ፨</l>
                  <l n="5">ጰራቅሊጦስሃ፡ መንፈሰ፡ ጸጋ፡ ዘፍጹም፡ ጸጋሁ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ በስመ፡ እግዚአብሔር፡ ዘተጸውዐ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ጽሑድ፡ ዘተከለለ፡ ቆብዐ፨</l>
                  <l n="3">አፍቀረነ፡ እግዚእ፡ ጳጳስ፡ ዘይንዕዳ፡ በአፍአ፨</l>
                  <l n="4">ከመ፡ እክሥት፡ እምተሠውሮ፡ መድፍነ፡ ውዳሴ፡ ኅቡአ፨</l>
                  <l n="5">በውስተ፡ ከርሥየ፡ ሐድስ፡ መንፈሰ፡ ርቱዐ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ ለመልክእከ፡ እስመ፡ ይደሉ፡ ንስቲተ፨</l>
                  <l n="2">ነዳየ፡ አእምሮ፡ ወልድከ፡ መጠነ፡ ተክህለኒ፡ ሊተ፨</l>
                  <l n="3">አፍቀረነ፡ እግዚእ፡ ክፍልየ፡ ዘረሰይኩከ፡ መክፈልተ፨</l>
                  <l n="4">ውኩፈ፡ ይኩን፡ በቃልከ፡ ወኢይትኀደግ፡ እቱተ፨</l>
                  <l n="5">እስመ፡ ወልድከ፡ አነ፡ ዘበጽድቅ፡ ወአቡየ፡ አንተ፨</l>
               </lg>
            </div>
         </div>

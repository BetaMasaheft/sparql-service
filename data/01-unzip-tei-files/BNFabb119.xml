                   <item xml:id="a1">
                     <locus target="#3r"/>
                      <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title></desc>
                      <q xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ። ወልደ፡ <sic resp="DN">ያራድ፡</sic> ሔኖክ፡ በከመ፡ ጸሐፈ፡ </q>
                  </item>
                       
                  <item xml:id="a2">
                    <locus target="#3v"/>

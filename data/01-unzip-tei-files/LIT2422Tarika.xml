      <body>
         
         
         
         
         <div type="edition">
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="Gen" corresp="https://betamasaheft.eu/LIT3854KingList">
               <label>Genealogy and History of the kings of Ethiopia from <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> to 
                  <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis I</persName>/ʾAdbǝʾal, successor of Fǝre Śannāy</label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="Yared">
               <label>Vita of <persName ref="https://betamasaheft.eu/PRS10245Yared">Yāred</persName>
               </label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="Christianization">
               <label>On the Christianization in Ethiopia</label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="ExtractYamaranWag">
               <label>Extract of <ref type="work" corresp="https://betamasaheft.eu/LIT2341serata">Śǝrʿāta mangǝśt (general record)</ref>
               </label>
               
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="Chronicle">
               <label>Chronicle of the kings from <persName ref="https://betamasaheft.eu/PRS10303Yekunno">Yǝkunno ʾAmlāk</persName> to <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas</persName>
               </label>
               
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="GenealogyMonks">
               <label>Genealogical list of the main Ethiopian monks starting with <persName ref="https://betamasaheft.eu/PRS1962Anthony">Antony</persName>
               </label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="GenealogyApostels" corresp="https://betamasaheft.eu/LIT5849GenealogyApostles">
               <label>Genealogy of the twelve apostles</label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="HistoryGran">
               <label>History of  <persName ref="https://betamasaheft.eu/PRS1522Ahmadb">ʾAḥmad</persName>
               </label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="Oromo">
               <label>Extract of <ref type="work" corresp="https://betamasaheft.eu/LIT2341serata">Śǝrʿāta mangǝśt (general record)</ref> concerning the <persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</persName>
               </label>
            </div>
            
            <div type="textpart" subtype="chapter" xml:lang="am" xml:id="HistoryDavid">
               <label>History of <persName ref="https://betamasaheft.eu/PRS3417David">David</persName>, king of Ethiopia</label>
            </div>
         </div>
      </body>
   </text></TEI>
                  <summary/>

                    <msItem xml:id="ms_i1">
                       <locus from="4ra" to="78ra"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1799Lifeof">Life and martyrdom of John the Baptist</title>
                       <incipit xml:lang="gez">
                       <locus target="#4ra"/>
                       <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቀዱስ፡ ፩አምላ</hi>ክ፡ ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡
                       ጸሒፈ፡ ዜናሁ፡ ወመንክራቲሁ፡ <hi rend="rubric">ለቅዱስ፡ ዮሐንስ፡ መጥምቅ፡ ዘከመ፡ እፎ፡ ኮነ፡ ሕ</hi>ይወቱ፨
                       ወከመ፡ ኮነ፡ ምትረተ፡ ርእሱ፡ በመዋዕለ፡ ሄሮድስ፡ ርጉም፡ ወዓማፂ፨ ወናሁ፡ ይቤ፡ ከመዝ፡ ዮሐንስ፡ አፈ፡
                       በትረ፡ ያርክ፡ ሊቀ፡ ጳጳሳት፡ ዘሃገረ፡ ቅስጥንጥያ፨ ወሶበ፡ ኮነ፡ ስደቱ፡ ውስተ፡ አብራክይስ፡ አ<hi rend="rubric">መ፡ ተስእሎ፡
                       ፩አይሁዳዊ፡ ኬልቀደናዊ፡ ወ</hi>ውእቱ፡ ዘኮነ፡ ምእመነ፡ በእግዚእነ፡
                     </incipit>
                       </msItem>

                       <msItem xml:id="ms_i2">
                          <locus from="78ra" to="88vb"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist">Miracles of John the Baptist</title>
                        


                          <msItem xml:id="ms_i2.1">
                             <locus from="78ra" to="78rb"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Introduction">Taʾammǝratihu la-Yoḥannǝs Maṭmǝq, Introduction</title>
                             <incipit xml:lang="gez">
                             <locus target="#78ra"/>
                             <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡
                             ንዌጥን፡</hi> በረድኤት፡ እግዚአብHኤር፡ ጽሒፈ፡ ተአምራቲሁ፡ ወመንክራቲሁ፡ ለኮከበ፡ ገዳመ፡
                             ዮርዳኖስ፨ ወማኅቶተ፡ ሄኖን፡ ቅሩበ፡ ሳሌም፨
                             </incipit>
                             </msItem>

                             <msItem xml:id="ms_i2.2">
                                <locus from="78rb" to="79rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle1">How the ruler Yǝkunno ʾƎgziʾ
                                  “Qundur” protected his brother in Sahart</title>
                                <incipit xml:lang="gez">
                                <locus from="78rb" to="78va"/>
                                <hi rend="rubric">በ፩ተአምሪሁ፡ ለብፁዕ፡ ነቢይ፡
                                ወሰማዕት፡ ቅዱስ፡ ዮሐንስ፡ </hi>መጥምቅ፡ ዘተኃርየ፡ እምከርሠ፡
                                 እሙ፡ ከመ፡ ኤርምያስ፡ ነቢዩ፨ ስምዑ፡ ንነግረክሙ፡ አኃዊነ፡ አድ፡ ወአንስት፡ <gap reason="ellipsis" resp="DN"/>
                                 ወ<pb n="78va"/>ነበረ፡ ፩ብእሲ፡ ዘረሰየ፡ ብሔሮ፡ መልዕልተ፡ አሐቲ፡ ደብር፡ ዘምድረ፡ ኅርጉድ፡ እንተ፡ ሃገረ፡ ጽልማ፡
                                ዘስሙ፡ ይኩኖ፡ እግዚእ፡ ወውሣጤ፡ ስሙ፡ ቁንዱር፡</incipit>
                                <note>In other witnesses the name of the land is Ḫǝrguṣ</note>
                                </msItem>

                                <msItem xml:id="ms_i2.3">
                                   <locus from="79rb" to="79vb"/>
                                   <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle2">How the man “whose name was mentioned above”
                                    defeated his enemies</title>
                                   <incipit xml:lang="gez">
                                   <locus from="79rb"/>
                                   <hi rend="rubric">፪ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡ መጥምቅ፡ ጸሎቱ፡</hi> የሃሉ፡ ምስለ፡ አግብርቲሁ፡
                                   <gap reason="ellipsis" resp="DN"/>
                                   ወካዕበ፡ ስምዑ፡ ንንግርክሙ፡ ዘገብረ፡ ሎቱ፡ ተአምረ፡ ለውእቱ፡ ብእሲ፡ ዘአቅደምነ፡ ነጊረ፡
                                   በእንቲአሁ። <gap reason="ellipsis" resp="DN"/>ወሀለውዎ፡ ሰብአ፡ ደም፡
                                   ፅኑዓነ፡ ኃይል፡ እለ፡ ርኁቅ፡ ብሔሮሙ፡
                                   </incipit>
                                   </msItem>

                                   <msItem xml:id="ms_i2.4">
                                      <locus from="79vb" to="80vb"/>
                                      <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle3">How Yǝkunno ʾƎgziʾ
                                        defeated those people who hated him</title>
                                      <incipit xml:lang="gez">
                                      <locus from="79vb" to="80ra"/>
                                      <hi rend="rubric">፫ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡ መጥምቅ፡</hi><gap reason="ellipsis" resp="DN"/>
                                      ስምዑ፡ ካዕበ፡ ዘገብረ፡ ተአምረ፡ ወመንክረ፡ ቅዱስ፡ <hi rend="rubric">ዮሐንስ፡</hi> መጥምቅ፡ ዘበእዴሁ፡ ገሠሠ፡
                                      ርእሶ፡ ለመለኮት፡ በውስተ፡ ዮርዳኖስ፡ <gap reason="ellipsis" resp="DN"/><pb n="80ra"/>
                                      ወሀለዉ፡ ሰብእ፡ ቅሩባን፡ እለ፡ ይነብሩ፡ ደወለ፡ ሀገሩ፡ ለይኩኖ፡ እግዚእ፡ እለ፡ ይጸልዕዎ፡ በአልባሲሆሙ፡ ወይትመነዩ፡ ሙስና፡ ዚአሁ፨
                                      </incipit>
                                      </msItem>

                                      <msItem xml:id="ms_i2.5">
                                         <locus from="80vb" to="81rb"/>
                                         <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle4">How Yǝkunno ʾƎgziʾ punished those who killed his shepherds</title>
                                         <incipit xml:lang="gez">
                                         <locus from="80vb"/>
                                         <hi rend="rubric">፬ተአምሪሁ፡ ለቅዱስ፡ ዮሐንስ፡</hi><gap reason="ellipsis" resp="DN"/>
                                         ወካዕበ፡ ንነግርክሙ፡ ተአምረሁ፡ ለቅዱስ፡ ነቢይ፡ ዘገብረ፡ በይእቲ፡
                                         ሀገር፨ ወሀለዉ፡ ሰብእ፡ ዘይቀንዮሙ፡ ይኩኖ፡ እግዚእ፡ ወረሰዮሙ፡ ከመ፡ አግብርቲሁ፨ ወእንዘ፡ ይወፍሩ፡ ወየአትዉ፡ ይሬእይዎሙ፡ ከመ፡ አግብርቲሁ፨
                                         </incipit>
                                         </msItem>

                                         <msItem xml:id="ms_i2.6">
                                            <locus from="81rb" to="82va"/>
                                            <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle5">About arrogance of
                                              the wife of Yǝkunno ʾƎgziʾ, his death and
                                            perdition of his country</title>
                                            <incipit xml:lang="gez">
                                            <locus from="81rb"/>

                                            <hi rend="rubric">፭ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡ መጥምቅ፡</hi><gap reason="ellipsis" resp="DN"/>
                                            ተብህለ፡ ዘከመ፡ ኮነት፡ ብእሲቱ፡ ወለተ፡ መኰንን፨ ወአውሰበ፡ ኪያሃ፡ እንዘ፡ ይሁብ፡ አምሐ፡ ሕፄሃ፡ ፰መሰፈርተ፡ ገሃፍተ፨ እስመ፡ ብዕሉ፡
                                            ለይኩኖ፡ እግዚእ፡ አልቦቱ፡ መስፈርት፨ ወሠራዊቱሰ፡ ኢይትከሃል፡ ኈልቆቶ፡
                                            </incipit>
                                            </msItem>

                                            <msItem xml:id="ms_i2.7">
                                               <locus from="82va" to="83rb"/>
                                               <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle6">Story about the church of John the Baptist
                                                 at Tedren</title>
                                               <incipit xml:lang="gez">
                                               <locus from="82va" to="82vb"/>
                                               <hi rend="rubric">፮ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡ መጥምቅ፡</hi><gap reason="ellipsis" resp="DN"/>
                                               ስምዑ፡ ንነግረክሙ፡ ወእምድ<pb n="82vb"/>ኅረ፡ ሖረ፡ እምድኅረ፡ ድልማ፡ ውስተ፡ ምድር፡ ቴድሬን፡
                                               ዘትሰመይ፡ ቤተ፡ ዮሐንስ፡ ወካዕበ፡ ይብልዋ፡ ማየ፡ ወገዲ፡ እንተ፡ ኃደረ፡ ውስቴታ፡ ለሊሁ፨ ወነበረት፡ ውስተ፡ ቤተ፡ ክርስቲያን፡ ውስተ፡
                                               መርሕብ፡ ምዕላድ፡ ዘኵስሕ፡ ወፈድፋደ፡ ፂአቱ፡ ዘጼናሁ፨
                                               </incipit>
                                               </msItem>

                                               <msItem xml:id="ms_i2.8">
                                                  <locus from="83rb" to="84ra"/>
                                                  <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle7">Story about a monk who
                                                  wanted to prohibit to the people to bring gifts to a church of John the Baptist</title>
                                                  <incipit xml:lang="gez">
                                                  <locus from="83rb" to="83va"/>
                                                  <hi rend="rubric">፯ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡</hi><gap reason="ellipsis" resp="DN"/>
                                                  ወነበረ፡ ፩መነኮስ፡ ዘስሙ፡ ቆሞስ፡ ውስተ፡ ይእቲ፡ ብሔር፡ ዘአቅደምነ፡ ዘክሮታ፡ ወኮነ፡ ይምሕር፡
                                                  በድፍረት፡ ለሰብአ፡ ዚአሃ፡ እንዘ፡ ይብል፡ ኢይደሉ፡ ጸዊረ፡ አምሐ፡ ለቤተ፡ ክርስቲያን፡ ዘቅዱስ፡ <hi rend="rubric">ዮሐንስ፡</hi> መጥምቅ፨ እስመ፡ ሕዝባዊ፡ ውእቱ።
                                                  </incipit>
                                                  </msItem>

                                                  <msItem xml:id="ms_i2.9">
                                                     <locus from="84ra" to="85ra"/>
                                                     <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle8">Story about the healing of Habta ʾIyasus</title>
                                                     <incipit xml:lang="gez">
                                                     <locus target="#84ra"/>
                                                     <hi rend="rubric">፰ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡</hi><gap reason="ellipsis" resp="DN"/>
                                                     ወነበረ፡ ፩ብእሲ፡ ዘስሙ፡ ሀብተ፡ ኢየሱስ፡ ወውእቱ፡ ብእሲ፡ ፈራሄ፡ እግዚአብሔር፡ ወባዕል፡ ፈድፋደ፨ ወይሁብ፡ ምጽዋተ፡ ለነዳያን፡ ወለምስኪናን፡
                                                     ወአምሐ፡ ለቤተ፡ ክርስቲያኑ፡ ለቅዱስ፡ ዮሐንስ፡ መጥምቅ፨ ወይገብር፡ ፈቃደ፡ ወትረ፡
                                                     </incipit>
                                                     </msItem>

                                                     <msItem xml:id="ms_i2.10">
                                                        <locus from="85ra" to="85vb"/>
                                                        <title type="complete" ref="https://betamasaheft.eu/LIT6166MiraclesJohnBaptist#Miracle9">Story about a
                                                          monk who stole a book of the Miracles of Mary</title>
                                                        <incipit xml:lang="gez">
                                                        <locus target="#85ra"/>
                                                        <hi rend="rubric">፱ተአምሪሁ፡ ለብፁዕ፡ ወቅዱስ፡ ዮሐንስ፡</hi><gap reason="ellipsis" resp="DN"/>
                                                        ወነበረ፡ ፩ቀሲስ፡ ዘመጽአ፡ <sic>ተሰዲዮ፡</sic> በረኃብ፡ ወኃደረ፡ ውስተ፡ ብር፡

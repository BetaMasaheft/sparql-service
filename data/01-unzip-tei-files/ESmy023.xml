                                 on <locus target="#20r"/>, <foreign xml:lang="gez">መስከረም</foreign> on <locus target="#27r"/>, <foreign xml:lang="gez">ዘጥቅምት</foreign>
                                 on <locus target="#34v"/>, <foreign xml:lang="gez">ዘኅዳር</foreign> on <locus target="#41r"/>, <foreign xml:lang="gez">የካቲት</foreign> on
                                 <locus target="#48r"/>, <foreign xml:lang="gez">ዘታህሣስ</foreign> on <locus target="#54v"/>, <foreign xml:lang="gez">ዘጥር</foreign>
                                 on <locus target="#59v"/>, <foreign xml:lang="gez">ዘመጋቢት፡</foreign> on <locus target="#61r"/>,
                                <foreign xml:lang="gez">ዘሚያዝያ፡</foreign> on <locus target="#65r"/>, <foreign xml:lang="gez">ዘግንቦት</foreign> on
                                <locus target="#70r"/>, <foreign xml:lang="gez">ዘዘወትር፨</foreign> on <locus target="#74v"/>.</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#16ra #18ra #38ra #42va #64vb"/>
                           <desc type="Correction">Omitted words or letters are written interlineally.</desc>
                         </item>


                       <item xml:id="e3">
                             <locus target="#51v"/>
                              <desc type="Correction">The correct reading sequence of misplaced <ref target="#q6"/> and <ref target="#q7"/> has been indicated by a note in
                               the bottom margin of the folium.</desc>
                              <q xml:lang="gez">ኅልፍ፡ ኀበ፡ ፰ጥራዝ፡ ዘይቤ፡ ብርሃን።</q>
                              <q xml:lang="en">Pass to the quire 8 which says: ብርሃን</q>
                              </item>

                              <item xml:id="e4">
                                    <locus from="59v" to="60r"/>
                                     <desc type="Correction">The correct reading sequence of misplaced <ref target="#q6"/> and <ref target="#q7"/> has been indicated in the note
                                     in the bottom and upper margins</desc>
                                     <q xml:lang="gez">ተመለስ፡ አንባቢ፡ ኀበ፡ ፯ጥራዝ፡ ዘውእቱ፡ <pb n="60r"/>ዘተረስአ፡</q>
                                     <q xml:lang="en">Reader, go back to quire 7, which was forgotten.</q>
                                     </item>
                                        </list>


                  </additions>

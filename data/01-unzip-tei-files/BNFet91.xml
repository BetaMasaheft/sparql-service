               <msContents>
                  <summary/> 
            
                  
            
                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3308Nicene">ጸሎተ፡ <choice>
                           <sic resp="PRS10747Zotenbe">ሃይማት፡</sic> 
                           <corr resp="PRS10747Zotenbe">ሃይማኖት፡</corr>
                        </choice>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>Instead of 
                        <foreign xml:lang="gez">ወተሰብአ፡ እመንፈስ፡ ቅዱስ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </foreign>, 
                        this manuscript has <foreign xml:lang="gez">ወተሰብአ፡  ወተሠገወ፡ እመንፈስ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </foreign> 
                        and then <foreign xml:lang="gez">ወተሰቅለ፡ በእንቲአነ</foreign>.</note>
                  </msItem>
            
                  <msItem xml:id="ms_i2">
                     <locus from="2r">Fols 2r and following</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3990Prayer">እሴብሐከ፡ ኦእግዚእየ፡ ኢየሱስ፡
                ክርስቶስ፡ ምስለ፡ አቡከ፡ ኄር፡ ወመንፈስ፡ ቅዱስ፡ በስብሐተ፡ ማር፡ <persName ref="https://betamasaheft.eu/PRS7853Philoxen">ፈለስኪኖስ፡</persName> ጳጳስ፡ ዘሀገረ፡ መንቡዠ፡
              ዘይጼልዩ፡ ቦቱ፡ ኵሉ፡ ሰብእ፡ ምእመናን፡ በእንተ፡ መድኀኒተ፡ ነፍሶሙ።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ስብሐት፡ ለከ፡ እግዚአብሔር፡ ስብሐት፡ ለከ፡ እግዚአብሔር፡ ስብሐት፡ ለከ፡ እግዚአብሔር፡
              ስብሐት፡ ለከ፡ ኦሥሉስ፡ በግጻዌ፡ ወ፩፡ በጽምረተ፡ መለኮት።</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i3">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/> 
              ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወሠናይ፡ ሥንዓሁ፡ በጽሒፈ፡ ጸሎታት፡ እንተ፡ ሰብዓቱ፡ ዕለታት፡ በሰላመ፡ እግዚአብሔር፡ አሜን።</title>
                     <textLang mainLang="gez"/>
                     <note>This manuscript's text agrees nearly always with <ref type="mss" corresp="https://betamasaheft.eu/BNFet89#ms_i1"><span xmlns="" class="w3-tag w3-red">No item: BNFet89#ms_i1</span></ref>.</note>
          
                     <msItem xml:id="ms_i3.1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Monday">Wǝddāse
                                                  ʾAmlāk, No item: chapter: Monday</title>
                     </msItem>
            
                     <msItem xml:id="ms_i3.2">

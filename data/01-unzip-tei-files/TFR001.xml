               <msContents>
                  <summary/>

                     <msItem xml:id="ms_i1">
                        <locus from="1r1" to="1r10"/>
                        <title type="complete">Prayer against <foreign xml:lang="gez">bāryā</foreign> and <foreign xml:lang="gez">legewon</foreign>
                     </title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመ<gap reason="illegible"/>
                           አምላክ፡ <gap reason="illegible"/> መ፡ ዓይነ፡</hi> ጸላ፡ ባርያ፡ ወሌጌዎን፡ ዛር፡</incipit>
                        <explicit xml:lang="gez">ቃለ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እምላዕለ፡ አመትከ፡ ወለተ፡ <hi rend="rubric">ኢየሱስ፡ ተርሳ፡
                           <gap reason="illegible"/> አ</hi>ምላክኒ፡ ዘበአማን፡ ወበቃልከ፡ ይትፈወሱ፡ ዱያን፡</explicit>
                     </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="1r11" to="1r18"/>
                     <title type="complete"/>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">ጸሎት፡ በእንተ፡</hi> ሕማመ፡ ቍርፀት፡ ዘተፈነወ፡ እምኀበ፡ ከመ፡ ይፃዕ፡ ወይቤዙ፡
                     ውሉደ፡ እጓሌ፡ እመሕያው፡</incipit>
                     <explicit xml:lang="gez">ይትሃረድ፡ ይትሃረድ፡ ይትሃረድ፡ ሸገር፡ ሸገር፡ ሸገር፡ አድኅና፡ ወፈውሳ፡ ለአመትከ፡ ወለተ፡ <hi rend="rubric">ኢየሱስ፡ ተርሳ፡</hi>
                     </explicit>

                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="1r19" to="1r24"/>
                     <title type="complete"/>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ምትዓት፡ ይኤርር፡ ይኤርር፡ ይሽባኤርር፡</incipit>
                     <explicit type="supplication" xml:lang="gez">ይሽለሸት፡ ይሽለሸት፡ ይሽለሸት፡ አድኅና፡ ወፈውሳ፡ ለአመትከ፡ ወለተ፡ <hi rend="rubric">ኢየሱስ፡ ተርሳ፡</hi>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="1r25" to="1r39"/>
                     <title type="complete">Prayer against bāryā and legewon, containing the beginning of the Gospel of John</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ባርያ፡ ወሌጌዎን፡ ወንጌል፡ ዘዮሐንስ፡ ቀዳሚሁ፡ ቃል፡ ውእቱ፡</incipit>
                     <explicit type="supplication" xml:lang="gez">ወጽልመትኒ፡ ኢይረክባ፡ ወኢይቀርባ፡ እምሕማመ፡ ባርያ፡ ወነገርገር፡ ለአመትከ፡ ወለተ፡
                     <hi rend="rubric">ኢየሱስ፡ ተርሳ፡</hi>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="1r40" to="1r49"/>
                     <title type="complete"/>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነ፡ ጽላ፡ ወማዕሠረ፡ አጋንንት፡ ወመርበብተ፡ ሰሎሞን፡ ዘሩበቦሙ፡ ለአጋንንት፡ ከመ፡ መርበብተ፡ ዓሣ፡</incipit>
                     <explicit type="supplication" xml:lang="gez">እልመረብ፡ አፍ፡ እልፍ፡ ጸልአኒ፡ እግዚኦ፡ እምጸላዒ፡ ወጸድፍ፡ ወሠውሮ፡ እምዓይነ፡ ጽላ፡ ለአመትከ፡
                     ወለተ፡ <hi rend="rubric">ኢየሱስ፡ ተርሳ፡</hi>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="1r49" to="1r129"/>
                     <title type="complete">Susǝnyos</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነ፡ ጽላ፡ ዛር፡ ወፍሬራኛ፡ በስመ፡ እግዚአብሔር፡ ሕያው፡ ነባቢ፡ ወተናጋሪ፡ ለቅዱስ፡ ሱስንዮስ፡</incipit>
                     <explicit type="supplication" xml:lang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <locus from="1r129" to="1r201"/>
                     <title type="complete"/>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ደም፡</incipit>
                     <explicit type="supplication" xml:lang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i8">
                     <locus from="1r201" to="1r228"/>
                     <title type="complete">Beginning of the first psalm and prayer</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"/>
                     <explicit type="supplication" xml:lang="gez"/>
                  </msItem>


                  </msContents>


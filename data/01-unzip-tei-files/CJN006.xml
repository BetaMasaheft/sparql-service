                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="5r" to="143r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez"/>

                    <msItem xml:id="ms_i1.1">
                      <locus from="5r" to="110r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez"/>
                      <incipit xml:lang="gez"><hi rend="rubric">
                        ዘከመ፡ መዝሙረ፡ ድንግል፡ ትመስል፡ ገነተ።</hi><lb/>
                        ወታስተጋብእ፡ አቅማኃ፡ ወፍሬያት፨<lb/>
                        <hi rend="rubric">ወትሰድድ፡ አጋንንተ፡ ወታቄርብ፡ መላእክተ።</hi><lb/>
                         ተግሣጽ፡ ለኵሉ፡ ወአሥተናሥኦ፡ ምግባራት፨<lb/>
                         ፨ ፨ ፨ ፨ ፨ ፨ ፨ ፨<lb/>
                         <hi rend="rubric">
                          ፍካሬ፡ ዘጻድቃን፡ ወዘኃጥአን።<lb/>
                          መዝሙር፡ ዘዳዊት፡ ሃሌሉያ።<lb/>
                      ፩</hi>ብፁዕ፡ ብእሲ፡ ዘኢሖረ፡ በምክረ፡ ረሲዓን፨<lb/>
                    ወዘኢቆመ፡ ውስተ፡ ፍኖተ፡ ኃጥአን፨<lb/>
                     <hi rend="rubric">ወዘኢነበረ፡ ውስተ፡ መንበረ፡ መስተሣልቃን።</hi><lb/></incipit>
                     <explicit xml:lang="gez">ወአሰሰልኩ፡ ጽእለተ፡ እምደቂቀ፡ እስራኤል፨<lb/>
                       <add place="below">ወአንሰ፡ ነሣእኩ፡ እምውስተ፡ አፍላግ፡ ፫አዕባነ</add><lb/>
                   </explicit>
                      </msItem>

                    </msItem>
                    <msItem xml:id="ms_i1.2">
                      <locus from="110v" to="121r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">
                        <hi rend="rubric">መሐልየ፡ ነቢያት፡ ወጸሎቱ፡ ለሙሴ።</hi><lb/></title>
                      <incipit xml:lang="gez">
                       <hi rend="rubric">ንሴብሖ፡ ለእግዚአብሔር፡ ስቡሕ፡ ዘተሰብሐ።</hi><lb/>
                     ፈረሰ፡ ወመስተፅዕነ፡ ወረወ፡ ውስተ፡ ባሕር፨<lb/></incipit>
                       <explicit xml:lang="gez">እስመ፡ ርእያ፡ አዕይንትየ፡ አድኅኖተከ፨<lb/>
                       ዘአስተዳሎከ፡ ቅድመ፡ ኵሉ፡ ሕዝብከ፨<lb/>
                        ከመ፡ ትክሥት፡ ብርሃነ፡ ለአሕዛብ፨<lb/>
                      ወክብረ፡ ለሕዝብከ፡ እስራኤል፨</explicit><lb/>
                    </msItem>

                    <msItem xml:id="ms_i1.3">
                      <locus from="121v" to="127v"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">መሐልየ፡ መሐልይ፡ ዝውእቱ፡ ዘሰሎሞን።</title>
                    <incipit xml:lang="gez"><hi rend="rubric">ይስዕመኒ፡ በስዕመተ፡ አፉሁ።</hi><lb/>
                   አዳም፡ አጥባተኪ፡ እምወይን፨<lb/>
                 </incipit>
                     <explicit xml:lang="gez">ጕይ፡ አንተ፡ ወልድ፡ እኁየ፡ ወተመሰላ፡ ለወይጠል፨<lb/>
                     ወከመ፡ ወሬዛ፡ ኃየል፡ ውስተ፡ አድባራተ፡ ድኍኃን፨<lb/></explicit>
                    </msItem>

                    <msItem xml:id="ms_i1.4">
                      <locus from="128ra" to="138va"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                      <textLang mainLang="gez"/>
                      <incipit xml:lang="gez"><hi rend="rubric">ውዳሴሃ፡ እግዚእትነ፡ ማርርያም፡
                      ወላዲተ፡ አምላክ፡ ዘ</hi>ይትነበብ፡ በዕለተ፡ ሰኑይ፡ ፈቀደ፡ ይግዕዞ፡ ለ<hi rend="rubric">አዳም፡ ኅዙነ፡
                      ወትኩዘ፡ ልብ፨ </hi></incipit>
                     <explicit xml:lang="gez">ይስረይ፡ ኃጢአተነ፡ በብዝኃ፡ ምሕረቱ፡ ሰአሊ፡ ለነ፡ ቅድስት፨፨፨</explicit>
                    </msItem>

                    <msItem xml:id="ms_i1.5">
                      <locus from="138va" to="143rb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa"><hi rend="rubric">ውዳሴ፡
                         ወግናይ፡ ዘእግዚእትነ፡ ማርያም፡</hi>
                    </title>
                    <incipit xml:lang="gez"><hi rend="rubric">ቅድስት፡ ወ</hi>ብፅዕት፡
                    ስብሕት፡ ወቡርክት፨ ክብርት፡ ወልዕልት፡ አንቀጸ፡ ብርሃን፡
                    መዓርገ፡ ሕይወት፡</incipit>
                      <explicit xml:lang="gez">ሣህሎ፡ ይክፍለነ፡ ሰአሊ፡ ለነ፡ ቅድስት፨
                      ጸሎታ፡ ለማርያም፡ ወስእለታ፡ የሃሎ፡ ምስለ፡ ገብራ፡ <hi rend="rubric"><del rend="erasure"/>።</hi>
                       ለዓለመ፡ ዓለም፡ አሜን፨</explicit>
                    </msItem>

                    <msItem xml:id="ms_i1.6">
                      <locus from="143ra" to="144va"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa malāʾǝkt la-Māryām</title>
                      <textLang mainLang="gez"/>
                      <note>Added in a later and less careful hand.</note>
                        <incipit xml:lang="gez"><hi rend="rubric">ይዌድስዋ፡ መላእክት፡ ለማርያም፡
                          በውስተ፡</hi> ውሳጤ፡ መንጦላዕት፡ ወይብልዋ፡ በሐኪ፡ <hi rend="rubric">ማርያም፡</hi>
                      ሐዳስዩ፡ ጣዕዋ፡ ይቤላ፡ መልአክ፡ ለ<hi rend="rubric">ማርያም፡ </hi></incipit>
                      <note>Probably incomplete,
                        the text at the end is damaged, unreadable.</note>
                      </msItem>

               </msContents>

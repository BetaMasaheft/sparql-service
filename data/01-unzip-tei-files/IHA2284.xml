               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="107v">2r-107v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0108IHA">ارشاد الغاوي الى مسالك الحاوي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم الحمد لله الذي لا تحصى مواهبه ولا تنفد عجائبه ولا تحصر له متن [...] وبعد فهذا مختصر حوى المذهب نطقا وضمنا خميص من اللفظ بطين من المعنى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#107r">-107r</locus>باب من انت بمتخطط بأحبال سيد عتعت وولدها بعده بموته وان قتله كمدبر وحاول دين عتقت بموت شركاء مؤسرين ادعى كل ايالاد اقبل ووقف الولاء وهي بولد قن لا في نقل ملك.
تم الكتاب بعون الله ومنه وكرمه بيد مالكه الفقير الحقير الراجي عفو</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0533</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ማኅበረ፡ ምእመናን፡ ኀበ፡ ተዐየኑ፡ ወአንገለጉ፡ ካዕበ፨</l>
                  <l n="2">ዜና፡ ውዳሴከ፡ እንግር፡ እንዘ፡ እዜኑ፡ ንባበ፨</l>
                  <l n="3">ገብረ፡ ማርያም፡ ጴጥሮስ፡ ዘተዐገሥከ፡ ዕጸበ፨</l>
                  <l n="4">እስመ፡ ለከ፡ እምሰማያት፡ መራኁተ፡ ጽድቅ፡ ተውህበ፨</l>
                  <l n="5">ማዕጾ፡ ኅሊናየ፡ አርኁ፡ ወምላእ፡ ጥበበ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምዝክረ፡ መላእክት፡ ዘተበፅዐ፨</l>
                  <l n="2">ወበሥነ፡ ሞገስ፡ ላዕሌሁ፡ ስመ፡ ማርያም፡ ዘተለክአ፨</l>
                  <l n="3">ገብረ፡ ማርያም፡ ከሃሊ፡ ከመ፡ ቃለ፡ ዳዊት፡ አይድዐ፡</l>
                  <l n="4">ፍጥር፡ ሊተ፡ እግዚእየ፡ ልበ፡ ካልአ፨</l>
                  <l n="5">ወበውስተ፡ ከርሥየ፡ ሐድስ፡ መንፈሰ፡ ርቱዐ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ ለፍልሰተ፡ ስምዖን፡ ዘተዛወጋ፨</l>
                  <l n="2">እምደብረ፡ ሊባኖስ፡ እምከ፡ ዘተበፅዐ፡ ሥርዓተ፡ ሕጋ፨</l>
                  <l n="3">ኀበ፡ ሀገሪትከ፡ ሐንታ፡ ገብረ፡ ማርያም፡ አበ፡ እንግልጋ፨</l>
                  <l n="4">ብእደ፡ ወለትከ፡ ኅሪት፡ እንተ፡ ተሰምየት፡ በጸጋ፨</l>
                  <l n="5">አመተ፡ ጽዮን፡ በንጽሕት፡ ወንድግልት፡ በሥጋ፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ዕበያቲከ፡ እዜኑ፡ ወእነግር፡ በውዳሴ፨</l>
                  <l n="2">ገብረ፡ ማርያም፡ ቀሲስ፡ ዘሦዕከ፡ መሥዋዕተ፡ ካዕሴ፨</l>
                  <l n="3">ምስለ፡ ሱራፌል፡ ካህናት፡ እለ፡ ይለብሱ፡ ሥእለ፡ ብናሴ?</l>
                  <l n="4">ድርገተ፡ ኮንከ፡ በላዕሉ፡ እንዘ፡ ትከውን፡ ብእሴ፨</l>
                  <l n="5">መንበረ፡ ጸባኦት፡ ትዕጥን፡ ወትቀድስ፡ ሥላሴ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ናሁ፡ ፈጸምኩ፡ ወሰለጥኩ፡ በድርየ፨</l>
                  <l n="2">እንዘ፡ እነግር፡ ክብረከ፡ ወዘዚአከ፡ ዕበየ፨</l>
                  <l n="3">ገብረ፡ ማርያም፡ ዘንተ፡ ተወኪፈከ፡ አቡየ፨</l>
                  <l n="4">ንስቲተ፡ ለዐስብየ፡ እመዝገብከ፡ ሠናየ፨</l>
                  <l n="5">ድሉ፡ ሊተ፡ ኢታትርፍ፡ ጻማየ፨</l>
               </lg>
               <lg type="stanza" n="41">
                  <l n="1">ስብሐት፡ ለከ፡ ወለዕበይከ፡ ሃሌ፨</l>
                  <l n="2">ወኍልቈ፡ ፍጥረታት፡ ዘታሕቱ፡ ወበፍቅደ፡ ግብር፡ ዘሉዓሌ፨</l>
                  <l n="3">አምላከ፡ ቅዱሳን፡ ትእዛዘከ፡ ዘጸሐፍኩ፡ በውስተ፡ ጽሌ፨</l>
                  <l n="4">ኢየኀድግ፡ ዘንተ፡ ተአምኖተከከሃሌ፨</l>
                  <l n="5">ኀበ፡ ተራከበኒላሕ፡ ወበጽሐኒ፡ ወይሌ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
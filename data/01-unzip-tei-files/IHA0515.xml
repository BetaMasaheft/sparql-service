               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="5r" to="27r">5r-27r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT1144IHA">براهين الحسان فيما يتعلق بهلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله الرحمن الرحيم .الحمد لله الذى انزل على عبده الكتاب الذى لا تأتيه الباطل من بين يديه ولا من خلفه وقال فيه فان تنازعتم فى شيئ فردوه الى الله ورسوله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>وأسئله الهداية وحسن الختام, والصلاة والسلام, على سيدنا محمد بدر التمام, ومصباح الظلام, وآله وصحبه الكرام, والتابعين لهم بأحسان الى يوم القيام, بين يدى الملك العلام, ذى الجلال والأكرام


</explicit>
                     <note>Draft</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="122r" to="186r">122r-186r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT1144IHA">براهين الحسان فيما يتعلق بهلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#122v">-122v</locus>بسم الله الرحمن الرحيم .الحمد لله الذى انزل على عبده الكتاب الذى لا تأتيه الباطل من بين يديه ولا من خلفه وقال فيه فان تنازعتم فى شيئ فردوه الى الله ورسوله

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#186r">-186r</locus>وهو حفظه الله يناجى ربه كثيرا سيما فى اوقات السحور وقد وضع للمناجات سجيعات عظيمة القدر جليلة الفخر واجبت ان اذكر هاهنا وهى هذه</explicit>
                     <note>Draft</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="189r" to="236v">189r-236v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT1152IHA">شرح خطبة وان تجد من هو عنها معرض فارفع وقل لا لأبيك
                    معبض</title>
                     <incipit xml:lang="ar">
                        <locus target="#189r">-189r</locus>وان تجد من هو عنها معرض فارفع وقل لا لأبيك معبض. اى وان تجد من هو لبيب سديد وموفق رشيد معرضا عنها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#236v">-236v</locus>خلله وجبر كسره اذا المأنون كالبنيان يشد بعضه بعضا نعوذ بالله من شنر من يتقصى عواره حسد او بغضا الحمد لله رب العالمين اللهم محمد ك نسالك ان تغصر لناز لا تنا وهفواتنا واقوالنا التى ليس على وقف اعما لنا واحوالنا وان لا تجعل ما كتبناه على الطروس وبالاولا سببا لعبدنا وطردنا انك انت البر الرحيم والجواد الكريم ربنا تقبل منا انك انت السمبع العليم وتب علينا انك انت التواب الرحبم امين</explicit>
                     <note>Mixed up folios. Some of them are upside-down.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="244r" to="271r">244r-271r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1144IHA">براهين الحسان فيما يتعلق بهلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#244v">-244v</locus>بسم الله الرحمن الرحيم الحمد لله الذى انزل على عبده الكتاب الذى لا بأتيه الباطل من بين يديه [...] اما بعد فيقول أسير ذنبه الراجى عفو ربه خادم طلبة العلم بدر الدين الزبى القبينى ابن المرحوم العارف بالله الحاج محمد سرور المعروف بأبى عفا الله عنه وعن والديه واخوانه وجميع المسلمين. إنى اطلعت على كتبهما بعض من ينتسب الى العلم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#270v">-270v</locus>شهر ذى القعدة رابعه يوم عرفة خامسه اول شهر رمضان| شهر ذى الحجة تاسعه يوم عرفة عاشره اول شهر رمضان. انتهى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="272r" to="274r">272r-274r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0616IHA">حاشية الشرواني على تحفة المحتاج بشرح المنهاج</title>
                     <incipit xml:lang="ar">
                        <locus target="#272r">-272r</locus>الحمد لله رب العالمين والصلاة والسلام على سيد المرسلين وعلى آله وصحبه أدمعين. وبعد فان القوم قالوا من لم يعرف اجداده فى الطريق فهو دعيّ فيها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#273">-273</locus>ولا يقابل بمال نعم يجوز اخد التال فى مقابلة اليه عنها ويفهمه قول ابن القاسم وغيره من انه يجوز نقل اليه عن الاخصاصة بالدراهم ا ه شروانى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="276r" to="285r">276r-285r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT1161IHA">توسل بالرسل والأنبياء والصالحين</title>
                     <incipit xml:lang="ar">
                        <locus target="#276r">-276r</locus> وقال العلامة المحقق المدقق شيخ الاسلام ومفتى الانام شيخنا الحاج  محمد سراج الأنّىّ مفتى رايّة رحمه الله الرحمة الواسعة ونفعنا بعلومه ان التوسل والشفع وكذ الاستفتاح والاستغاثة متقاربة فى المعنى  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#285r">-285r</locus>تحقيق على الزيارة اذا فعلت مع المحافظة على اداب الشريعة الغراء لا تؤدى الى محذول البتة وان القائل بالمنع منها سد اللذريعة متعول على الله وعلى رسوله صلى الله عليه وسلم ا ه باختصار هذا والسلام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="32r" to="32v">32r-32v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1155IHA">قصيدة اصل كل الاصول</title>
                     <incipit xml:lang="ar">
                        <locus target="#32r">-32r</locus>اصل كل الاصول| ومصدر الوجود| يابرزخ الأرواح ميزاب الاستمداد| ياربيع الشهور| ازلا وأبد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#32v">-32v</locus>هام بكم غراما| فواشوقى ووجدى| ياجنة الأرواح| ياعالم الشهود</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="33r" to="35v">33r-35v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1158IHA">نظم اللهم صلى على ذاك الحبيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#33r">-33r</locus>اللهم صلى على ذاك الحبيب نوراني ذات جمالي عجب واله وصابه لبيب.

الحمد لله ء لطيف الهادق| لماءكر منا بخير العباد| شفيع البرايا ميزاب المدد| فيه هدانا سيد الرشاد تا الله إنه كنز الله المطلوب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35v">-35v</locus>يارسول الله ايا شمس الهدف يا عرو سبادى فى صحن قدس الله| ها انا هائم فبحكم| احنا اشتكى رئيا وجهكم| عجلو منائ بوصالكم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="36r" to="50v">36r-50v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1159IHA">منتخب من السيرة النبوية</title>
                     <incipit xml:lang="ar">
                        <locus target="#36r">-36r</locus>صفر يلى لعام هجرته فعزى رسول الله صلى الله عليه وسلم واله وصحبه ومن اسلم تسعا وعشرين او سبعا وعشرين غزوة وبعث سبعا واربعين أو نحو سبعين سريه والغزوة هى الق حضرها الرسول عليه والصلاة والسلام بنفسه سواء حارب فيها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#50v">-50v</locus>هو ابن اثنين وثمانين سنة فتولاها على بن ابى طالب رضى الله عنه وكرم وجهه بمبايعة اكثر الصحابة ولبث فيها اربع سنين وتسعة اشهر وقتل شهيد او هو ابن ثلاث وستين سنة والله اعلم هذا والسلام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="55v" to="69r">55v-69r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1160IHA">نظم السلام عليك يا زين الوجود</title>
                     <incipit xml:lang="ar">
                        <locus target="#55v">-55v</locus>السلام عليك يا زين الوجود اشرف الرسل حبيب الودود طه صاحب المقام المحمود| أصلى على نبراس الظلا م| بعد كل نفس الأنا م| من أذل الى الأذ دحا م| جميع الصلاة وكذا السلا م</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#69r">-69r</locus>وآله الغر والصحب الكرام والفضل الجلى والسلام والطيب الحفل| تفضل بالمقصود معبول يا الله| اللهم صل وسلم عليه ٢ عد مخلوق الله مك مكنون الله ٣</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="78r" to="83v">78r-83v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1144IHA">براهين الحسان فيما يتعلق بهلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#78r">-78r</locus>بهم فى العمل ومجاهدة النفس ان فقد المتأهلين وذلك مرة فى كل وليلة فى غيرا وان الخلوة واما فيها</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#83v">-83v</locus>وان كانت مثل زبد البحررواه عبد الله بن عمر وروى باسناد صحيح انه عليه الصلاة والسلام ور على من يغرس غرسا فقال له خير من هذ سبحان الله والحمد لله ولا اله الا الله والله اكبر يغرس لك بكل واحدة شجرة فى الجنة وروى ابو هريرة انه صلى الله عليه وسلم قال لان اقول سبحان الله والجمد لله ولا اله الا الله واكبر احب الىّ مما طلعت عليه الشمس وفى رواية أخرى زيادة </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="85r" to="98v">85r-98v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1144IHA">براهين الحسان فيما يتعلق بهلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#85v">-85v</locus>بسم الله الرحمن الرحيم .الحمد لله الذى انزل على عبده الكتاب الذى لا تأتيه الباطل من بين يديه ولا من خلفه وقال فيه فان تنازعتم فى شيئ فردوه الى الله ورسوله

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#98v">-98v</locus>لو وقعت نية الصوم والصلاة بعد دخول الوقت فى نفس الامر قبل ظهوره لنا لم ينعقد وان أخبره معصوم فضلا عن الولىّ للعلة قاله بعضهم</explicit>
                     <note>Draft</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="106r" to="119r">106r-119r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1145IHA">جوهرة البهية في مولد خلاصة بطون الهاشمية</title>
                     <incipit xml:lang="ar">
                        <locus target="#106r">-106r</locus>يا رب صل على محمد وحفنا مولانا با النعم| يا رب صل على محمد واجرنا جميعا من مغرم
بسم الله الرحمن الرحيم هو الذى يصلى عليكم وملءكته ليخرجكم من الظلمات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#119r">-119r</locus>قلت فى حقهم سبحانك اللهم ومخيتهم فيها سلام وآخر دعوى هم ان الحمد لله رب 
العلمين آمين سبحان| ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين</explicit>
                     <note/>
                     <note/>
                  </msItem>

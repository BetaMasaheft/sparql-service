               <msContents>
                  <summary>Gospel of John, ወንጌል፡ ዘዮሐንስ</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="2r">2r-93v</locus>
                     <title>Gospel of John</title>
                     <note>arranged for the days of the week</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="93v">93v-95r</locus>
                     <title ref="https://betamasaheft.eu/LIT3064RepCh344">Hymn to Mary, I praise your grace</title>
                     <incipit xml:lang="gez">እሴብሕ፡ ጸጋኪ፡ ኦምልዕተ፡ ጸጋ፡ ወእትጋነይ፡ ለኪ። ኦምልዕተ፡ ውዳሴ።</incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="95r" to="97r">95r-97r</locus>
                     <title>Asmāt prayer for a snakebite victim</title>
                     <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ዘነሰኮ፡ አርዌ፡ ምድር፡ ታወሥእ፡ ወትብል፡ ፫ተ፡ ጊዜ፡ በል።</incipit>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>

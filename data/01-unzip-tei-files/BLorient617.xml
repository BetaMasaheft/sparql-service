<msContents>

<msItem xml:id="ms_i1">
<locus from="1r"/>
<title type="complete" ref="https://betamasaheft.eu/LIT1284Dersan">Dǝrsāna Gabrǝʾel</title>
<textLang mainLang="gez"/>


<msItem xml:id="ms_i1.1">
<locus from="5r"/>
<title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1284Dersan#Tahsas">For the 19th of Tāḫśāś</title>
<incipit xml:lang="gez">ድርሳን፡ ዘቅዱስ፡ ሊቀ፡ መላእክት፡ ገብርኤል፡ አመ፡ በዓሉ፡ ዘይትነበብ፡ አመ፡ ፩ወ፱ለታኅሣሥ፡ ሠምረ፡ እግዚአብሔር፡ እግዚእነ፡
ኢየሱስ፡ ክርስቶስ፡ ከመ፡ እሑር፡ ኀበ፡ አብያተ፡ ክርስቲያናት፡ እለ፡ ሐነጸት፡ እሌኒ፡ ንግሥት፡ ኀበ፡ ቅድስት፡ ሀገረ፡ ኢየሩሳሌም። </incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.2">
<locus from="9v"/>
<title type="incomplete" xml:lang="en" ref="https://betamasaheft.eu/LIT4652TaammeraGa">Miracles</title>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.3">
<locus from="12v"/>
<title type="complete" xml:lang="en">Homily on the Nativity of our Lord</title>
<incipit xml:lang="gez">ድርሳን፡ ዘቅዱስ፡ ሊቀ፡ መላእክት፡ ገብርኤል፡ ፍሡሐ፡ ገጽ፡ ፩እምእለ፡ ይተግሁ፡ መላእክት፡ ቅዱሳን፡ አብሳሬ፡ ፍሥሐ፡ ወሐሤት፡ ለኵሉ፡
ዓለም፡ ሰባኬ፡ ፀሐየ፡ ጽድቅ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.4">
<locus from="27v"/>
<title type="incomplete" xml:lang="en" ref="https://betamasaheft.eu/LIT4652TaammeraGa">Miracles</title>
<textLang mainLang="gez"/>
</msItem>
</msItem>

<msItem xml:id="ms_i2">
<locus from="64r"/>
<title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2729RepCh13">A hymn to Michael and Gabriel</title>
<incipit xml:lang="gez">ሚካኤል፡ ዘትቀውም፡ በየማነ፡ ማርያም፡ ድንግል።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i3">
<locus from="66v"/>
<title type="complete" xml:lang="gez">A prayer to our Lord</title>
<incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ አማኅፀንኩ፡ አነ፡ ገብርከ፡ <gap reason="omitted"/> ነፍስየ፡ ወሥጋየ፡ ውስተ፡ እዴከ፡ ከመ፡ ትሥረይ፡
ኵሎ፡ ኃጢአትየ፡ ዘገበርክዎ፡ በአእምሮ፡ ወኢያእምሮ፡</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i4">
<locus from="3r" to="4v"/>
<locus from="69r" to="72r"/>
<title type="complete" xml:lang="en">A prayer to the blessed Virgin Mary</title>
<incipit xml:lang="gez">ኦሊቀ፡ መላእክት፡ ገብርኤል፡ ተመጣዌ፡ ጸሎት፡ ንጹሕ። እስእለከ፡ በጽንስ፡ ንጹሕ፡ ዘአብሰርካ፡ ለእግዝእትነ፡ ማርያም፡ ክብርት፡ ወልዕልት፡
ወንጽሕት። ከመ፡ ታብጽሕ፡ ጸሎትየ፡ ቅድመ፡ መንበር፡ ዘእግዚአብሔር፡ ንጹሕ። ኦእግዝእትየ፡ ማርያም፡</incipit>
<textLang mainLang="gez"/>
</msItem>

</msContents>


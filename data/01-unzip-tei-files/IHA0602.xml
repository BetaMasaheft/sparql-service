               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="7r" to="26r">7r-26r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0995IHA">جالية الكدر بذكر أهل بدروشهداء أحد السادة الغرر</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>بسم الله الرحمن الرحيم بدرية وافت ببرهان بهر | أحدية فى سردها سر ظهر| جمعتلأسماء الدين سمو ذرى| متن العلى فى المجد من صحر غرر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26r">-26r</locus>ثم الصلاة مع السلام على الذي| ايدته بظبي الملائك والبشر| والأل والصحب الضراغم فى الوغاصيد المأثر والمشاهدوالظفر

تمت المنظومة المسماة بجمالية الكدر باصحاب سيد الملائكة والبشر واهل البد والحض صلى الله عليه وعلى اله فى الاصال والبكر امين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="27r" to="52v">27r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1224IHA">جالية الكدر وجالبة المطلوب</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v-29r">-27v-29r</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين والصلاة والسلام على سيد المرسلين 
وبعد فيقول مؤلف هذه الاستغاثة فقد اجزت قراتها لكل صالح تقي نقى الساحة عن ضرر المسلمين ولا أجيزها لا ضرار المسلمين ولهذا الاستعانة منافع وأغاثة للمستغيثين بهار قد جربناها مرارا وقد أخبرنى من أثق به من اهل الكشف أنها عجيبة فى سرعة اغاثة المستغيثين بهم وقال شاهدتها مرار كثيرة [...] بسم الله الرحمن الرحيم الحمد لله
 ولي الخيرات ثم صلاته على ذى الفيضات| فندعوك ربى بانوار الصفات بمظهر الاسماء بسر الذات| بسر سرك وبالطلسمات بالكنز المخفي من الاشارات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>ثم صلاته مع سلامه على محمد خير البريات| مع اصحابه وع اله ومن ذكرتهم من تلك السادات |ومن تبعهم على تلك القدم ومن راقبهم فى تلك اللحظات |وصلى الله على سيدنا محمد وعلى ءاله وصحبه وسلم أ م ي ن</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="53r" to="62r">53r-62r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1062IHA">عروة الوثقى للبحر بشرى</title>
                     <incipit xml:lang="ar">
                        <locus target="#53v">-53v</locus>بسم الله الرحمن الرحيم
بدأت بحمدى لرب عليا| مستعينا به سجاعا يائيا| صلاة على من قد كان مهديا| سلام عليه أيضا صمدا نيا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#62r">-62r</locus>ولحاملها حجابا سنيا \ ولمنشدها حضرة عليا \ عد ابياتها عدا جمليا \ قوي حبلها قوة نصريا \ تمت
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="62v" to="64r">62v-64r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3042IHA">نظم فحمدي لربي ذى الكرم</title>
                     <incipit xml:lang="ar">
                        <locus target="#62v">-62v</locus>بسم الله الرحمن الرحيم \ فحمدى لربى ذى الكرم , انعم علينا بالاسلام \ صلاتى سلامى على النبى , المختار حقا من هاشم \ ذى الطبع الكريم خير أب , ساله صحبه الاكام [كذا] \ فلما ظهر حب النبى , أقلق قلوب المتيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#64r">-64r</locus>عبدك واقف لد الباب , راجى التفضل بالختام \ تمت شافية للكرب , بحمد ذي الفضل والكرم \ وصلى الله على سيدنا وعلى اله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="65r" to="71v">65r-71v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3096IHA">نظم والحمد لله حمدا مجدد كانعامه الذي لا ينفد</title>
                     <incipit xml:lang="ar">
                        <locus target="#65r">-65r</locus>بسم الله الرحمن الرحيم
والحمد لله حمدا مجدد كانعامه الذي لا ينفد| متزائد دوما مؤبد لله |صلاة الله الواحد الاحد مع سلامه الصمد| لم يكذ له كفوا أحد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71v">-71v</locus>صاحب هذى الأسجاع الأبلد جوهر الوسيخ| من فتح فعل به تكمد| عدها حطي هوز ايحد كل تم لم ينقص لم يزدد | والله اعلم به تعمد 
تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="73r" to="74r">73r-74r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0455IHA">نظم يا مفتاحا لكنوز الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#73r">-73r</locus>خذ بيدي | يا رسول الله \ يا مفتاحا لكنوز الله | يا حجابا لعذب الله \  يا كعبة لتجلى الله | يا مجالا لجمال الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#74r">-74r</locus>جعلتها لي راتمة  ارجو بها حسن الخاتمة | وصلاة هو اهلها , ما [غردا لب] اهل الله | وءاله وصحبه الكرام ما تواتر غيث حب الله   </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="74r" to="74v">74r-74v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4072IHA">نظم اهد [ايها] ولي الله منتقلا لرحمة الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#74r">-74r</locus>اهد انها ولي الله | منتقلا لرحمة الله \ يا فياضا لرحمة الله | فأدخلنا فى جوار الله \ فاغثنا يا حبيب الله | بجاهك الوسع عند الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#74v">-74v</locus>| وصلاة وسلام الله | على النبي خير خلق الله \ وءاله خير حزب الله وصحبه خير جند الله \ بعدد معلومات الله | ومداد كلمات الله \ وتابع للسيبا الله | ما دامة الصفات لله \ ت م ت </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="75r" to="79r">75r-79r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1229IHA">نظم طلعتم لنا شمسا فانفعنا بكم</title>
                     <incipit xml:lang="ar">
                        <locus target="#75v">-75v</locus>سلام عليكموا سلام عليكوا \ سلام عليكوا توسلنا بكموا \
طلعتم لنا شمسا فانفعنا بكموا \ الم بنا الظلمة لما عنا غبتموا \ فكنتم لنا كهفا فعشنا تحته \ فأورثنا الغم بانطوى حياتكموا \ كنتم معنا سيدى وكنا معكمو</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#79r">-79r</locus>مددنا المثمر وفيضنا المغمر \ ومن كل الخطور فامن بكموا \ قد خلفتم لنا سيدى ابنا مجوهرا \  جزى الله عنا خيرا سيدى عنكموا \ انتم كهفنا حقا ومغيثنا صدقا \ لجأنا اليكم فاجعلونا منكموا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="80v" to="82v">80v-82v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1227IHA">مديح شيء لله يا سيدي</title>
                     <incipit xml:lang="ar">
                        <locus target="#80v">-80v</locus>شي لله يا سيدى شى لله يا سيدى فسلام عليك| هيهات هيهات هيهات| فاتنا حياتكم| بقي القلب سكارى| حيار لفقدكم| ما حيلة عبيدكم| حيره هجركم| أسكر عقول الاحباب| سيدى انتقالكم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#82v">-82v</locus>ولف قتيل الوجد| بحرير وصلكم| لله الحمد والشكر| قد اكر منا بكم| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>

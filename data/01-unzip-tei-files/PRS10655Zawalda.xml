      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዘወልደ፡ ማርያም፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Zawalda Māryām</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾǝč̣č̣age</t:roleName>
               </t:persName>
                  <t:occupation type="ecclesiastic">abbot</t:occupation>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>

               <t:floruit notBefore="1705" notAfter="1728">
                  He was a monk of the monastery of <t:placeName ref="https://betamasaheft.eu/LOC4417Magwin">Magʷinā</t:placeName>
                  in northern <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName> and
                  <t:persName ref="https://betamasaheft.eu/PRS10655Zawalda">
                     <t:roleName type="title">ʾǝč̣č̣age</t:roleName>
                  </t:persName> of <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName> between <t:date>1725-1728</t:date>.
                  He succceeded <t:persName ref="https://betamasaheft.eu/PRS3669edaKres">ʾƎdā Krǝstos</t:persName> as the head of  <t:placeName ref="https://betamasaheft.eu/LOC4417Magwin">Magʷinā</t:placeName> in<t:date>1706</t:date>,
                  which was an important stronghold of the Unionist movement at a time of great instability, caused by the doctrinal controversies between
                  the Qǝbāt party and the Tawāḥǝdo supporters. He also played his role in reconciling
                  <t:persName ref="https://betamasaheft.eu/PRS9152TaklaHa">
                     <t:roleName type="title">ʾaṣe </t:roleName> Takla Hāymānot I</t:persName> with
                  <t:persName ref="https://betamasaheft.eu/PRS5616IyasuI">
                     <t:roleName type="title">ʾaṣe </t:roleName> ʾIyāsu I</t:persName> in <t:date>1706</t:date>.

He was appointed as the 34th <t:persName ref="https://betamasaheft.eu/PRS10655Zawalda">
                     <t:roleName type="title">ʾǝč̣č̣age</t:roleName>
                  </t:persName> of  <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName> in <t:date> 1725</t:date>.


                  But he was deposed three years later in <t:date>1728</t:date>. </t:floruit>

               </t:person>
               
         </t:listPerson>

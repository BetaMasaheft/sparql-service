               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="275r">1v-275r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الله الرحمن الرحيم , الحمد لله رب العلمين , الرحمن الرحيم , ملك يوم الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#274v">-274v</locus>الخناس , الذي يوسوس في صدور الناس . من الجنة والناس</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="275v" to="275v">275v-275v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4126IHA">دعاء ختم القران اجعل اللهم له ثواب قراتنا وبركة
                    دعائنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#275v">-275v</locus>بسم الله الرحمن الرحيم \ صدق الله العظيم وصدق رسوله النبي الكريم [...] اجعل اللهم ثواب قراتنا وبركة دعائنا واستغفارنا لمن جمعتنا بسبب وتلونا القران من اجله

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#275v">-275v</locus>ذلك الفضل من الله وكفي بالله عليما دعواهم فيها سبحانك اللهم وتحيتهم فيها سلام واخر دعواهم ان الحمد لله رب العالمين 
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="276r" to="276r">276r-276r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0698IHA">دعاء ختم القرآن اللهم اجعل القرآن العظيم لقلوبنا
                    نورا</title>
                     <incipit xml:lang="ar">
                        <locus target="#276r">-276r</locus>بسم الله الرحمن الرحيم \ اللهم اجعل القران العظيم لقلوبنا نورا وهدى ولصدورنا شفا من كل دا ولهمومنا وغمومنا جلا من كل الصدا وكفارة لذنوبنا

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#276r">-276r</locus>واجعله حجة لنا ولا تجعله [حجة] علينا يا رب العالمين دعواهم فيها سبحانك اللهم وتحيتهم فيها سلام واخر دعواهم ان الحمد لله رب العالمين 

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="276r" to="276v">276r-276v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#276r">-276r</locus>بسم الله الرحمن الرحيم \ اللهم ارحمنا بالقران العظيم وانفعنا بالايات والذكر الحكيم وبارك لنا في السبع المثاني والقران العظيم

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#276v">-276v</locus>اللهم اشف مرضانا وعاف مبتلانا وارحم موتانا وتمم نعمتك علينا واجعل اجتماعنا ودعانا وتاميننا بركة لنا في ديننا ودنيانا وشفا لنا من كل داء وسقم وفرج عنا من كل هم وغم برحتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين


</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="276v" to="276v">276v-276v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4151IHA">دعاء ختم القران اللهم اني اسالك ما كان فى تلاوتنا هذه من
                    خطا</title>
                     <incipit xml:lang="ar">
                        <locus target="#276v">-276v</locus>بسم الله الرحمن الرحيم \ اللهم اني [اسالك] ما كان في تلاوتنا هذه من خطا او نسيان او زيادة او نقصان او تقديم او تاخير</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#276v">-276v</locus>واصلح اللهم لنا ولاباىنا ولامهاتنا ولاخواننا ولاخواتنا ولجيراننا ولمشاىخنا ولجميع المسلمين والمسلمات والمومنين والمومنات برحمتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين

</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

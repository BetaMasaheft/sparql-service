               <msContents>
                  <summary>Praises of God, <foreign xml:lang="gez">ውዳሴ፡ አምላክ፡</foreign>
                  </summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="142v" facs="001">Fols 1r–142v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2505Weddas">Wǝddāse
                                                  ʾAmlāk</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Monday prayers, missing</note>

                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="7v" facs="001">Fols 1r–7v, </locus>
                        <locus from="8r" to="14v" facs="008">8r–14v, </locus>
                        <locus from="15r" to="40v" facs="015">15r–40v</locus>
                        <title>Tuesday prayers</title>
                        <incipit xml:lang="gez">ጸሎት፡ ዳግሚት፡ እንተ፡ ዘዕለተ፡ ሠሉስ፡ እምድርሳነ፡ ቅዱስ፡ ኤፍሬም፡ ሶርያዊ፡ አፈ፡ በረከት፡ ወበቍዔት፡<gap reason="omitted"/>ስብሐት፡ ለከ፡ ኦመስተዓግሥ፡<gap reason="omitted"/></incipit>
                        <note>Lacunae between folio ranges. Normal attribution to St Ephrem the Syrian</note>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="41r" to="62r" facs="041">Fols 41r–62r</locus>
                        <title>Wednesday prayers</title>
                        <incipit xml:lang="gez">ጸሎተ፡ ወስእለት፡ ሣልሲት፡ እንተ፡ ዘዕለተ፡ ረቡዕ፡ እምድርሳነ፡ ቅዱስ፡ ማሪ፡ ኤፍሬም፡ ካዕበ። ኦእግዚአብሔር፡ አምላክ፡ መሀሪ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሶበ፡ ተዘከርኩ፡ ምጽአተከ፡<gap reason="omitted"/></incipit>
                        <note>Normal attribution to St Ephrem the Syrian, with incipit</note>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="62r" to="86v" facs="062">Fols 62r–86v</locus>
                        <title>Thursday prayers</title>
                        <note>Normal attribution to St John Saba</note>
                        <incipit xml:lang="gez">ጸሎት፡ ዘዕለተ፡ ሐሙስ፡ አስተጋብእዋ፡ እመጽሐፈ፡ አረጋዊ፡ መንፈሳዊ፡ ቅዱስ፡<gap reason="omitted"/>ቡሩክ፡ ውእቱ፡ አቡሁ፡ ለእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘከሠተ፡ ምሥጢረ፡ አፍቅሮቶ፡ ለነፍሳቲነ፡<gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.4">
                        <locus from="87r" to="105v" facs="087">Fols 87r–105v</locus>
                        <title>Friday prayers</title>

                        <msItem xml:id="ms_i1.4.1">
                          <locus from="87r" to="96v" facs="087">Fols 87r–96v</locus>
                          <title>Prayers by John Chrysostom (?, otherwise by Abba Sinoda the Archmandrite, otherwise known as Shenute of Atripe, to whom these prayers are normally attributed)</title>
                          <incipit xml:lang="gez">ጸሎት፡ ወስእለት፡ ሐምስ፡ [እ]ምድርሳነ፡ ቅዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡<gap reason="omitted"/>ዘተብህለ፡ ለመዝሙር፡ እግዚኦ፡ በመአትከ፡ ኢትቅሥፈኒ፡<gap reason="omitted"/></incipit>
                          </msItem>
                        <msItem xml:id="ms_i1.4.2">
                          <locus from="96v" to="105v" facs="097">Fols 96v–105v</locus>
                          <title>Prayer by Abbot Pachomius‎</title>
                          <incipit xml:lang="gez">ጸሎት፡ ዘአባ፡ ጳኵሚስ፡ እንበይነ፡ ፍጻሜሃ፡ በዛቲ፡ ዕለት፡ ዘዕለተ፡ ዓርብ፡<gap reason="omitted"/>ስብሐት፡ ለአብ፡ ስብሐት፡ ለወልድ፡ ስብሐት፡ ትሀ መንፈስ፡ ቅዱስ፡ ሥላሴ፡ በተዋህዶ፡ ወተዋህዶ፡ በሥላሴ፡<gap reason="omitted"/></incipit>
                        </msItem>
                        </msItem>
                        <msItem xml:id="ms_i1.5">
                          <locus from="106r" to="120v" facs="106">Fols 106r–120v</locus>
                          <title>Saturday prayers</title>
                          <incipit xml:lang="gez">ጸሎት፡ ሳድሲት፡ ዘዕልተ፡ ሰንበተ፡ አይሁድ፡ ዘአስተጋብኣ፡ እማኅሌተ፡ ቅብጢ፡ አቡነ፡ አትናቴዎስ፡ ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ እለ፡ እስክንድርያ፡..ወትብል፡ ከመዝ፡ ኃሠሥኩከ፡ እማዕምቀ፡ ልብየ፡<gap reason="omitted"/></incipit>
                          <note>normal attribution to St Athanasius of Alexandria from Coptic hymns</note>
                        </msItem>
                        <msItem xml:id="ms_i1.6">
                          <locus from="121r" to="135v" facs="121">Fols 121r–135v, </locus>
                          <locus target="#137r #137v #136r #136v" facs="137 138 136 137">137r, 137v, 136r, 136v, </locus>
                          <locus from="138r" to="140r" facs="138">138r–140r</locus>
                          <title>Sunday prayers</title>
                          <incipit xml:lang="gez">ጸሎት፡ ወስእለት፡ ሳብዓይ፡ እንተ፡ ዘዕለተ፡ እሁድ፡ አስተጋብእዋ፡ እምቅዱስ፡ ቄርሎስ፡ እምብዙኅ፡ ስእለታት፡<gap reason="omitted"/>ባርክ፡ እግዚኦ፡ ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አአምን፡ ወእትአመን፡<gap reason="omitted"/></incipit>
                        </msItem>
                        </msItem>
               </msContents>

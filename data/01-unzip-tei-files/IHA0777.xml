               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="8r">1r-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1879IHA">Ḫutba al-Mawlid al-nabawī</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسملة \ الحمد لله الذي شرّفنا وجعلنا من أمّة حبيبه ومصطفاه \ ألذي إعتزّ بعبوديّتهله جل علاه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>ألذي أتقض ظهرك ورفعنا لك ذكرك بارق الله لي ولكم باالقرءن [...] إستغفر الله العظيم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="8v" to="14v">8v-14v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1856IHA">خطبة المولد النبويّ</title>
                     <incipit xml:lang="ar">
                        <locus target="#8v">-8v</locus>ألحمد لله الذي خلق خلقه من ماء مهين فجعله في قرار مكين \ إلى قدر معلوم وإليه المهرب ولديه المطلب ومنه القدر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14v">-14v</locus>ويمنحهم من لدنه توفيقا وسدادا فإنّه سميع قر \ يب يا ربّ العالمين بارك الله لي ولكم باالقرءان العظيم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="15r" to="16v">15r-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1961IHA">خطبة الثانية مولد رسول الأعظم</title>
                     <incipit xml:lang="ar">
                        <locus target="#15r">-15r</locus>ألحمد لله ربّ العالمين وأشهد أن لا إلاه إلّا الله وحده لا شريك له \ وأشهد أن محمد عبده ورسوله أما بعد فيا عباد الله في ذكرى \ مولدك يا رسول الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>وقد جعلتم الله عليكم كفيلا إن الله يعلمها \ ما تفعلون وذكر والله العظيم الجليل يذكركم وشكروه على نعمه يزدكم ولذكر الله أكبر والله يعلم ما تضعون</explicit>
                     <note>f. 16v blank</note>
                     <note/>
                  </msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="114">p. 1-114</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3051IHA">نور البراق في مدح النبي المصداق ويليه النفحات المدنية في
                    مدائح المصطفوية</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 2">-p. 2</locus>النور البراق | بسم الله الرحمن الرحيم | به لأنه عابدا وختما وصلى الله على سيدنا محمد ذاتا وصنفا وسما | قال رضي الله عنه في حرف الألف | يقول عبيد مرغنى سابدا بحمد الهى رب حمدا اويتلؤ لنظم بمدح المصطفى وانبا له الشكر شكرا في الوجود منما </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 114">-p. 114</locus>وانتمو عدتى في كل نازلة ووسيلتى لوظيم وهو رحمان | وانتم كرام الحمى والوقت وقتكم وذا اعتقادى وقد قواه برهان </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v">1r-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3052IHA">علي الأولياء القيت سري وبرهاني</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم وبه نستعين علي الاويا ؟ القيت سري وبرهان فهامقا به من ... | فاسكرهم كاسي فتباقوا بخمرتي سكاري من شهود وعرفاني | فاكنت قبل القبل قطبا مبجلا وطافت بي الأملاك والرب سماني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>فمن رحال الله نال مكانتي وجدي رسول الله في الأصل الرئان | ...الوقت عبد القادر كني محيي الدين والاصل كيلان تمت وعمت
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="1v" to="2r">1v-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0753IHA">قصيدة طف بحالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>طف بحاني سبعا ولذ بذمامي وتجرد لزورتي كل عارم | انا سر الاسرار من سر سري كعبتي راحتي وبسطي مدامي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>انا عبد القادر طاب وقتي جدي المصطفي وحسبي امام | فعليه الصلاة في كل وقت وعلي اله بطول الدوام </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="2r" to="2r">2r-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3053IHA">نظم لي همة</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم | لي همة بعصها نعلوا علي الهمم ولي هوى قبل خلق اللوح والقلم | ولي حبيب بلا كيف ولا مثل ولي مقام ولي ربع ولي حرم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>هدني عصاء اتي فيها مأرب لي وقد اهثى بها يوما ولي غنم | ان القها تتلقف كل ما صنعوا اذا اتيت بسخر من كلامهم تمت وعمت بالخير</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="2v" to="2v">2v-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3054IHA">نظم قلبي الذي في ذاتكم ينقلب</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم قلبي ... علي مقام الهاشمي مهذب فلا جل ذا من كل معني اطرب | ... الاطيب | تاتي لسري اية منصوصة | فرياتى اجنحة بها مقصوصة ما في الجمال ذو ابة مقصوصة او في المكان مكانة مخصوصة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>ما ذلت ارتع في ميادين الرضا حتي وهبت مكانة لا توهب اسموا باسرار لكم مكتوبة | ما بين استار لنا معلومة كم في الوري من حالة موسومة اضحي الزمان كحلة مرقومة | تز [كذا] هو ونحن لها الطراز المذهب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="3r" to="4r">3r-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3056IHA">نظم نظرت بعين الفكر</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسم الله الرحمن الرحيم وبه نستعين نظرت بعين الكفر في حان حضرتي حبيبا ... تجلي للقلوب فنت؟ | سقاني بكاس من مدامة حبه فكان من الساقي خماري وسكرتي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>وجدي رسول الله
 اعني محمدا انا عبد قادر دام عزى ورفعتي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="4r" to="4v">4r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3057IHA">نظم سقاني الحب</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>بسم الله الرحمن الرحيم | سقاني الحب كاسات الوصال فقلت لخمرتي فحوى تعالي | سعت ومشيت النحوي في كؤوس فهمت بسكرتي بين الموالي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>وكل ولي له قدم واني علي قدم النبي بدر الكمال | انا الجيلى محيي الدين اسمي واعلامي علي روس الذبال</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="5r" to="6v">5r-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3058IHA">نظم سقاني ربي</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>بسم الله الرحمن الرحيم شهدت بالله ولي الولاية قد من بالتصريف في كل حاله | سقاني ربي كؤس شرابه واسكرني حقا فهمت بسكرتي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>ومن كان يخشع ي الصلاة توضعا مع الله ... جميع البرية | فجدي رسول الله طه محمد انا عبد القادر شيخ كل طريقة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="6v" to="6v">6v-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3059IHA">نظم سقاني حبيبي من شراب ذوي المجد</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus>سقاني حبيبي من شراب ذوي المجد فاسكر في حقا فغبت علي وجد | واجلسني في قاب قوسين سيدي علي منبر التخصيص في حسن مقعد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>فان شئت ان تحظي ... قربة فدوام علي حبي وحافظ على عهدي | تمت وعمت بالخير</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

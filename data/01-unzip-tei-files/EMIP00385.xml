         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Weiner Art Scroll </repository>
                  <collection>EMIP</collection>
                  <idno n="16" facs="EMIP/Codices/385/" corresp="https://betamasaheft.eu/api/iiif/EMIP00385/manifest">Weiner Art Scroll 1</idno>
               </msIdentifier>
               <msContents>
                  <summary>Art Scroll produced for the tourist industry with icons of Saint George and the Dragon, Madonna and Child, the Martyrdom of Saint George, the beating of Jesus, Jesus with his cross, the Crucifixion, the removal and burial of Jesus' Body, the resurrection of Jesus and raising Adam and Eve</summary>
                  <msItem xml:id="ms_i1">
                     <textLang/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Scroll">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">8 panels</measure>
                           <dimensions type="outer" unit="mm">
                              <height>437</height>
                              <width>3080</width>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#Panel 1" facs="001">Fols. Panel, </locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> with caption <q>“How Saint George, arch martyr, killed the dragon,” “Maiden Birtawit,” “unclean spirit,” “dragon.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#Panel 2" facs="001">Fols. Panel, </locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two guardian angels behind and two patrons prostrate before them. With caption <q>“Saint Mika’el,” “With her beloved Son,” “Saint Gabri’el,” “How Ǝfanikos[?],” “How Ǝsṭǝfanos interceded.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#Panel 3" facs="002">Fols. Panel, </locus><desc>Matyrdom of Saint George with caption <q>“How Saint George, the arch martyr, was beheaded,” “How. . .[incomplete]”, “Our Lord,” “the Angel Saint Mika’el,”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#Panel 4" facs="003">Fols. Panel, </locus><desc>Matyrdom of Saint George with caption <q>“How the Jews beat and whipped Saint George, the arch martyr, in the fire,” “How righteous Ǝsṭǝfanos interceded.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#Panel 5" facs="004">Fols. Panel, </locus><desc>How the Jews scourged our Lord with caption <q>“How the Jews scourged our Lord,” “Bärban [Barabas, the one released by Pilate],” “Jews.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#Panel 6" facs="005">Fols. Panel, </locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1065RoadtoCalvary">Road to Calvary</ref>“How the Jews made our Lord carry the cross,” “Disciples,” Jews,” “Peter,” “Malkos.”</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#Panel 7" facs="006">Fols. Panel, </locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>“Linginos,” “How Our Lady wept,” “How John, beloved of our Lord, wept,” “Barabas, owner of the vinegar.”</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#Panel 8" facs="007"> Panel 8, left</locus><desc>Taking down the body of Jesus with caption <q>“How Joseph and Nicodemus removed Our Lord from the cross,” “Our Lady [abbreviated],” “John [abbreviated].”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#Panel 8" facs="007"> Panel 8, upper right</locus><desc>“How Joseph and Nicodemus prepared Our Lord for burial.”</desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#Panel 8" facs="007"> Panel 8, middle right</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1112JesusBurial"><span xmlns="" class="w3-tag w3-red">No item: AT1112JesusBurial</span></ref>“How Joseph and Nicodemus buried Our Lord.”</desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#Panel 8" facs="007"> Panel 8, lower right</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising Adam and Eve. “How Our Lord rose from the tomb,” “Adam,” “Eve.”</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Ornate borders surround each panel
                    </desc>
                    </item>
                  </list>
                </additions>

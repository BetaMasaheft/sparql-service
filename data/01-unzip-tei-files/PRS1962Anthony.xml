         <listPerson>
            <person sex="1" sameAs="wd:Q170547">
               <persName xml:lang="gez" xml:id="n1" type="birth">እንጦንስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾƎnṭonǝs</persName>
               <persName xml:lang="en" corresp="#n1" type="main">Antony</persName>
               <persName xml:lang="en" xml:id="n2">Anthony (the Great)</persName>
               
               <persName xml:lang="gez" xml:id="n3" type="birth">እንጦንዮስ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">ʾƎnṭonyos</persName>
               <persName xml:lang="grc" corresp="#n3">Ἀντώνιος</persName>
               <persName xml:lang="gez" xml:id="n4" type="birth">እንጦኒ፡</persName>
               <persName xml:lang="gez" corresp="#n4" type="normalized">ʾƎnṭoni</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Egypt"/>
                  <faith type="Coptic"/>

                  <birth when="0251"/>
                  <residence/>
                  
               <floruit>"Father of all monks", he is considered to have been the founder of monasticism,
                  born from Christian parents in <placeName ref="https://betamasaheft.eu/LOC5219Qimana">Qimān al-ʿArūs</placeName>.  
                  At the age of 20,  he started to practice ascetic life. 
                  He was an ardent supporter of <persName ref="https://betamasaheft.eu/PRS2209Athanasi">Athanasius</persName> 
                  in his fight against Arianism. 
                  He is highly respected in the monasticism tradition of <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</placeName>. 
                  The monastic houses of both <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymanot</persName> and <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</persName>
                  trace themselves back to Anthony.</floruit>
                 <death when="0356"/>
               <note type="commemoration"><date type="diesNatalis" ref="ethiocal:Terr22">22 ṭǝrr</date></note>
               </person>
               
         </listPerson>
         
         

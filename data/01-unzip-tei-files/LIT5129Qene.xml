        <t:body>
            <t:div type="bibliography">
                
            </t:div>
            <t:div type="edition">
                <t:div type="textpart" xml:lang="gez">
                    <t:note>The text follows the description of <t:ref type="mss" corresp="https://betamasaheft.eu/IVEf45">Saint Petersburg, Institut Vostočnyh Rukopisej Rossijskoj Akademii Nauk, IV Ef. 45</t:ref> in <t:bibl corresp="http://zotero.org/groups/358366/items/T6UTP6JE"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Turaev1906rukopisi"/><title level="m">Ėfiopskija rukopisi v S.-Peterburgě</title><title level="s">Pamjatniki ėfiopskoj pis'mennosti</title><author><forename>Boris</forename><surname>Turaev</surname></author><pubPlace>St Petersburg</pubPlace><publisher>Tipografija imperatorskoj Akademii Nauk</publisher><date>1906</date><series><title level="s">Pamjatniki ėfiopskoj pis'mennosti</title><biblScope unit="volume">3</biblScope></series><biblScope unit="volume">3</biblScope><note type="url">http://digitale-sammlungen.ulb.uni-bonn.de/content/titleinfo/2104581</note><note type="tags"><note type="tag">Manuscripts</note><note type="tag">Cataloguing</note><note type="tag">bm:Turaev1906rukopisi</note></note><note type="tag">Manuscripts</note><note type="tag">Cataloguing</note><note type="tag">bm:Turaev1906rukopisi</note><t:citedRange unit="page">130</t:citedRange></t:bibl>.</t:note>                   
              <t:ab>
                  <t:l n="1">በምጽአተ፡ ክርስቶስ፡ ስንቃዊ፡</t:l>
                  <t:l n="2">በከናፍረ፡ ብእሲት፡ ዘማ፡ ወበመሥገርትየ፡ አፈ፡ ነዓዊ፡</t:l>
                  <t:l n="3">ኦካህን፡ ትምክህተ፡ ቤቱ፡ ለሌዊ፡</t:l>
                  <t:l n="4">ለምንት፡ ሞትከ፡ እምትሙት፡ ዘማዊ።</t:l>
              </t:ab>
                </t:div>
                
                <t:div type="translation" xml:lang="en" xml:id="translationEthio" corresp="https://betamasaheft.eu/LIT5129Qene#etiopica">                    
                        <t:ab>
                            <t:l n="1">Through the advent of Christ, the musician,</t:l>
                            <t:l n="2">Through the lips of a lady, the adulteress, and through my trap, the mouth of the hunter,</t:l>
                            <t:l n="3">Oh priest, glory of the house of Levi,</t:l>
                            <t:l n="4">You the adulterer, why (does) your death (come) before she would die?</t:l>
                        </t:ab>
                </t:div>
            </t:div>
        </t:body>

                        <additions>
                            <list> 
                                
                                <item xml:id="a1">
                                    <locus target="#46v"/>
                                    <desc type="OwnershipNote">
                                        A note giving the name of one  <persName role="donor" ref="https://betamasaheft.eu/PRS11650MahtamaKrestos">Māḫtama Krǝstos</persName>,
                                        who bought this manuscript for a church of <persName ref="https://betamasaheft.eu/PRS7049Michael">St Michael</persName>.
                                    </desc>
                                    <q xml:lang="gez">ዝመጽሐፍ፡ <persName ref="https://betamasaheft.eu/PRS11650MahtamaKrestos">ዘማኅተመ፡ ክርስቶስ።</persName> ዘአጥረዮ፡ በነዋዩ፡ 
                                        ለ<persName ref="https://betamasaheft.eu/PRS7049Michael">ታበተ፡ ሚካኤል።</persName>
                           </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#147v"/>
                                    <desc type="OwnershipNote">
                                        A note, in the same hand as the manuscript, stating that it belonged to one 
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS11651TaklaGiyorgis">Takla Giyorgis</persName>.
                                        
                                    </desc>
                                    <q xml:lang="gez">ለዝንቱ  መጽሐፈ፡ ወንጌል፡ ቅዱስ፡ ዘአጥረዮ፡ በንዋዩ፡ <persName ref="https://betamasaheft.eu/PRS11651TaklaGiyorgis">ተክለ፡ ጊዮርጊስ፡</persName> ከመ፡ ይኲኖ፡ ተዝካረ፡ 
                                        በዕለተ፡ ክርስቶስ፡ ይጽሐፍ፡ ስሞ፡ ውስተ፡ መጽሐፈ፡ ሕይወት፡ ዘኢይደመሰስ፡ በከመ፡ ጸሐፈ፡ ዮሐንስ፡ ስመ፡ ረድኡ፡ አብሮኮሮስ፡ 
                                        እግዚአብሔር፡ ንጉሥ፡ ወይክፍሎ፡ ኃዲረ፡ ውስት፡ መካነ፡ ዛሕን፡ ወመርስ፡ አሜን። etc.</q>
                                </item>           
                            
                                <item xml:id="a3">
                                    <locus target="#147v"/>
                                    <desc type="OwnershipNote">
                                        Subsequently the ms belonged to one <persName role="owner" ref="https://betamasaheft.eu/PRS11652Matewos">Mātewos</persName> and his son   
                                         
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS11653KenfaM">
                                 <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾabbā</t:roleName> Kǝnfa Mikāʾel</persName>.
                                        
                                    </desc>
                                    <q xml:lang="gez">ዝመጽሐፍ፡ ዘማቴዎስ፡ ወለውሉዱ፡ አባ፡ ክንፈ፡ ሚካኤል። </q>
                                </item>
                                
                                
                                <item xml:id="a4">
                                    <locus target="#148r"/>
                                    <desc type="PoemSalam">
                                        Salām to various saints, in an old hand.
                                    </desc>
                                    <q xml:lang="gez">ሰላም፡ ለዮሐንስ፡ ዘይሴሰይ፡ አሕማላተ።  ...</q>
                                </item>
                                
                                <item xml:id="a5">
                                    <locus target="#148v"/>
                                    <desc type="Genealogy">
                                        A genealogy, <q xml:lang="gez">መጽሐፈ፡ ልደቱ፡ ለእነማይ፡  ...</q>, 
                                        ending with the name of the writer, <persName role="author" ref="https://betamasaheft.eu/PRS11654EsbaGiyorgis">ʿƎsba Giyorgis</persName>, 
                                        followed by a continuation, <q xml:lang="gez">መጽሐፈ፡ ልደቱ፡ ለ፬ልጀ፡ (sic) እነማይ  ...</q>.
                                    </desc>
                                    
                                </item>
                                
                                <item xml:id="a6">
                                    <locus target="#149r"/>
                                    <desc type="Genealogy">
                                        Another genealogy, <q xml:lang="gez">ወበዋተይሂ፡ መጽሐፈ፡ ልደቱ፡ ለነመራጌ፡  ...</q>, 
                                        ending with the name of the writer, <persName role="author" ref="https://betamasaheft.eu/PRS11655WakaDengel">Wākā Dǝngǝl</persName>, ዋካ፡ ድንግል።
                                    </desc>
                                    
                                </item>
                                
                                
                                <item xml:id="a7">
                                    <locus target="#149r"/>
                                    <desc type="GuestText">
                                        An extract from a homily (dǝrsān) on the holy Eucharist (qʷǝrbān) and on the last hours of our Lord.
                                    </desc>
                                    
                                </item>
                                
                            </list>
                        </additions>
                        
                        <bindingDesc>
                            <binding contemporary="partly" xml:id="binding">
                                <decoNote xml:id="b1" type="Boards">Two wooden boards.</decoNote> 
                                <decoNote xml:id="b2" type="Cover">Blind-tooled leather <term key="quarterCover" ana="#quarterCover">quarter cover</term>
                                    (with the gilded title and shelfmark on the spine).</decoNote> 
                                <decoNote xml:id="b3" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                </decoNote>
                                <decoNote xml:id="b4" type="SewingStations">4</decoNote> 
                                <decoNote xml:id="b5" type="SewingStations">Sewing stations are used in an irregular way.</decoNote> 
                                <decoNote xml:id="b6">The manuscript has probably been rebound in the library. Possibly both wooden boards have been replaced, 
                                    and a blind-tooled leather cover added.</decoNote>
                            </binding>
                        </bindingDesc>
                        
                        

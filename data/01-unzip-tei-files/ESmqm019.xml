                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Crude, but careful.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>19th century.</date>
                        <seg type="rubrication">Holy names; incipit of Texts I; titles of books to
                           be read; elements of the punctuation signs; elements of Ethiopic
                           numerals. 
 On the incipit page of Text I (fol. 3r), a few lines are
                           rubricated (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2v">f. 2v</locus>
                           <desc type="GuestText">: Unidentified prayer.</desc>
                           <q xml:lang="gez"/>
                           
                           <note> The text is hardly readable, the folio is affected by humidity.
                           </note>
                        </item>
                        <item xml:id="e1">- Note crudely written in a secondary hand: <locus target="#22v">22v</locus>.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">- Names of the days of the week written in the upper
                              margin in the main hand of some fols. indicate readings for Text I:
                              ዘዘወትር: <locus target="#3r">fol. 3r</locus>. ዘቀዳሚት: <locus target="#8v">fol. 8v</locus>. ዘሰንበት: <locus target="#12r">fol. 12r</locus>.
                              ዘዘወትር: <locus target="#20v">fol. 20v</locus>. - Names of the feasts
                              written in the upper margin in the main hand of some fols. indicate
                              readings for Text I: ዘሰማዕት: <locus target="#20r">fol. 20r</locus>.
                              ዘመላእክት: <locus target="#21r">fol. 21r</locus>.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>

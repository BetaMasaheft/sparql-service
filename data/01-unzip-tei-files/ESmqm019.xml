                        <extent>Made of <measure unit="leaf">22.0</measure> folios, of which
                              <measure unit="leaf" type="blank"/> blank <locus target="#1r">1r-</locus>v, 2v, 22r., in <measure unit="quire">3.0</measure> quires
                           (A+2). <dimensions type="outer">
                              <height unit="mm">145</height>
                              <width unit="mm">100</width>
                              <depth unit="mm">15</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">2</dim>

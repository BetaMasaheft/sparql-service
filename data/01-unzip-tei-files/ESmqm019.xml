                              <dim type="bottom">30</dim>
                              <dim type="right">7</dim>
                              <dim type="left">6</dim>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <note>All data for <locus target="#4r">4r</locus>.</note>

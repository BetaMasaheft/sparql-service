                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#1r"/>
                                    <desc type="GuestText">Prayer about the paten (<q xml:lang="gez">ጻሕል፡</q>), each written by the same hand as 
                                        <ref target="#a2 #a3 #a4 #a5">additiones a2, a3, a4 and a5</ref>.</desc>        
                                </item>
                                <item xml:id="a2">
                                    <locus from="1r"/>
                                    <desc type="GuestText">Prayer about the chalice, written by the same hand as 
                                        <ref target="#a1 #a3 #a4 #a5">additiones a1, a3, a4 and a5</ref>.</desc>
                                    <q xml:lang="gez">ጸሎት፡ በእንተ፡ ጽዋዕ፡</q>
                                </item>
                                <item xml:id="a3">
                                    <locus target="#2r"/>
                                    <desc type="GuestText">Prayer about the bread-basket, written by the same hand as 
                                        <ref target="#a1 #a2 #a4 #a5">additiones a1, a2, a4 and a5</ref>.</desc>
                                    <q xml:lang="gez">ጸሎት፡ በእንተ፡ መሶብ፡</q>
                                </item>
                                <item xml:id="a4">
                                    <locus from="2r" to="2v"/><locus target="#135r"/>
                                    <desc type="GuestText">Prayer about the Eucharist, written by the same hand as 
                                        <ref target="#a1 #a2 #a3 #a5">additiones a1, a2, a3 and a5</ref>.</desc>
                                    <q xml:lang="gez">ይንሣዕ፡ ካህን፡ ቁርባን፡ በንጹሕ፡ እዴሁ። <gap reason="ellipsis"/> ዝንቱ፡ ኅብዝት፡ ይኵን፡ ለስርየተ፡ ኃጢአት፡ 
                                        <gap reason="ellipsis"/> ከማሁ፡ ረስዮ፡ ለዝንቱ፡ ወይን፡ <gap reason="ellipsis"/></q>
                                </item>
                                <item xml:id="a5">
                                    <locus target="#1r"/>
                                    <desc type="GuestText">Prayer about the incense (<q xml:lang="gez">ዕጣን፡</q>), written by the same hand as 
                                        <ref target="#a1 #a2 #a3 #a4">additiones a1, a2, a3 and a4</ref>.</desc>        
                                </item>
                                <item xml:id="a6">
                                    <locus target="#118r"/>
                                    <desc type="GuestText"><ref type="work" corresp="https://betamasaheft.eu/LIT6011FeastsList">A short calendar for the commemoration of 
                                        saints</ref>, written by the same hand as <ref target="#e1">additio e1</ref>.</desc>
                                    <q xml:lang="gez">ሠረቀ፡ መስከረም፡ አመ፩በርተለሎሜዎስ፡ ሠረቀ፡ ጥቅምት፡ አመ፡ ፳ወ፪ሉቃስ፡ </q>
                                </item>
                                <item xml:id="e1">
                                    <locus target="#118r"/>
                                    <desc type="Condemnation">Anathema against any who would steal the manuscript or erase it, written by the same 
                                        hand as <ref target="#a6">additio a6</ref>.The name of the owner was erased.</desc>
                                    <q xml:lang="gez">ዝንቱ፡ መጽሐፍ፡ <gap reason="lost"/> ውጉዘ፡ ለይኩን፡ ዘሠረቆ፡ ወዘፈሐቆ። </q>
                                </item>
                                <item xml:id="e2">
                                    <locus target="#135v"/>
                                    <desc type="AcquisitionNote"/>
                                    <q>Presented by Mrs. <persName role="bequeather" ref="https://betamasaheft.eu/PRS14367Harty">D'Harty</persName> 
                                        <date when="1922-02-11">11 Feb. 1922</date></q>
                                </item>
                            </list>
                        </additions>

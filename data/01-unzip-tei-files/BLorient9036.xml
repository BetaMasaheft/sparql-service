                                <msItem xml:id="ms_i1.2.2.1">
                                    <title ref="https://betamasaheft.eu/LIT2362Songof#FirstCanticle">Song of Songs: First Canticle (Song 1:1 - 2:7)</title>
                                    <note>Title missing</note>
                                </msItem>
                                <msItem xml:id="ms_i1.2.2.2">
                                    <title ref="https://betamasaheft.eu/LIT2362Songof#SecondCanticle">Song of Songs: Second Canticle (Song 2:8 - 3:5)</title>
                                    <incipit xml:lang="gez">ካልዕ፡ ማኅልይ፡ ዘይዜኑ፡ ልደቶ፡ ለዋህድ።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2.2.3">
                                    <title ref="https://betamasaheft.eu/LIT2362Songof#ThirdCanticle">Song of Songs: Third Canticle (Song 3:6 - 5:8)</title>
                                    <incipit xml:lang="gez">ሳልስ፡ መኀልይ፡ ዘይነግር፡ ዕርገተ፡ ትስብእት፡ ምስለ፡ መላእክት፡ ድኅረ፡ ፩ከዊን።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2.2.4">
                                    <title ref="https://betamasaheft.eu/LIT2362Songof#FourthCanticle">Song of Songs: Fourth Canticle (Song 5:9 - 8:4)</title>
                                    <incipit xml:lang="gez">ራብዕ፡ ዘይነግር፡ ውዳሴ፡ መርዓት፡ ለመርዓዊሃ።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.2.2.5">
                                    <title ref="https://betamasaheft.eu/LIT2362Songof#FifthCanticle">Song of Songs: Fifth Canticle (Song 8:5 - 14)</title>
                                    <incipit xml:lang="gez">እምዚአሃ፡ ዘዚአሃ፡ ለቤተ፡ ክርስቲያን።</incipit>
                                </msItem>
                            </msItem>
                        </msItem>

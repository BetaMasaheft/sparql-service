                    <history>
                        <origin>
                          The manuscript was copied for king <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>. The production
                          of this manuscript seems to be related to the production of manuscript
                          <ref type="mss" corresp="https://betamasaheft.eu/BLorient602">London, British Library, BL Oriental 602</ref> and <ref type="mss" corresp="https://betamasaheft.eu/BLorient603">London, British Library, BL Oriental 603</ref>.
                            <origDate notBefore="1730" notAfter="1755" evidence="reign"/>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area,
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.
                          The manuscript was then sent to the Royal Library at Windsor and 
                          presented by <persName ref="https://betamasaheft.eu/PRS9745Victoria">Victoria II</persName> to the <placeName ref="https://betamasaheft.eu/INS00001BL">British Library</placeName> on the <date>21st January 1869</date>.
                          <listBibl type="secondary">
                            <bibl corresp="http://zotero.org/groups/358366/items/MIFKZCUN"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Wright1877BM"/><title level="m">Catalogue of the Ethiopic Manuscripts in the British Museum Acquired since the Year 1847</title><author><forename>William</forename><surname>Wright</surname></author><pubPlace>London</pubPlace><publisher>Gilbert and Rivington</publisher><date>1877</date><note type="url">https://archive.org/details/catalogueofethio00brituoft</note><note type="tags"><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note></note><note type="tag">bm:Wright1877BM</note><note type="tag">British Museum</note><note type="tag">Cataloguing</note><note type="tag">Ethiopic</note><citedRange unit="page">iv</citedRange></bibl>
                          </listBibl></provenance>

                    </history>


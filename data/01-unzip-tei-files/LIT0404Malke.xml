      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘእምቅድመ፡ ዓለም፡ ኅሩይ፨</l>
                  <l n="2">ወለሥዕርትክሙ፡ ሰላም፡ በቅብአ፡ ሃይማኖት፡ ሲሩይ፨</l>
                  <l n="3">አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ ምስካይ፨</l>
                  <l n="4">ዘተውህበክሙ፡ በረከተ፡ ሰማይ፨</l>
                  <l n="5">ሲሳየ፡ ዕለት፡ ሀቡኒ፡ ለብእሲ፡ ነዳይ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለርእስክሙ፡ አናብስት፡ ልዑል፨</l>
                  <l n="2">ለገጽክሙ፡ ከመ፡ ገጸ፡ ፀሓይ፡ ጽዱል፨</l>
                  <l n="3">አብርሃም፡ መቅደስ፡ ወያዕቆብ፡ መስቀል፨</l>
                  <l n="4">ወያዕቆብ፡ ዕንቈ፡ ኅሬ፡ ውእቱ፡ ዝንቱ፡ እስራኤል፨</l>
                  <l n="5">ኮል፡ ዘጸገየ፡ በገዳመ፡ ሐቅል፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ እብል፡ ለአእጽምቲክሙ፡ ዝርው፨</l>
                  <l n="2">ማእከለ፡ ተኵላት፡ ወአኅርው፨</l>
                  <l n="3">አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ በበድው፨</l>
                  <l n="4">በክብረ፡ ሥጋክሙ፡ ኅሩያን፡ ዕደው፨</l>
                  <l n="5">አማሐፅን፡ ነፍስየ፡ ወሥጋየ፡ ድልው፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ኦማርያም፡ ለአብርሃም፡ ሃይማኖቱ፨</l>
                  <l n="2">ወለይስሐቅ፡ ኪዳነ፡ ምሕረቱ</l>
                  <l n="3">ወለያዕቆብ፡ ዕንቈ፡ ኅሬ፡ ዘኮንኪ፡ ሠርጐ፡ ትርሲቱ፨</l>
                  <l n="4">ኢትመንንኒ፡ ወኢትኅድግኒ፡ በእንተ፡ አበሳየ፡ ዝንቱ፨</l>
                  <l n="5">አኮኑ፡ ወልድኪ፡ መሓሪ፡ ውእቱ፨</l>
               </lg>
            </div>
         </div>
      </body>

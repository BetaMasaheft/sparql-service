                     <summary/>

                     <msItem xml:id="p2_i1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT2886RepCh167">Malkəʾa Mikāʾel</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                           <lb/>እኁዛነ፡ አርማ<supplied reason="undefined" resp="PRS10747Zotenbe">ሕ፡</supplied> ወማእፀድ። <lb/> ማኅበረ፡ ሚካኤል፡ ተስዓ፡ ወትስዐቱ፡ ነገድ። </incipit>
                        <note>This <foreign xml:lang="gez">salām</foreign> has 56 stanzas, the
                           following is the first. <foreign xml:lang="gez">
                              <lb/>ሰላም፡ ለዝክረ፡ ስምከ፡ ዘጥቀ፡ ተሞገሰ። <lb/>እስከ፡ በኀይላት፡ ከብረ፡ ወበሊቃናት፡ ረአሰ።
                              <lb/>ጊዜ፡ ተከዝኩ፡ ትካዘ፡ ወጊዜ፡ ኀጣዕኩ፡ ፈውሰ። <lb/>ቅድመ፡ ስዕልከ፡ ሚካኤል፡ ሶበ፡ እትመሀለል፡
                              አንሰ። <lb/>እንዘ፡ ትብል፡ ነየ፡ ንበበኒ፡ ሥልሰ።</foreign>
                        </note>
                     </msItem>

                     <msItem xml:id="p2_i2">
                        <title type="complete">Names and magic formulas</title>
                        
                        <textLang mainLang="gez"/>
                        <msItem xml:id="p2_i2.1">
                           <title>First Part</title>
                           <incipit xml:lang="gez"> በአስማተ፡ ሥላሴ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ፩፡ አምላክ፡ ጸ፡ ጸ፡
                              ይምናግኤል፡ ስሙ፡ ለጻባኦት።</incipit>
                        </msItem>

                        <msItem xml:id="p2_i2.2">
                           <title>Second Part</title>
                           <incipit xml:lang="gez"> አስማት፡ በእንተ፡ አንብቦ፡ መጻሕፍት፡ ጰለከዲም፡ ጰለሜና፡ ጰለሲም፡ በፄወ፡
                              መለኮትከ፡ ልስሐተ፡ ልሳንየ፡ ቅስም፡ ፐአፒሮስ፡ ፒፒሮስ፡ ፒዖስ፡</incipit>
                        </msItem>

                        <msItem xml:id="p2_i2.3">
                           <title>Third Part</title>
                           <incipit xml:lang="gez"> ሳአዳአር፡ ሰርአዮአ፡ ንእዶ፡ አደሰርአ፡</incipit>
                        </msItem>
                     </msItem>



                            <bibl corresp="http://zotero.org/groups/358366/items/W7HE9FNZ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1929Evangeliska"/><title level="a">Die abessinischen Handschriften der Evangeliska Fosterlands-Stiftelsen, Stockholm</title><title level="j">Le Monde Oriental</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><date>1929</date><biblScope unit="volume">23</biblScope><biblScope unit="page">1-22</biblScope><citedRange unit="page">20</citedRange><citedRange unit="number">Nachtrag 7</citedRange></bibl> based on information provided by 

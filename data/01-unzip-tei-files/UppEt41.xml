                            <bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">130</citedRange></bibl> 

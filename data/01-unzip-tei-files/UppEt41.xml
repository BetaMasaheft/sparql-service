                    <msContents>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="6ra" to="164ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3190Tergwam">Tǝrgʷāme Mātewos</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                <hi rend="rubric">በስመ፡ እግዚአብሔር፡ ሕያው፡ ቀ</hi>ዳማዊ፡ 
                                ዘሀሎ፡ ወይሄሉ፡ እምቅድመ፡ <hi rend="rubric">ዓለም፡ ወይሄሉ፡ እስከ፡ ለዓለመ፡</hi>
                                ዓለም<hi rend="rubric" rendition="#partialRubric">፨</hi> 
                                ን<choice><sic cert="high">ዌ</sic><corr>ወ</corr></choice>ጥን፡ እንከ፡ 
                                በጽሒፈ፡ <hi rend="rubric">መጽሐ<del rend="erasure" unit="chars" quantity="1"/>፡ ዘውእቱ፡ 
                                    ብስራተ፡ ማ</hi>ቴዎስ፡ ሐዋርያ፡ ወንጌላዊ፡ ሣህሉ፡ ወምሕረቱ፡ ወረድኤተ፡ አምላኩ፡ የሀሉ፡ 
                                ምስለ፡ ፍቁሩ፡ <hi rend="rubric"><del rend="erasure" unit="chars" quantity="1"/><unclear>ዕ</unclear>ለ፡ 
                                    <unclear>ክ</unclear><del rend="erasure" unit="chars" quantity="1"/>ስ<del rend="erasure" unit="chars" quantity="1"/>ስ።</hi><lb/>
                                <hi rend="rubric">መጽሐፈ፡ ልደቱ፡ ለኢየሱስ፡ ክርስቶስ። ይቤ፡ መተርጕም፡ እ</hi>ስመ፡ 
                                ይትኃሠሡ፡ መፈክራን፡ በእንተ፡ ዝንቱ፡ ክፍል፡ ተኃሥሦተ፡ ብዙኃ<hi rend="rubric" rendition="#partialRubric">፨</hi> 
                                ወምክንያቱሰ፡ ለቀዳማዊ፡ ዘበእንቲአሃ፡ ኢጸሐፈ፡ ማቴዎ<sic resp="JK">ሰ</sic>፡ በከመ፡ ልማደ፡ 
                                ነቢያት<hi rend="rubric" rendition="#partialRubric">፨</hi>
                                ወካልአኒሆሙ፡ እለ፡ ቀደምዎ፡ በእንተ፡ ቃላት፡ ዘተናገረ፡ እንዘ፡ ያስተላፅቆ፡ ኀበ፡ እግዚአብሔር፡ ወይብል፡ 
                                ይቤለኒ፡ እግዚአብሔር<hi rend="rubric" rendition="#partialRubric">፨</hi>
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="166ra" to="218vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3193Tergwam">Tǝrgʷāme Yoḥannǝs</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                <hi rend="rubric">በስመ፡ እግዚአብሔር፡ ፈጣሪ፡ ሕያው፡</hi> 
                                ቀዳማዊ፡ ዘሀሎ፡ ወይሄሉ፡ እስከ፡ ለዓለ<hi rend="rubric">ም። ንወጥን፡ እንከ፡ ብስራተ፡ ዮሐንስ፡</hi> 
                                ሐዋርያ፡ ፍጻሜ፡ ብስራት፡ ክቡር፡ ነባ<hi rend="rubric">ቤ፡ መለኮት። ይቤ፡ ሐዋርያ፡ እምቀዳሚ፡</hi> 
                                ኮነ፡ ቃል፡ ህልወ<hi rend="rubric" rendition="#partialRubric">፨</hi> 
                                <hi rend="rubric">ይቤ፡ መተርጕም፡</hi> እስመ፡ ይትኃሠሡ፡ መተርጕማን፡ በዝንቱ፡ ክፍል፡ 
                                ተኃሥሦተ፡ ብዙኃ<hi rend="rubric" rendition="#partialRubric">፨</hi> ቀዳሚሁሰ፡ እስመ፡ 
                                ምክንያት<hi rend="rubric" rendition="#partialRubric">፨</hi> ዘበእንቲአሃ፡ ኢተናገረ፡ 
                                ባቲ፡ ዮሐንስ፡ በከመ፡ ልማደ፡ ማቴዎስ፡ ወሉቃስ፡ በእንተ፡ ዜንዎ፡ ልደቱ፡ ለእግዚእነ፡ መድኅነ፡ 
                                ኵሉ<hi rend="rubric" rendition="#partialRubric">፨</hi> 
                            </incipit>
                        </msItem>
                        
                    </msContents>
                    

                        <additions>
                            <list>
                                
                                <item xml:id="a1">
                                    <locus from="1ra" to="5vc"/>
                                    <locus from="218vc" to="219rb"/>
                                    <desc type="GuestText">
                                        <title type="complete" ref="https://betamasaheft.eu/LIT7124Theology">Theological treatise on the nature of God</title>
                                    </desc>
                                    <q xml:lang="gez">አንቀጽ፡ ሣልስ፡ በእንተ፡ ሀልዎተ፡ ፈጣሪ፡ ልዑል፡ ወነገሩ፡ እምቅድመ፡ ተዋሕዶ፡ 
                                        ወውእቱ፡ በዝየ፡ ፫፡ ክፍላተ። <gap reason="omitted"/> ቀዳሚ፡ እስመ፡ ጥያቄሁ፡ 

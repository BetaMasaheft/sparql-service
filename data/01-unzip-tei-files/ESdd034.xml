                           <q xml:lang="en">This book is of <persName role="owner" ref="https://betamasaheft.eu/PRS14663Yehdago"><t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾabeto </t:roleName> Yǝḥdago</persName>.</q>

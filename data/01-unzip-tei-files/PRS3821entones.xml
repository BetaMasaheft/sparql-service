      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="monastic">እንጦንስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾƎnṭonǝs</persName>
                  <persName xml:lang="gez" xml:id="n2" type="birth">አመንኩ፡ እግዚእ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAmanku ʾƎgziʾ</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">abbot</occupation>
               <birth> He was born in <placeName ref="https://betamasaheft.eu/LOC5575Saraye">Sarāye</placeName>
               </birth>
               <residence> 
                  <placeName ref="https://betamasaheft.eu/LOC2388DabraT">Dabra Tambuk</placeName>
               </residence>
               <floruit> He was a monk of the 14th century and was consecrated as
                  a deacon by 
                  <persName ref="https://betamasaheft.eu/PRS10200Yaeqob">
                     <roleName type="title">ʾabuna</roleName> 
                     Yāʿqob</persName>. 
                  He became a monk after the soldiers abducted his wife. 
                  He took the monastic habit from 
                  <persName ref="https://betamasaheft.eu/PRS5635Iyesanan">
                     <roleName type="title">ʾabbā</roleName> 
                     ʾIyǝsanano ʾƎgziʾ</persName>. He was the spiritual father of <persName ref="https://betamasaheft.eu/PRS8483Samuel">Sāmuʾel of Dabra Halleluyā</persName>.
               </floruit>
               <death> He died during the reign of King <persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</persName>
               </death>
               </person>  
               
         </listPerson>
    

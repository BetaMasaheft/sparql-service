                  <summary>Missal, መጽሐፈ፡ ቅዳሴ፡</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="1v" facs="001">Fols 1r–1v, </locus><locus from="38r" to="42r" facs="038">38r–42r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

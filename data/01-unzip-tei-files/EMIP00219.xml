                            </item>
                              <item xml:id="q2" n="2">
                                 <dim unit="leaf">10</dim>
                                 <locus from="3" to="12" facs="003">Fols 3–12</locus>
                              Quire 2
                            </item>
                              <item xml:id="q3" n="3">
                                 <dim unit="leaf">10</dim>
                                 <locus from="13" to="22" facs="013">Fols 13–22</locus>
                              Quire 3
                            </item>
                              <item xml:id="q4" n="4">
                                 <dim unit="leaf">10</dim>
                                 <locus from="23" to="32" facs="023">Fols 23–32</locus>
                              Quire 4
                            </item>
                              <item xml:id="q5" n="5">
                                 <dim unit="leaf">5</dim>
                                 <locus from="33" to="37" facs="033">Fols 33–37</locus>
                                 <note>
                                    <locus target="#33" facs="033">Fols. 33, </locus> is a single folio attached to <locus target="#46" facs="046">46</locus>. Approximately two-thirds of f. 46 has been torn off, and only the top one-third remains extant.</note>
                              Quire 5:
                              1 added
                            </item>
                              <item xml:id="q6" n="6">
                                 <dim unit="leaf">9</dim>
                                 <locus from="38" to="46" facs="038">Fols 38–46</locus>

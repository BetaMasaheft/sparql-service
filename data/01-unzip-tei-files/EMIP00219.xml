                  <handDesc><handNote xml:id="h1" script="Ethiopic">
                    <seg type="rubrication">
                      <foreign xml:lang="gez">ማርያም፡</foreign></seg>
                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#28r #32r #35v #42r" facs="028 032 036 042">fols. 28r, 32r, 35v, 42r</locus> (multiple full stops).
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1">
                        <desc>Not well-preserved</desc>
                      </item>
                      <item xml:id="a1">
                        <desc>
                          <locus target="#18r" facs="018">Fols. 18r, </locus> There is a space for the name of the bishop, but it is left unfilled.  On folio <locus target="#25v" facs="026">25v</locus>, the same thing happens with the name of the king.
                        </desc>
                      </item>
                      <item xml:id="e2">
                        <desc>
                          words of text are written interlinearly (<locus target="#14r" facs="014">fols. 14r, </locus>);
                          and lines of text are written interlinearly (<locus target="#16v" facs="017">16v, </locus>);
                          and in the upper margin with a symbol (┴) marking the location where the text is to be inserted (<locus target="#37r" facs="037">  f. 37r, col. 2, line 4</locus>);
                          erasure markings are visible (<locus target="#7v #17v #22r #33v" facs="008 018 022 034">7v, 17v, 22r, 33v</locus>)
                        </desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 207 x 135 x 30 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, covered with a linen double pocket cover.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                           <material key="textile"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

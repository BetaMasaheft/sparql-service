                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="Subscription">A final note states that the manuscript was written by <persName ref="https://betamasaheft.eu/PRS11265Hezqeyas">Ḥǝzqǝyas</persName> at the order of <persName ref="https://betamasaheft.eu/PRS11264Yeshaq">Yǝsḥāq</persName>,
                    of the order of
                    <persName ref="https://betamasaheft.eu/PRS11208HouseTakla">House of Takla Hāymānot</persName> and <persName ref="https://betamasaheft.eu/PRS11266HouseBasa">House of Baṣalota Mikāʾel</persName>.</desc>
                           <q xml:lang="gez">ወአነሂ፡ <persName ref="https://betamasaheft.eu/PRS11264Yeshaq">ይስሓቅ፡</persName> ወልደ፡ <persName ref="https://betamasaheft.eu/PRS11208HouseTakla">ተክለ፡ ሃይማኖት፡</persName>
                    ወወልደ፡ <persName ref="https://betamasaheft.eu/PRS11266HouseBasa">በጸሎተ፡ ሚካኤል፡</persName> አጽሐፍክዋ፡
                    ለዛቲ፡ መጽሐፈ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
                     </list>
                  </additions>

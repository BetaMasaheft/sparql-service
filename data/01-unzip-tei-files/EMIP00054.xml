               <msContents>
                  <summary>Anaphora of Our Lady Mary by Cyriacus of Bǝhǝnsa, ቅዳሴ፡ ማርያም፡, Prayer of the Blessed Virgin Mary at Golgotha, incomplete, ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ዘሰኔ፡ ጎልጎታ፡, Mystagogia, ትምህርተ፡ ኅቡዓት፡, Calendar of the Apostles and Evangelists</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="36v" facs="003">Fols 1r–36v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="37r" to="69r" facs="039">Fols 37r–69r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                     <note>Incomplete at the end</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="70r" to="81r" facs="072">Fols 70r–81r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="81r" to="81v" facs="083">Fols 81r–81v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6011FeastsList">Register of the
                                                  Church feasts for the entire year</title>
                  </msItem>

               </msContents>

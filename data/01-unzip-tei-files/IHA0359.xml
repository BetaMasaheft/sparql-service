               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="3r" to="203v">3r-203v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>اللهم صلى وسلم على سيدنا محمد |الذمن صلى عليه في يوم الف مرة واخرة | نجاه الله من عذاب الدنيا والاخرة اللهم الذمن صلى عليه الف مرة قبل ان يموت أعطاه الله الف قصر في الجنة من درّ وياقوت</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#203v">-203v</locus>اللهم صلى وسلم على سيدنا محمد| صلاة تجبر بها منا الضعيف يا لطيف</explicit>
                     <note>Vocalized. Some words in blue. The words are not divided.</note>
                     <note/>
                  </msItem>
               </msContents>

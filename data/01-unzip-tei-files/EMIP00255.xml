              <textLang mainLang="gez">Gǝ'ǝz</textLang>

              <msItem xml:id="ms_i1.1">
                <locus from="1r" to="18r" facs="002">Fols 1r–18r</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Daily">Maṣḥafa
                                                  qǝddāse, Daily Office Prayers and litanies</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                <incipit xml:lang="gez">፩ሃሌ፡ ሉያ፡ ይትፌሣሕ፡ ልብኪ፡ ኦድንግል፡ ወይትሌዓል፡ ቀርንኪ፡ በክብር፡ ሰማይ፡ ዳግሚት፡
                  ብኪ፡ ድኅነ፡ ዓለም፡ ወበወልድኪ፡ ኮነ፡ ሰላም፡</incipit>
              </msItem>

              <msItem xml:id="ms_i1.2">
                <locus from="18r" to="23v" facs="019">Fols 18r–23v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddaseChapter1">Maṣḥafa qǝddāse, Śǝrʿāta qǝddāse, Chapter 1:
                                                  Prayer over new vessels</title>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="omitted"/> እመቦ፡ ሊቀ፡ ጳጳሳት፡ ወለእመቦ፡
                  ሊቀ፡ ጳጳስ፡ አው፡ ኤጲስ፡ ቆጶስ፡ አው፡ ቀሲስ፡ አው፡ ዲያቆን፡ ዘኢተምሕረ፡ ወኢያእመረ፡ መጽሐፈ፡ ኪዳን፡ እስከ፡ ፍጻሜሁ፡
                  ወሲኖዶስ፡ ወዲድስቅልያ፡ ወሥርአተ፡ ቤተ፡ ክርስቲያን፡ ወኵሎ፡ ሕገጋቲሃ፡<gap reason="omitted"/></incipit>
              </msItem>

              <msItem xml:id="ms_i1.3">
                <locus from="23v" to="42v" facs="025">Fols 23v–42v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddaseChapter3">Maṣḥafa qǝddāse, Śǝrʿāta qǝddāse, Chapter 3:
                                                  Liturgy of Catechumen, Liturgy of the Word</title>
                <incipit xml:lang="gez">በስመ አብ ወወልድ<gap reason="omitted"/> ሚ፡ መጠን፡ ግርምት፡ ይእቲ፡ ዛቲ፡
                  ዕለተ፡ ወዕፅበት፡ ዛቲ፡ ሰአት፡ እንተ፡ ባቲ፡ ይወርድ፡ መንፈስ፡ ቅዱስ፡ እመልዕልተ፡ ሰማያት፡ ወይጼልሎ፡ ለዝንቱ፡
                    መሥዋዕት፡<gap reason="omitted"/></incipit>
                <textLang mainLang="gez">Gǝ'ǝz</textLang>
                <notatedMusic>
                  <desc>with musical notation</desc>
                </notatedMusic>
              </msItem>


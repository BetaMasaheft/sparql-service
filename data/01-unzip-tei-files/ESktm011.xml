                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Second half of the 19th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donors; incipit of Text
                           I; directives to the ministers and their abbreviations; titles of the
                           books to be read; elements of the punctuation signs; elements of Ethiopic
                           numerals.
 On the incipit page of Text I (fol. 2r), two lines are
                           rubricated (alternating with two black lines).</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">

                              <desc type="DonationNote" xml:lang="ru"/>
                              <q xml:lang="ru">Ot'' pervago Russkago Svjaščennoslužitelja posětivšago Abissiniju <persName ref="https://betamasaheft.eu/PRS12297Efrem">
                                 <title>Sobornago Ieromanaxa</title> Efrema</persName>.
                              Gorod'' <placeName ref="https://betamasaheft.eu/LOC3786Harar">Xarar''</placeName> - <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Abissinija</placeName>. <date calendar="julian" when-custom="1895-02-12">Fevralja 12-go dnja 1895 g</date>.<foreign xml:lang="en">
                              From the first ecclesiastic who visited Abyssinia, <persName ref="https://betamasaheft.eu/PRS12297Efrem">
                                    <title>the synodic hieromonk</title> Efrem</persName>.
                              The city of <placeName ref="https://betamasaheft.eu/LOC3786Harar">Harar</placeName>, <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Abyssinia</placeName>. <date calendar="julian" when-custom="1895-02-12">12th of February 1895</date>.</foreign>
                           </q>
                            </item>

                            <item xml:id="a1">
                                <locus target="#2r"/>
                                <desc type="OwnershipNote">The note states that the manuscript belonged to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                </desc>
                                <q xml:lang="gez">ግንዘት፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኀኔ፡ ዓለም።</placeName></q>

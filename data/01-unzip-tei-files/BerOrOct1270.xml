            <additions>
              <list>
                <item xml:id="a1">
                  <desc type="Record">Calculation of the jubilee years</desc>
                  <note>Recent hand; crudely written; black and red ink.</note>
                  <locus from="24va" to="24vb"/>
                  <q xml:lang="gez">ግጽው፡ ዘኢዮቤልዬ ... </q>
                </item>
                <item xml:id="a2">
                  <desc type="Inventory">Inventory of the lands</desc>
                  <note>Crudely and recently written; black ink.</note>
                  <locus from="26ra" to="27rb"/>
                  <q xml:lang="gez">ኆልቈ፡ ገራሕቱ፡ ... </q>
                </item>
                <item xml:id="a3">
                  <desc type="Excerpt">Prayer of the incense</desc>
                  <note>Written in black ink. The text on <locus target="#39r"/> is within any
                    columns (<locus target="#39r"/>is without layout). The handwriting seems to be
                    slightly different, but not so much recent than the main hand (in a smaller
                    size).</note>
                  <locus from="38vb" to="39r"/>
                </item>
                <item xml:id="a4">
                  <desc type="Unclear">Unclear note</desc>
                  <note>Crudely and recently written (after Additio 3); black ink. The initial lines
                    have been erased.</note>
                  <locus target="#39r"/>
                </item>
                <item xml:id="a5">
                  <note>Black ink. Recent hand.</note>
                  <locus target="#39v"/>
                  <desc type="Supplication"/>
                  <q xml:lang="gez">መስተብቍዕ፡...</q>
                </item>
                <item xml:id="e1">
                  <desc type="ScribalSupplication">The personal name ኆላዊ፡ ክርስቶስ፡ Ḫolāwi Krǝstos is
                    written (in red ink) in the supplication formula on <locus target="#30ra"/>, at
                    the explicit of miracle 1.</desc>
                </item>
                <item xml:id="e2">
                  <desc type="ScribalSupplication">The personal name ሀብተ፡ ሥላሴ፡ Habta Śǝllāse is
                    written (on the left margin, by a more recent hand) over another name originally
                    written but not readable anymore (with the exception of the last letter, i.e.
                    {n.l.}ን፡), in the supplication formula on <locus target="#36va"/>, at the
                    incipit of miracle 6.</desc>
                </item>
                <item xml:id="e3">
                  <desc type="ScribalSupplication">The same name mentioned in the supplication
                    formula on <locus target="#36va"/>, at the incipit of miracle 1, has been also
                    added in the supplication formula at the explicit of the miracle 6, on <locus target="18rb"/></desc>, written here as ሀብተ፡ ሥላሲ፡ Habta Śǝllāsi. </item>
                <item xml:id="e4">
                  <desc type="Correction">Scribal Corrections: few omitted letters written
                    interlineally (e.g.<locus target="#11va"/>, <locus target="#16vb"/>).</desc>
                </item>
                <item xml:id="e5">
                  <desc>Writing exercises on <locus target="#1r"/>, <locus target="#10v"/> (in the
                    margins).</desc>
                </item>
                <item xml:id="e6">
                  <desc type="StampExlibris"> on <locus target="#1r"/> and on <locus target="#40v">
                      (at the bottom).</locus></desc>
                </item>
                <item xml:id="e7">
                  <desc type="Unclear">Text not readable on <locus from="40v" to="41r"/>
                  </desc>
                </item>
              </list>
            </additions>

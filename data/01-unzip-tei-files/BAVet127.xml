                        <handDesc>
                          <handNote script="Ethiopic" xml:id="h1">
                            <desc>The writing is thin and tall, presenting equal shafts and angular forms especially in the letters
                              <foreign xml:lang="gez">ቆ</foreign>, <foreign xml:lang="gez">ቶ</foreign>,
                              <foreign xml:lang="gez">ዐ</foreign>, and notably in the letter <foreign xml:lang="gez">የ</foreign>.</desc>
                            <seg type="ink">Black, red</seg>
                            <seg type="rubrication">Name of the owner (now erased).</seg>
                            <date notBefore="1600" notAfter="1799"/>
                          </handNote>
                        </handDesc>
                      
                        <additions>
                          <list>
                            <item xml:id="e1">
                              <desc>The name of the owner, which has been erased everywhere, can be read as <persName role="owner" ref="https://betamasaheft.eu/PRS14400YerdaA">ይርዳእ፡ አምላክ፡</persName>.
                                At the beginning of the manuscript, the name <persName role="owner" ref="https://betamasaheft.eu/PRS14401WaldaM">ወልደ፡ ማርያም፡</persName> is often added above it.</desc>
                            </item>
                            
                            <item xml:id="a1">
                              <locus target="#5r"/>
                              <desc type="OwnershipNote">Ownership note written in blue ink in the upper margin. According to the catalogue, the word
                                <foreign xml:lang="gez">አርቶዶክሣዊ፡ </foreign> (‘orthodox’) indicates that the person is Melkite, not Jacobite.</desc>
                              <q xml:lang="gez">ዝንቱ፡ መጽሐፍ፡ ዘአርቶዶክሣዊ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS14401WaldaM">ወልደ፡ ማርያም፡</persName></q>
                            </item>
                          </list>
                        </additions>
                      

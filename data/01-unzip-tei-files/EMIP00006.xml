                  <decoDesc>
                    <summary>

                    </summary>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs
                      <locus target="#5r #6r #10v #11v #12r #12v #14r #14v #15v #18r #34r" facs="007 008 013 014 014 015 016 017 018 020 036"/> (row of multiple full stop symbols in black and red or in red).</decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#38v" facs="031"/>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> praying in the temple</desc>
                    </decoNote>

                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#39r" facs="041"/>
                        <desc>The Archangel <persName ref="https://betamasaheft.eu/PRS7840Phanuel">Phanuel</persName> smiting the sorcerers and driving the <term key="demon" ana="#demon"/>s <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                        </desc>
                    </decoNote>

                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#39v" facs="042"/>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName> standing for prayer</desc>
                     </decoNote>

                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <locus target="#37r" facs="039"/>
                           <desc type="Asmat">Asmat prayer against epidemics and dysentery, copied for <foreign xml:lang="gez">ወልደ፡ ሐና፡</foreign> in a crude hand</desc>
                        </item>

                        <item xml:id="a2">
                           <locus target="#37v" facs="040"/>
                           <desc type="GuestText">Quotation from <title type="incomplete" ref="https://betamasaheft.eu/LIT1882MarkGo">Mk 21:23</title></desc>
                        </item>

                        <item xml:id="a3">
                           <locus target="#37v" facs="040"/>
                           <desc>Directory for funeral ritual, <foreign xml:lang="gez">ግንዘት፡</foreign>, in a crude hand</desc>
                        </item>

                        <item xml:id="a4">
                           <locus target="#38r" facs="040"/>
                           <desc>Greeting to the Archangel Michael, but the content is about the Trinity, in a crude hand, with incipit <foreign xml:lang="gez">ሰላም፡ ለሚካኤል፡ ዘእንበለ፡ አምድ፡ ወሰርዌ፡ ዘትሴለሱ፡ በአካላት፡ ወትትዋሐዱ፡ በህላዌ፡<gap reason="omitted"/></foreign></desc>
                        </item>

                        <item xml:id="e1">
                          <locus target="#4r #7v #23r #27v #33v #36v" facs="006 010 025 030 036 039"/>
                           <desc>Overlooked words of text are written interlinearly</desc>
                        </item>

                        <item xml:id="e2">
                           <locus target="#ir(ecto) #iir(ecto) #40r" facs="001 002 042"/>
                           <desc>Crude drawings in blue ink pen, the last one being of <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName></desc>
                        </item>

                        <item xml:id="e3">
                           <locus target="#ir(ecto) #iv(erso) #iir(ecto)" facs="001 002"/>
                           <desc>Pen trial</desc>
                      </item>

                        <item xml:id="e4">
                           <locus target="#iiv(erso)" facs="003"/>
                          <desc type="OwnershipNote">Note of ownership by <foreign xml:lang="gez">አለቃ፡ ወልደ፡ ሐና፡</foreign>,
                          whose father was <foreign xml:lang="gez">ዐርከ፡ ሥሉስ፡</foreign>,
                          mother <foreign xml:lang="gez">ዐመተ፡ ሥላሴ፡ አጆሪ፡</foreign>,
                          and whose country was <foreign xml:lang="gez">ባሠራ</foreign></desc>
                        </item>

                        <item xml:id="e5">
                          <locus target="#40v" facs="043"/>
                          <desc>Blank</desc>
                        </item>

                    </list>

                  </additions>

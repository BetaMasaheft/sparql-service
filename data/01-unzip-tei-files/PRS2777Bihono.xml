      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ቢሆኖ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Bihono</persName>
               
               <persName xml:lang="gez" xml:id="n2" type="birth">ቢሆኖ፡ ኃያል፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Bihono Ḫāyyāl</persName>
               
        
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               
               <occupation type="other">rebel</occupation>
               
          
                  <floruit notBefore="1629" notAfter="1632">He was the commander of the rebel forces of 
                    
                     <persName ref="https://betamasaheft.eu/PRS6609Malkea"> 
                     <roleName type="title">ʾabetohun</roleName> Malkǝʾa Krǝstos</persName>, 
                     who led anti-Catholic rebellion against <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName> between <date>1629-1632</date> from a regional 
                     base <placeName ref="https://betamasaheft.eu/LOC4259Lasta">Lāstā</placeName> and <placeName ref="https://betamasaheft.eu/LOC6135Wag">Wāg</placeName>. As a commander, 
                     <persName ref="https://betamasaheft.eu/PRS2777Bihono">Bihono</persName> was  noted for his a brilliant 
                     military victories against the royal army. </floruit>
               <death when="1632"> He died fighting against the royal army of  
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <roleName type="title">ʾaṣe</roleName> Susǝnyos</persName> at 
                  <placeName ref="https://betamasaheft.eu/LOC6268WaynaD">Waynā Dagā</placeName> in <date>1632</date>. </death>
            </person>  
            
         </listPerson>

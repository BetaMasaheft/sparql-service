                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="34"/>
                            <title ref="https://betamasaheft.eu/LIT1526GadlaZ">Gadla Zamikāʾel ʾAragāwi</title>
                            <note>
                            <q xml:lang="gez">ንጽሕፍ፡ ስነ፡ ገድሉ፡ ወስመ፡ ገድሉ፡ ወጽንዐ፡ ትዕግሥቱ፡ ወትኅርምቱ፡ ለብፁዕ፡ ወቅዱስ፡ ብእሴ፡ እግዚአብሔር፡ አቡነ፡ ዘሚካኤል፡ ዘውእቱ፡ አረጋዊ፡ 
                                መክብበ፡ ፱ቅዱሳን፡ ያሬድ፡ ቀሲስ፡ ማኅሌታዊ፡ ብርሃና፡ ለኢትዮጵያ፡ በመዋዕለ፡ መንግሥቱ፡ ለገብረ፡ መስቀል፡ ንጉሥ፡ ወልደ፡ ካሌብ።</q>
                            </note>
                            <listBibl type="text">
                            <bibl corresp="http://zotero.org/groups/358366/items/UQCZ2TD5"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Guidi1895GadlaAragawi"/><title level="a">Il «Gadla ʾAragāwi»</title><title level="j">Atti della R. Accademia dei Lincei, Memorie della Classe di scienze morali, storiche e filologiche</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ignazio</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Guidi</t:surname></author><date>1894</date><biblScope unit="volume">Serie quinta, 2</biblScope><biblScope unit="page">54-96</biblScope></bibl>
                            </listBibl>
                        </msItem>

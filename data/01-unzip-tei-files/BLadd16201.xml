                        <msItem xml:id="ms_i3">
                            <locus from="152"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">Malkǝʾa ʾAbuna Takla Hāymānot</title>
                            <incipit xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ እምከርሥ።
                                <lb n="2"/>አመ፡ ፳ወረቡዑ፡ ለወርኀ፡ ታኅሣሥ። 
                                <lb n="3"/>ተክለ፡ ሃይማኖት፡ በኵሉ፡ ወበውስተ፡ ኵሉ፡ ቅዱስ። 
                                <lb n="4"/>ናሁ፡ ወጠንኩ፡ ወእቤ፡ እምስብሐቲከ፡ ሐዲስ።
                                <lb n="5"/>በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ።                                
                            </incipit>
                            <note>The hymn contains 56 stanzas.</note>
                        </msItem>
                        

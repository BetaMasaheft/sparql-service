               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
                  <persName xml:lang="gez" xml:id="n3" type="regnal">ስልጣን፡ ሰገድ፡</persName>
                  <persName xml:lang="gez" corresp="#n3" type="normalized">Sǝlṭān Sagad I</persName>
                     <persName xml:lang="gez" xml:id="n4" type="regnal">ዓለም፡ ሰገድ፡</persName>
                     <persName xml:lang="gez" corresp="#n4" type="normalized">ʿĀlam Sagad</persName>
      
                     <occupation type="ruler">Emperor</occupation>
              <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName>
               </residence>
               <birth when="1603"/>
               <floruit notBefore="1632" notAfter="1667">He succeeded his father 
                
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos">  
                     <roleName type="title">ʾaṣe</roleName> Susǝnyos</persName> in <date>1632</date>. 
                  He had grown up during the time of bitter religious controversy when his father 
               
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos"> 
                     <roleName type="title">ʾaṣe</roleName> Susǝnyos</persName> helped the Jesuits for about 20 years
                  in an attempt to introduce Roman Catholicism. 
                  However, he restored Orthodoxy on <date>18 June 1632</date>, 
                  which had been denounced during the reign of his father in favour of Catholicism. 
                     </floruit>
                  <death when="1667"/>
                  </person>
                  
         </listPerson>

         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1">ዮስዴቅ፡ ወልደ፡ አቢብ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Yosedeq Walda ʾAbib</t:persName>
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč̣</t:roleName>
               </t:persName>
               <t:occupation type="political">ruler </t:occupation>
               
               <t:floruit notBefore="1751" notAfter="1759">He was the governor of <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName> 
                  from <t:date>1751</t:date> to <t:date>1759</t:date>. His early life history is obscure, but he descended from <t:persName ref="https://betamasaheft.eu/ETH1126Amhara">ʾAmhārā</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</t:persName> and <t:persName ref="https://betamasaheft.eu/ETH1499Gafat">Gāfāt</t:persName>. 
                  <t:persName ref="https://betamasaheft.eu/PRS10451Yosedeq">Yosedeq Walda ʾAbib</t:persName> was in hostile relation with <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</t:persName>
                  after he demoted his father <t:persName ref="https://betamasaheft.eu/PRS9873WaldaAb">Walda ʾAbib</t:persName> in <t:date>1749</t:date>,  but later he made peaceful relation through 
                  marriage alliance with the king, marrying the half-sister of <t:persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/PRS9827Walatta">Walatta ʾƎsrāʾel</t:persName> and daughter of <t:persName ref="https://betamasaheft.eu/PRS2682BerhanM">Bǝrhan Mogasā</t:persName>. 
                     Then, he was appointed as the governor of <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName> in <t:date>1751</t:date>. 
                
               
      </t:floruit>
               
            </t:person>
            

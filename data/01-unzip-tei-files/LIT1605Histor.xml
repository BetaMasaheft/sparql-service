            <t:div type="textpart" subtype="part" xml:lang="gez" xml:id="Part2">
               <t:label>
                  <t:persName ref="https://betamasaheft.eu/PRS1666Alexande">Alexander the Great</t:persName> discovers the Island of the Blessed</t:label>
            </t:div>
            <t:div type="textpart" subtype="part" xml:lang="gez" xml:id="Part3">
               <t:label>The monk Gerasimas is lead to the Island of the Blessed after having read about it in a History of Alexander</t:label>
            </t:div>

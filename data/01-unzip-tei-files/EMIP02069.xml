               <msContents>
                  <summary>Excerpt of Angels Praise Her, ይዌድስዋ፡ መላእክት፡ ለማርያም፡; Excerpt from Book of Hours of Abba Giyorgis, መጽሐፈ፡ ሰዓታት፡ ዘአባ፡ ጊዮርጊስ፡, Prayer of the Covenant, ጸሎተ፡ ኪዳን፡; Excerpt of Image of Gäbrä Mänfas Qǝddus, መልክአ፡ ገብረ፡ መንፈስ፡ ቅዱስ፡; Excerpt of Image of the Savior of the World, መልክአ፡ መድኃኔ፡ ዓለም።; Image of the Trinity, መልክአ፡ ሥላሴ፡; Mystagogia, ትምህርተ፡ ኅቡዓት፡; Asmat Prayer of the Archangel Mika’el which is written on his left and right wings</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v" facs="001">Fols 1r–1v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Excerpt of Angels Praise Her</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2r" to="8r" facs="002">Fols 2r–8r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa
                                                  saʿātāt</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Excerpt from Book of Hours of Abba Giyorgis</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="9r" to="20r" facs="009">Fols 9r–20r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="21r" to="22v" facs="021">Fols 21r–22v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkǝʾ-hymn to
                                                  Gabra Manfas Qǝddus</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Excerpt of Image of Gäbrä Mänfas Qǝddus</note>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="23r" to="26r" facs="023">Fols 23r–26r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne
                                                  ʿālam</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Excerpt of Image of the Savior of the World</note>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="26v" to="37v" facs="027">Fols 26v–37v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">Malkǝʾa
                                                  Śǝllāse</title>
                     <incipit xml:lang="gez">ሰላም፡ ለህላዌክሙ፡ ዘይመውዕ፡ ህላውያተ፡</incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="39r" to="42r" facs="039">Fols 39r–42r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                     <incipit xml:lang="gez">በእንተ፡ ትምሕርተ፡ ኅቡዓተ፡ ቅድመ፡ ዘትትነገር፡ እምጵርስ፡ ፎራ፡ ለምእመናን፡ ኅቡዓት፡<gap reason="omitted"/>
                     </incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="42v" to="43v" facs="043">Fols 42v–43v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT5876AsmatPrayer">Asmat Prayer of the Archangel Mika’el</title>
                     <incipit xml:lang="gez">ኤኮስ፡ አስሊ፡ ኤፓ፡ ኤፓስ፡ ኤንክም ካም፡ ኤቦካኬ ሮም፡ ለካፍ፡ ፌኤ፡ ሎኬ፡ ወአርናኬ፡ ጓአብሶላ፡ አስቢክ፡ አበሳኩ፡ አሜዕ፡ አውፅዕ፡<gap reason="omitted"/>
                     </incipit>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <note>Asmat Prayer of the Archangel Mika’el which is written on his left and right wings, incomplete at the end</note>
                  </msItem>
               </msContents>

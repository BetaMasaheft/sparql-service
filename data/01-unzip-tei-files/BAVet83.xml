               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1ra" to="84vb"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2505Weddas">Wǝddāse ʾAmlāk</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ ወስእለት፡ ወአስተብቍዖት፡ እንተ፡ ነበበ፡ ባቲ፡ ቅዱስ፡ 
                        ባስልዮስ፡ ኤጲስ፡ 
                           <sic>ቆጳስ፡</sic>
                         ዘቂሳ<del rend="erasure">ጎ</del>ርያ፡ በእንተ፡ ሰብዓቱ፡ ዕለታት። ዘመፍትው፡ ይጸልዩ፡ ባቲ፡ ለለ፡ ኵሉ፡ ዕለት፡ 
                        ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ <add place="overstrike">ኤርምያስ፡</add> ለዓለመ፡ ዓለም፡ አሜን፨
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11673Ermeyas">ʾErmǝyās</persName> is written over another erased name in the 
                        supplication formula at the beginning of the text.</note>
                     </incipit>
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1ra" to="15rb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Monday">Wǝddāse ʾAmlāk, : Monday</title>
                        <incipit xml:lang="gez">
                           ቀዳሚ፡ ስእለት፡ ዘይትነበብ፡ በዕለተ፡ ሰኑይ፡ ኦእግዚአብሔር፡ እግዚእየ፡ ስረይ፡ ኃጢአትየ፡ አንተ፡ 
                              <sic>ተአምር፡</sic>
                            ኵሎ፡ ኃጢአትየ፡ እንተ፡ ገበርክዋ፡ ጽሚተ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ተወከፍ፡ 
                              <sic>ስእለትይ፡</sic>
                            ድክምተ፡ ወኅሥርተ፡ በዕበየ፡ አፍቅሮትከ፡ እንተ፡ አልባቲ፡ ወሰነ፨ እስመ፡ ለከ፡ ይደሉ፡ ስብሐት፡ ወክብር፡ ወተጋንዮ፡ እምይእዜ፡ 
                           ወእስከ፡ ለዓለም፤ አሜን፤ ወአሜን፨
                        </explicit>
                        <note/>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="15va" to="33vb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Tuesday">Wǝddāse ʾAmlāk, : Tuesday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ወስእለት፡ ዘዕለተ፡ ሠሉስ፡ እምድርሳነ፡ ቅዱስ፡ ማሪ፡ ኤፍሬም፡ ሶርያዊ፡ አፈ፡ በረከት፡ ወበቍዔት፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           ስብሐት፡ ለከ፡ ኦመስተዓግሥ፨ ስብሐት፡ ለከ፡ ኦመሐሪ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ወእኩን፡ ሱታፈ፡ ለቅዱሳን፡ እለ፡ አስመሩከ፨ እስመ፡ ለከ፡ ይደሉ፡ ስብሐት፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                        <note/>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.3">
                        <locus from="33vb" to="45rb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Wednesday">Wǝddāse ʾAmlāk, : Wednesday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ወስእለት፡ ወአስተብቍዖት፡ እምድርሳነ፡ ቅዱስ፡ ማሪ፡ ኤፍሬም፡ ካዕበ፨ ኦእግዚአብሔር፡ አምላክ፡ መሐሪ፡ ኢየሱስ፡ ክርስቶስ፡ ኦወልደ፡ እግዚአብሔር፡ ሶበ፡ እዜከር፡ ምጽአተከ፡ ግሩመ፡ 
                           ለኰንኖ፡ ፍጥረትከ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ከመ፡ አስምሮ፡ ለእግዚአብሔር፡ በብሔረ፡ ሕያዋን። ወይረስየኒ፡ ድልወ፡ ከመ፡ እስማዕ፡ ቃለ፡ ዘይብል፡ ዝንቱ፡ ወልድየ፡ ሞተሂ፡ ወሐይወ፨ ተገድፈሂ፡ ወተረክበ፨ እስመ፡ ለከ፡ ስብሐት፡ ወክቡ<supplied reason="explanation">ር</supplied>፡ 
                           ወእዘ<supplied reason="explanation">ዝ</supplied>፡ እስከ፡ ለዓለም፡ አሜን፨
                        </explicit>
                        <note/>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.4">
                        <locus from="45va" to="58va"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Thursday">Wǝddāse ʾAmlāk, : Thursday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ራብዕ፡ ዘዕለተ፡ ሐሙስ፡ እንተ፡ ተጋብአት፡ እምቃለ፡ አረጋዊ፡ መንፈሳዊ፡ ቅዱስ፡ ዮሐንስ። <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           ቡሩክ፡ ውእቱ፡ አቡሁ፡ ለእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ዘከሠተ፡ ምሥጢረ፡ አፍ<supplied reason="omitted">ቅ</supplied>ሮቱ፡ በነፍሳቲነ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ወንብጻሕ፡ ቦቱ፡ በሞገስ፡ ኀቤከ፡ በብ<supplied reason="omitted">ዝ</supplied>ኀ፡ ሣህልከ፡ ወምሕረትከ፨ ወበጸሎተ፡ ዝንቱ፡ አረጋዊ፡ መንፈሳዊ፡ ዮሐንስ፡ ዕቀቦ፡ ለገብርከ፡ ኤርምያስ፡ 
                           እስመ፡ ለከ፡ ይደሉ፡ ስብሐት፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11673Ermeyas">ʾErmǝyās</persName> is written in the supplication formula at the end 
                           of the text.</note>
                     </msItem>
                                                           
                                          <msItem xml:id="ms_i1.5">
                        <locus from="58vb" to="68v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Friday">Wǝddāse ʾAmlāk, : Friday</title>
                        
                        <msItem xml:id="ms_i1.5.1">
                           <locus from="58vb" to="64rb"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#FridayShenute">Wǝddāse ʾAmlāk, : FridayShenute</title>
                           <incipit xml:lang="gez">
                              ጸሎተ፡ አባ፡ ሲኖዳ፡ አርሳይ፡ መትርያድስ፡ ዘማኅበር፡ እንተ፡ ይትነበብ፡ በዕለተ፡ ዓርብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                              እግዚኦ፡ በመዓትከ፡ ኢትቅሥፈኒ፡
                           </incipit>
                           <explicit xml:lang="gez">
                              ወተወክፈ፡ እግዚአብሔር፡ ጸሎትየ፨ ይትኃፈሩ፡ ወይኅሰሩ፡ ኵሎሙ፡ ጸላእትየ፨ ሊተ፡ ለገብርከ፡ ኤርምያስ፡ ወይግብኡ፡ ድኅሬሆሙ፡ ወይኅሠሩ፡ ፈድፋደ፡ ፍጡነ፨
                           </explicit>
                           <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11673Ermeyas">ʾErmǝyās</persName> is written in the supplication formula at the end 
                              of the text.</note>
                        </msItem>
                        <msItem xml:id="ms_i1.5.2">
                           <locus from="64vb" to="68v"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#FridayPachomius">Wǝddāse ʾAmlāk, : FridayPachomius</title>
                           <incipit xml:lang="gez">
                              ጸሎት፡ ዘአባ፡ ጳኵሚስ፡ አበ፡ ድርገታት፡ እንተ፡ ይእቲ፡ ተፍጻሜት፡ ዘዕለተ፡ ዓርብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                              ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥላሴ፡ በተዋሕዶ፡ ወተዋሕዶ፡ በሥላሴ፨ እግዚኦ፡ ስረይ፡ ሊተ፡ እስመ፡ አበስኩ፡ በኀቤከ፡ ከመ፡ ሰብእ፨ ወአንተ፡ ስረይ፡ ሊተ፡ ከመ፡ 
                              
                                 <sic>አምላከ፡</sic>
                               ኄር፡ ኦመፍቀሬ፡ እጓለ፡ እመሕያው።
                           </incipit>
                           <explicit xml:lang="gez"/>
                           <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11673Ermeyas">ʾErmǝyās</persName> is written in the supplication formula at the end 
                              of the text.</note>
                        </msItem>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.6">
                        <locus from="68vb" to="76va"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Saturday">Wǝddāse ʾAmlāk, : Saturday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ሳድሲት፡ 
                              <sic>ዘዕለት፡</sic>
                            ሰንበት፡ አይሁድ፡ ዘአስተጋብአ፡ እመኃልየ፡ ቅብጢ፡ አቡነ፡ አትናቴዎስ፡ ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ እስክንድርያ፡ 
                           <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወትብል፡ ከመዝ፡ ኃሠሥኩከ፡ እማዕምቀ፡ ልብየ፡ ኦእግዚእየ፡ ኢየሱስ፡ 
                           ክርስቶስ፡ ርድአኒ፡ ወፍትሐኒ፡ እማእሰረ፡ ኃጢአት፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ሥሉስ፡ ፍጹም፡ ንስግድ፡ ሎቱ፡ ወንሰብሖ፨ ሎቱ፡ ስብሐት፤ እምአፈ፡ ሰብእ፡ ወመላእክት፡ ወእምአፈ፡ ኵሉ፡ ፍጥረት፡ እለ፡ 
                              <sic>ሀለው፡</sic>
                            በምድር፡ ወበሰማያት፡ 
                           በባሕርኒ፡ ወበቀላያት፡ ለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                        <note/>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.7">
                        <locus from="76va" to="83v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Sunday">Wǝddāse ʾAmlāk, : Sunday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ወስእለት፡ ዘቅዱስ፡ 
                              <sic>ቀርሎስ፡</sic>
                            ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ እስክንድርያ፡ ዘዕለተ፡ ሰንበተ፡ ክርስቲያን፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           ስብሐ<supplied reason="omitted">ት</supplied>፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ቦሙ፡ አአምን፡ ወእትአመን፡ እስከ፡ ነፍስ፡ ደኃሪት።
                        </incipit>
                        <explicit xml:lang="gez">
                           አንሰ፡ እገኒ፡ ለከ፡ ወእሴብሕ፡ ለስምከ፡ ቅዱስ፡ እስከ፡ ተፍጻሜተ፡ ሕይወትየ፨ ወለከ፡ ይሴብሑ፡ ኪሩቤል፡ 
                              <sic>ወሴራፌል፡</sic>
                            ወሐራ፡ መላእክት፡ ኵሎሙ፡ እስከ፡ 
                           ለዓለም፡ አሜን፨
                        </explicit>
                        <note/>

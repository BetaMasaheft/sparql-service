               <msContents>
                  <summary>Gospel of John, ወንጌል፡ ዘዮሐንስ፡, Absolution of the Son, ፍትሐት፡ ዘወልድ፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="55v" facs="003">Fols 1r–55v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>arranged for the days of the wee</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="56r" to="58r" facs="058">Fols 56r–58r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat
                                                  za-wald</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <incipit xml:lang="gez">
                      ፍትሐት፡ ዘወልድ፡ እግዚእ፡ እግዚኦ፡ ኢየሱስ፡ ክርስቶስ፡ ወልድ፡ ዋሕድ፡ ቃለ፡ እግዚአብሔር፡<gap reason="omitted"/>
                      </incipit>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>

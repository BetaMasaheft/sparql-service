                                 <note>Folio stubs are visible prior to <locus target="#i" facs="001">fols. i, </locus> and between <locus target="#i #ii" facs="002">i, ii</locus>.</note>
                              Protection Quire
                            </item>
                              <item xml:id="q2" n="1">
                                 <dim unit="leaf">10</dim>
                                 <locus from="1" to="10" facs="003">Fols 1–10</locus>

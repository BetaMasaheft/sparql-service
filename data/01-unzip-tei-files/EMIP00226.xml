                                 <dim unit="leaf">8</dim>
                                 <locus from="11" to="18" facs="013">Fols 11–18</locus>
                              Quire 2
                            </item>
                              <item xml:id="q4" n="3">
                                 <dim unit="leaf">10</dim>
                                 <locus from="19" to="28" facs="021">Fols 19–28</locus>
                              Quire 3
                            </item>
                              <item xml:id="q5" n="4">
                                 <dim unit="leaf">12</dim>
                                 <locus from="29" to="40" facs="031">Fols 29–40</locus>
                              Quire 4
                            </item>
                              <item xml:id="q6" n="5">
                                 <dim unit="leaf">8</dim>
                                 <locus from="41" to="48" facs="043">Fols 41–48</locus>
                              Quire 5
                            </item>
                              <item xml:id="q7" n="6">
                                 <dim unit="leaf">10</dim>
                                 <locus from="49" to="58" facs="051">Fols 49–58</locus>
                                 <note>A two folio quire is stitched in between <locus target="#55 #58" facs="060">fols. 55, 58</locus>.</note>
                              Quire 6:
                              8 added
                              9 added
                            </item>

                  <handDesc><handNote xml:id="h1" script="Ethiopic"><seg type="rubrication"><foreign xml:lang="gez">ኢየሱስ፡</foreign><foreign xml:lang="gez">ማርያም፡</foreign></seg></handNote></handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#29r" facs="031">Fol. 29r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref>, drawing</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#29v" facs="032">Fol. 29v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#40r" facs="042">Fol. 40r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, (Mary holds Jesus on her right side)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#40v" facs="043">Fol. 40v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref>, drawing (identical to <ref target="#d1"/>)</desc></decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs:
                      <locus target="#1r #56r" facs="003 058">folss. 1r, 56r, </locus> (simple black ḥarägs);
                      <locus target="#55v" facs="058">55v, </locus> (line of alternating red and black dots);
                      <locus target="#58r" facs="060">58r</locus> (multiple full stops</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc>EMML numbers on the folios</desc></item>
                      <item xml:id="e2"><desc><locus target="#ir(ecto) #58v #59r #59v #60r #60v" facs="001 061 062 063">Fols. ir(ecto), 58v, 59r, 59v, 60r, 60v</locus> blank</desc></item>
                      <item xml:id="a1"><desc><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus> a personal medical prescription included by the owner of the manuscript</desc></item>
                      <item xml:id="a2"><desc type="OwnershipNote"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus> (later) owner, Mämǝre Čäkolä, and the phrase, “Gospel of John.” </desc></item>
                      <item xml:id="e3"><desc><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus> pen trials</desc></item>
                      <item xml:id="a3"><desc><locus target="#55v" facs="058">Fol. 55v</locus> scribe mentioned, Wäldä Mädḫǝn. Text: “Those who were assembled at Nicea were 150, and at Constantinople, 200.” </desc></item>
                      <item xml:id="a4"><desc type="OwnershipNote"><locus target="#56v" facs="059">Fol. 56v</locus>  and passim, owner: Gäbrä Maryam; scribe Ḫaylä Maryam</desc></item>
                      <item xml:id="a5"><desc><locus target="#58r" facs="060">Fol. 58r</locus> mentions Metropolitan Abbä Sälama (III, 1841–1867) and Metropolitan Atǝnatewos (1869–1876). </desc></item>
                      <item xml:id="e4"><desc>
                        words of text are written interlinearly (<locus target="#6r #13r #15r #27v" facs="008 015 017 030">folss. 6r, 13r, 15r, 27v, </locus>, etc.);
                        erasure markings are visible (<locus target="#37r" facs="039">37r, </locus>); text has been removed (e.g., <locus target="#14r" facs="016">14r</locus>).</desc></item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 185 x 129 x 34 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered by tooled leather with the traditional patterns, headband and tailband.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1869">late-nineteenth century, ca. 1869 (<locus target="#58r" facs="060">fol. 58r</locus>) mentions <persName ref="https://betamasaheft.eu/PRS8388SalamaI">Salāmā III</persName> and <persName ref="https://betamasaheft.eu/PRS11991Athanasius">Athanasius II</persName></origDate>
                  </origin>
                  <provenance>Purchased in Nairobi before 2009.</provenance>
               </history>

               <msContents>
                  <summary>Psalter, ዳዊት፡, Angels Praise Her, ይዌድስዋ፡ መላእክት፡ ለማርያም፡, “For the sake of peaceful holy things,” በእንተ፡ ቅድሳት፡ ሰላማዊት፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="145v" facs="001">Fols 1r–145v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                   </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="145v" to="146v" facs="146">Fols 145v–146v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>incomplete at the beginning</note>
                     <colophon xml:id="coloph1">
                       <locus target="#145v" facs="146">Fol. 145v</locus>
                       <note>mentioning owner, Gäbrä Haywot and scribe, Wäldä Iyasus</note>
                     </colophon>
                  </msItem>
                  <msItem xml:id="ms_i3"><locus from="109v" to="113r" facs="110">Fols 109v–113r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1190Baenta">Baʾǝnta
                                                  qǝddǝsāt</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>


                </msItem>

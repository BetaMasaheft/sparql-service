         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ አብ፡ እምቅድመ፡ ዓለማት፡ ዘሀሎ፨</l>
                  <l n="2">ወበስመ፡ እግዚአብሔር፡ ወልድ፡ ለሥጋ፡ ማርያም፡ እንተ፡ አልዐሎ፨</l>
                  <l n="3">ወመንፈስ፡ ቅዱስ፡ አሐዱ፡ እምኔሆሙ፡ በኢሰስሎ፨</l>
                  <l n="4">አኀሥሥ፡ ሰሌዳ፡ ስሙ፡ ከመ፡ እጽሐፍ፡ ፊደሎ፨</l>
                  <l n="5">እምኀበ፡ አልቦ፡ ግብር፡ እሉ፡ ዘአምጽአ፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ እመሐፀነ፡ ቅድስት፡ ዮስቲና፨</l>
                  <l n="2">በብስራተ፡ ጻድቅ፡ ባሕታዊ፡ ሠናየ፡ ዜና፨</l>
                  <l n="3">ሀብተ፡ ማርያም፡ ጴጥሮስ፡ ሐዋርያ፡ ወልደ፡ ዮና፨</l>
                  <l n="4">መሐረኒ፡ ምግባረ፡ ጽድቅ፡ ወጸግወኒ፡ ልቡና፨</l>
                  <l n="5">አፍቅሮተ፡ ቢጽ፡ እኅሥሥ፡ ዘምስለ፡ ፍጽምት፡ ትሕትና፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘይትፈቀር፡ እምወይን፨</l>
                  <l n="2">ወዘያረስዕ፡ ጽምአ፡ በደኃራዊ፡ ዘመን፨</l>
                  <l n="3">ሀብተ፡ ማርያም፡ ፍቁሩ፡ ለወልደ፡ ማርያም፡ ሕፃን፨</l>
                  <l n="4">ከመ፡ ሰአለከ፡ አስተሐሚሞ፡ ተክለ፡ ሃይማኖት፡ ምእመን፨</l>
                  <l n="5">እስእለከ፡ ታድኅነኒ፡ እምኵሉ፡ ኀዘን፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ለደብረ፡ ሊባኖስ፡ ገዳሙ፨</l>
                  <l n="2">ለተክለ፡ ሃይማኖት፡ አቡነ፡ ዘቀሠብረ፡ አፅሙ፨፨</l>
                  <l n="3">በአሚን፡ ወበቅፍር፡ እስመ፡ ስንእዋን፡ አንትሙ፨</l>
                  <l n="4">ጥዑም፡ ስምከ፡ ሀብተ፡ ማርያም፡ በከመ፡ ጥዑም፡ ስሙ፨</l>
                  <l n="5">እመዐር፡ ወሶከር፡ ይቤሉ፡ ኵሎሙ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ሰላም፡ ለትንሣኤ፡ ሥጋከ፡ ምስለ፡ ነፍስከ፡ በደርግ፨</l>
                  <l n="2">ወአባላቲከ፡ ኵሉ፡ እንበለ፡ አሐዱ፡ ነቲግ፨</l>
                  <l n="3">ሀብተ፡ ማርያም፡ ክቡር፡ እምነ፡ ክቡራን፡ አእሩግ፨</l>
                  <l n="4">ኀበ፡ እሳት፡ ማኅደርከ፡ እለ፡ ይመጽኡ፡ በጹግ፨</l>
                  <l n="5">ኢይክሉ፡ አጥፍኦቶ፡ ብዙኃን፡ አፍላግ፨</l>
               </lg>
               <lg type="stanza" n="43">
                  <l n="1">ለዝንቱ፡ ቃለ፡ ማሕሌት፡ ወለዝንቱ፡ ድርሳን፨</l>
                  <l n="2">ዘያነብቦ፡ በቃል፡ ወዘይሰምዖ፡ በእዝን፨</l>
                  <l n="3">እብዚአብሔር፡ ይቅብኦ፡ ለሀብተ፡ ማርያም፡ ኪዳን፨</l>
                  <l n="4">ወዘያሰትቶ፡ በልቡናሁ፡ ምኑን፨</l>
                  <l n="5">ከመ፡ ዳታን፡ ወአቤሮን፡ ይትኰነን፡ በደይን፨</l>
               </lg>
            </div>
         </div>
      </body>

      <t:body>
         <t:div type="bibliography">
            
            <t:listBibl type="editions">
               <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl>       
               <t:bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename>Marius</t:forename><t:surname>Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><t:citedRange unit="item">102</t:citedRange></t:bibl>
            </t:listBibl>
         </t:div>
         <t:div type="edition" xml:lang="gez">
            <t:div type="textpart">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለክሙ፡ ለርስትክሙ፡ አክሚም፡ ልሳናተ፡ ኵሉ፡ መካን፨</t:l>
                  <t:l n="2">ሰማዕታቲሃ፡ አንትሙ፡ እስመ፡ ኅሩያን፨</t:l>
                  <t:l n="3">ሰመይዋ፡ ደብረ፡ ጽዮን፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለክሙ፡ ሥጋክሙ፡ ልብሰ፡ ሰማዕታተ፡ ሀገር፡ አክሚም፨</t:l>
                  <t:l n="2">በየማነ፡ መንግሥት፡ ትቁሙ፡ እምነ፡ ፀጋም፨</t:l>
                  <t:l n="3">ሐፀብክሙ፡ በማየ፡ ደም፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ሰላም፡ ለክሙ፡ ጥብሐ፡ በግዕ፡ ወላህም፡ በይነ፡ ክብረ፡ በዓል፡ ልማድ፨</t:l>
                  <t:l n="2">ህየንተ፡ ዝንቱሰ፡ ዮም፡ ሰማዕታተ፡ ወልድ፨</t:l>
                  <t:l n="3">ከዓውክሙ፡ ደመ፡ ክሳድ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ሰላም፡ ለክሙ፡ መንግሥተ፡ ሰማያት፡ ለክሙ፡ እስመ፡ ይእቲ፡ ድሉት፨</t:l>
                  <t:l n="2">ትግርምተ፡ መኰንን፡ ወሰይፍ፡ ከመ፡ ኢምንት፨</t:l>
                  <t:l n="3">ኮነክሙ፡ ሰማዕታት፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ሰላም፡ ለክሙ፡ ለእሳተ፡ ምድር፡ መግርህ፡ አእንተ፡ ፍቅረ፡ አብ፡ ወወልዱ፨</t:l>
                  <t:l n="2">ሰማዕታተ፡ አክሚም፡ አንትሙ፡ ለለ፩፨</t:l>
                  <t:l n="3">ቆምክሙ፡ ውስተ፡ ዓፀዱ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ሰላም፡ ለክሙ፡ ሰማዕታተ፡ አክሙም፡ ጥዑም፡ ለተናግሮ፡ በአፍ፨</t:l>
                  <t:l n="2">ዜና፡ ገድልክሙ፡ ጥቀ፡ ፍካሬ፡ መጽሐፍ፨</t:l>
                  <t:l n="3">ክብርክሙ፡ እስመ፡ ትሩፍ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሰላም፡ ለክሙ፡ አዕባነ፡ ህንደኬ፡ አክሚም፡ ሰማዕታተ፡ ክርስቶስ፡ ሥሉጥ፨</t:l>
                  <t:l n="2">በኃፍረት፡ ኢይሑር፡ ውስተ፡ ምሥራጥ፨</t:l>
                  <t:l n="3">ማኅቶተ፡ ብርሃን፡ ይኩነኒ፡ እንበለ፡ ተውላጥ፨</t:l>
                  <t:l n="4">ገድልክሙ፡ ዘአፍአ፡ ወውሥጥ፨</t:l>
               </t:lg>
            </t:div>
         </t:div>
      </t:body>

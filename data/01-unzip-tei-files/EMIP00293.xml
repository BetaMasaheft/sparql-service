                    <decoNote type="miniature" xml:id="d4"><locus target="#105r" facs="107">Fol. 105r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="5r" to="86v">5r-86v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0176IHA">تخميس الوترية</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>بسم الله الرحمن الرحيم \ بدأت بذكر الله مدحا مقدما \ واثني بحمد لله شكرا معظما \ وأختم قولي بالصلاة وانما \ اصلى صلاة تملا الارض والسما على من له اعلا العلا متبوأ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#86v">-86v</locus>يمينا لربي ان قلبي يحبه وذاك رجا فى الممات وفى المحيا \ تمت وبالخير عمت </explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
               </msContents>

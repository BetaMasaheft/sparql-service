            <div type="bibliography"><listBibl type="editions">
                <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl></div>
            
            <div type="edition" xml:lang="gez"><note>from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">ሰላመ፡ ስቅለትከ፡ ክርስቶስ፡ ለለ፡ ንብል፡ ንሕነ፨</l>
                        <l n="2">ሐዘነ፡ ዝንቱ፡ ዓለም፡ ዘያረስእ፡ ይኩነነ፨</l>
                        <l n="3">ሰላምከ፡ እግዚኦ፡ ትትወሀብ፡ ለነ፨</l>
                        <l n="4">ይትቀደስ፡ ስምከ፡ ዘበሰማያት፡ አቡነ፨</l>
                        <l n="5">ወመንግሥት፡ ትምጻእ፡ ኀቤነ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘራብእ፡ ፊደሉ፨</l>
                        <l n="2">እምብሂለ፡ ኢየሱስ፡ ኢሐፀ፡ ኍልቈ፡ ሆህያተ፡ መስቀሉ፨</l>
                        <l n="3">ለምክረ፡ ሞትከ፡ ክርስቶስ፡ አመ፡ እስራኤል፡ መድበሉ፨</l>
                        <l n="4">ሶበ፡ በመስቀል፡ አልዐሉ፨</l>
                        <l n="5">ወፀሓይ፡ እምነጽሮ፡ ሠወረ፡ ጽዳሉ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ዘአጽነነ፡ ርእሶ፨</l>
                        <l n="2">ኀበ፡ አቡሁ፡ ልዑል፡ እንዘ፡ ያመሐጽን፡ ነፍሶ፨</l>
                        <l n="3">ኢየሱስ፡ ክርስቶስ፡ ቅንዋተ፡ መስቀል፡ በተአግሶ፨</l>
                        <l n="4">እሰግድ፡ ለመስቀሉ፡ እንተ፡ በደሙ፡ ቀደሶ፨</l>
                        <l n="5">ንሴብሕ፡ ካዕበ፡ ዕበዮ፡ ወንግሦ፨</l>
                    </lg>
                    <lg type="stanza" n="4">
                        <l n="1">ሰላም፡ ለርእስከ፡ ዘሰመዩ፡ ስማ፨</l>
                        <l n="2">ልሳነ፡ ግዕዝ፡ ርእስ፡ ወልሳነ፡ ዕብራይስጥ፡ ብሂለ፡ ድማ፨</l>
                        <l n="3">ኢየሱስ፡ ክርስቶስ፡ ለመስቀልከ፡ ማሕተማ፨</l>
                        <l n="4">ይትሐትም፡ በርእስየ፡ ወለሕማምከ፡ ሕማማ፨</l>
                        <l n="5">ወዲበ፡ ኵሉ፡ አባላ፡ ወቆማ፨</l>
                    </lg>
                    <lg type="stanza" n="41">
                        <l n="1">ሰላም፡ ለአእጋሪከ፡ ቅድመ፡ ጲላጦስ፡ ዘቆማ፨</l>
                        <l n="2">እምበለ፡ ቅንዋት፡ ያልክኦ፡ ወቅድመ፡ ይሕመማ፨</l>
                        <l n="3">ስቅለትከ፡ ክርስቶስ፡ በሞገስ፡ ወኀይለ፡ ግርማ፨</l>
                        <l n="4">ሰገዱ፡ በቅድሜከ፡ አእላፈ፡ ትጉሃን፡ ዘራማ፨</l>
                        <l n="5">እስመ፡ አንተ፡ ውእቱ፡ ንጉሦሙ፡ ፌማ፨</l>
                    </lg>
                    <lg type="stanza" n="47">
                        <l n="1">ሰላም፡ ለመልክእከ፡ መልክአ፡ አዳም፡ ነሣኢ፨</l>
                        <l n="2">አምላክ፡ ኅቡእ፡ ዘኢያስተርኢ፨</l>
                        <l n="3">መስቀልከ፡ ክርስቶስ፡ ዕፀ፡ መዋኢ፨</l>
                        <l n="4">ይፈውስ፡ ሕማምየ፡ ወቍስልየ፡ ያጥኢ፨</l>
                        <l n="5">እንተ፡ በዲቤየ፡ ከዐ?ወ፡ ሕምዝ፡ ቀትል፡ ጸላኢ፨</l>
                    </lg>
                    <lg type="stanza" n="53">
                        <l n="1">ሰላም፡ ለዕርገትከ፡ የማነ፡ አቡከ፡ ልዑል፨</l>
                        <l n="2">ዘምስለ፡ አብሐት፡ ወዕበይ፡ ወብርሃን፡ ጽዱል፨</l>
                        <l n="3">አዕርገኒ፡ ክርስቶስ፡ በዘዚአከ፡ ክሂል፨</l>
                        <l n="4">ኢየሩሳሌም፡ ዘላዕሉ፡ ሰማያዊት፡ ደወል፨</l>
                        <l n="5">እሳት፡ ውስቴታ፡ ምሉእ፡ ፍሥሓ፡ ወሣህል፨</l>
                    </lg>
                    <lg type="stanza" n="54">
                        <l n="1">ሰላም፡ ለመጽአትከ፡ በመንክር፡ ሥ</l>
                        <l n="2">መልአከ፡ ስሕተት፡ ትደይን፡ ወለርጉማን፡</l>
                        <l n="3">አቁመኒ፡ ክርስቶስ፡ ምስለ፡ ቡሩካን፨</l>
                        <l n="4">ኀበ፡ ይትፌሥሑ፡ ወይትሐሰዩ፡ ጻድቃን፨</l>
                        <l n="5">እስመ፡ አለቦሙ፡ እምዝ፡ ሐዘን፨</l>
                    </lg>
                    <lg type="stanza" n="55">
                        <l n="1">ስብሐት፡ ይደሉ፡ ለክርስቶስ፡ ለዘጾረ፡ ሕማመ፨</l>
                        <l n="2">ወስብሐት፡ ሎቱ፡ ለዘከዐወ፡ ደመ፨</l>
                        <l n="3">ወስብሐት፡ ዓዲ፡ ለዘሰከበ፡ ወኖመ፨</l>
                        <l n="4">ስብሐት፡ ለዘሐይወ፡ ወተንሥአ፡ ፍጹመ፨</l>
                        <l n="5">ስብሐት፡ ለዘዐርገ፡ ወለዘይመጽእ፡ ዳግመ፨</l>
                        <l n="6">ስብሐት፡ ለመስቀሉ፡ ወእሁብ፡ ሰላመ፨</l>
                    </lg>
                </div>
            </div>
            
          <div xml:lang="gez" type="edition">
            <note>The incipit is taken from <ref type="mss" corresp="https://betamasaheft.eu/EMML1939">Dabub Wallo, Dabra Ḥayq ʾƎsṭifānos, MS EMML no. 1939</ref></note>
            <div type="textpart" subtype="incipit">
             <ab xml:lang="gez">ሰላም፡ ስቅለትከ፡ ክርስቶስ፡ <gap reason="illegible"/> ንብል፡ ንሕነ፡ ሐዘነ፡ ዝንቱ፡ ዓለም፡ ዘያረስእ፡ ይኩነነ። </ab>
            </div>
            <div type="textpart" subtype="explicit">
             <ab>ስብሐት፡ ለዘዐርገ፡ ወለዘይመጽእ፡ ዳግመ፡ ስብሐት፡ ለመስቀል፡ ወእሁብ፡ ሰላመ።</ab>
            </div>
          </div>

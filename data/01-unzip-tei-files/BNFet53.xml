                           <desc type="Unclear">Above the title of <ref target="#ms_i1"/>, the date of the birth of Mary is added.</desc>
                           <q xml:lang="gez">አመ፡<date> ፩፡ ለወርኀ፡ ግንቦት</date>፡ ልደታ፡ ለማርያም።</q>
                        </item>
                
                        <item xml:id="a2">
                           <locus target="#25r" facs="f55"/>
                           <desc type="Unclear">Above the title of <ref target="#ms_i2"/>, the date of the Assumption of Mary is added.</desc>
                           <q xml:lang="gez">አመ፡ <date>፲ወ፯ለወርኀ፡ ነኀሴ</date>፡ ፍልሰታ፡ ለማርያም።</q>
                        </item>
                
                     </list>
                  </additions>
            

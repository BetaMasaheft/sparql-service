                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  <locus target="#26r" facs="026">fols. 26r, </locus> (haräg);
                  <locus target="#25v" facs="026">25v</locus> (multiple full stops)
                  </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#15r" facs="015"> f. 15r and passim</locus>
                           <desc type="OwnershipNote">the name of the original owner is Ṭäfe Askalä Maryam. The secondary owner is, Ḍäḥay Ǝsetä Maryam, written in blue ink</desc>
                        </item>
                        <item xml:id="e1">
                           <desc>
                            It is unclear what manuscript this is in the insurance hand list
                            </desc>
                        </item>
                     </list>
                  </additions>

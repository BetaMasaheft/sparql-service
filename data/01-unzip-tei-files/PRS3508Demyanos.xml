      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ድምያኖስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Dǝmyānos</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  <t:residence/>
                  <t:birth when="1381" cert="medium"/>
               <t:floruit notBefore="1400" notAfter="1450">He was the abbot of the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2379DabraS">Dabra Sinā</t:placeName>
                  in <t:placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</t:placeName>. He was initiated into monastic life by 
                  <t:persName ref="https://betamasaheft.eu/PRS7402Muse">Muse</t:persName>, a disciple of <t:persName ref="https://betamasaheft.eu/PRS1302Absadio">ʾAbsādi  of Dabra Māryām</t:persName>. 
                  He was succeeded by his  disciple  <t:persName ref="https://betamasaheft.eu/PRS11291Yonas">Yonās of Dabra Sinā</t:persName>. </t:floruit>
                  <t:death when="1441"/>
               </t:person>  
               
         </t:listPerson>
    

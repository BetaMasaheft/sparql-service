                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                           <desc type="GuestText">Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2940RepCh221">Malkǝʾ-hymn to Our
                                                  Lady Mary</title></desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#167r" facs="169">f.167r, column one and top of column two</locus>
                           <desc type="Asmat">Asmat prayer to bring a person back to their home</desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#iir(ecto)" facs="003">Fol. iir(ecto)</locus>
                           <desc>Instructions about the measurement of shadows for the telling of time throughout the year.
                             Incipit: <foreign xml:lang="gez">መስከረም፡ እና፡ መጋቢት፡ ነግሁ፡ ሃያ፡ አራት፡ ሰለስቱ፡ አስር፡ ነው፡ ቀትሩ፡ አራት፡</foreign></desc>
                        </item>
                        <item xml:id="a4">
                          <locus target="#166v" facs="169">Fol. 166v</locus>
                           <desc>Treatise on the spiritual meanings of the Hebrew Letters, incomplete at the end. Written in a different hand of the nineteenth century.
                             Incipit: <foreign xml:lang="gez">አሌፍ፡ ዘይቤ፡ ኍላቄሁ፡ ፳፪ ይተረጐም፡ በ፳ወ፪ ግብራት፡ ፍጡራን፡ አሌፍ፡ ብሂል፡ አነ፡ እግዚአብሔር፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="a5">
                          <locus target="#167r" facs="169">f. 167r, column one and top of column two</locus>
                          <desc type="Asmat">Asmat prayer to bring a person back to their hom‎e</desc>
                        </item>
                        <item xml:id="a6">
                          <locus target="#167r" facs="169">f. 167r, column two</locus>
                           <desc type="Asmat">Asmat prayer against an enemy in the court</desc>
                        </item>
                        <item xml:id="a7">
                          <locus target="#167v" facs="170">Fol. 167v</locus>
                           <desc type="GuestText">Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title> for Sunday, copied in a nineteenth- or twentieth-century hand</desc>
                        </item>
                        <item xml:id="a8">
                          <locus target="#166r" facs="168">Fol. 166r</locus>
                           <desc type="OwnershipNote">Note of ownership, with the original owner’s name erased.  A secondary owner is listed below, Ǝmäyät Žämanäš</desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#ir(ecto) #iv(erso)" facs="001">Fols. ir(ecto), iv(erso)</locus>
                           <desc>Pen trials and notes, written upside down</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#55r #101r #162v" facs="057 103 165">Fols. 55r, 101r, 162v</locus>
                           <desc>badly faded seal</desc>
                        </item>
                        <item xml:id="e3">
                          <locus from="107r" to="117r" facs="109">Fols 107r–117r</locus>
                           <desc>Psalms 118–130 are misnumbered</desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#125r" facs="127">Fol. 125r</locus>
                           <desc>erased, illegible note</desc>
                        </item>
                        <item xml:id="e5">
                          <locus target="#161v #162v" facs="164 165">f. 161v, 162v, bottom margins</locus>
                           <desc>inventory of cattle, written in a crude hand</desc>
                        </item>
                        <item xml:id="e6">
                          <locus target="#166v" facs="169">f. 166v, column two, bottom</locus>
                           <desc>List of properties.  Judge, witnesses, and participants in a court case are mentioned</desc>
                        </item>
                        <item xml:id="e7">
                           <desc>Identified in the insurance hand list as Psalter 25</desc>
                        </item>
                        <item xml:id="e8">
                          <locus target="#35 #44 #60 #88" facs="005 006 008 010">Fols. 35, 44, 60, 88</locus>
                           <desc>red, yellow, and blue string is sewn into the fore edge as navigation system</desc>
                           </item>
                        <item xml:id="e9">
                          <locus target="#117 #124" facs="013 014">Fols. 117, 124</locus>
                          <desc>red string is sewn into the fore edge as navigation system</desc>
                          </item>
                        <item xml:id="e10">
                           <desc>Numbered quires: quires 2–9, <locus target="#q2 #q3 #q4 #q5 #q6 #q7 #q8 #q9">fols. q2, q3, q4, q5, q6, q7, q8, q9</locus></desc>
                        </item>
                        <item xml:id="e11">
                           <desc>Occasionally, a second spiritual meaning to the Hebrew letters of Ps118 is inserted by a later hand</desc>
                        </item>
                        <item xml:id="e12">
                          <locus target="#2r #5r #6v #10v #12v" facs="004 007 009 013 015">Fols. 2r, 5r, 6v, 10v, 12v</locus>
                           <desc>etc., words of text are written interlinearly</desc>
                           </item>
                        <item xml:id="e13">
                          <locus target="#78r #108v #110v #113v #135r" facs="080 111 113 116 137">Fols. 78r, 108v, 110v, 113v, 135r</locus>
                          <desc>etc., lines of text are written interlinearly</desc>
                          </item>
                        <item xml:id="e14">
                          <locus target="#78v" facs="081"> line 16</locus>
                          <desc>lines of text written in the upper margin with a symbol (┴) marking the location where the text is to be inserted</desc>
                          </item>
                        <item xml:id="e15">
                          <locus target="#97v" facs="100">Fol. 97v</locus>
                          <desc>etc., erasure markings are visible</desc>
                          </item>
                        <item xml:id="e16">
                          <locus target="#17r #62r #91v #101v #104r" facs="019 064 094 104 106">Fols. 17r, 62r, 91v, 101v, 104r</locus>
                          <desc>etc., text has been removed</desc>
                          </item>

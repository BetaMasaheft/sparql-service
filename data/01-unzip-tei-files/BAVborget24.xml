                  <msContents>
                    <summary/>

                    <msItem xml:id="ms_i1">
                      <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                      <textLang mainLang="gez"/>
                      <note>Some parts of the work have been copied out of order, most notably, the <ref type="work" corresp="https://betamasaheft.eu/LIT1758Lefafa#ThirdChapter">Prayer Concerning the Agony of Death</ref> has been swapped with two <ref type="work" corresp="https://betamasaheft.eu/LIT1873Mangad">Prayers for the Journey to Heaven</ref>.</note>

                      <msItem xml:id="ms_i1.1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#FirstChapter">Lǝfāfa ṣǝdq, First Chapter</title>
                      </msItem>

                      <msItem xml:id="ms_i1.2">
                        <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#SecondChapter">Lǝfāfa ṣǝdq, Second Chapter</title>
                      </msItem>

                      <msItem xml:id="ms_i1.3">
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1873Mangad">Mangada samāy</title>
                        <explicit xml:lang="gez">ወለመንበረ፡ ስብሐቲሁ፡ ለእግዚአብሔር፡ ዘሐነጸ፡ ጽርሖ፡ ወአልቦ፡ <sic>ዘየአምሮ፡</sic> ዘእንበለ፡ አብ፡ ባሕቲቱ፡ ወዘእንበለ፡ ክርስቶስ፡ ወልዱ፡ ወመንገሱ፡ ቅዱስ<supplied reason="omitted">፡</supplied>ኦመሓሪ፡ መሐረንኢ፡ ወስረይ፡ ኃጢትየ፡ ሊተ፡ ለገብርከ፡ <add place="above">ኃይለ፡ ጊዮርጊስ፡</add> <add place="overstrike">ወልደ፡ ሩፋኤ<supplied reason="omitted">ል፡</supplied></add></explicit>
                        <note>Only two prayers have been included instead of the usual seven.</note>

                        <msItem xml:id="ms_i1.3.1">
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT1873Mangad#Second">Mangada samāy, Second prayer</title>
                        </msItem>

                        <msItem xml:id="ms_i1.3.2">
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT1873Mangad#Third">Mangada samāy, Third prayer</title>
                        </msItem>
                      </msItem>

                      <msItem xml:id="ms_i1.4">
                        <title>Two parts of <ref type="work" corresp="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</ref> copied together.</title>
                        <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/> በብርሃን፡ ስሙ፡ ለእግዚአብሔር፡ ኢይትፈለጥ፡ ሰማይ፡ ወምድር፡ ፯መላእክት፡ ብርሃናውያን፡ እለ፡ ይነብሩ፡ ታሕተ፡ መንጦላዕቱ፡ ቅዱስ፡</incipit>

                        <msItem xml:id="ms_i1.4.1">
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT1758Lefafa#FourthChapter">Lǝfāfa ṣǝdq, Fourth Chapter</title>
                        </msItem>

                        <msItem xml:id="ms_i1.4.2">
                          <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#FifthChapter">Lǝfāfa ṣǝdq, Fifth Chapter</title>
                        </msItem>

                      </msItem>

                      <msItem xml:id="ms_i1.5">
                        <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#SixthChapter">Lǝfāfa ṣǝdq, Sixth Chapter</title>
                      </msItem>

                      <msItem xml:id="ms_i1.6">
                        <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa#ThirdChapter">Lǝfāfa ṣǝdq, Third Chapter</title>
                      </msItem>

                      <msItem xml:id="ms_i1.7">
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT1873Mangad#Sixth">Mangada samāy, Sixth prayer</title>
                      </msItem>

                    </msItem>

                  </msContents>


                  <history>
                    <origin>
                      <origDate notBefore="1700" notAfter="1788"/>
                    </origin>
                    <provenance>
                      According to <ref type="mss" corresp="https://betamasaheft.eu/BAVborglat285#a1">a letter</ref> from <persName ref="https://betamasaheft.eu/PRS9535tobiyaG">Ṭobiya Giyorgis Gäbrä Ǝgziʾabǝḥer</persName> to <persName ref="https://betamasaheft.eu/PRS2853Borgia">Stefano Borgia</persName> dated <date>19 December 1788</date>, <persName ref="https://betamasaheft.eu/PRS9535tobiyaG">Ṭobiyā</persName>, who found the scroll in the library at <ref type="ins" corresp="https://betamasaheft.eu/INS0302SanStefano">Santo Stefano de' Mori</ref>, sent it to <persName ref="https://betamasaheft.eu/PRS2853Borgia">Borgia</persName> along with a description of its contents.
                    </provenance>
                    <acquisition>
                      The Borgia collection entered the Vatican Library during the pontificate of <persName ref="https://betamasaheft.eu/PRS6258LeoXIII">Leo XIII</persName> (<date>1878-1903</date>).
                    </acquisition>
                  </history>


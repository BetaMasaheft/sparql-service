                        <locus target="#strip1"/>
                        <desc>Three black and red <term key="cross" ana="#cross">crosses</term> with interlaced border above and below at the top of the first strip.</desc>
                      </decoNote>
                      <decoNote xml:id="d2" type="miniature">
                        <locus target="#strip2"/>
                        <desc>Three black and red <term key="cross" ana="#cross">crosses</term> with decorative border above and below at the top of the second strip.</desc>
                      </decoNote>
                      <decoNote xml:id="d3" type="miniature">
                        <locus target="#strip3"/>

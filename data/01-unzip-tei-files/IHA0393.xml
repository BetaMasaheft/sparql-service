               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="191v">1r-191v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0002IHA">Muḫtaṣar Tanbīh al-Anām / مختصر تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله الذي زين سماء الاذكار بالصلاة على النبي المختار واطلع من سناء انوارها مطالع...والاقمار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#191v">-191v</locus>وبارك على سيدنا ومولانا محمد خاتم النبيين وإمام المرسلين والحمد لله رب العالمين وصلى الله على سيدنا ومولانا محمد خاتم النبيين والمرسلين </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="192r" to="192r">192r-192r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0741IHA">دعاء الوادين</title>
                     <incipit xml:lang="ar">
                        <locus target="#192r">-192r</locus>الاهي امرتني ببر والدي واوجبت حقهما علي والزمت شكرهما مع شكرك وفرضت علي برهما مع برك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#192r">-192r</locus>الاهي شرف منزليهما في جنتك واجزل حظهما منقربك واجعلني واياهما من اهل خصوصيتك امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="192r" to="192r">192r-192r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0743IHA">دعاء عذاب القبر</title>
                     <incipit xml:lang="ar">
                        <locus target="#192r">-192r</locus>اللهم رب كل شي بقدرتك على كل شي</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="192r" to="192r">192r-192r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0745IHA">دعاء الكرب</title>
                     <incipit xml:lang="ar">
                        <locus target="#192r">-192r</locus>لا اله إلا الله العظيم الحليم لا اله إلا الله رب العرش العظيم</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="193r" to="195r">193r-195r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0757IHA">عرف الندي في تخميس لامية ابن الوردي</title>
                     <incipit xml:lang="ar">
                        <locus target="#193r">-193r</locus>كل غيداء إذا ما سبحت ذيلها تيها العقلي سلبت إن نفسي كل هذا جربت واله عن الة لهوا طربت/وعن الامرد مرتج الكفل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#195r">-195r</locus>الازل القادر المؤبد/مع شكر وثناء لم تزل ; وصلاة وسلاما ابدا على الزكي المصطفى محمدا وعلى الال الكرام السعدا وعلى الاجداد والقوم الاول</explicit>
                     <note/>
                     <note/>
                  </msItem>

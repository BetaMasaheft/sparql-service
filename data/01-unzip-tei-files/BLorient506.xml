                    <msContents>
                        <summary/>
                        
                        
                                                
                        <msItem xml:id="ms_i1">
                            <locus from="4r" to="87v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1819Maccab">Maccabees, Book of (Ethiopic)</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="88r" to="149r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1373Bookof">Book of Ezekiel (General record)</title>
                            <note>The title gives the name of the owner, <persName role="owner" ref="https://betamasaheft.eu/PRS11649WaldaSum">Walda Sum</persName>.</note>
                            <note>The exposition (see <ref target="#a2">additio 2</ref>) follows the text.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="149ra" to="159rb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5799TergwHezq">ትርጓሜ፡ መጽሐፍ፡ ዘሕዝቅኤል፡</title>
                            <incipit xml:lang="gez">ወኮነ፡ አመ፡ ሰላስ፡ ክረምት፡ ዘይቤ፡ እመከራሁ፡ ወእምፄዋዌሁ፡ ለሕዝቅኤል፡ ድኅረ፡ ኮነ፡ 
                                ፫ዓመተ፡ በራብዕ፡ ወርህ፡ ዘ፡ በሐምሌ፡ በሐሙስ፡ ሠርቅ፡ ዘ፡ ክብ[?]ለት፡ (sic)ወርህ፡ 
                                በ፭ዕለት፡ ኮቦር፡ ዘ፡ ፈለገ፡ ፋርስ፡ እደ፡ እግዚአብሔር፡ ዘ፡ ሥልጣን፡ መጽአ፡ መንፈስ፡ እምደቡብ፡ ዘ፡ ነፋስ፡ ዓቢይ፡ ምስለ፡ ደመና፡</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="160r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1376Apocal">Apocalypse of Ezra</title>
                            <note>The First Book of Esdras or 4 Esdras according to the Vulgate</note>
                            
                        </msItem>
                        
                    </msContents>
                    

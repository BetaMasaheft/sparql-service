               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="24r">2r-24r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4189IHA">كتاب الشافية في علمي الخط والتصريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم وصلي الله علي محمد الحمد لله رب العالمين وصلي الله على سيدنا محمد خاتم النبيين وعلى آله الطيبين الطاهرين وبعد فقد سألني من لا تسعني مضايقته ولا توافقني مخالفته أن ألحق بمقدمتي في الإعراب مقدمة في التصريف علي نحوها ومقدمة في الخط فأجبته سآئلا متضرعا أن ينفع الله بها كما نفع بأختها والله الموفق ومامعين التصريف علم بأصول يعرف بها أحوال أبنية الكلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>نحو شوي الا ما شذ نحو القوي والطوي فان جهل فان أمليت فباليا؟ نحو متي والا فالألف فإنما كتبوا لدي باليا لقولهم لديك وكلا علي الوجهين لإحتماله واما الحروف فلم يكتب منها بالياء ... وعلي وحتي واله اعلم بالصواب </explicit>
                     <note>The title page is full of barely readable or unreadable quotations of poetry and adab literature.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="26v" to="26v">26v-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4210IHA">قصيدة أوى العمر في اللذات</title>
                     <incipit xml:lang="ar">
                        <locus target="#26v">-26v</locus>اوى العمر في اللذات اللهوم تهز | فبادر بصرف العمر في الفرض السنن | وان شيت ... الفضل والخير والمنن | عليك بتقوى الله في السر والعلن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>وسامح ولاطف واكف ما قد اه... | ووفق وسل ذو اصلح؟ الكل واهدنا لسنة خير الخلق والسيد الحسن </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="28v" to="28v">28v-28v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4249IHA">نظم لاحت لي دلائل القبول</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>لاحت لي دلاىل القبولي مدحات ... بالوصولي | قم ردها حرفا؟ بالامزاج من على شموس عيطبولي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28v">-28v</locus>والدمع يصيب ... الحبيبي روحي؟ فداكم؟ | ا من ترض عني فلا ابالي بمن فلان روحي ... | الله الله الله حي وباقي والكل فاني وله نعم اخر ... | </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="31r" to="34v">31r-34v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4250IHA">نظم مدح حبيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#31r">-31r</locus>بسم الله الرحمن الرحيم | نبي نوروا سلامي نور سلام الصلوه والسلامي الف عامي | بسم الله ابتداي ثانيا الصلاة علي الهادي لارشادي | نب نعم المجيبا ور عجيبا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34 v">-34 v</locus>هلموا يا اخواني الموا؟ واسمعوا بمدحى لحبيبي | نلت نول المعاني بمدحي من علي او تجلي بالمعالي</explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="36r" to="41v">36r-41v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4254IHA">Unidentified text on ortography</title>
                     <incipit xml:lang="ar">
                        <locus target="#36r">-36r</locus>الفصل الاول في بيان أحكام الالف وهو مشتمل على ثلثة [كذا] الاول فى الحذف والثانى فى الزيادة والثالث في رسمه وكتابته على صورة الواو او الياء اما النوع الاول ففي الحذف يحذف فى الرحمن والعلمين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#41v">-41v</locus>على قوله يخرجون الرسول وابتدائه من قوله واباكم وشد هذا يروي عن القامي؟ اي ذرف نظر ... الفقهاء في اخر الدين؟ واعشارهم الوقف والدهر في القران والله اعلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="42r" to="45r">42r-45r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4257IHA">كتاب الألفاظ</title>
                     <incipit xml:lang="ar">
                        <locus target="#42r">-42r</locus>بسم الله الرحمن الرحيم رب يسر علا تعسر عونك | كتاب الألفاظ تأليف ابن الأعرابي واسمه محمد بن زياد رحمه الله باب يقال ان فلانا لكريم الأصل والسيح؟ والمحتد والمحكد والأص</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#45r">-45r</locus>باب يوم ابت وامت وحمت اذا كان شديدا هذا في الحرسلا؟ غيره وقال غيره هو اليوم الذي فيه الشدة من شدايد الدهر وبالله التوفيق</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="26v" to="26v">26v-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4212IHA">قصيدة لك الحمد يا مستوجب</title>
                     <incipit xml:lang="ar">
                        <locus target="#26v">-26v</locus>لك الحمد يا مستوجب الحمد دائما على كل حال فان لدايم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>ومن من يد الا يد الله فوقها ولا ظالم الا ... بظالم | وصل علي خير البرية كلها محمد المختار من ال هاشم | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="26v" to="26v">26v-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4224IHA">نظم ما كان الماضى</title>
                     <incipit xml:lang="ar">
                        <locus target="#26v">-26v</locus>قيل الغم؟ ما كان الماض القاويل قايل له منطق فيه كلام محبر </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>على انه لم ينج من قول قايل بقول غير حق فيه ويكثر تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="27r" to="27r">27r-27r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0724IHA">قصيدة أغيب وذو اللطائف لا يغيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>أغيب وذو اللطايف لا يغيب وارجوه رجا لا تخيب [كذا] | واسله لسلامة من زمانى بليت به نوايبه تشيب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>وصل علي النبي وآله ما ترنم في الاراك العندليب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="27r" to="27r">27r-27r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4213IHA">قصيدة كأنك لم تسمع باخبار من مضى</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>صلاة وتسليم وازكي تحية علي المصطفى المختار ... البريات ... | كأنك لم تسمع باخبار من مضى ولم تر في باقين ما يصنع الدهر | فان كنت لا تدري فتلك ديارهم مجاها مجال الريح بعدك والقطر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>فصبرا علي ايام حتي تجوزها فعما قليل بعدها  يحمد الصبر</explicit>
                     <note>The text is written in vertical in the external margin of the page, in two colums, separated by the last verse.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="27v" to="27v">27v-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4215IHA">نظم شي لله يا سيد الكونين</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>شي لله يا سيد الكونين الغار يا قرة العين | يا فتاح افتح لنا بابك واجعلنا من جملة احبابك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27v">-27v</locus>اعطاني محبوبي الخلة مكتوبه الكل بسم الله | صلي الله على ابن عبد   | الله الداعي الي جناب الله </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="27v" to="27v">27v-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4221IHA">قصيدة الا يا سادة الكرماء</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>الا يا سادة الكرما ومن بالفضل هم قدما | قفوا ثم اسمعوا مدحا | ... الدر قد نظما | مدحت به نبي ... الظلما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27v">-27v</locus>فنلت؟ بمدحهم شرفا فمن مدح اكرام سما | فقد ... معالي العلا فلاحمد لله على النعما </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="28v" to="28v">28v-28v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4281IHA">نظم ببسم الله مولانا ابتدينا</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>بسم الله مولانا ابتدينا ونحمده على نعماه فينا | توسلنا به في كل امر غياث الخلق رب العلمينا | وبالاسما ما ورد ت بنص بما في الغيب مخزينا مصونا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28v">-28v</locus>وستر العرش مسبول علينا وعين الله ناظر الينا | ونختم بالصلاة ولي محمد امام الكل خير الشافعينا</explicit>
                     <note>The ending of this version differs form the one found in DWL00004.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="28v" to="28v">28v-28v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4248IHA">نظم على المختار صلوا</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>علي المختار صلوا يا رفاقي ثنا لوا الفوز؟ في يوم الحلاقي؟ | حمدت الله لا احصي ... | صلاة قبل ما تمضي البواقي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28v">-28v</locus>واليك الصحاب فهم سبيل الذي ود الي كاسن؟ دهاقي | واياد واولاد محيا واكرم من تخلف باللحاق<note>Written in vertical, in the inner margin of the page.</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>

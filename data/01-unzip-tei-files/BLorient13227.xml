                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7248PrMaftehe">Prayer for undoing charms</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> መፍትሔ፡ ሥራይ፡ ፍታሕ፡ ሥራየ፡ ዓይነ፡ ብእሲ፡ ወብእሲት፡ አድኅን፡ ይቤለከ፡ ኢየሱስ፡ 
                                ክርስቶስ፡ ለገብርከ፡ <gap reason="illegible"/></incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7258FetahQ">Fǝtāḥ Qǝḥdudān Qǝḥdudān Qǝḥdudān ʾArkyān ʾǝm-nǝstit
          Makiryā</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ፍታሕ፡ ቅሕዱዳን፡ ቅሕዱዳን፡ ቅሕዱዳን፡ አርክያን፡ እምንስቲት፡ መኪርያ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7252FetahSeray">Fǝtāḥ śǝrāya ʾagānǝnt</title>
                            <note>Contrary to <bibl corresp="http://zotero.org/groups/358366/items/RSEA4WPK"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Strelcyn1978BritishLibrary"/><title level="m">Catalogue of Ethiopian Manuscripts in the British Library acquired since the Year 1877</title><author><forename>Stefan</forename><surname>Strelcyn</surname></author><pubPlace>London</pubPlace><publisher>British Museum</publisher><date>1978</date><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">British Museum</note><note type="tag">bm:Strelcyn1978BritishLibrary</note><citedRange unit="page">132</citedRange></bibl>, who saw in this text four different prayers for the undoing of charms.</note>
                            <msItem xml:id="ms_i3.1">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7252FetahSeray#Aganent">Prayer for undoing the charms of devils and Bāryā, the charms of priests and of deacons</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ፍታሕ፡ ሥራየ፡ አጋንንት፡ ወባርያ፡ ሥራየ፡ ካህናት፡ ኪን፡ ወካህናት፡ ወዲያቆናት፡
                                    </incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i3.2">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7252FetahSeray#Tor">Prayer for undoing the ties of death, the charms of Dask and Bāryā, the charms of Mǝč and of ʿaynat, the charms of magicians
                                    and priests</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> በእንተ፡ ጦር፡ በዝንቱ፡ አስማት፡ ግበር፡ ዘፈታሕከ፡ ማእሰሪሁ፡ ለሞት፡ ሥራየ፡ ደስክ፡ ወባርያ፡
                                    ሥራየ፡ ምቼ፡ ወዓይነት፡ ሥራየ፡ ኪን፡ ወካህናት፡</incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i3.3">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7252FetahSeray#Rakon">Prayer for undoing charms</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ራኮን፡ ፍታሕ፡ ፈታሕኩ፡ ቀርነለው፡ </incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i3.4">
                                <title type="complete" ref="https://betamasaheft.eu/LIT7252FetahSeray#Sefanzer">Prayer for undoing charms</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ስፋንዝር፡ ፯ፍታሕ፡ ወዘርዝር፡ ሰዓር፡ ወመንዝር፡ አስማተ፡ ሥራይ፡</incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4604Salot">Ṣalot baʾǝnta ḥǝmāma qʷǝrṣat</title>
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ቍርጸት፡ ዌጼቤ፡ ዌጼቤ፡ ዌጼቤ፡ ዌፌኑ፡ ዌፌኑ፡ ዌፌኑ፡ ዌፌኑ፡ ዌፌኑ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>

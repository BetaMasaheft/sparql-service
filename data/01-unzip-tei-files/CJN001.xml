                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5821MagicPrayer">Ṣalot baʾǝnta māʿǝsara mǝqqaňňā wa-tankolaňňā</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩</hi> አምላክ፡
                          ጸሎት፡ በእንተ፡ ማዕሠረ፡ ምቀኛ፡ ወተንኮለኛ፡ ኢኮስ፡
                          አካስ፡ ኤፓ፡</incipit>
                          <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12863WalattaK">Walatta Kidān</persName>
                          is written at the end of the text.</note>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <title type="complete" ref="https://betamasaheft.eu/LIT5822MagicPrayer">Ṣalot baʾǝnta ḥǝmāma dam</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi> ፩ አምላክ፡
                          ጸሎት፡ በእንተ፡ ሕማመ፡ ደም፡ ወጽንስ፡ ለእግዚአብሔር፡
                          ምድር፡ በምልዓ፡ ዓለምኒ፡</incipit>
                            <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12863WalattaK">Walatta Kidān</persName>
                            is mentioned twice in the text.</note>
                        </msItem>
                        <msItem xml:id="ms_i3">
                          <title type="complete" ref="https://betamasaheft.eu/LIT5823MagicPrayer">Ṣalot baʾǝnta māʿǝsara dam wa-šotalāy</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi> ፩ አምላክ፡ ጸሎት፡
                          በእንተ፡ ማዕሠረ፡ ደም፡ ወሾተላይ፡ ብፁዕ፡
                            ብዕሲ፡ ዘኢሖረ፡ በምክረ፡ ረሲአን፡
                          </incipit>
                          <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12863WalattaK">Walatta Kidān</persName> is written at the end of the text.</note>
                        </msItem>
                        <msItem xml:id="ms_i4">
                          <title type="complete" ref="https://betamasaheft.eu/LIT5824MagicPrayer">Ṣalot baʾǝnta māʿǝsara ʾagānǝnt wa-ʿāyna ṭǝlā</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩</hi> ጸሎት፡ በእንተ፡
                          ማዕሠረ፡ አጋንንት፡ ወዓይነ፡ ጥላ፡ ሰላም፡ ለከ፡
                          ፋኑኤል፡ ስድድ፡ አጋንንተ፡ እምላዕሌየ፡</incipit>
                          <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12863WalattaK">Walatta Kidān</persName> is written at the end of the text.</note>
                        </msItem>

                        <msItem xml:id="ms_i5">
                          <title type="complete" ref="https://betamasaheft.eu/LIT5825MagicPrayer">Ṣalot baʾǝnta ʾǝǧa sabʾ wa-maftǝḥe śǝrāy</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi> ፩
                          አምላክ፡ ጸሎት፡ በእንተ፡ እጀ፡ ሰብእ፡ ወመፍትሔ፡ ሥራይ፡
                          በምናቴ <gap reason="lost"/> ስምከ፡ በሙራኤል፡</incipit>
                          <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12863WalattaK">Walatta Kidān</persName> is written at the end of the text.</note>
                        </msItem>

                    </msContents>

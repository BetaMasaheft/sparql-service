         <listBibl type="editions">
            <bibl corresp="http://zotero.org/groups/358366/items/5IZXUEI4"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1879Joel"/><title level="a">Der äthiopische Text des Joel</title><title level="m">Die Prophetie des Joel und ihre Ausleger von den ältesten Zeiten bis zu den Reformatoren</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Christian Friedrich August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></author><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Adalbert</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Merx</t:surname></editor><pubPlace>Halle</pubPlace><publisher>Buchhandlung des Waisenhauses</publisher><date>1879</date><biblScope unit="page">449-458</biblScope></bibl>

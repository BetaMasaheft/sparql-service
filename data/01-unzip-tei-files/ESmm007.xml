               <msContents>
                  <summary>I) Maṣḥafa krǝstǝnnā “Book of the Christening” (fols. 3r-48v)</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>- Text I is called Maṣḥafa ṭǝmqat in the incipit (<locus target="#3r">3r</locus>).</note>
                     <note>- Text I contains the embedded colophon (<locus target="#48v">48v</locus>) which states that the book, here called Maṣḥafa krǝstǝnnā, was
                        translated from Coptic and Arabic.</note>
                  </msItem>
               </msContents>

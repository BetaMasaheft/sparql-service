               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1"><locus from="3r" to="140r" facs="003">Fols 3r–140r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="3r" to="109r" facs="003">Fols 3r–109r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                  <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> with the simple modern system</note>
                  <note><locus target="#108r" facs="108">Fol. 108r</locus> <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> contains only the first of the four pluses that together make up the long version</note>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="109v" to="121r" facs="110">Fols 109v–121r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <note><locus target="#113r" facs="113">Fol. 113r</locus><ref target="#ms_i1.2" type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is here identified as
                  <q><foreign xml:lang="gez">ጸሎተ፡ ሐና፡ አመ፡ ሰሙኤል፡ ነቢይ፡</foreign>, Prayer of Hana, mother of Samuel, prophet</q></note>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="121r" to="127r" facs="121">Fols 121r–127r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>

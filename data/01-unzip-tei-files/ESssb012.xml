                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Second half of the 19th century.</date>
                        <seg type="rubrication">Nomina sacra; names of the donors, King,
                           Metropolitan and Patriarch; incipit of Text I; incipit of the prayers to
                           be read; directives to the ministers; elements of the punctuation signs;
                           elements of Ethiopic numerals. 
 On the incipit page of Text I (fol.
                           5r), a few lines are rubricated (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#63vb">ff. 63vb-64</locus>
                           <desc>rb: Ownership note.</desc>
                           <quote xml:lang="gez">
                              <locus target="#63vb">63vb</locus>: ዘአጥረያ፡ በንዋዩ፡ ትኩኖ፡ መድኃኒተ፡ ነ[<locus target="#64ra">64ra</locus>]ፍስ፡ ወሥጋ፡ ለአቡየ፡ ክንፈ፡ ሚካኤል፡ ወለአቡየ፡ ገብረ፡
                              ማርያም፡ ወለተ፡ ስላሤ፡ ወለተ፡ ስላሤ። ወለደ፡ ቂቁ፡ ወልደ፡ ማርያም፡ ወልደ፡ ገብርኤል፡ ገብረ፡
                              እግዚአብሔር፡ ወለተ፡ ማርያም፡ ወለተ፡ ጊዎርጊስ፡ ለዓለመ፡ ዓለም፡ አ[<locus target="#64rb">64rb</locus>]ሜን። የተገዛች፡ ፬ብር፡</quote>
                           <quote xml:lang="en"/>
                           <note> Partly written in Amharic; partly rubricated. The names of the
                              donors are mentioned as the owners of the Ms. The note mentions also
                              that the Ms. was bought for 4 birr. </note>
                        </item>
                        <item xml:id="e1">- Pen trials or writing exercises (?): <locus target="#3r">3r-</locus>v, 4r, 65v.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">Daily readings are indicated by the names of the
                              days of the week written in the upper margin, in a secondary hand:
                              ዘሰኑይ: <locus target="#5r">fol. 5r</locus>. ዘሠሉስ: <locus target="#12v">fol. 12v</locus>. ዘረቡዕ: <locus target="#20r">fol. 20r</locus>.
                              ዘሐሙስ: <locus target="#27r">fol. 27r</locus>. ዘዓርብ: <locus target="#36r">fol. 36r</locus>. ዘቀዳም: <locus target="#40v">fol.
                                 40v</locus>. ዘእሁድ: <locus target="#46r">fol.
                           46r</locus>.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards covered with reddish-brown tooled
                           leather.
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two pairs of chains of endband stitches
                           at the spine cover.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the reddish-brown leather
                           cover (at least 5 tools were used: double line fillet, triple line
                           fillet, double circle, cross hatching, criss-cross).</decoNote>
                     </binding>
                  </bindingDesc>

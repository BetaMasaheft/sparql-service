<msItem xml:id="ms_i3">
<locus from="67r" to="67v"/>
<title ref="https://betamasaheft.eu/LIT4327Basamay">Prayer</title>
<incipit xml:lang="en">በሰማይ፡ የሃሉ፡ ልብክሙ፡ ወለእመቦ፡ <choice><sic>ዘተሕየሰ፡</sic><corr>ዘተሓየሰ፡</corr></choice> ምስለ፡ ቢጹ፡ ይኅድግ፡ ሎቱ፡ እመቦ፡ ዘሐለየ፡ <choice><sic>ወ</sic><corr>በ</corr></choice>ልቡ፡ ኑፋቄ፡ ይትጋነይ፡</incipit>
<explicit xml:lang="gez">ወይጕየይ፡ እመአተ፡ እግዚአብሔር፨ እስመ፡ ዘይ<gap reason="lost"/>፡ ብርሃነ፡ አብ፡ ብርሃነ፡ ምስለ፡ ገብርከ፡<gap reason="omitted"/></explicit>
</msItem>

<msItem xml:id="ms_i4">
<locus target="#69"/>
<title/>
<incipit xml:lang="gez">ርእየት፡ ፍንዋን፡ ስብሐት፡ ለኪ፡ ማርያም፡ ለጽጌ፡ ሰማእት፤ ወፃድቃን፡ ስብሐት፤ ለኪ፡ ማርያም፡ ለጽጌ፡ ደነግል፡ ንጹሐን፡ እስመ፤
በቅድሜከ፡ ንጹሕ፡ ይትፌሳህ፡ ኅዙን፨</incipit>
</msItem>

<msItem xml:id="ms_i5">
<locus from="69v" to="70v"/>
<title xml:lang="en" ref="https://betamasaheft.eu/LIT5921SalamLaki">Salām-hymn to Dabra Libānos monastery</title>  
<incipit xml:lang="en">ሰላም፡ ለኪ፡ ደብረ፡ ሊባኖስ፡ ገነት፡ ዘመዓዘኪ፡ ዕረፍት፡ ዘአዕረፈ፡ ብኪ፡ ተክለ፡ ሃይማኖት፡ <gap reason="omitted"/> ሰላም፡ ለኪ፡
ዘባረከኪ፡ አምላክ፡ በየማነ፡ እዱ፡ ቅዱስ፡</incipit>
<explicit xml:lang="gez">ሰላም፡ ለኪ፡ ደቂቀ፡ አዳም፡ ኵልነ፡ ለእለ፡ ጸዋዕነ፡ ስምኪ፡ ደብረ፡ ሊባኖስ፡ አንተ፡ ሰአሊ፡ ለነ፡ ኀበ፡ አምላክኪ፡ ለኃጥአን፡ ነፍሳት፡
ኢይጽናዕ፡ ልብኪ፡ ይክፍለነ፡ እመርዔትኪ፡</explicit>
</msItem>


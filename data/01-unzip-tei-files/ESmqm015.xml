                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Late 19th – early 20th cent.</date>
                        <seg type="rubrication">Nomina sacra; Trinitarian formula; several groups of
                           lines on the incipit page of Text I and II, alternating with black lines;
                           elements of the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- The title of Text I is written in Gǝʿǝz and English in red and blue pen: <locus target="#2r">fol.  2r</locus> and 2v, መፅሓፈ፡ አብርሃም , and <locus target="#2r">fol.  2r</locus> "Book of Abriham(sic)" - Lacunas: fols. 10ra, 15va, 18va, 25va. - Scribbles in the margin: <locus target="#6r">fol.  6r</locus>, 9v, 11r, 12r, 24r, 30r, 32v, 42v, 45v.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Limp binding made of one piece of stiff leather
                           embracing the text block (possibly formerly spine protection); only front
                           board is present.
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible in the centre
                           fold of the quires, one close to the head and one close to the tail of
                           the codex.
 Quire VI (<locus from="43r" to="45v">43r-45v</locus>) is
                           reinforced by a parchment guard.</decoNote>
                     </binding>
                  </bindingDesc>

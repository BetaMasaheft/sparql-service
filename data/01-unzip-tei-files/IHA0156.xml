               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="68v">1r-68v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>باب في فضل الصلاة على النبي صلى الله عليه وسلم وشرف وكرم ومجد وعظم الله عظم قدر جاه محمد واناله قضلا لديه عظيما </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68v">-68v</locus>المخاطب بقوله عز وجل ثم جعلناك على شريعة من الامر فاتبغها فصل منه</explicit>
                     <note>Vocalized. The text ends fol. 68v. Fols 69r-71v are blank.</note>
                     <note/>
                  </msItem>
               </msContents>

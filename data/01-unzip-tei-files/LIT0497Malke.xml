      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0497</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለመግደላዊት፡ ማርያም፡ ስማ፨</l>
                  <l n="2">ለኢየሱስ፡ ዘርእየቶ፡ እምሐዋርያት፡ ቀዲማ፨</l>
                  <l n="3">ወለአንስት፡ ሰላም፡ ዘተሳተፋ፡ ድካማ፨</l>
                  <l n="4">እንዘ፡ ይትራወጻ፡ ኀበ፡ መቃብሩ፡ ለፌማ፨</l>
                  <l n="5">እንበለ፡ ያፍርሆን፡ ዘሌሊት፡ ግርማ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በሥምረተ፡ አብ፡ ክቡር፡ ወጠንኩ፡ ናሁ፨</l>
                  <l n="2">ዝክረ፡ ስምኪ፡ ኣየድዕ፡ በበ፡ ጾታሁ፨</l>
                  <l n="3">እስመ፡ አርአየኪ፡ ቅድመ፡ ኵሉ፡ ክርስቶስ፡ ትንሣኤሁ፨</l>
                  <l n="4">መግደላዊት፡ ማርያም፡ ለኅዙነ፡ ልብ፡ ተስፋሁ፨</l>
                  <l n="5">ሐዋርያት፡ በነገርኪ፡ ፍሥሓ፡ አብዝኁ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ወለሥዕርትኪ፡ ጸሊም፨</l>
                  <l n="2">ወለርእስኪ፡ ቅቡእ፡ ቅብአ፡ ሃይማኖት፡ መድምም፨</l>
                  <l n="3">መግደላዊት፡ ማርያም፡ ዘኵለንታኪ፡ ፍጹም፨</l>
                  <l n="4">ከሠተ፡ ለኪ፡ ትንሣኤሁ፡ ቅድመ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="5">አመ፡ ውስተ፡ ገነት፡ ቆመ፡ ፈጣሪ፡ ግሩም፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለትንሣኤ፡ ሥጋኪ፡ አመ፡ ደኃራዊ፡ ዕለት፨</l>
                  <l n="2">እንተ፡ ይከብት፡ ሱራፊ፡ በንፍሐተ፡ ቀርን፡ ዕምርት፨</l>
                  <l n="3">መግደላዊት፡ ማርያም፡ ማዕከለ፡ ጉቡኣን፡ አርድዕት፨</l>
                  <l n="4">ህየ፡ ሰበኪ፡ ዜና፡ ትንሣኤ፡ ቃል፡ ቅድስት፨</l>
                  <l n="5">እስከነ፡ አንከራ፡ አሐትኪ፡ አንስት፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ ዘአፈጸመኒ፡ ሊተ፨</l>
                  <l n="2">እንብብ፡ ዘለኪ፡ ውዳሴ፡ ከመ፡ ኪሩቤል፡ ስብሐተ፨</l>
                  <l n="3">መግደላዊት፡ ማርያም፡ እስእለኪ፡ ስእለተ፨</l>
                  <l n="4">ከመ፡ ትንግርኒ፡ ወታይድዕኒ፡ ብስራተ፨</l>
                  <l n="5">እንዘ፡ ትብሊ፡ ፍቁርየ፡ ኢትመውት፡ ሞተ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">መጠነ፡ አቅረብኩ፡ ለኪ፡ አምኃ፡ ስብሐት፡ ወውዳሴ፨</l>
                  <l n="2">እምበረከትኪ፡ ሕቀ፡ እንዘ፡ እከውን፡ ኀሣሤ፨</l>
                  <l n="3">መግደላዊት፡ ማርያም፡ ዘተአመንኪ፡ ቅድመ፡ ሥላሴ፨</l>
                  <l n="4">ለፀርየ፡ ፈርኦን፡ ብእሴ፡ ካሕድ፡ ወላዴ፡ ከዊን፡ አባሴ፨</l>
                  <l n="5">ውስተ፡ ቀላየ፡ ሀጕል፡ ያስጥሞ፡ ሥልጣንኪ፡ ሙሴ፨</l>
               </lg>
            </div>
         </div>
      </body>

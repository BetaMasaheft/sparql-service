                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date notBefore="1575" notAfter="1625">Late 16th - early 17th
                           century.</date>
                        <seg type="rubrication">Nomina sacra; incipits and headings of the texts;
                           postscripts to the Gospels of Mark, Luke and John; marginal notes
                           repeating chapter titles or indicating Gospel readings for certain
                           occasions; chi rho and crux ansata signs; elements of the punctuation
                           signs; chapter numbers and the word mǝʿǝraf.
 
 Incipits of the
                           Gospel texts are written alternately in red and black lines (fols. 4r,
                           56r, 88r, 138r).</seg>
                     </handNote>
                  </handDesc>

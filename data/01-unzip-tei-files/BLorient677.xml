                            <colophon xml:id="coloph1" xml:lang="gez">
                                <locus from="199v"/>
                                ተፈጸመ፡ ዝንቱ፡ መጽሐፈ፡ ገድለ፡ ሐዋርያት። ዘተጽሕፈ፡ በ፯ዓመተ፡ መንግሥቱ፡ ለንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ኢዮአስ፡</persName> መፍቀሬ፡ እግዚኢበሔር፤ 
                                በ<date calendar="world" when-custom="7257" notBefore="1764" notAfter="1765">፸፻ወ፪፻፶ወ፯ዓመተ፡ ዓለም።</date>
                                ወበ<date when-custom="7043">፯፻፵ወ፫ተረፈ፡ ዓመተ፡ ቀመር፡</date> በ<date calendar="grace" when-custom="1757">፲፻ወ፯፻፶ወ፯ዓመተ፡ ምሕረት፡</date>
                                ወመድኃኒት፡ ዘውእቱ፡ መዋዕለ፡ ሥጋዌሁ፡ ለእግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ 
                                ኢየሱስ፡ ክርስቶስ፡ ዘገብሮ፡ በእንተ፡ መድኃኒትነ፡ በኪነ፡ ጥበቡ፡ መንክር፡ 
                                <seg type="supplication">ለጸሐፎ፡ ኃጥእ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS12881Tewodotos">ቴዎዶጦስ፡</persName> ወለዘአጽሐፎ፡ 
                                    <persName role="patron" ref="https://betamasaheft.eu/PRS12882Awsegneyos"><roleName type="title">አባ፡</roleName> አውስግንዮስ፡</persName> ወለዘአንበቦ፡ ወለዘተርጐሞ፡ ወለዘሰምዓ፡ ቃላቲሁ፡ 
                                ኅቡረ፡ ይምሐሮሙ፡ በመንግሥተ፡ ሰማያት፡ አሜን። </seg>
                                ወበእንተዝ፡ አነ፡ 
                                <persName ref="https://betamasaheft.eu/PRS12882Awsegneyos">አውስግንዮስ፡</persName> ኃጥእ፡ ወአባሲ፡ ላዕከ፡ እግዝእትነ፡ ማርያም፡ ዘወሀባ፡ ኪዳነ፡ በእንተ፡ መድኃኒተ፡ ዓለም። አጽሐፍኩ፡ አነ፡ 
                                ዘንተ፡ መጽሐፈ፡ ገድሎሙ፡ ለሐዋርያት፡ ከመ፡ ይኩነኒ፡ መርሐ፡ 
                                ለመንግሥተ፡ ሰማያት።

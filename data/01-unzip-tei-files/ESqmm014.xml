                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, red.</seg>
                        Scribe: ʿAsratä Māryām. ʿAsratä
                        Māryām is mendioned as the scribe in the supplication formula, <locus target="#40v">40v</locus>.<date>19th century</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>አ፡</abbr> for <expan>አምሕለከ፡ </expan> (<locus from="5v" to="11r">5v-11r</locus>)</item>
                           <item>
                              <abbr>መ፡</abbr> for <expan>መሐልኩ፡ </expan> (<locus from="34r" to="38v">34r-38v</locus>)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Texts I-IV and of their
                           sections; initial words of prayers and theirs abbreviations; elements of
                           the punctuation signs; elements of Ethiopic numerals.
 On the incipit
                           page of Texts I-II (fols. 1r, 41r), a few lines are rubricated
                           alternating with black lines.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">- <locus target="#1r">1r</locus>: coloured
                        (black, red) ornamental band; geometric motifs.</decoNote>
                     <decoNote type="frame" xml:id="d2">- <locus target="#41r">41r</locus>: coloured
                        (black, red) ornamental band; geometric motifs.</decoNote>
                     <decoNote type="frame" xml:id="d3">- <locus target="#54v">54v</locus>: coloured
                        (black, red) ornamental band; geometric motifs.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- Supplication for the scribe and donor, written less carefully, but still by the main hand: fols. 74v-75r. - Doodles and pen trials: fols. 75r, 76r, 76v.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards (possibly re-used).
 Two pairs
                           of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible in the centre
                           fold of the quires, one close to the head, one close to the
                           tail.</decoNote>
                        <decoNote xml:id="b5">None.</decoNote>
                     </binding>
                  </bindingDesc>

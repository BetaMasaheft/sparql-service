                  <decoNote type="miniature" xml:id="d3"><locus target="#88v" facs="091">Fol. 88v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with a broken water jug</desc></decoNote>
                  <decoNote type="miniature" xml:id="d4"><locus target="#89r" facs="091">Fol. 89r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>

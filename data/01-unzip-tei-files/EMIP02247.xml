                  <decoNote type="miniature" xml:id="d6"><locus target="#91r" facs="093">Fol. 91r</locus><desc>An <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> standing on church stabbing creature (demon?) with spear</desc></decoNote>
                  <decoNote type="miniature" xml:id="d7"><locus target="#93v" facs="096">Fol. 93v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John stand beside the <term key="cross" ana="#cross"/></desc></decoNote>
                  <decoNote type="miniature" xml:id="d8"><locus target="#94r" facs="096">Fol. 94r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref></desc></decoNote>

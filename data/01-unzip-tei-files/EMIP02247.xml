                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#ms_i1">Fols. ms_i1, </locus>
                    <locus target="#1r #6r #11r #16r #21v #28v #33v" facs="003 008 013 018 024 031 036">1r, 6r, 11r, 16r, 21v, 28v, 33v</locus>
                    <desc>Headings for the days of the week the week by a later hand, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday</desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="GuestText">
                    <locus target="#iv(erso) #iir(ecto) #iiv(erso)" facs="002 003">Fols. iv(erso), iir(ecto), iiv(erso)</locus>
                    Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa
                                                  saʿātāt</title>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="Asmat">
                    <locus target="#91v #92r #92v #93r" facs="094 095">Fols. 91v, 92r, 92v, 93r</locus>
                    Asmat prayer for protection which the Lord prayed, written in a later hand
                    Incipit: <foreign xml:lang="gez">ጸሎት፡ ዘጸለየ፡ እግዚአ፡ ዘቀተልከ፡ አንበሳ፡ ለዠብ፡ ወለሐነር፡ ወለነምር፡፡ይትአስር፡ ጉርዔሆሙ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc type="OwnershipNote">
                    <locus target="#16r" facs="018"> f. 16r and passim</locus>
                    mentions the owner Wäldä Ḥäna (<foreign xml:lang="gez">ወልደ፡ ሐና፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc type="OwnershipNote">
                    <locus target="#37r" facs="039"> f. 37r and passim</locus>
                    a secondary owner is listed Wäldä Sämaʿǝt (<foreign xml:lang="gez">ወልደ፡ ሰማዕት፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                      <locus target="#90" facs="092">Fol. 90</locus> is a piece of linen stitched into the codex to protect the miniatures.
                      There is a green textile label that reads <q>“Best Turkey Red.”</q>
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#16 #81" facs="018 083">Fols. 16, 81</locus>
                    red string sewn into the fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#69" facs="071">Fol. 69</locus>
                    green string sewn into the fore edge as navigation system
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                      words of text are written interlinearly (<locus target="#3v #4v #6r #6v #7r" facs="006 007 008 009">folss. 3v, 4v, 6r, 6v, 7r, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#24r #45v #46v" facs="026 048 049">24r, 45v, 46v, </locus>);
                      lines of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted (<locus target="#15r #17r #25v #32r #38v" facs="017 019 028 034 041">15r, 17r, 25v, 32r, 38v, </locus>, etc.);
                      erasure markings are visible (<locus target="#16v #45r" facs="019 047">16v, 45r, </locus>);
                      text has been removed (<locus target="#13v #30r #34v #35r #39r" facs="016 032 037 041">13v, 30r, 34v, 35r, 39r</locus>, etc.)
                    </desc>
                    </item>
                  </list>

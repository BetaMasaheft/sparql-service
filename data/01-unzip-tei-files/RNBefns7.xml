               <msContents>

                  <summary> </summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="63r"/>

                     <title type="complete" ref="https://betamasaheft.eu/LIT3179Revela">Revelation of John</title>
                     <textLang mainLang="gez"/>
                     <note>The text is not divided into chapters.</note>
                     <incipit xml:lang="gez">
                       <locus target="#1r"/>ዘዮሐንስ፡ ኤጲስ፡ ቆጶስ፡ ዘቍስጥንጥንያ፡ መጥሮጶሊስ፡
                       አመ፡ ሃለዎ፡ ይስደድ። ረእዩ፡ ለዮሐንስ፡</incipit>
                     <explicit xml:lang="gez">
                    <locus target="#63r"/>
                    ዝየ፡ ተፈጸመ፡ ራእየ፡ ዮሐንስ፡ አቡቀለምስስ፡ ዘውእቱ፡ በሂል፡ ዘርእየ፡ በሕይወቱ፡ ራእየ።
                    ወተጽሕፈ፡ ለአቡነ፡ ዮሐንስ፡ ለገብረ፡ እግዚአብሔር፡ ወሊተኒ፡ ለገብርከ፡ ዮሐንስ፡ ይምሐረኒ፡ በጸሎትከ፡ ለዓለመ፡ ዓለም፡ አሜን።
                    </explicit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="63v" to="73v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">በእንተ፡ ትምህርተ፡ ኅቡአት፡</title>
                     <textLang mainLang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="74r" to="81v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">ኪዳን፡ ዘእግዚእነ፡ ኢየሱስ፡
                     ክርስቶስ፡</title>
                     <textLang mainLang="gez"/>
                  </msItem>

                  <msItem xml:id="ms_i1.4">
                     <locus from="74r" to="81r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4663Eqabanni">ʿƎqabanni (longer version)</title>
                     <note>The prayer was received from the sky
                       by a nobleman, <foreign xml:lang="gez">makʷannǝn</foreign>in the city of Franks,
                        <foreign xml:lang="gez">ʾafrǝngi</foreign>,
                the indication in <bibl corresp="http://zotero.org/groups/358366/items/T6UTP6JE"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Turaev1906rukopisi"/><title level="m">Ėfiopskija rukopisi v S.-Peterburgě</title><title level="s">Pamjatniki ėfiopskoj pis'mennosti</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Boris</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Turaev</t:surname></author><pubPlace>Sanktpeterburg</pubPlace><publisher>Tipografija imperatorskoj Akademii Nauk</publisher><date>1906</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Pamjatniki ėfiopskoj pis'mennosti</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">3</t:biblScope></series><biblScope unit="volume">3</biblScope><note type="url">http://digitale-sammlungen.ulb.uni-bonn.de/content/titleinfo/2104581</note><citedRange unit="page">23</citedRange></bibl>
                     </note>
                  </msItem>

               </msContents>


                    <decoNote type="frame" xml:id="d1">
                      Decorative designs: <locus target="#126r" facs="127">fol. 126r</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red);
                      <locus target="#16v #138r #161r" facs="018 139 162">16v, 138r, 161r, </locus> (line of pairs of black and red dots);
                      <locus target="#24v #25r #35r #42v #58r #83r #94v #108r #112r #118v" facs="026 036 044 059 084 096 109 113 120">24v, 25r, 35r, 42v, 58r, 83r, 94v, 108r, 112r, 118v, </locus> (line of black dots);

               <t:occupation type="academic">scholar</t:occupation>
               <t:nationality type="Poland"/>
               <t:faith type="notSpecified"/>
               <t:birth when="1906"/>
               <t:floruit notBefore="1930" notAfter="2006">He was one of the most prominent ethiopisants of the 20th century.
                  He published over 300 books, articles and reviews. 
                  He was an accomplished lexicographer and philologist. His interests lay mostly in the field of descriptive and comparative linguistics, but also philology and ethnography. </t:floruit>
               <t:death when="2006"> He died four days after his 100th birthday in <t:date>2006</t:date>. </t:death>
            </t:person>
            

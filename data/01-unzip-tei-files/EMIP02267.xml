                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Incomplete at the beginning (with a painting over the first folio)</note>
                  </msItem>
                  </msContents>

                    <history>
                        <origin>
                            <origPlace>
                        <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</placeName>
                     </origPlace>
                            <origDate notBefore="1830" notAfter="1832"/>
                        </origin>
                        <provenance>This manuscript, one of the earliest known Tigrinya manuscripts, was produced possibly for <persName role="patron" ref="https://betamasaheft.eu/PRS4722Gobat">Samuel Gobat</persName>, see
                            <bibl corresp="http://zotero.org/groups/358366/items/BRDJ9JFF"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Rueppell1840Reise"/><title level="m">Reise in Abyssinien</title><author><forename>Eduard</forename><surname>Rüppell</surname></author><pubPlace>Frankfurt am Main</pubPlace><publisher>Gedruckt auf Kosten des Verfassers, und in Commission bei Siegmund Schmerber</publisher><date>1840</date><biblScope unit="volume">II</biblScope><note type="url">https://archive.org/details/reiseinabyssinie02rupp</note><note type="tags"><note type="tag">bm:Rueppell1840Reise</note></note><note type="tag">bm:Rueppell1840Reise</note><citedRange unit="page">408</citedRange></bibl>. 
                            It was bought by <persName ref="https://betamasaheft.eu/PRS8249Ruppell">Eduard Rüppell</persName> between <date>1831</date> and <date>1834</date> in <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</placeName> and given by him
                            after his return to the <placeName ref="https://betamasaheft.eu/INS0317Frank">Stadtbibliothek Frankfurt</placeName>. 
                            While being transported from the Soviet to the American occupation zone on the  <date>3rd July 1945</date>, it fell from a truck, and remained lost in the following decades. 
                            It was returned in <date>1979</date> to the Landesbibliothek Coburg and in <date>1980</date> finally restituted to the <placeName ref="https://betamasaheft.eu/INS0317Frank">Universitätsbibliothek Johann Christian Senckenberg</placeName> .
                            See also <bibl corresp="http://zotero.org/groups/358366/items/JJP3KQK2"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Toennies2012Verlust"/><title level="a">Verlust und Wiederauffindung äthiopischer Handschriften aus der Sammlung Rüppell</title><title level="j">Aethiopica</title><author><forename>Bernhard</forename><surname>Tönnies</surname></author><date>2012</date><biblScope unit="volume">15</biblScope><biblScope unit="page">228-232</biblScope><note type="url">http://journals.sub.uni-hamburg.de/aethiopica/article/view/669</note><note type="tags"><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Library</note><note type="tag">bm:Toennies2012Verlust</note><note type="tag">Rüppell</note></note><note type="tag">History</note><note type="tag">Manuscripts</note><note type="tag">Library</note><note type="tag">bm:Toennies2012Verlust</note><note type="tag">Rüppell</note></bibl>.
                    </provenance>
                    </history>

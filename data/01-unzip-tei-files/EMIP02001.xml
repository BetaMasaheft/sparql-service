               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="161v" facs="003">Fols 1r–161v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Gate of Light <locus target="#161" facs="163">fols. 161, </locus> has been dislocated from its proper place after <locus target="#156" facs="159">156</locus>
                     <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters</note>
                     </note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">ii + 161</measure>
                           <measure unit="quire">Protection quire + 5</measure>
                           <dimensions type="outer" unit="mm">
                              <height>168</height>
                              <width>145</width>
                              <depth>77</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>After quire 5 there are many loose folios; the quires have been restitched, and it is impossible to discern the original quire structure.</note>
                          <list>
                            <item xml:id="q1" n="a">
                              <dim unit="leaf">2</dim>
                              <locus from="i" to="ii" facs="001">Fols i–ii</locus>
                              <note>Folio stubs are visible between <locus target="#i #ii" facs="002">fols. i, ii</locus>.</note>
                              Protection Quire
                            </item>
                            <item xml:id="q2" n="1">
                              <dim unit="leaf">10</dim>
                              <locus from="1" to="10" facs="003">Fols 1–10</locus>
                              Quire 1
                            </item>
                            <item xml:id="q3" n="2">
                              <dim unit="leaf">10</dim>
                              <locus from="11" to="20" facs="013">Fols 11–20</locus>
                              Quire 2
                            </item>
                            <item xml:id="q4" n="3">
                              <dim unit="leaf">10</dim>
                              <locus from="21" to="30" facs="023">Fols 21–30</locus>
                              Quire 3
                            </item>
                            <item xml:id="q5" n="4">
                              <dim unit="leaf">10</dim>
                              <locus from="31" to="40" facs="033">Fols 31–40</locus>
                              Quire 4
                            </item>
                            <item xml:id="q6" n="5">
                              <dim unit="leaf">10</dim>
                              <locus from="41" to="50" facs="043">Fols 41–50</locus>
                              Quire 5
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                         <dimensions type="margin" unit="mm">
                           <dim type="top">15</dim>
                           <dim type="bottom">29</dim>
                           <dim type="right">24</dim>
                           <dim type="left">13</dim>
                         </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="21 22">
                         <locus from="1r" to="144v" facs="003">Fols 1r–144v</locus>
                       </layout>
                       <layout columns="2" writtenLines="21 22">
                         <locus from="145r" to="161v" facs="147">Fols 145r–161v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="rubrication">
                           <foreign xml:lang="gez">ማርያም፡</foreign>
                        </seg>
                        <desc>The word God is not rubricated in the first three works; the word Mary is rubricated in the final two works</desc>
                        <desc>Columetric layout of text: <locus target="#126r #126v" facs="128 129">folss. 126r, 126v, </locus> (Ps. 150); <locus target="#135r #135v #136r" facs="137 138">135r, 135v, 136r</locus> (tenth Biblical Canticle)</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="frame" xml:id="d1">
                  Decorative designs:
                  <locus target="#15v #55v #83v #126v #138v #160v" facs="018 058 086 129 141 163">folss. 15v, 55v, 83v, 126v, 138v, 160v, </locus> (line of alternating red and black dots);
                  <locus target="#97r #113v #120r" facs="099 116 122">97r, 113v, 120r</locus> (line of black dots)
                  </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                    <item xml:id="e1">
                   <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>
                   <desc>
                   excerpts from the alphabet in the various orders (fidäl)
                   </desc>
                   </item>
                    <item xml:id="a1">
                    <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                    <desc type="GuestText">
                    An excerpt of <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur#Psalm1">Psalms of
                                                  David, Psalm1</title> as a pen trial
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#55v" facs="058">Fol. 55v</locus>
                    <desc>
                    An attempt to copy, in a crude hand, the text in the upper part of the folio
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#ir(ecto)" facs="002">Fol. ir(ecto)</locus>
                    <desc>
                    blank
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>It is unclear what manuscript this is in the insurance hand list
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#15 #23 #77 #97 #110 #126" facs="017 025 079 099 112 128">Fols. 15, 23, 77, 97, 110, 126</locus>
                    <desc>blue yarn is sewn into the fore edge as navigation system</desc>
                    </item>
                    <item xml:id="e6">
                    <locus target="#120" facs="122">Fol. 120</locus>
                    <desc>brown string is sewn into the fore edge as navigation system</desc>
                    </item>
                    <item xml:id="e7">
                    <locus target="#42r #64v #70r #127r" facs="044 067 072 129">Fols. 42r, 64v, 70r, 127r</locus>
                    <desc>
                    etc., words of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <locus target="#16v #23r #39r #59r #81r" facs="019 025 041 061 083">Fols. 16v, 23r, 39r, 59r, 81r</locus>
                    <desc>
                    etc., lines of text are written interlinearly
                    </desc>
                    </item>
                    <item xml:id="e9">
                    <locus target="#13r #18r #19v #20r #25v" facs="015 020 022 028">Fols. 13r, 18r, 19v, 20r, 25v</locus>
                    <desc>etc., text has been removed</desc>
                    </item>
                     </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

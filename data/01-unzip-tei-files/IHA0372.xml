                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="143v">1r-143v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>الْحَمْدُ لِلَّهِ الَّذِي أَنزَلَ عَلَى عَبْدِهِ الْكِتَابَ وَلَمْ يَجْعَل لَّهُ عِوَجًا

قَيِّمًا لِّيُنذِرَ بَأْسًا شَدِيدًا مِن لَّدُنْهُ وَيُبَشِّرَ الْمُؤْمِنِينَ الَّذِينَ يَعْمَلُونَ الصَّالِحَاتِ أَنَّ لَهُمْ أَجْرًا حَسَنًا

مَاكِثِينَ فِيهِ أَبَدًا<note>18.1</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#143v">-143v</locus>سورة البينة مكية .بسم الله الرحمن الرحيم

.لَمْ يَكُنِ الَّذِينَ<note>98:1</note>
                     </explicit>
                     <note>Vocalized.  </note>
                     <note/>
                  </msItem>

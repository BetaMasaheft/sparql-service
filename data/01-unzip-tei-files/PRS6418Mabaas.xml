               <persName xml:lang="gez" xml:id="n1" type="monastic">መባአ፡ ጽዮን፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Mabāʾa Ṣǝyon</persName>
               <persName xml:lang="gez" xml:id="n2" type="monastic">መብአ፡ ጽዮን፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Mabǝʾa Ṣǝyon</persName>
               <persName xml:lang="gez" xml:id="n3" type="birth">ተክለ፡ ማርያም፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Takla Māryām</persName>
               <persName>
                  <roleName type="title">ʾabuna</roleName>
               </persName>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               
               
               <residence/>
               <floruit> He was a 15th century monk and saint. He was born from a certain nobleman <persName ref="https://betamasaheft.eu/PRS4948Habtase">Habta Ṣǝyon</persName> 
                  who was from a lineage of
                  <persName ref="https://betamasaheft.eu/PRS8487Samuel"> 
                     <roleName type="title">nǝbura ʾǝd</roleName>
                     Sāmuʾel of ʾƎndagabṭan</persName>. 
                  He was trained in chanting, writing and painting </floruit>
               <death/>
            </person>  
            

<locus target="#8r"/>
<desc><term key="angel" ana="#angel">Archangel</term> in triumph over Satan.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d2">
<locus target="#8v"/>
<desc><term key="angel" ana="#angel">Archangel</term> with a <term key="sword" ana="#sword">sword</term> overseeing sinners in hell.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d3">
<locus target="#103v"/>
<desc>Annunciation with a female <term key="donordepiction" ana="#donordepiction">donor</term> prostrating to Virgin Mary.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d4">
<locus target="#134v"/>
<desc><term key="angel" ana="#angel">Archangel</term> with a female <term key="donordepiction" ana="#donordepiction">donor</term> in prostration.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d5">
<locus target="#182v"/>
<desc><term key="angel" ana="#angel">Archangel</term> killing a sea monster.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d6">
<locus target="#183r"/>
<desc><term key="angel" ana="#angel">Archangel</term> cures a man's blindness.</desc>
</decoNote>

<decoNote type="miniature" xml:id="d7">
<locus target="#183v"/>
<desc>In the upper register <term key="angel" ana="#angel">archangel</term> saving people at sea, in the lower - healing a man possessed by a <term key="demon" ana="#demon">demon</term>.</desc>
</decoNote>


</decoDesc>


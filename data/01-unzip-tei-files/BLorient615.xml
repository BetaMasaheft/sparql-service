  <list>
    <item xml:id="a1">
    <locus target="#2r"/>
      <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
              <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
          <q xml:lang="gez">ድርሳነ፡ ሚካኤል፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam"> ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName></q>
</item>

<item xml:id="a2">
<locus target="#179v"/>
<desc type="MixedNote">List of drugs</desc>
<q xml:lang="am"><seg part="I">ኈልቈ፡ መድኃኒት፤ ዕፀ፡ ምናሄ፤ ዕፀ፡ ዘዌ፤ አሜራ፤ ሰመግ፤ ፅፍሬና፤ ዘርጫ፡ የምድር፡ እምባይ፤ በቶ፤ አሰረት፤ የምድር፡ ቁግ፤ የመካን፡ እንዶድ፡ ስር፤</seg></q>
</item>

<item xml:id="a3">
<locus target="#111v"/>
<desc type="Supplication">Name of the first owner erased; earliest substitution <foreign xml:lang="gez"><persName role="owner" ref="https://betamasaheft.eu/PRS13461Anagda">አናግደ፡
ወለተ፡ ሚካኤል፡</persName></foreign> e. g. on f. 111v, but also erased.</desc>
</item>

<item xml:id="a4">
<locus target="#79r"/>
<desc type="Supplication">According to the supplication, the manuscript was commissioned by <foreign xml:lang="gez"><persName role="patron" ref="https://betamasaheft.eu/PRS13462AmataD">ዓመተ፡ ድንግል፡</persName></foreign>during the reign
of emperor <persName ref="https://betamasaheft.eu/PRS2377Bakaffa">Bakāffā</persName>.</desc>
<q xml:lang="gez"><seg part="I">በረከቱ፡ ለቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ ወሊቀ፡ ሐራ። ይኩኖ፡ ለንጉሥነ፡ በካፋ፡ ዘመዊእ፡ ጌራ። ወያብኦ፡ ሀገረ፡ ዓይነ፡ ንስር፡ እለ፡ ኢነጸራ።
ነፍሳተ፡ ጻድቃን፡ ኀበ፡ የሐድሩ። አመ፡ ይሠራዕ፡ ምሳሐ፡ ለጽዮን፡ ማኅበራ። ወዓዲ፡ ዘአጽሐፈ<add place="above">ት</add>፡ ዘንተ፡ መጽሐፈ፡ ዓመተ፡ ድንግል፡ በእንተ፡ ፍቅሩ፡<sic/> ለሚካኤል፡ መልአከ፡ ቅዳሴ፡ ይኅድር።
በረከቱ፡ ላዕሌሀ፡</seg></q>
</item>


                    <msItem xml:id="ms_i3">
                      <locus from="17r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT4723TarikaWaldaAmid">Tārika Walda ʾAmid (general record)</title>
                      <textLang mainLang="gez"/>
                      <note>Apparently this is an abbreviated version</note>
                      <incipit xml:lang="gez"><locus target="#17r"/>በስመ፡ እግዚአብሔር፡ መሓሪ፡ ወመስተሣህል። ንዌጥን፡ በጽሒፈ፡ መጽሐፍ፡
                        ዘይነግር፡ በቃል፡ ዓመታተ፡ ዓለም፡ ዘአስተጋብአ፡ አብ፡ ክቡር፡ ወትሩፍ፡ ጊዮርጊስ፡ ወልደ፡ አሚድ፡ ዘብሔረ፡ ግብጽ፡
                        ጸሎቱ፡ ወበረከ<add>ቱ፡ ይሀሉ፡ ምስለ፡ ፍቁሩ፡ ዘአምላክ፡ ዓለመ፡ ዓለም፡ አሜን።</add>
                      </incipit>
                      <explicit xml:lang="gez"><locus target="#19r"/>
                      <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ኢያሱ፡</persName> ወልዱ፡
                      ዘስመ፡ መንግሥቱ፡ አድያ<sic>መ</sic>፡ ሰገድ፡ ነግሠ፡ <add>፳ወ፬ ዓመተ፡</add>
                    </explicit>

            <t:div type="bibliography">
                <t:listBibl type="editions">
                    <t:bibl corresp="http://zotero.org/groups/358366/items/73NH4QWK"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:HEpA"/><title level="a">The &lt;hi rend="italics"&gt;History of the Episcopate of Alexandria&lt;/hi&gt; (&lt;hi rend="italics"&gt;HEpA&lt;/hi&gt;): &lt;hi rend="italics"&gt;Editio minor&lt;/hi&gt; of the fragments preserved in the &lt;hi rend="italics"&gt;Aksumite Collection&lt;/hi&gt; and in the &lt;hi rend="italics"&gt;Codex Veronensis&lt;/hi&gt; LX (58)</title><title level="j">Adamantius</title><author><forename>Alessandro</forename><surname>Bausi</surname></author><author><forename>Alberto</forename><surname>Camplani</surname></author><date>2016</date><biblScope unit="volume">22</biblScope><biblScope unit="page">249-302</biblScope><note type="url">https://www.academia.edu/33507697/The_History_of_the_Episcopate_of_Alexandria_HEpA_Editio_minor_of_the_fragments_preserved_in_the_Aksumite_Collection_and_in_the_Codex_Veronensis_LX_58_</note><note type="tags"><note type="tag">AdW</note><note type="tag">TraCES</note><note type="tag">bm:HEpA</note></note><note type="tag">AdW</note><note type="tag">TraCES</note><note type="tag">bm:HEpA</note></t:bibl>
               

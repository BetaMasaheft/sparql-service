        <body>
            <div type="bibliography">
                
                <listBibl type="editions">
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                    <bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Marius</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><citedRange unit="item">339</citedRange></bibl>
                </listBibl>
            </div>
            <div type="edition" xml:lang="gez">
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">እሰግድ፡ ለፅንሰትከ፡ ወለልደትከ፡ መድምም፨</l>
                        <l n="2">እምድንጋሌ፡ ሥጋ፡ ሕቱም፨</l>
                        <l n="3">ኢየሱስ፡ ክርስቶስ፡ መድኃኔ፡ ዓለም፨</l>
                        <l n="4">ልብየ፡ አንቅሕ፡ ወነፍስየ፡ ለስብሐቲከ፡ አዳም፨</l>
                        <l n="5">ለሥጋየሰ፡ አኀዞ፡ ድካም፨</l>
                    </lg>
                    <lg type="stanza" n="2"><note>same as <ref type="work" corresp="https://betamasaheft.eu/LIT3059RepCh339">Hymn to Jesus Christ</ref></note>
                        <l n="1">እሰግድ፡ ለዝክረ፡ ስምከ፡ መልአከ፡ ምሥጢር፡ ዘተርጐሞ፨</l>
                        <l n="2">ቅድመ፡ ማርያም፡ ወዮሴፍ፡ አመ፡ ወርኀ፡ ብስራት፡ ወተሳልሞ፨</l>
                        <l n="3">መድኃኔ፡ ዓለም፡ ክርስቶስ፡ ስመ፡ ስብሐቲከ፡ ሶበ፡ አደሞ፨</l>
                        <l n="4">ጳውሎስ፡ ከልሀ፡ ወይቤ፡ በዐውደ፡ ኔሮን፡ ቀዊሞ፨</l>
                        <l n="5">መኑ፡ ያኀድገነ፡ ለክርስቶስ፡ ስሞ፨</l>
                    </lg>
                    <lg type="stanza" n="30">
                        <l n="1">እሰግድ፡ ለትንሣኤከ፡ እንዘ፡ ተኀድገ፡ መንዲለ፨</l>
                        <l n="2">ወሰበነኒ፡ እንተ፡ ባሕቲቱ፡ ጥብሉለ፨</l>
                        <l n="3">መድኃኔ፡ ዓለም፡ ክርስቶስ፡ ዘኢገፋዕከ፡ መስቀለ፨</l>
                        <l n="4">አንሥአኒ፡ በትንሣኤከ፡ ድኅረ፡ ሥጋየ፡ ተቀትለ፨</l>
                        <l n="5">ወበዕርገትከ፡ አዕርገኒ፡ ላዕለ፨</l>
                    </lg>
                    <lg type="stanza" n="31">
                        <l n="1">እሰግድ፡ ለዕርገትከ፡ ማሕተመ፡ ነገር፡ ወምሳሌ፨</l>
                        <l n="2">ወለመጽአትከ፡ ካዕበ፡ በደመና፡ ሰማይ፡ ሉዓሌ፨</l>
                        <l n="3">መድኃኔ፡ ዓለም፡ ክርስቶስ፡ ምስለ፡ አባግዒከ፡ ሰብዓ፡ ክላሌ፨</l>
                        <l n="4">አቁመኒ፡ በየማንከ፡ እንዘ፡ ታረስአኒ፡ ወይሌ፨</l>
                        <l n="5">አመ፡ በፀጋምከ፡ ደርገ፡ ታቀውም፡ አጣሌ፨</l>
                    </lg>
                    <lg type="stanza" n="32">
                        <l n="1">ሙሴ፡ ነቢይ፡ በገዳም፡ ሶበ፡ ሞተ፨</l>
                        <l n="2">መጠነ፡ በከይዎ፡ ሕዝቡ፡ ሠላሳ፡ ዕለተ፨</l>
                        <l n="3">መድኃኔ፡ ዓለም፡ ክርስቶስ፡ እስመ፡ አበ፡ ነፍስየ፡ አንተ፨</l>
                        <l n="4">አወትር፡ ብሂሎትየ፡ እስከ፡ እትከደን፡ መሬተ፨</l>
                        <l n="5">አምላከ፡ ሰማይ፡ እፎ፡ ተሰቀልከ፡ ሊተ፨</l>
                    </lg>
                    <lg type="stanza" n="33">
                        <l n="1">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ሰብእ፡ ወመላእክት፨</l>
                        <l n="2">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ጽዱላት፡ ከዋክብት፨</l>
                        <l n="3">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ዕለታት፡ ወአዝማናት፨</l>
                        <l n="4">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ይደሉ፡ ለመስቀልከ፡ ሕይወት፨</l>
                        <l n="5">እስመ፡ በመስቀልከ፡ ድኅነ፡ ኵሉ፡ ፍጥረት፨</l>
                    </lg>
                </div>
            </div>
            
            <div xml:lang="gez" type="edition">
                <note>The following incipit is taken from <ref type="mss" corresp="https://betamasaheft.eu/EMML6251">Addis ʿAläm, ʾAddis ʿĀlam Māryām, MS EMML no. 6251</ref>.</note>
                <div type="textpart" subtype="incipit">
                    <ab>መልክዓ፡ መድኃኔ፡ ዓለም፡ <date>መጋቢት፡ ፳፯፡</date>
                        <lg n="1" type="stanza" xml:id="s1">
                            <l n="1">እሰግድ፡ ለጽንሰትከ፡ ወለልደትከ፡ መድምም።</l>
                            <l n="2">እምድንጋሌ፡ ሥጋ፡ ኅቱም፡</l>
                            <l n="3">ኢየሱስ፡ ክርስቶስ፡ መድኃኔ፡ ዓለም።</l>
                            <l n="4">ልብየ፡ አንቅህ፡ ወነፍስየ፡ ለስብሐቲከ፡ አዳም፡</l>
                        </lg>
                        <lg n="2" type="stanza" xml:id="s2">
                            <l n="1">ለሥጋየስ፡ አኃዞ፡ ድካም።</l>
                        </lg>
                       </ab>
                </div>
            </div>
        </body>

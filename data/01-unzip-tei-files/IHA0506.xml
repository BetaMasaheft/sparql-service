               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="24v">1v-24v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1074IHA">رسالة عبادية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله الذي انزل على عبده الكتب وبدأئه من العمل باك داي ووعد على ذلك الثواب واوعد على تركه العقاب أحمده على الهام المتاب وأسئله التوفيق لك للصواب وأشهد ان لا اله الا الله شهادة من خلع الارباب واستعا ينورا لكتب وأشهد أن محمد عبد ورسوله المبعوث بالجزا والثواب المنعوت بسوره الا خراب صلى الله عليه وسلم تسليما كثيرا 
اما بعد فقد امر الله عباده باداب المجاورة قيل المجالسة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>وقيل شال أعرابي قراه منصورا اعلم الناس فقال بمن وجدت هذا قال لم ائق شيا ا تعلمه ولم أبخل بشيء اعلمه فقال فذلك متعت بفهمك وعلمك فبورك لك فى علمك </explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

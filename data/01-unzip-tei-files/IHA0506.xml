                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a3_1273">
                           <locus target="#3v">-3v</locus>
                           <q xml:lang="ar">أبي [متصف] بالعقل وذلك بأن يحسن من ءسماء اليه ويعطى من حرمه يصل من قطعه وإلى غير ذلك</q>
                           <note>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a1_1273">
                           <locus target="#2v">-2v</locus>
                           <q xml:lang="ar">لعله على القول المرجوح في مذهب الامام الشافعي رضي لله</q>
                           <note>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a4_1273">
                           <locus target="#6r">-6r</locus>
                           <q xml:lang="ar">شعر تعلم وليس المرء يولد عالما| وليس أخا علم كمن هو جاهلا</q>
                           <note>
                              <p>ِAuthor: <persName ref="https://betamasaheft.eu/PRS0407IHA"> الشافعي,
               ابو عبد الله محمد بن ادريس بن العباس بن عثمان بن شافع بن السائب بن عبيد بن عبد يزيد
               بن هاشم بن المطلب بن عبد مناف بن قصي القرشي</persName>
                              </p>
                              <p>
                                 ِAuthor
                              : <persName ref="https://betamasaheft.eu/PRS0407IHA"> الشافعي,
               ابو عبد الله محمد بن ادريس بن العباس بن عثمان بن شافع بن السائب بن عبيد بن عبد يزيد
               بن هاشم بن المطلب بن عبد مناف بن قصي القرشي</persName>
                              </p>
                              <term key="Adab" ana="#Adab"/>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a0_1273">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">والأداب جمع ادب لغة إتباع مكارم الأخلاق ومجانسة الشرعية وشرعا إمثال الأوامر والتخلق بإخلاق الجميلة وحقيقة حفظ الحواش وشرطة الخوف من لله والحياة من لناس ه ج</q>
                           <note>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a5_1273">
                           <locus target="#12v">-12v</locus>
                           <q xml:lang="ar">قال الشاعر أخي لذ تنال العلم إلا بستة سأنبي عن أنبائها ببيان ه ذكاء حزمو مطبار وبلغة وءرشاد
أستاذ وطيب زمان وقال غيره ألا إنّ هذ العلم ليس بمدرك براحة جسم قد يصان ويودع فى محمد وااحد فالكالب لعلم محمد الأنبى ويشرب </q>
                           <note>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                        <item xml:id="a6_1273">
                           <locus target="#24r-24v">-24r-24v</locus>
                           <q xml:lang="ar">تم زبد هذ الكتاب المبارك النافع لمن تفهمه وتارب به وبماقيه والافهو حجة على من تعلمه ولم بعمل به والعياذ بالله من علم يكون سبب هلاك صاحبه بيد عبد لصغير صاحب الهقوة والقصير الرجي عفو وربه القدير بما فعله فى الجنان والضمير وقت العصر يوم الجمعة فى تاسع ذ لحجة سنة ١٣٥ الهم اغفر لقارءه ولكاتبه ولسامعه ولجامع المسلمين امين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a2_1273">
                           <locus target="#2v">-2v</locus>
                           <q xml:lang="ar">قوله عن خبائثه لغية والفخر والكبر والرباء وسمعة والحسد والنميمة و؟؟؟</q>
                           <note>
                              <term key="Fawaid_Masail" ana="#Fawaid_Masail"/>
                           </note>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#1r">-1r</locus>
                           <desc>Waqf</desc>
                           <q>موقوف على بدر الدين ثم على جميع المسلمين</q>
                           <note/>
                        </item>
                        <item xml:id="a2">
                           <locus target="#7r-10r-16r">-7r, 10r, 16r</locus>
                           <desc>Ownership</desc>
                           <q>زبى مولا</q>
                           <note/>
                        </item>
                     </t:list>

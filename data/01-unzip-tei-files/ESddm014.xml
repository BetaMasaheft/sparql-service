                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: mediocre; hand b: crude.</seg>
                        <seg type="ink">Black, red (strong vermillion).</seg>
                        <date>Mid-18th – mid-19th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>አሜ፡</abbr> for <expan>አሜን፡ </expan> (<locus target="#58v">58v</locus>)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; name of the owner; two groups of line
                           on the incipit page of Text I; incipit of Text II and of sections of
                           Texts I and II; elements of the punctuation signs and text dividers;
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="4r" to="57v">4r-57v</locus>
                        
                     </handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="57v" to="58v">57v-58v</locus>.</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#5r">5r</locus> (incipit page of Text I): simple coloured
                        (red) ornamental band; geometrical motifs. Mostly faded away.</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- Omitted letters inserted interlineally: e.g., fols. 15v, 41v, 53v, 56r. - Omitted word inserted in the upper margin: <locus target="#57v">fol.  57v</locus>. - Corrections written over erasures in the main hand: e.g., fols. 16r, 27r. - The name Wälättä Ṣǝrḥa is written in a secondary hand in blue pen in the supplication formulas over an erased name (e.g., fols. 19r, 20v, 26r, 42r, 50v, 55v, 58b) or in the lower margin (e.g., fols. 6r, 7r, 23v, 26v). - Scribbles and pen trials in black ink: <locus target="#4r">fol.  4r</locus>. - Scribbles in blue pen: fols. 59r, 59v, 60r.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards.
 One pair of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible on the spine fold
                           of the quires, close to the head and to the tail of the codex.</decoNote>
                     </binding>
                  </bindingDesc>

                        <decoDesc>
                            <decoNote type="miniature" xml:id="d1">
                              <locus target="#2v">Fol. 2v</locus>
                              <desc>The miniature is pasted on the manuscript. It depicts an <term key="angel" ana="#angel">angel</term> holding a <term key="sword" ana="#sword">sword</term> surrounded by a frame with an interlaced pattern.</desc>
                            </decoNote>

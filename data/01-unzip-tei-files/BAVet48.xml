                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v" facs="0003"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4324Asmatihu">ʾAsmātihu la-ʾǝgziʾǝna za-wahabo la-Ṗeṭros</title> 
                     <quote xml:lang="gez">
                        አስማቲሁ፡ <choice>
                           <sic>ለእግሂእነ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ለእግዚእነ፡</corr></choice>
                         ዘወሀቦ፡ ለጴጥሮስ፡ ከመ፡ ይርከብ፡ 
                        ሞገሰ፡ በቅድመ፡ ነገሥት፡ ወመኳን<add place="inline">
                           <supplied reason="omitted">ን</supplied>
                        </add>ት፡ ወሶበ፡ ይኔጽሮሙ፡ ይብል፡ ጋስን፡ ፫ጊዜ፡ ወራካን፡ 
                        መጵርድን፨ ጰርሳን፡ በዝንቱ፡ አስማቲከ፡ ተማኅፀንኩ፡ ከመ፡ 
                           <sic>ያሀቡኒ፡</sic>
                         እሉ፡ 
                           <sic>ሰብአ፡</sic>
                         መፍቅድየ፡ ዘንተ፡ 
                        ብሂለከ፡ ትተፍእ፡ 
                           <sic>ምራቅከ፡</sic>
                         ወትቀብእ፡ 
                           <sic>ገጽከ፨</sic>
                         
                     </quote>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="2r" to="20v" facs="0004"/>

               <msContents>
                  <summary>Likely a fly-leaf from a service-book. The work contains a list of
                            dates (1508 CE; 1512 CE; 1513 CE) on which various persons died or are
                            to be remembered.</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v">1r-1v</locus>
                     <title>Service Book</title>                     
                     
                     <textLang mainLang="gez">Geez</textLang>
                     <note>Fragment</note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc defer="parchment">
                        <extent>1 leaf<dimensions type="leaf" unit="cm">

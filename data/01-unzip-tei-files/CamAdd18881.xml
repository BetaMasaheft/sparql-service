                              <width>14.5</width>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="22"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote script="Ethiopic" xml:id="h1">
                        <seg type="script">
                           Fair. Careless at end of verso
                        </seg>
                     </handNote>
                  </handDesc>
                  
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1500" notAfter="1599">early
                                16th cent.</origDate>
                     <origPlace>Ethiopia</origPlace>. A list of
                            dates related to deceased persons is given: <date when="1508">1508</date> CE;
                            <date when="1512">1512</date> CE; <date when="1513">1513</date> CE.</origin>
                  

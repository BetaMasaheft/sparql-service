         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ክርስቶስ፡ ተስፋነ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Krǝstos Tasfāna</persName>
                 <persName>
                  <roleName type="title">ʿaqqābe saʿat</roleName>
               </persName>
                  <occupation type="ecclesiastic">abbot</occupation>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                
               <residence>
                  <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos</placeName>
               </residence>
               <floruit when="1299">He was one of the illustrious early abbots of 
                  <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos</placeName> 
                     succeeded <persName ref="https://betamasaheft.eu/PRS10531Zaiyas">Zaʾiyasus</persName> in around <date>1299</date>. 
                  He lived in the vital period of 
                     King <persName ref="https://betamasaheft.eu/PRS1854Amdase">ʾAmda Ṣǝyon I</persName>. 
                  He was very close to the King and
                     the King <persName ref="https://betamasaheft.eu/PRS1854Amdase">ʾAmda Ṣǝyon I</persName>affectionately called him "my Father". 
                  He was the owner of  <ref type="mss" corresp="https://betamasaheft.eu/NLA28">Addis Ababa, Ethiopian National Archives and Library Agency, NALE 28</ref>.
                     
                  </floruit>
                  <death> 
                  <date>1339/40</date> 
               </death>
               </person>
               
         </listPerson>
         
         

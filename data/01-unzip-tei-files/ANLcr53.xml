                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="3r" to="83v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="3r" to="11v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Introduction">Sayfa Śǝllāse, Introduction</title>
                                <incipit xml:lang="gez">
                                    በስመ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/>
                                    ንጽሕፍ፡ <t:choice xmlns:t="http://www.tei-c.org/ns/1.0" resp="DR"><sic>አንከ፡</sic><t:corr>እንከ፡</t:corr></t:choice>
                                    መቅድመ፡ ሰይፈ፡ ሥላሴ፡ በ፯ ዕለታት፡ ተማኅፀንኩ፡ ብክሙ፡ አብ፡ ወወልድ፡ 
                                    ወመንፈስ፡ ቅዱስ፡ በከመ፡ አተውክሙ፡ ውስተ፡ ቤተ፡ አብርሃም፡
                                    ከማሁ፡ ተዘከሩኒ፡ ለገብርክሙ፡
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="11v" to="22v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Monday">Sayfa Śǝllāse, Praise for Monday</title>
                                
                                <msItem xml:id="ms_i1.2.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="11v" to="20v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Enaqqeh">Sayfa Śǝllāse, div Enaqqeh</title>
                                    <incipit xml:lang="gez">
                                        በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እነቅሕ፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እትነሣእ። 
                                        በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ: አአትብ፡ ገጽየ፡ በትእምርተ፡ መስቀ<pb n="12r"/>ል።
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="20v" to="22v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7311MTPromises">Miracle of the Trinity: Promises to the faithful</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/>
                                        ወአሐተ፡ ዕለተ፡ ይቤ፡ አብ፡ ዘአክበረኒ፡ በምድር፡ አከብሮ፡ በመንግሥተ፡ ሰማያት፡ ገጸ፡ አርያም፡ ይመስል፡ አምሳሊሁ፡ 
                                        ወዘወሀበኒ፡
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="22v" to="29r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Tuesday">Sayfa Śǝllāse, Praise for Tuesday</title>
                                
                                <msItem xml:id="ms_i1.3.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="22v" to="28v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Babahreya">Sayfa Śǝllāse, div Babahreya</title>
                                    <incipit xml:lang="gez">
                                        አአምን፡ አንሰ፡ በባሕርየ፡ ስሙ፡ ለአብ፡ ዘይሴባሕ፡ ቦቱ፡ ወልድ፡ ወይትቄደስ፡ 
                                        ቦቱ፡ መንፈስ፡ ቅዱስ፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="28v" to="29r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7312MTBeer">Miracle of the Trinity: Demons burnt in beer</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/>
                                        ወሀሎ፡ ፩ ብእሲ፡ ውስተ፡ ሀገረ፡ ፍልስጥኤም፡ ወአሐተ፡ ዕለተ፡ ረሰየ፡ ምዝረ፡ ለገቢረ፡ ተዝካሮሙ፡ መጽኡ፡
                                        ሰይጣናት፡ ብዙኃት፡
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="29v" to="42r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Wednesday">Sayfa Śǝllāse, Praise for Wednesday</title>
                                
                                <msItem xml:id="ms_i1.4.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="29v" to="32v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Sellusan">Sayfa Śǝllāse, div Sellusan</title>
                                    <t:note xmlns:t="http://www.tei-c.org/ns/1.0">This prayer is typically transmitted in manuscripts of the <t:ref type="work" corresp="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</t:ref>
                                  as part of the prayers for Tuesday.
                                    </t:note>
                                    <incipit xml:lang="gez">
                                        አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥሉሳን፡ በገጽ፡ ኅቡራን፡ በራዕይ፡ ግጽዋን፡
                                        በስም፡ ዕሩያን፡ በመንግሥት፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="32v" to="33v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7313MTGovernor">Miracle of the Trinity: A governor is angry with his troops for commemorating the Trinity</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> <pb n="33r"/> ወሀሎ፡ ፩ መኰንን፡ ውስተ፡ ሀገረ፡ ፍልስጥኤም፡ ወአሐተ፡
                                        ዕለተ፡ አዘዞሙ፡ ለሠራዊቱ፡ ከመ፡ ይትጋብዑ፡ ወሶበ፡ ርእየ፡<surplus>፡</surplus>  መኮንን፡ <add place="below">ይቤ፡</add> ዘገብረ፡
                                        ተዝካረ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.3">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="32v" to="42r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Akal">Sayfa Śǝllāse, div Akal</title>
                                    <t:note xmlns:t="http://www.tei-c.org/ns/1.0">Most likely a part of the prayers typically transmitted in manuscripts of the <t:ref type="work" corresp="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</t:ref>
                                        as part of the prayers for Tuesday, described here by the catalogue
                                        as continuation of <t:ref target="#ms_i1.4.1"/>.</t:note>
                                    <incipit xml:lang="gez">
                                        አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ህበራነ፡ ህላዌ፡ በ፩ መንበር፡ ህላዌ፡ አብ፡
                                        ኢይትሌለይ፡ <pb n="34r"/>
                                            እምህላዌ፡ ወልድ፡ ወመንፈስ፡ ቅዱስ።
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.5">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="42v" to="53v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Thursday">Sayfa Śǝllāse, Praise for Thursday</title>
                                
                                <msItem xml:id="ms_i1.5.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="42v" to="52r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Bagessawe">Sayfa Śǝllāse, div Bagessawe</title>
                                    <incipit xml:lang="gez">
                                        በስመ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ግጽው፡ ዋህድ፡ አምላክ፡ ፫ አዕማደ፡ ብርሃን፡ ፩ ሥልጣኖ<surplus>፡</surplus>ሙ፡ ወ፩ ስኖሙ፡ ፫ መባርቅት፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.5.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="52r" to="53v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7314MTFather">Miracle of the Trinity: Promise by God the Father to the faithful</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> <pb n="52v"/> ወአሐተ፡ ዕለተ፡ ቦዑ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ 
                                        ውስተ፡ ጽርሐ፡ አርያም፡ ወአዕረፉ፡ ውስተ፡ መናብርቲሆሙ፡ ለፌ፡
                                        ወለፌ፡ ነጸራ፡ ወርእያ፡ ለዛቲ፡ ዕለት፡ ወይቤ፡ አብ፡
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="54r" to="65v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Friday">Sayfa Śǝllāse, Praise for Friday</title>
                                
                                <msItem xml:id="ms_i1.6.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="54r" to="64r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#AyLessan">Sayfa Śǝllāse, div AyLessan</title>
                                    <incipit xml:lang="gez">
                                        ዓይ፡ ልሳን፡ ወዓይ፡ ከናፍር፡ ዘይክል፡ ነቢበ፡ ግብሩ፡ ለሥላሴ፡ ወዓይ፡ ልቡና፡ ወዓይ፡ ሰሚዕ፡ ዘይክል፡ አእምሮ፡ ህላዌሁ፡ ለሥላሴ፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.6.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="64r" to="65v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7315MTVoice">Miracle of the Trinity: Promises to the faithful by the voice of the Trinity</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ወአሐተ፡ ዕለተ፡ ቦዑ፡ ውስተ፡ ፈለገ፡ ጸቃውዕ፡ ወተናገሩ፡
                                        ጥቀ፡ ነገረ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እንዘ፡ ይብሉ፡ ዝንቱ፡ ቃልነ፡ እንዘ፡ ይትነበብ፡
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.7">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="65v" to="73r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Saturday">Sayfa Śǝllāse, Praise for Saturday</title>
                                
                                <msItem xml:id="ms_i1.7.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="65v" to="71v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2933RepCh214">Malkǝʾ-hymn to the Holy Trinity</title>
                                    <incipit xml:lang="gez">
                                        ሰላም፡ ለፍቅረ፡ መለኮት፡ በትስብእቱ፡ ዘጾመ፡ እንበይነ፡ ዚአነ፡ አርአያሁ፡ ከመ፡ የሀበነ።
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.7.2">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="71v" to="73r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7316MTReign">Miracle of the Trinity: The future reign of the Trinity</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> <pb n="72r"/><t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ወአሐተ፡ ዕለተ፡ አተዉ፡ ውስተ፡ ገጸ፡ አርያም፡ 
                                        ወይቤ፡ አብ፡ ሀለወኒ፡ ጊዜ፡ ይወጽእ፡ ቃልየ፡ ወይትሌዓል፡ በ፬ቱ፡ ማዕዘንት።
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.8">
                                <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="73v" to="81v"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Sunday">Sayfa Śǝllāse, Praise for Sunday</title>
                                
                                <msItem xml:id="ms_i1.8.1">
                                    <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="73v" to="79v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Ahasses">Sayfa Śǝllāse, div Ahasses</title>
                                    <incipit xml:lang="gez">
                                        አኃሥሥ፡ ጽድቀ፡ ዘእምኀቤከ፡ ኦቀማሬ፡ ጽድቅ፡ አኃሥሥ፡ ጥበበ፡ ዘእምኀቤከ፡ ኦሙዳየ፡ ጥበብ፡ ኦሥሉስ፡ ቅዱስ፡ አብ፡ ወወልድ፡ ወመንፈስ፡
                                        ቅዱስ፡
                                    </incipit>

        <body>
            <div type="bibliography">
                
                <listBibl type="editions">
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>
            </div>
            <div type="edition">
                <div type="edition" xml:lang="gez"><note>from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                    <div type="textpart" xml:id="malke">
                        <lg type="stanza" n="1">
                            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተሰብሐ፡ ወተወደሰ፨</l>
                            <l n="2">በአፈ፡ ካህናት፡ ኄራን፡ እለ፡ አድምኡ፡ ሞገሰ፨</l>
                            <l n="3">ከመ፡ እስብሐከ፡ ብሶይ፡ ስብሐተ፡ ሐዲሰ፨</l>
                            <l n="4">ዘጥበብ፡ መንፈሳዊት፡ ክድነኒ፡ ቃሰ፨</l>
                            <l n="5">ወበውስተ፡ ክርሥየ፡ ሐድለ፡ መንፈሰ፡ ቅዱሰ፨</l>
                        </lg>
                        <lg type="stanza" n="2">
                            <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ሕሩመ፡ ተጸፍሮ፡ እምንእሱ፨</l>
                            <l n="2">ወለርእስከ፡ ሰላም፡ ዘቆብዐ፡ መላእክት፡ ልብሱ፨</l>
                            <l n="3">ለእግዚአብሔር፡ ብሶይ፡ ዘትቀውም፡ ደብረ፡ መቅደሱ፨</l>
                            <l n="4">አቅም፡ ሊተ፡ አእምሮ፡ ዘመርኅበ፡ ልብየ፡ ያንሶሱ፨</l>
                            <l n="5">በከመ፡ ሐፃየ፡ ዐቀመ፡ ኢያሱ፨</l>
                        </lg>
                        <lg type="stanza" n="22">
                            <l n="1">ሰላም፡ ለሰኰናከ፡ ወለመከየድከ፡ እለ፡ ቆማ፨</l>
                            <l n="2">ዐጸደ፡ ጸሎት፡ ወጾም፡ መግረሬ፡ ጸላኢ፡ መስቴማ፨</l>
                            <l n="3">ጻድቅ፡ ብሶይ፡ ፍሬ፡ ከርሠ፡ ሰማዕት፡ ዮሐንስ፡ ካማ፨</l>
                            <l n="4">ለክርስቶስ፡ እንበይነ፡ ፍቅሩ፡ ምሉአ፡ ሞገስ፡ ወግርማ፨</l>
                            <l n="5">ለዛቲ፡ ዓዸም፡ መነንከ፡ ጣዕማ፨</l>
                        </lg>
                        <lg type="stanza" n="25">
                            <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ወለበድነ፡ ሥጋከ፡ ቅዱስ፨</l>
                            <l n="2">እምነ፡ ግማኔ፡ ወርኵስ፨</l>
                            <l n="3">እምአመ፡ አዕረፍከ፡ ብሶይ፡ በወርኀ፡ ማእረር፡ ታኅሣሥ፨</l>
                            <l n="4">እስከ፡ ዮም፡ ይበከይከ፡ ኵሉ፡ ዘነፍስ፨</l>
                            <l n="5">ወያስቆቅዉከ፡ አራዊት፡ ዘየብስ፨</l>
                        </lg>
                        <lg type="stanza" n="26">
                            <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ ወለመቃብሪከ፡ ሕንጽት፨</l>
                            <l n="2">በስመ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ ክርስቶስ፡ ሕይወት፨</l>
                            <l n="3">ንሥአ፡ ብሶይ፡ ዐሥራተ፡ ምሕረት፨</l>
                            <l n="4">ኀቤከ፡ ለዘይጼሊ፡ በዛቲ፡ ጸሎት፨</l>
                            <l n="5">ከመ፡ ቅድመ፡ ገጹ፡ ኢይቁም፡ መልአኩ፡ ለሞት፨</l>
                        </lg>
                        <lg type="stanza" n="27">
                            <l n="1">እግዚአብሔር፡ መፍቀሬ፡ ሰብእ፡ ዘዐጸደ፡ መስቀል፡ ኀለፈ፨</l>
                            <l n="2">ጸሪቀ፡ መበለት፡ አሐቲ፡ ከመ፡ ቅድመ፡ ዘመን፡ ተወከፈ፨</l>
                            <l n="3">ተወከፍ፡ ብሶይ፡ ዘሰላምየ፡ መጽሐፈ፨</l>
                            <l n="4">ወልስሐተ፡ ቃሉ፡ ቅሥም፡ ዘልፈ፨</l>
                            <l n="5">ውስተ፡ ምድረ፡ በድው፡ ኢይኩን፡ ግዱፈ፨</l>
                        </lg>
                    </div>
                </div>
                
              <note>The following text is taken from <ref type="mss" corresp="https://betamasaheft.eu/EMIP00499">Portland, Ethiopic Manuscript Imaging Project, Kaleab Addis Project 65</ref>.</note>
                <div type="textpart" subtype="stanza" xml:id="Stanza1" xml:lang="gez" n="1">
                  <label>Stanza 1</label>
                  <ab>
                    ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተሰብሐ፡ ወተወደሰ፡
                    በአፈ፡ ክህናት፡ ኄራን፡ እለ፡ አድምኡ፡ ሞገሰ።
                    ከመ፡ እስብሕከ፡ ብሶይ፡ ሰብሐተ፡ ሐዲስ።
                    ዘጥበብ፡ መንፈሳዊት፡ ከድነኒ፡ ቃስ።
                    ወበውስተ፡ ከርሥዓ፡ ሐድስ፡፡መንፍስ፡ ቅዱስ።
                  </ab>
              </div>
            </div>
        </body>
    </text></TEI>
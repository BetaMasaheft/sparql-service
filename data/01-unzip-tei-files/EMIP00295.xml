               <msContents>
                  <summary>Ziq Chants, መጽሐፈ፡ ዚቅ፡, and Mäwaś‘ǝt Chants, መዋሥዕት፡, Image of the Archangel Michael, መልክአ፡ ሚካኤል፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="11v" to="3r" facs="012"> f. 11v-3r, (bound upside down)</locus>
                    <title>A quire, from another manuscript, of the <title type="incomplete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>, containing chants called <title type="complete" ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Contains 16 lines per folio</note>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="13r" to="98v" facs="013">Fols 13r–98v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1979Mashaf">Maṣḥafa ziq</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>A new pen begins at 35vff</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                    <locus from="99r" to="158v" facs="099">Fols 99r–158v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1990Mawase">Mawāśǝʾǝt</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i4">
                    <locus from="159r" to="159v" facs="159">Fols 159r–159v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2055nags">nägś</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>Excerpt from Nägś Chants, God Reigns</note>
                  </msItem>

                  <msItem xml:id="ms_i5">
                    <locus from="160r" to="168v" facs="160">Fols 160r–168v, </locus><locus from="170v" to="169r" facs="171">170v–169r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT3081RepCh361">Hymn to St
                                                  Michael</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>The last sheet is bound upside down in relation to the rest of the codex</note>
                  </msItem>
               </msContents>

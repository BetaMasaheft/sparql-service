               <msContents>
                  <summary>Homiliary in Honor of the Monthly Feast of the Archangel Gabri’el, with five illuminations and three further locations prepared to add illuminations over the top of text.  </summary>
                  <msItem xml:id="ms_i1"><title>Homiliary in Honor of the Monthly Feast of the Archangel Gabri’el</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">79</measure>
                           <dimensions type="outer" unit="mm">
                              <height>210</height>
                              <width>160</width>
                              <depth>47</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="2" writtenLines="15 17"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#2v" facs="003">Fol. 2v</locus><desc>The <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName>?), holding drawn <term key="sword" ana="#sword"/> and processional staff with <term key="cross" ana="#cross"/> at the bottom, saving the three Hebrew Children. This illumination is identical in most of its details to that in EMIP 3261, Antippas 12, f. 51v</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#76v" facs="077">Fol. 76v</locus><desc>The <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName>?), holding drawn <term key="sword" ana="#sword"/> and processional staff with <term key="cross" ana="#cross"/> at the bottom, saving the three Hebrew Children. This illumination is identical in most of its details to that on frame 3 and the one in EMIP 3261, Antippas 12, f. 51v</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#77r" facs="077">Fol. 77r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#77v" facs="078">Fol. 77v</locus><desc>Arch<ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName> Conquering Demons. This illumination is identical in most of its details to the illumination in EMIP 3262, Antippas 12, f. 25v</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#78r" facs="078">Fol. 78r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> flanked by two <term key="angel" ana="#angel"/>s with wings covering them. This illumination is identical in most of its details to the illumination in EMIP 3262, Antippas 12, f. 41v</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#26r" facs="026"> f. 26r, top</locus><desc>has been painted over in red and black ink to prepare for an illumination</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#59v" facs="060"> f 59v, column 2</locus><desc>has been painted over in black ink to prepare for an illumination</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#74r" facs="074"> f. 74r, right top</locus><desc>has been painted over in black ink to prepare for an illumination</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#79r" facs="079">Fol. 79r</locus>
                    <desc>
                    Fragment of an Image of Aragawi beginning, <foreign xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምከ፡ ቀዋሚ</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc>
                    The harag goes across the top, down each side and in the middle margin as well. A (student?) replica appears on <locus target="#2r" facs="002">fol. 2r</locus>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#76r" facs="076">Fol. 76r</locus>
                    <desc>
                    Note: scribe’s name: <foreign xml:lang="gez">አለቃ ዘርአ ዮሐንስ</foreign>
                    </desc>
                    </item>
                  </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="textile"/>
                        <material key="leather"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

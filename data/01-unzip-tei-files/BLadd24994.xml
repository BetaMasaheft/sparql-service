                            </msItem>
                            
                            <msItem xml:id="ms_i4.2"> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT2257salota">The Prayer of Hannah, mother of Samuel the Prophet</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i4.3"> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT2258salota">The Prayer of Hezekiah, King of Judah</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i4.4"> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT2265salota">The Prayer of Manasseh</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i4.5"> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT2274salota">The Prayer of Jonah</title>

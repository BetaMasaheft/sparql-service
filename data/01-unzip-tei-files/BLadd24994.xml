                            <msItem xml:id="ms_i4.6"> 
                                <title type="complete" ref="https://betamasaheft.eu/LIT2250salota">Ṣalota Dānǝʾel nabiy sǝbḥat za-ʾǝm-ʾAzāryā</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                        </msItem>

                    <msContents>
                        <summary>Gospel of John, copied in a fine hand, with excellent materials.
                            Several very fine illuminations and cloth coverings for the
                            illuminations. Leather covered with fine fabric visible between the turn
                            downs.</summary>
                        <msItem xml:id="ms_i1">
                            <textLang/>
                        </msItem>
                    </msContents>

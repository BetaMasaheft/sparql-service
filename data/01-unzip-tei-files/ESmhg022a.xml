                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre but careful.</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>19th century.</date>
                        <seg type="rubrication">Nomina sacra; name of the donor; elements of the
                           punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#27r">f. 27r</locus>
                           <desc>: Donation note.</desc>
                           <note> Half-erased, probably written in the main hand. The note mentions
                              the church of Ḥarennät. </note>
                        </item>
                        <item xml:id="e1"><desc>- Written in pencil on <locus target="#27v">27v</locus>, a
                           note partly faded and hardly readable (written exercise?). The note
                           states that mamhǝr Za-Walda Māryām donated the Ms. to the church of
                           Māryām Gäbäzäyti.</desc></item>
                        <item xml:id="e2"><desc>Writing on the stub: <locus target="#25r">25r</locus>.</desc></item>
                        <item xml:id="e3"><desc> Doodles: <locus target="#1r">1r</locus>, 1v, 2r,
                           2v, 27v.</desc></item>
                     </list>
                  </additions>

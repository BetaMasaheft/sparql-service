                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="1v" to="2v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5439Homily">Homily on the Ark of the Covenant</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ድርሳን፡ ዘደረሰ፡ ፩ ርቱዓ፡ ሃይማኖት፡
                        ወነደየ፡ ምግባር፡ ሶበ፡ ረከቦ፡ እምቃለ፡ መጻሕፍት፤ ይቤ፡ ናሁ፡ እጽሕፍ፡ ቃለ፡
                        ጽድቅ፡ ወተስፋ፡ ሰጊድ፡ ወጸሎት፡ ወቃለ፡ ማኅሌት።</incipit>
                          <note>With musical notation.</note>

                          
                        </msItem>

                        <msItem xml:id="ms_i2">
                          <locus from="3r" to="12v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3990Prayer">ጸሎተ፡ ማር፡ ፊላክሲኖስ፡ ጳጳስ፡ ዘሀገረ፡ መንቡዝ፡</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡
                          ፩ አምላክ። ጸሎተ፡ ማር፡ ፈላክሲኖስ፡ ጳጳስ፡ ዘሀገረ፡ መንጉዠ፡ ዘይጼልዩ፡ ቦቱ፡
                        ኲሉ፡ ሰብእ፡ በእንተ፡ መድኃኒተ፡ ነፍሶሙ። </incipit>
                          <explicit xml:lang="gez"> ዘንተ፡ ስብሐተ፡ አቄርብ፡ ለዕበይከ፡ ኦንጉሥየ፡ ወአምላኪየ፨ ተወከልኩ፡ ኪያከ፡ ስረይ፡ ሊተ፡ ኃጢአትየ፡ ወጌጋይየ፡ ወደምስስ፡
                          ኵሎ፡ አበሳየ፨ አድኀነኒ፡ እምጸላእትየ፡ ወእምኵሎሙ፡ እለ፡ ይትቃወምዋ፡ ለነፍስየ፡ ወእምትምይንተ፡ ሰይጣን፡ ፀርየ፡ ሊተ፡ ለገብርከ፡ አጽመ፡ ጊዮርጊስ፡ ምስለ፡ ሰብአቤትየ፡ ዕቀበኒ፡ ወተማኅፀነኒ፡
                        ለዓለመ፡ ዓለም፡ አሜን፨ </explicit>

                          <note> The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS12564AsmaG">ʾAṣma Giyorgis</persName> is mentioned on <locus target="#12v"/>
                     </note>
                        </msItem>

                        <msItem xml:id="ms_i3">
                          <locus from="13r" to="183r"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1146Argano">አርጋኖነ፡ ማርያም፡</title>
                            <textLang mainLang="gez"/>
                            <note>Organized according to week days.</note>
                        </msItem>

                        <msItem xml:id="ms_i4">
                          <locus from="184r" to="184v"/>
                          <title type="complete" cert="medium" xml:lang="en" ref="https://betamasaheft.eu/LIT3058RepCh338">Hymns to Mary</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ተፈሥሒ፡ ኦዘንስአለኪ፡ ዳኅና። ኦቅድስት፡ መልዕተ፡ ክብር፡
                          ድንግል፡ ኲሎ፡ ጊዜ።</incipit>
                        </msItem>

                        <msItem xml:id="ms_i6">
                          <locus from="184v" to="185v"/>
                          <title type="incomplete" cert="medium" ref="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ናስተበቍዓከ፡ ኦእግዚእነ፡ ወንጉሥነ፡ ክርስቶስ፡</incipit>
                          <explicit xml:lang="gez"> በእንተ፡ ማርያም፡ ድንግል፡ መኅፈደ፡ መለኮት፨ እንተ፡ ተርሕብ፡ እምሰማየ፡ ሰማያት፡ ወተዓምቅ፡ እምቀላየ፡ ቀላያት፨ ወተፀድል፡ እምስነ፡ ፀሐይ፡ ወወርኅ፡ ወከዋክብት፨
                          እንተ፡ ይእቲ፡ አንቀጸ፡ ፍሥሐ፡ ወኃሤት፡ አንቀጸ፡ ቅዳሴ፡ ወአንቀጸ፡ ክህነት፡ ላቲ፡ ግናይ፡ በኵሉ፡ ጊዜ፡ ወበኵሉ፡ ሰዓት፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨</explicit>
                        </msItem>


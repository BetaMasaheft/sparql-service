                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus from="185r" to="186r"/>
                              <desc type="MagicText">
                                <title type="complete" ref="https://betamasaheft.eu/LIT5440MagicPrayer">Magic Prayer for Travellers</title> 
                           </desc>
                              <q xml:lang="gez"> ቦልፀ፡ ለስም። ርዶሳ፡ ርይራአ፡ ስናዲ፡ ራዴአ፨ ስዳሮ፡ ማዕተብ፡ ዘወልደ፡ አብ፡ ጸጋ፡ ዘተውህበ፡ ለአሕዛብ።
                                ይኩኖ፡ ረዳኤ፡ ለጊርዮጊስ፡ መጸአለ፡ ፈልፈለ፡ ጥበብ፨ በኵሉ፡ ፍኖቱ፡ ኀበ፡ ሖረ፡ በምሥራቅ፡ ወበምዕራብ፡ በሰሜን፡ ወበድቡብ፨
                                ብአ፡ ይመሰይ፡ ስኦታ፨ ድልወ፡ ይመስይ፡ ስኦታ፨ ስዱቅ፡ ስፈንመ፡ ይመስይ፡ ስኦታ፡ ሙስ፡ ብአለ፡ ልኤራሙ፨ ሙስ፡ ደልወለ፡ ርቴናም፨ ሙስ፡ ስዱቅ፡ ስፈንመለ፡ ርቴያብአ፨ ሙስ፡ ስዱቅ፡
                                ስፈንመ፡ ቂየኅማ፡ ስኖቃጢኖጢ፨ ዝንቱ፡ አስማተ፡ ሥሉስ፡ ቅዱስ፨ ይኩኖ፡ ዓቃቤ፡ ወረዳኤ፡ ወመድኅነ፡ በሥጋ፡ ወነፍስ፨ ለአጽመ፡ ሰማዕት፡ መዋኢ፡ ቅዱስ፡ ጊዮስ፡ በቤት፡ ወበገዳም፡ በባሕር፡ ወበየብስ፨ ለዓለመ፡ ዓለም፡ አሜን፨</q>

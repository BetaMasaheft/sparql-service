               <msContents>
                  <summary>School Chants, የቃል፡ ትምህርት፡</summary>
                    <msItem xml:id="ms_i1"><locus from="1r" to="11v" facs="003">Fols 1r–11v</locus>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <title>Chants called Mästägabǝ’<foreign xml:lang="gez">መስተጋብዕ፡</foreign></title>
                    <incipit xml:lang="gez">ዕዝል: መስተጋብዕ። ዘሰኑይ: ወለቡ: ጽራኅየ: ወአጽምዓኒ: ቃለ ስእለትየ: ከመ: ወልታ: ሥሙር: ከለልከነ:</incipit>
                    <notatedMusic><desc>With musical notation</desc></notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i2"><locus from="11v" to="17v" facs="014">Fols 11v–17v</locus>
                  <title>Chants called  Qālǝya Aṣmǝ‘<foreign xml:lang="gez">ቃልየ፡ አጽምዕ፡</foreign></title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <incipit xml:lang="gez">ቃልየ: አጽምእ: እግዚኦ: ሃሌ: ሉያ: ሃሌ: ሉያ: ወለቡ: ጸራኅየ: <sic/> ሃሌ: ሉያ: ሃሌ: ሉያ: ወአጽምዓኒ: ንጉሥየኒ: ወአምላኪየኒ:..</incipit>
                  <notatedMusic><desc>With musical notation</desc></notatedMusic>
              </msItem>
                <msItem xml:id="ms_i3"><locus from="18r" to="26v" facs="020">Fols 18r–26v</locus>
                <title>Chants called Śäläst<foreign xml:lang="gez">ሠለስት፡</foreign></title>
                <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                <incipit xml:lang="gez">ሠለስት። ስምዓኒ: እግዚኦ: ጸሎትየ: ሃሌ: ሃሌ: ሉያ: ሃሌ: ሉያ: ሃሌ: ሉያ: ሃሌ: ሉያ: ወይብጻሕ: ቅድሜከ: ገዐርየ:</incipit>
                <notatedMusic><desc>With musical notation</desc></notatedMusic>
            </msItem>
              <msItem xml:id="ms_i4"><locus from="27r" to="33v" facs="029">Fols 27r–33v</locus>
              <title>Chants called Aryam<foreign xml:lang="gez"/>አርያም፡</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <incipit xml:lang="gez">አርያም። ሃሌ: ሉያ: ለአብ: ሃሌ: ሉያ: ለወልድ: ሃሌ: ሉያ: ወለመንፈስ: ቅዱስ: ዮሐንስኒ: ሀሎ: ያጠምቅ: በሔኖን: በቅሩበ: ሳሌም: በማዕዶተ: ዮርዳኖስ:</incipit>
                     <notatedMusic><desc>With musical notation</desc></notatedMusic>
                </msItem>
               </msContents>

      <t:body>
         <t:div type="bibliography">
                        
            
         </t:div>
         <t:div type="edition"><t:note>Here the most standard sequence is described</t:note>
            <t:div type="textpart" xml:id="Miracle1" corresp="https://betamasaheft.eu/LIT7170MiracleMichaelSailors">
               <t:label>Miracle Ḫǝdār: on the Egyptian sailors</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleSailors"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle2" corresp="https://betamasaheft.eu/LIT7171MiracleMichaelTreasure">
               <t:label>Miracle Tāḫśāś: on the poor peasant who found a treasure in a fish</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleTreasure"/></t:note>              
            </t:div>
            <t:div type="textpart" xml:id="Miracle3" corresp="https://betamasaheft.eu/LIT7172MiracleRichPoor">
               <t:label>Miracle Ṭǝrr: about the rich man (woman) who became poor</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleRichPoor"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle4" corresp="https://betamasaheft.eu/LIT7191MiracleMichaelParalytic">
               <t:label>Miracle Yakkatit: Miracle of St Michael healing of a paralytic</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleParalytic"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle5" corresp="https://betamasaheft.eu/LIT7175MiracleMichaelElephantiasis">
               <t:label>Miracle Maggābit: on the woman suffering from elephantiasis</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleElephantiasis"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle6" corresp="https://betamasaheft.eu/LIT7179MiracleMichaelHand">
               <t:label>Miracle Miyāzyā: on the withered hand</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleHand"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle7" corresp="https://betamasaheft.eu/LIT7192MiracleMichaelSterile">
               <t:label>Miracle Gǝnbot: on a sterile woman, who bears a son through the intervention of St Michael, devoting her child to service
                  in St Michael's church.</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleSterile"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle8" corresp="https://betamasaheft.eu/LIT7180MiracleMichaelJew">
               <t:label>Miracle Sane: on a leprous Jew</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleSane"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle9" corresp="https://betamasaheft.eu/LIT7181MiracleMichaelFreed">
               <t:label>Miracle Ḥamle: on a possessed freed in church</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleFreed"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle10" corresp="https://betamasaheft.eu/ LIT7183MiracleMichaelBlind">
               <t:label>Miracle Naḥase: on healing a blind</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleBlind"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle11" corresp="https://betamasaheft.eu/LIT7185MiracleMichaelDorotheus">
               <t:label>Miracle Maskaram: on Dorotheus and Theophista, who found a treasure in the belly of a fish</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleDorotheus"/></t:note>
            </t:div>
            <t:div type="textpart" xml:id="Miracle12" corresp="https://betamasaheft.eu/LIT7189MiracleMichaelRich">
               <t:label>Miracle Ṭǝqǝmt: of the rich man who recovers his possessions</t:label>
               <t:note>Also in <t:ref type="work" corresp="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna Mikāʾel</t:ref> as <t:ref type="work" target="LIT1295Dersan#MiracleRich"/></t:note>
            </t:div>
         </t:div>
      </t:body>

         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3272/" n="169" corresp="https://betamasaheft.eu/api/iiif/EMIP03272/manifest">Antippas 22</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter made in the Government Scriptorium</summary>
                  <msItem xml:id="ms_i1"><locus from="5r" to="157r" facs="005">Fols 5r–157r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="5r" to="120v" facs="005">Fols 5r–120v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Each section of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118</span></ref> begins with a transliterated Hebrew letter, but no statement of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has only the first of the plusses that make up the longer version, the word <foreign xml:lang="gez">ወአድኃኒ፡</foreign></note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="121r" to="133r" facs="121">Fols 121r–133r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>The superscription to the fourth biblical canticle, <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref>, is <q>“Prayer of Hana, mother of Samuel, prophetess.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="134v" to="140r" facs="135">Fols 134v–140r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Common version</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="140v" to="151v" facs="141">Fols 140v–151v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Arranged for the days of the week, laid out beginning on Monday and culminating on Sunday</note>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="152r" to="157r" facs="152">Fols 152r–157r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2"><locus from="157r" to="158v" facs="157">Fols 157r–158v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Written in a different hand</note>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">160</measure>
                           <dimensions type="outer" unit="mm">
                              <height>193</height>
                              <width>125</width>
                              <depth>50</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="22 23">
                         <locus from="1r" to="140r" facs="001">Fols 1r–140r</locus>
                       </layout>
                       <layout columns="2" writtenLines="22 23">
                         <locus from="140v" to="160r" facs="141">Fols 140v–160r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is unrubricated, except for in <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps145"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps145</span></ref></desc>
                  <desc>The first word of each line of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps148"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps148</span></ref> is rubricated</desc>
                  <desc>The entire first line of each section <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</ref> is rubricated</desc>
                  <desc><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps150">Psalms of
                                                  David, Psalmus 150</title> and the tenth biblical canticle show columetric rubrication</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1r" facs="001">Fol. 1r</locus>
                    <desc type="GuestText">Excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT1693John#Chp1">Gospel of John,
                                                  Chp1</title>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for protection against small pox and measles, <q><foreign xml:lang="gez">ጸሎተ፡ ፈንፃፃ፡ በእንተ፡ ሕማመ፡ ወኩፍኝ፡</foreign></q>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#2r" facs="002">Fol. 2r</locus>
                    <desc type="Asmat">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for protection against small pox, <q><foreign xml:lang="gez">በስመ፡ አብ፡ በል፡ <gap reason="omitted"/> በኃይለ፡ ዝንቱ፡ አስ፡ አድኅኖ፡ ለገብ፡ እገሌ፡ ያለህ ፈንፃፃ፡ ዘዓረብ፡ ወበቀወ፡ ፈንፃፃ፡</foreign></q>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc>
                    Beginning of a letter written in 1923 AM, written in red ink
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#3v" facs="004">Fol. 3v</locus>
                    <desc type="GuestText">
                    Pen trial employing a prayer from <title type="incomplete" ref="https://betamasaheft.eu/LIT1960Mashaf">Maṣḥafa
                                                  qǝddāse</title>, and mentioning <foreign xml:lang="gez">መምሬ፡ ወልደ፡ ማርያም፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#4r" facs="004">Fol. 4r</locus>
                    <desc>
                    Pen trial for Haile Maryam
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#159r #159v #160r #160v" facs="159 160 161">Fols. 159r, 159v, 160r, 160v</locus>
                    <desc>
                    various small notes in various hands
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#64r" facs="064">Fol. 64r</locus>
                    <desc>
                    The midpoint of the Psalms is marked with a text, <q><foreign xml:lang="gez">መንፈቁ፡ ዝየ፡</foreign>, “its half here.”</q>
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    Colored threads were sewn into the fore edge of various folios as a navigation sysmte to mark the location of the main sections of the Psalter
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <locus target="#120v" facs="121">Fol. 120v</locus>
                    <desc type="OwnershipNote">
                    originally contained a reference to the owner (two lines from the  bottom), but it has been erased
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    The book has an interesting means for securing the book closed; a small strip of parchment has a knot securing it to the board, then passing around the book twice
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1999">Twentieth century</origDate>
                  </origin>
               </history>
            </msDesc>
         </sourceDesc>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወበግዐ፡ ፍርቃን፡ ወመንፈስ፡ ቅዱስ፡ ዖፍ፨</l>
                  <l n="2">ከናፍርየ፡ እክሥት፡ ለስብሐቲከ፡ ትሩፍ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዘትኄይስ፡ እመዛግብተ፡ ወርቅ፡ አእላፍ፨</l>
                  <l n="4">ይክሥቱ፡ ዜና፡ ጽድቅ፡ ወይትናበብ፡ በአፍ፨</l>
                  <l n="5">ምሥጢረ፡ ንጉሥ፡ ይኅብኡ፡ አኮኑ፡ ጽሑፍ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ እብል፡ ለሆህያተ፡ ስምከ፡ ሳምን፨</l>
                  <l n="2">ታሕተ፡ ክነፊሁ፡ ለአብ፡ እለ፡ ጽሑፋን፨</l>
                  <l n="3">ጣዕመ፡ ውዳሴከ፡ እንብብ፡ ተክለ፡ ሃይማኖት፡ ወይን፨</l>
                  <l n="4">ምላእ፡ ውስተ፡ አፉየ፡ ስብሐተ፡ ሱራፌል፡ ካህን፨</l>
                  <l n="5">ከመ፡ በአጽፍከ፡ ሰማያዊ፡ ተመልአ፡ ልሳን፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለርእስከ፡ ዘኮኖ፡ ግልባቤ፨</l>
                  <l n="2">ቆብዐ፡ እንጦንዮስ፡ አብ፡ ዘይምዕዝ፡ እምጼና፡ ከርቤ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጻድቅ፡ በይነ፡ ዘጾርከ፡ ምንዳቤ፨</l>
                  <l n="4">ይቤ፡ ይቤ፡ መልአከ፡ ሕይወትየ፡ ይቤ፨</l>
                  <l n="5">በገነተ፡ ሰማይ፡ ተመልአከ፡ ወተሰምየ፡ ሀቤ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ሰላም፡ ለዘባንከ፡ ዘአፈድፈደ፡ ተቀሥፎ፨</l>
                  <l n="2">ሕማማተ፡ ክርስቶስ፡ ለተሳትፎ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ቀልቀለ፡ አመ፡ ወገሩከ፡ በከርሠ፡ ቀፎ፨</l>
                  <l n="4">እፎ፡ እፎ፡ ዘይሔድፈከ፡ እፎ፨</l>
                  <l n="5">ለመልአከ፡ ሰማይ፡ ሚካኤል፡ ተረከብከ፡ ክንፎ፨</l>
               </lg>
               <lg type="stanza" n="43">
                  <l n="1">መጠነ፡ ብየ፡ ክሂለ፡ ትስዓተ፡ ትሕማሰ፨</l>
                  <l n="2">ማሕሌተ፡ መልክእከ፡ ኵሉ፡ አስተሐመምኩ፡ አንሰ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሀበኒ፡ እሞገስከ፡ ሞገሰ፨</l>
                  <l n="4">ክድነኒ፡ እምአልባሲከ፡ እለ፡ ይቄድሱ፡ ቅዱሰ፨</l>
                  <l n="5">ከመዝ፡ ወልድከ፡ አኀሥሥ፡ ኀሢሠ፨</l>
               </lg>
               <lg type="stanza" n="44">
                  <l n="1">ሰላም፡ ለህላዌከ፡ በዐቂበ፡ ሥርዓት፡ ወሕግ፨</l>
                  <l n="2">አርአያ፡ ቅዱሳን፡ አኃው፡ ዘደብረ፡ በግቢግ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጴጥሮስ፡ ዘገነተ፡ ጽባሕ፡ ዘውግ፨</l>
                  <l n="4">የዐውዱ፡ ዐውደ፡ ዚአከ፡ ወንጌላውያን፡ አፍላግ፨</l>
                  <l n="5">አባ፡ ጽጌ፡ ሮማን፡ ወዘወይን፡ ሐረግ፨</l>
               </lg>
            </div>
         </div>
      </body>

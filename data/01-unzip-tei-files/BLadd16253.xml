                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="30"/>
                            <title xml:lang="am" ref="https://betamasaheft.eu/LIT2422Tarika#t2amharic">
                                <lb n="1"/>የግራኝ፡ ታሪክ፡ የነገሥታትና፡ የመነኮሳት፡ ታሪክ፡ የሚቀርም።
                                <lb n="2"/>ጸሓፊሁ፡ ወርቅነህ፡ በዘመነ፡ ንጉሥ፡ ሣህለ፡ ሥላሴ፡ በሀገረ፡ አንኮ፡ ባር፡ ፲ወ፰፻ወ፵ዘኍልቈ፡ ፈረንጅ።
                            </title>
                            <note>The title is written according to the European style. It mentions <persName role="scribe" ref="https://betamasaheft.eu/PRS11081Warqena">Warqǝnah Habta Giyorgis</persName> 
                                as the scribe and states that the manuscript was written in <placeName ref="https://betamasaheft.eu/LOC1465Ankoba">Ankobar</placeName> in the year 
                                <date>1840 AD</date>, during the reign of king <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śāhla Śǝllāse</persName>.</note>
                        
                            <msItem xml:id="ms_i1.1">
                            <locus from="1" to="4"/>
                                <title>Genealogy of the kings of Ethiopia from <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> to ʾAdbǝʾal</title>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="4" to="7"/>
                                <title>Vita of <persName ref="https://betamasaheft.eu/PRS10245Yared">Yāred</persName>, who lived at the time of king <persName ref="https://betamasaheft.eu/PRS4327GabraMa">Gabra Masqal</persName>
                        </title>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="7" to="9"/>
                                <title>On the Christianization in Ethiopia</title>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="9" to="12"/>
                                <title>Chronicle of the kings from <persName ref="https://betamasaheft.eu/PRS10303Yekunno">Yǝkunno ʾAmlāk</persName> to <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas</persName>
                        </title>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="12v" to="14"/>
                                <title>History of the monasticism in Ethiopia, from <persName ref="https://betamasaheft.eu/PRS1962Anthony">Anthony the Great</persName>
                        </title>
                            </msItem>
                            <msItem xml:id="ms_i1.6">
                                <locus target="#14"/>
                                <title>Genealogy of the twelve apostles</title>
                            </msItem>
                            <msItem xml:id="ms_i1.7">
                                <locus from="14" to="20"/>
                                <title>History of the <persName ref="https://betamasaheft.eu/PRS1522Ahmadb">Grāñ</persName>
                        </title>
                            </msItem>
                            <msItem xml:id="ms_i1.8">
                                <locus from="20" to="23"/>
                                <title>History of <persName ref="https://betamasaheft.eu/PRS4428Galawdew">Galāwdewos</persName>
                        </title>
                            </msItem>
                            <msItem xml:id="ms_i1.9">
                                <locus from="23" to="24"/>
                                <title>On the Oromo people</title>
                            </msItem>
                            <msItem xml:id="ms_i1.10">
                                <locus from="24v" to="30"/>
                                <title>History of <persName ref="https://betamasaheft.eu/PRS3417David">David</persName>, king of Ethiopia</title>
                            </msItem>
                        </msItem>
                    </msContents>
                    

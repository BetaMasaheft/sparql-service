                  <msItem xml:id="ms_i1">
                     <locus from="2ra" to="86vb"/>
                     <title type="complete">Commentary on the books of the Octateuch by Mǝhǝrka Dǝngǝl</title>

                  <msItem xml:id="ms_i1.1">
                    <locus from="2ra" to="86vb"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl</title>
                                      
                     <msItem xml:id="ms_i1.1.1">
                              <locus from="2ra" to="37vb"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary#Genesis">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl, On Genesis</title>
                              <textLang mainLang="gez"/>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡ እግዚአብሔር፡ አብ፡ ወማ</hi>
                           ኅየዊ፡ ንዊጥን፡ ትርጓሜ፡ ኦሪት፡ ዘጸሐፈ፡ <persName ref="https://betamasaheft.eu/PRS5720JohnChr">ዮሐንስ፡ አፈ፡ ወርቅ፨</persName> በረከቱ፡ ተሃሉ፡ ምስሌነ፨ መጽሐፈ፡ ብሊት፡ ኵለንታሃ፡ በፂዋዌ፡ ጠፉአት፡</incipit>
                              </msItem>


                              <msItem xml:id="ms_i1.1.2">
                                <locus from="38ra" to="54rb"/>
                                 <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary#Exodus">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl, On Exodus</title>
                                 <textLang mainLang="gez"/>
                                 <incipit xml:lang="gez"><hi rend="rubric">ፍካሬ፡ መጽሐፍ፡ ዳግም፡ ወውእቱ፡ ፀአት፡ እምግብጽ፡ ክፍል፡ ቀዳማዊ፡ ዘተሰመየሰ፡ መ</hi>ጽሐፈ፡ ፀአት፡ እስመቦ፡ ውስቴቱ፡ ዜና፡ ፀአተ፡ ደቂቀ፡ ፳ኤል፡ 
                                    እምግብጽ፡ በእንተ፡ ዘቦ፡ ውስቴቱ፡ አስተርእዮተ፡ ጥያቄ፡ ቃላተ፡ ተስፋ፡ አንተ፡ አስፈዎ፡ <sic resp="DN">እግዚ፡</sic> ለአብርሃም፨</incipit>
                              </msItem>

                                 <msItem xml:id="ms_i1.1.3">
                                    <locus from="54rb" to="64vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary#Leviticus">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl, On Leviticus</title>
                                    <textLang mainLang="gez"/>
                                    <incipit xml:lang="gez"><hi rend="rubric">መጽሐፍ፡ ሣልስ፡ ወውእቱ፡ መጽሐፈ፡ ካህናት፡ ክፍል፡ ቀዳማዊ፡ እግዚአብሔር፡</hi> ይዕበይ፡ ስሙ፡ ኢአዘዞሙ፡ ለሕዝብ፡ ሠዊዓ፡ መሥዋዕት፡ እንበይነ፡ 
                                       ረባሕ፡ <sic resp="DN">ዘት፡ መጽእ፡</sic> ኀቤሁ፡ ዳእሙ፡ ለአሠንዮተ፡ <sic resp="DN">ፍጣሪሁ፨</sic></incipit>
                                 </msItem>

                              <msItem xml:id="ms_i1.1.4">
                                 <locus from="64vb" to="75ra"/>
                                 <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary#Numbers">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl, On Numbers</title>
                                 <textLang mainLang="gez"/>
                                 <incipit xml:lang="gez"><hi rend="rubric">መጽሐፍ፡ ራብዕ፡ ወውእቱ፡ መጽሐፈ፡ ኈልቈ፡ ክፍል፡ ቀዳማዊ፡ ወመፍቀዱሰ፡ ለዝንቱ፡</hi> መጽሐፍ፡ አዘክሮተ፡ ኵሉ፡ ሰርዓታት፡ እንተ፡ ሠርዓ፡ <sic resp="DN">እግዚ፡</sic>
                                 ለደቂቀ፡ ፳ኤል፡ ውስተ፡ ገዳም፡ መራር፡</incipit>
                                 
                             </msItem>
                     
                     <msItem xml:id="ms_i1.1.5">
                        <locus from="75ra" to="84ra"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6608Commentary#Deuteronomy">Commentary on the Pentateuch by Mǝhǝrka Dǝngǝl, On Deuteronomy</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez"><hi rend="rubric">መጽሐፍ፡ ሐምስ፡ ወውእቱ፡ መጽሐፍ፡ ወዳግም፡ ሕግ፡ ክ</hi>ፍል፡ ዳግማይ፡ ወ<gap reason="illegible" resp="DN" unit="chars" extent="5"/> ለሙሴ፡ 
                           በደጊመ፡ ሕግ፡ ከመ፡ ይስማዕ፡ ሕዝብ፡ ዳግማዊ፡ እምዘ፡ ቦቱ፡ በከመ፡ ሰምዓ፡ ሕዝብ፡ ቀዳማዊ፡</incipit>
                     </msItem>
                  </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="84ra" to="86vb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6817CommentJoshua">ፍካሬ፡ መጽሐፈ፡ ኢያሱ፡ ወልደ፡ ነዌ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez"><hi rend="rubric">ንወጥን፡ በስመ፡ እግዚአብሔር፡ ሕያው፡</hi> ወወሃቤ፡ ሕይወት፡ ፍካሬ፡ መጽሐፈ፡ ኢ<hi rend="rubric">ያሱ፡ ወልደ፡ ነዌ፡ ክፍል፡ ቀዳ፡ ወምክንያቱ</hi>ሰ፡ በእንተ፡ ዘኃረዮሙ፡ እግዚ፡ ለሕዝበ፡ 
                           ደቂቀ፡ ፳ኤል፡ ካልእ፡ እሞ፡ ካልአኒሁ። </incipit>
                     </msItem>
                  </msItem>
                         </msContents>

            <t:person sex="1" sameAs="wd:Q3614181">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አምኃ፡ ኢየሱስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAmmǝḫā ʾIyasus</t:persName>
                
                  <t:persName>
                  <t:roleName type="title">marǝd ʾazmāč</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  <t:occupation type="political">ruler</t:occupation>
                
                  <t:floruit notBefore="1743" notAfter="1775">He was the fourth ruler of the Kingdom of 
                     <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">
                     Šawā </t:placeName> from about <t:date>1743</t:date> to <t:date>1775</t:date>. 
                     He moved his capital from
                     <t:placeName ref="https://betamasaheft.eu/LOC3776HarAmb">Ḥār ʾAmbā</t:placeName> to <t:placeName ref="https://betamasaheft.eu/LOC1464Ankoba">ʾAnkobar</t:placeName>
                     He expanded the kingdom of <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName> further south annexing new territories. 
                     He was succeeded by his son 
                  
                     <t:persName ref="https://betamasaheft.eu/PRS2110AsfaWas">   
                     <t:roleName type="title">marǝd ʾazmāč</t:roleName> ʾAsfā Wasan</t:persName>
               </t:floruit>
               <t:death when="1775"/>
                  
                  <t:death/>
               </t:person>
               
         </t:listPerson>

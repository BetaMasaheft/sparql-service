          <msContents>
            <summary>Magic Scroll</summary>
            <msItem xml:id="ms_i1">
              <locus from="1ra1" to="1ra27" facs="001">Fols 1ra1–1ra27</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> against demons, headache, tremors,
                back pain, etc.</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="1ra27" to="1rb26" facs="001">Fols 1ra27–1rb26</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> against the evil eye of Barya, the
                binding of demons, which was spoken to Alexander the Great</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i3">
              <locus from="1rb26" to="1rb57" facs="002">Fols 1rb26–1rb57</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> against the evil eye of Barya, the
                binding of demons, which Alexander spoke at Gog and Magog</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i4">
              <locus from="1ra60" to="1ra89" facs="003">Fols 1ra60–1ra89</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> against the evil eye with the story
                of Jesus and the disciples at the Sea of Tiberias, Ṣälota Nǝdra, <foreign xml:lang="gez">ጸሎተ ንድራ</foreign></title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i5">
              <locus from="1ra89" to="1rb97" facs="004">Fols 1ra89–1rb97</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> against charm, <foreign xml:lang="gez">ጸሎት በእንተ መፍትሔ ሥራይ</foreign></title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i6">
              <locus from="1ra98" to="1rb154" facs="005">Fols 1ra98–1rb154</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> of St. Susǝnyos and the story of his
                fight against Wǝrzǝlya, demon of infant mortality</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i7">
              <locus from="1rb132" to="1rb154" facs="006">Fols 1rb132–1rb154</locus>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT5696MagicPrayer">Ḥaṣura
                                                  Masqal</title>
              <note>The starting point of this excerpt is not clear</note>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i8">
              <locus from="1ra155" to="10rb169" facs="008">Fols 1ra155–10rb169</locus>
              <title>Prayer of Blessing of Saint Susǝnyos</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i9">
              <locus from="1rb170" to="1rb209" facs="009">Fols 1rb170–1rb209</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> invoking the Gospel of John
                1:1-4</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
          </msContents>
          <physDesc>
            <objectDesc form="Scroll">
              <supportDesc>
                <support>
                  <material key="parchment"/>
                </support>
                <extent>
                  <measure unit="leaf">9</measure>
                  <dimensions type="outer" unit="mm">
                    <height/>
                    <width/>
                  </dimensions>
                </extent>
              </supportDesc>
              <layoutDesc>
                <layout columns="2"/>
              </layoutDesc>
            </objectDesc>
            <decoDesc>
              <decoNote type="frame" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc>a small harag
                  at the top of the scroll, and at various places throughout between
                works</desc></decoNote>
              <decoNote type="miniature" xml:id="d2"><locus target="#1r" facs="004">Fol. 1r</locus><desc>elaborate
                  nine-box panel with illuminations of a face in the center and faces of people in
                  each of the four corners</desc></decoNote>
              <decoNote type="miniature" xml:id="d3"><locus target="#1r" facs="007">Fol. 1r</locus><desc>large
                  talismanic symbol with four quadrants and eyes embedded</desc></decoNote>
              <decoNote type="miniature" xml:id="d4"><locus target="#9r" facs="009">Fol. 9r</locus><desc>four-petal symbol at the end of the scroll</desc></decoNote>
            </decoDesc>
            <additions>
              <list>
                <item xml:id="a1">
                  <desc> The scroll was made for <foreign xml:lang="gez">ወለተ ሩፋኤል</foreign>
                  </desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="true">
                <decoNote xml:id="b1" type="bindingMaterial">
                  <material key="parchment"/>
                </decoNote>
              </binding>
            </bindingDesc>
          </physDesc>
          <history>
            <origin>
              <origDate notBefore="1900" notAfter="1999">Twentieth century</origDate>
            </origin>
            <provenance>The scroll was made for ወለተ ሩፋኤል.</provenance>
          </history>
        </msDesc>
      </sourceDesc>

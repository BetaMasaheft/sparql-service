      <t:body>
         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q893610">
               <t:persName xml:id="n1">
                  <t:forename>Boris</t:forename>
                  <t:surname>Turaev</t:surname>
               </t:persName>
               <t:persName xml:id="n2">
                  <t:forename>Boris</t:forename>
                  <t:forename>Aleksandrovič</t:forename>
                  <t:surname>Turaev</t:surname>
               </t:persName>


               <t:occupation type="academic">scholar</t:occupation>
               <t:nationality type="Russia/USSR"/>
               <t:faith type="Orthodox"/>
               <t:birth when="1868"/>

               <t:floruit notBefore="1891" notAfter="1920">He was a renowned Russian Orientalist born
                  to provincial gentry. He studied Egyptology in the historico-philological faculty
                  of St <t:placeName ref="https://www.wikidata.org/entity/Q656">Saint Petersburg</t:placeName> University and completed the course in
                     <t:date>1891</t:date>. Then, he was retained as a post-graduate student, was sent
                  for studies abroad for one year. He worked in the museums of <t:placeName ref="https://www.wikidata.org/entity/Q64">Berlin</t:placeName>, <t:placeName ref="https://www.wikidata.org/entity/Q90">Paris</t:placeName>, <t:placeName ref="https://www.wikidata.org/entity/Q84">London</t:placeName>, and also <t:placeName ref="https://www.wikidata.org/entity/Q38">Italy</t:placeName> collecting the material for his Magister Thesis. After his return in
                     <t:date>1896</t:date>, he lectured on the history of the Ancient Orient and
                  Egyptology at St <t:placeName ref="https://www.wikidata.org/entity/Q656">Saint Petersburg</t:placeName> University as assistant Professor. In
                     <t:date>1898</t:date>, he obtained his Magister of General History. Turaev
                  published his first work in the field of Ethiopian Studies in <t:date>1897</t:date>
                  and since then he produced writings devoted to Ethiopian topics every year. He
                  edited and translated several Gǝʿǝz texts. </t:floruit>
               <t:death when="1920">He died at <t:placeName ref="https://www.wikidata.org/entity/Q656">Saint Petersburg</t:placeName> in <t:date>1920</t:date>
               </t:death>
            </t:person>
            
         </t:listPerson>



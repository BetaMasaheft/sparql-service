                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1_106">
                           <locus target="#37v-60r">-37v, 60r</locus>
                           <q xml:lang="ar">Circles in the margins</q>

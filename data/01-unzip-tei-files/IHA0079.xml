               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="180v">1v-180v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s39IHA">قران, Second half (ǧuz’ 16-30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>قَالَ أَلَمْ أَقُلْ إِنَّكَ لَن تَسْتَطِيعَ مَعِيَ صَبْراً</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#180v">-180v</locus> قُلْ أَعُوذُ بِرَبِّ النَّاسِ  مَلِكِ النَّاسِ  إِلَهِ النَّاسِ  مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِمِنَ الْجِنَّةِ وَالنَّاسِ. تمت</explicit>
                     <note>18:75–114:6.
The last word of the page is often repeated in the next one, and the catchword matches then with the second word.</note>
                     <note/>
                  </msItem>
               </msContents>

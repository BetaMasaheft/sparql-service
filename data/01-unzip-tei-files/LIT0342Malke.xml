      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስምዐኒ፡ ብሂል፨</l>
                  <l n="2">እምአፈ፡ ነቢይት፡ ሐና፡ እንዘ፡ እዝነ፡ እግዚአብሔር፡ ልዑል፨</l>
                  <l n="3">ኮከበ፡ ገዳም፡ ሳሙኤል፡ ዘውገ፡ ሚካኤል፨</l>
                  <l n="4">ሀበኒ፡ ኀይለ፡ ለፍጻሜ፡ በሞገሰ፡ ንባብ፡ ወቃል፨</l>
                  <l n="5">ውዳሴ፡ ዚአከ፡ ዘሥርው፡ በሣህል፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ወለገጽከ፡ ስቡሕ፨</l>
                  <l n="2">ለቀራንብቲከ፡ ክልኤ፡ ወለዐይንከ፡ ፍሡሕ፨</l>
                  <l n="3">ገዳማዊ፡ ሳሙኤል፡ መግረሬ፡ አንበሳ፡ መፍርህ፨</l>
                  <l n="4">ሚካኤል፡ ቅድሜከ፡ ፍና፡ ጽድቅ፡ እንዘ፡ ይመርሕ፨</l>
                  <l n="5">ሐውጸኒ፡ በረድኤት፡ ወምሕረት፡ ብዙኅ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ መቃብረ፡ ጻድቃን፡ ዘኮነ፨</l>
                  <l n="2">ለዘዓለመ፡ ኀደገ፡ ወለዘመንግሥቶ፡ መነነ፨</l>
                  <l n="3">ላዕለ፡ ታቦተ፡ ሕግ፡ ሳሙኤል፡ ዘተሰመይከ፡ ካህነ፨</l>
                  <l n="4">ሥነ፡ ስብሐቲከ፡ እንዘ፡ ይትሜሰል፡ ብርሃነ፨</l>
                  <l n="5">ሰማየ፡ ሰማየ፡ ወሰማያተ፡ ከደነ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">እስመ፡ አቅረብኩ፡ ስብሐተ፡ ለመልክእከ፡ አምጣነ፡ ብየ፡ ልቡና፨</l>
                  <l n="2">በእንተ፡ ማርያም፡ ድንግል፡ ወዕፀ፡ ትእምርት፡ ዘደብረ፡ ሲና፨</l>
                  <l n="3">ሳሙኤል፡ ምርሐኒ፡ ገዳመ፡ ጸሎት፡ ወጽሙና፨</l>
                  <l n="4">ለወለተ፡ ከልብ፡ ዘመራሕካ፡ በፍና፨</l>
                  <l n="5">እስከነ፡ ግብራ፡ ተበፅዐ፡ ወኮነ፡ ለዜና፨</l>
               </lg>
            </div>
         </div>
      </body>

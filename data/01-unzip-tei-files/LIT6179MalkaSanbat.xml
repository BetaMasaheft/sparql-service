        <body>
            
            <listBibl type="editions">
                <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
            <div type="edition" xml:lang="gez">
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ስመ፡ ነከራ፡ ወተዐጽቦ፨</l>
                        <l n="2">ወለሥዕርተ፡ ርእስኪ፡ ሰላም፡ ብርሃነ፡ መለኮት፡ ዘይገለብቦ፨</l>
                        <l n="3">ሰንበተ፡ ክርስቲያን፡ ቅድስት፡ አረፍተ፡ ኀጥኣን፡ እምተመድንቦ፨</l>
                        <l n="4">ዕቀብኒ፡ ለመልአከ፡ ኀይል፡ ኢይኩን፡ ምርካቦ፨</l>
                        <l n="5">እስመ፡ እንበሌኪ፡ ዘያመሥጥ፡ አልቦ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለርእስኪ፡ ርጢነ፡ መድኃኒት፡ ቅቡእ፨</l>
                        <l n="2">ወለገጽኪ፡ ሰላም፡ እምነጽሮተ፡ ሰብእ፡ ኅቡእ፨</l>
                        <l n="3">ሰንበተ፡ ክርስቲያን፡ ጽሕፍት፡ በዘመንፈስ፡ ቅዱስ፡ ብርዕ፨</l>
                        <l n="4">ኢይትፌጸም፡ አንብቦቶ፡ በአፈ፡ ብእሲ፡ ኃጥእ፨</l>
                        <l n="5">ስብሐተ፡ ስምኪ፡ በዓለም፡ ምሉእ፨</l>
                    </lg>
                    <lg type="stanza" n="24">
                        <l n="1">ሰላም፡ ለቆምኪ፡ እምነ፡ በቀልት፡ ኅሩይ፨</l>
                        <l n="2">ወለመልክእኪ፡ ሥርግው፡ በሜላተ፡ ረቂቅ፡ ባሕርይ፨</l>
                        <l n="3">ሰንበተ፡ ክርስቲያን፡ ቅድስት፡ ዕለተ፡ ማርያ፡ ዐባይ፨</l>
                        <l n="4">አድኅነኒ፡ በኪዳንኪ፡ እሞግበ፡ እሳት፡ ውዑይ፨</l>
                        <l n="5">ከመ፡ ለባዕል፡ ማርያም፡ በማይ፨</l>
                    </lg>
                    <lg type="stanza" n="25">
                        <l n="1">አቅረብኩ፡ ለኪ፡ ስብሐታተ፡ መጠነ፡ ፳ወ፭ቱ፨</l>
                        <l n="2">መድኃኒተ፡ ነፍሶ፡ ይኩኖ፡ ለአምላከ፡ ጽድቅ፡ ጊዜ፡ ምጽአቱ፨</l>
                        <l n="3">ሰንበተ፡ ክርስቲያን፡ ሀብኒ፡ ፍትሐ፡ ሣህልኪ፡ ለለ፡ ዕለቱ፨</l>
                        <l n="4">ከመ፡ ይነሥአ፡ ዐስበ፡ ጻማሁ፡ ነጋጺ፡ ዓለም፡ ዝንቱ፨</l>
                        <l n="5">ዐስበ፡ ድርሳንየ፡ ኢጥፋዕ፡ በከንቱ፨</l>
                    </lg>
                </div>
            </div>
            
        </body>

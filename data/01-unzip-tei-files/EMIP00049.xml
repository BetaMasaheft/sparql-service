                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="138r" facs="005">Fols 1r–138r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="104r" facs="005">Fols 1r–104r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <note><locus from="97r" facs="101">Fols 97r and following</locus>, <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>

                        <msItem xml:id="ms_i1.1.1">
                          <locus from="1r" facs="005">Fols 1r and following</locus>
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT2005Mazmur">Mazmura
                                                  Krǝstos</title>
                          <note>introduced with the first pslam from this work</note>
                        </msItem>

                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="104v" to="115r" facs="109">Fols 104v–115r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                        <note>Columetric layout of text: <locus target="#111v #112r #112v" facs="116 117">fols. 111v, 112r, 112v</locus> (tenth biblical canticle)</note>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="115v" to="123r" facs="120">Fols 115v–123r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                        <note>a fine example of the Hebraic version in the base text</note>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="123v" to="134r" facs="128">Fols 123v–134r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                        <note>
                    Arranged for the days of the week
                    (Monday, <locus target="#123v" facs="128">fols. 123v, </locus>;
                    Tuesday, <locus target="#124v" facs="129">124v, </locus>;
                    Wednesday, <locus target="#126r" facs="130">126r, </locus>;
                    Thursday, <locus target="#128r" facs="132">128r, </locus>;
                    Friday, <locus target="#130r" facs="134">130r, </locus>;
                    Saturday, <locus target="#131v" facs="136">131v, </locus>;
                    Sunday, <locus target="#132v" facs="137">132v</locus>)
                  </note>
                     </msItem>

                     <msItem xml:id="ms_i1.5">

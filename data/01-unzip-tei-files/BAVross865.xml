                    </msIdentifier>
                    
                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="28v">Fols 1r–28v</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna Māryām ba-Dabra Golgotā</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="28v" to="42v">Fols 28v–42v</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ውዳሴ፡ ዘእግ<sic>ግ</sic>ዝእ<sic>ተ</sic>። ማርያም<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> ዘይ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">ት</t:supplied>ነበብ፡ በሰንበተ፡ ክርስዪታን፡ ጸሎታ፡ ወበረከታ፡ <sic>ያሁሉ፡</sic> ምስሌነ፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="43r" to="45r">Fols 43r–45r</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4534Salam">Malkǝʾ-hymn to Our Lady Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ባሕታዊት፡ ወለት፡ እንበለ፡ እኅው፡ ወእኅት፡</incipit>
                            <explicit xml:lang="gez"><sic>ተዝከረ፡</sic> አንብዕኪ፡ ይቁም፡ ቅድመ፡ ገጹ፨ ወልድኪ፡ በኀቤየ፡ ምሕረቶ፡ ኢይዕፁ፨</explicit>
                        </msItem>
                    </msContents>
                    

                        <additions>
                            <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                                <item xml:id="e1">
                                    <locus target="#1r">Fol. 1r</locus>
                                    <t:desc>The name of the church of "S. Martino in Secchia" is written, as well as the name "Ioachinus Bon(oniensis?)."</t:desc>
                                </item>
                                <item xml:id="e2">
                                    <locus target="#33r">Fol. 33r</locus>
                                    <t:desc>Written in the lower margin with faded yellow ink is, <foreign xml:lang="it">io non capisco questo libro per niente</foreign>, the rest is illegible.</t:desc>
                                </item>
                                <item xml:id="e3">
                                    <locus target="#46r">Fol. 46r</locus>
                                    <t:desc type="OwnershipNote">
                                        A description of the manuscript in Italian and an ownership note in Gǝʿǝz.
                                        <q>Questo officiolo chaldeo <lb/> è da Luca d'ethyopia <lb/> Indiano della India <lb/> maggior del Prete Ioannj<lb/>
                                            <sic>ዘቲ፤</sic> መጽሐፍ፡ ዘሉቃስ፡ <lb/> ኢትዮጵያዊ። ዘሰረቆ፡ ዲ<lb/>ያብሎስ፡ ይስርቆ።</q>
                                    </t:desc>
                                </item>
                                <item xml:id="e4">
                                    <locus target="#46v">Fol. 46v</locus>
                                    <t:desc>
                                        A description of the manuscript in Italian.
                                        <q>Manoscritto del Sec. XIV in lingua Etiopica <lb/> intitolato GHEEZ e contente <lb/> Orazioni alla Vergine ed alcuni <lb/> salmi, ordinato da un certo <lb/> Luca Etiopeno</q>
                                    </t:desc>
                                </item>
                                <item xml:id="e5">
                                    <locus target="#46v">Fol. 46v</locus>
                                    <t:desc>
                                        An added note in Latin, written in pen in a ninteenth century hand.
                                        <q>nihil addendum <lb/> sed Gheez non est <lb/> titulus, verum nomen <lb/> linguae ethiopicae hâc <lb/> ipsa linguâ</q>
                                    </t:desc>
                                </item>
                            </t:list>
                        </additions>

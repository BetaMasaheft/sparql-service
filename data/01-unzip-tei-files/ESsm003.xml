                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">careful</seg>
                        <seg type="ink">Black; red.</seg>
                        Scribe: Bäʾǝdä
                        Māryām. &lt;Bäʾǝdä&gt; Māryām (s. Additio 3).<date>Mid or second
                           half of 18th century</date>
                        <seg type="rubrication">Nomina sacra; name of the donor; names of the
                           Evangelists written in the margins; groups of lines on the incipit page
                           of each text; incipit of sections of Text I and of each chapter of Texts
                           II-V; the word mǝʿrāf and chapter numbers; numbers of the “tituli”;
                           elements of the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>

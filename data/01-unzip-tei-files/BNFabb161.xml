                      <msItem xml:id="p1_i1">
                                                <locus from="1r" to="107vb">1-214</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6912CommentaryEnoch">Amharic commentary on the Book of Enoch by mamhǝr Getāhun</title>
                         <textLang mainLang="am"/>
                        <incipit xml:lang="am">ዘሄኖክ፡ ነቢይ፡ በረከቱ፡ ተሀሉ፡ ምስለ፡ ፍቁሩ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS1071dAbbadi">እንጦንዮስ፡</persName> ለዓለመ፡ ዓለም፡ አሜን፨
                        ሄኖክ፡ ማለት፡ ተሐደሰ፡ ማለት፡ ነው። ይኸስ፡ በባሕርዩ፡ ብልዬተ፡ ኃጢአት፡ ያለበት፡ ይመስላል፡ ብሎ፡ ሐዲስ፡ ማለት፡ ነው፡</incipit>
                        <colophon xml:lang="gez" xml:id="coloph1">
                          <locus from="117va" to="117vb">214</locus>
                          ጻድቃንና፡ ኃጥአንም፡ በየተፃፈ፡ ላቸው፡ ስፍራ፡ ለመኖር፡ ይሄዳሉ። አስጀምሮ፡ ላስጨረሰን፡ ክብር፡ ይግባዉ፡ በውነት፡ እንበለ፡ ሐሰት። 
                          ይኽ፡ የሄኖክ፡ ትርጓሜ፡ የተጻፈ፡ የ<persName role="owner" ref="https://betamasaheft.eu/PRS1071dAbbadi">እንጦንዮስ፡ ዘአባዲያ፡</persName> 
                          በቃለ፡ <persName ref="https://betamasaheft.eu/PRS14260Getahun">መምህር፡ ጌታሁን፡</persName>
                          በእደ፡ ጸሐፊ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS14286Warqe">ወርቄ።</persName>  በ<date>ሽሕ፡ ከስምንት፡ መቶ፡ አርባ፡ ዓመተ፡ ምሕረት፡ በዘመነ፡ ዮሐንስ፡ ወንጌላዊ፡ በወርኃ፡ ሚያዝያ፡ በኃ<cb n="b"/>ያ፡ ቀን፡ በዕለተ፡ ሐሙስ፡</date> ተፈጸመ።
                          እንዘ፡ አበቅቴ፡ ፀሐይ፡ አርባዕቱ፡ ወአበቅቴ፡ ወርኅ፡ እስራ፡ ወሐምስቱ፡ በሐሳበ፡ ፀሐይ። <gap reason="ellipsis" resp="DN"/>
                        </colophon> 
                        <note>The colophon mentions <date>20 Miyāzyā 1840  EC, the year of John (=27 April 1848 CE)</date>.</note>
                               </msItem>


         <t:listPerson>
            <t:person sex="1">
          
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ተክለ፡ ሐዋርያት፡ ተክለ፡ ማርያም፡</t:persName>

               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Takla Ḥawāryāt Takla Māryām</t:persName>
                   <t:persName>
                  <t:roleName type="title">baǧǝrond</t:roleName>
               </t:persName>
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
                  <t:occupation type="literary">writer</t:occupation>
               <t:occupation type="political">statesman</t:occupation>
                  <t:birth notBefore="1867" notAfter="1868"/>
               <t:birth when="1884"> He was born at <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName> in <t:date>1884</t:date>.</t:birth>
                  
                  
                  <t:floruit notBefore="1896" notAfter="1977">He was a prominent statesman and administrator, 
                     as well as an important figure in the history of Amharic literature. 
                     When he was 9 years old he moved to <t:placeName ref="https://betamasaheft.eu/LOC3786Harar">Ḥarar</t:placeName> 
                     with his elder brother who became a secretary to 
                      
                     <t:persName ref="https://betamasaheft.eu/PRS6567Makwanne">
                     <t:roleName type="title">rās</t:roleName>
                  </t:persName> where he was brought up as a family member. 
                     In <t:date>1896/97</t:date>, 
                     he was sent to <t:placeName ref="https://www.wikidata.org/entity/Q159">Russia</t:placeName> where he joined St. Petersburg military school and
                     later Michael Artillery School. In <t:date>1908 </t:date> 
                     he returned to <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>.
                     A year later, <t:date>1909</t:date>, he was sent to <t:placeName ref="https://www.wikidata.org/entity/Q142">France</t:placeName> to study agriculture. 
                     On his return, he served the Imperial government for a long time in various posts.
                     He was one of the intellectual reformists of the imperial government before the Italian war. 
                   He drafted the first Ethiopian Constitution which was promulgated in <t:date>1931</t:date>. 
                     Apart from his political and administrative activities,
                     his name is also closely linked to the emergence of Ethiopian drama and theatre.
                  </t:floruit>
               <t:death when="1977">He died at <t:placeName ref="https://betamasaheft.eu/LOC3875Hirna">Hirna</t:placeName>.
               </t:death>
                  
                  
               </t:person>
               
         </t:listPerson>
 
            
            

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="50r">Fols 1r–50r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa saʿātāt</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ነሢዕየ፡ ማዕተበ፡ ለወልደ፡ እግዚአብሔር፡ አአትብ፡ በሥላሴ፡ ለእመኒ፡
                       ወደቁ፡ አቲብየ፡ እትነሣእ፡ በስመ፡ አብ፡
                        ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ኃይለ፡ መሰቀሉ፡ ዕትመረጐዝ፨ ሃ<hi rend="rubric">ሌ፡ ሃሌ፡ ሃሌ፡ ለያ፡</hi>
                        አአትብ፡ ወእትነሣእ፡ በስመ፡ አብ፡ ወወልድ፡ <hi rend="rubric">ወመንፈስ፡</hi> ቅዱስ፡</incipit>
                     <explicit xml:lang="gez">
                        <locus target="#50r">Fol. 50r</locus>
                        እ<hi rend="ligature">ግዚ</hi>አብሔር፡ ይባርክነ፡ ለአግብርቲሁ፡ በሰላም፡ ስርየተ፡ ይኵነነ፡ ዘተመጣነ፡ ወደምከ፡ ሐብነ፡
                        ወምንፈስ፡ ንኪድ፡ ኵሎ፡ ኃይሎ፡ ለጸላኢ፡ በረከተ፡ <hi rend="expunctuated">እ</hi>እዴከ፡ ቅድስት፡ እንተ፡
                        <add place="above"><hi rend="rubric">ምልዕተ፡</hi></add> ምሕረት፡ ኪያሃ፡ ንሴፎ፡ ኵልነ፡ እምኵለ፡ ምግባረ፡ ዕኩይ፡
                        አግሕሐነ፡ ወውስተ፡ ኵሉ፡ ምግባረ፡ ሠናይ፡ ደምረነ<hi rend="rubric">፨</hi>
                        ቡሩክ፡ ዘወሀበነ፡ ሥጋሁ፡ ቅዱሰ፡ ወደሞ፡ ክቡረ፡ ጸጋ፡ ነሣእነ፡ ወሕይወተ፡ ረከብነ፡ በኃይለ፡ ወሰቀለ፡ ኦኢየሱስ፡ ክርስቶስ፡ ኪያከ፡ እግዚኦ፡
                        ነአኵት፡ ነሣአነ፡ ጸጋ፡ ዘእመንፈስ፡ ቅድይስ<hi rend="rubric">፨</hi> <hi rend="rubric">ይዲ፡</hi>
                        እትው፡ በሰላም<hi rend="rubric">፨ ፨ ፨ ፨ ፨ ፨ ፨</hi>
                     </explicit>
                     <note>A version of the work similar to
                       <bibl corresp="http://zotero.org/groups/358366/items/I6R8Q66K"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Tasfa1955Saatat"/><title level="m">&lt;hi rend="italics"&gt;ሰዓታት። ዘሌሊት፡ ወዘነግህ። (&lt;/hi&gt;Saʿātāt. Za-lelit wa-za-nagh&lt;hi rend="italics"&gt;, ‘The Book of the Hours. Of the night and of the morning’)&lt;/hi&gt;</title><editor><name>Tasfā Gabra Śǝllāse</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā Gabra Śǝllāse māttamiyā bet</publisher><date>1954</date><note type="tags"><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note></note><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note></bibl>,
                       but with omissions. A
                       small portion of the text at the beginning is missing.
                        The beginning of the text corresponds to
                        <bibl corresp="http://zotero.org/groups/358366/items/I6R8Q66K"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Tasfa1955Saatat"/><title level="m">&lt;hi rend="italics"&gt;ሰዓታት። ዘሌሊት፡ ወዘነግህ። (&lt;/hi&gt;Saʿātāt. Za-lelit wa-za-nagh&lt;hi rend="italics"&gt;, ‘The Book of the Hours. Of the night and of the morning’)&lt;/hi&gt;</title><editor><name>Tasfā Gabra Śǝllāse</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā Gabra Śǝllāse māttamiyā bet</publisher><date>1954</date><note type="tags"><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note></note><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note><citedRange unit="page">6</citedRange></bibl>.
                  </note>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="50r" to="51r">Fols 50r–51r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3308Nicene">Nicene Creed</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡</hi> ሃይማኖት፡ ነአምን፡ ፩አምላክ፡ እ<hi rend="ligature">ግዚ</hi>አብሔር፡ አብ፡ አኃዜ፡ ኵሉ፡ ገባሬ፡ ሰማያት፡
                        ወምድር፡ ዘያስተርአ፡ ወዘ<pb n="50v"/>ኢያስተርኢ፡ ወነአምን፡ በ፩ እግ<gap reason="illegible"/>እ፡ ኢየሱስ፡ ክርስቶስ፡
                        ወልደ፡ አ<supplied resp="DN" reason="undefined">ብ፡</supplied> ዋሕድ፡ ዘህልው፡
                        ምስሌ<del rend="expunctuated">ሆ</del>ሁ፡
                        እም<supplied resp="DN" reason="undefined">፡</supplied> ቅድ<del rend="expunctuated">ደ</del>መ፡ ይትፈጠር፡ አለም፡
                     ብርሃን፡ ዘ<add place="above">ዕ</add>ምብርን፡ አምላክ፡ ዘእምአምላክ፡ ዘበአማን፡ ዘተወልደ፡ ወአኮ፡ ዘተገብረ፡ ዘእሩይ፡ ምስለ፡ አብ፡ በመለኮቱ፡</incipit>
                     <explicit xml:lang="gez">ወነአምን፡ በሐቲ፡ ጥምቀት፡ ለሥርየተ፡ ኃጢአት፡ ወንሲፎ፡ ትንሣኤ፡ ሙታን፡ ወሕይወተ፡
                        ዘይመጸእ፡ ለዓለም፡ ዓለም፨ ፨ ፨</explicit>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="51r" to="67r">Fols 51r–67r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT5400AmmestuTig">Explications to the treatise ʾAmmǝstu ʾaʿmāda
                    mǝśṭir (‘The Five Pillars of Mystery’)</title>
                     <textLang mainLang="ti"/>
                     <note> Possibly incomplete, some leaves between
                        <locus target="#66">fols. 66, </locus> and <locus target="#67">67</locus> appear to be cut away
            (stubs are visible).</note>
                     <incipit xml:lang="ti">
                        <hi rend="rubric"> በስመ፡ አብ፡ ወወልድ፡
             ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡</hi> ኢልና፡ ንምእመናን፡ ንዓቢይ፡ ንንእሸቶ፡ ጥቅም፡
             ዚከውን፡ ካብ፡ ብዙኅ፡ ሒደቶ፡ ካብ፡
           ነዊኅ፡ ሐፂር፡ ስለዝበልናዮ፡ ግን፡ ሐፂር፡ <hi rend="rubric">
           አኰነን፡ አብ፡ ቅዱሳት፡ መጻሕፍት፡ ዘሎ፡ ምሥጢር፡ ዘይጐደለ፡ እዩ፡ ፭ተ፡

           አእማደ፡ ምስጢር፡</hi> ናይ፡ ፯መዓልቲ፡ <pb n="51v"/>ስነ፡ ፍጥረት፡

           ንጽሕፈልኩም፡ አሎና፡ </incipit>
                     <explicit xml:lang="ti">ሶሰነተይ፡ በሶሰነተይ፡ አንድነተይ፡ አሎኒ፡ ንማለት፡ ሰተ፡ ሰተ፡
             ግብር፡ ፈጠረሎም፡ ተፈጸመት፡ ዛቲ፡ መጽሐፍ፡ በሰላመ፡ እ<hi rend="ligature">ግዚ</hi>አብሔር፡ አሜን፨
           ተፈጸመ፡ በዕለተ፡ <hi rend="rubric">ረቡዕ</hi>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="67r" to="68r">Fols 67r–68r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5407BigFeastsTig">Quṣǝr baʿālāt za-ʿābiy wa-za-nǝʾus</title>
                     <textLang mainLang="ti" otherLangs="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">ቁጽር፡ በዓላት፡ ዘዓቢይ፡</hi> ወዘንኡስ፡ ሠረቀ፡ መስከረም፡ ፩ቅዱስ፡<hi rend="rubric">ዮሐንስ፡
                      </hi> በርተሎሜዎስ፡ ኢዮብ፡</incipit>
                     <explicit xml:lang="gez">አመ፡ ፬ለታኅሣሥ፡ እንድርያስ፡ ሐዋርያ ፨</explicit>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="68v" to="69v">Fols 68v–69v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1191Baenta">Baʾǝnta śǝllāseka</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">

                        <hi rend="rubric">በእንተ፡ ስላሴከ፡ </hi>እ<hi rend="ligature">ግዘ</hi>ኦ፡ በእንተ፡ <hi rend="rubric">በእንተ፡
                           እ<hi rend="ligature">ግዘ</hi>ኦ፡ ተ፡</hi> በእንተ፡ <sic resp="DN">ኅላዌዌከ፡</sic> እ<hi rend="ligature">ግዘ</hi>ኦ፡ ተሣሃለኒ፡ </incipit>

                  </msItem>


                  <msItem xml:id="ms_i6">
                     <locus from="69v" to="72v">Fols 69v–72v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4960Taabbeyo">Saʾali lana Māryām saʾali lana Māryām ḫaba waldǝki
                    ḫer madhane ʿālam</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez"><hi rend="rubric"> ተዓብዮ፡ ነፍስየ፡ ለእግዚአብኄር፡ </hi>በል፡ ፫ጊዜ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡
                     ሉያ፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሥላሴ፡ ብሂልየ፡
          ወጠንኩ፡ ዘለኪ፡ ውዳሴ፨ ማርያም፡ እኅቱ፡ ለሙሴ፡ ሰአሊ፡ ለነ፨ ማርያም፡ ወልኪ፡ መድሃኔ፡ ዓለም፡
          ንዒ፡ ንዒ፡ ማርያም፡ ዘትነብሪ፡ በአርያም፡ </incipit>
                     <explicit xml:lang="gez">ማርያም፡ እሙ፡ ለእ<hi rend="ligature">ግዚ</hi>እነ፡ በኪዳንኪ፡ ድንግል፡ ተማኅጸነ፡ ፫ጊዜ፡ በል፨</explicit>
                     <note>Possibly incomplete, some folia may be missing
                        since stubs are visible between <locus target="#71">fols. 71, </locus> and <locus target="#72">72</locus>.</note>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <locus from="72v" to="73v">Fols 72v–73v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4957SebhataF">Sǝbḥāta fǝqur za-Giyorgis</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">ሰአል፡ ለነ፡ ጊዮርጊስ፡</hi>ሰማዕተ፡
          ኢየሱስ፡ ክርስቶስ፡ ነአ፡ ነአ፨ ጊዮርጊስ፡ እንተ፡ ትሰርር፡ በፈረስ፡</incipit>
                     <explicit xml:lang="gez"><hi rend="rubric">ጊዮር፡
                     </hi>ሰማዕት፡ ፍጡነ፡ ረድኤት፡ ሐውፀነ፡ በምኅረት፡ ወተራድአነ፡ በቅጽበት፡፡

            </explicit>
                     <colophon xml:id="coloph1">
                        <locus target="#73v">Fol. 73v</locus>
                        <note xml:lang="en">Short colophon written in the main hand (Hand 1), mentioning only the day of the week (Tuesday),
                        followed by a Tigrinya note stating that the manuscript was owned by <persName ref="https://betamasaheft.eu/PRS12557Barha">Barhe</persName>.</note>
                        <foreign xml:lang="ti">ተፈጸመ፡ በዕለተ፡ ሠሉስ፡ እዚ፡ መጽሐፍ፡ ናይ፡ <persName ref="https://betamasaheft.eu/PRS12557Barha">በርሄ</persName>፡ እዩ፡፡</foreign>
                     </colophon>

                        </msItem>

                  <msItem xml:id="ms_i8">

                    <decoNote type="miniature" xml:id="d11"><locus target="#42r" facs="042">Fol. 42r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> (right), an <term key="angel" ana="#angel"/> on a cloud (left), <persName ref="https://betamasaheft.eu/PRS5764Joseph">Joseph</persName> (?) far left)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d12"><locus target="#45v" facs="046">Fol. 45v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1025NativityJesus">Nativity of Jesus</ref>, with the Holy family</desc></decoNote>
                    <decoNote type="miniature" xml:id="d13"><locus target="#46r" facs="046">Fol. 46r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1025NativityJesus">Nativity of Jesus</ref>, baby <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> among the angels</desc></decoNote>
                    <decoNote type="miniature" xml:id="d14"><locus target="#51v" facs="052">Fol. 51v</locus><desc>The child <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, with <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (left) and three figures right</desc></decoNote>
                    <decoNote type="miniature" xml:id="d15"><locus target="#52r" facs="052">Fol. 52r</locus><desc>The child <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, with the holy family (left) and evil boys (showing one eye) right. Three <term key="angel" ana="#angel"/>s are above</desc></decoNote>
                    <decoNote type="miniature" xml:id="d16"><locus target="#57v" facs="058">Fol. 57v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> on cloud (upper left) speaking to four men (upper right) and to four women (lower right)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d17"><locus target="#58r" facs="058">Fol. 58r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (left) and <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (right) above an <term key="angel" ana="#angel"/> with outstretched wings</desc></decoNote>
                    <decoNote type="miniature" xml:id="d18"><locus target="#63v" facs="064">Fol. 63v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName>, surrounded by four women and two <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d19"><locus target="#64r" facs="064">Fol. 64r</locus><desc>The beheading of John the Baptist</desc></decoNote>
                    <decoNote type="miniature" xml:id="d20"><locus target="#73v" facs="074">Fol. 73v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> (center), and <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> (left), with pots before <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (The Wedding at Cana?)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d21"><locus target="#74r" facs="074">Fol. 74r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, kneeling (center) and stretching out hands toward a person (left) with a jug tied to their back</desc></decoNote>
                    <decoNote type="miniature" xml:id="d22"><locus target="#81v" facs="082">Fol. 81v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, on a cloud (left), instructing a group of disciples</desc></decoNote>
                    <decoNote type="miniature" xml:id="d23"><locus target="#82r" facs="082">Fol. 82r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (center) with disciples behind and encountering three evil (showing one eye) men</desc></decoNote>
                    <decoNote type="miniature" xml:id="d24"><locus target="#89v" facs="090">Fol. 89v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (center), being led away bound by an evil man (showing one eye, right), disciples following (left)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d25"><locus target="#90r" facs="090">Fol. 90r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1086StrikingHead">The Striking of the Head, ኵርዓተ፡ ርእሱ፡</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d26"><locus target="#92v" facs="093">Fol. 92v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, tied to a post, with <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and <persName ref="https://betamasaheft.eu/PRS5695John">John</persName> grieving (left)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d27"><locus target="#93r" facs="093">Fol. 93r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, with sun, moon, and stars above</desc></decoNote>
                    <decoNote type="miniature" xml:id="d28"><locus target="#103v" facs="104">Fol. 103v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1010Entombment">Entombment of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d29"><locus target="#104r" facs="104">Fol. 104r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref></desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                      <locus target="#1r" facs="001">Fol. 1r</locus>
                      <desc>Despite the label, the Weiner collection number should be 466 and not 463</desc>
                    </item>
                    <item xml:id="a1">
                      <locus target="#1r" facs="001">Fol. 1r</locus>
                      <desc type="RecordTransaction">Record of donation of the book to the church: Debra Mariam Church in Damot Gojjam</desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#32r" facs="032">Fol. 32r</locus>
                      <desc>the opening prayer remembers the soul of Abuna Walda Giyorgis</desc>
                    </item>
                    <item xml:id="a3">
                      <locus target="#31v" facs="032">Fol. 31v</locus>
                      <desc type="OwnershipNote">
                      Written in pink ink.
                      <foreign xml:lang="gez">ዘአጥረያ፡ በነዋዩ፡ ለዛቲ፡ መጽሐፍ፡ ዘወሀበ፡ ለአቡነ፡ አፍቀረነ፡ እግዚእ፡ ዘደብረ፡ ጕግቤን፡ ብእሴ፡ እግዚአብሔር፡ ወምዕመን፡ አባ፡ ገብረ፡ ጻድቅ።
                        አክቡራን፡ ማህበራነ፡ ጕግቤን፡ ኢትር[..]ዑኒ፡ በጸሎትክሙ፡ አላ፩፩፡ አቡነ፡ ዘበሰማያት፡ ለዝ፡ መጽሐፍ፡ ዘሰራቆ፡ ወዘፈሀቆ፡ በስልጣነ፡ ጴጥሮስ፡ ወጳውሎስ፡ ውጉዘ፡ ለይኩን።</foreign>
                        Translation:
                        <q>Man of God and faithful, Abba Gabra Tsadek, bought this book with his own money and gave it to [the church of] Abuna Afaqerana Egzia, of Dabra Gugben.
                          Honorable member of Gugben, do not forget me in your prayers. Instead, [recite] one Our Father. Anyone who steals or defaces this book,
                          may he be anathemized by the authority of Peter and Paul</q>
                      </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#62r" facs="062">Fol. 62r</locus>
                    <desc>
                    Twice, an original name, in red ink, has been erased and a secondary name written over in black ink: <foreign xml:lang="gez">አቡነ ወልደ ጊዮርጊስ</foreign>, Abuna Walda Giyorgis
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#111r" facs="111"> f. 111r, column 1</locus>
                    <desc>
                    closes in a prayer remembering the soul of Abuna Walda Giyorgis
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1750" notAfter="1799">Late-eighteenth century</origDate>
                  </origin>
               </history>
            </msDesc>
         </sourceDesc>

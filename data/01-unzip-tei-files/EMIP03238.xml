               <msContents>
                  <summary>Miracles of Mary</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="2r" to="31v" facs="002">Fols 2r–31v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>, including, for instance (the miracles are unnumbered; many folios are covered with paintings)</note>

                      <msItem xml:id="ms_i1.1"><title type="complete" ref="https://betamasaheft.eu/LIT6024IntroMM">Introductory text
                                                  and hymn to the Miracles of Mary</title></msItem>
                      <msItem xml:id="ms_i1.2"><title>Thirty-Eight Miracles of Mary</title>
                        <msItem xml:id="ms_i1.2.1"><locus from="5V" to="6R" facs="006">Fols 5V–6R</locus><title type="complete" ref="https://betamasaheft.eu/LIT3716Miracle">Miracle of Mary:
                                                  Miracle of the blind child of a woman from Cairo
                                                  healed by Mary</title>
                          <incipit xml:lang="gez">ወሀለወት፡ እሐቲ፡ ብእሲት፡ ምስለ፡ ሐማታ፡ በይወለ፡ ቃትራ፡ ወቢታኒ፡ በጽንፈ፡ ባሕር፡ ወመዋግዲሁ፡ ይበጽሕ፡ ውስተ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.2"><locus from="6r" to="6v" facs="006">Fols 6r–6v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3655Miracle">Miracle of Mary:
                                                  Miracle of a woman from Ceasarea whom Mary helped
                                                  to give birth</title>
                          <incipit xml:lang="gez">ወሀለወት፡ አሐቲ፡ ብእሲት፡ እምዓበይተ፡ ሀገር፡ ዘቂሳርያ፡ ወኮነ፡ አቡሃባዕለ፡ በሕቁ፡ በወርቅ፡ ወበብሩር፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.3"><locus from="6v" to="7r" facs="007">Fols 6v–7r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3708Miracle">Miracle of Mary:
                                                  Miracle of a woman who despite her mother-in-law
                                                  adored a torn image of Mary</title>
                          <incipit xml:lang="gez">ወሀለወት፡ አሐቲ፡ ብእሲት፡ ምስለ፡ ሐማታ፡ ዘታፈቅራ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ማርያም፡ ወላዲተ፡ መለኮት፡ ወሶበ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.4"><locus from="7r" to="7v" facs="007">Fols 7r–7v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3919Miracle">Miracle of Mary:
                                                  Miracle of the sinful deacon ʾAstirās whom Mary
                                                  ordered to be buried in the believers'
                                                  graveyard</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩መስፍን፡ ሐራዊ፡ ዘንጉሥ፡ ውስተ፡ ጠርሲስ፡ ዘዊልቅያ፡ ወዲይቆን፡ ውእቱ፡ ዘበስም፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.5"><locus from="7v" to="8r" facs="008">Fols 7v–8r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3709Miracle">Miracle of Mary:
                                                  Miracle of a woman who prayed for a child and sees
                                                  three sons in an apparition</title>
                          <incipit xml:lang="gez">ወሀለወት፡ አሐቲ፡ ብእሲት፡ በዳወ፡ ቃሐራ፡ ወወለደተ፡ ፯ውሉደ፡ ወሞቱ፡ ኵሎሙ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.6"><locus from="8r" to="8v" facs="008">Fols 8r–8v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3646Miracle">Miracle of Mary:
                                                  Miracle of Mark, son of the king of Rome, Gabra
                                                  ʾIyasus</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩ብአሲ፡ ዘስሙ፡ ማርቆስ፡ ንጉሠ፡ ሮምያ፡ እምድኅረ፡ አቡሁ፡ ንጉሥ፡ ዘስሙ፡ ገብራ፡ ኢያሱስ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.7"><locus from="8v" to="9r" facs="009">Fols 8v–9r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3694Miracle">Miracle of Mary:
                                                  Miracle of Qirās, a brigand of Galatia, saved by
                                                  Mary from hanging</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩፡ ብእሲ፡ በሀገረ፡ ገላትያ፡ ዘስሙ፡ ቂራስ፡ ሠራዊ፡ ውእቱ፡ ወፈያታዊ፡ ወቀታሌ፡ ነፍስ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.8"><locus from="9r" to="9v" facs="009">Fols 9r–9v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3919Miracle">Miracle of Mary:
                                                  Miracle of the sinful deacon ʾAstirās whom Mary
                                                  ordered to be buried in the believers'
                                                  graveyard</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩ዲያቆን፡ ውስተ፡ አሐቲ፡ ደሴት፡ ዘባሕረ፡ ኢያሪኮ፡ አንተ፡ ስማ፡ ገሪሳት፡ ውእቱሰ፡ ዲያቆን፡ ዘማዊ፡ ውእቱ፡ ወይገብር፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.9"><locus from="9v" to="10r" facs="010">Fols 9v–10r</locus><title>Covered with paintings</title></msItem>
                        <msItem xml:id="ms_i1.2.10"><locus from="10v" to="11r" facs="011">Fols 10v–11r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3590Miracle">Miracle of Mary:
                                                  Miracle of the scribe Damianus from
                                                  Philippi</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩፡ መነከስ፡ ዘይነብር፡ በሀገረ፡ ፊልጵስዩስ፡ ዘስሙ፡ ድምያኖስ፡ ለእግዝአትነ፡ ቅድስት፡ ድንግል፡ ብ፪ማርያም፡ ወላዲተ፡ መለኮት፡ እማእምቀ፡ ልቡ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.11"><locus from="11v" to="12r" facs="012">Fols 11v–12r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3592Miracle">Miracle of Mary:
                                                  Miracle of the monk Isaac</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩፡ መነኮስ፡ ኄር፡ ዘስሙ፡ ይስሐቅ፡ ወያፈቅራ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.12"><locus from="12r" to="12v" facs="012">Fols 12r–12v</locus><title>Maryam from Dǝfrā, a child who wanted to receive Communion but was shut up in the house when her family went to church</title>
                          <incipit xml:lang="gez">ወሀሎ፡ ፩፡ ብእሲ፡ ፈራሄ፡ እግዚአብሔር፡ ዘይፈቅራ፡ ለእግዝአትነ፡ ቅድስት፡ ድንግል፡ <gap reason="omitted"/> ሀገሩሰ፡ ድፍራ፡ ወአውሰበ፡ ብእሲተ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.13"><locus from="12v" to="13r" facs="013">Fols 12v–13r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3594Miracle">Miracle of Mary:
                                                  Miracle of a French painter whose scaffold was
                                                  overthrown by the devil</title>
                          <incipit xml:lang="gez">ወሀሎ ፩፡ ብእሲ፡ ሰዓሊ፡ ወአልቦ፡ ዘይትማሰሎ፡ በውእቱ፡ አዝማን፡ በገብረ፡ ሥዕል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.14"><locus from="13r" to="13v" facs="013">Fols 13r–13v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3595Miracle">Miracle of a sick
                                                  man in a hospital whom Mary carries to
                                                  Jerusalem</title>
                          <incipit xml:lang="gez">ወሀለወት፡ ሥዕለ፡ እግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ማርያም፡ ወላዲተ፡ አምላክ፡ በደብረ፡ ነጋድያን፡ በቤተ፡ ሕሙማን፡ መንገለ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.15"><locus from="13v" to="14v" facs="014">Fols 13v–14v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3596Miracle">Miracle of Mary:
                                                  Miracle of the youth Zechariah, from Rome</title>
                          <incipit xml:lang="gez">ወሀሎ: ፩ወሬዛ: ዘሠናይ: አርአያሁ: ዘስሙ: ዘካርያስ: እምዘመደ: መንግሥት: ዘሀግረ: ሮሜ:</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.16"><locus from="14v" facs="015">Fols 14v and following</locus><title type="complete" ref="https://betamasaheft.eu/LIT3597Miracle">Miracle of Mary:
                                                  Miracle of Juliana and Barbara from
                                                  Bethlehem</title>
                          <incipit xml:lang="gez">ወሀለዋ፡ ክልኤ፡ አንስት፡ አእማተ፡ እግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ማርያም፡ ወላዲተ፡ ፈጠሪ፡ በቤተ፡ ልሔም፡ እምአዋልደ፡ ይሁዳ፡ ስማ፡ ለአሐቲ፡ ዮልያና፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2.17"><locus from="15r" to="31v" facs="015">Fols 15r–31v</locus><title>Approximately 22 further Miracles of Mary</title></msItem>
                      </msItem>
                    </msItem>

                  <msItem xml:id="ms_i2"><locus from="32r" to="111r" facs="032">Fols 32r–111r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme">Taʾammǝra
                                                  ʾIyasus</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>32 Miracles of Jesus Christ</note>

                    <colophon xml:id="coloph1">

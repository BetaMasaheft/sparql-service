            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/JQ8WXBQV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Uhlig1993Katholischen"/><title level="m">Novum Testamentum Aethiopice: Die katholischen Briefe</title><title level="s">Aethiopistische Forschungen</title><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Josef</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Hofmann</t:surname></editor><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Siegbert</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Uhlig</t:surname></editor><pubPlace>Stuttgart</pubPlace><publisher>Franz Steiner</publisher><date>1993</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Aethiopistische Forschungen</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">29</t:biblScope></series><biblScope unit="volume">29</biblScope></bibl>

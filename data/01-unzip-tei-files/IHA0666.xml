               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="40r">1r-40r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1484IHA">بضاعة المسكين في مولد خير الانبياء والمرسلين</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله الذي بدء العوالم بالنور المحمدية صلى الله عليه وسلم وبه ختم وجعل سرا جداول هيكل الذات وروح الطلسم [...] وبعد فيقول واضع هذا التعليق احقر الناس قدرا واسوئهم حالا محمد يس بن منصور الياس بن محمد الامين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#40r">-40r</locus>ما تلملت حيتان مدحه في صفته اليم وترونق افواه تالي لا اله الا هو الحي القيوم لا تاخذه سنة وال نوم تمت</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="40v" to="41r">40v-41r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1486IHA">نظم الله يا الله صلاة منك</title>
                     <incipit xml:lang="ar">
                        <locus target="#40v">-40v</locus>الله يالله صلاة منك يا هو اعلي النبي تغشاه والصحب من والاه  \ محمد شفيع نبينا الرفيع وحصننا المنيع من كل ما نخشاه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#41r">-41r</locus>وامنح رضاك ربي واستر عيوب الذنب واصلح فساد القلب بحق مصطفى \ صلى عليه الله والصحب من والاه ما قانت اواه يقول يالله</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="41r" to="42r">41r-42r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1487IHA">نظم جمالك الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#41r">-41r</locus>وقال رضي الله عنه \ الله الله كمالك الله جلالك الله جمالك الله \ سبحان ذي العلاء والمجد والثناء والنور والضياء جمالك الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#42r">-42r</locus>بحق مولي الجودى واشرف الوجود محمد المحمود جمالك الله \ عليه صلى الوالي وصحبه والال دوما علي التوالي جمالك الله</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="42r" to="43r">42r-43r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1488IHA">نظم رسول الله غط الران قلبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#42r">-42r</locus>قال رضي الله عنه \ صلاة الله ما فاه المنبي علي طه وال ثم صحب \ رسول الله غط الران قلبي فسل مولاي تفريجا لكربى رسول الله انت القصد فاشفع الي مولي العظيم بفقر ذنبي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43r">-43r</locus>رسول الله غشني ما تغنا عبيدك او شدا شاد بحب \ رسول الله غط الران قلبي فسل مولاي تفريجا لكربي</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="43r" to="43v">43r-43v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1489IHA">نظم احمد الداعي الى الرشد والهدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#43r">-43r</locus>وقال رضي الله عنه \ صلاة وتسليم من الله مرمدا على احمد الداعي الى الرشد والهدا \ حبيب قريب لا يضاها بمرسل شريف ظريف حاز فخرا وسوددا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43v">-43v</locus>عليك صلاة الله ما هبت الصبا وغرد قمري بصوت ورددا \ كذا الال والاصحاب ما قال منشد صلاة وتسليم من الله سرمدا</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="43v" to="44r">43v-44r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1491IHA">نظم صلاة الله ما نادى المنادي</title>
                     <incipit xml:lang="ar">
                        <locus target="#43v">-43v</locus>وقال رضي الله عنه \ صلاة الله ما نادي المناد علي المختار من رب العباد \ شفيع الخلق يا ذخر المعاد رفيع الجاه في يوم التنادي \ نبي الله يا زين البرايا رسول الله يا عين المراد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#44r">-44r</locus>عليك الله صلي يا عمادي وال ثم اصحاب جيادي \ دواما دائما ما قال صب صلاة الله ما ناد المنادي</explicit>
                     <note>Vocalized.</note>
                     <note/>
                  </msItem>

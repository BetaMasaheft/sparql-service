                           <condition key="good">Stamp of Mal'aka Zahāy Tāffasa Dasse'alann, ff. 14a, 22a and 30a.</condition>
                        </supportDesc>
                        <layoutDesc>
                           <layout>2 cols.; 21 lines (ff. 14-29) and 25 to 27 lines (ff. 30-39)</layout>
                        </layoutDesc>
                     </objectDesc>
                  </physDesc>
                  <history>
                     <origin>
                        <origDate notBefore="1863" notAfter="1864">19th century, 1863-1864</origDate>
                     </origin>
                  </history>
               </msPart>

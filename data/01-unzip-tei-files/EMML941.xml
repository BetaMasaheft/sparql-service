               <msPart xml:id="p1">
                  <msIdentifier>
                     <collection>Addis Ababa, Bolē</collection>
                  </msIdentifier>
                  <msContents>
                     <summary/>
                     <msItem xml:id="p1_i1">
                        <locus from="1a" to="7b,9a-10a">Fols 1a–7b,9a-10a</locus>
                        <title type="supplied">Chronology of the invasions of Grann</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note>Written in the Wollo dialect of Amharic.F. 8b: blank.</note>
                     </msItem>
                     <msItem xml:id="p1_i2">
                        <locus from="10a" to="12a">Fols 10a–12a</locus>
                        <title type="supplied">History of the Gāllā at the Time of Emperor Mal'ak Saggad (Nagara Gāllā ba-Azē Mal'ak Saggad gizē)</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>Śarsa Dengel, 1563-1597.  The initial page also has the title: Tewledd za-Arami, i.e. History of the Gāllā. Ff. 12b-13b: blank.</note>
                     </msItem>
                  </msContents>
                  <physDesc>
                     <objectDesc form="Codex">
                        <supportDesc>
                           <support>
                              <material key="parchment"/>
                           </support>
                           <extent>
                              <measure unit="leaf"> 1-12</measure>
                           </extent>
                           <foliation/>
                           <condition key="good">Stamp of Mal'aka Zahāy Tāffasa Dasse'alann, ff. 14a, 22a and 30a.</condition>
                        </supportDesc>
                        <layoutDesc>
                           <layout>2 cols.; 20 to 21 lines (ff. 1-7) and 27 to 29 lines (ff. 9-12),</layout>
                        </layoutDesc>
                     </objectDesc>
                  </physDesc>
                  <history>
                     <origin>
                        <origDate when="1922"/>
                     </origin>
                  </history>
               </msPart>
               <msPart xml:id="p2">
                  <msIdentifier>
                     <collection/>
                  </msIdentifier>
                  <msContents>
                     <summary/>
                     <msItem xml:id="p2_i1">
                        <locus from="14a" to="39b">Fols 14a–39b</locus>
                        <title type="supplied">Ge'ez treatise on computus [Bāḥra ḥassāb].</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>Ff 14a-15a: Contents of the treatise; ff. 15a-16a, Introduction; ff. 16a-39b, text; Ff. 40a-59b, tables and diagrams.</note>
                     </msItem>
                     <msItem xml:id="p2_i2">
                        <locus from="40a" to="53b">Fols 40a–53b</locus>
                        <title type="supplied">Table for the 532-year cycle of the Julian calender.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>The table has been used to record important happenings of the 19th and early 20th centuries, including eclipses.</note>
                     </msItem>
                     <msItem xml:id="p2_i3">
                        <locus target="#54ab">Fol. 54ab</locus>
                        <title type="supplied">Perpetual calendar for the date of Easter and other movable celebrations, with the years of the 19-year lunar cycle and the tenteyon (day of the week that the 1st of Maskaram falls on) as coordinates.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>There are numerous errors in the table.</note>
                     </msItem>
                     <msItem xml:id="p2_i4">
                        <locus from="55a" to="56b">Fols 55a–56b</locus>
                        <title type="supplied">Perpetual calendar for the date of Easter and other movable celebrations, expanded and divided into seven tables for each possible tenteyon.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>The same perpetual calendar found on f. 54ab.</note>
                     </msItem>
                     <msItem xml:id="p2_i5">
                        <locus from="56b" to="57a">Fols 56b–57a</locus>
                        <title type="supplied">Shadow table.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i6">
                        <locus target="#57b">Fol. 57b</locus>
                        <title type="supplied">Divination diagram for the different directions of the wind. (?)</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i7">
                        <locus target="#58a">Fol. 58a</locus>
                        <title type="supplied">Diagram showing the direction of the sun at different hours of the day.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i8">
                        <locus target="#58b">Fol. 58b</locus>
                        <title type="supplied">Diagram showing the directions of sunrise and sunset for the different months of the year.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i9">
                        <locus target="#59a">Fol. 59a</locus>
                        <title type="supplied">Diagram that gives certain computation rules. (?)</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i10">
                        <locus target="#59b">Fol. 59b</locus>
                        <title type="supplied">Diagram of the fraction of the eucharistic bread.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i11">
                        <locus from="60a" to="64b">Fols 60a–64b</locus>
                        <title type="supplied">Brief treatise on computus, indicating the different cycles used and exemplifying them in calculating the movable feasts and fasts of 7400 A.M/ 1900 E.C. (= 1907-8 /A.D.).</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i12">
                        <locus target="#57a">Fol. 57a</locus>
                        <title type="supplied">Note , that the year [19]41 was 567 years after the death of St. Gabra Manfas Qeddus.</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i13">
                        <locus target="#57a">Fol. 57a</locus>
                        <title type="supplied">Note , that the 8000 years began 126 years after the death of St. Gabra Manfas Qeddus.</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p2_i14">
                        <locus target="#58b">Fol. 58b</locus>
                        <title type="supplied">Note, that Wasanē was born on the feast of God the Father in Sanē, the same day that Rās Dārgē set out to conquer Arusi, and that in 1919 E.C. (= 1926-7 A.D.) she is 41 years, 2 months and 18 days old.</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note/>
                     </msItem>
                  </msContents>
                  <physDesc>
                     <objectDesc form="Codex">
                        <supportDesc>
                           <support>
                              <material key="parchment"/>
                           </support>
                           <extent>
                              <measure unit="leaf"> 13-39 </measure>
                           </extent>

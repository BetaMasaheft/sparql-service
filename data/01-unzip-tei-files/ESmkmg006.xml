                        <handNote xml:id="h1" script="Ethiopic">
                           
                           <seg type="script">Hand a: fine and careful: <locus from="4r" to="148rb">4r-148rb l.15, </locus><locus from="162ra" to="172vb">162ra-172vb l.7</locus></seg>

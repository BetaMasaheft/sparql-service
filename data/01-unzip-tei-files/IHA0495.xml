                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="19v">1v-19v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s18IHA">قران, Eleventh ǧuz’ (11/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>[يَعْتَذِرُوْنَ اِلَيْكُمْ اِذَا رَجَعْتُمْ اِلَيْهُـ[ـمْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19r-19v">-19r-19v</locus>اَلَا حِيْنَ يَسْتَغْشُوْنَ ثِيَابَهُمْ يَعْلَمُ مَا يُسِرُّوْنَ وَمَا يُعْلِنُوْنَ اِنَّهُ عَلِيْمٌ بِذَاتِ الصُّدُوْرِ</explicit>
                     <note>9:94-11:5.</note>
                     <note/>
                  </msItem>
               </msContents>

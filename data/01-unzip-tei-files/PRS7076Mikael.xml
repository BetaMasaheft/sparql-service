               <occupation type="ecclesiastic">metropolitan</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
             
               
               <floruit notBefore="1650" notAfter="1663">He was a metropolitan of the Ethiopian Orthodox Church who succeeded    
             
                  <persName ref="https://betamasaheft.eu/PRS6776Marqos"> 
                     <roleName type="title">ʾabuna</roleName>
                     Mārqos [III]</persName> in <date>1650</date> during the reign of  
                  King <persName ref="https://betamasaheft.eu/PRS4015Fasilada">Fāsiladas</persName>. During his episcopate, a debate took place between Qǝbāt (Unctionists) and Kārrā (Unionists)
                  on <date>23 June 1655</date>. His successor was ʾabuna <persName ref="https://betamasaheft.eu/PRS6071Krestodo">Krǝstodolu [II]</persName>.      
                 </floruit>
               <death when="1663"/>
              
            </person>
            

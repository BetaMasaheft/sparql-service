                  <msItem xml:id="ms_i0">
                     <locus from="1" to="28">p. 1-28</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3089IHA">حاشية الامام العارف بالله تعالى أبى البركات سيدى أحمد
                    الدردير على قصة المعارج للعلامة الهمام بركة النام نجم الدين الغيطى</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 2">-p. 2</locus>بسم الله الرحمن الرحيم الحمد لله والصاة والسلام على رسول الله وبعد فهذه كلمات جمعتها على قصة المعراج رجاء أن ينتفع بها من يتصدى الى قراءتها ممن هو قاصر مثلى جمعتها من الوجوه التي ذكرها مؤلفها العلامة النجم الغيطى </incipit>
                     <explicit xml:lang="ar"/>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/AN5BLUTY"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook618"/><title level="m">Ḥāšiyat alimām al-ʻārif bi'Llāh taʻālā Abī al-Barakāt sayyidī Aḥmad al-Dardīr ʻalā Qiṣṣat al-miʻrāǧ li'l-ʻallāma al-himām barakat al-anām Naǧm al-Dīn al-Ġayṭī</title><author><name>al-Dardīr, Aḥmad</name></author><author><name>al-Ġayṭī, Naǧm al-Dīn</name></author><pubPlace>al-Qāhira</pubPlace><publisher>Dār al-Kutub al-ʻArabiyya - Muṣtafā al-Bābī al-Ḥalabī</publisher><date>1328</date><note type="tags"><note type="tag">bm:IHABook618</note></note><note type="tag">bm:IHABook618</note></bibl>

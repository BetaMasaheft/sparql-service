                  <msItem xml:id="ms_i1">
                     <locus from="1" to="28">*p. 1-28</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3090IHA">قصة المعراج</title>
                     <incipit xml:lang="ar">
                        <locus target="#*p. 2">-*p. 2</locus>بسم الله الرحمن الرحيم بينما النبى صلى الله عليه وسلم في الحجر عند البيت مضطجعا بين رجلين اذ أتاه جبريل وميكائيل ومعهما ملك آخر فاحتملوه حتى جاؤا به زمزم</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="377" to="470">p. 377-470</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0015IHA">حاشيه الباجوري علي شرح ابن قاسم الغزي على متن ابي الشجاع
                    في مذهب الامام الشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 377">-p. 377</locus>وقوله سببها أي سبب تلك العصوبة وقوله زوال الملك عن رقيق معتق أي زوال ملك السيد عن رقيقه الذى أعتقه فمعتق في كلامه بفتح التاء الفوقية بمعنى العتيق </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 469">-p. 469</locus>وهذا آخر ما يسره الله تعالى من الحاشية الماركة النافعة بعد صلاة الظهر يوم الأربعاء المبارك من شهر جمادى الآخرة الذى هو من شهور سنة ألف ومائتين وثمانية وخمسين من الهجرة النبوية [...] وقد وفق تمام هذه الكتابة مولد سيدى أحمد البدوى رضى الله عنه وقد قرأت له الفاتحة فينبغى قراءتها له كلما ختمها انسان بالقراءة والله المسهول غفر الله لنا ولوالدينا ولمشايخنا واخواننا المسلمين آمين 
</explicit>
                     <note/>
                     <note/>
                  </msItem>

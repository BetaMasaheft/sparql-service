                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> , saving Birutawit</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#2r" facs="002">Fol. 2r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> flanked by angels with <term key="sword" ana="#sword"/>s on either side</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#4r" facs="004">Fol. 4r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> standing with a man on either side. He is blessing the man on his right</desc></decoNote>

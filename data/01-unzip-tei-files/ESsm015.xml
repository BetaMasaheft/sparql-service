                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, vermilion</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>ምዕ፡, ምዕራ፡ for ምዕራፍ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the commissioners; a few
                           lines or groups of lines (alternating with black lines) of the incipits
                           of the texts; word mǝʿrāf; “tituli” written in the upper margins;
                           stichometry; elements of the punctuation signs and Ethiopic
                           numerals.</seg>
                     </handNote>
                  </handDesc>

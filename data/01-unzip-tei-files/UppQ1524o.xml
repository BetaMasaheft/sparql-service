                    <history>
                        <origin>
                            <origDate when="1909">1909</origDate>
                        </origin>
                        <provenance>
                            <ref target="#p1"/> was written by <persName role="scribe" ref="https://betamasaheft.eu/PRS6046Kolmodin">Johannes Axel Kolmodin</persName>.
                            It is not known who the scribe of <ref target="#p2"/> was, but seeing that the three 
                            <foreign xml:lang="gez">qǝne</foreign> poems that it contains are all attributed to
                            <persName role="author" ref="https://betamasaheft.eu/PRS14574GabraLeul">Gabra Lǝʿul Tǝrfe</persName> in <ref target="#p1"/>, it seems
                            possible that the latter was the scribe of <ref target="#p2"/>.
                            
                            The manuscript remained in <persName role="owner" ref="https://betamasaheft.eu/PRS6046Kolmodin">Johannes Axel Kolmodin</persName>'s possession
                            until his death, when it was bequeathed to its current repository.
                        </provenance>
                        <acquisition>
                            The manuscript reached its current repository in <date when="1953"/>.
                        </acquisition>
                    </history>
                    

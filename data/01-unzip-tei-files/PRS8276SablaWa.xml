            <t:person sameAs="wd:Q60537581" sex="2">


                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ሰብለ፡ ወንጌል፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n1" type="normalized">Sabla Wangel</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾǝtege</t:roleName>
               </t:persName>

              <t:occupation type="ruler">queen</t:occupation>
               <t:birth when="1500"/>
               <t:floruit notBefore="1518" notAfter="1567">She was a dominant political figure in the dynasty of her time.
                  She married
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName> in <t:date>1518</t:date>.
                  She came from a noble <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>
                  <t:persName ref="https://betamasaheft.eu/ETH1126Amhara">ʾAmhārā</t:persName>.
                  She played a prominant role in the court politics after the death of her husband

                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>
               </t:floruit>
               <t:death when="1567" evidence="internal"> She died during the reign of her
                  grandson
                  <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Śarḍa Dǝngǝl</t:persName>. </t:death>
            </t:person>

               
         </t:listPerson>


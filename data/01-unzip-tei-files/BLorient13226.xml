                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7476PPNails">Baʾǝnta ʿāynata Bāryā</title>  
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> በእንተ፡ ዓይነተ፡ ባርያ፡ ወዓይነ፡ ጥላ፡ ወሌጌዎን፡ ሕማመ፡ ቡዳ፡ ዛር፡ ነሀቢ፡ ጠቢብ፡ 
                                <gap reason="ellipsis"/> በ፭ ቅንዋተ፡ መስቀሉ፡ 
                                ለ<supplied reason="omitted" resp="PRS8999Strelcyn">እ</supplied><hi rend="ligature">ግዚ</hi>እነ፡ ኢየሱስ፡ ክርስቶስ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title>  
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> በስመ፡ እግዚአብሔር፡ 
                                ሕያው<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ነባቢ፡ ወተናጋሪ፡ ጸሎተ፡ ቅዱስ፡ 
                                <persName ref="https://betamasaheft.eu/PRS9038Susenyos">ሱስንዮስ፡</persName> በእንተ፡ አሰስሎ፡ ደዌ፡ እምሕፃናት፡ እለ፡ ያጠቡ፡ ጥቡ፡ እሞሙ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT6844PPHemorrhage">Protective prayer against hemorrhage and for
          childbirth</title>  
                            <incipit xml:lang="gez">ጸሎት፡ ዓርጋኤ፡ ደም፡ ሰንተም፡ ፫ በል፡ ሰንቀረም፡ ፫</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT4624Prayer">Ṣalot baʾǝnta ḥǝmāma wǝgāt</title>  
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ውግዓት፡ ምድምያስ፡ ፫ በል፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>

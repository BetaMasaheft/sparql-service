                      <msItem xml:id="ms_i1.21">
                        <locus from="123r" to="126r" facs="123">Fols 123r–126r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title>
                        <incipit xml:lang="gez">
                          በስመ፡ አብ፡<gap reason="omitted"/>ጸሎተ፡ ድኅንተ፡ ወመጽሐፈ፡ ሕይወት፡ ልፋፈ፡ ጽድቅ፡
                          ዘተናገረ፡ አብ፡ በቃሉ፡ እምቅድመ፡ ይትወልደ፡ ክርስቶስ፡ በሥጋ፡
                          እማርያም፡ እንተ፡ ኢታበውዕ፡ ውስተ፡ ፀባብ፡ አንቀጽ፡ ወታበጽሕ፡ ውስተ፡
                          መንፍሥተ፡ ሰማያተ፡<gap reason="omitted"/>
                        </incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.22">
                        <locus from="126r" to="130r" facs="126">Fols 126r–130r</locus>
                        <title>Prayer for the journey to heaven</title>
                        <note>This prayer is part of the <ref type="work" corresp="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</ref>
                        </note>
                        <incipit xml:lang="gez">
                          በስመ፡ አብ፡<gap reason="omitted"/>ጸሎት፡ ዘመንገደ፡ ሰማይ፡ ዕቀበኒ፡ ክርስቶስ፡
                          ከመ፡ ኢያዕቅፍዋ፡ ለነፍስየ፡ መላእክተ፡ ጽልመት፡ ውስተ፡ ፀባብ፡ አንቀጽ፡<gap reason="omitted"/>
                        </incipit>
                      </msItem>

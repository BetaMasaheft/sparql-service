                  <summary>Funeral Ritual, መጽሐፈ፡ ግንዘት፡</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="136v" facs="001">Fols 1r–136v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1931Mashaf">Maṣḥafa
                                                  gǝnzat</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="6r" facs="001">Fols 1r–6r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1931Mashaf#Intro">Maṣḥafa
                                                  gǝnzat, Introduction</title>
                        <incipit xml:lang="gez">
                          በስመ፡ አብ፡<gap reason="omitted"/>ንጽሕፍ፡ ዘንተ፡ መቅድመ፡ ግንዘት፡ ዘአስተሃባእነ፡
                          እምሲኖዶስ፡ ወእምፍትሐ፡ ነገሥት፡ ወእምዝንቱ፡ መጽሐፍ፡
                          በበሥርዓቱ፡ ወበበመትልዉ፡ ቅዳሜ፡ ኵሉ፡ ጊዜ፡ በጸዓተ።ነፍስ፡ ዘቃለ፡
                          አትናቴዎስ፡ ይድግሙ፡<gap reason="omitted"/>ወእምድኅረ፡ ፍጻሜ፡
                          ፍትሐት፡ ያልክፍዎሙ፡ እምሥጋሁ፡ ቅዱስ፡ ወእምደሙ፡ ክቡር፡<gap reason="omitted"/>
                        </incipit>
                      </msItem>

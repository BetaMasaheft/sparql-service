            <listPerson>
                <person sex="1" sameAs="wd:Q44024">
                    <persName xml:lang="en" xml:id="n1">Athanasius</persName>
                    <persName xml:lang="gez" xml:id="n2" type="birth">አትናቴዎስ፡</persName>
                    <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAtǝnātewos</persName>
                    <persName xml:lang="gez" xml:id="n3" type="alt">አትናቴዮስ፡</persName>
                    <persName xml:lang="gez" corresp="#n3" type="normalized">ʾAtǝnāteyos</persName>
                    <persName xml:lang="gez" xml:id="n4" type="alt">አትናሲስ፡</persName>
                    <persName xml:lang="gez" corresp="#n4" type="normalized">ʾAtnāsis</persName>
                    <persName xml:lang="gez" xml:id="n5" type="alt">ሐዋርያዊ፡</persName>
                    <persName xml:lang="gez" corresp="#n5" type="normalized">Ḥawāryāwi</persName>
                    <occupation type="ecclesiastic">bishop</occupation>

                    <nationality type="Egypt"/>
                    <faith type="Coptic"/>


                    <birth when="0295"/>


                    <floruit notBefore="0328" notAfter="0373">He was an <placeName ref="https://www.wikidata.org/entity/Q87">Alexandria</placeName>
                        bishop between <date>328-373</date>. He was a champion of Nicene Orthodoxy,
                        which for most of his life was attacked by the supporters of Arianism. For
                        his staunch attitude he was persecuted, being forced into exile five times
                        during his episcopacy. He was also the <placeName ref="https://www.wikidata.org/entity/Q87">Alexandria</placeName> metropolitan
                        who consecrated <persName ref="https://betamasaheft.eu/PRS8386SalamaI">Salāmā Kaśāte Bǝrhān</persName> as bishop of <placeName ref="https://betamasaheft.eu/LOC7363Aksum">ʾAksum</placeName>. In Ethiopic literature, many works are attributed
                        to him, most of which remain unpublished.</floruit>
                    <death when="0373">He died at <placeName ref="https://www.wikidata.org/entity/Q87">Alexandria</placeName> in <date>373</date>. </death>

                </person>

                
            </listPerson>



                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                      <desc>Columetric layout of text: <locus from="104v" to="105r" facs="107">fols 104v–105r</locus> (tenth biblical canticle)</desc>
                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <foreign xml:lang="gez">ሐረግ፡</foreign> in red and black on
                      <locus target="#1r #13r #19v #45r" facs="003 015 022 047">folss. 1r, 13r, 19v, 45r, </locus> (erased),
                      <locus target="#60r #64v #76r #93r #97r #107v #114v #122r" facs="062 067 078 095 099 110 117 124">fols. 60r, 64v, 76r, 93r, 97r, 107v, 114v, 122r</locus> (one column);
                      <foreign xml:lang="gez">ሐረግ፡</foreign> in black on <locus target="#28r #88r" facs="030 090">folss. 28r, 88r, </locus>.
                      A line of alternating red and black dots marks the division between groups of ten psalms (<locus target="#38v" facs="041">fols. 38v, </locus>).
                    A row of full-stop symbols marks divisions in the Praises of Mary (<locus target="#114v #119r #125r" facs="117 121 127">fols. 114v, 119r, 125r</locus>).</decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1079DavidGoliath">David Beheads Goliath</ref> with caption <q><foreign xml:lang="gez">ወመተርኬ፡ ርእሶ፡ ለጎልያድ፡</foreign></q></desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref></desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#33v" facs="036">Fol. 33v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> holding a book in his right hand and raising up his left hand</desc>
                        <note>painted erasing the text of Ps 50:6–51:2.</note>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#46r" facs="048">Fol. 46r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> receives a book from above, probably the booklet of prayer</desc>
                        <note>painted erasing the text of Ps 71:16–72:8</note>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#70r" facs="072">Fol. 70r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, <persName ref="https://betamasaheft.eu/PRS1002Aaron">Aaron</persName> and his <term key="rod" ana="#rod"/> blooming</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#94r" facs="096">Fol. 94r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>, <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName></desc>
                        <note>painted erasing the text of Ps 142:7–143:5</note>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d8">
                        <locus target="#113v" facs="116">Fol. 113v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> brandishing a <term key="sword" ana="#sword"/></desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d9">
                        <locus target="#126v" facs="129">Fol. 126v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc>
                        <note>painted erasing the text of the rest of the calendar</note>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d10">
                        <locus target="#127r" facs="129">Fol. 127r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, the resurrected Christ displays his wounds</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">

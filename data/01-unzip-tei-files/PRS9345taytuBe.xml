      <t:body>
         <t:listPerson>
            <t:person sex="2" sameAs="wd:Q298216">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ጣይቱ፡ ብጡል፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Ṭāytu Bǝṭul</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ወለተ፡ ሚካኤል፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Walatta Mikāʾel</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="regnal">ብርሃን፡ ዘኢትዮጵያ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Bǝrhān  Zaʾityoṗyā</t:persName>
               
               <t:persName>
                  <t:roleName type="title">ʾǝtege</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">queen</t:occupation>
               <t:birth when="1853">She was born at <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>.</t:birth>
               <t:floruit notBefore="1883" notAfter="1910">She was the wife of 
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk II</t:persName> and
                  an influential politician in his court. 
                  She married 
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk II</t:persName>,  her fifth husband,  
                  in<t:date>1883</t:date> in the church ceremony that took place in<t:placeName ref="https://betamasaheft.eu/LOC1464Ankoba">ʾAnkobar</t:placeName>. 
                  She was crowned as <t:persName ref="https://betamasaheft.eu/PRS9345taytuBe">
                     <t:roleName type="title">ʾǝtege</t:roleName> Ṭāytu Bǝṭul </t:persName> on <t:date>03-10-1889</t:date>, 
                  two days after 
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk II</t:persName>'s  coronation as emperor. 
                  She did not have children with 
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk II</t:persName> and
                  was probably a barren. 
                 
                  <t:persName ref="https://betamasaheft.eu/PRS9345taytuBe"> 
                     <t:roleName type="title">ʾǝtege</t:roleName> Ṭāytu Bǝṭul</t:persName> was recognized in 
                  <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> as an outstanding beauty 
                  and a clever and educated woman. 
                 
                  <t:persName ref="https://betamasaheft.eu/PRS9345taytuBe"> 
                     <t:roleName type="title">ʾǝtege</t:roleName> Ṭāytu Bǝṭul</t:persName> was active both in domestic and foreign policy. 
            
               </t:floruit>
               <t:death when="1918"> She died in <t:placeName ref="https://betamasaheft.eu/LOC2976Entott">ʾƎnṭoṭṭo</t:placeName> in <t:date>1918</t:date>. </t:death>
            </t:person>  
            
         </t:listPerson>
         

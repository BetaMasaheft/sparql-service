                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="2r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾtǝna Māryām ba-Dabra Golgotā</title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <locus from="13v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab">Mazgaba hāymānot</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i2.1">
                            <locus from="13v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Introduction">No item: LIT1994Mazgab, could not check for Introduction</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              በስመ፡ እግዚአብሔር፡<gap reason="ellipsis"/> ንጽሕፍ፡ ዘንተ፡ መጽሐፈ፡
                              ዘይሰመይ፡ መዝገበ፡ ሃይማኖት፡ ከመ፡ ያለብውዎ፡ ማኅበረ፡ መሃይምናን፡ ወመሃይምንት፡ ካህናት፡
                              ወዲያቆናት፡ አዕሩግ፡ ወሕፃናት፡ እድ፡ ወአንስት፡ ዘውስቴቱ፡ እስትግቡእ፡ እምቃለ፡ ቅዱሳት፡ መጻሕፍት፡
                              ዘያሌቡ፡ ጽምረተ፡ ፩ መለኮት፡ ወኈልቈ፡ ፫ አካላት፤ ተዋሕዶተ፡ ትስብእት፡ ወመለኮት። ዘከመ፡ ኮነ፡
                              ለጉባኤ፡ ቀዳማዊ፡ ወዳግማዊ፡ ወሣልሳዊት፡ ከመ፡ አርትዑ፡ ለነ፡ ርቱዐነ፡ ቃላት፡ ወዘከመ፡ አስተሐፈርዎሙ፡
                              ወሰደድዎሙ፡ ለሰብአ፡ ዕልወት። ወአውገዘቶሙ፡ አሐቲ፡ ጉባኤ፡ እንተ፡ ሐዋርያት። ወለጉባኤሰ፡ ራብዒት፡
                              ወሳኪት፡ ዐካል፡ ራብዓይ፡ ዲበ፡ ሥላሴ፡ ቅድስት።
                            </incipit>
                            <msItem xml:id="ms_i2.1.1">
                              <locus from="16v" to="25v"/>
                              <title type="complete" xml:lang="en">Account of the four Councils</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                          </msItem>
                          <msItem xml:id="ms_i2.2">
                            <locus from="25v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chapter1">No item: LIT1994Mazgab, could not check for Chapter1</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chapter2">No item: LIT1994Mazgab, could not check for Chapter2</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chapter3">No item: LIT1994Mazgab, could not check for Chapter3</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chapter4">No item: LIT1994Mazgab, could not check for Chapter4</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.6">
                            <locus to="44v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chapter5">No item: LIT1994Mazgab, could not check for Chapter5</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.7">
                            <locus from="44v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1994Mazgab#Heresies">
                              Confutation of propositions of Sabellius
                            </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.8">
                            <locus from="47r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Chrono">No item: LIT1994Mazgab, could not check for Chrono</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              እም፡ ስብከተ፡ ሐዋርያት፡ እስከ፡ መንግሥተ፡ ዲዮግልጢያኖስ፡ ፪፻፸፯፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.9">
                            <locus from="47r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1994Mazgab#Nature">No item: LIT1994Mazgab, could not check for Nature</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              በእንተ፡ ክርስቶስ፡ ዘፈጸመ፡ ሕገ፡ ስብእት፡ እንዘ፡ ውእቱ፡ መለኮታዊ፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.10">
                            <locus from="48v"/>
                            <title type="complete" xml:lang="en">Selections from various Fathers</title>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i2.10.1">
                              <locus target="#49r"/>
                              <title type="complete" xml:lang="en">Selection from
                                <foreign xml:lang="gez">አንጢፎስ፡ ረድኦሙ፡ ለሐዋርያት፡</foreign>,
                              patriarch of Constantinople</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i2.10.2">
                              <locus target="#49r"/>
                              <title type="complete" xml:lang="en">Selection from
                                <foreign xml:lang="gez">አርክዎስ፡</foreign></title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i2.10.3">
                              <locus from="49r"/>
                              <title type="complete" xml:lang="en">Selection from Irenaeus,
                                <foreign xml:lang="gez">ሔሬኔዎስ፡</foreign></title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i2.10.4">
                              <locus from="50r"/>
                              <title type="complete" xml:lang="en">Selection from
                                Dionysius the Areopagite</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i2.10.5">
                              <locus from="51r"/>
                              <title type="complete" xml:lang="en">Selection from
                                <foreign xml:lang="gez">እግ፡</foreign>,
                              bishop of Antioch, third in succession to St. Peter</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                          </msItem>
                        </msItem>
                        <msItem xml:id="ms_i3">
                          <locus from="51v"/>
                          <title type="complete" xml:lang="en">Hymns</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i3.1">
                            <locus from="51v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2896RepCh177">Malkǝʾa maṭlali</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ሰላም፡ ለዝክረ፡ ስምኪ፡ አምሳለ፡ ስቴ፡ ወይን፡ መጥለሊ።
                            </incipit>
                          </msItem>
                          
                          <msItem xml:id="ms_i3.2">
                            <locus from="53v"/>
                            <title type="complete" xml:lang="en">Hymn to the blessed Virgin,
                            the Angels and the Prophets</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.3">
                            <locus from="54v"/>
                            <title type="complete" xml:lang="en">Hymn to George</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.4">
                            <locus from="55r"/>
                            <title type="complete" xml:lang="en">Hymn to Takla Hāymānot</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.5">
                            <locus from="56r"/>
                            <title type="complete" xml:lang="en">Hymn to Eustathius</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.6">
                            <locus from="56v"/>
                            <title type="complete" xml:lang="en">Hymn to the holy Cross</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.7">
                            <locus from="57r"/>
                            <title type="complete" xml:lang="en">Hymn to the Church</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.8">
                            <locus from="57r"/>
                            <title type="complete" xml:lang="en">Hymn to the blessed Virgin</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.9">
                            <locus from="58v"/>
                            <title type="complete" xml:lang="en">Hymn to our Lord Jesus</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i3.10">
                            <locus from="59r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2952RepCh233">Hymn to Jesus Christ</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ስብሐት፡ ለከ፡ ዘበሰማያት፡ አቡነ፡ ወዘበምድር፡ ዓዲ።
                            </incipit>
                          </msItem>
                        </msItem>

                  <additions>
                     <list>
                
                        <item xml:id="a1">
                           <desc type="MagicFormula">A magic formula to hinder a captive from escaping has been added later
                    at the beginning of the volume.</desc> 
                           <q xml:lang="gez">ከልሹት፡ ከልሹት፡ ምርያን፡ ቆሮተንደከኤል፡ በዝንቱ፡ አስማቲከ፡
                    ዘአሰ<supplied reason="undefined" resp="PRS10747Zotenbe">ደ</supplied>ከ፡
                    ለብርያል <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
                
                        <item xml:id="a2">
                           <locus target="#2v">Fol. 2v</locus>
                           <desc type="MagicFormula">Magic prayer</desc> 
                           <q xml:lang="gez">ዓመደ፡ ብርሃን፡ መሰረተ፡ ጽድቅ፡ ግልበበ፡ ጽድቅ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
                
                        <item xml:id="a3">
                           <locus target="#7r">Fol. 7r</locus>
                           <desc type="MagicFormula">Magic prayer</desc> 
                           <q xml:lang="gez">በስመ፡<gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                    ወከመ፡ መፍዝዝ፡ ዴሎኆሎሂል፡ ልባጥ፡ ልማብጣ፡ በዱሂ፡ ፍዝፍዝ፡ ዘያደነግጾሙ፡ ለመላእክት፡ ግሩማን፡ ወለፀርየ፡ ወለጸላእትየ፡ ለገብርከ፡ አሜን፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
                
                        <item xml:id="e1">
                           <desc>The manuscript was produced for <persName ref="https://betamasaheft.eu/PRS11045FereK">Fǝre Kāhǝn</persName>,
                    whose name is mentioned in the invocations.</desc> 
                           <q xml:lang="gez"/>
                        </item>
                
                     </list>
                  </additions>
           

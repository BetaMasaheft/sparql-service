               <msContents>
                  <summary/> 
         
                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2246salotz">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡ 
                  ወላዲተ፡ አምላክ፡ ቅድስት፡ ድንግል፡ እሙ፡ ለብርሃን፡ ጸሎታ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                ምስሌነ፡ አሜን። ዘጸለየት፡ አመ፡ ፳ወ፬፡ ለስኔ፡ በደብረ፡ ጎልጎታ፡ ዝውእቱ፡ መቃብረ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ ትብል፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">እግዚእየ፡ ወ<sic resp="DR">እ</sic>ምላኪየ፡ ወወልድየ፡ ወንጉሥየ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተወለድከ፡ በፈቃድከ።
                እምኔየ፡ ጠበውከ፡ ሐሊበ፡ እምአጥባትየ፡ እንዘ፡ ሰማያት፡ ዘኢያገምረከ፡ ወምድር፡ ዘኢትክል፡ ጸዊሮተከ፡
                ከርሠ፡ ቀላያትኒ፡ ዕሙቀ።</incipit>
                     <note>The following is the end of the prayer itself:
                 <quote xml:lang="gez">
                           <locus target="#17r">Fol. 17r</locus>
                  ከመ፡ ትስማዕ፡ ቃለ፡ ስእለትየ፡ ከመ፡ ትምጻእ፡ ኀቤየ፡ ወትፈጽም፡ ኵሎ፡ ዘውስተ፡ ልብየ፡ ለገብርከ፡ እገሌ።</quote>
                     </note>
                  </msItem>
            
                  <msItem xml:id="ms_i2">
                     <locus from="34r">Fols 34r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4299Prayer">Prayer of Our Lady
                                                  Mary to Jesus Christ at the sepulchre</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                ኢየሱስ፡ ክርስቶስ፡ ትፍሥሕት፡ ለኵሉ፡ ዓለም፡ ኢየሱስ፡ ክርስቶስ፡ ያስተፈሥሕ፡ ኵሎ፡ ልበ፡</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i3">
                     <locus from="41r">Fols 41r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3583Prayer">Prayer for the protection from illnesses, accidents and witchcraft</title>
                     <textLang mainLang="gez"/>
                     <note>Cp. <ref target="#Prayer"/>.</note>
                  </msItem>
            
                  <msItem xml:id="ms_i4">
                     <locus from="62">Fols 62 and following</locus>
                     <title type="complete">Magic prayer</title> 
                     
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ጸሎተ፡ ኬናት፡ ኢያሄድ፡ አፍናኤል፡ አቅናኤል፡ መግረሬ፡ ፀር፡ አግርር፡ እለ፡ ያጌይቡ፡ በሐሊበ፡ ላህም፡ አው፡ በዐውድ፡</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i5">
                     <locus from="65r">Fols 65r and following</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1113Anqasa">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                ቅድስት፡ ወብጽዕት፡ ስብሕት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </title>
                     <textLang mainLang="gez"/>
                  </msItem>
            
                  <msItem xml:id="ms_i6">
                     <locus from="81r">Fols 81r and following</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3582Prayer">ጸሎት፡ ወአስተብቍዖት፡ ኀበ፡ እግዝእትነ፡ ማርያም፡ ዘይትነበብ፡ በሌሊት።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">እሴብሕ፡ ጸጋኪ፡ ኦእግዝእትየ፡ ወእስእለኪ፡ ተብርሂ፡ ልብየ፡</incipit>
                  </msItem>
                            
                  <msItem xml:id="ms_i7">
                     <locus from="85r">Fols 85r and following</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3086RepCh366">Hymn to Our Lady
                                                  Mary</title>
                     <incipit xml:lang="gez">ኦመሰረት፡ አንቲ፡ ለኵሉ፡ ዓለም፡ ዘኮንኪ፡ ማኅደሮ፡ ለዐቢይ፡</incipit>
                  </msItem>
                     
            

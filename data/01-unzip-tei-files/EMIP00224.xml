               <msContents>
                  <summary>Fragment of Horologium</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="11v" facs="001">Fols 1r–11v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa
                                                  saʿātāt</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>
                       <locus target="#4v" facs="005">Fols. 4v, </locus> begins the section for the third hour;
                       <locus target="#8v" facs="009">8v, </locus> has the concluding formula which mentions the name of the work;
                       <locus target="#8v" facs="009">8v</locus> begins the Addendum, <foreign xml:lang="gez">ዘተረፈ፡ ሰላምታ፡</foreign>
                     </note>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">11</measure>
                           <measure unit="quire">2</measure>
                           <dimensions type="outer" unit="mm">
                              <height>175</height>
                              <width>167</width>
                              <depth>7</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Quire descriptions: quire 1 adjusted balanced; quire 2 unbalanced.</note>
                          <list>
                              <item xml:id="q1" n="1">
                                 <dim unit="leaf">6</dim>
                                 <locus from="1" to="6" facs="001">Fols 1–6</locus>
                                 <note>A reinforcement strip precedes <locus target="#1" facs="001">fols. 1, </locus>. Folio stubs are visible between <locus target="#2 #3" facs="003">2, 3, </locus> and between <locus target="#5 #6" facs="006">5, 6</locus>.</note>
                              Quire 1:
                              2, stub after 5
                              5, stub after 2
                            </item>
                              <item xml:id="q2" n="2">
                                 <dim unit="leaf">5</dim>
                                 <locus from="7" to="11" facs="007">Fols 7–11</locus>
                                 <note>
                                    <locus from="7" to="11" facs="007">Fols 7–11</locus> are attached using a stab stitch.</note>
                              Quire 2:
                              1, no stub
                              1 added
                              2 added
                              3 added
                              4 added
                              5 added
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">18</dim>
                              <dim type="bottom">38</dim>
                              <dim type="right">27</dim>
                              <dim type="left">4</dim>
                           </dimensions>
                       </layout>
                       <layout columns="2" writtenLines="18">
                           <locus from="1r" to="11v" facs="001">Fols 1r–11v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc><handNote xml:id="h1" script="Ethiopic"><seg type="rubrication"><foreign xml:lang="gez">ኢየሱስ፡</foreign><foreign xml:lang="gez">ማርያም፡</foreign></seg></handNote></handDesc>
                  <decoDesc>
                    <decoNote type="frame" xml:id="d1"> Decorative designs: <locus target="#4r #8v" facs="004 009">folss. 4r, 8v, </locus> (line of alternating red and black dots); <locus target="#8v" facs="009">8v</locus> (multiple connected full stops)</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc>Scribal intervention: words of text are written interlinearly (<locus target="#7r #8r" facs="007 008">folss. 7r, 8r, </locus>);
                        and lines of text are written interlinearly (<locus target="#1r #7r" facs="001 007">1r, 7r</locus>)</desc></item>
                    </list>
                  </additions>

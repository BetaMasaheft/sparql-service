               <msContents>
                  <summary>
                    Octateuch, ኦሪት፡,
                    Genesis (f<locus target="#1r">fols. 1r, </locus>-21v),
                    Exodus (f<locus target="#21v">21v, </locus>-39v),
                    Leviticus (f<locus target="#39v">39v, </locus>-53r),
                    Numbers (f<locus target="#53v">53v, </locus>-72v),
                    Deuteronomy (f<locus target="#73r">73r, </locus>-89v),
                    Joshua (f<locus target="#90r">90r, </locus>-101r),
                    Judges (f<locus target="#101v">101v, </locus>-112v),
                    Ruth (f<locus target="#112v">112v</locus>-114r),
                    belonging to Nǝburä ‘Ǝdǝ Dǝmeṭǝros Gäbrä Maryam</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="114r" facs="002">Fols 1r–114r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2083Octate">Octateuch</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1.1">
                      <locus from="1r" to="21v" facs="002">Fols 1r–21v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1546Genesi">Genesis</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘልደት፡ ምዕራፍ፡ ፩ በቀዳሚ፡ ገብረ፡ እግዚአብሔር፡ ሰማየ፡ ወምድረ፡ ወምድርሰ፡ ሀለወት፡ ዕራቃ፡ ወኢታስተርኢ፡ ወኢኮነት፡ ድሉተ፡ ወጽልመት፡
                        መልዕልተ፡ ቀላይ፡ ወመንፈሰ፡ እግዚአብሔር፡ ይጼልል፡ መልዕልተ፡ ማይ።
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘልደት፡ በሰላመ፡ እግዚአብሔር፡ ወስብሐት፡ ለእግዚአብሔር፡ ፈጣሬ፡ ኵሉ፡ ፍጥረታት።
                      </explicit>
                    </msItem>
                    <msItem xml:id="ms_i1.2">
                      <locus from="21v" to="39v" facs="023">Fols 21v–39v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1367Exodus">Exodus</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘፀአት፡ ምዕራፍ፡ ፩ ዝውእቱ፡ አስማቲሆሙ፡ ለደቂቀ፡ እ[ስ]ራኤል፡ እለ፡ ብሔረ፡ ግብጽ፡ ምስለ፡ ያዕቆብ፡ አቡሆሙ፡ ብእሲ፡ ብእሲ፡ ወቤቱ፡ ቦኡ፡
                        ሮቤል፡ ወስምዖን፡ ሌዊ፡ ወይሁዳ፡ ይሳኮር፡ ወዛብሎን፡ ዳን፡ ወንፍታሌም፡ ጋድ፡ ወአሴር፡ ወብንያም፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘፀአት፡ ስብሐት፡ ለእግዚአብሔር፡ ገባሬ፡ ኵሉ፡ ፍጥረት።
                      </explicit>
                    </msItem>
                    <msItem xml:id="ms_i1.3">
                      <locus from="39v" to="53r" facs="041">Fols 39v–53r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1793Leviti">Leviticus</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘሌዋውያን፡ ምዕራፍ፡፩ ወጸውዖ፡ እግዚአብሔር፡ ለሙሴ፡ ወተናገሮ፡ እምውስተ፡ ደብተራ፡ መርጡል፡ ወይቤሎ፡ በሎሙ፡ ለደቂቀ፡ እስራኤል፡ ወአይድዖሙ፡ እመቦ፡ ብእሲ፡ እምኔክሙ፡
                        ዘአብአ፡ መባእ፡ ለእግዚአብሔር፡ እምእንስሳ፡ እምአልህምት፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘሌዋውያን፡ ስብሐት፡ ለእግዚአብሔር፡ ተወካፊ፡ መሥዋዕት፡ ወቍርባን።
                      </explicit>
                    </msItem>
                    <msItem xml:id="ms_i1.4">
                      <locus from="53v" to="72v" facs="055">Fols 53v–72v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2075Number">Book of
                                                  Numbers</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘኁልቍ፡ ምዕራፍ፩ ወነበቦ፡ እግዚአብሔር፡ ለሙሴ፡ በገዳም፡ ዘሲና፡ በውስተ፡ ደብተራ፡ ዘመርጡል፡ አመ፡ ርእሰ፡ ሠርቀ፡ ወርኅ፡ ካልእ፡ በካልእት፡ ዓመት፡ እምዘ፡ ወፅኡ፡ እምድረ፡ ግብጽ፡ ወይቤሎ፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘኁልቍ፡ ወስብሐት፡ ለእግዚአብሔር፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፡ ለይኩን፡ ለይኩን።
                      </explicit>
                    </msItem>
                    <msItem xml:id="ms_i1.5">
                      <locus from="73r" to="89v" facs="074">Fols 73r–89v</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2637Deuteronomy">Deuteronomy</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘዳግም፡ ምዕራፍ፡፩ ዝንቱ፡ ውእቱ፡ ነገር፡ ዘነገሮሙ፡ ሙሴ፡ ለደቂቀ፡ እስራኤል፡ በማዕዶተ፡ ዮርዳኖስ፡ በመንገለ፡ ዓረቢሃ፡ በኀበ፡ ባሕረ፡ ኤርትራ፡ በማእከለ፡ ፋራን፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘዳግም፡ ስብሐት፡ ለእግዚአብሔር፡ ጸጋዌ፡ ጸጋ፡ ፍጹም።
                      </explicit>
                    </msItem>
                    <msItem xml:id="ms_i1.6">
                      <locus from="90r" to="101r" facs="091">Fols 90r–101r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1696Joshua">Book of
                                                  Joshua</title>
                      <incipit xml:lang="gez">
                        ኦሪት፡ ዘኢያሱ፡ ምዕራፍ፡፩ ወኮነ፡ እምድኅረ፡ ሞተ፡ ሙሴ፡ ገብረ፡ እግዚአብሔር፡ ይቤሎ፡ እግዚአብሔር፡ ለኢያሱ፡ ወልደ፡ ነዌ፡ ላእኩ፡ ለሙሴ፡ ናሁ፡ ሞተ፡ ሙሴ፡
                        ቍልዔየ፡ ወይእዜኒ፡ ተንሥእ፡ ወአድዎ፡ ለዝንቱ፡ ዮርዳኖስ፡ አንተ፡ ወኵሉ፡ ዝንቱ፡ ሕዝብ፡ ውስተ፡ ምድር፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ተፈጸመ፡ ኦሪት፡ ዘሆሴዕ።
                      </explicit>
                </msItem>
                <msItem xml:id="ms_i1.7">
                  <locus from="101v" to="112v" facs="103">Fols 101v–112v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT1700Judges">Book of
                                                  Judges</title>
                  <incipit xml:lang="gez">
                    ኦሪት፡ ዘመሳፍንት፡ ምዕራፍ፡፩ ወኮነ፡ እምድኅረ፡ ሞተ፡ ኢያሱ፡ ተሰአሉ፡ ደቂቀ፡ እስራኤል፡ ኀበ፡ እግዚአብሔር፡ እንዘ፡ ይብሉ፡ መኑ፡ የዓርግ፡ ለነ፡ ኀበ፡ ከናኔዎን፡ መልአክ፡ ዘይታቀተሎሙ፡
                    ለነ፡ ወይቤሎሙ፡ እግዚአብሔር፡ ይሁዳ፡ ይዕርግ፡ ወናሁ፡ አግባእክዋ፡ ለምድር፡ ውስተ፡ እዴሁ፡
                  </incipit>
                  <explicit xml:lang="gez">
                    ተፈጸመ፡ ኦሪት፡ ዘመሳፍንት፡ ወስብሐት፡ ለእግዚአብሔር፡ አሜን።
                  </explicit>
                </msItem>
                <msItem xml:id="ms_i1.8">
                  <locus from="112v" to="114r" facs="114">Fols 112v–114r</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT2229RuthBo">Book of Ruth</title>
                  <incipit xml:lang="gez">
                    ኦሪት፡ ዘሩት፡ ምዕራፍ፡፩ ወኮነ፤ በመዋዕለ፡ ይኴንኑ፡ መሳፍንት፡ መጽአ፡ ረኃብ፡ ውስተ፡ ብሔር፡ ወሖረ፡ ፩ብእሲ፡ እምቤተ፡ ልሔም፡ ዘይሁዳ፡ ከመ፡ ይንበር፡ ውስተ፡ ሐቅለ፡ ሞአብ፡ ውእቱ፡
                  </incipit>
                  <explicit xml:lang="gez">
                    ተፈጸመ፡ ኦሪት፡ ዘሩት፡ ስብሐት፡ ለእግዚአብሔር፡ ለዓለመ፡ ዓለም፡ አሜን።
                  </explicit>
                  </msItem>
                </msItem>
               </msContents>

<physDesc>

  <handDesc>
  <handNote script="Ethiopic" xml:id="h2">
  <desc>The manuscript is written in a good hand, towards the end of <date>18th century</date>.</desc>
  <date notBefore="1750" notAfter="1800"/>
  </handNote>
  </handDesc>

  <additions>
  <list>

  <item xml:id="a1">
  <locus target="#4r"/>
  <desc type="OwnershipNote">The manuscript was written for a woman called <persName ref="https://betamasaheft.eu/PRS13410Walatta">Walatta Takla Hāymānot</persName>. Her
  name is also mentioned on <locus target="#13v">f. 13v</locus> and <locus target="#14r">14r</locus>, with that of her father <persName ref="https://betamasaheft.eu/PRS13409Hensa">Ḥǝnḍā Śǝllāse</persName> and
  her brother <persName ref="https://betamasaheft.eu/PRS13412Haile">Ḫayla Takla Hāymānot</persName>.</desc>
  </item>

  <item xml:id="a2">
  <desc type="MixedNote">The name of the king <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis</persName> often occurs (e. g. on <locus target="#12v">f. 12v</locus>) and
  the sitting ʾabuna was <persName ref="https://betamasaheft.eu/PRS10450YosabI">ʾIyosāb</persName>. (<locus target="#45r">f. 45r</locus>, <locus target="#65r">65r</locus>). The name of the
  patriarch of Alexandria is left blank.</desc>
  </item>

  <item xml:id="a3">
  <locus target="#4r"/>
    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
            <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
        <q xml:lang="gez">ቅዳሴ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName></q>
  </item>

  <item xml:id="e1">
  <desc>The name <persName ref="https://betamasaheft.eu/PRS13414Walatta">Walatta Giyorgis</persName> occurs
  on <locus target="#14v">f. 14v</locus>, <persName ref="https://betamasaheft.eu/PRS13413Semrata">Śǝmrata Dǝngǝl</persName> on <locus target="#15r">f. 15r</locus>.</desc>
  </item>
  </list>
  </additions>

</physDesc>


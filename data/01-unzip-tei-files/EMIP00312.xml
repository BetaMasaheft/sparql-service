                    <decoNote type="miniature" xml:id="d1"><locus target="#8v" facs="011">Fol. 8v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> with caption <q>“George.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#9r" facs="011">Fol. 9r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> attended by the angels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#39r" facs="041">Fol. 39r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref> with caption <q>“Holy Trinity.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#61r" facs="063">Fol. 61r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1067LastSupper">The Last Supper</ref> with caption <q>“Maundy Thursday.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#92r" facs="094">Fol. 92r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#121r" facs="123">Fol. 121r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#151r" facs="153">Fol. 151r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref> raising Adam and Eve. with caption <q>“With Eve,”</q> <q>“How Our Lord Jesus Christ rose from the dead on the third day,”</q> and <q>“With Adam.”</q></desc></decoNote>

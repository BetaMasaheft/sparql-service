         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q969286">
               <t:persName>
             
                     <t:forename>Marcel</t:forename>
                     <t:surname>Cohen</t:surname> 
               </t:persName>
                  
                  <t:occupation type="academic">scholar</t:occupation>
                  <t:nationality type="France"/>
                  <t:faith type="notSpecified"/>
               <t:birth when="1884">He was born at <t:placeName ref="https://www.wikidata.org/entity/Q90">Paris</t:placeName> in <t:date>1884</t:date>.</t:birth>
                  <t:floruit notBefore="1908" notAfter="1974">He was a distinguished French linguist, born from a middle class Jewish family. He devoted to comparative
                     Semitic linguistics and prepared himself for this work in the areas of Oriental studies and linguistics.
                     He attended Amharic course under 
                     <t:persName ref="https://betamasaheft.eu/PRS7146MondonV">Casimir Mondon-Vidailhet</t:persName> and later, he published couplets amharique du choa in <t:date>1924</t:date>. </t:floruit>
                  <t:death when="1974"/>
            </t:person>
            
         </t:listPerson>
         
         

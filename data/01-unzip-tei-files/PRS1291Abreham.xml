                  <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName>
               </t:residence>
               <t:floruit notBefore="1591" notAfter="1612">He was the seventeenth abbot of 
                  <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName>
                  who succeeded ʾǝč̣č̣age <t:persName ref="https://betamasaheft.eu/PRS10651ZatraW">Zatra Wangel</t:persName> in<t:date>1591</t:date>. 
                  He was a contemporary of both King  
                  <t:persName ref="https://betamasaheft.eu/PRS8550sardaDe">Śarḍa Dǝngǝl</t:persName> and King<t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</t:persName> 
                  
                </t:floruit>
               <t:death when="1612" evidence="internal">He died in the sixth year of  the reign of King <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</t:persName> in <t:date>1612</t:date>.
               </t:death>
            </t:person>
            

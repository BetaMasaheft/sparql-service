                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful</seg>
                        <seg type="ink">Black, red, crimson</seg>
                        <date>Late 19th cent.</date>
                        <seg type="rubrication">Holy names; names of the donors; the word
                           taʾammǝr; incipit of Text I-1 and its subsections; incipit of Text I-2;
                           incipit of Text I-3 and its subsections; incipit of Text II and its
                           subsections; elements of the punctuation signs; Ethiopic numerals. 
                           On the incipit page of Text I-1 lines are rubricated, alternating with
                           black lines (s. fol. 4r). 
 On fol. 64r, lines are rubricated,
                           alternating with black lines.</seg>
                     </handNote>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre but careful.</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>First half of 20th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                           <item>ንስእ፡ እግ፡ for ንስእለከ፡ እግዚኦ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; initial line of
                           prayers; directives to the ministers and their abbreviations; the
                           sentence nǝsǝʾǝ[läkä] ʾǝgz[iʾo] and its abbreviation (fols. 19v-23v);
                           some letters (fols. 26v); elements of the punctuation signs.
 On the
                           incipit page of Text I (fol. 3r), a few lines are rubricated (alternating
                           with black lines).</seg>
                     </handNote>
                  </handDesc>

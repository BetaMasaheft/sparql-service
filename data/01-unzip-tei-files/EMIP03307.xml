               <msContents>
                  <summary>Asmat prayer God gave to Moses</summary>
                  <msItem xml:id="ms_i1"><locus from="3r" to="33r" facs="003">Fols 3r–33r</locus><title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> God gave to <persName ref="https://betamasaheft.eu/PRS7182Moses">Moses</persName></title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">34</measure>
                           <dimensions type="outer" unit="mm">
                              <height>140</height>
                              <width>93</width>
                              <depth>25</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="11"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1v" facs="002">Fol. 1v</locus><desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#2r" facs="002">Fol. 2r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with drawn <term key="sword" ana="#sword"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#2v" facs="003">Fol. 2v</locus><desc>Two people, facing one another</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#11r" facs="011">Fol. 11r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, flanked by two guardian <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#16v" facs="017">Fol. 16v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with drawn <term key="sword" ana="#sword"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#17r" facs="017">Fol. 17r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> holding the hand of a man, both facing an <term key="angel" ana="#angel"/> with drawn <term key="sword" ana="#sword"/></desc></decoNote>
                  	<decoNote type="miniature" xml:id="d7"><locus target="#34v" facs="035">Fol. 34v</locus><desc>Crude drawing of a figure, in pencil</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#3r" facs="003"> f. 3r, top margin</locus>
                    <desc>
                    Arranged for the days of the week, Monday
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#3r" facs="003">Fol. 3r</locus>
                    <desc>
                    a small harag at the top of the folio
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#3r" facs="003"> f. 3r and passim</locus>
                    <desc type="OwnershipNote">
                    the owner, Gabra Selassie, is mentioned throughout the book
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#33r" facs="033">Fol. 33r</locus>
                    <desc>
                    The scribe, <foreign xml:lang="gez">ወልደ፡ ጸድቅ፡</foreign>, Walda Tsedeq, is mentioned on the last folio of the main work
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#33v #34r #34v" facs="034 035">Fols. 33v, 34r, 34v</locus>
                    <desc type="Record">
                    Record of transaction: in the year 1900, in the year of  John the Evangelist, <foreign xml:lang="am">ልጅ፡ ሀብተ፡ ጊዮርጊስ፡</foreign>, Lej Yohannes, bought land in <foreign xml:lang="am">ወሊሶ፡</foreign>, Woliso from <foreign xml:lang="am">ባላምባራስ፡ ገመዳ፡</foreign>, for 50 birr. A list of witnesses and judges follows. Written a fine hand, in Amharic
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#34v" facs="035">Fol. 34v</locus>
                    <desc>
                    Indecipherable record mentioning <foreign xml:lang="gez">መኒልክ፡</foreign> written in pencil in a poor hand
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#Inside back cover" facs="001">Fols. Inside,, </locus>
                    <desc>
                    the name Gabre Kristos (in English characters) is written in black ink pen on the leather
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

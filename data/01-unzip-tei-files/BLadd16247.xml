                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="8"/>
                            <title>Various prayers and magic texts</title>
                        </msItem>
                            
                        <msItem xml:id="ms_i2">
                            <locus from="9" to="62"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1171Awdana">አውደ፡ ነገሥት።</title>
                            <msItem xml:id="ms_i2.1">
                                <locus from="9" to="18"/>
                                <title ref="https://betamasaheft.eu/LIT1171Awdana#tables"/>
                                <note>Sixteen circular tables, each subdivided into sixteen parts with questions on various topics.</note>
                            </msItem>
                            <msItem xml:id="ms_i2.2">
                                <locus from="19" to="60"/>
                                <title ref="https://betamasaheft.eu/LIT1171Awdana#seas">ʿAwda nagaśt, Sixteen "seas" (ባሕር፡), each containing 16 sentences as a response to the previous questions</title>
                                <note>Sixteen "seas" (<foreign xml:lang="gez">ባሕር፡</foreign>), each containing 16 sentences as a response to the previous questions.</note>
                            </msItem>
                        </msItem>
                            
                        <msItem xml:id="ms_i3">
                            <locus from="62" to="64"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3578Prayer">ጸሎት፡ ዘቅዱስ፡ ቆጵርያኖስ፡</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="64" to="67"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4011Zodiac">Untitled text on the twelve signs of the zodiac</title>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="67" to="79"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1947Mashaf">መጽሐፈ፡ መቅድመ፡ ከሣቴ፡ ምሥጢር፡</title>
                            <incipit xml:lang="gez">
                                <locus target="#67"/>
                                በስመ፡ እግዚአብሔር፡ መሐሪ፡ ወመስተሣህል፡ ጸሐፍነ፡ ዘንተ፡ መጽሐፈ፡ መቅድመ፡ ከሣቴ፡ ምሥጢር፡ ዘበጥሊሞስ፡ ጠቢብ፡ ዮናናዊ፡ ላዕሌሁ፡ ሰላም፡ አሜን።  
                            </incipit>

                            <title type="complete" ref="https://betamasaheft.eu/LIT4012Stars">On various stars and their names</title>
                            <note>It consists of 16 chapters. The names of the stars are of Arabic origin.</note>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus target="#89v"/>
                            <title type="incomplete">Prayers to God</title>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <locus from="90" to="99"/>

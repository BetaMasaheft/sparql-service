         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="monastic">ጽሕማ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Ṣǝḥmā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="nick">ጸሕማ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Ṣaḥmā</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
               
                  <t:floruit> He was one of the Nine Saints, a group of foreign monks who arrived in Ethiopia
                     in the 5th and 6th century. 
                     After he arrived with the other saints, he is believed to have settled in the southeast of 
                     <t:placeName ref="https://betamasaheft.eu/LOC1264Adwa">ʿĀdwā</t:placeName>.
                  </t:floruit>
                  <t:death/>
               </t:person>  
               
         </t:listPerson>
         

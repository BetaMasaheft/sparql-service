                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_6524">
                           <locus target="#295v">-295v</locus>
                           <q xml:lang="ar">فتمت كلمات ربك صدقا وعدلا لا مبدل لكلماته وهو السميع العليم</q>
                           <note/>
                        </item>
                        <item xml:id="a1_6524">
                           <locus target="#295v">-295v</locus>
                           <q xml:lang="ar">تم الكتاب الشريف بحمد الله تعالى ومنه وكرمه وحسن توفيقه على حسب الطاقة والامكان نهار الاربع في شهر الله المبارك شعبان [هو ثلاثين] سنة ١١٠٠  من الهجرة المباركة المصطفية على صاحبها افضل الصلوة والسلام والحمد لله رب العالمين</q>
                           <desc>Colophon</desc>
                           <note>The text in square brackets is written upside down above the words Šaʻbān and sana. </note>
                           <note/>
                        </item>
                        <item xml:id="a0_7397">
                           <locus target="#296r">-296r</locus>
                           <q xml:lang="ar">دعاء ختم القران العظيم</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#2v-3r">-2v, 3r</locus>
                           <desc>Loose folio</desc>
                           <q/>
                           <note>Two small fragments, badly damaged. Text in red ink.</note>
                        </item>

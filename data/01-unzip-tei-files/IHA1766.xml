               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="1v">1v-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4519IHA">مطول كلام قديم</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>كلام قديم لا يمل سماعه , تنزه عن قول وفقل ونيتي \ به استشفي من كل دا ونوره , دليل لقلبي عند جهلي وحيرتي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>وصل وسلم كل يوم وليلة , على من به الرحمن يقبل توبتي \ وال واصحاب كرام ائمة , بهم يغفر الغفار ذنبي وزلتي \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="2r">2r-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0692IHA">دعاء اللهم لك الحمد منا ولك الشكر اذ هديتنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم \ اللهم لك الحمد منا ولك الشكر اذ هديتنا للايمان وعلمتنا القران اذ مننت علينا بما وهبتنا من علم تنزيلك وتاويله

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>اللهم انا نقرا كتابك العزيز لنيل الدرجات العلي ولقضاء الحاجات ولاسقاط الذنوب ولنور القلوب ولطرد الشيطان الرجيم اعوذ بالله من الشيطان الرجيم

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2v" to="295v">2v-295v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>سورة الفاتحة \ سبع ايات مكية \ بسم الله الرحمن الرحيم , الحمد لله رب العلمين , الرحمن الرحيم , ملك يوم الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#295v">-295v</locus>الذي يوسوس في صدور الناس , من الجنة والناس</explicit>
                     <note>Triple dots as verse markers. Words ǧuz' and ḥizb in red in the margins. Fol. 221v does not contain any text but there is no lacuna.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="296r" to="296v">296r-296v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#296r">-296r</locus>بسم الله الرحمن الرحيم \ اللهم ارحمنا بالقران العظيم وانفعنا بالايات والذكر الحكيم وبارك لنا في السبع المثانى والقران العظيم

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#296v">-296v</locus>وفرج عنا من كل هم وغم برحمتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="296v" to="297r">296v-297r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0688IHA">دعاء ختم القرآن الهمّ اجعلنا لنعمائك شاكرين</title>
                     <incipit xml:lang="ar">
                        <locus target="#296v">-296v</locus>بسم الله الرحمن الرحيم \ اللهم اجعلنا لنعمائك شاكرين , وعن بلائك ناجين , وبما قضيت علينا راضين

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#297r">-297r</locus>اللهم اجمع لنا خير الدنيا والاخرة , وقنا شرّ الدنيا والاخرة وبرحمتك , يا ارحم الراحمين , سبحان ربك رب العزة عما يصفون , وسلام علي المرسلين , والحمد لله رب العلمين

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="297r" to="297v">297r-297v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4152IHA">دعاء ختم القران اللهم ارزقنا توفيق الطاعة</title>
                     <incipit xml:lang="ar">
                        <locus target="#297r">-297r</locus>بسم الله الرحمن الرحيم \ اللهم ارزقنا توفيق الطاعة , وغفران المعصية , وصدق النية , واكرمنا بالهدى والاستقامة

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#297v">-297v</locus>وتب علينا وعليهم , وعلى جميع المسلمين والمسلمات , برحمتك يا ارحم الراحمين , سبحان ربك رب العزة عما يصوفون , وسلام على المرسلين , والحمد لله رب العلمين

</explicit>
                     <note/>
                     <note/>
                  </msItem>

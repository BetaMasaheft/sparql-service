         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ዮሐንስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Yoḥannǝs</persName>
               <persName>
                  <roleName type="title">ʿaqqābe saʿat</roleName>
               </persName>
               <occupation type="ecclesiastic">abbot</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
             
               <residence>
                  <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos</placeName>
               </residence>
               <floruit notBefore="1300" notAfter="1400">He was the fourteenth century abbot of <placeName ref="https://betamasaheft.eu/INS0327DHE">Dabra Ḥayq ʾƎsṭifānos</placeName> 
                  during the reign of 
                  <persName ref="https://betamasaheft.eu/PRS8595SayfaAr">
                     <roleName type="title">ʾaṣe</roleName> Sayfa ʾArʿad</persName>. 
                  He was a very strong abbot who organized the monastery and the services of 
                  individual members of the community during his term office. It is not known exactly when his term office started and nor when it came to an end. He was succeeded by
                  ʿaqqābe saʿat <persName ref="https://betamasaheft.eu/PRS11171Krestos">Krǝstos Moʾa</persName>. He had a land grant mentioned in <ref type="mss" corresp="https://betamasaheft.eu/NLA28">Addis Ababa, Ethiopian National Archives and Library Agency, NALE 28</ref>
                                    
               </floruit>
        
            </person>
            
         </listPerson>
         
         

                            <additions>
                                <list>

                                  <item xml:id="a1">
                                    <locus target="#3r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ዲድስቅልያ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam"> ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                              </q>
                                  </item>

                                  <item xml:id="a2">
                                    <locus from="109r"/>
                                    <desc type="GuestText">
                                      <title ref="https://betamasaheft.eu/LIT1994Mazgab">Mazgaba hāymānot</title>
                                    </desc>
                                  <q xml:lang="gez"/>
                                  </item>
                                  <item xml:id="a3">
                                    <locus from="122r"/>
                                    <desc type="GuestText">
                                      <title xml:lang="en" ref="https://betamasaheft.eu/LIT2293Sawase">Explanation of words,
                                      chiefly Biblical in Amharic.</title>
                                    </desc>
                                    <q xml:lang="am">
                                      <seg part="I">
                                        ንጽሕፍ፡ ነገረ፡ ሰዋስው፡ ዘሐዲስ፡ ወዘብሉይ። ሰዋስው፡ ዘ፡ መሽጋገርያ፡ ወዓዲ፡ ዘ፡ መሰላል፡ ዲበ፡ ዘ፡
                                        በላ፡ እንዘ፡ ዘ በ፫፡ ሲሰስ፡ እስመ፡ ዘ፡ በ፪፡ ኮን፡ ስለ፡ እመ፡ ሶበ፡ ዘ፡ ፪፡ በቢቡብ፡ እንከ፡ ዘ፡ እንግድያ፡
                                        እፎ፡ ዘ፡ በ፪፡ እንዴት፡ ምን፡ እምዝ፡ ዘ፡ በ፪፡ ከዝያ፡ እንግዴኅ፡ እንተ፡ እለ፡ ዘ፡ የ፡ ይእዜ፡ ዘ፡ በ፫፡
                                        አኁን፡ ዛሬም፡ እንግዴኅ፤
                                      </seg>
                                    </q>
                                  </item>
                                  <item xml:id="a4">
                                    <locus from="126r"/>
                                    <desc type="GuestText">
                                      <title xml:lang="en" ref="https://betamasaheft.eu/LIT3852KingList">
                                        List of Kings of Ethiopia, from
                                        <persName ref="https://betamasaheft.eu/PRS10303Yekunno">Yǝkunno ʾAmlāk</persName> to
                                        <persName ref="https://betamasaheft.eu/PRS10198Yaeqob">ʾaṣe Yāʿqob</persName> and
                                        <persName ref="https://betamasaheft.eu/PRS10513Zadenge">Zadǝngǝl</persName>.
                                      </title>
                                    </desc>
                                    <q xml:lang="gez"/>
                                  </item>
                                  <item xml:id="a5">
                                    <locus from="126rb"/>
                                    <desc type="GuestText">
                                      List of important events from the Nativity of our Lord to the
                                      time of <persName ref="https://betamasaheft.eu/PRS10303Yekunno">Yǝkunno ʾAmlāk</persName>.
                                    </desc>
                                    <q xml:lang="gez"/>
                                  </item>
                                </list>
                                <list>
                                  <item xml:id="e1">
                                    <desc>The name of the owner or the scribe is
                                    <persName ref="https://betamasaheft.eu/PRS13175YamanaA">Yamāna ʾAb Lāʾka Māḫbar</persName>.</desc>
                                  </item>

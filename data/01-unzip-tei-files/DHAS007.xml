                       <additions>
                           <list>
                               <item xml:id="a1">
                                   <locus target="#72rb">Fol. 72rb</locus>
                                   <desc type="Unclear">A list of the followers or disciples of mamher Takla Mikāʾel (probably of Dabra Hāllelo)</desc>
                                   <q xml:lang="gez">ናሁ፡ ጸሐፍነ፡ ሰመ፡ መምህርነ፡ ተክለ፡ ሚካኤል፡ ወእለ፡ ምስሌሁ፡ ወልደ፡ አምላክ፡<gap reason="ellipsis" resp="DN"/></q>
                                   <note>Written in a more recent hand.</note>
                               </item>
                               
                               <item xml:id="a2">
                                   <locus target="#72va">Fol. 72va</locus>
                                   <desc type="Unclear">A list of the followers or disciples of mamhǝr Sayfa Mikāʾel (probably of Dabra Hāllelo)</desc>  
                                   <note>Written in the same hand as <ref target="#a1">Additional note 1</ref>.</note>                                   
                               </item>
                               
                               <item xml:id="a3">
                                   <locus target="#72va">Fol. 72va</locus>
                                   <desc type="Unclear">A list of the followers or disciples of mamhǝr Muse (probably of Dabra Hāllelo)</desc>
                                   <q xml:lang="gez">ዓዲ፡ ጸሐፍነ፡ ሰመ፡ መምህርነ፡ ሙሴ፡ ዮናክንዲስ፡ ክንፈ፡ ሚካኤል፡ ኢያሱ፡<gap reason="ellipsis" resp="DN"/></q>
                                   <note>Written in the same hand as <ref target="#a1">Additional note 1</ref>.</note>    
                               </item>
                               
                               <item xml:id="a4">
                               <locus target="#73ra">Fol. 73ra</locus>
                                   <desc type="Unclear">A list of the followers or disciples of ʾabuna Kǝnfa Mikāʾel (probably of Dabra Hāllelo)</desc>
                                   <note>Written in the same hand as <ref target="#a1">Additional note 1</ref>.</note>    
                               </item>
                               
                               <item xml:id="a5">
                                   <locus target="#73rb">Fol. 73rb</locus>
                                   <desc type="Unclear">A note recording the penalty for anyone missing the church rituals</desc> 
                                   <note>Written in the same hand as <ref target="#a1">Additional note 1</ref>.</note>    
                               </item>
                               
                               <item xml:id="a6">
                                   <locus target="#181rb">Fol. 181rb</locus>
                                   <desc type="Unclear">A commissioner's note mentioning  ʾabbā Gabra Dǝngǝl, here 
                                       called the bishop (ኤጲስ፡ ቆጶስ፡) of the sanctuary of ʾabbā Sāmuʾel of Halle Luyā</desc> 
                                   </item>
                               
                           </list>

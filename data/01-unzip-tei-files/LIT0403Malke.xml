         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ ሥላሴ፡ ዋሕድ፡ ኅጡአ፡ ቅድምና፡ ወይእዜ፨</l>
                  <l n="2">ውዳስል፡ መልክእከ፡ እውጥን፡ ረኪብየ፡ ሰዓተ፡ ጊዜ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ አስተምሕር፡ ከመ፡ ግዮን፡ ቢጸ፡ ተከዜ፨</l>
                  <l n="4">ልብየ፡ ዕዝራ፡ እስመ፡ መልአ፡ ዕንባዜ፨</l>
                  <l n="5">ጰራቅሊጦስ፡ ኡርአ_፡ ይኩነኒ፡ ናዛዜ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ በሥርዓተ፡ ሰብሳብ፡ ወሕግ፨</l>
                  <l n="2">ወለልደትከ፡ ዘኮነ፡ በትንቢት፡ ኄራን፡ አእሩግ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ ያዕቆብ፡ ማኅቶተ፡ ከስዋ፡ ስሩግ፨</l>
                  <l n="4">አብርሆ፡ ለኅሊናየ፡ እምጾታ፡ ጽልመት፡ ጸዋግ፨</l>
                  <l n="5">ምልአ፡ ገጸ፡ ድርሳት፡ እርአይ፡ ዘአልቦ፡ ንተግ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተበፅዐ፡ ወተወደሰ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ በቅብአ፡ ምናኔ፡ ዘርኅሰ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ በኵሉ፡ አስተበቍዐከ፡ አንሰ፨</l>
                  <l n="4">በዋዕየ፡ ገድልከ፡ እስመ፡ ጥለ፡ ጌጋይየ፡ የብሰ፨</l>
                  <l n="5">ወአመ፡ ጽድቅከ፡ ገጸየ፡ ሐዲሰ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ናሁ፡ ቀሠምኩ፡ ጽጌ፡ መልክእከ፡ በይባቤ፨</l>
                  <l n="2">እምገነተ፡ ዜና፡ መድምም፡ እንዘ፡ እጸርሕ፡ ወእቤ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ በለኒ፡ በመዐዛ፡ ቃልከ፡ እምጼና፡ ከርቤ፨</l>
                  <l n="4">ሠመርኩ፡ አነ፡ ድርሳንከ፡ ኢትኩን፡ ነባቤ፨</l>
                  <l n="5">ኪዳንየ፡ በአርምሞ፡ ይኩንከ፡ ዐቃቤ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ስብሐት፡ ለእግዚአብሔር፡ ወለማርያም፡ ይደሉ፨</l>
                  <l n="2">ፍጻሜ፡ መልክእከ፡ አባ፡ ዘበጻሕኩ፡ በጽንዐ፡ እሉ፨</l>
                  <l n="3">መዝገበ፡ ሥላሴ፡ ዝክርከ፡ ለትውልደ፡ ትውልድ፡ ዘይሄሉ፨</l>
                  <l n="4">ሰሚዖሙ፡ ለደቂቅከ፡ ሀብተ፡ በረከትከ፡ ኵሉ፨</l>
                  <l n="5">ትጉሃን፡ መላእክት፡ አሜነ፡ ይበሉ፨</l>
               </lg>
            </div>
         </div>
      </body>

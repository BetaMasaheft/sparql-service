               <msContents>
                  <summary>Story of the Trinity</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="122v">Fols 4r–122v</locus>
                     <title>Zēnā Śellāsē</title>
                     <note>Introduction, fol. 4r-11v; Homilies for the monthly feasts of the Trinity, fol. 11v-42r; Additional homilies of the Trinity, fol. 42r-59v; 63 miracles of the Trinity, fol. 59v-122v. Arranged for the days of the week.          
                     </note>
                  </msItem>
               </msContents>

                        <msItem xml:id="ms_i1">
                            <locus from="14r" to="59r">Fols 14r–59r</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna Māryām ba-Dabra Golgotā</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አሐዱ፡ አምላክ፡
                                ዛቲ፡</hi> ጸሎት፡ ዘእግዝእትነ፡ <hi rend="rubric">ማርያም፡</hi> እሙ፡ ለብርሃን፡ ወላዲተ፡ አምላክ፡ 
                                ቅድስ<hi rend="rubric">ት፡ ድንግል፡ ንጽሕት፡ ዘጸሐፋ፡
                                አብሮኮሮስ፡ ረድአ፡</hi> ዮሐንስ። ጸሎተ፡ ወበረከተ፡ ወምሕረተ፡ ፍቁር፡ ወልዳ፡ የሃሉ፡ ምስለ፡ ገብራ፡ 
                                <hi rend="rubric">
                           <persName ref="https://betamasaheft.eu/PRS11744HabtaM">ሀብተ፡ ማርያም፡</persName> ለዓለመ፡</hi> ዓለም፡ አሜን። ጸሎት፡ ዘ<hi rend="rubric">ጸ</hi>ለ<hi rend="rubric">የ</hi>ት፡ <hi rend="rubric">ባ</hi>ቲ፡ አመ፡ 
                                <hi rend="rubric">፰</hi>ወ<hi rend="rubric">፩</hi>ለወርኀ፡ ሰኔ፡ በደብረ፡ ጎልጎታ፡
                                ዘውእቱ፡ መቃብረ፡ እግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ሎቱ፡ ስብሐት፡ ለዓለመ፡ ዓለም፡
                                አሜን። </incipit>
                        </msItem>
                        

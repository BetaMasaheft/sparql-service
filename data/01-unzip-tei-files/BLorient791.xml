                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="3r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#PartII">
                            The second part of Gubāʿe mǝśṭirāta zamanāt
                          </title>
                          <textLang mainLang="gez"/>
                          <note><ref type="mss" corresp="https://betamasaheft.eu/BLorient790">London, British Library, BL Oriental 790</ref> contains the first part.</note>

                          <msItem xml:id="ms_i1.1">
                            <locus from="3r" to="4ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#IntroductionII">Maṣḥafa madbal: Introduction to the second part</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ አብ፡ ንዌጥን፡ በረድኤተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡
                            ጽሒፈ፡ መጽሐፍ፡ ዘይሰመይ፡ መድበል፡ ዘበትርጓሜሁ፡ ጉባኤ፡ ምስጢረ፡ ዘመናት፡ ዘገብረ፡ እግዚአብሔር፡
                          ኂሩተ፡ ለሰብእ። በእደ፡ ወልድ፡ ዋሕድ፡</incipit>
                          </msItem>
                          <msItem xml:id="ms_i1.2">
                              <locus from="4va" to="4vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#Verses">Maṣḥafa madbal: Verses addressed to the Holy Trinity</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.3">
                              <locus from="5ra" to="174va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#FourGospels">Maṣḥafa madbal: The four Gospels in verses</title>

                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.4">
                            <locus from="170v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#Testament">Maṣḥafa madbal: in verses</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.5">
                              <locus from="173v" to="174rb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#DoctrinaArcanorum">Maṣḥafa madbal: in verses</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.6">
                              <locus from="174rb" to="175vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#Draught">Maṣḥafa madbal: Miraculous Draught of Fishes</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.7">
                              <locus from="175vb" to="179va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5188MashafaMadbal#Ascension">Maṣḥafa madbal: Ascension</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                        </msItem>

                    </msContents>

                    <physDesc>
                        <objectDesc form="Codex">
                            <supportDesc>
                                <support>
                                    <material key="parchment"/>
                                </support>
                                <extent>
                                    <measure unit="leaf" quantity="180">180</measure>
                                    <dimensions type="outer" unit="in">
                                        <height>15.125</height>
                                        <width>12.375</width>
                                    </dimensions>
                                </extent>
                                <foliation>Foliation in the upper right corner by the library.</foliation>
                                <condition key="good"/>

                            </supportDesc>

                            <layoutDesc>
                                <layout columns="2" writtenLines="6 20">
                                    <ab type="pricking">Pricking and ruling are visible.</ab>
                                    <ab type="pricking">Primary pricks are visible, horizontal pricks are visible.</ab>
                                    <ab type="ruling" subtype="pattern">1A-1A-1A1A/0-0/0-0/C</ab>
                                    <note>The painted areas are not ruled.</note>
                                    <ab type="ruling">The upper line is written above the ruling,
                                        the lower line is written above the ruling.</ab>
                                </layout>
                            </layoutDesc>
                        </objectDesc>

                        <handDesc>

                            <handNote script="Ethiopic" xml:id="h1">
                                <desc>The manuscript is  written in fine hand of the earlier
                                  part of <date>18th century.</date>
                                </desc>
                                <seg type="ink">Black, red</seg>
                                <date notBefore="1700" notAfter="1800" resp="PRS10171Wright"/>
                            </handNote>

                        </handDesc>
                        <decoDesc>
                          <summary>
                              Most pages contain a large miniature in the middle, above which there are four written lines and below it two written lines.
                              Starting from <locus target="#165v"/>, the miniatures are unfinished, and some parts of them are left uncoloured.
                              On 
                            <locus target="#179r"/> the space left for the miniature is left blank.</summary>
                            <decoNote xml:id="d1" type="miniature">
                              <locus target="#176v"/>
                              <desc>There is a mention of the artist
                                <persName role="illustrator" ref="https://betamasaheft.eu/PRS12451Hezqeel">Ḥǝzqǝʿel</persName>.</desc>
                            </decoNote>
                        </decoDesc>
                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus target="#1r"/>
                              <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                  <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                              <q xml:lang="gez">ወንጌል፡ አስተዋጽኦ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">
                                ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                        </q>
                            </item>
                            <item xml:id="e1">
                              <desc>The owner's name <persName role="owner" ref="https://betamasaheft.eu/PRS12449WaldaGiyorgis">Walda Giyorgis</persName>
                             is mentioned on <locus target="#2v #4r #180v"/></desc>
                            </item>

                          </list>

                        </additions>
                        
                        <bindingDesc>
                            <binding contemporary="false" xml:id="binding">
                                <decoNote xml:id="b1" type="Boards">Two wooden boards. Both inner boards are darkened around the edges, 
                                    possibly showing traces of a former cover.</decoNote> 
                                <decoNote xml:id="b2" type="Cover">Blind-tooled leather <term key="quarterCover" ana="#quarterCover">quarter cover</term>
                                    (with the gilded title and shelfmark on the spine).</decoNote> 
                                <decoNote xml:id="b3" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                </decoNote>
                                <decoNote xml:id="b5" type="SewingStations">Sewing stations are used in an irregular way.</decoNote> 
                                <decoNote xml:id="b6">The manuscript has been rebound in the library. Possibly both wooden boards have been replaced, 
                                    and a blind-tooled quarter cover added.</decoNote>
                            </binding>
                        </bindingDesc>
                        

                    </physDesc>

                    <history>
                        <origin>
                            <origDate notBefore="1721" notAfter="1730" evidence="reign">

                              <certainty locus="value" match="../@notBefore" cert="high"/>
                              <certainty locus="value" match="../@notAfter" cert="high"/>
                                The provided time span is attested in the manuscript which contains
                                the first part of the work <ref type="mss" corresp="https://betamasaheft.eu/BLorient790">London, British Library, BL Oriental 790</ref>.
                            </origDate>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area, 
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted 
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.
                        </provenance>

                    </history>


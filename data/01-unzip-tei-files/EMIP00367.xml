          <msContents>
            <summary>Image of Marqorewos, Image of Honorable Saints, </summary>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="1v" facs="004">Fols 1r–1v</locus>
              <title>Fragment of Image of Marqorewos, <foreign xml:lang="gez">መልክአ፡
                  መርቆሬዎስ፡</foreign></title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
              <note>Illumination of two angels with drawn swords is painted over most of <locus target="#1v" facs="003">fol. 1v</locus>. Could be either <ref type="work" corresp="https://betamasaheft.eu/LIT2888RepCh169">Malkǝʾ-hymn to St
                                                  Mercurius</ref> or <ref type="work" corresp="https://betamasaheft.eu/LIT2871RepCh152">Malkǝʾ-hymn to St
                                                  Mercurius</ref></note>
            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="2r" to="2v" facs="003">Fols 2r–2v</locus>
              <title>Fragment of Image of Honorable Saints, <foreign xml:lang="gez">መልክአ: ቅዱሳን:
                  ኄራን:</foreign></title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
              <note>Illumination of Madonna and Child is painted over most of <locus target="#2r" facs="004">fol. 2r</locus></note>
            </msItem>
            <msItem xml:id="ms_i3">
              <locus from="3r" to="3v" facs="002">Fols 3r–3v</locus>
              <title>Fragment of Image of Tewodros, Malk‘a Tewodros</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
              <note>Illumination of Madonna and Child is painted over most <locus target="#3v" facs="006">fol. 3v</locus></note>
            </msItem>
            <msItem xml:id="ms_i4">
              <locus from="4r" to="4v" facs="006">Fols 4r–4v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT3073RepCh353">Hymn to
                                                  ʾEwosṭātewos</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
              <note>(illumination of Saint George and the Dragon is painted over most of <locus target="#4r" facs="006">fol. 4r</locus>)</note>
            </msItem>
            <msItem xml:id="ms_i5">
              <locus from="5r" to="6v">Fols 5r–6v</locus>
              <title>Fragment of Unknown Image (on Repentance and the Soul)</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
              <note>Illumination of Madonna and Child is painted over most of <locus target="#5v">fols. 5v, </locus>
                and an illumnination of Saint George and the Dragon is painted over most of <locus target="#6r" facs="007">6r</locus>)</note>
            </msItem>
          </msContents>

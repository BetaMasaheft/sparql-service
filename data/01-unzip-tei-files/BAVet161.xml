          <msContents>
            <summary/>
            
            <msItem xml:id="ms_i1">
              <locus from="1r" to="16r"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkəʾa Māryām</title>
              <textLang mainLang="gez"/>
              <explicit xml:lang="gez">
                በዝንቱ፡ ቃለ፡ ማኅሌት፡ ወበዝንቱ፡ ይባቤ፡
                ለዘይስእ<add place="above">ለ</add>ኪ፡ ብእሲ፡ ጊዜ፡ ረከቦ<choice><sic>ን</sic><corr/></choice>፡ ምንዳቤ፡
                ብጽሒ፡ ፍጡነ፡ <gap reason="ellipsis"/>  ስብሐት፡ ለኪ<supplied reason="omitted">፡</supplied> 
                ማርያም<supplied reason="omitted">፡</supplied> በኍልቈ፡ ኵሉ፡ ስእርትየ። <gap reason="ellipsis"/>
              </explicit>
              <explicit xml:lang="gez" type="supplication"><choice><sic>ጸ</sic><corr/></choice> ምስለ፡ ጸሐፊሁ፡ 
                <persName role="scribe" ref="https://betamasaheft.eu/PRS14053WaldaG">ወል<lb/>ደ፡ ጊዮርጊስ፡</persName> ለዓለመ፡ ዓለ<lb/>ም፡ አሜን፨</explicit>
              <note>Grébaut took the text quoted here to be an additional prayer, but both stanzas are part of the usual text.</note>
            </msItem>
            
            <msItem xml:id="ms_i2">
              <locus from="16v" to="30v"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
              <textLang mainLang="gez"/>
              <explicit xml:lang="gez">
                እምሥራቀ፡ ፀሐይ፡ እስከ፡ <choice><sic>ነ</sic><corr/></choice> ዓረብ፡ ይትአኰት፡ ስሙ፡ ለእግዚአብሔር፡ አምላክነ፡ <gap reason="ellipsis"/>
                ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ ስእርትየ፡
                ስ<add place="above">ብ</add>ሐት<supplied reason="omitted">፡</supplied> ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ አዕፅምትየ፡ <gap reason="ellipsis"/>
              </explicit>
              <note>Grébaut took the text quoted here to be an additional prayer, but both stanzas are part of the usual text.</note>
            </msItem>
            
            <msItem xml:id="ms_i3">
              <locus from="32r" to="45r"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title>
              <textLang mainLang="gez"/>
              <explicit xml:lang="gez">
                <note>Grébaut took the text quoted here to be an additional supplication, but the stanza is part of the usual text.</note>
                ኦሚካኤል፡ ኦሚካኤ<lb/>ል፡
                ኦመተንብል፡
                ካህነ፡ አር<lb/>ያም፡ ትሰመይ፡ ቢጸ፡ ሱራ<lb/>ፌል፡ ወኪሩቤል፡
                <choice><sic>ዘእምርኡስን፡</sic><corr>ዘእም<lb/>ርኡሳን፡</corr></choice> ርዑስ፡ ዘእም<lb/>ልዑላን፡ ልዑል፡
                <del>በ</del>ጊዜ፡<lb/> ጸዋዕኩከ፡ ቅረበኒ፡ በም<pb n="45r"/>ሕረት፡ ወሣህል፡
              </explicit>
              <explicit xml:lang="gez" type="supplication">ኦቅዱ<lb/>ስ፡ ሚካኤል<supplied reason="omitted">፡</supplied> ዕቀበኒ፡ ወአ<lb/>ድኅነኒ፡ እመከራ፡ ሥጋ፡<lb/> ወነፍስ፡ ለገብርከ፡</explicit>
            </msItem>
            
            <msItem xml:id="ms_i4">
              <locus from="45v" to="47r"/>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa Gabrǝʾel</title>
              <textLang mainLang="gez"/>
              <note>The text ends in the middle of the sixth stanza.</note>
              <explicit xml:lang="gez">ሰላም<supplied reason="omitted">፡</supplied> ለቀራንብቲከ፡ ዘኢፈቀደ፡ ንዋመ። ወለአእይ<supplied reason="omitted">ን</supplied>ቲከ፡ <gap reason="ellipsis"/></explicit>
            </msItem>
            
          </msContents>
          

                    <msPart xml:id="p1">
                        <msIdentifier/>
                        <msContents>
                            <summary/>
                            
                            
                            <msItem xml:id="p1_i1">
                                <locus from="4r"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SaturdaySunday">Lectionary for Sundays</title>
                                <textLang mainLang="gez"/>
                                <note>The following are the principal divisions.</note>
                                
                                <msItem xml:id="p1_i1.1">
                                    <locus from="4r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#Lent">Eve of the beginning of Lent</title>
                                    <incipit xml:lang="gez">
                                        <locus from="4r"/>
                                        በስመ፡ አብ፡ <gap reason="ellipsis" resp="PRS10171Wright"/>
                                        ዘይትነበብ፡ በመኃትወ፡ ድራረ፡ ጾም፡ በ፲ወ፪ሰዓት፡ ወውእቱ፡ ጾመ፡ ፵ዓቢይ። እስከ፡ ፍጻሜ፡ ፯አውራኅ።
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.2">
                                    <locus from="30r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#ChPentecost">Pentecost</title>
                                    <incipit xml:lang="gez">
                                        <locus from="30r"/>
                                        በቀዳሚት፡ ሰንበት፡ ዘበዓለ፡ ፶ቅድስት፡ እንተ፡ ይእቲ፡ እሑድ፡ ዘግብረ፡ ወሀብከኒ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.3">
                                    <locus from="47v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#Ascension">Thursday of the Ascension</title>
                                    <incipit xml:lang="gez">
                                        <locus from="47v"/>
                                        በሠርከ፡ ሐሙስ፡ በዓለ፡ ዕርገት።</incipit>
                               </msItem>
                                
                                <msItem xml:id="p1_i1.4">
                                    <locus from="54v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SGenbot">Third Sunday of Gǝnbot</title>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.5">
                                    <locus from="59v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SGenbot">Fourth Sunday of Gǝnbot</title>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.6">
                                    <locus from="63v"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SSane">Four Sundays of Sene</title>
                                    <note>The name of the month is spelled here <foreign xml:lang="gez">ሴኔ፡</foreign></note>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.7">
                                    <locus from="80r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SHamle">Four Sundays of Ḥamle</title>
                                </msItem>
                                
                                <msItem xml:id="p1_i1.8">
                                    <locus from="96r"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT1932Mashaf#SNahase">Four Sundays of Naḥase</title>
                                    <explicit xml:lang="gez">
                                        እኁድ፡ ራብዒት፡ እምነሐሴ፡ ትትነበብ፡ ዳግመ። ለእመ፡ ሀሎ፡ እኁድ፡ በጳጕሜን።
                                    </explicit>
                                </msItem>
                            </msItem>
                        </msContents>
                        

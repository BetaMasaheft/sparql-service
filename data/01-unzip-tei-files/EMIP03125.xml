                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Part of the collection of Haroutune Nazarian, who had microfilms made of his Ethiopian manuscripts and the microfilms sent to the Institute of Ethiopian Studies. They were digitized by EMIP workers in Addis Ababa in the first half of 2010
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#43r" facs="043">Fol. 43r</locus>
                    <desc>
                    The microfilming information board (image 43) indicates that the manuscript was microfilmed in 1982 and assigned the number 127
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <locus target="#21r" facs="021">Fol. 21r</locus>
                    <desc>
                    Scribal note: “The number of the sections of the chants: Arba’et chants is 33; Selest chants is 58; Aryam chants is 53; the total number of chants is 142.” The name of the scribe is given, <foreign xml:lang="gez">ሕፃንሞአ</foreign>
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="partly">
                    <decoNote xml:id="b1">Parchment. No images were taken of the external sides of the book but one can see evidence of wooden boards, both broken and stitched together with string.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>

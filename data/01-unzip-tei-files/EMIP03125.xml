               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="21r" facs="001">Fols 1r–21r</locus>
                    <title>Chants called Arba’ǝt, <foreign xml:lang="gez">አርባዕት</foreign>, of the Psalms, interspersed with Chants called Aryam, <foreign xml:lang="gez">አርያም፡</foreign> laid out in one column with both left and right justification, incomplete at the beginning; starting with <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps19">Psalms of
                                                  David, Psalmus 19</title></title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <notatedMusic><desc>with musical notation</desc></notatedMusic>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="21v" to="33r" facs="022">Fols 21v–33r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>in Aryam chants, arranged for the days of the week</note>
                  <msItem xml:id="ms_i2.1"><locus from="21v" facs="022">Fols 21v and following</locus><title>Monday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.2"><locus from="22v" facs="023">Fols 22v and following</locus><title>Tuesday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.3"><locus from="24v" facs="025">Fols 24v and following</locus><title>Wednesday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.4"><locus from="26v" facs="027">Fols 26v and following</locus><title>Thursday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.5"><locus from="29r" facs="029">Fols 29r and following</locus><title>Friday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.6"><locus from="30v" facs="031">Fols 30v and following</locus><title>Saturday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.7"><locus from="31v" facs="032">Fols 31v and following</locus><title>Sunday</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
              </msItem>
              <msItem xml:id="ms_i3"><locus from="33r" to="39r" facs="033">Fols 33r–39r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <notatedMusic><desc>with musical notation</desc></notatedMusic>
            </msItem>
              <msItem xml:id="ms_i4"><locus from="39v" facs="040"> f. 39v, top ten lines</locus><title>Chant for Dabra Tabor</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
              <msItem xml:id="ms_i5"><locus from="39v" facs="040"> f. 39v, bottom lines</locus><title>Chant for Saint Mika’el</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>

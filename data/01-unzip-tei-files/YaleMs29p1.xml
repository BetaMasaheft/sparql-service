                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#163v" facs="164">Fol. 163v</locus>
                           <desc> contains further information about the book. The two volumes of
                              the Synaxarium were purchased by <foreign xml:lang="gez">ገብረ
                                 ማርያም</foreign>, with his own money for two <foreign xml:lang="gez">ወቂት</foreign>. The record also mentions other books he bought.
                              Thereafter, the record (continuing on <locus target="#165r">fol. 165r</locus>)
                              mentions a list of purchased books owned by the church, 20 books in
                              all, as well other church utensils and priestly garments, crosses.
                              Another record lists books given by other people with a curse on
                              anyone who steals or erases. A final record, written in a different
                              hand, lists more books and materials given to the church </desc>
                        </item>
                        <item xml:id="e1">
                           <locus target="#164v" facs="165">Fol. 164v</locus>
                           <desc> contains the name plate of Yale University Library, the Edwin J.
                              Beinecke Fund </desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>

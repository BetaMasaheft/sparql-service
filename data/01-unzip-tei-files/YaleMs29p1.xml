               <msContents>
                  <summary>Synaxarium, መጽሐፈ፡ ስንክሳር፡, Part 1</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="163v" facs="001">Fols 1r–163v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2375Synaxa">first part, beginning in the month
                        of Mäskäräm. The opening incipit mentioning the ones who ordered the book:
                        Abba Mika’el, whose country is <foreign xml:lang="gez">አትሪብ</foreign> (in
                        Egypt?), Abba Yohannes, whose country is <foreign xml:lang="gez">ቡርልስ</foreign></title>
                     <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="27v" facs="001">Fols 1r–27v</locus>
                        <title>For Mäskäräm</title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="28r" to="51r" facs="028">Fols 28r–51r</locus>
                        <title>For Ṭǝqǝmt</title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="51r" to="77r" facs="051">Fols 51r–77r</locus>
                        <title>For Ḫǝdar. <locus target="#77r">Fol. 77r</locus> contains one of the prayers that is
                           used in the church after the reading of a section of the
                           Synaxarium</title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="77v" to="108r" facs="078">Fols 77v–108r</locus>
                        <title>For Taḫśaś</title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="108r" to="140v" facs="108">Fols 108r–140v</locus>
                        <title>For Ṭǝrr. <locus target="#140v">Fol. 140v</locus> contains prayers for one, <foreign xml:lang="gez">ገብረ ማርያም</foreign></title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="141r" to="163v" facs="141">Fols 141r–163v</locus>
                        <title>For Yäkkatit</title>
                        <textLang mainLang="gez">Gǝ'ǝz</textLang>
                     </msItem>
                  </msItem>
               </msContents>

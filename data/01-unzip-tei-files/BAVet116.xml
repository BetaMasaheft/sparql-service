                        <msItem xml:id="ms_i1.1">
                          <locus from="5r" to="20r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1960Mashaf#Daily">Maṣḥafa qǝddāse, Daily Office Prayers and Litanies</title>

                          <msItem xml:id="ms_i1.1.1">
                            <locus from="5r" to="10v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">
                              Prayers of the morning office
                              <foreign xml:lang="gez">ኪዳን፡ ዘነግህ፡</foreign>
                            </title>
                            <incipit xml:lang="gez">
                              ይበል፡ ካህን፡ ዘእመጽሐፈ፡ ኪዳን፡
                            </incipit>
                          </msItem>

                          <msItem xml:id="ms_i1.1.2">
                            <locus from="10v" to="11v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1808Litonz">
                              Prayers for the evening
                              <foreign xml:lang="gez">ሊጦን፡ ዘሠርክ፡</foreign>
                            </title>
                            <explicit xml:lang="gez">
                              እስመ፡ <sic>ኂር፡</sic> ወመፍቀሬ፡ ሰብእ፡ አንተ፡ አምላክነ፡ በ፩ወልድከ፡ ዘቦቱ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                            </explicit>
                          </msItem>

                          <msItem xml:id="ms_i1.1.3">
                            <locus from="11v" to="16r"/>
                            <title>
                              Prayers of supplication,
                              <foreign xml:lang="gez">መስተብቍዕ፡</foreign>
                            </title>
                            <explicit xml:lang="gez">
                              በአተነ፡ ወጸአተነ፡ በሰላም፡ ዕቀብ፡ ከመ፡ በኅዱዕ፡ ወበጽምው፡ ሕይወተነ፡ እንዘ፡ <sic>ናሀዩ፡</sic> በኵሉ፡ አምላኮ፡ ሠናይ፡ በፈሪሃ፡ እግዚአብሔር፡ ወበኂሩት፡ ንትረከብ፡ በክርስቶስ፡ ዘቦቱ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                            </explicit>
                            <note>
                              The supplications for those offering an oblation and for the deceased are omitted.
                            </note>
                          </msItem>

                          <msItem xml:id="ms_i1.1.4">

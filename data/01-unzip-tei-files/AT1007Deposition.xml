        <t:profileDesc xmlns:t="http://www.tei-c.org/ns/1.0">
            <t:creation/>
            <t:abstract>
                <t:p> A miniature showing the moment in which <t:persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</t:persName> is taken down from the Cross,
                  typically featuring Joseph and Nicodemus bearing His body
                  (<t:ref cRef="urn:cts:greekLit:tlg0031.tlg001.perseus-grc1:27.59">Matthew 27, 59</t:ref>;
                  <t:ref cRef="urn:cts:greekLit:tlg0031.tlg002.perseus-grc1:15.46"> Mark 15, 46</t:ref>;
                  <t:ref cRef="urn:cts:greekLit:tlg0031.tlg003.perseus-grc1:23.53">Luke 23, 53</t:ref>;
                  <t:ref cRef="urn:cts:greekLit:tlg0031.tlg004.perseus-grc1:19.38">John 19, 38</t:ref>),
                  and several Holy Women
                  mourning, such as Salome and the Virgin Mary,
                    (<t:ref cRef="urn:cts:greekLit:tlg0031.tlg001.perseus-grc1:27.61">Matthew 27, 61</t:ref>;
                    <t:ref cRef="urn:cts:greekLit:tlg0031.tlg002.perseus-grc1:15.47"> Mark 15, 47</t:ref>;
                    <t:ref cRef="urn:cts:greekLit:tlg0031.tlg003.perseus-grc1:23.55">Luke 23, 55</t:ref>).
                </t:p>
            </t:abstract>

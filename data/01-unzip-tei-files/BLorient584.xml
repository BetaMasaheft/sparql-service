                        <msItem xml:id="ms_i1">
                            <locus from="1ra" to="130vc"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                            <textLang mainLang="gez"/>
                            <notatedMusic>
                                <desc>With musical notes.</desc>
                            </notatedMusic>
                            <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ ዘይትወሐድ፡ ዘኢይትፈለጥ፡ ወዘኢይትበአድ፡
                                ጸሐፍነ፡ እንከ፡ ማኅሌተ፡ ያሬድ፡ ዘይደምጽ፡ ከመ፡ ነጐድጓድ፡ ወጣእመ፡ ዜማሁ፡ ፍድፋድ፡ ወኃይለ፡ ቃሉ፡
                                ንዑድ፡ አስራበ፡ ስብሐት፡ ዘተቀድሐ፡ እምባሕረ፡ መጻሕፍት፡ እሉድ፡ ሰርጐ፡ ኢትዮጵያ፡ መስተዛውአ፡
                                ካህናት፡ መንፈሳዊት፡ ማኅፈድ፡ መስተፍሥሔ፡ አልባቢሁሙ፡ ለሕዝብ፡ ክቡድ፡ እለ፡ ዘይገይሡ፡ ኀበ፡
                                ዘመለኮት፡ ዓፀድ፡ ክቡራነ፡ ዘመድ፡ እለ፡ ሐጸኖሙ፡ አሐዱ፡ ጕንድ። ዘውእቱ፡ ጸዋትው፡ ወማኅልይ፡
                                ዋዜማ፡ ወመዋሥዕት፡ ዘእግዚአብሔር፡ ምድር፡ በምልዓ፡ ወእግዚአብሔር፡ ነግሠ፡ ወዘይትባረክ፡ አርያም፡
                                ወመዝሙር፡ ዘአምላኪየ፡ ወአርባዕት፡ ዕዝል፡ ወዘይእዜ፡ ማኅሌት፡ ወዘይባርክዎ፡ ስብሐተ፡ ነግሕ፡ ሠለስት፡
                                ወሰላም፡ ዘወትር፡ ወዘበዓል፡ እሉ፡ እንከ፡ ማኅልዳ፡ ቅማሐ፡ ሐዲስ፡ ወብሉይ፡ ውዳስያተ፡ አምላክ፡ ምስለ፡
                                ግናይ። ዘመጸው፡ ወዘጸደይ፡ ዘክረምት፡ ወዘሐጋይ፡ ዘይፌጽም፡ ጥንቁቀ፡ ዓለም፡ ዘለለ፡ አውራኁ፡
                                ወዘለለ፡ ዕለቱ፡ ዘለለ፡ ሰንበቱ፡ ወዘለለ፡ በዓላቱ፡ ዘተሠርዓ፡ በምድር፡ በሥምረቱ፡ በእንተዝ፡ ያበጽሐነ፡
                                ለለዓመቱ፡ በኂሩቱ። እምአመ፡ ነግሠ፡ ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName> በኃምስቱ፡ ዓመት፡ ወሰኑዩ፡ ወርኅ፡ በዘመነ፡
                                ሉቃስ፡ ወንጌላዊ፡ እምሰኑዩ፡ ለጳግሜ፡ ተወጥነ፡ ዝመዝገብ፡ ወድጓ፡ ወሥምረተ፡ እግዚአብሔር፡ ከመ፡
                                ይኵኖ፡ ለመድኃኒተ፡ ነፍሱ፡ ወጣጋሁ፡ ለኃጥእ፡ ወለምስኪን፡ <add place="overstrike">ዝመጽሐፍ፡ 
                                <persName ref="https://betamasaheft.eu/PRS13812ZamanfasQ">ዘመንፈስ፡ ቅዱስ።</persName></add> </incipit>

                            <msItem xml:id="ms_i1.1">
                                <locus from="1ra" to="120vc"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#part1">Dǝggʷā: Part 1, from the feast of St John the Baptist to the feast of Simon, 8 Yakkātit</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ምልጣን፡ ዘሰርክ፡ ዘዮሐንስ፡ በ፩ብፁዕ፡ አንተ፡
                                    ዮሐንሰ፡ ዘሀለወከ፡ ታእምር፡ ወተሐውር፡ ቅድመ፡ እግዚአበሐር፡</incipit>
                                <note>Musical notation provided by the catalogue could not be
                                    transcribed here. Please refer to the catalogue or manuscript images.</note>
                                <note>The text begins with <ref type="work" corresp="https://betamasaheft.eu/LIT4350JohnTheBaptist">Wāzemā za-qǝddus Yoḥannǝs</ref>, 
                                    and ends with <ref type="work" corresp="https://betamasaheft.eu/LIT4380Epiphany">Wāzemā za-ʾastarʾǝyo</ref> and <ref type="work" corresp="https://betamasaheft.eu/LIT4381Simeon2">Hymn to Simeon</ref>.</note>
                            </msItem>

                            <msItem xml:id="ms_i1.2">
                                <locus from="121ra" to="121vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Haleta">Dǝggʷā: Table of melodic variations for the Hallelujah (same as https://betamasaheft.eu/LIT1110Anqasa)</title>
                                <textLang mainLang="gez"/>
                            </msItem>

                            <msItem xml:id="ms_i1.3">
                                <locus from="122ra" to="154rc"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Lent">Dǝggʷā: Lent (same as LIT2361somade)</title>
                                <textLang mainLang="gez"/>
                            </msItem>

                            <msItem xml:id="ms_i1.4">
                                <locus from="155ra" to="130vc"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#part2">Dǝggʷā: Part 2, from Easter to the end of the liturgical year</title>
                                <textLang mainLang="gez"/>
                                <note>The first hymn is <ref type="work" corresp="https://betamasaheft.eu/LIT4387EasterSunday">Hymn for Easter Sunday</ref>, the last 
                                   on a hymn on the appearance of God to Abraham.</note>
                            </msItem>

                        </msItem>


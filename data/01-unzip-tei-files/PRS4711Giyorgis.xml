               <nationality type="Egypt"/>
               <faith type="Coptic"/>
               <birth when="1206">He was born in <date>1206</date> at <placeName ref="https://www.wikidata.org/entity/Q85">Cairo</placeName>.</birth>
               <floruit notBefore="1206" notAfter="1293">He was a Christian Arab historian whose work was translated and incorporated into 
                  Ethiopian tradition. 
                  He wrote his <ref type="work" corresp="https://betamasaheft.eu/LIT4723TarikaWaldaAmid">Tārīḫ</ref> in 
                  <date notBefore="1262" notAfter="1277"> between 1262-1277</date>,

                  <persName ref="https://betamasaheft.eu/PRS10626ZaraY"><roleName type="title">ʾaṣe</roleName> Zarʾa Yāʿqob</persName> and 
                  <persName ref="https://betamasaheft.eu/PRS6229LebnaDe"><roleName type="title">ʾaṣe</roleName>  Lǝbna Dǝngǝl</persName>
                  as <foreign xml:lang="gez">ታሪከ፡ ወልደ፡ አሚድ</foreign>. 
              </floruit>
               <death notBefore="1273" notAfter="1293">He died either in 1273 or in 1293 CE.</death>

                  <msItem xml:id="ms_i9">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="203ra" to="241va">Fols 203ra–241va</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5901DersanaGabrielNaglon">Dǝrsāna Gabrǝʾel</title>

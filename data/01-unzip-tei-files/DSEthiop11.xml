                  <msItem xml:id="ms_i10">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="242ra" to="256ra">Fols 242ra–256ra</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4959HomilyChildren">Dǝrsāna ḥǝḍānāt</title>

                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez" type="inscriptio">
                           <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ ድ</hi>ርሳነ፡ ሕፃናት፡ ዘጸሐፎ፡ ብፁዕ፡
                        ወቅ<hi rend="rubric">ዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ በእንተ፡ ሰ</hi>ብአ፡ ሰገል፨
                        ዘመጽኡ፡ እምሥራቅ፡ ከመ፡ ይስግዱ፡ ለ<hi rend="rubric">ክርስቶስ፡ ወበእንተ፡ ሕፃናት፡ ዘቀተሎ</hi>ሙ፡
                        ሄሮድስ፡ በእንተ፡ እግዚእነ፡ <hi rend="rubric">ኢየሱስ፡ ክርስቶስ፡</hi> አመ፡ <date ref="ethiocal:Terr3">፫ለወርኃ ጥር፡</date> ወኍልቆሙ፡ ፲ወ፬፻፻ ወ፵፻፡
                     </incipit>
                     <incipit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="242ra" to="242rb">Fols 242ra–242rb</t:locus>
                        በረከተ፡ ጸሎቶሙ፡ ወአሰ<cb n="b"/>ተብቍዖቶሙ፡ የሃሉ፡ ምስለ፡ ጸሐፊ፡ ዝንቱ፡ ዜናሆሙ፡ <hi rend="rubric">ገብረ፡ እግዚአብሔር፡</hi>
                        <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ ማርያም፡</hi>
                        </persName> ወምስለ፡
                        ኵሎሙ፡ <sic resp="DN">ወሉደ</sic>፡ ጥምቀት፡ ለዓለመ፡ ዓለም፡ አሜን፡
                     </incipit>

                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#242rb">Fol. 242rb</t:locus>
                        <hi rend="rubric">ይቤ፡ ንዑ፡ ይእዜ፡ ኀበ፡ ዝንቱ፡ ገድል፡ ዘኮነ፡ በዛቲ፡</hi> ዕለት፡ ወናርኅቅ፡ እምኔነ፡ እከዮ፡ ለሄሮድስ፡ መናፍቅ፡ ዘአዘዘ፡ በቀቲለ፡ ሕፃናት፡ ዘእንበለ፡ ዘ<hi rend="rubric">መን፡ ዘኮኑ፡ ሰማዕተ። አመ፡ ቀዳሚ፡</hi> መዋዕሊሆሙ፡ በእንተ፡ እግዚእነ፡
                     </incipit>

                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="255vb" to="256ra">Fols 255vb–256ra</t:locus>
                        ወያጽንዑነ፡ በርትዕት፡ ሃይማኖት፡ አርቶዶክሳዊት፤ ወይረሰዩ፡ ኃዋኅወ፡ ቤተ፡ ክርስቲያን፡ ቅድስት፤ ርኅወ፡ ለነ፡ በኵሉ፡ መዋዕል፡ ወአዝማናት፤ እስከነ፡ እስትንፋስ፡ ደኃሪት፨ ወያዕርፉ፡ ነፍሳተ፡ ምውታኒነ፡ ውስተ፡ መንግሥተ፡ ሰማያት፨ በጸሎታ፡ ለእግዝእትነ፡
                        <hi rend="rubric">ማርያም፡</hi> ወላዲተ፡ ሕይወት፨ ወበሰብከቶሙ፡ ለአጋዕዝቲነ፡ ሐዋርያት፡ ወበጸሎተ፡ ኵሎሙ፡ ቅዱሳን፡ ወሰማዕት፨ ወበጸሎተ፡ ትጉሃን፡ መላእክት፨ ወስብሐት፡ <hi rend="rubric">ለሥሉስ፡ ቅዱስ፡</hi>
                     </explicit>

                     <explicit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#256ra">Fol. 256ra</t:locus>
                        ኦአምላከ፡ ቅዱሳን፡ ሕፃናት። ስረይ፡ ኃጢአቶ፡ ለጸሐፊሁ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">ወልደ፡ <hi rend="rubric">ማርያም።</hi>
                        </persName>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i11">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="256ra" to="276ra">Fols 256ra–276ra</t:locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6265ZenaPauli">Zenāhu la-ʾabbā Ṗāwli za-taśamya Bulā</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="256ra" to="256rb">Fols 256ra–256rb</t:locus>
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፩</hi> አምላክ፡ ንቀድም፡ በረድኤተ፡ <hi rend="rubric">እግዚአብሔር፡ ልዑል፡ ወበሠናይ፡ ሀብቱ፡ በጽሒፈ፡</hi> ዜናሁ፡ ለብፁዕ፡ ወለቅዱስ፡ ዘዓቢይ፤
                        <pb n="256rb"/><hi rend="rubric">ወልዑል፡ እምቅዱሳን፡ ወቀዳሚሆሙ፡</hi>
                        ለመናንያን፡ ወባሕታውያን፨ <hi rend="rubric">አባ፡ ጳውሊ፡ ዘተሠምየ፡ ቡላ፡ ርእሰ፡ ባሕታ</hi>ውያን፡ ዘእስክንድርያ፨ ዘመነነ፡ እምድኅሬሆሙ፡
                        ለእሙንቱ፡ ብፁዓን፡ ኤ<hi rend="rubric">ልያስ፡ ነቢየ፡ እግዚአብሔር፡ ወዮሐንስ፡</hi> መጥምቀ፡ <hi rend="rubric">መለኮት፡</hi> ጸሎቱ፡ ትዕቀቦ፡
                        ለገብረ፡ <hi rend="rubric">እግዚአብሔር፡ ወልደ፡ ማርያም፡ ወለ</hi>ኵልነ፡ ሕዝበ፡ ክርስቲያን፡ ለዓለመ፡ ዓለም፡ አሜን፨
                     </incipit>

                     <incipit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#256rb">Fol. 256rb</t:locus>
                        ጸሎቱ፡ ትዕቀቦ፡ ለገብረ፡ <hi rend="rubric">እ<hi rend="ligature">ግዚ</hi>አብሔር፡</hi>
                        <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ ማርያም፡</hi>
                        </persName>
                        <hi rend="rubric">ወለ</hi>ኵልነ፡ ሕዝበ፡ ክርስቲያን፡ ለዓለመ፡ ዓለም፡ አሜን፨
                     </incipit>
                     <explicit xml:lang="gez">

                     </explicit>

                     <colophon xml:id="coloph1">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#276ra">Fol. 276ra</t:locus>
                       <foreign xml:lang="gez">ተፈጸመት፡ ዛቲ፡ መጽሐፍ፡ አመ<date calendar="ethiopian" when-custom="1912-07-11" when="1920-03-20">፲ወ፩፡ ለመጋቢት፡ በ፲ወ፱፻ወ፲ወ፪ቱ፡ ዓመተ፡ ምሕረት፡ በዘመነ፡ <hi rend="rubric">ዮሐንስ፡
                        ወንጌላዊ</hi></date>፨ በመዋዕሊሁ፡ ለጳጳስነ፡ <hi rend="rubric">ቅዱስ፡ አባ፡ ቄርሎስ</hi>፨ በብሔረ፡ <sic resp="DN">መሰር</sic>፨</foreign>
                        <t:note xmlns:t="http://www.tei-c.org/ns/1.0" xml:lang="en">The colophon contains the date 1 Maggābit 1912 <hi rendition="simple:smallcaps">EC</hi>,
                           the year of John (= 20 March 1920 <hi rendition="simple:smallcaps">CE</hi>).
                         Therefore, the words <foreign xml:lang="gez">ጳጳስነ፡ ቅዱስ፡ አባ፡ ቄርሎስ</foreign>, <foreign xml:lang="en">‘our saint bishop
                            <t:roleName type="title"><hi rendition="simple:italic">ʾAbbā</hi></t:roleName> Cyril’</foreign> must refer to the Coptic patriarch <persName ref="https://betamasaheft.eu/PRS3259CyrilV">Cyril V</persName> (in tenure 1874-1927),
                          and not to the Ethiopian metropolitan <persName ref="https://betamasaheft.eu/PRS8033Qerellos">Qerǝllos VI</persName>
                           (in tenure 1929–1950).
                      </t:note>
                     </colophon>
                  </msItem>


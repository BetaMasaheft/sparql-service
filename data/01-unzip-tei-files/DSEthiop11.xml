                  <summary/>

                  <msItem xml:id="ms_i1">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="1ra" to="57vb">Fols 1ra–57vb</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1941Mashaf">Maṣḥafa lǝdatā la-Māryām</title>
                    <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ መንፈስ፡ ቅዱስ፡ ፩አምላ</hi>ክ፡ ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ልዑል፡ ወበሠናይ፡ ሀብተ፡
                        ጽሒ<hi rend="rubric">ፈ፡ ድርሳነ፡ ልደታ፡ ለእግዝእተ፡ ኵልነ፡ ቅድስት፡ ወንጽሕት፡ ወድንግል፡ በ፪ኤ፡ ማርያም፡</hi> አመ፡ ፩ለግንቦት፡ ዘሠርዓ፡ አብ፡
                        ቅዱስ፨ ወትሩፈ፡ ምግባር፡ ዘ<hi rend="rubric">ያበርህ፡ ለኵሉ፡ በጸጋ፡ መንፈስ፡ ቅዱስ፡ ወክቡር፡ በ</hi>ኀበ፡ እግዚአብሔር፡ ወሰብእ፡ አቡነ፡ ቅዱስ፡ ወክቡር፡
                        <hi rend="rubric">ያዕቆብ፡ ሐዋርያ፡ ኤጲስ፡ ቆጶስ፡ ዘኢየሩሳሌም፡ ዘበጸጋ፡ እግዚአብሔር፡</hi> ተጸውዓ፡ እኁሁ፡ ለእግዚእነ፨ ወውእቱ፤
                        ይነግር፡ ቦቱ፤ ዘከመ፡ ልደታ፤ <add place="above">ኮነ፡</add> ለእግዝእተ፤ ኵልነ፡ ቅ<hi rend="rubric">ድስት፡ ወንጽሕት፡ ማርያም፡
                        ወላዴ</hi>ተ፡ አምላክ፤ አመ፡ ፩ለግንቦን<add place="above">ት</add>፡ በሰላመ፤ እግዚአብሔር፤
                     </incipit>
                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="57va" to="57vb">Fols 57va–57vb</t:locus>
                        አሥረቀ፡ ቦቱ፤ ጸጋ፤ <hi rend="rubric">መንፈስ፡ ቅዱስ፡ ዘመለኮቱ፡</hi> ፍጽም፡ ወአብጽሐ፡ ኀበ፡ ማዕርጋት፡ ሉዓላውያት፡ ምስለ፡ ኵሎሙ <hi rend="rubric">ቅዱሳን</hi>፨ ወለ<hi rend="rubric">እግዚእነ፡</hi>
                        ዘሥሉጥ፡ ለመድኃኒትነ፡ ይደሉ፡ <hi rend="rubric">ስብሐት፡ ወክብር፡ ወዕዘዝ፡ ወልዕልና፡ ወክሂል፡</hi> ወሰጊድ፡ ምስለ፡ አቡሁ፡ ኄር፡ ሰማያዊ፡
                        ወምስለ፡ <hi rend="rubric">መንፈስ፡ ቅዱስ፡ ማሕዊ፡</hi> ዘዕሩይ፡ ምስለሁ፡ ይእዚኒ፡ ወዘልፈኒ፡ ለዓለም፡ ወለዓለመ፡ ዓለም፡ አሜን፨ ፨
                     </explicit>
                     <explicit xml:lang="gez" type="subscriptio">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#57vb">Fol. 57vb</t:locus>
                        ተፈጸመ፡ ድርሳነ፡ ልደታ፡ ለእግዝእትነ፡ <hi rend="rubric">ማርያም፡</hi> በሰላመ፡ <hi rend="rubric">እግዚአብሔር፡</hi> አሜን፤ ወአሜን፤
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="58ra" to="85vb">Fols 58ra–85vb</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#58ra">Fol. 58ra</t:locus>
                        <hi rend="rubric">ጽጌ፡ አስተርዓየ፡ ሠሪፆ፡ እምዓፅሙ፨ ለ</hi>ዘአምኃኪ፡ ጽጌ፡ ለ<hi rend="rubric">ገ</hi>ብ<hi rend="rubric">ር</hi>ኤ<hi rend="rubric">ል፡</hi> ምስለ፡
                        ሰላ<hi rend="rubric">ሙ</hi>፨ <hi rend="rubric">ወበእንተዝ፡ ማርያም፡ ሶበ፡ ሐወዘኒ፡ መዓዛ፡ ጣዕሙ</hi>፤ ለተአምርኪ፡ እሐሊ፡ እሙ፨ ማኅሌተ፡ <hi rend="rubric">ጽጌ፡</hi> ዘይሠመይ፡ ስሙ፨
                        ጽጌ፡ አስተርአየ፡ ሠሪፆ፡ በደመና፡ ተፀውረ፡ በማኅፀና፨ <hi rend="rubric">ማርያም፡ ድ<add place="above">ን</add>ግል፡ ማርያም፡ ዓ</hi>ፈ፡ ብርሃና፨
                     </incipit>
                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#85vb">Fol. 85vb</t:locus>
                        <hi rend="rubric">ስብሐት፡ ለኪ፡ ማርያም፡</hi> በጽጌ፡ ሐዋርያት፡ ፍንዋን፨ <hi rend="rubric">ስብሐት፡ ለኪ፡ ማርያም፡</hi> በጽጌ፡ ሰማዕት፡ ወጻድቃን፨
                        ወ<hi rend="rubric">ስብሐት፡</hi> ይዴሉ፡ ለማኅኬተ፡ ጽጌኪ፡ ወይን፨ እስመ፡ በተአምርኪ፡ ወይን፡ ይትፌሣሕ፡ ኅዚን፨ ፨ ፨
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="86ra" to="103vb">Fols 86ra–103vb</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara
                    Bǝhnǝsā</title>

                     <incipit xml:lang="gez" type="supplication">
                        <hi rend="rubric">አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ማርያም፡</hi> ዘደረሰ፡ ላቲ፡ <hi rend="rubric">በመንፈስ፡ ቅዱስ፨</hi> አባ፡ <hi rend="rubric">ሕርያቆስ፡
                        ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ብህንሳ፡</hi>ጸሎታ፡ ወበረከታ፡ የሃሉ፡ ምስለ፡ ገብራ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ መርያም፡</hi>
                        </persName> ለዓለመ፡ ዓለም፡ አሜን፨
                     </incipit>

                     <incipit xml:lang="gez">
                        <hi rend="rubric">ጐሥዓ፡ ልብየ፡ ቃለ፡ <add place="above">ሠናየ፡</add> ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፨ ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፤</hi> ወአነ፡ አየድዕ፡ ቅዳሴሃ፡ ለ<hi rend="rubric">ማርያም፡</hi>
                     </incipit>

                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="103ra" to="103va">Fols 103ra–103va</t:locus>
                        ወረከብኩ፡ በውስቴታ፡ ዘይብል፡ ዘንተ፡ ቅዳሴ፡ ዘይቄድስ፡ ካህን፡ አኮ፡ <hi rend="rubric">ማርያም</hi>ሃ፡ ዘይቄድስ፡ እላ፡ ውእቱ፡ ይትቄድስ፨ ወእለሂ፡ ሰምዕዋ፡ ይትቄደሱ፡ <hi rend="rubric">ማርያም</hi>ሰ፡ እግዝእትነ፡ ቅድስት፡ ይእቲ፡ ወትረ፡ በሰማይ፡ ወበምድር፨ በረከተ፡ ጸሎታ፡ ትሩፍ፡
                        የሃሉ፡ ምስለ፡ ገብራ፡ ኃጥእ፡ ወአባሲ፡ ጸሐፌሁ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ መርያም፡</hi>
                        </persName> ለዓለመ፡ ዓለም፡ አሜን፡ ለይኩን፡ ለይኩን፨
                     </explicit>

                     <explicit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#103vb">Fol. 103vb</t:locus>
                        ኦእግዝእትኤ፡ <hi rend="rubric">ማርያም፡</hi> እቀብኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ሊተ፡ ለኃጥእ፡ ገብርኪ፡ ወአባሲ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ መርያም፡</hi>
                        </persName>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="104ra" to="123vb">Fols 104ra–123vb</t:locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</title>
                     <textLang mainLang="gez"/>

                     <msItem xml:id="ms_i4.1">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="104ra" to="110va">Fols 104ra–110va</t:locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1968Mashaf">Maṣḥafa śǝrʿāt za-waṣʾa ʾǝm-manbara Mārqos ḥawāryā
                    ʾǝm-makāna maʿāllǝqā</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                           <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#104ra">Fol. 104ra</t:locus>
                          <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምልላክ፡</hi> ዝንቱ፡ መጽሐፈ፡ ሥርዓት፡ ዘወጽአ፡ መንበረ፡ ማርቆስ፡ ሐዋርያ፨ እመካነ፡ መዓልቃ፡ ዘምስር፡ ዘአንበሩ፡ መምሕራን፡ ሊቃነ፨ ጳጳሳት፡ ክቡራን፡
                           መጋብያነ፡ ምሥጢር፡ <hi rend="rubric">ርቱዓነ፡
                           ሃይማኖት፡ ዘትትናገሮሙ፡ ዘልፈ፡ እግዝእትነ፡ ማርያም፡ ወቦ፡ እ</hi>መ፡ ትትናገሮሙ፡ በሕልም፨
                        </incipit>
                        <explicit xml:lang="gez">
                           <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#110va">Fol. 110va</t:locus>
                           ይመጽእ፡ ወልዳ፡ በስብሐቲሁ፡ አሜን፨
                        </explicit>
                     </msItem>

                     <msItem xml:id="ms_i4.2">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="110va" to="114rb">Fols 110va–114rb</t:locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3058RepCh338">ʾƎsaggǝd laki ʾǝsaggǝd laki ʾǝsaggǝd laki
                    wa-ʾǝweddǝsaki</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <hi rend="rubric">እሰግድ፡ ለኪ፡ እሰግድ፡ ለኪ፡ ወእዌድሰኪ፡</hi> ኦእግዝእትየ። <hi rend="rubric">ማርያም፡ ድንግል፡ ወላዲተ፡ አም</hi>ላክ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="114ra" to="114rb">Fols 114ra–114rb</t:locus>
                           ወቅድመ ሥዕለ፡ ሰግዱ፡ ወዘኢይሰግዱ፡ ላቲ፡ ይደምሰስ፡ እምቅዋሙ፡ ወኢይተዓወቅ፡ ዝክረ፡ ስሙ፡ አሜን፡ ይበሉ፡ መላእክተ፡ ሰማይ፡ ኵሎሙ፡ ለዓለም፡ ዓለም፡ አሜን፨
                        </explicit>
                     </msItem>

                     <msItem xml:id="ms_i4.3">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="114rb" to="123vb">Fols 114rb–123vb</t:locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3993Miracle">Miracle of Mary (general record for a single
                    unidentified miracle)</title>

                        <incipit xml:lang="gez" type="inscriptio">
                           <hi rend="rubric">ተአምሪሃ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ</hi>፪ኤ፡ <hi rend="rubric">ማርያም፡ ወላ</hi>ዲተ፡ አምላክ፨
                        </incipit>
                        <incipit xml:lang="gez" type="supplication">
                           ጸሎታ፡ ወበረከታ፡ ወምሕረተ፡ ፍቁር፡ ወልዳ፨ የሃሉ፡ ምስለ፡ ኵልነ፡ ውሉደ፡ ጥምቀት፡ ለዓለመ ዓለም፡ አሜን፨
                        </incipit>
                        <incipit xml:lang="gez">
                           ወሀሎ፡ ፩ብእሲ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           <hi rend="rubric">ድንግል፡ ድንግል፡ ወላዲተ፡ አምላክ፡</hi> ቃል፨ ይኵነነ፡ ቤዛ፡ ማየ፡ አንብዕኪ፡ እሞኃጕል፨
                        </explicit>
                        <explicit xml:lang="gez" type="supplication">
                           <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#123vb">Fol. 123vb</t:locus>
                           ኦእግዝእትየ፡ ማርያም፡ እቀብኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ወባልህኒ፡ እምኵሉ፡ መንሱት፡ ለኃጥእ፡ ገብርኪ፡ ወምስኪን፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                              <hi rend="rubric">ወልደ፡ መርያም፡</hi>
                           </persName> ወምስለ፡ ኵልነ፡ አግብርትኪ፡ ወአእማትኪ፡ ለዓለመ፡
                           ዓለም፡ አሜን፡ ወአሜን፡ ለይኩን፡ ለይኩን፨
                        </explicit>
                        <t:note xmlns:t="http://www.tei-c.org/ns/1.0">Several miracles of St Mary possibly followed by one or more minor texts.</t:note>
                     </msItem>
                  </msItem>

                  <msItem xml:id="ms_i5">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="124ra" to="143rb">Fols 124ra–143rb</t:locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1651Homily">Homily on the Four Living Creatures (general
                    record)</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡</hi> ዝንቱ፡ ድርሳን፡ ዘ፬እንስሳ፡
                        <hi rend="rubric">መንፈሳውያን፡ ወብርሃናውያን፡ እለ፡ እንበለ፡</hi> ሥጋ፡ ዘሠርዖ፡ ወጸሐፎ፡ ብፁዕ፡
                        ወ<hi rend="rubric">ቅዱስ፡ ወንጹሕ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡</hi> በእንተ፡ ዕበየ፡ ክብሮሙ፡
                        ለእሙንቱ <hi rend="rubric">መንፈሳውያን፡ ወ</hi>ተዝካሮሙ፡ ዘውእቱ፡ አመ፡ ፰ለኅ<hi rend="rubric">ዳር፡</hi>
                     </incipit>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በረከቶሙ፡ ትዕቀበ፡ ለጸሐፊሁ፡</hi> ኃጥእ፡ ወጊጉይ፡ ገብረ፡ ዚአሆሙ፡ <hi rend="rubric">
                           <persName role="scribe" ref="https://betamasaheft.eu/PRS11958WaldaM">ወልደ፡ ማርያም፡</persName> ወምስለ፡ ኵሎሙ፡ ጻድቃ፡ ለቤተ፡ ክርስቲያን፡</hi> ለዓለመ፡ ዓለም፡ አሜን፨
                     </incipit>
                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="142vb" to="143ra">Fols 142vb–143ra</t:locus>
                        በጸሎታ፡ ወበአስተብቍዖታ፡ ለእግዝእትነ፡ ቅድስት፡ ወንጽሕት፡ <hi rend="rubric">ወድንግል፡</hi> በ፪ኤ፡ <hi rend="rubric">ማርያም፡</hi> ንግሥተ፡ ዓለማት፡ ፪ቱ፡ ወበትንብልናሆሙ፡ ለእሙንቱ፡
                        <hi rend="rubric">መንፈሳውያን፡ ፬እንስሳ።</hi> እለ፡ እንበለ፡ ሥጋ፡ ወኵሎሙ፡ ሠራዊተ፡ መላእክት፡ ሰማያውያን፨
                        ወኵሎሙ፡ አበው፡ ነቢያት፡ ወሐዋርያት፡ አጋዕዝቲነ፨ ወሰማዕታት፡ መዋዕያን፡ ወኵሎ፡ ሙ፡ <hi rend="rubric">ቅዱሳን፡</hi> ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፨
                     </explicit>
                     <explicit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#143rb">Fol. 143rb</t:locus>
                        ተፈጸመ፡ ድርሳነ፡ <hi rend="rubric">፬እንስሳ፡</hi> እለ፡ እንበለ፡ ሥጋ፡ <hi rend="rubric">መንፈሳውያን፡</hi> በረከተ፡ እለ፡ ብርሃናውያን፡ ወትንብልናሆሙ፡ ይዕቀቦ፡
                        ለገብረ፡ <hi rend="rubric">እግዚአብሔር፡</hi> ኃጥእ፡ ወአባሲ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ ማርያም፡</hi>
                        </persName> ወምስለ፡ ኵልነ፡ ውሉደ፡ ጥምቀት፡ አሜን፡
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="143ra" to="158rb">Fols 143ra–158rb</t:locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4958Priests">Dǝrsān baʾǝnta kǝbromu la-24 kāhǝnāta samāy</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="143ra" to="143b">Fols 143ra–143b</t:locus>
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ</hi>
                        ድርሳን፡ ዘሠርዖ፡ <hi rend="rubric">አብ፡
                        ቅዱስ፡ ቄርሎስ፡ ኤጲስ፡ ቆጶስ፡ ዘኢየሩሳሌ፡</hi> ም፡ ወውእቱ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#158ra">Fol. 158ra</t:locus>
                        <hi rend="rubric">ሃሌ፡ ሉያ፡</hi> ክሂሎት፨ ወመድኃኒት፡ ወስብሐት፡ ለመድኃኒነ፡ አሜን፨ <hi rend="rubric">ሃሌ፡ ሉያ፡</hi> ወጸሎተ፡ ኵሎሙ፡ <hi rend="rubric">ቅዱሳን፡</hi> ወሰማዕት፨ አሜን፨
                     </explicit>
                     <explicit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#158rb">Fol. 158rb</t:locus>
                        ኦአምላከ፡ <hi rend="rubric">፳ወ፬ ካህናተ፡ ሰማይ፡</hi> ሰረይ፡ ኃጢአቶ፡ ወዕቀብ፤ ሕይወቶ፡ ለጸሐፌ፤ ዝንቱ፡ ድርሳን፡ ኃጥእ፤ ወአባሲ፤ ነዳይ፤ ወምስኪን፤ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ ማርያም፡</hi>
                        </persName>ወምስለ፤ ኵልነ፤ ውሉደ፤ ጥምቀት፤ አሜን፤
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i7">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="158ra" to="178rb">Fols 158ra–178rb</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5898DersanaMikael">Homily on the Archangel Michael</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez" type="inscriptio">
                        ድርሳን፡
                        በእንተ፡ መልአክ፡ ክቡር፡ ሚካኤል፡
                     </incipit>
                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="158ra" to="158rb">Fols 158ra–158rb</t:locus>
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አም</hi>ላክ፡
                        ንቀድም፡ በረድኤተ፡ <hi rend="rubric">እ<hi rend="ligature">ግዚ</hi>አብሔር፡
                        ልዑል፡ ወበሠናይ፡ ሀብቱ፡ ጽሒፈ፡</hi> ድርሳን፡
                     </incipit>
                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="177vb" to="178rb">Fols 177vb–178rb</t:locus>
                        ወያፅንዕክሙ፨ በሃይማኖተ፡ ርትዕት፤ በስሙ፡ ቅዱስ፡ ወቡሩክ፡ እስከ፡ ለዓለም፤ በጸሎታ፡
                        ወበአስተብቍዖታ፡ ለእግዝእተ፡ ኵልነ፡ ቡርክት፡ ወንጽሕት፡ ወቅድስት፡ ወድንግል፡ በ፪ኤ፡ ማርያም፡
                        ንግሥተ፡ ዓለማት፡ ፪ቱ፨ ወለኵሎሙ፡ እለ፡ ህልዋን፡ በውስቴቶሙ፡
                        መላእክት፤ ወደቂቀ፡ አዳም፤ ነቢያት፡ ወሐዋርያት፡ ጻድቃን፡ ወሰማዕታት፨ ወለኵሎሙ፤ እለ፡ አሥመርዎ፡
                        ለ<hi rend="rubric">እ<hi rend="ligature">ግዚ</hi>አብሔር፡</hi> በስነ፡ ምግባሮሙ፡ በሕይወቶሙ፨
                        ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን፨ ለይኩን፡ ለይኩን፨
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i8">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="179ra" to="203rb">Fols 179ra–203rb</t:locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT5900DersanaMikaelTheo">Dǝrsān baʾǝnta ʿǝbayu wa-kǝbru
                    la-Mikāʾel</title>
                     <incipit xml:lang="gez" type="inscriptio">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡
                          ድ</hi>ርሳን፡ ዘብፁዕ፡ ወ<hi rend="rubric">ቅዱስ፡ ሊቀ፡ መላክእት፡ ሚካኤል፡ ዘ</hi>ደረሰ፡ ሊቀ፡ ጳጳሳት፡
                        አባ፡ ቴዎዶስዮ<hi rend="rubric">ስ፡ በመንፈስ፡ ቅዱስ፡ በእንተ፡ ዕበዩ፡ ወ</hi>ክብሩ፡ ለውእቱ፡ መልአክ፡ መሐር፡
                        <hi rend="rubric">ሚካኤል፡ ሊቀ፡ መላእክት፡ ወበእንተ፡</hi> ተአምር፡ ዘገብረ፡
                        ምስለ፡ ዱራታዎስ፡ ወቴዎብስታ፡ ብእሲቱ፡ አመ፡ ፲ወ፪ለኅዳር፡</incipit>
                        <incipit xml:lang="gez" type="supplication">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="179ra" to="179rb">Fols 179ra–179rb</t:locus>
                        በረ<cb n="b"/>ከቱ፡ ትኩን፡ ምስሌነ፡ ወምስለ፡ ጸሐፊሁ፡ ኃጥእ፡ ወጊጉይ፡ <persName ref="https://betamasaheft.eu/PRS11958WaldaM">
                           <hi rend="rubric">ወልደ፡ ማርያም፡</hi>
                        </persName> አሜን፡
                     </incipit>
                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#179rb">Fol. 179rb</t:locus>
                        አሜን፡ ይቤ፡ ሠናይ፡ ውእቱ፡ ዘይቤ፡ <sic resp="DN">ዳዋት</sic>፡ መዘምር፡ ሰብሕዎ፡ ለ<hi rend="rubric">እግዚአብሔር፡</hi> ኵልክሙ፡
                        መላእክቲሁ፨ ሰብሕዎ፡ ለ<hi rend="rubric">እግዚአብሔር፡ እምሰማያት፨ ይሴ</hi>ብሕዎ፡ በአርያም፨
                        ወዓዲ፡ ይቤ፡ ዘይሬሰዮሙ፡ ለመላእክቲሁ፡ <hi rend="rubric">መንፈስ፡</hi> ወለእለ፡ ይትለዓክዎ፡ ነደ፡ እሳት፨
                     </incipit>

                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="202vb" to="203va">Fols 202vb–203va</t:locus>
                        ወይረሲ፡ ለክሙ፡ ኃዋኅወ፡ ቤተ፡ ክርስቲያን፡ ርኅወ፡ በምሕረት፡ ወበአሚን፡ እስከ፡ ለዓለመ፡ ዓለም፨ ወዝናመ፡ ምሕረቱ፡ ያውርድ፡
                        ለክሙ፡ ወየሀብ፡ ዘርዓ፡ ለዘራዒ፡ ወእክለ፡ ለሲሳይ፡ ወይቀጥቅጦ፤ ለሰይጣን፡ በታሕተ፡ እገሪክሙ፡ ወያንግሥ፡ ለክሙ፡ ንጉሠ፡
                        ራትዓ፡ ወይዕቀብ፡ ንጉሦ፡ ወሠራዊቶ፨ አሜን፤
                     </explicit>
                     <explicit xml:lang="gez" type="subscriptio">

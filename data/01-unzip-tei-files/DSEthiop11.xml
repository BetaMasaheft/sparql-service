                     <incipit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="203ra" to="203rb">Fols 203ra–203rb</t:locus>
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡
                          ንዌጥ</hi>ን፡ በረድኤተ፡ <hi rend="rubric">እግዚአብሔር፨</hi>
                        ወበሠናይ፡ ሀብቱ፡ <sic resp="DN">በጽሔፈ</sic>፤ ድርሳኑ፡ ወበእንተ፡ ሕንፃ፡ ቤተ፡ ክርስቲያኑ፤
                        ዓዲ፡ ለሊቀ፡ መላእክት፡ <hi rend="rubric">ገብርኤል፡</hi> ዘደብረ፡ ነግሎን፡ ዘብሔረ፡ ግብፅ፤ ወበእንተ፡
                        መንክራቲሁ፡ ዘከሠተ፡ በውስቴታ፤ <hi rend="rubric">በላዕለ፡ ዕደዊሁ፡</hi>
                     </incipit>

                     <explicit xml:lang="gez">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#241va">Fol. 241va</t:locus>
                        ይእዜኒ፡ ወዘፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን፡ ኪራላይሶን፨ ወአሜን፨ ለይኩን፡ ለይኩን፨

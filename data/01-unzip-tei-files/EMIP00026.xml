               <msContents>
                  <summary>Anaphora of Our Lady Mary by Cyriacus of Bǝhǝnsa, ቅዳሴ፡ ማርያም፡, Image of Mary, መልክአ፡ ማርያም፡, Image of Jesus Christ, መልክአ፡  ኢየሱስ፡, Image of Michael, መልክአ፡ ሚካኤል፡</summary>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                     <msItem xml:id="ms_i1">
                       <locus from="1r" to="29v" facs="003">Fols 1r–29v</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                       <note>Cf. EMIP 27</note>
                     </msItem>

                     <msItem xml:id="ms_i2">
                       <locus from="29v" to="47r" facs="032">Fols 29v–47r</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2891RepCh172">Malkǝʾa
                                                  Māryām</title>
                     </msItem>

                     <msItem xml:id="ms_i3">
                       <locus from="47r" to="63r" facs="049">Fols 47r–63r</locus>

      <t:body>
         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ተዋበች፡ አሊ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Tawābačč ʾAli</t:persName>
             
               <t:persName>
                  <t:roleName type="title">ʾǝtege</t:roleName>
               </t:persName>
               <t:occupation type="political">queen</t:occupation>
               
               <t:floruit notBefore="1845" notAfter="1858">She was the daughter of 
                  <t:persName ref="https://betamasaheft.eu/PRS1688AliAlul">
                     <t:roleName type="title">rās</t:roleName> ʾAli ʾAlulā</t:persName> 
                  who became the first wife of <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName> in <t:date>1845</t:date>.
                  It was a political marriage designed to curb <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">
                     Tewodros II</t:persName>'s ambition as his rise increasingly threatened the rule of  
                 
                  <t:persName ref="https://betamasaheft.eu/PRS1688AliAlul"> 
                     <t:roleName type="title">rās</t:roleName> ʾAli ʾAlulā </t:persName>'s mother  
                  <t:persName ref="https://betamasaheft.eu/PRS6643MananLi">Manan Liban  ʾAmade</t:persName> over 
                  <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName> and the western Ethiopian borderlands. 
               
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">   
                     <t:roleName type="title">ʾaṣe</t:roleName> Tewodros II</t:persName> 
                  is said to have been remained faithful to <t:persName ref="https://betamasaheft.eu/PRS9320Tawabacc">Tawābačč ʾAli</t:persName>
                  during her lifetime and reluctant to remarry following her death. </t:floruit>
               <t:death when="1858"/>
            </t:person>  
            
         </t:listPerson>
   

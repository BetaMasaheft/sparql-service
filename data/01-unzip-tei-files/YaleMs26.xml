                  <title>Thursday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.5">
                  <locus from="148v" facs="151">Fols 148v and following</locus>
                  <title>Friday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.6">
                  <locus from="149v" facs="152">Fols 149v and following</locus>
                  <title>Saturday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.7">
                  <locus from="150v" facs="153">Fols 150v and following</locus>
                  <title>Sunday</title>
                </msItem>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="151v" to="154v" facs="154">Fols 151v–154v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
              </msItem>
            </msItem>

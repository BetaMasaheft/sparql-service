      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0570</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘያስተፌሥሖ፡ ለሰማዒ፨</l>
                  <l n="2">ዜና፡ ማርቆስ፡ መዋኢ፨</l>
                  <l n="3">ማሕሌተ፡ እንብብ፡ ቅድመ፡ ሰብአ፡ ቢት፡ ወገባኢ፨</l>
                  <l n="4">አባ፡ አባ፡ ጸሎተ፡ ልሳን፡ አዒ፨</l>
                  <l n="5">ወአድኅኖተከ፡ በላዕሌየ፡ አርኢ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለርእስከ፡ ጸውሬ፡ አስር፡ ሐዋስ፨</l>
                  <l n="2">ውእቱ፡ ዓዲ፡ ማኅደረ፡ ለባዊት፡ ነፍስ፨</l>
                  <l n="3">ዜና፡ ማርቆስ፡ መልአክ፡ ዘባርየከ፡ መንፈስ፨</l>
                  <l n="4">አመ፡ ይነቅሑ፡ ምዉታን፡ እምሰሚዐ፡ ቃላት፡ ሥላስ፨</l>
                  <l n="5">ክፍለኒ፡ እኅድር፡ በዓለም፡ ሐዳስ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ እብል፡ ለከናፍሪከ፡ ፍሡሓት፨</l>
                  <l n="2">እስመ፡ አናቅጽ፡ ስማንቱ፡ ለማኅፈደ፡ ሥጋከ፡ ሕንጽት፨</l>
                  <l n="3">ዜና፡ ማርቆስ፡ አልዓዛር፡ ሊቀ፡ ካህናት፨</l>
                  <l n="4">አስተብቍዕ፡ ኀበ፡ አምላክ፡ ሰላመ፡ ናዕስ፡ ወመርዔት፨</l>
                  <l n="5">እስከ፡ ጽላሎታ፡ ትመይጥ፡ ዕለት፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለአፉከ፡ ዘመሀረ፡ ጽድቀ፨</l>
                  <l n="2">ለብእሲ፡ አፍአዊ፡ እምነ፡ ሃይማኖት፡ ዘርኅቀ፨</l>
                  <l n="3">ዜና፡ ማርቆስ፡ ምስሌየ፡ እንተ፡ ትከውን፡ ልጹቀ፨</l>
                  <l n="4">አለብወኒ፡ እግዚኦ፡ ወመሀረኒ፡ ጥዩቀ፨</l>
                  <l n="5">ጸዋትወ፡ ኵሉ፡ ነገር፡ ወምክረ፡ ዕሙቀ፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ በየማነ፡ ቅዱስ፡ ምሥዋዕ፨</l>
                  <l n="2">ኀበ፡ ይቀውማ፡ እገሪሁ፡ ለሊቀ፡ ካህናት፡ ቅቡእ፨</l>
                  <l n="3">ዜና፡ ማርቆስ፡ ምንተ፡ እነግር፡ ወምንተ፡ ኣየድዕ፨</l>
                  <l n="4">እምብዝኀ፡ ገድሉ፡ ጥዕጡዕ፨</l>
                  <l n="5">ዜና፡ ማርቆስ፡ አቡየ፡ ስሑከ፡ መልክእ፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">ሐሩራ፡ ለመርቴ፡ ወቁራ፡ ለደደክ፡</l>
                  <l n="2">ዘኢያመጽልዎ፡ ምንተኒ፡ ለለ፡ ጊዜ፡ ጽባሕ፡ ወሠርክ</l>
                  <l n="3">ዜና፡ ማርቆስ፡ አቡየ፡ ምድራዊ፡ መልአክ፨</l>
                  <l n="4">አማዑተ፡ ከርሡ፡ በፀሓይ፡ ምስማክ፨</l>
                  <l n="5">ከመ፡ መንኰራኵር፡ ዘልፈ፡ ይሰግድ፡ በብረክ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="10v">1r-10v</locus>
                     <textLang xml:lang="am-Arab">Amharic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT2062IHA">ʻAǧamī text (Amharic) on the battles of the madinan
                    period of the Prophet</title>
                     <incipit xml:lang="am-Arab">
                        <locus target="#6r">-6r</locus>باب غزوت بقرقرة لكدر| بسبات قنو تملسو تبدر</incipit>
                     <explicit xml:lang="am-Arab">
                        <locus target="#1r">-1r</locus>صلاو صلوت لله وسلام لله| حجده لاكبر يرد واله| على محمد خير رسل الله| وعلى له صاحبه والتابعين لهم بطاعة لله </explicit>
                     <note>The fol. 1r-5v are bound upside down. Taḫmīs. Vocalized. Text in black ink. Words aren't divided. Historical text in amharic on the battles of the madinan period of the Prophet.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="11r" to="22v">11r-22v</locus>
                     <textLang xml:lang="am-Arab">Amharic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2065IHA">نص خير خلق لله أكرم مولد طيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>خير خلق لله أكرم مولد طيب لسبنو تقي لجدود دواء لقلوب قوت أهل الجزبا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22v">-22v</locus>ألهم صل على سيدنا ولأل وصحب أنصاردينا| وسلم وبارف بهم رب أنصرنا. تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="23r" to="28v">23r-28v</locus>
                     <textLang xml:lang="am-Arab">Amharic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2070IHA">ألحمد لله لباسطلبا سطا</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>ألحمد لله لباسطلبا سطا ومن رحمته طلب لبا لبسط</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28v">-28v</locus>Unreadable</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="29r" to="52v">29r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0176IHA">تخميس الوترية</title>
                     <incipit xml:lang="ar">
                        <locus target="#29r">-29r</locus>له نائل عم لأنام| بأسره فلا واحد إلا يبوح بشكره| ونحن جميع طانعون لأمره| زيولا سبحاناها إفتخار لفره لنا كل باب للمفاخر ينقذ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>فتحنا لمسراى المعظم بابنا| دنو إلينا قد رفعنا حجابنا أيحجب محبوب له لوصل يرصد</explicit>
                     <note>Taḫmīs. Some of the fol. are bound upside down. Words aren't divided.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="53r" to="54v">53r-54v</locus>
                     <textLang xml:lang="am-Arab">Amharic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2064IHA">أيما ساسل يس</title>
                     <incipit xml:lang="ar">
                        <locus target="#54v">-54v</locus>أيما ساسل يس يليلا ساو رمطا أخبار هلا| بس أل هلم شليلا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53r">-53r</locus>نورن سرانا أله تعلى من أن بلود نجطا وفلا| بأوقونو يسن جلاما<note>Approximated transliteration</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>

      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0545</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ኦኤልያስ፡ ዘወሀብኮ፡ ካዕበተ፡ መንፈስ፡ ምስለ፡ ሐሜለት፨</l>
                  <l n="2">ለረድእከ፡ ኤልሳዕ፡ ገባሬ፡ ኀይላት፨</l>
                  <l n="3">ሰላመ፡ መልክእከ፡ እንብብ፡ በረድኤትከ፡ ቅድስት፨</l>
                  <l n="4">ጸጋ፡ ሀበኒ፡ እግዚኦ፡ እምእግዚእከ፡ ከመ፡ ሐዋርያት፨</l>
                  <l n="5">ዘወረደ፡ ላዕሌሆሙ፡ መንፈስ፡ ቅዱስ፡ ከመ፡ ዘእሳት፡ ወተናገሩ፡ በነገረ፡ ኵሉ፡ በሐውርት፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለትርጓሜ፡ ስምከ፡ ዘተብህለ፡ ዘይተ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘኢተቀርዐ፡ ቅርዐተ፨</l>
                  <l n="3">በጸውዖ፡ ስምከ፡ ኤልሳዕ፡ ፈለገ፡ ዮርዳኖስ፡ አእተተ፨</l>
                  <l n="4">እኩየ፡ ስመ፡ ኢተሀበኒ፡ እንበለ፡ እግበር፡ እኪተ፨</l>
                  <l n="5">ኤልያስ፡ ማእምርየ፡ ወአውቅየ፡ አንተ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለቆምከ፡ ወለመልክእከ፡ ክሡት፨</l>
                  <l n="2">ለዐይነ፡ እስክንድር፡ ንጉሥ፡ ነጻሬ፡ ኅቡኣት፨</l>
                  <l n="3">ኤልያስ፡ ጴጥሮስ፡ ተፍጻሜ፡ ሰማዕት፨</l>
                  <l n="4">በጽድቅ፡ ገሥጸኒ፡ ወተዛለፈኒ፡ በምሕረት፨</l>
                  <l n="5">ከመ፡ ታድኅነኒ፡ እም፡ ዳግም፡ ሞት፨</l>
               </lg>
               <lg type="stanza" n="35">
                  <l n="1">ሰላም፡ ለትንሣኤከ፡ በመንፈቀ፡ ዕለት፡ ራብዕ፨</l>
                  <l n="2">ከመ፡ ቃለ፡ ዮሐንስ፡ ረድእ፨</l>
                  <l n="3">ዘሀሎ፡ እምቅድሜየ፡ ወዘድኅሬየ፡ ይመጽእ፨</l>
                  <l n="4">ዘይቤ፡ ዮሐንስ፡ መጥምቃዊ፡ በእንተ፡ ክርስቶስ፡ እግዚእ፨</l>
                  <l n="5">አማን፡ ይደልወከ፡ ኤልያስ፡ ራትዕ፨</l>
               </lg>
               <lg type="stanza" n="36">
                  <l n="1">ካህን፡ ወነቢይ፡ ወሰማዕተ፡ ዳግም፡ ጽዋዔ፨</l>
                  <l n="2">እምሐዋርያት፡ ሐዋርያ፡ በታቦራዊ፡ ጉባኤ፨</l>
                  <l n="3">ኤልያስ፡ ዘኮንከ፡ ሕገ፡ መነኮሳት፡ ሠራዔ፨</l>
                  <l n="4">እስመ፡ ፈጸምኩ፡ ወድሶተከ፡ በሰላመ፡ ኃምስ፡ ሱባዔ፨</l>
                  <l n="5">ከመ፡ ዮናስ፡ ዘአንሣእኮ፡ ረስየኒ፡ ቍልዔ፨</l>
               </lg>
            </div>
         </div>
      </body>

                  </msItem>
                  <msItem xml:id="ms_i9">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="102v" to="102v">102v-102v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4014IHA">دعاء بعد صلاة العشاء</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#102v">-102v</t:locus>بسم الله الرحمن الرحيم اللهم اجرنا \ سالمين وقنا شر الظلمين وانصرنا علي القوم الكفرين \ الهى ارزقنا نظر وجهك الكريم</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#102v">-102v</t:locus>رب توفني مسلما والحقني \ بالصالحين برحمتك يا أرحم الراحمين</explicit>
                     <note>
                        <note>
        Manuscript item  6493 relates to manuscript item 6495</note>

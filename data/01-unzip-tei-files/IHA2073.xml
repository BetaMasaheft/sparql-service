                  </msItem>
                  <msItem xml:id="ms_i8">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="102v" to="102v">102v-102v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4013IHA">دعاء بعد صلاة العصر</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#102v">-102v</t:locus>بسم الله الرحمن \ الرحيم اللهم اني أسألك سلامة في الدين وعافية في الجسد وزيادة \ في العلم</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#102v">-102v</t:locus>ومغفرة بعد الموة يا سامع كل صوة هون \ علينا سكرات الموة برحمتك يا أرحم الراحمين</explicit>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="127v">1r-127v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1829IHA">كتاب مادحة [كذا] المختار في الصلاة على النّبي
                    المختار</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسملة \ لك الحمد يا اله القديم \ ذي الملك والجبروت الدائم \ ثمّ الصلاة على محمد المعصوم \ اللهم صل وسلم على سيدنا محمد وعلى أل محمد أللهمّ صلّ وسلّم على سيدنا محمد صلى الله عليه وسلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#126v">-126v</locus>تمت حليتي بمدح المهتد \ عليه الصلاة من ربّ العباد \ بعدد المؤمن والمساجد \ تمت \ تمت وبالخير عمت \ ألفين وعشرين بيت</explicit>
                     <note>ff. 1r-v blank; at ff. 116v-126v the three verses of each stanza are written in a chevron disposition</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="128r" to="129v">128r-129v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1831IHA">نظم الحمد لله ذي العلاء والفضل والنعم</title>
                     <incipit xml:lang="ar">
                        <locus target="#128r">-128r</locus>أللهمّ صلّي وسلّم على سيدنا محمد \ حبيبك أل محمد أللهمّ صلّي وسلّم \ على سيدنا محمد صلّى الله عليه وسلم \ الحمد لله ذي العلاء والفضل والنعم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#129v">-129v</locus>عفو الله محو ذنبي وستر عيبي وكشف ضري \ والفوز باالجنة النعيم بحرمة المصطفى المختار \ تمت بالخير عمت باالنور  \ (تصلية)ا</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

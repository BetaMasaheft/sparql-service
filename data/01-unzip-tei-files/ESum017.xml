                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red</seg>
                        Scribe: Sǝbbuḥ, märigeta (?). s.
                        Additio 1.<date>second half of the 20th century</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                           <item>በእ፡ for በእንተ፡</item>
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                           <item>እማ፡ for እማሬ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; name of King Ḫāyla Śǝllāse;
                           interlinear musical notation signs; a few lines (alternating with black)
                           on the incipit page of Texts I-II; incipits of sections of Texts I-III;
                           some lines in Text II; directions for the ministers; some words, e.g.,
                           ቡራኬ, ወእምዝ, ጸሎት; elements of the punctuation signs; Ethiopic numerals
                           and/or their elements.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#132r">f. 132r</locus>
                           <desc>: Inventory of books and church utensils. </desc>
                           <quote xml:lang="gez"> </quote>
                           <quote xml:lang="en"/>
                           <note> Very recent, in pen. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#133r">f. 133r</locus>
                           <desc>: Record concerning a manuscript transaction (?). </desc>
                           <quote xml:lang="gez">
                              <locus target="#133r">133r</locus>: እኔ፡ መሪጌታ፡ ስቡሕ፡ ተድላ፡ አንድ፡ ሙሉ፡ መዝገብ፡
                              ዘአጸሐፈት፡ ወለተ፡ ዓብየ፡ እግዚእ ...</quote>
                           <quote xml:lang="en"/>
                           <note> Written in Amharic in pen. The note contains the name of a scribe
                              (?) märigeta Sǝbbuḥ, names of donors and the date Miyāzyā 1962.
                           </note>
                        </item>
                        <item xml:id="e1">- Notes on the content: <locus target="#3v">3v</locus>,
                           132v.
 - Recent notes on the content in the upper margin: e.g.,
                              <locus target="#27r">27r</locus>, 28r. etc.
 - Some lines are
                           erased: <locus target="#60va">60va</locus>.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">- Coloured threads inserted in the corner of fols.
                              13, 45, 49, 58, 59, 70, 86, 102, 110, 121.</desc>
                        </item>
                     </list>
                  </additions>

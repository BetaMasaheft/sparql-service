               <msContents>
                  <summary>A codex containing a Psalter, Canticles, and the Song of Songs. Psalm
                            150 is followed by doxology with musical notation. </summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1r">1r</locus>
                     <title xml:lang="en">Ethiopic alphabet</title>
                     <textLang mainLang="gez">Geez</textLang>
                     <note>F. 1r contains part of the Ethiopic Alphabet written upsidedown in
                                a crude hand. </note>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="2r" to="127v">2r-127v</locus>
                     <title ref="https://betamasaheft.eu/LIT2000Mazmur">Psalms</title>
                     <note>
                        <ref target="https://www.fihrist.org.uk/catalog/work_546">See in FIHRIST.</ref>
                     </note>
                     <listBibl type="relations">
                        <bibl/>
                        <relation name="skos:broadMatch" ref="http://www.w3.org/2004/02/skos/core#broadMatch" active="https://www.fihrist.org.uk/catalog/work_546" passive="https://betamasaheft.eu/LIT2000Mazmur"/>
                     </listBibl>
                     <textLang mainLang="gez">Geez</textLang>
                     <note>Pss 15, 16, 36, 58, 114-116, 125-127, 148, 150 are incorrectly
                                numbered. Psalm 118 is unnumbered as usual. Pss 148-150 contain
                                musical notation.</note>
                  </msItem>

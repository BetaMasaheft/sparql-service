         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">አብሳዲ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAbsādi</persName>
                  <persName>
                  <roleName type="title">ʾAbbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC2313DabraM">Dabra Māryām</placeName>
               </residence>
               <birth>He was born in the province of <placeName ref="https://betamasaheft.eu/LOC2947Endart">ʾƎndartā</placeName>.
               </birth>
               <floruit notBefore="1300" notAfter="1380">
                  He was a monk of the monastery of <placeName ref="https://betamasaheft.eu/LOC2313DabraM">Dabra Māryām</placeName>
                  in the 14th century and was a leader of the
                  <persName ref="https://betamasaheft.eu/PRS11207Ewostateans">ʾEwosṭātean</persName> movement. 
                  He was a pupil of <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭatewos</persName> of 
                  <placeName ref="https://betamasaheft.eu/LOC2358DabraS">Dabra Ṣārbi</placeName>. 
                  He is still venerated as a saint in <placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</placeName> and 
                  <placeName ref="https://betamasaheft.eu/LOC5932Tegray">Tǝgrāy</placeName>. 
                  He is represented as one of "the great masters" of the monastery of <placeName ref="https://betamasaheft.eu/LOC2313DabraM">Dabra Māryām</placeName>
                  together with  
                  <persName ref="https://betamasaheft.eu/PRS2050Aronof">ʾabbā
                     ʾAron of Galilā</persName> in the 
                  <ref type="work" corresp="https://betamasaheft.eu/LIT2375Synaxa">Sǝnkǝssār</ref> entry.
                  </floruit>
                  <death when="1380"/>
               </person>  
               
         </listPerson>

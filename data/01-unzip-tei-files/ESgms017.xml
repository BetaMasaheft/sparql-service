                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: careful, well-trained; hand b: mediocre.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Hand a: first half of the 20th century; hand b: second half of the
                           20th century (?).</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይበል፡ ካህን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the kings; incipit of Text I;
                           titles of the books to be read; titles and initial lines of the payers to
                           be read; directives to the ministers; the abbreviation “yǝka” for “yǝbäl
                           kahǝn” in fol. 41v; elements of the punctuation signs; Ethiopic
                           numerals.
 On the incipit page of Text I (fol. 5r), a few lines are
                           rubricated (alternating with black lines).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="5ra" to="34vb">5ra-34vb</locus> (quires
                        I-IV).</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="36r" to="47r">36r-47r</locus> (quire
                        V).</handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#5r">5r</locus>: simple uncoloured ornamental band
                        (ails).</decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- Crude recent note written in pen: <locus target="#2r">fol.  2r</locus>. - Numbers written in pen in the right margin of <locus target="#37r">fol.  37r</locus>.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards covered with brown tooled
                           leather.
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Two pairs of chains (partly damaged) of
                           endband stitches at the spine cover.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornaments on the brown leather cover (4
                           tools were used: fourfold line fillet, double circle, cross-hatching,
                           x-form).</decoNote>
                     </binding>

                        <handDesc>

                            <handNote script="Ethiopic" xml:id="h1">
                                <desc>The manuscript is written by two or three hands  of the <date>18th century</date>.

                                </desc>

                                <date notBefore="1700" notAfter="1800" resp="PRS10171Wright"/>

                            </handNote>

                        </handDesc>
                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#3r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ገድለ፡ ኤዎስጣቴዎስ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                           </q>
                                </item>

                                <item xml:id="a2">
                                    <locus target="#143r"/>
                                    <desc type="GuestText"> It contains apparently the end of a tract called <title type="incomplete" ref="https://betamasaheft.eu/LIT1919Mashaf">Maṣḥafa bāḥrǝy, The Book of the Pearl</title>.
                                    </desc>
                                    <q xml:lang="gez">ተፈጸመ፡ ባሕርይ፡ ዘይትነበብ፡ በርእሰ፡ ዓውደ፡ ዓመት፡ አመ፡ ፩ለወርኃ፡
                                        ሴብቴብሮስ፡ ዘውእቱ፡ መስከረም፡ ወተርጐምነ፡ እመዛግብተ፡ ኅቡኣቲሁ፡ ለእግዚአብሔር፡
                                        መድኃኒነ፡ በልሳነ፡ መዋቲ፡ ኃጥእ፡ ወምስኪን፡ ትንብልናሁ፡ ለዮሐንስ፡ ካህን፡ ይዕቀበነ፡ ለኲልነ፡ እምትካዝ፡ ወኀዘን etc.</q>
                                </item>
                                <item xml:id="a3">
                                    <locus target="#97r"/>
                                    <desc type="Invocation"> It is an invocation of various saints by <persName ref="https://betamasaheft.eu/PRS12599Tawaldamadhen">Tawalda Madhǝn</persName>; and
                                        on the verso are some particulars regarding the life of <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</persName>
                                    </desc>

                                </item>
                                <item xml:id="a4">
                                    <locus target="#1v"/>
                                    <desc type="DonationNote"> The record of a present of books, made by the monk <persName ref="https://betamasaheft.eu/PRS12600ZaWaldamaryam">Zawalda Māryām</persName> to the tabot of <persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">saint Michael</persName>
                                    </desc>

                                </item>
                                <item xml:id="a5">
                                    <locus target="#1v"/>
                                    <desc type="DonationNote"> The record of a present of books, made by <persName ref="https://betamasaheft.eu/PRS12598RehruhAmlak">. </persName>
                                    </desc>

                                </item>


                               <item xml:id="e1">
                                   <locus target="#159v">

                                   </locus>
                                   <desc>The name of one owner was <persName ref="https://betamasaheft.eu/PRS12598RehruhAmlak">ርኅሩኅ፡ አምላክ፡</persName>
                                       of another <persName ref="https://betamasaheft.eu/PRS12599Tawaldamadhen">ተወልደ፡ መድኅን፡</persName> whose parents and other relatives are named on <locus target="#93v, 142r"/>
                                           . The name of the scribe has been erased , but it began with the letter  አር፡ at <locus target="#142r"/>, and ended with ሮስ፡ at <locus target="#143r"/>, before which page a leaf is wanting.
                                     </desc>
                               </item>
                            </list>


                        </additions>
                        

                    <msContents>
                        <summary/>
                      <msItem xml:id="ms_i1">
                          <locus from="2r" to="105v"/>
                          <title ref="https://betamasaheft.eu/LIT3200DossierEw">Hagiographic Dossier of St ʾEwosṭātewos</title>

                          <msItem xml:id="ms_i1.1">
                            <locus from="2r" to="94v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT4319GadlaEA">The life of ʾEwosṭātewos</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ገድል፡ ዘቅዱስ፡ ወብፁዕ፡ <persName ref="https://betamasaheft.eu/PRS3934Ewostate"><roleName type="title">አባ፡ </roleName>  ኤዎስጣቴዎስ፡ </persName> መንኮስ፡
                                ዘብሔረ፡ <placeName ref="https://betamasaheft.eu/LOC3010Ethiop">ኢትዮጵያ፡</placeName> ድንግል፡ ወኅሩይ፡</incipit>


                        </msItem>

                        <msItem xml:id="ms_i1.2">
                          <locus from="98r" to="105v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1438GadlaE#Taamer">Miracles of ʾEwosṭātewos</title>
                          <textLang mainLang="gez"/>

                          <msItem xml:id="ms_i1.2.1">
                            <locus from="98r" to="103v"/>
                            <title ref="https://betamasaheft.eu/LIT6201Hymn">Collection of Hymns for the Miracles of ʾEwosṭātewos</title>
                            <textLang mainLang="gez"/>

                            <msItem xml:id="ms_i1.2.1.1">
                              <locus target="#98r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3043RepCh323">A hymn to his miracles</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">አናኅኩ፡ ነቢበ፡ ወከሠትኩ፡ አፈ፡ <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ኤዎስጣቴዎስ፡</persName> እዜኑ፡ ተአምሪከ፡ ትሩፈ።</incipit>
                            </msItem>

                            <msItem xml:id="ms_i1.2.1.2">
                              <locus from="98r" to="100r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3053RepCh333">A hymn to his miracles</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">እምብዙኅ፡ ተአምሪከ፡ አቀድም፡ አሐተ፡ <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ኤዎስጣቴዎስ፡</persName> ዘትገብር፡ ዐበይተ፡ ኃይላተ፡ መኰንን፡ ዝኁር፡</incipit>
                            </msItem>

                            <msItem xml:id="ms_i1.2.1.3">
                              <locus from="100r" to="103v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3073RepCh353">A hymn to his miracles</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">እንዘ፡ ሀሎኩ፡ በተሰዶ፡ ወበተሞቅሖ፡ ዕፁብ፤ ተዝካረ፡ ዕድወትከ፡ ባሕረ፡ ከመ፡ እዜኑ፡ ለሕዝብከ፤ etc</incipit>
                            </msItem>

                          </msItem>

                          <msItem xml:id="ms_i1.2.2">
                            <locus from="103v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2780RepCh64">A hymn to his miracles</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"> ሰላም፡ ለከ፡ <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ኤዎስጣቴዎስ፡</persName>  ዐቢይ፡ ዘኢትትከበት፡ ሃገር።</incipit>
                          </msItem>

                          <msItem xml:id="ms_i1.2.3">
                            <locus from="105v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1438GadlaE#Taamer">Other miracles</title>
                            <textLang mainLang="gez"/>
                          </msItem>

                        </msItem>
                      </msItem>

                        <msItem xml:id="ms_i2">
                            <locus from="105v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1285Dersan">A discourse on Isaac or Garimā</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ድርሳን፡ ዘደረሰ፡ ቅዱስ፡ ዮሐንስ፡ ኤጲስ፡ ቆጶስ፡ ዘአክሱም፡ በእንተ፡ ዕበዩ፡ ወገድሉ፡ ለቅዱስ፡ ይስሐቅ።</incipit>




                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="143v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4050ZenaBul">The Acts of ʾAbib or ʾabbā Bulā</title>
                            <textLang mainLang="gez"/>





                        </msItem>

                        <msItem xml:id="ms_i4">
                            <locus from="168v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1448GadlaG">The history of Gabra ʾƎndrǝyās</title>
                            <textLang mainLang="gez"/>








                        </msItem>



                    </msContents>







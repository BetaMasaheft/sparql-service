                  <msItem xml:id="ms_i1">
                    
                    <title type="complete" xml:lang="la">Hoc lexicon amharicum <persName ref="https://betamasaheft.eu/PRS6378Ludolf">chariss° patre</persName> dirigente a me
                      <persName ref="https://betamasaheft.eu/PRS6377Ludolf">Christiano Ludolfo</persName> mense Majo et Junio descriptum fuit. <date>A. S. MDCLXXXV.</date>
                     </title> 
                    <textLang mainLang="am" otherLangs="la"/>
                    
                    <msItem xml:id="ms_i1.1">
                        <locus from="1" to="8"/>
                        <title type="complete">Elements of Amharic grammar, notes on orthography and the writing 
                    of the dictionary</title> 
                        <textLang mainLang="am" otherLangs="la"/>
                     </msItem>
                    
                    <msItem xml:id="ms_i1.2">
                        <locus from="11"/>
                        <title type="complete" xml:lang="la">Lexidion amharicum primum præsente Aethiope a me collectum, prout
                        videre est in Lexico <persName ref="https://betamasaheft.eu/PRS10129Wemmers">Wemmeri</persName> in charta pura ibi a me 
                        congestum; postea descripsit <persName ref="https://betamasaheft.eu/PRS10036Wansleb">Wanslebius</persName> exemplar
                      ex eo idque secum in iter asportavit. Ex hoc vero exemplari denuo huc Amharica, famulus vero meus
                        <persName ref="https://betamasaheft.eu/PRS11320Thieme">Johann David Thieme</persName>, nunc <foreign xml:lang="de">Ambts schreiber zu <placeName ref="https://www.wikidata.org/entity/Q559841">Ichtershausen</placeName>
                           </foreign>, latina adscripsit.</title> 
                        <textLang mainLang="am" otherLangs="la"/>
                    </msItem>
                    

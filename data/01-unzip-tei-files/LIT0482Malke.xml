      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0482</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">መጽሔተ፡ አእምሮ፡ ስቅሊ፡ ለአንጻርየ፡ በፍጽሙ፨</l>
                  <l n="2">ዘያጤይቀኒ፡ መልክአ፡ በዐቅሙ፨</l>
                  <l n="3">ማርያም፡ ድንግል፡ ክሥቲ፡ ምስጢረ፡ ስሙ፨</l>
                  <l n="4">ለገነትኪ፡ ዘካርያስ፡ ለለጌሠሙ፡ ወዐሙ፨</l>
                  <l n="5">ምስለ፡ ቈጽል፡ ወፍሬ፡ ዘይትረከብ፡ ኦሙ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እንዘ፡ አንተ፡ ሕፃን፨</l>
                  <l n="2">በስመ፡ ዘሰመየከ፡ አቡከ፡ ዘካርያስ፡ ቍርባን፨</l>
                  <l n="3">አብሳዲ፡ ብፁዕ፡ ሊቀ፡ ብፁዓን፨</l>
                  <l n="4">ይትቀዳሕ፡ እምውሳጤየ፡ በጽዋዐ፡ ንስቲት፡ ልሳን፨</l>
                  <l n="5">መልክአ፡ ውዳሴከ፡ ሜስ፡ ወዜናከ፡ ወይን፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለኅሊናከ፡ መዝገበ፡ ይዋሄ፡ ዘረሰዮ፨</l>
                  <l n="2">ፈታኔ፡ ኅቡኣት፡ ክርስቶስ፡ ለባሕረ፡ ጠባይዕ፡ ዘይቀልዮ፨</l>
                  <l n="3">ዘካርያስ፡ ካህን፡ ሠራዬ፡ ኀጢአት፡ ወአሥተስርዮ፨</l>
                  <l n="4">ትነዝኀኒ፡ በአዛብከ፡ ወታጸርየኒ፡ አጽርዮ፨</l>
                  <l n="5">ዲበ፡ ፐፒራ፡ ለይ፡ ቅዳሕ፡ ታስተዳሉ፡ ማዮ፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ መካነ፡ ስብሐት፡ ወድልቅልቅ፨</l>
                  <l n="2">ደብረ፡ ማርያም፡ ቅድስት፡ እንተ፡ ትስመይ፡ በጽድቅ፨</l>
                  <l n="3">እንዘ፡ ዘካርያስ፡ አበ፡ ሥነ፡ ሥርጋዌሁ፡ መብረቅ፨</l>
                  <l n="4">ዕንቍ፡ ውስጣ፡ ወዴዴያቲሃ፡ ዘወርቅ፨</l>
                  <l n="5">እስመ፡ በውሳጤሃ፡ ተቀብሩ፡ ኅሩያን፡ ደቂቅ፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">መኑ፡ እምሰብእ፡ ጽንዐ፡ ሕሊናሁ፡ ዘኢሰበረ፨</l>
                  <l n="2">በሰሚዐ፡ ገድልከ፡ ዝንቱ፡ ወኢበከየ፡ መሪረ፨</l>
                  <l n="3">ዘካርያስ፡ መጋቢ፡ ዘሀይማኖትከ፡ ተነክረ፨</l>
                  <l n="4">አንብረኒ፡ ውስተ፡ ሕፅንከ፡ ከመ፡ ይተሉ፡ አእጋረ፨</l>
                  <l n="5">ወጽላሎት፡ ዘይተሉ፡ ድኅረ፨</l>
               </lg>
               <lg type="stanza" n="47">
                  <l n="1">አስቆቀወት፡ አባ፡ ልብሰ፡ ብልባሌ፡ ቀኒታ፨</l>
                  <l n="2">ነፍስየ፡ ዕጓለ፡ ማውታ፨</l>
                  <l n="3">ዘካርያስ፡ መርዓዊ፡ ለመርዓት፡ ሥርጋዌ፡ ቤታ፨</l>
                  <l n="4">አንተኬ፡ ለትፍሥሕትነ፡ ኃሤታ፨</l>
                  <l n="5">ወለዓለምነ፡ ኪያከ፡ ማኅቶታ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ለዛቲ፡ አስትአ፡ ውዳሴከ፡ እንበለ፡ አሌዕል፡ መጠና፨</l>
                  <l n="2">ዘካርያስ፡ ቅድሜከ፡ ዘአቅረብኩ፡ ዘምስለ፡ ትሕትና፨</l>
                  <l n="3">ተወከፋ፡ አባ፡ ወኢትመንና፨</l>
                  <l n="4">አብሰ፡ እንበይነ፡ ንስቲት፡ ቀኖና፨</l>
                  <l n="5">ለፅሩዕ፡ ወልድ፡ ይሁቦ፡ ምዝጋና፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
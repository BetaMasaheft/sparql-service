               <msContents>
                  <summary>Gospel of John, ወንጌል፡ ዘዮሐንስ፡; Image of Jesus Christ, መልክአ፡  ኢየሱስ፡; Anaphora of Our Lady Mary of Cyriacus of Bǝhǝnsa, ቅዳሴ፡ ማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="55v" facs="005">Fols 1r–55v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="55v" to="56r" facs="060">Fols 55v–56r, </locus>
                     <locus from="67v" to="68r" facs="072">67v–68r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4131Salam">Salām to Jesus
                                                  Christ</title>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="56r" to="66v" facs="060">Fols 56r–66v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                  </msItem>
               </msContents>

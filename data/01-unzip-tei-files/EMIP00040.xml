                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="130r" facs="003"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <incipit xml:lang="gez">መዝሙረ፡ ዳዊት፡ ትመስል፡ ገነተ። ታስተጋብእ፡ አቅማኃ፡ ወፍሬያተ።</incipit>
                        <note> A crude hand has attempted to arrange it for the days of the week</note>
                        <msItem xml:id="ms_i1.1.1">
                          <locus from="1r" facs="003"/>
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT2005Mazmur#Introduction">Mazmura Krǝstos,  Introduction</title>
                          <note>Introduced with the psalm of the shorter version of this text</note>
                        </msItem>
                     </msItem>

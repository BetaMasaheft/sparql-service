                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7287PrBaryaSusenyos">Ṣalot baʾǝnta ḥǝmāma ʿāynata Bāryā wa-Maggāññā
          wa-Šotolāy</title>
                            <note>Containing <ref type="work" corresp="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</ref>.</note>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነት፡ ባርያ፡ ወመጋኛ፡ ወሾቶላይ፡ ተያዥ፡ ወፃራሪ፡ ዛር፡ 
                                ወተዋ<gap reason="illegible"/>ድድቅ፡ ወጋኔነ፡ ቀትር፡ በስመ፡ እግዚአብሔር፡ ሕያው፡ ነባቢ፡ ወተናጋሪ፡ ጸሎተ፡ ቅዱስ፡ 
                                ሱ<choice><sic>ሱ</sic><corr>ስ</corr></choice>ንዮስ፡ በእንተ፡ አሰስሎ፡ ደዌ፡ እምሕፃናት፡ እለ፡ ደጠብው፡ ጥበ፡ እሞሙ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7288PrBaryaDis">Ṣalot baʾǝnta ʿāynata Bāryā Magāññā wa-Šotolāy wǝgʿāt
          wa-qʷǝrṭǝmāt fǝlḍat</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="illegible"/> ጸሎት፡ በእንተ፡ ዓይነተ፡ ባርያ፡ መጋኛ፡ ወሾቶላይ፡ ውግዓት፡ ወቍርጥማት፡ ፍልፀት፡ 
                                ወ<supplied reason="omitted" resp="PRS8999Strelcyn">ቍ</supplied>ርጸት፡ ቡዳ፡ ወጠቢብ። አአትብ፡ ገጽየ፡ ከመ፡ ኢይቅረብ፡ ደልፋኤል፡
                                ሀልኤል፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7290PrRheuma">Ṣalot baʾǝnta ḥǝmāma qʷǝrṭǝmāt qarǝrṭǝmātǝs</title>  
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ቍርጥማት፡ ቀር<sic>ር</sic>ጥማትስ፡ ቀር<sic>ር</sic>ጥማትስ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7289PrChest">Ṣalot baʾǝnta ḥǝmāma wǝgʿāt Liqānos bǝhil ʿǝḍub</title>
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ውግዓት፡ ሊቃኖስ፡ ብሂል፡ ዕፁብ፡</incipit>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title type="complete" ref="https://betamasaheft.eu/LIT7291PrBaryaPhanuel">Ṣalot baʾǝnta ḥǝmāma ʿāynata Bāryā</title>
                            <note>Containing a "salām to the archangel <persName ref="https://betamasaheft.eu/PRS7840Phanuel">Phanuel</persName>".</note>
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነተ፡ ባርያ።</incipit>
                            <textLang mainLang="gez"/>
                        </msItem> 
                    </msContents>

                      <locus target="#1r #7v #14v #22v #32r #39v #45v #54v #65v #73v #79r #92r #104r #107r #113r #119r #139r #141r #145r #146v #148v" facs="002 009 016 024 033 041 047 056 067 075 080 093 105 108 114 120 140 142 146 148 150">1r, 7v, 14v, 22v, 32r, 39v, 45v, 54v, 65v, 73v, 79r, 92r, 104r, 107r, 113r, 119r, 139r, 141r, 145r, 146v, 148v, </locus> (dotted line using alternating black and red);
                      <locus target="#22v #145r #147v" facs="024 146 149">22v, 145r, 147v</locus> (dotted line using alternating black and red surrounded by <foreign xml:lang="gez">ሐረግ፡</foreign>-like border);

                          <locus target="#109v" facs="111">Fol. 109v</locus>
                          <desc>Overlooked lines of text are written interlinearly</desc>
                        </item>
                        <item xml:id="e3">
                          <locus target="#23v" facs="025"> f. 23v, line 15</locus>
                          <desc>Overlooked lines of text are written in the upper margin with a symbol marking the location where the text is to be inserted</desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#1r #4r #7r #15r #18v" facs="002 005 008 016 020">Fols. 1r, 4r, 7r, 15r, 18v</locus>
                           <desc>etc., the scribe regularly has to complete a line of text on another line. Much of the problem is addressed through the selection of an appropriate aspect ratio
                        for the codex combined with an appropriate script size. This scribe will reduce the font size at the end of lines to avoid having to go onto the next line</desc>
                        </item>
                        <item xml:id="e5">
                          <locus target="#3v #5r #8v #10r #12r #12v #14v #16r" facs="005 006 010 011 013 014 016 017">Folss. 3v, 5r, 8v, 10r, 12r, 12v, 14v, 16r, </locus>,

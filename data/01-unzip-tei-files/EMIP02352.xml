                    <decoDesc>
                  <decoNote type="frame" xml:id="d1">
                    Decorative designs:
                    <locus target="#17r #24v" facs="017 025">folss. 17r, 24v, </locus>, line of alternating red and black dots;
                    <locus target="#35v" facs="036">35v</locus>, multiple full stops</decoNote>
                </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc>Text is badly faded throughout the codex.</desc></item>
                      <item xml:id="a1"><desc type="OwnershipNote"><locus target="#24v" facs="025">f. 24v and passim</locus> mention the owner Wäldä Gäbrǝʾel (<foreign xml:lang="gez">ወልደ፡ ገብርኤል፡</foreign>) and the scribe Gäbrä Yoḥännǝs (<foreign xml:lang="gez">ገብረ፡ ዮሐንስ፡</foreign></desc></item>
                      <item xml:id="a2"><desc><locus target="#56v">Fol. 56v</locus>Record written in pen <q>“This is from the ancient church books, written during the reign of emperor Susǝnyos, 1623 E.C.”</q> Susǝnyos I reigned 1606–1632, but the hand is clearly 20th century.  Perhaps the note refers to the manuscript from which this one was copied</desc></item>
                      <item xml:id="e2">
                        <desc>
                          Scribal intervention:
                          words of text are written interlinearly, <locus target="#29r #39v #49r" facs="029 040 049">folss. 29r, 39v, 49r, </locus>;
                          erasure markings are visible, <locus target="#10r #48r" facs="010 048">10r, 48r</locus>
                        </desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached to rough-hewn boards of the traditional wood covered with tooled leather, pieces of headband and tailband visible, book has been rebound and original binding has been damaged.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

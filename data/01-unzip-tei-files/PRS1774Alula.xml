               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAlulā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">አሉላ፡ ጉግሳ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAlulā Gugsā</t:persName>
          
               
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">ruler</t:occupation>
               
               <t:floruit notBefore="1825" notAfter="1828">He was one of the most influential 
                  political figures during the time of Zamana masāfǝnt 
                  who was involved in a number of battles to support the rule of his father, 
                  <t:persName ref="https://betamasaheft.eu/PRS4870GugsaMa">Gugsā Marsā</t:persName>. 
                  In return, he was named governor of <t:placeName ref="https://betamasaheft.eu/LOC2488Damot">Dāmot</t:placeName>
                  and <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>. </t:floruit>
               
         
            </t:person>
            

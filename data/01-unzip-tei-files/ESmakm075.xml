                           <note> </note>
                        </item>
                        <item xml:id="a11">
                           <locus target="#158va">f. 158va</locus>
                           <desc>-vb: Inventory of the books and the liturgical utensils of the May
                              ʾAnbäsa monastery.</desc>
                           <quote xml:lang="gez">

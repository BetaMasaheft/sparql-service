               <msContents>
                  <summary>I) Taʾammǝra Māryām "Miracles of Mary": ca. 84 miracles (fols.
                     1ra-154rb)
 
 Additiones 1-3.</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1ra" to="154rb"/>
                     <title ref="https://betamasaheft.eu/LIT2384Taamme">Taʾāmmǝra Māryām "Miracles of Mary"</title>
                     <textLang mainLang="gez"/>
                
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1ra" to="154rb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3585Taamme">Miracles of Mary: ca. 84 miracles</title>        
                        <note>Some miracles are numbered.</note>
                     </msItem>
                     
                     
                     
                  </msItem>
                  
               </msContents>

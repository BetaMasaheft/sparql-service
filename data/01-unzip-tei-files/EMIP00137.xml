               <msContents>
                  <summary>Ziq Chants, መጽሐፈ፡ ዚቅ፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="10r" facs="001">Fols 1r–10r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1979Mashaf">Maṣḥafa ziq</title>
                     <note>Without musical notation, incomplete at the beginning.</note>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="11r" to="167v" facs="011">Fols 11r–167v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1979Mashaf">Maṣḥafa ziq</title>
                    <incipit type="supplication" xml:lang="gez">
                            እዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ ዚቅ፡ ወእስመ፡ ለዓለም፡ ወአቡን፡ ምስለ፡ ዋዜማ፡ ዘአውጽዎ፡ ሊቃውንተ፡ ጎንደር፡ እምዮሐንስ፡ እስከ፡ ዮሐንስ፡ </incipit>
                    <incipit xml:lang="gez">
                      ብፁዕ፡ አንተ፡ ዮሐንስ፡ ዘሀለወከ፡ ታእምር፡ ወተሐውር፡ ቅድመ፡ እግዚአብሔር፡ ጸሊ፡በእንቲአነ፡<gap reason="omitted"/>
                    </incipit>
                    <note>Ziq Chants and Abun Hymns, arranged for the feasts for the entire year.</note>
                    <notatedMusic><desc>with musical notation</desc></notatedMusic>
                  </msItem>
               </msContents>

                       <msItem xml:id="ms_i1.1">
                            <locus from="1ra" to="97va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1507GadlaT">Gadla Takla Hāymānot (Dabra Libānos recension, general
          record)</title>
                            <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ በኢተሌልዮ፡ ወዋሕድ፡ በኢተፋልዮ፡ ክዱነ፡ መለኮት፡ ወእምተሐልዮ። 
                                ወኅሩመ፡ ሥልጣን፡ እምተመኳስዮ። ኅቡረ፡ መንግሥት፡ በኢተባርዮ። ወዕሩየ፡ አካል፡ ዘበተአይዮ። ንጽሕፍ፡
                                ገድለ፡ ፃማሁ፡ ለአቡነ፡ ቅዱስ፡ <sic>ብፀዓዊ፡</sic> ተክለ፡ አብ፡ ተክለ፡ ወልድ፡ ተክለ፡ መንፈስ፡ ቅዱስ። ዘውእቱ፡ አባ፡ ተክለ፡ ሃይማኖት፡ 
                                ጸዋሬ፡ ስመ፡ ሥላሴ። ዘይትነበብ፡ አመ፡ ፳ወ፬ ለነሐሴ።
                            </incipit>
                            <explicit xml:lang="gez">በትእዛዘ፡ አቡነ፡ ጴጥሮስ፡ ዲበ፡ መንበረ፡ ተክለ፡ ሃይማኖት፡ ዘነበረ፡ ሜላተ፡ ጽድቁ፡ ዘተአጽፈ፡ ወበሐፀ፡ 
                                ፍቅሩ፡ ዘተነድፈ፡ ዘንተ፡ መጽሐፈ፡ ከመ፡ የሀሉ፡ ዘልፈ፡ ይክድነነ፡ ዘብርሃን፡ <t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">ዓፅፈ፡</t:supplied> 
                                ወብዕለ፡ ጸጋሁ፡ ትሩፈ፡ ለዓለመ፡ ዓለም፡ አሜን።
                                <gap reason="ellipsis"/>
                            </explicit>
                        </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="98ra" to="98vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3143Ledata">Lǝdata ʾabaw</title>
                                <incipit xml:lang="gez">መጽሐፈ፡ ልደቱ፡ ለአቡነ፡ ተክለ፡ ሃይማኖት፡ ወልደ፡ እግዚአብሔር፡ በጸጋ፡ ወወልደ፡ አዳም፡ በሥጋ፡ 
                                    አዳም፡ ወለዶ፡ ለሴት፡</incipit>
                            </msItem>
                            
                            <colophon xml:id="coloph1" xml:lang="gez">
                                <locus from="98vb" to="99r"/>
                                ዝንቱ፡ ታሪክ፡ ወዜና፡ ነገር፡ ዘመነኮስ፡ ክቡር፡ አቡነ፡ ተክለ፡ ሃይማኖት፡ ዘከመ፡ ተመሐለ፡ ምስለ፡ ይኩኖ፡ አምላክ፡ ንጉሥ፡ 
                                እንዘ፡ ሀሎ፡ በ<pb n="99r"/><cb n="a"/> ደብረ፡ ሊባኖስ፡ በመሐላ፡ ክቡድ፡ ወኪዳን፡ ጽኑዕ፡ 
                                እመንግሥቱ፡ <sic>ይኰኖ፡</sic> አምላክ። ወእስከ፡ 
                                ሐፄጌ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> ወናግ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፤</t:supplied>
                                ሰገድ፡ እንዘ፡ <sic>የሰየሙ፡</sic> መምህራነ፡ በተታልዎ፡ ትውልድ፡ ድኅረ፡ ትውልድ፡ በትእዛዘ፡
                                አምላካዊት፡ ዝውእቱ፡ አስማቲሆሙ፡ ለእለ፡ ተሠይሙ፡ መምህራነ፡ በግሼ፡ መቅድመ፡ ኵሎሙ፡ አባ፡ ዮስጢኖስ፡
                                ወእምዝ፡ አባ፡ አበ፡ ከረዙን፡ ወአባ፡ ኤርምያስ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> አባ፡ ዘርአ፡ ዳዊት፤ ወአባ፡ ፍሬ፡
                                ካህን<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> አባ፡ ሲኖዳ፡ ወአባ፡ ተስፋ፡ ወንጌል፡
                                ወዘንተ፡ ኵሎ፡ ሥርዓተ፡ ወግዕ፡ የአምሩ፡ ፲ወ፪ በዓለ፡ ሕግ፡ እለ፡ ወፅኡ፡ እምኢየሩሳሌም፡ ምስለ፡ 
                                ንጉሥ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> ዕብነ፡ ሐኪም፡ ሰሎሞን፡ ወሾብር። አፈ፡ አቃሞባ፡ ወመልከኛ፡ በዓለ፡ ሐርብ።
                                ወኵሎሙ፡ ደብ<add place="below">ተ</add>ራ፡ የአምሩ፡ ወይጤይቆ፡ ከመ፡ ግሸን፡ ዘአቡነ፡ ተክለ፡ ሃይማኖት፡ ውእቱ፡ እስመ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied>
                                <unclear>ዐለ፡</unclear> በዐለ፡ ወግዕ።
                            </colophon>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="100ra" to="108rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1929Mashaf">Maṣḥafa fǝlsatu la-Takla Hāymānot (general record)</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ፩ ወልዱ፡ ወ፩
                                    መንፈሱ፡ ፩ አምላክ፡ ወ፩ እግዚአብሔር፡ ዘበ፩ ሕሉና፡ ወምልክና፡
                                    <gap reason="ellipsis"/>
                                    <pb n="199v"/><cb n="a"/>
                                    <gap reason="ellipsis"/>
                                    <cb n="b"/>
                                    <gap reason="ellipsis"/>
                                    ስምዑ፡ ወለብው፡ ኦፍቁራንየ፡ መጽሐፈ፡ ዜናሁ፡ ለክቡር፡ ወቅዱስ፡ ወብፁፅ፡ ተክላ፡ ሃይማኖት፡ ፍቁረ፡ እግዚአብሔር፡
                                    ዘይትነበብ፡ በዕለተ፡ ፍልሰተ፡ ሥጋሁ፡ አመ፡ ፲ወ፪ ለወርኃ፡ ግንቦት፡
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="108va" to="114ra"/>
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT3971Taamme">Taʾammǝra Takla Hāymānot</title>
                                <note>The text ends abruptly in the middle of the last miracle.</note>
                                <incipit xml:lang="gez">በስመ፡ እግዚአብሔር፡ <sic>እግዚእ፡</sic> ሰማየ፡ ዘረሰየ፡ መንበሮ፡ 
                                    ወምድረ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied> መከየደ፡ እግሮ፡ ሰማይ፡ ወምድር<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">፡</t:supplied>
                                    ዘኢያገምሮ። 
                                    <gap reason="ellipsis"/><cb n="b"/><gap reason="ellipsis"/>
                                    ንጽሐፍ፡ እንከ፡ ዮም፡ በዛቲ፡ ዕለት፡ ዘከመ፡ ልደቱ፡ ኮነ፡ ለአቡነ፡ ተክለ፡ ሃይማኖት፡ ወዘከመ፡ ገብረ፡ እግዚአብሔር፡ ተአምረ፡ ወመንክረ፡
                                </incipit>
                                
                                <msItem xml:id="ms_i1.4.1">
                                    <locus from="114ra" to="115rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7482MTHConversion">LIT7482MTHConversion</title>
                                    <incipit xml:lang="gez">አኮ፡ እምውሉደ፡ ክርስቲያን፡ አላ፡ እምአረሚኒ፡ ሀለወት፡ አሐቲ፡ 
                                        ብእሲት፡ አረማዊት፡ እንተ፡ እምሥራቀ፡ ፀሐይ፡ ቦአ፡ ኀቤሃ፡ በሌሊት፡ አቡነ፡ ተክለ፡ ሃይማኖት፡ ሀለወ፡ 
                                        ምስሌሁ፡ ፩ እምውሉዱ፡ አብርሃ፡ ቤታ፡ ለይእቲ፡ ብእሲት፡ ከመ፡ ብርሃነ፡ መዓልት። ወርእያ፡ ብርሃነ፡ 
                                        ገጹ፡ ደንገፀት፡ ወወድቀት፡ በገጻ፡ <cb n="b"/> ወይቤላ፡ 
                                        አቡ<add place="below">ነ</add>፡ ተንሥኢ፡ ወለትየ፡ ኢትፍርሂ፡ ትቤሎ፡ መኑ፡ አንተ፡ 
                                        እግዚእየ፡ <gap reason="ellipsis"/> ወይቤላ፡ አነ፡ ውእቱ፡ ተክለ፡ ሃይማኖት፡ ዝንቱኒ፡ 
                                        ዘሀሎ፡ ምስሌየ፡ ሳሙኤል፡ ውእቱ፡ ዘገዳመ፡ ዋሊ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.2">
                                    <locus from="115rb" to="115vb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7483MTHHealing">LIT7483MTHHealing</title>
                                    <incipit xml:lang="gez">፪ ተአምሪሁ፡ <gap reason="ellipsis"/>
                                        መጽአ፡ ፩ ብእሲ፡ ዘኢይክል፡ ኃዊረ፡ በእግሩ፡ ዘእንበለ፡ በእደዊሁ፡ ነበረ፡ ከመዝ፡ በዴዴ፡ ቤተ፡
                                        ክርስቲያን፡ ፩ ሰሙነ፡ አው፡ ፪ እንዘ፡ ይትመሐለል፡ ኀበ፡ አቡነ፡ ተክለ፡ ሃይማኖት፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.3">
                                    <locus from="115vb" to="116ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7484MTHChild">LIT7484MTHChild</title>
                                    <incipit xml:lang="gez">፫ ተአምሪሁ፡ <gap reason="ellipsis"/> ሐመ፡ ፩ ወልድ፡ 
                                        ንዑስ፡ ወተ<add place="below">አ</add>ስረ፡ እደዊሁ፡ ወእገሪሁ፡ ተእኅዘ፡ አብራኪሁ፡ ምስለ፡ ክሳዱ፡ ወኢተክህሎ፡ ከመ፡ ይቁም፡ 
                                        ወከመ፡ ይትመየጥ፡ እመሂ፡ ለየማን። ወእመሂ፡ ለፀጋም።</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.4">
                                    <locus from="116rb" to="118va"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7485MTHAlexander">LIT7485MTHAlexander</title>
                                    <incipit xml:lang="gez">፬ ተአምሪሁ፡ <gap reason="ellipsis"/>
                                        ኮነ፡ እንዘ፡ የሐውር፡ ውስተ፡ ፀብዕ፡ እስክንድር፡ ንጉሥ፡ አማኅፀኖ፡ ለአቡነ፡ መርሐ፡ ክርስቶስ፡ እንዘ፡ ይብል፡ አንሰ፡ ኢይትአመን፡
                                        በብዙኀ፡ ሠራዊትየ፡ ዘእንበለ፡ ኃይለ፡ ተአምራቲሁ፡ ለአቡነ፡ ተክለ፡ ሃይማኖት፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.5">
                                    <locus from="118va" to="119rb"/>

                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iir(etco)" facs="003">Fol. iir(etco)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with angels catching the blood from the wounds of <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName>. For the story behind this scene, see Image of Uriel</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#93v" facs="096">Fol. 93v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> attended by the angels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#94r" facs="096">Fol. 94r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1047Apostles">Apostles Portrait</ref> , in panels one and two (Three box panel (1 x 3), five saints in top row, six saints in middle row, and two saints and two equestrian saints in bottom row.)</desc></decoNote>
                    <decoNote type="frame" xml:id="d4">
                    Decorative designs:
                    <locus target="#1r" facs="003">fol. 1r</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>

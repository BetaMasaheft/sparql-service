                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>First half of the 20th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ or ካ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ or ዲ for ይብል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Holy names; incipit of Text I; directives to the
                           ministers and their abbreviations; titles or initial lines of the prayer
                           to be read; the word “ʾǝgale” in Text I; elements of the punctuation
                           signs; elements of Ethiopic numerals. 
 On the incipit page of Texts
                           I-II (fols. 3r, 45r), few lines are rubricated (alternating with two
                           black lines).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">On <locus from="45r" to="56r">45r-56r</locus> (quires VII-IX), the handwriting becomes less careful,
                        the letters are of somewhat smaller
                        size.</handNote>
                  </handDesc>

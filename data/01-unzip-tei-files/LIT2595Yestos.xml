         <t:div type="bibliography">
            <t:listBibl type="editions">
               <t:bibl corresp="http://zotero.org/groups/358366/items/7X73H4I5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Pereira1907Acta"/><title level="m">Acta Martyrum</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><author><forename>Franciscus Maria</forename><surname>Esteves Pereira</surname></author><pubPlace>Romae</pubPlace><publisher>Excudebat Karolus de Luigi</publisher><date>1907</date><series><title level="s">Corpus Scriptorum Christianorum Orientalium</title><biblScope unit="volume">Series Altera 28</biblScope></series><biblScope unit="volume">Series Altera 28</biblScope><note type="url">https://archive.org/details/actamartyrum01este</note><note type="tags"><note type="tag">bm:Pereira1907Acta</note></note><note type="tag">bm:Pereira1907Acta</note><t:citedRange>79-116</t:citedRange></t:bibl>
            </t:listBibl>
            
         </t:div>
         <t:div type="edition">
            <t:div type="textpart" subtype="incipit" xml:lang="gez">
               <t:ab>
               </t:ab>
            </t:div>
         </t:div>
         <t:div type="edition">
            <t:div type="textpart" subtype="incipit" xml:lang="gez">
               <t:ab>
                 ኮነ፡ እንከ፡ ሶበ፡ ነበረ፡ ዲዮግልድያኖስ፡ ዐላዌ፡ ሕግ፡ ነግሠ፡ ላዕለ፡ መንበረ፡ መንግሥተ፡ ሮም፡
               </t:ab>
            </t:div>
            <t:div type="textpart" subtype="explicit" xml:lang="gez">
               <t:ab>
                  ወአዕረጋ፡ ውስተ፡ ሰማያት፡ በዐቢይ፡ ስብሐት። አነ፡ ሰርጊዮስ፡ ገብሩ፡ ለቅዱስ፡ <t:gap reason="omitted"/> ኵሎ፡ መዋዕለ፡ ሕይወትየ። 
                  ሰላም፡ <t:gap reason="omitted"/> ወአሜን።
               </t:ab>
            </t:div>
            <t:div type="textpart" subtype="colophon" xml:lang="gez">
               <t:ab>
                  ወአጽሐፋ፡ እንከ፡ አቡነ፡ አባ፡ ሰላማ፡ ጳጳስ፡ ላእከ፡ ምሥጢሩ፡ ለክርስቶስ፡ እምንዋዩ፡ መጸሐፈ፡ ዓረቢ፡ ለግዕዝ፡ ከመ፡ ይኩኖ፡ ተዝካረ፡ በቅድመ፡ ክርስቶስ፡ ለዓለመ፡ ዓለም፡ አሜን።
               </t:ab>
               <t:note>quoted after <t:ref type="mss" corresp="https://betamasaheft.eu/BLorient686">London, British Library, BL Orient 686</t:ref></t:note>
            </t:div>
         </t:div>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ እምከርሥ፨</l>
                  <l n="2">አመ፡ ዕሥራ፡ ወረቡዑ፡ ለወርኀ፡ ታኅሣሥ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ በኵሉ፡ ወበውስተ፡ ኵሉ፡ ውዱስ፨</l>
                  <l n="4">ናሁ፡ ወጠንኩ፡ ወእቤ፡ እምስብሐቲከ፡ ሐዲስ፨</l>
                  <l n="5">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘጥንተ፡ ፊደሉ፡ መስቀል፨</l>
                  <l n="2">ስመ፡ ክቡር፡ ወስመ፡ ልዑል፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ማቴዎስ፡ በዓለ፡ ቀዳማይ፡ ወንጌል፨</l>
                  <l n="4">ከመ፡ እወድስከ፡ መጠነ፡ አውሥኦተ፡ እክል፨</l>
                  <l n="5">ማእሰረ፡ ልሳንየ፡ ትፍታሕ፡ ማርያም፡ ድንግል፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ በኅሊና፡ አምላክ፡ እለ፡ ተፈቅዳ፨</l>
                  <l n="2">እስመ፡ ቦን፡ ግልባቤ፡ አምሳለ፡ ሠላስ፡ ደቂቀ፡ ይሁዳ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ማርቆስ፡ ጸሓፌ፡ መንክራት፡ ውስተ፡ ሰሌዳ፨</l>
                  <l n="4">አበውእ፡ ለከ፡ እግዚኦ፡ ዘስብሐት፡ ጋዳ፨</l>
                  <l n="5">ህየንተ፡ ወርቅ፡ ወብሩር፡ ጸዐዳ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለርእስከ፡ እምወርቅ፡ አፌዝ፡ ጽሩይ፨</l>
                  <l n="2">ዘአስተማሰለቶ፡ መርዓት፡ ሠናይተ፡ ላሕይ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሉቃስ፡ ዓቃቤ፡ ሥራይ፨</l>
                  <l n="4">ከመ፡ ታዕድወኒ፡ እማእከለ፡ እሳት፡ ወማይ፨</l>
                  <l n="5">አባ፡ እትአመነከ፡ ወልድከ፡ ነዳይ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለገጽከ፡ በስብሐተ፡ ክርስቶስ፡ ስቡሕ፨</l>
                  <l n="2">ዘይኤድም፡ ስኑ፡ እምስነ፡ ፀሐይ፡ ወወርኅ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዮሐንስ፡ ዘብስራትከ፡ ዝኅዙኅ፨</l>
                  <l n="4">ያዕርፈኒ፡ እምግብረ፡ ጻማ፡ ቃለ፡ ዚአከ፡ ንፁሕ፨</l>
                  <l n="5">ለዓለምሰ፡ ስራሑ፡ ብዙኅ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለቀራንብቲከ፡ እለ፡ ይመስላ፡ ኵህለ፨</l>
                  <l n="2">እስመ፡ ኪያሆን፡ አምላክ፡ ቅሩበ፡ አዕይንት፡ ሠዓለ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጴጥሮስ፡ ዘሥልጣንከ፡ ተልዕለ፨</l>
                  <l n="4">እስመ፡ ሞእከ፡ መስተቃትለ፡ ተመርጕዘከ፡ መስቀለ፨</l>
                  <l n="5">ወተስኢነከ፡ ዘወንጌል፡ ቃለ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለአዕይንቲከ፡ ዘአርአያሆን፡ ሐዋዝ፨</l>
                  <l n="2">እስመ፡ ጽዱላን፡ እማንቱ፡ ከመ፡ ሠርቀ፡ ቤዝ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ኅብአኒ፡ እሞተ፡ ጌጋይ፡ ዓዚዝ፨</l>
                  <l n="4">ለከሰ፡ አኮ፡ ከመዝ፨</l>
                  <l n="5">ኢይረክበከ፡ ሞት፡ ዳግመ፡ እምዝ፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለአእዛኒከ፡ እለ፡ አጽምአበምሳሌ፨</l>
                  <l n="2">ዘሐዋርያት፡ ብሩካን፡ ወዘነቢያት፡ ሰብአ፡ ኩፋሌ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሥጋዊ፡ ወመልአክ፡ ዘሉዓሌ፨</l>
                  <l n="4">ምስጠኒ፡ ውስተ፡ ቤትከ፡ ዘአረፋቲከ፡ ቢረሌ፨</l>
                  <l n="5">ከመ፡ አዕርፍ፡ ባቲ፡ እምብካይ፡ ወወይሌ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለመላትሒከ፡ ተጸፍዖ፡ ዘኢኃፈራ፨</l>
                  <l n="2">ለወልደ፡ ማርያም፡ ጽፍዓቱ፡ ሶበ፡ ተዘከራ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሚናስ፡ ዘሰማይ፡ ሐራ፨</l>
                  <l n="4">ኵሎ፡ ቅንአተ፡ በአርኅቆ፡ ወኵሎ፡ መከራ፨</l>
                  <l n="5">ኢታስትት፡ እምአፉየ፡ ቃለ፡ ጽድቅ፡ ለግሙራ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለአእናፊከ፡ ዘአፄነዋ፡ ፄና፨</l>
                  <l n="2">መዓዛ፡ ማርያም፡ ድንግል፡ ወመዓዛ፡ ክርስቶስ፡ ሕፍና፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ኤልያስ፡ ዘንብረትከ፡ ጽሙና፨</l>
                  <l n="4">ኃይለ፡ ጸሎትከ፡ ነበልባለ፡ እሳት፡ ከዊና፨</l>
                  <l n="5">ሦከ፡ ኃጢአትየ፡ ታውዒ፡ ኢታትርፍ፡ ለዜና፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለከናፍሪከ፡ ዘኢነበባ፡ ከንቶ፨</l>
                  <l n="2">እንበለ፡ ዳእሙ፡ አእኵቶ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ፀሐይ፡ ለጽልመት፡ ዘታአትቶ፨</l>
                  <l n="4">አንተኑ፡ ደብረ፡ ከርቤ፡ ዘመዓዛከ፡ ይትፈቶ፨</l>
                  <l n="5">ወሚመ፡ ደብረ፡ ጽጌ፡ ዘኢትክል፡ ተከብቶ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለአፉከ፡ ዘዜነወ፡ በጠይቆ፨</l>
                  <l n="2">ለወልደ፡ ማርያም፡ ጽድቆ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሐዋርያ፡ ጳውሎስ፡ ዘደማስቆ፨</l>
                  <l n="4">ከመ፡ አሳፍ፡ ወኤዶትም፡ እለ፡ ቀደሙ፡ ተዓውቆ፨</l>
                  <l n="5">ኣኃሊ፡ ለከ፡ በመሰንቆ፡ ወእዜምር፡ ለከ፡ በመሰንቆ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለአስናኒከ፡ እምውሣጤ፡ አፍ፡ እለ፡ ይሠርቃ፨</l>
                  <l n="2">በይናቲሆሙ፡ እንዘ፡ ትላጸቃ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ባስልዮስ፡ ለቤተ፡ ክርስቲያን፡ አበ፡ ደቂቃ፨$</l>
                  <l n="4">ስእለትየ፡ ዘፈነውክዋ፡ መንገለ፡ ህላዌከ፡ ጥቃ፨</l>
                  <l n="5">እንበለ፡ ተስፋ፡ ኢትግባእ፡ ዕራቃ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለልሳንከ፡ በሥሉስ፡ ዕለት፡ ዘተውህባ፨</l>
                  <l n="2">አኰቴተ፡ ታቅርብ፡ ለወልደ፡ ማርያም፡ ንጉሠ፡ ሕዝባ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጻማዊ፡ ዮሐንስ፡ ዘቤተ፡ ራባ፨</l>
                  <l n="4">ታሠምረከ፡ ልሳንየ፡ በአምጣነ፡ ኵሉ፡ ንባባ፤</l>
                  <l n="5">ከመ፡ አሥመሮ፡ ያዕቆብ፡ ለላባ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለቃልከ፡ ዘአእመኖሙ፡ ለሕዝብ፨</l>
                  <l n="2">በስመ፡ ኢየሱስ፡ ክርስቶስ፡ ቅዳሜ፡ ቃሉ፡ ለአብ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አቡየ፡ ምስራቃዊ፡ ኮከብ፨</l>
                  <l n="4">ተክለ፡ ሃይማኖት፡ ፀሐይ፡ ልሁብ።</l>
                  <l n="5">ተክለ፡ ሃይማኖት፡ ጠቢብ፡ ወየዋህ፡ ርግብ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለእስትንፋስከ፡ ፈዋሴ፡ ድዉያን፡ በንፍሐቱ፨</l>
                  <l n="2">ወሰራዬ፡ ጌጋይ፡ በክሂሎቱ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ይስሐቅ፡ ለእግዚአብሔር፡ መሥዋዕቱ፨</l>
                  <l n="4">ወሀ{ብኩ፡ ቃለ፡} ውዳሴ፡ በማኅሌተ፡ ስምከ፡ ዝንቱ፨</l>
                  <l n="5">ውሂብሰ፡ እምረኪብ፡ ውእቱ፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለጕርዔከ፡ ዘተኰነነ፡ በጽምእ፨</l>
                  <l n="2">አመ፡ ኢሰተይከ፡ ማይ፡ መጠነ፡ ዓመታት፡ አርባዕ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ኅሠኒ፡ ለወዓሊከ፡ ኅጡእ፨</l>
                  <l n="4">ከመ፡ የኃሥሥ፡ አስተሐሚሞ፡ ኖላዊ፡ ጥቡዕ፨</l>
                  <l n="5">ለእመ፡ በገዳም፡ ተረስዓ፡ ፩፡ በግዕ፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ሰላም፡ ለክሳድከ፡ ዘዓነቀ፡ አስኬማ፨</l>
                  <l n="2">አምሳለ፡ ባግና፡ ወቃማ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ፄው፡ ለዓለም፡ ዘትቀስማ፨</l>
                  <l n="4">ይትፈለጥ፡ ወልድ፡ እመቡሁ፡ ለትምህርትከ፡ በጣዕማ፨</l>
                  <l n="5">ወወለትኒ፡ ትሌለይ፡ እምእማ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለመትከፍትከ፡ በረሪር፡ እለ፡ ይገንያ፨</l>
                  <l n="2">አርዑተ፡ ወንጌል፡ ይጹራ፡ ወመስቀል፡ ቀስተ፡ ራያ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሙቁሕ፡ ጎርጎርዮስ፡ ዘአርማንያ፨</l>
                  <l n="4">ሕማሞሙ፡ ለደቂቅከ፡ አዕይንቲከ፡ ይርአያ፨</l>
                  <l n="5">እስመ፡ አስርሖሙ፡ ለዘመን፡ እከያ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ሰላም፡ እብል፡ ለአክናፊከ፡ ስድስቱ፨</l>
                  <l n="2">ዘመንገለ፡ የማን፡ ሠለስቱ፡ ወመንገለ፡ ፀጋም፡ ሠለስቱ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ወልድከ፡ በረከተከ፡ ይፈቱ፨</l>
                  <l n="4">ሶበ፡ ኀሠሠከ፡ ጊዜ፡ ኀደጎ፡ ዕለቱ፨</l>
                  <l n="5">ለረዲኦቱ፡ ክንፈከ፡ አስተፋጥን፡ ሎቱ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለዘባንከ፡ በሐብለ፡ ጥብጣቤ፡ ዘተኰነነ፨</l>
                  <l n="2">ከመ፡ ጥብጣቤሁ፡ ለክርስቶስ፡ በዕለተ፡ ዓርብ፡ ዘኮነ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሌዋዊ፡ እንተ፡ ታዓርግ፡ ቍርባነ፨</l>
                  <l n="4">ለረዲኦትየ፡ ተንሥእ፡ ፍጡነ፨</l>
                  <l n="5">እስመ፡ ዘአእመርከ፡ አንተ፡ ኢየአምር፡ አነ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለእንግድዓከ፡ ዘጥበብ፡ ምእላድ፨</l>
                  <l n="2">ወዘመንፈስ፡ ቅዱስ፡ ማኅፈድ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ያዕቆብ፡ አንተ፡ እግርከ፡ ግሙድ፨</l>
                  <l n="4">ያስተበፅዑከ፡ ሰማያውያን፡ ነገድ፨</l>
                  <l n="5">እለ፡ ይገስሱ፡ እሳተ፡ በእድ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ እብል፡ ለክቡር፡ ኅፅንከ፨</l>
                  <l n="2">ከላስስተ፡ ሞገስ፡ ቦቱ፡ ዘአስተጋባእከ፨</l>
                  <l n="3">አክለ፡ ሃይማኖት፡ ስምዓ፡ ለወልደ፡ ማርያም፡ ዘኮንከ፨</l>
                  <l n="4">እንዘ፡ ትብል፡ አመ፡ ህላዌከ፡ ኪያሁ፡ ሰባሕከ፨</l>
                  <l n="5">አምላከ፡ ኵሉ፡ እስመ፡ ለከ፡ ኵሉ፡ ወኵሉ፡ ብከ፡ ዘሀሎ፡ ለከ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለአእዳዊከ፡ ዘገሰሳ፡ ነዶ፨</l>
                  <l n="2">ለኢየሱስ፡ ክርስቶስ፡ ስብሐተ፡ መላእክት፡ ዘየአውዶ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አብርሃም፡ ዘጻመውከ፡ በተአንግዶ፨</l>
                  <l n="4">አድኅነኒ፡ እምቀሳሜ፡ ወይን፡ አመ፡ ያሌዕል፡ ማዕፅዶ፨</l>
                  <l n="5">እስመ፡ ለአብ፡ ሥሩዕ፡ ከመ፡ ያድኅን፡ ወልዶ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለመዛርዒከ፡ ዘተመሰሉ፡ አክናፈ፨</l>
                  <l n="2">መኰንን፡ ዓላዊ፡ አመ፡ ወገረከ፡ ጸድፈ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አቡየ፡ ኢትግደኒ፡ ገዲፈ፨</l>
                  <l n="4">አሐቲ፡ ጸሎትከ፡ ትሰድዶሙ፡ ዘልፈ፨</l>
                  <l n="5">ለኃጣውእየ፡ ዘኮኑ፡ አእላፈ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ እብል፡ ለኵርናዕከ፡ በአኅብሮ፨</l>
                  <l n="2">ዘሠለጠ፡ በድረ፡ በሕማም፡ ወበተፅፅሮ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሄኖክ፡ ጸሐፌ፡ ጥበባት፡ ወአእምሮ፨</l>
                  <l n="4">ኅብአኒ፡ በጸላሎትከ፡ ወሰውረኒ፡ ሰውሮ፨</l>
                  <l n="5">አመ፡ ኵሉ፡ ይትፈደይ፡ ወይጸውር፡ ጾሮ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለእመትከ፡ በተአምኖ፡ ዘሰፈረ፨</l>
                  <l n="2">ዘትዕግሥት፡ ቤተ፡ ወዘተጋድሎ፡ ማኅደረ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጽድቅከ፡ በላዕሌየ፡ ተነክረ፨</l>
                  <l n="4">እንበለ፡ ሐመር፡ እፎ፡ ዓዶከ፡ ባሕረ፨</l>
                  <l n="5">ወእፎ፡ እንበለ፡ ሐብል፡ ተለዓልከ፡ ደብረ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለእራኃቲከ፡ ለውሂበ፡ ጸጋ፡ ትሩፍ፨</l>
                  <l n="2">እለ፡ ስፉሐት፡ እማንቱ፡ አምሳለ፡ ክልኤ፡ አክናፍ፤</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አቤል፡ ዘቍርባንከ፡ ውኩፍ፨</l>
                  <l n="4">አንሥእ፡ ኃይለከ፡ እግዚኦ፡ በፀአትከ፡ ዘዘልፍ፨</l>
                  <l n="5">ወውስተ፡ ቤትከ፡ ተመየጥ፡ በእልፍ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለአፃብዓ፡ ከ፡ ሥጋ፡ መለኮት፡ እለ፡ ጠብሐ፨</l>
                  <l n="2">ወደሞ፡ ክቡረ፡ በዕርፈ፡ መስቀል፡ ዘቀድሐ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ምርሐ፡ ለነፍስየ፡ ውስተ፡ ንስሐ፨</l>
                  <l n="4">ለሰብእ፡ ምንተ፡ ይበቍዖ፡ አመ፡ ተብህለ፡ አሜሃ፨</l>
                  <l n="5">ለእመ፡ ኵሉ፡ ዓለማት፡ ረብሐ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ እብል፡ ለአጽፋሪከ፡ ዘአእዳው፨</l>
                  <l n="2">እለ፡ ፍሑቃት፡ እማንቱ፡ በርኄ፡ አፈው፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አንተ፡ አመ፡ ውስተ፡ ጾማዕት፡ ህልው፨</l>
                  <l n="4">ኢይቅሥሙ፡ ፍሬ፡ ዘርኦሙ፡ ለደቂቅከ፡ አኃው፨$</l>
                  <l n="5">ተአስሩ፡ በቃልከ፡ አራዊት፡ ዘበድው፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለገቦከ፡ በቅትራተ፡ ኃፂን፡ እለ፡ ተወግኡ፨</l>
                  <l n="2">ለፌ፡ ወለፌ፡ አመ፡ ተጸንግዑ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዮሴፍ፡ ለክርስቶስ፡ መጋቤ፡ ሰብኡ፨</l>
                  <l n="4">ምስሌየ፡ ሃሉ፡ ማኅፀንትከ፡ ልዕረፍትየ፡ በሳዑ፨</l>
                  <l n="5">ኢያጻምወኒ፡ ፍናዋት፡ ሰብዑ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለከርሥከ፡ ምንዳቤ፡ ረኃብ፡ ዘኢይያንሀኮ፨</l>
                  <l n="2">ወኀጢአ፡ ቅብእ፡ ዘኢያስሐኮ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዳዊት፡ ለእግዚአብሔር፡ ዘትባርኮ፨</l>
                  <l n="4">አድኅነኒ፡ እምእኩያን፡ ዘልማዶሙ፡ ተሀውኮ፨</l>
                  <l n="5">ወእመቅድመ፡ ገጽየ፡ ስድድ፡ ለዓለም፡ መልአኮ፨</l>
               </lg>
               <lg type="stanza" n="33">
                  <l n="1">ሰላም፡ ለልብከ፡ ቅዱስ፡ ወቡሩክ፨</l>
                  <l n="2">ዘዓቀበ፡ ሕጎ፡ ለእግዚአብሔር፡ አምላክ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ፩፡ እምዓሳባዊያን፡ ዘሰርክ፨</l>
                  <l n="4">እምይእቲ፡ ዓስበ፡ ጻማከ፡ ዘኢትትኀደግ፡ በበክ፨</l>
                  <l n="5">ያስተሳትፈኒ፡ ለፅሩዕ፡ ሚካኤል፡ መልአክ፨</l>
               </lg>
               <lg type="stanza" n="34">
                  <l n="1">ሰላም፡ ለኵልያቲከ፡ ዘፈተኖን፡ በትዕግሥት፨</l>
                  <l n="2">ኢየሱስ፡ ክርስቶስ፡ አበ፡ ብርሃናት፤</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሰጋዲ፡ ከመ፡ መላእክት፨</l>
                  <l n="4">ጸሎትከ፡ ዘገበርካሃ፡ እስከ፡ ኆላቌ፡ ፻፡ ዓመት፨</l>
                  <l n="5">መድኃኒተ፡ ትኩኒኒ፡ እምግሩም፡ ቅስት፨</l>
               </lg>
               <lg type="stanza" n="35">
                  <l n="1">ሰላም፡ ለሕሊናከ፡ ዘኮነ፡ መምለኬ፨</l>
                  <l n="2">ሥላሴ፡ ዕሩየ፡ እንበለ፡ ውሳኬ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ቄርሎስ፡ ዘላፌ፡ ረሲዓን፡ እለ፡ አውጣኬ፨</l>
                  <l n="4">ባርከኒ፡ አባ፡ ለወልድከ፡ ዝኬ፨</l>
                  <l n="5">እስመ፡ ልማዱ፡ ለመምህር፡ ቡራኬ፨</l>
               </lg>
               <lg type="stanza" n="36">
                  <l n="1">ሰላም፡ ለአማዑቲከ፡ በእሳተ፡ ፍቅሩ፡ ዘውእየ፨</l>
                  <l n="2">ለወልደ፡ ማርያም፡ ክርስቶስ፡ እንተ፡ ይነብር፡ ሰማየ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ምክር፡ በዘትድኅን፡ ነፍስየ፨</l>
                  <l n="4">አኮኑ፡ አምላክከ፡ ሶበ፡ አድኅኖተ፡ ሰብእ፡ ሐለየ፨</l>
                  <l n="5">በኢያእምሮ፡ ጌጋይ፡ ለሞት፡ ተቀንየ፨</l>
               </lg>
               <lg type="stanza" n="37">
                  <l n="1">ሰላም፡ እብል፡ በስብሐት፡ ወበውዳሴ፨</l>
                  <l n="2">ለንዋየ፡ ውስጥከ፡ ቅሩበ፡ ካዕሴ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዐዋዲ፡ ዘትሰብክ፡ ብስመ፡ ሥላሴ፨</l>
                  <l n="4">እስመ፡ ወለድከ፡ በጸጋ፡ ብእሲተ፡ ወብእሴ፨</l>
                  <l n="5">እለ፡ ይከይዱ፡ አንበሳ፡ ወከይሴ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለኅንብርትከ፡ ማእከለ፡ ከርሥ፡ ሀላዊ፨</l>
                  <l n="2">ዘተቶስሐ፡ ደሙ፡ ለወልደ፡ ማርያም፡ ናዝራዊ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ጽጌ፡ ዘሠረጽከ፡ እምአረጋዊ፨</l>
                  <l n="4">ተበሀሉ፡ በእንቲአከ፡ ካህናተ፡ ይሁዳ፡ ወሌዊ፨</l>
                  <l n="5">መልአክኑ፡ ሰማያዊ፡ ወአኮ፡ ምድራዊ፨</l>
               </lg>
               <lg type="stanza" n="39">
                  <l n="1">ሰላም፡ ሰላም፡ ለሐቌከ፡ ይደሉ፨</l>
                  <l n="2">ዘቀነተ፡ ጽድቀ፡ ለነቢይ፡ በከመ፡ ባህሉ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ፍትሐኒ፡ ለጌጋይ፡ እምሰናስሉ፨</l>
                  <l n="4">ዘፈታሕከ፡ በዲበ፡ ምድር፡ ፍቱሕ፡ ውእቱ፡ በላዕሉ፨</l>
                  <l n="5">ወዘአሰርከ፡ ይትአሰር፡ በኵሉ፨</l>
               </lg>
               <lg type="stanza" n="40">
                  <l n="1">ሰላም፡ ለአቍያጺከ፡ አምሳለ፡ አዕማድ፡ ዘባላቅ፨</l>
                  <l n="2">እለ፡ ሱሩራት፡ እማንቱ፡ በመንበረ፡ ሥጋከ፡ ወርቅ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ያዕቆብ፡ ወላዴ፡ እስራኤል፡ ደቂቅ፨</l>
                  <l n="4">አንብረኒ፡ ከመ፡ ኅልቀት፡ ውስተ፡ ልብከ፡ ዕሙቅ፨</l>
                  <l n="5">አመ፡ እምዕፁብ፡ ይድኅን፡ ጻድቅ፨</l>
               </lg>
               <lg type="stanza" n="41">
                  <l n="1">ሰላም፡ ለአብራኪከ፡ እለ፡ አንኃ፡ ሰጊደ፨</l>
                  <l n="2">ለእግዚአብሔር፡ አምላክ፡ እንተ፡ እማርያም፡ ተወልደ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አቅልል፡ ዘጌጋይየ፡ ክበደ፨</l>
                  <l n="4">እስመ፡ ኢዓቀብኩ፡ እምትእዛዝከ፡ አሐደ፨</l>
                  <l n="5">ባሕቱ፡ በምሕረትከ፡ ረስየኒ፡ ወልደ፨</l>
               </lg>
               <lg type="stanza" n="42">
                  <l n="1">ሰላም፡ ለአእጋሪከ፡ ዘተወደሳ፡ ወተበፅዓ፨</l>
                  <l n="2">አመ፡ ማእከለ፡ ባሕር፡ ሐራ፡ ኀበ፡ ኢየሱስ፡ ሞአ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ኪሩብ፡ እንተ፡ ተዓቅብ፡ ምሥዋዓ፨</l>
                  <l n="4">ተዘኪረከ፡ ጸሎተ፡ እምልሳንየ፡ ዘወፅአ፨</l>
                  <l n="5">እንበለ፡ ንስሐ፡ ኢትግዝም፡ ኪያየ፡ ኃጥአ፨</l>
               </lg>
               <lg type="stanza" n="43">
                  <l n="1">ሰላም፡ ለሰኳንዊከ፡ ዘተሴረያ፡ በደም፨</l>
                  <l n="2">አመ፡ ተሰብረ፡ እግርከ፡ እምብዝኃ፡ ቀዊም፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ኢዮብ፡ ዘትዕግሥትከ፡ ፍጹም፨</l>
                  <l n="4">ባርኮሙ፡ ለደቂቅከ፡ እለ፡ ውስተ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="5">ከመ፡ ባረኮሙ፡ ኖኅ፡ ለያፌት፡ ወሴም፨</l>
               </lg>
               <lg type="stanza" n="44">
                  <l n="1">ሰላም፡ ለመከየድከ፡ ውስተ፡ ደብረ፡ አማን፡ ዘጌሣ።</l>
                  <l n="2">ገጸ፡ ማርያም፡ ወልዳ፡ እንዘ፡ የኃሥሣ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ንስር፡ ወዘሐቀለ፡ ገዳም፡ አንበሳ፨</l>
                  <l n="4">በቅድሜለ፡ ትልበር፡ እግዚኦ፡ ለነፍሰ፡ ዚአየ፡ ሞገሳ፨</l>
                  <l n="5">ከመ፡ ቅድመ፡ ኤልያስ፡ ከብረ፡ ርእሶሙ፡ ለ፶፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለአፃብዓ፡ እግርከ፡ በኍላቌሆን፡ ዓሥር።</l>
                  <l n="2">አመ፡ ሰለ፡ ፲፡ ወአውቃር፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ቲቶ፡ ረድአ፡ ጳውሎስ፡ መምህር፨</l>
                  <l n="4">ዕዳየ፡ ፍዲ፡ እግዚኦ፡ ወመሐረኒ፡ በፍቅር፨</l>
                  <l n="5">ከመ፡ ሠናይትከ፡ ኢይኩን፡ በግብር፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">ሰላም፡ ሰላም፡ እንዘ፡ እብል፡ እገኒ፨</l>
                  <l n="2">ለአጽፋረ፡ እግርከ፡ ዓሥር፡ ወአኮ፡ ሰማኒ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዮሴዕ፡ ወካሌብ፡ ወልደ፡ ዮፎኒ፨</l>
                  <l n="4">አመ፡ ንግደትየ፡ እምዓለም፡ ማሳኒ፨</l>
                  <l n="5">ውስተ፡ ሀገርከ፡ እግዚኦ፡ ምርሐኒ፨</l>
               </lg>
               <lg type="stanza" n="47">
                  <l n="1">ሰላም፡ ለቆምከ፡ ዘጶዴረ፡ ሰማይ፡ ልብሱ፨</l>
                  <l n="2">ልሳናት፡ ቦቱ፡ እለ፡ ይትቄደሱ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ በለዝ፡ ለክርስቶስ፡ ዓምደ፡ መቅደሱ፨</l>
                  <l n="4">ጸውዓኒ፡ እትሉ፡ እግዚኦ፡ ኀበ፡ እግርከ፡ ያንሶሱ፨</l>
                  <l n="5">ከመ፡ ተለዎ፡ ለሙሴ፡ ኢያሱ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለመልክዕከ፡ በአርአያ፡ ክርስቶስ፡ እለ፡ ተሥዕላ፨</l>
                  <l n="2">እንዘ፡ ኢየሐጽጻ፡ ሕቀ፡ ወእንዘ፡ ኢይትካፈላ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ቀናኢ፡ ናትናኤል፡ ዘገሊላ፨</l>
                  <l n="4">ለሃይማኖትከ፡ እንተ፡ ተሰምዓት፡ በኵላ፨</l>
                  <l n="5">ሤምክዋ፡ በርእስየ፡ ትኩነኒ፡ ቀጸላ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ በስብሐተ፡ አእላፍ፡ እንግልጋ፨</l>
                  <l n="2">ለዛቲ፡ ዓለም፡ እምግብርናቲሃ፡ ወጹጋ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ቶማስ፡ ለመርዓስ፡ ሠራዔ፡ ሕጋ፨</l>
                  <l n="4">ለእለ፡ ይገብሩ፡ ተዝካረከ፡ እንዘ፡ ሀለዉ፡ በሥጋ፨</l>
                  <l n="5">ሀቦሙ፡ እግዚኦ፡ ሞገሰ፡ ወጸጋ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋከ፡ ኤልሳዕ፡ መምህር፡ ዘገነዛ፨</l>
                  <l n="2">በሠናይ፡ ፄና፡ መዓዛ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሰባኪ፡ ፊልጶስ፡ ዘብሔረ፡ ጋዛ፨</l>
                  <l n="4">ለሥጋየ፡ መሬታዊት፡ አመ፡ የሐልቅ፡ ዕዘዛ፨</l>
                  <l n="5">ስብረተ፡ ዓፅምከ፡ ትኩነኒ፡ ቤዛ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ እንዘ፡ ቦቱ፡ ይትመኀፀኑ፨</l>
                  <l n="2">ነገሥተ፡ እስራኤል፡ ኄራን፡ ዘአስተሣነይዎ፡ ለለ፡ ዘመኑ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ሠዋዒ፡ ለእግዚአብሔር፡ ካህኑ፨</l>
                  <l n="4">አድኅነኒ፡ እምፀብአ፡ አርዌ፡ ዘዓሥር፡ ቀርኑ፨</l>
                  <l n="5">ወእምብእሲ፡ ዘክልኤ፡ ልሳኑ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ እምቅድመ፡ ትኑም፡ ውስቴታ፨</l>
                  <l n="2">ታቦተ፡ ማርያም፡ ድንግል፡ ዘአንበርከ፡ በውሳጢታ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ አቡየ፡ ለወልድከ፡ እጓለ፡ ማውታ፨</l>
                  <l n="4">ለበረከትከ፡ ይከልለኒ፡ ረድኤታ፨</l>
                  <l n="5">ወይዑደኒ፡ ዘጽድቅከ፡ ወልታ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">አመ፡ አዕረፈ፡ ተክለ፡ ሃይማኖት፡ ከዊኖ፡ ቅውመ፡ ውስተ፡ ጾማዕቱ፨</l>
                  <l n="2">እንዘ፡ ርኁብ፡ ወእንዘ፡ ጽሙእ፡ ውእቱ፨</l>
                  <l n="3">ላእካነ፡ ማርያም፡ አሜሃ፡ እለ፡ መጽኡ፡ ለአፍልሰቱ፨</l>
                  <l n="4">ተበሀሉ፡ በአርጋኖን፡ ወዘመሩ፡ ሎቱ፨</l>
                  <l n="5">አማን፡ ለጻድቅ፡ ክቡር፡ ሞቱ፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ እምውሳጤ፡ ገዳም፡ ኤላመ፨</l>
                  <l n="2">ወእምኤላምሂኒ፡ ደብረ፡ ሊባኖስ፡ ዳግመ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ባህለ፡ ከመ፡ ወንጌላዊ፡ ቀደመ፨</l>
                  <l n="4">እመ፡ ረከቡ፡ ደቂቅከ፡ በዓለም፡ ሕማመ፨</l>
                  <l n="5">እምኀቤከአ፡ ይርከቡ፡ ሰላመ፨</l>
               </lg>
               <lg type="stanza" n="55">
                  <l n="1">አኮ፡ አኮ፡ በአብዝኆ፡ ነገር፡ ወዝንጋዔ፨</l>
                  <l n="2">አላ፡ ኅዳጠ፡ ወደስኩከ፡ በኢምማዔ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ዘንተ፡ ሠሚረከ፡ ቅድመ፡ ጉባኤ፨</l>
                  <l n="4">በለኒ፡ የሀብከ፡ ለትንቱን፡ እግዚአብሔር፡ ትንሣኤ፨</l>
                  <l n="5">ወቡርክት፡ ማርያም፡ ትኩንከ፡ መጽንዔ፨</l>
               </lg>
               <lg type="stanza" n="56">
                  <l n="1">እንዘ፡ አኀሥሥ፡ በረከተከ፡ አእዳወ፡ ልብየ፡ በአንሥኦ፨</l>
                  <l n="2">እለ፡ መርሐ፡ ክርስቶስ፡ ወጴጥሮስ፡ ከመ፡ ኀሠሡ፡ በተማልኦ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ውሑደ፡ ሰአልኩከ፡ በአስተብቍዖ፨</l>
                  <l n="4">ለጻቅሰ፡ ኅዳጥ፡ ቃል፡ ይበቍዖ፨</l>
                  <l n="5">ተሰጠወኒ፡ እግዚኦ፡ እግዚኦ፨</l>
               </lg>
               <lg type="stanza" n="57">
                  <l n="1">ስብሐት፡ ይደልዋ፡ ለማርያም፡ በሰጊድ፡ ወአስተሐምሞ፨</l>
                  <l n="2">ዘከፈለተኒ፡ ቃለ፡ ከመ፡ እወድከ፡ በኢያርምሞ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ ግበር፡ ለልብየ፡ ዘይኤድሞ፨</l>
                  <l n="4">እስመ፡ ነገርኩ፡ በዐቅሙ፡ ለመልክእከ፡ ሰላሞ፨</l>
                  <l n="5">ወግብረ፡ ዘወሀብከኒ፡ ፈጸምኩ፡ ፈጽሞ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለቀሚስከ፡ ወለቅናትከ፡ ቅዱስ፨</l>
                  <l n="2">ለአጽፍከ፡ ክቡር፡ ወለቆብዕከ፡ ዘርእስ፨</l>
                  <l n="3">ተክለ፡ ሃይማኖት፡ በባሕር፡ ተክለ፡ ሃይማኖት፡ በየብስ፨</l>
                  <l n="4">ለኵሎሙ፡ መነኮሳት፡ ደቂቀ፡ እንጥዖንስ፡ ወመቃርስ፨</l>
                  <l n="5">አንተ፡ መኰንን፡ ወአንተ፡ ንጉሥ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለከ፡ ተክለ፡ ሃይማኖት፡ መናኒ፨</l>
                  <l n="2">አሠረ፡ ወንጌል፡ ዴጋኒ፨</l>
                  <l n="3">ቍርባንከሰ፡ አባ፡ እምቍርባነ፡ አቤል፡ ይሤኒ፨</l>
                  <l n="4">አባ፡ አባ፡ ዘሰአልኩከ፡ ስምዐኒ፨</l>
                  <l n="5">አባ፡ በሰማያት፡ ወልድየ፡ በለኒ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሐዲስ፡ ሐዋርያ፡ ሱታፌ፡ ቶማስ፡ ሰማዕት፨</l>
                  <l n="2">በስባረ፡ እግሩ፡ ዘቆመ፡ መጠነ፡ ሰባዕቱ፡ ዓመት፨</l>
                  <l n="3">ሐጸነቶ፡ ገዳ፡ ወአልኀቀቶ፡ ጸሎት፨</l>
                  <l n="4">ቅዱስ፡ ዘይቤ፡ በስመ፡ ሥላሴ፡ ቅድስት፨</l>
                  <l n="5">ጽጌ፡ ገነት፡ ዘተክለ፡ ሃይማኖት፨</l>
                  <l n="6">ዲበ፡ ህባኔ፡ መልበሱ፡ ስኩዕ፡ ከመ፡ ሱራፌል፡ ካህናት፨</l>
               </lg>
            </div>
         </div>

      </body>
   </text></TEI>
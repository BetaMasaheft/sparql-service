                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_7833">
                           <locus target="#195v">-195v</locus>
                           <q xml:lang="ar">وقع الفراغ \ من نسخة \ هذا لاكتاب \ يوم الجمعة و \ قت الظهر \ في شهر الله \ الاعظم \ هو رمضان \ منه [...]ا</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_7834">
                           <locus target="#225v">-225v</locus>
                           <q xml:lang="ar">[تمت] القصيدة بحمد الله ومنه وكرمه \ وعونه وحسن توفيقه والحمد لله رب \ العالمين واتفق الفراغ من تحرير \ شرح هذه الدرة الوسيلة \ وقت الاستواء من يوم السبت \ سابع وعشرين من شهر جملد الاخر \ سنة ١٣٣٢ \ من الهجرة \ النبوية \ ع م </q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                     </t:list>

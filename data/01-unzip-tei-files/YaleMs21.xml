          <msContents>
            <summary>Psalter, ዳዊት፡</summary>
            <msItem xml:id="ms_i1">
              <locus from="2r" to="184v" facs="002">Fols 2r–184v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
              <msItem xml:id="ms_i1.1">
                <locus from="2r" to="143v" facs="002">Fols 2r–143v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> with the simple
                  modern system</note>
              </msItem>
              <msItem xml:id="ms_i1.2">
                <locus from="144r" to="157v" facs="144">Fols 144r–157v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                <note><locus target="#149r" facs="149">Fol. 149r</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is here identified as <q><foreign xml:lang="gez">ጸሎተ፡ ሐና፡ አመ፡ ሳሙኤል፡ ነቢይ፡</foreign>, Song of Hana, Mother of
                    Samuel, prophet</q></note>
              </msItem>
              <msItem xml:id="ms_i1.3">
                <locus from="158r" to="166v" facs="159">Fols 158r–166v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">, common version</title>
              </msItem>
              <msItem xml:id="ms_i1.4">
                <locus from="167r" to="177v" facs="168">Fols 167r–177v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                <msItem xml:id="ms_i1.4.1">
                  <locus from="167r" facs="168">Fols 167r and following</locus>
                  <title>Monday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.2">
                  <locus from="168r" facs="169">Fols 168r and following</locus>
                  <title>Tuesday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.3">
                  <locus from="169v" facs="171">Fols 169v and following</locus>
                  <title>Wednesday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.4">
                  <locus from="171v" facs="173">Fols 171v and following</locus>
                  <title>Thursday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.5">
                  <locus from="173v" facs="175">Fols 173v and following</locus>
                  <title>Friday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.6">
                  <locus from="175r" facs="176">Fols 175r and following</locus>
                  <title>Saturday</title>
                </msItem>
                <msItem xml:id="ms_i1.4.7">
                  <locus from="176v" facs="178">Fols 176v and following</locus>
                  <title>Sunday</title>
                </msItem>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="177v" to="182v" facs="179">Fols 177v–182v</locus>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
              </msItem>
            </msItem>
          </msContents>
          <physDesc>
            <objectDesc form="Codex">
              <supportDesc>
                <support>
                  <material key="parchment"/>
                </support>
                <extent>
                  <measure unit="leaf">i + 184</measure>
                  <dimensions type="outer" unit="mm">
                    <height>234</height>
                    <width>168</width>
                    <depth/>
                  </dimensions>
                </extent>
              </supportDesc>
              <layoutDesc>
                <layout columns="1" writtenLines="19">
                  <locus from="1r" to="168v" facs="002">Fols 1r–168v</locus>
                </layout>
                <layout columns="2" writtenLines="19">
                  <locus from="169r" to="184v" facs="168">Fols 169r–184v</locus>
                </layout>
              </layoutDesc>
            </objectDesc>
            <handDesc>
              <handNote xml:id="h1" script="Ethiopic">
                <seg type="rubrication">
                  <locus target="#ms_i1.1">Fol. ms_i1.1</locus>
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                </seg>
              </handNote>
            </handDesc>
            <additions>
              <list>
                <item xml:id="e1">
                  <locus target="#158r" facs="158">Fol. 158r</locus>
                  <desc>The book has been foliated, though a page was missed in the foliation.
                    Numbers given here are based on the foliation of the manuscript</desc>
                </item>
                <item xml:id="a1">
                  <locus target="#2r" facs="002">Fol. 2r</locus>
                  <desc type="GuestText">
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</ref> begin with a strophe from <ref type="work" corresp="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</ref>
                  </desc>
                </item>
                <item xml:id="e2">
                  <locus target="#73v" facs="074">Fol. 73v</locus>
                  <desc> It appears that the midpoint of the Psalms was marked at Psalm 77, but
                    erased </desc>
                </item>
                <item xml:id="e3">
                  <locus target="#143r #143v" facs="143 144">Fols. 143r, 143v</locus>
                  <desc> Psalm 151 contains all four of the plusses that constitute the long version
                  </desc>
                </item>
                <item xml:id="a3">
                  <locus target="#154v" facs="155">Fol. 154v</locus>
                  <desc type="ScribalNoteCompleting"> Note of completion of copying the book on the
                    30th of Ḫǝdar </desc>
                </item>
                <item xml:id="e4">
                  <locus target="#169r" facs="170">Fol. 169r</locus>
                  <desc>
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</ref> is arranged to begin on Monday and
                    culminate on Sunday </desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="true">
                <decoNote xml:id="b1">Parchment. Wooden boards, with four chain stitches; fine
                  fabric is visible between the paste downs on the inside covers. Leather
                  bound.</decoNote>
                <decoNote xml:id="b2" type="bindingMaterial">
                  <material key="parchment"/>
                  <material key="wood"/>
                  <material key="textile"/>
                  <material key="leather"/>
                </decoNote>
              </binding>
            </bindingDesc>
          </physDesc>
          <history>
            <origin>
              <origDate notBefore="1800" notAfter="1899">Nineteenth century</origDate>
            </origin>
          </history>

                    <msContents>
                        <msItem xml:id="ms_i1">
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT1399Filkes">Filkǝsyos</title>
                            <textLang mainLang="gez"/>
                            <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">106</citedRange></bibl>
                                notes that the text of this manuscript is especially close to the one in <ref type="mss" corresp="https://betamasaheft.eu/BerOrQuart344">BerOrQuart344</ref>,
                                while 
                                <bibl corresp="http://zotero.org/groups/358366/items/9QK2HWDJ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Zettersteen1899Upsala"/><title level="a">Die Abessinischen Handschriften der Königl. Universitätsbibliothek zu Upsala</title><title level="j">Zeitschrift der Deutschen Morgenländischen Gesellschaft</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">K.V.</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Zetterstéen</t:surname></author><date>1899</date><biblScope unit="volume">53</biblScope><biblScope unit="page">508–520</biblScope><note type="accessed">2024-07-03</note><note type="url">https://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/63139</note><citedRange unit="page">514–515</citedRange></bibl>
                                remarks that the colophons of the three first parts are identical with those in that manuscript.
                                <bibl corresp="http://zotero.org/groups/358366/items/9QK2HWDJ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Zettersteen1899Upsala"/><title level="a">Die Abessinischen Handschriften der Königl. Universitätsbibliothek zu Upsala</title><title level="j">Zeitschrift der Deutschen Morgenländischen Gesellschaft</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">K.V.</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Zetterstéen</t:surname></author><date>1899</date><biblScope unit="volume">53</biblScope><biblScope unit="page">508–520</biblScope><note type="accessed">2024-07-03</note><note type="url">https://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/63139</note><citedRange unit="page">514–515</citedRange></bibl>
                                quotes the incipit of the text.
                                Both note that the text is incomplete at the end but that only little is missing 
                                (<bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">106</citedRange></bibl>:
                                <foreign xml:lang="de">es fehlt aber nur wenig</foreign>). 
                                <bibl corresp="http://zotero.org/groups/358366/items/9QK2HWDJ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Zettersteen1899Upsala"/><title level="a">Die Abessinischen Handschriften der Königl. Universitätsbibliothek zu Upsala</title><title level="j">Zeitschrift der Deutschen Morgenländischen Gesellschaft</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">K.V.</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Zetterstéen</t:surname></author><date>1899</date><biblScope unit="volume">53</biblScope><biblScope unit="page">508–520</biblScope><note type="accessed">2024-07-03</note><note type="url">https://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/63139</note><citedRange unit="page">514–515</citedRange></bibl>
                                notes that the number 217 has been skipped in the numeration of the questions.
                            </note>
                            <incipit xml:lang="gez">
                                <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡</hi> 
                                ቅዱስ፡ <hi rend="partialRubric">፩</hi>አምላክ<hi rend="partialRubric">፤</hi> 
                                እዌጥን፡ በኀይለ፡ 
                                <hi rend="rubric">እግዚአብሔር፡ ወስነ፡ ሀብቱ፡ ለጽ</hi>ሒፈ፡ 
                                አስተጋብአ፡ ዝመጽሐፍ፡ ወውእቱ፡ 
                                ክፍል፡ ቀዳሚ፡ ዘእምተስእሎታት፡ ዜናሆሙ፡ ለአበወ፡ መነኮሳት፡ ግብጻውያን፨
                                ወጸሐፎ፡ ቅዱስ፡ ፊልክስዩስ፡ ሶርያዊ፡ ኤጲስ፡ ቆጶስ፡ ዘመንበግ፡ 
                                ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ገብሩ፡ 
                                <hi rend="rubric"><del rend="erasure" unit="chars" quantity="6"/>ስ፡</hi> 
                                ለዓለመ፡ ዓለም፡ አሜን<hi rend="partialRubric">፨</hi>
                            </incipit>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="1ra" to="13ra"/>
                                <title type="complete">Part 1: Questions 1–16 with answers</title>
                                <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">105</citedRange></bibl>
                                    cites the incipit. He
                                    notes that the explicit of this part (on <locus target="#13ra"/>) mentions that forty questions are missing from
                                    the beginning (<foreign xml:lang="gez">እምቀዳሚሁ፡</foreign>), concluding that the text has been
                                    abbreviated.
                                </note>
                                <incipit xml:lang="gez">
                                    በእንተ፡ ዘከመ፡ ይኄይስ፡ ሥርዓተ፡ ብሕትውና፡ እምሥርዓተ፡ ማኅበር<hi rend="partialRubric">፨</hi>
                                    <hi rend="rubric">ክፍል፡</hi> <hi rend="partialRubric">፩</hi>ይቤሉ፡ 
                                    አኃው፡ ንወጥን፡ እምጥንቱ፡ ለግብር፡ ሀለዉ፡ ክልኤቱ፡ አኃው፡ 
                                    ወልደ፡ ብእሲ፡ ነጋዲ፡ ወሶበ፡ አዕረፈ፡ አባሆሙ፡ ወተካፈሉ፡ ርስቶ፡
                                </incipit>
                                <explicit xml:lang="gez">
                                    ወይደሉ፡ እንከ፡ ለነ፡ ከመ፡ ንእመን፡ ዘይትበሀል፡ በእንተ፡ ቅዱሳን፡ እምዜናውያን፡ 
                                    ጽዱቃውያን<hi rend="partialRubric">፨</hi> ወለእመኒ፡ ኢሀለዉ፡ በአዝማኒነ፡ 
                                </explicit>
                                    <explicit xml:lang="gez">
                                    <locus target="#13ra"/>
                                    ተፈጸመ፡ ክፍል፡ ቀዳሚ፡ በረድኤተ፡ እግዚአብሔር፡ ወነገረ፡ ከመ፡ ተኃጥአ፡ እምቀዳሚሁ፡ 
                                    <hi rend="partialRubric">፵</hi>ተስእሎታት<hi rend="partialRubric">፨</hi>
                                    </explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="13ra" to="18va"/>
                                <title type="complete">Part 2: Questions 17–34 with answers</title>
                                <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">105</citedRange></bibl>
                                    quotes the explicit (on <locus target="#18va"/>) and translates it as follows: "End of the abbreviation of Part 2"
                                    (<foreign xml:lang="de">"Ende der Kürzung von Teil 2"</foreign>). He does not provide the incipit of this part.
                                </note>
                                <incipit xml:lang="gez">
                                    <hi rend="rubric">፲፯እምነ፡ ክፍል፡ ካዕበ፡ ይቤሉ፡ አ</hi>ኃው፡ 
                                    ተርጕም፡ ለነ፡ ቃለ፡ አባ፡ መቃርስ፡ ቀሲስ፡ ዘይቤ፡ አንሰ፡ ኢያቅረብክዎ፡ 
                                    ግሙራ፡ ለማርቆስ፡ ዘየዓቢ፡ አላ፡ መልዓክ፡ እግዚእ፡ ኮነ፡ ይሜጥዎ፡ 
                                    በዕዴሁ፡ እምሥዋዕ<hi rend="partialRubric">፨</hi>
                                </incipit>
                                <explicit xml:lang="gez">
                                    ወይቤ፡ ወቅሪስኒ፡ ለእመ፡ ተሞአ፡ ረድእከ፡ ስርዮ፡ ወለእመ፡ ሞአ፡ ሰብሖ<hi rend="partialRubric">፨</hi>
                                    እስመ፡ ሰብሖ፡ ይዌስኮ፡ ጽኑዕ፡ <sic resp="JK">ኃይላ</sic><hi rend="partialRubric">፨</hi>
                                </explicit>
                                <explicit xml:lang="gez">
                                    <locus target="#18va"/>
                                    ተፈጸመ፡ <sic resp="PRS6337Lofgren">ዘአኅፅሮ፡</sic> ኪያሁ፡ ዘውስተ፡ 
                                    ክፍል፡ <sic resp="JK">ካዕበ</sic><hi rend="partialRubric">፨</hi>
                                </explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="18va" to="22ra"/>
                                <title type="complete">Part 3: Questions 35–43 with answers</title>
                                <note><bibl corresp="http://zotero.org/groups/358366/items/X4SBAXAT"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1974Katalog"/><title level="m">Katalog über die äthiopischen Handschriften in der Universitätsbibliothek Uppsala, Sowie Anhänge über äthiopische Handschriften in anderen Bibliotheken und in Privatbesitz in Schweden</title><title level="s">Acta Bibliothecae R. Universitatis Upsaliensis</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><pubPlace>Uppsala</pubPlace><publisher>Almqvist &amp; Wiksell</publisher><date>1974</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Bibliothecae R. Universitatis Upsaliensis</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">18</t:biblScope></series><biblScope unit="volume">18</biblScope><citedRange unit="page">106</citedRange></bibl>
                                    notes that the explicit (on <locus target="#22ra"/>) is also found in <ref type="mss" corresp="https://betamasaheft.eu/BerOrQuart344">BerOrQuart344</ref>
                                    and translates it as follows: "Full is Part 3 in the abbreviation by <foreign xml:lang="gez-tr">Yǝrunāmes</foreign>
                                    (<persName ref="https://betamasaheft.eu/PRS5340Hieronym">Jerome</persName>), who attributed to <persName ref="https://betamasaheft.eu/PRS7706Palladiu">Palladius</persName>
                                    the 'Questions' and two chapters, for he wrote in the time of 
                                    <persName ref="https://betamasaheft.eu/PRS9479Theodosi">Theodosius the Great</persName>, but 
                                    <persName ref="https://betamasaheft.eu/PRS7706Palladiu">Palladius</persName> wrote under his son
                                    <persName ref="https://betamasaheft.eu/PRS2016Arcadius">Arcadius</persName>"
                                    (<foreign xml:lang="de">voll ist Teil III in der Abkürzung von <foreign xml:lang="gez-tr">Yerunāmes</foreign>
                                        (Hieronymus), der die 'Fragen' und 2 Kapitel dem Palladius zugeteilt hat, denn er schrieb in der Zeit von
                                        Theodosius dem Großen, Palladius aber unter seinem Sohn Arkadius</foreign>).
                                </note>
                                <incipit xml:lang="gez">
                                    <hi rend="rubric">ክፍል፡ ሣልስ፡ ፴፭ይቤሉ፡ አኃው፡ እስ</hi>መ፡ 
                                    ጳውሎስ፡ ሐዋርያ፡ ይብል፡ ተፋቅሮ፡ ኢያወድቅ፡ ግሙራ<hi rend="partialRubric">፨</hi>
                                </incipit>
                                <explicit xml:lang="gez">
                                    ወሶቤሃ<sic resp="JK">፡ </sic> ኬ፡ ትበርህ፡ ንጽሐ፡ ልብ፡ 
                                    ወይበርህ፡ ልቡናከ፡ ከመ፡ ኮከብ፡ ትሬእዮ፡ በውስተ፡ ጸሎትከ<hi rend="partialRubric">፨</hi>
                                </explicit>
                                <explicit xml:lang="gez">
                                    <locus target="#22ra"/>
                                    መልአ፡ ክፍል፡ ሣልስ፡ በአሕፅሮ፡ ለ<persName ref="https://betamasaheft.eu/PRS5340Hieronym">ይሩናሜስ፡</persName> 
                                    ዘአንበሮ፡ ተስእሎታተ፡ ወ፪ክፍላተ፡ ለ<persName ref="https://betamasaheft.eu/PRS7706Palladiu">በላድዮስ፡</persName> እስመ፡ 
                                    ውእቱ፡ ጸሐፈ፡ በአዝማነ፡ <persName ref="https://betamasaheft.eu/PRS9479Theodosi">ትዮዶስዮስ፡</persName> ዘየዓቢ፡ 
                                        ወ<persName ref="https://betamasaheft.eu/PRS7706Palladiu">ብላድዮስ፡</persName> ጸሐፈ፡ 
                                        በዘመነ፡ <persName ref="https://betamasaheft.eu/PRS2016Arcadius">አርቃድዮስ፡</persName> 
                                    ወልዱ<hi rend="partialRubric">፨</hi> ለእግዚአብሔር፡ አኰቴት፡ ለዓለመ፡ ዓለም፡ 
                                    አሜን<hi rend="partialRubric">፨</hi> ወትረ<hi rend="partialRubric">፨</hi>
                                </explicit>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="22ra" to="91vb"/>
                                <title type="complete">Part 4: Questions 44–244 with answers</title>

                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_846">
                           <locus target="#Througout">-Througout</locus>
                           <q xml:lang="ar">اللهم صل وسلم على سيدنا ومولنا محمد وعلى ال سيدنا محمد مصباح دلائل الدقائق صح</q>
                           <desc>Marginalia</desc>
                           <note>Corrections in the margins. Example in fol. 27v</note>
                           <note/>
                        </item>
                        <item xml:id="a2_846">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">كتاب تنبيه الانام في علو مقامسيدنا ونبينا محمد عليه افضل الصلاة وازكى السلام</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_846">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Double or multiple circles with text as markers for completion of hundreds.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_846">
                           <locus target="#171r - 173r">-171r - 173r</locus>
                           <q xml:lang="ar">بسم الله الرحمن الرحيم الحمد الله الذي زين السماء الاذكار بالصلاة على النبي المختار واطلع سنا ءانوارها مطالع الشموس والاقماروجعلها وسيلة معينة لقضاء الاوطار ومحو الذنوب والاوزار واشهد أن لا اله الا الله وحده لا شريك له الواحد القهار رب السموات والأرض وما بينهما العزيز الغفار واشهد ان سيدنا ومولانا محمداً عبده ورسوله كنز الادخار صلى الله عليه وعلى آله وصحبه صلاة دائمة التكرار تدوم بدوام الليل والنهار والعشي والإبكار وسلم تسليماً كثيراً
</q>
                           <note>The folios are placed upside down in the end of the manuscript.</note>
                           <note>
                              <desc>
                                 <ref type="work" corresp="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</ref>
                              </desc>
                           </note>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <locus target="#38v">-38v</locus>
                           <desc>Marginalia</desc>
                           <q>كتب بزيادة الالف في الرسم \ فظا عليظ كلاهما بالظاء</q>
                           <note>Note on spelling</note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#11r">-11r</locus>
                           <desc>Marginalia</desc>
                           <q>فائدة ابرهيم بلا الف بعد الراء [...] وهذه الثلثة والثلثون [.؟.] اه ا هشام</q>
                           <note>Marginal note marked Hišām</note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#80v">-80v</locus>
                           <desc>Marginalia</desc>
                           <q>اللهم بحق سورة الانعام وبحق اسماء العظام [...] واخذ جوابنا سريعا فهذه الحاجة وحوائج المسلمين</q>
                           <note>Placed at sūra 6, verses 128-129.</note>
                        </item>
                        <item xml:id="a4">
                           <locus target="#105r">-105r</locus>
                           <desc>Marginalia</desc>
                           <q>اعوذ بالله من النار ومن شر الكفار ومن غضب الجبار العزة لله ولرسوله وللمؤمنين</q>
                           <note>Placed at the beginning of sūra 9.</note>
                        </item>
                        <item xml:id="a5">
                           <locus target="#Throughout">-Throughout</locus>
                           <desc>Marginalia</desc>
                           <q>Taǧwīd marks and comments</q>
                           <note>Recitation marks. Interlinear marks, comments in the margins in red.</note>
                        </item>
                        <item xml:id="a6">
                           <locus target="#33r-102r">-33r, 102r</locus>
                           <desc>Ǧuz' markers: the word ǧuz'</desc>
                           <q/>
                           <note>In black ink, carelessly written.</note>
                        </item>
                        <item xml:id="a7">
                           <locus target="#12v-44v-56r-67v. 113r-148v">-12v, 44v, 56r, 67v. 113r, 148v</locus>
                           <desc>Ǧuz' markers: word ǧuz' with number in letters</desc>
                           <q/>
                           <note>In red.</note>
                        </item>
                     </t:list>

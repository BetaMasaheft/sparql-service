                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="173r">2r-173r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>باب في فضل الصلاة على النبي صلى الله عليه وسلم وشرف وكرم ومجد وعظم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#171r">-171r</locus>وصل اللهم بجلالك وسلم وبارك على سيدنا ومولانا محمد خاتم النبيين , وامام المرسلين , والحمد لله رب العالمين تمت بحمد لله وعونه وكرمه والحمد لله رب العالمين تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

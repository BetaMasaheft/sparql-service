                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="15r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1933Mashaf">Maṣḥafa ḥāwi</title>
                          <textLang mainLang="gez"/>

                          <msItem xml:id="ms_i1.1">
                            <locus from="15r" to="20v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1933Mashaf#Introduction">Maṣḥafa ḥāwi: Introduction followed by the table of the 63 rubrics and a short explanation by the translator on his methods.</title>
                            <textLang mainLang="gez"/>
                          </msItem>

                          <msItem xml:id="ms_i1.2">
                            <locus from="21r"/>
                            <title type="complete">Main part of the work</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.3">
                            <locus target="#268v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1933Mashaf#ColophonTranslation">Maṣḥafa ḥāwi: On the time of this work's composition</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <colophon xml:id="coloph1" xml:lang="gez">
                            <locus from="269r"/>
                            ዝንቱ፡ መጽሐፍ፡ ሓዊ፡ ተጽሕፈ፡
                            <date calendar="world" when-custom="7237" when="1745">በዓመት፡ ፸፻ወ፪፻፴ወ፯ ዘከመ፡ እምፍጥረተ፡ ዓለም፡</date>
                            በግዕዝ፡ ወዘከመ፡ ሐሳቦሙ፡ ለቅብጣውያን፡ ወዮናናውያን፡ ፷፻ወ፰፻ወ፫። ዘከመ፡
                            ሐሳቦሙ፡ ለዕብራውያን፡ ፳፻፶ወ፬ እምዓመተ፡ እስክንድር፡ ዮናናዊ፡
                            <date calendar="ethiopian" when-custom="1747">
                            ወበ፲፻ወ፯፻፵ወ፯ እምዓመተ፡ ሥጋዌሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡
                            መድኅነ፡ ዓለም፡</date>
                            <date calendar="diocletian" when-custom="1459">ወበ፲፻ወ፬፻፶ወ፱ እምዓመተ፡ ሰማዕታይ፡ ንጹሓን፡</date>
                            ወበ፲፻ወ፩፻ወ፶ እምዓመተ፡ አጋር፡ ዕብናዊ። ወበ፲ወ፬ ዓመተ፡ መንግሥቱ፡
                            ለመፍቀሬ፡ እግዚአብሔር፡ ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName>
                            ወወላዲቱ፡ ንግሥትነ፡ <persName ref="https://betamasaheft.eu/PRS2682BerhanM">ወለተ፡
                            ጊዮርጊስ፡</persName> በዘመነ፡ ዮሐንስ፡ በየካቲት፡ በ፮ ዕላት፡ በ፮ ሰዓት፡ በዕለተ፡ ሐሙስ።
                          </colophon>
                        </msItem>

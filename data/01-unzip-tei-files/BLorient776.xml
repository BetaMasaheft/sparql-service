                            <item xml:id="a2">
                              <locus target="#4r"/>
                              <desc type="Inventory">List of property of the convent of
                                  <placeName ref="https://betamasaheft.eu/INS0330DDQ">Dabra Ḍaḥay Qʷǝsqʷām</placeName> from the year
                            <date when="1776">1776</date>.</desc>
                            <q xml:lang="am">
                            <date calendar="world" when-custom="7258">በ፸፻ወ፪፻፶ወ፰ ዓመተ፡ ዓለም።</date>
                                በዘመነ፡ ማርቆስ፡ ሠረቀ፡ ሚያዝያ፡ በ፲፰ ቀን፡ ሐሙስ፡ ኍልቈ፡ ንዋይ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0330DDQ">ደብረ፡ ፀሐይ፤</placeName>
                            ቍጻሪ፡ መልአከ፡ ፀሐይ፡ ቴዎድሮስ፡
                                አስቆጸሮች፡ <persName ref="https://betamasaheft.eu/PRS13813Armasqos"><roleName type="title">አዛዢ፡</roleName> አርማስቆስ፡</persName>
                                ሊቀ፡ ፋሲሎ፤
                            አዛዢ፡ አቤሴሎም፡ ተቀባዩ፡ ሊቀ፡ ጠበብት፡ ጉብጭ። ፩ ቀይ፡ ከፈይ፡ ካፓ፡ ከራዎቱ።
                            ፪ ሰማያዊ፡ ሲኒ፡ ካፓ፡ ከራዎቱ። ፩ ቀይ፡ መስ፡ ካፓ።
                          </q>
                            </item>
                            <item xml:id="a3">
                              <locus target="#15r"/>
                              <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                  <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                              <q xml:lang="gez">ሐዊ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam"> ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                        </q>
                            </item>
                          </list>


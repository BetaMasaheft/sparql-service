                        <decoDesc>
                            <decoNote type="miniature" xml:id="d1">
                              <locus target="#1v">Fol. 1v</locus>
                              <desc>
                                A haloed <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> hold the <term key="sword" ana="#sword"/> in his right hand. Human souls are crambling on his wings. A chained blue Satan is burning down his feet in a fire.
                                The scene is set in a pink frame with fading colors in the background: blue, yellow and green.
                              </desc>
                            </decoNote>
                            <decoNote type="band" xml:id="d2">
                              <locus target="#3r">Fol. 3r</locus>
                              <desc>
                                Geometrical band at the incipit of the text in black, red, blue and yellow color.
                              </desc>
                            </decoNote>
                            <decoNote type="miniature" xml:id="d3">
                              <locus target="#12v">Fol. 12v</locus>
                              <desc>
                                Schematized figure of the archangels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>, identified by the caption <foreign xml:lang="gez">ቅዹስ ሚካኤል፡</foreign>
                                and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName>, identified by the caption <foreign xml:lang="gez"> ቅዹስ ገብርኤል፡</foreign> are depicted with geometrical pattern:
                                Their face is triangular, the body a simple rectangle.
                                Fading colors in the background: yellow and blue.
                              </desc>
                            </decoNote>
                            <decoNote type="band" xml:id="d4">
                              <locus target="#28r #33r">Fols. 28r, 33r</locus>
                              <desc>
                                Geometrial band in black and red ink.
                              </desc>
                            </decoNote>
                            <decoNote type="miniature" xml:id="d5">
                              <locus target="#94r">Fol. 94r</locus>
                              <desc>
                                A bearded hooked figure holds a horn in his left hand and pour water on an unbearded kneeling figure. Fading colors in the background: blue, yellow and red.
                              </desc>
                            </decoNote>
                            <decoNote type="punctuation" xml:id="d6">
                              <locus target="#9rb #12rb #12vab #18va #28ra #46va #48vb #49ra #53ra #55rb #55vb #57vb #60vb #66rb #73va #75rb #88rb #94ra">Fols. 9rb, 12rb, 12vab, 18va, 28ra, 46va, 48vb, 49ra, 53ra, 55rb, 55vb, 57vb, 60vb, 66rb, 73va, 75rb, 88rb, 94ra</locus>
                              <desc>
                                Row of red and black dots.
                              </desc>
                            </decoNote>
                        </decoDesc>


               <msContents>
                  <summary/>
                     
                  <msItem xml:id="ms_i1">
                        <locus from="3r" to="76r">Fols 3r–76r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                        <textLang mainLang="gez"/> 
                     <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/> 
                        ብስረተ፡ አብ፡ ቅዱስ፡ ትሩፍ፡ ረድእ፡</incipit> 
                     <note>The new scribe beginning on <locus target="#61r">fol. 61r</locus> has noticed the discrepancies in his predecessor's
                     chapter numbering, so he begins a new system of counting, but often omits to indicate the number of the chapter altogether, 
                     writing <foreign xml:lang="gez">ምዕራፍ</foreign> only. See <locus target="#61v">61v, </locus> and <locus target="#63v">63v</locus>.</note>
                     <note>Chapter 4 in this manuscript corresponds to 3:22 in printed editions.
                     Chapter 5 beginning on <locus target="#13r">fols. 13r, </locus> corresponds to 4:1 in printed editions.
                     Chapter 6 corresponds to 4:4 in printed editions. Chapter 7 beginning on <locus target="#17r">17r</locus> corresponds
                     to 4:45 in printed editions. There are similar discrepancies elsewhere.</note>
                     <note>The text differs considerably from the printed edition.</note>
                     <colophon xml:id="coloph1" xml:lang="gez">
                       
                        መልአ፡ ጽሕፈተ፡ ብስራቱ፡ ለዮሐንስ፡ ወንጌላዊ፡ ወልደ፡ ዘብዴዎስ፡ ሐዋርያ፡ ፩ እም ፲ወ፪ ሐዋርያት፡ ዘጸሐፎ፡ በልሳነ፡ ዮናናውያን፡ 
                        ለ<sic resp="DR">ስ</sic>ብአ፡ ሀገረ፡ ኤፌሶን። 
                        እምድኅረ፡ እርገቱ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ በሥጋ፡ ውስተ፡ ሰማይ። በ፴ወ፰ ዓመት፡
                        <choice>
                           <sic resp="PRS9622Ullendor">መንግቱሥቱ፡</sic>
                           <corr resp="PRS9622Ullendor">መንግሥቱ፡</corr>
                        </choice>
                        ለኔሮን፡ ወልደ፡ ቀለውዴዎስ፡ ቄሳር፡ ንጉሠ፡ ሮሜ፡ 
                        ስብሐት፡ ለእግዚአብሔር፡ ሣህሉ፡ ወምሕረቱ፡ የሀሉ፡ 
                        <choice>
                           <sic resp="PRS9622Ullendor">ምለገብሩ፡</sic>
                           <corr resp="PRS9622Ullendor">ምስለ፡ ገብሩ፡</corr>
                        </choice>
                        <gap reason="lost" extent="unknown"/> ለዓለመ፡ ዓለም፡ አሜን፡ <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/>
                     </colophon>

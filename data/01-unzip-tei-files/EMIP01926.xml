                        <note>The fourth biblical canticle is Prayer of Hana, Mother of Samuel, prophet</note>
                      </msItem>
                      <msItem xml:id="ms_i1.3"><locus from="170r" to="181v" facs="176">Fols 170r–181v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>

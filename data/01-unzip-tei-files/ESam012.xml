               <msContents>
                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="70v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2342serata">Śǝrʿāta ʾasira mǝnkʷǝsǝnnā ‘The Order of Binding (to) Monasticism’</title>
                     <note>The manuscript contains a text different from <t:ref xmlns:t="http://www.tei-c.org/ns/1.0" type="mss" corresp="https://betamasaheft.eu/ESaqm010">AQM-010</t:ref> and <t:ref xmlns:t="http://www.tei-c.org/ns/1.0" type="mss" corresp="https://betamasaheft.eu/ESdd041">DD-041</t:ref>. </note>
                     <incipit xml:lang="gez">
                        <locus target="#2ra"/>
                        <hi rend="rubric">በስመ፡<gap reason="ellipsis"/> ዝንቱ፡ ሥርዓ</hi>ት፡ አሲረ፡ ምንኵስና፨ <hi rend="rubric">በአስኬማ፡
                        ቅዱስ፡ እመ</hi>ቦ፡ ዘፈቀደ፡ ይልበስ፡ አስኬማ፡ ቅዱስ፡ ዝውእቱ፡ ለምንኵስና፡ ይንበር፡ ማእከለ፡ መነኮሳት፡ ፩፡ ዓመተ፡ ያመክር፡ ርእሶ፡ ወይትገሠጽ፡ ብዙኃ፨
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#70va3"/><gap reason="ellipsis"/>ወግሩም፡ እስመ፡ ሙሉእ፡ ወቡሩክ፡ ስብሐተ፡
                        ስምከ፨ ኦሥሉስ፡ ቅዱስ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ኵሎ፡ ጊዜ፡ ይእዜኒ፧ ወዘልፈኒ፧ ወለዓለምመ፧ ዓለም፧ አሜን፧ ወአሜን፨ 
                     </explicit>
                     <msItem xml:id="ms_i1.1">
                        <locus from="2ra"/>
                        <title>Requirements for the novitiate; preparation of the ritual</title>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡<gap reason="ellipsis"/>ዝንቱ፡ ሥርዓ</hi>ት፡ አሲረ፡ ምንኵስና፨ በአስኬማ፡ ቅዱስ፡ እመቦ፡
                           ዘፈቀደ፡ ይልበስ፡ አስኬማ፡ ቅዱስ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus target="#3va"/>
                        <title>Investigation of the candidate, and rules given to him to observe as a monk</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ትእዛዘ፡ መነኮሳት፡</hi> ኦእኁ፡ ለምንት፡ መጻእከ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus target="#7va"/>
                        <title>Continuation; further directives for the ritual</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ትእዛዘ፡ መነኵስና።</hi> ለገቢረ፡ ሠናይ፡ ናሁ፡ ጾርከ፡ አስኬማ፡ ዘመላእክት፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus target="#10vb"/>
                        <title>Prayer of thanksgiving over the girdle</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡ አኰቴት።</hi> ለማዕሰር፡ ይብል፡ ካህን፨</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus target="#11va"/>
                        <title>Prayer of the tonsure</title>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡</hi><gap reason="ellipsis"/>ዝንቱ፡ ሥርዓት፡ ዘመነኮሳት፡ ሕገ፡ ምንኵስና፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus target="#15ra"/>
                        <title>Prayer of thanksgiving over the monastic habit</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡ አኰቴት።</hi> ወካዕበ፡ ላዕለ፡ መልበስ፡<hi rend="rubric"> ነአኵተከ፡ ኪያከ።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus target="#15vb"/>
                        <title>Prayer over the girdle</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡ ላዕለ፡ ቅናት፡ አምላክ፡ ዘለዓለም፡ ዘይጼዓን፡</hi> ዲበ፡ ሰረገላ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus target="#18vb"/>
                        <title>Blessing of the girdle</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡ ቡራኬ፡ ላዕለ፡ ቅናት፡ እግዚእነ፡</hi> ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፨ ዘእምብዝኃ፡ ምሕረቱ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus target="#20rb"/>
                        <title>New Testamental readings</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወጳውሎስ፡ ኤፌሳን፡ ጽንዑ፡</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus target="#25rb"/>
                        <title>Prayer over the candidate</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወእምድኅሬሁ።</hi> ሰላም፡ ወትጸርኅ፡ ወትብል፡ ኪርያላይሶን፡ ፵፩፡ ጊዜ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus target="#25va"/>
                        <title>Prayer while putting on the girdle</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወተአሥር፡ ሐቌሁ፡ በቅናት፡ ዘአዲሞ።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus target="#25vb"/>
                        <title>Prayer while putting on the clothes</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወታቀንቶ፡ ወታለብሶ፡ ልብስ፡</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.13">
                        <locus target="#26ra"/>
                        <title>Prayer of thanksgiving after putting on the clothes</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወትብል፡</hi> ጸሎተ፡ አኰቴት፡ እምድኅረ፡ ለብስ፡ ልብስ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.14">
                        <locus target="#27ra"/>
                        <title>Prayer after putting on the girdle</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡</hi> እምድኅረ፡ አቅነትከ፡ መነኮሳት፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.15">
                        <locus target="#27rb"/>
                        <title>Prayer over the virgins</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡</hi> ላዑለ፡ ደናግል፡ <sic>ወለያልያት፡</sic></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.16">
                        <locus target="#28ra"/>
                        <title>Directives for the ritual</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ትብል፡</hi> ቅዱስ፡ ቅዱስ፡ ቅዱስ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.17">
                        <locus target="#28vb"/>
                        <title>Precepts to be read to the monk</title>
                        <incipit xml:lang="gez"><hi rend="rubric">እምድኅረ፡ ፈጸምከ፡ ምንኵስና፡ ላዕሌሆሙ፡</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.18">
                        <locus target="#37ra"/>
                        <title>Directives for the ritual</title>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡</hi><gap reason="ellipsis"/> እምቅድመ፡ ኵሉ፡ ትጼሊ፡ ጸሎተ፡ ወንጌል፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.19">
                        <locus target="#37vb"/>
                        <title>Prayer over the monastic cap (<foreign xml:lang="gez">qobʿ</foreign>)</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎተ፡</hi> ላዕለ፡ ቆብዕ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.20">
                        <locus target="#40ra"/>
                        <title>New Testamental readings</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጳውሎስ፡</hi> ለሰብአ፡ ዕብራውያን፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.21">
                        <locus target="#45va"/>
                        <title>Narration concerning St Anthony</title>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡</hi> ድኅረ፡ ፈጸምከ፡ ላዕሌሁ፡ ዘንተ፡ ቃለ፡ ነገረ፡ ዘአባ፡ እንጦንስ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.22">
                        <locus target="#46rb"/>
                        <title>Directive for the ritual about the scapular (<foreign xml:lang="gez">ʾaskemā</foreign>)</title>
                        <incipit xml:lang="gez"><hi rend="rubric">በስመ፡</hi> ዝንቱ፡ ስእለታት፡ ዘይትነበብ፡ ላዕለ፡ አስኬማ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.23">
                        <locus target="#46va"/>
                        <title>Prayer over the scapular (<foreign xml:lang="gez">ʾaskemā</foreign>)</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወትብል፡ ዘንተ፡ ጸሎት፡</hi> ላዕለ፡ አስኬማ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.24">
                        <locus target="#47va"/>
                        <title>New Testamental readings</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ለሰብአ፡ ገላትያ።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.25">
                        <locus target="#51ra"/>
                        <title>Prayer</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወእምድኅሬሁ፡ ትብል፡ ዘንተ፡ እግዚአብሔር፡ እግዚ</hi>እነ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.26">
                        <locus target="#51va"/>
                        <title>Prayer</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡</hi> ወካዕበ፡ እምድኅሬሁ፡ እግዚአብሔር፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.27">
                        <locus target="#51vb"/>
                        <title>Prayer over virgins</title>
                        <incipit xml:lang="gez"><hi rend="rubric">መነኮሳት፡</hi> ደነግል፡ ይትዓሰሩ፡ በአስኬማ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.28">
                        <locus target="#52va"/>
                        <title>Prayer over virgins</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡ ዘደናግል።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.29">
                        <locus target="#52vb"/>
                        <title>Prayer over monks</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡ ላዕለ፡ መነኮሳት።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.30">
                        <locus target="#54ra"/>
                        <title>Prayer over a would-be nun</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡</hi> ላዕለ፡ ብእሲት፡ እንተ፡ ትፈቅድ፡ ኀቤከ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.31">
                        <locus target="#55rb"/>
                        <title>New Testamental readings</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ዘጢሞቴዎስ።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.32">
                        <locus target="#57va"/>
                        <title>Prayer over the scapular</title>
                        <incipit xml:lang="gez">ጸሎት፡ ላዕለ፡ አስኬማ።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.33">
                        <locus target="#59vb"/>
                        <title>Prayer over the scapular</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ጸሎት፡ ላዕለ፡ አስኬማ።</hi></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.34">
                        <locus target="#60vb"/>
                        <title>Prayer</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወእምድኅሬሁ።</hi> ወታነብብ፡ ዘንተ፡ ጸሎተ፡ ወበል፡ እግዚኦ፡ አምላከ፡ ኃያላን፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.35">
                        <locus target="#63ra"/>
                        <title>Prayer 1</title>
                        <incipit xml:lang="gez">እግዚእ፡ እግዚኦ፡ መናፍስት፡ ወለኵሉ፡ ፍጥረት፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.36">
                        <locus target="#65ra"/>
                        <title>Prayer 2</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ወካዕበ፡</hi> ናስተበቍዕ፡ ወነኃሥሥ፡ በኀቤከ፡ እግዚእነ፡ ኢያሱስ፡ ክርስቶስ።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.37">
                        <locus target="#65vb"/>
                        <title>Prayer 3</title>
                        <incipit xml:lang="gez"><hi rend="rubric">ሣልስ፡ ጸሎት።</hi> ዘይትነበብ፨</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.38">
                        <locus target="#66va"/>
                        <title>Prayer 4</title>

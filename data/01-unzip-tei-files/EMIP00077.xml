         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Bernhardt</repository>
                  <collection>EMIP</collection>
                  <idno n="111" facs="EMIP/Codices/77/" corresp="https://betamasaheft.eu/api/iiif/EMIP00077/manifest">Bernhardt Codex</idno>
               </msIdentifier>
               <msContents>
                  <summary>Calendar of the feasts of the year, Asmat prayer against evil eye</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="28r" facs="003">Fols 1r–28r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="25r" to="30v" facs="027">Fols 25r–30v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2940RepCh221">Malkǝʾ-hymn to Our
                                                  Lady Mary</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="31r" to="38v" facs="033">Fols 31r–38v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="38v" to="39v" facs="041">Fols 38v–39v</locus>
                     <title>Prayer against demons with the <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> preserved in the <title ref="https://betamasaheft.eu/LIT1295Dersan">Dǝrsāna
                                                  Mikāʾel</title>
                     </title>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="40r" facs="042">Fols 40r and following</locus>
                     <title>List of the sufferings of Jesus during Passion Week</title>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="40v" to="41v" facs="043">Fols 40v–41v</locus>
                     <title>Erased, but probably a certain <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> prayer</title>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="41v" facs="044">Fols 41v and following</locus>
                     <title>The beginning of an Amharic letter, in a crude hand</title>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">ii + 41 </measure>
                           <measure unit="quire">Protection sheet + 5</measure>
                           <dimensions type="outer" unit="mm">
                              <height>128</height>
                              <width>82</width>
                              <depth>25</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Quire descriptions: quires 1–5 balanced. Double-slip case with leather strap.</note>
                          <list>
                              <item xml:id="q1" n="a">
                                 <dim unit="leaf">2</dim>
                                 <locus from="i" to="ii" facs="001">Fols i–ii</locus>
                                 <note>The protection sheet is upside down and backwards in relation to the rest of the codex.</note>
                              Protection Sheet
                            </item>
                              <item xml:id="q2" n="1">
                                 <dim unit="leaf">10</dim>
                                 <locus from="1" to="10" facs="003">Fols 1–10</locus>
                              Quire 1
                            </item>
                              <item xml:id="q3" n="2">
                                 <dim unit="leaf">10</dim>
                                 <locus from="11" to="20" facs="013">Fols 11–20</locus>
                              Quire 2
                            </item>
                              <item xml:id="q4" n="3">
                                 <dim unit="leaf">10</dim>
                                 <locus from="21" to="30" facs="023">Fols 21–30</locus>
                              Quire 3
                            </item>
                              <item xml:id="q5" n="4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="31" to="38" facs="033">Fols 31–38</locus>
                              Quire 4
                            </item>
                              <item xml:id="q6" n="5">
                                 <dim unit="leaf">2</dim>
                                 <locus from="39" to="40" facs="042">Fols 39–40</locus>
                              Quire 5
                            </item>
                              <item xml:id="q7" n="6">
                                 <dim unit="leaf">1</dim>
                                 <locus target="#41" facs="043">Fol. 41</locus>
                                 <note>
                                    <locus target="#41" facs="043">Fol. 41</locus> is a single half-folio attached to the binding of the codex (as a protection sheet?).</note>
                              Quire 6:
                              1, no stub
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top" atLeast="5" atMost="7">5-7</dim>
                              <dim type="bottom">30</dim>
                              <dim type="right">15</dim>
                              <dim type="left">7</dim>
                           </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="16"/>
                     </layoutDesc>
                  </objectDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <desc>
                              <locus target="#iir(ecto) #iv(erso)" facs="002">Fols. iir(ecto), iv(erso)</locus> Calendar of the feasts of the year, bound upside down</desc>
                        </item>
                        <item xml:id="a2">
                           <desc type="Asmat">Asmat prayer against evil eye, with incipit
                          <foreign xml:lang="gez">
                            በስመ፡ አብ፡<gap reason="omitted"/>ጸሎተ፡ ነደራ፡ በዕንተ፡ ሕማመ፡ ዓይነት፡ አትሪኮን፡ በትሪኮን፡ ፓተሮ፡ ፎሪኮን፡ አትርጋዎን፡ በኃይለ፡ ዝንቱ፡ አስማቲከ፡ አድህና፡ እምሕማመ፡ ዓይነ፡ ሰብዕ፡ ለ<gap reason="omitted"/>
                          </foreign>
                           </desc>
                        </item>
                        <item xml:id="a3">
                           <desc>
                              <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus> What seems a proper name: <foreign xml:lang="gez">ባለ፡ ጠካሴ፡</foreign>(?)</desc>
                        </item>
                        <item xml:id="a4">
                           <desc>
                              <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus> Unintelligible words</desc>
                        </item>

                        <item xml:id="e1">
                           <desc>
                          Most of the pages are water stained along their top outer edges. The water has caused some of the ink to run.
                          The last page of the manuscript is heavily water damaged. The text on this page is almost completely washed off
                        </desc>
                        </item>
                        <item xml:id="e2">
                           <desc>The lower and outer edges of many pages are darkened from use and from water stains</desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                        <decoNote xml:id="b1">Parchment, 128 x 82 x 25 mm, two secondary stitches attached to rough-hewn boards.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3">
                        The stitching has been done with two different types of string. One type, is a stiff parchment colored string made up of very
                        thin strands of some type of animal (?) material. The other type, is a cotton based string. Green, orange, and light tan colored
                        cotton strings have been used. Each quire of pages is bound using a different type/color of string, sometimes two. This mixture of
                        string types and colors are probably the result of rebinding or repair efforts done over time. New string was added to replace
                        or reinforce a worn or broken string or to bind in new quire of pages
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1907">reign of Metropolitan Matewos (1889-1926)</origDate>
                  </origin>
                  <provenance>
                    Provenance: Owned by Theodore Bernhardt Jr., Edgewater Park, New Jersey. Purchased June 25, 2002 (eBay Item #888884839) from Adam Langweiler,
                    Amsterdam, the Netherlands. (Before 2002) Private collection of Coptic and Ethiopian manuscripts
                  </provenance>
                  <provenance>
                    Publication: On-line presentation of the manuscript – August 30, 2002 to present (as of April 2006). Ethiopian Manuscript Prayer Book http://members.tripod.com/~palaeography/index.html. Note: This was the first Ethiopian manuscript codex to be presented in its entirety on the World Wide Web
                  </provenance>
               </history>
            </msDesc>

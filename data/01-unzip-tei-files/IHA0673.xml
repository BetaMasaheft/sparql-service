               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" from="2r" to="10v">2r-10v</t:locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1224IHA">جالية الكدر وجالبة المطلوب</title>
                     <incipit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#2r">-2r</t:locus>بسم الله الرحمن الرحيم الحمد لله ولي الخيرات ثم صلاته على ذى الفيضات| فندعوك ربى بانوار الصفات بمظهر الاسماء بسر الذات| بسر سرك وبالطلسمات بالكنز المخفي من الاشارات

</incipit>
                     <explicit xml:lang="ar">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#10v">-10v</t:locus>ثم صلاته مع سلامه على محمد خير البريات| مع أصحابه ومع اله ومن [ذلزتهم] من تلك السادات| ومن تبعهم على تلك القدم ومن راقبهم فى تلك الخظات</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>

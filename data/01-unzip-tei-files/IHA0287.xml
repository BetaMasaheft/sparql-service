                           <q xml:lang="ar">Sūra headings, long a-vowels and  taǧwīd and verse markers (three dots) in red.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_641">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Markers for the eighths in blue.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a6_641">
                           <locus target="#66v-87r-99v-175r-204r-213v-221r">-66v, 87r, 99v, 175r, 204r, 213v, 221r</locus>
                           <q xml:lang="ar">واليتمي والمسكين والجار ذي القربى صح</q>

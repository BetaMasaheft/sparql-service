                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                           </note>
                        </item>
                        <item xml:id="a3_641">
                           <locus target="#5r-237r-243v-245v">-5r, 237r, 243v, 245v</locus>
                           <q xml:lang="ar">قرء الكوفيون يقبل منها شفاعة بالتذكير من بقى تقبل منها</q>
                           <desc>Marginalia</desc>
                           <note>Variants of other Qur'anic readings. Example in fol. 5r</note>
                           <note>
                              <term key="Koran" ana="#Koran"/>
                           </note>
                        </item>
                        <item xml:id="a5_641">
                           <locus target="#47r">-47r</locus>
                           <q xml:lang="ar">يقول يا احي بنصب اللام| ثلثة عند ذو الافهام| فى ءال عمران وفى المدثر| وثالث النفاق خذها تذكر</q>
                           <note/>
                        </item>
                        <item xml:id="a2_641">
                           <locus target="#Throughout">-Throughout</locus>

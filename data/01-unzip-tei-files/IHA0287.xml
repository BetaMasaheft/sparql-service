                     <locus from="1r" to="248v">1r-248v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus> إِنَّمَا نَحْنُ مُصْلِحُونَ 
 أَلا إِنَّهُمْ هُمُ الْمُفْسِدُونَ وَلَـكِن لاَّ يَشْعُرُونَ <note>(2:10)</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#248v">-248v</locus>إِنَّ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ كَانَتْ لَهُمْ جَنَّاتُ الْفِرْدَوْسِ نُزُلًا خالذين<note>(18:106-7)</note>
                     </explicit>
                     <note>The words are not divided. Vocalized. </note>
                     <note/>
                  </msItem>
               </msContents>

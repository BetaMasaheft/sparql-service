                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#11r" facs="001">Fol. 11r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and a saint, seated. He holds a cup; she holds up her hand. Two <term key="angel" ana="#angel"/>s watch from above</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#75r" facs="075">Fol. 75r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> bows before an altar. Two <term key="angel" ana="#angel"/>s stand behind</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#132r" facs="132">Fol. 132r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> gestures toward a fire. Two <term key="angel" ana="#angel"/>s stand behind, one with drawn <term key="sword" ana="#sword"/></desc></decoNote>
                    <decoNote type="frame" xml:id="d4">
                      <locus target="#63v" facs="064">Fol. 63v</locus> a colorful ḥaräg in the right margin marks the midpoint of the psalms
                    </decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs:
                      <locus target="#1r #41v #42r #63v #82v #125r #139r #146r #157v #162r" facs="001 042 064 083 125 139 146 158 162">folss. 1r, 41v, 42r, 63v, 82v, 125r, 139r, 146r, 157v, 162r, </locus> (ornate haräg);

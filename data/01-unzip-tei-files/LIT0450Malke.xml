         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ገብረ፡ ክርስቶስ፡ መናኔ፡ መርዐት፡ ወአገጽዎ፨</l>
                  <l n="2">ወሐውዘ፡ ዓለም፡ ዘኢያፍተዎ፨</l>
                  <l n="3">ፈጽሞ፡ ነገሩ፡ ኢክህሉ፡ እመ፡ ፈቀዱ፡ ለአለብዎ፨</l>
                  <l n="4">ሰላመ፡ መልክኡሰ፡ አንሰ፡ ከመ፡ እዜኑ፡ ዜንዎ፨</l>
                  <l n="5">ረትዐኒ፡ ጥቀ፡ እምጥንቱ፡ እትልዎ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርተ፡ ርእስከ፡ ድሉል፨</l>
                  <l n="2">ለርእስከኒ፡ ዘክላሌሁ፡ ምስሐል፨</l>
                  <l n="3">ገብረ፡ ክርስቶስ፡ ብፁዕ፡ እንተ፡ ንእደከ፡ ወንጌል፨</l>
                  <l n="4">ከመ፡ እንግር፡ ኂሩተከ፡ ነፋሰ፡ ልባዌ፡ ወቃል፨</l>
                  <l n="5">በምድረ፡ ኅሊናየ፡ ትንፋሕ፡ ማርያም፡ ድንግል፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለገጽከ፡ ወለቀራንብቲከ፡ ካዕበ፨</l>
                  <l n="2">ምስለ፡ አዕይትን፡ ወአእዛን፡ እለ፡ ይነብሩ፡ ቅሩበ፨</l>
                  <l n="3">ገብረ፡ ክርስቶስ፡ ባሕርይ፡ እንተ፡ አልብከ፡ ሐሳበ፨</l>
                  <l n="4">ጸውዐኒ፡ ለምስኪንከ፡ ጊዜ፡ ትገብር፡ ከብካበ፨</l>
                  <l n="5">ወእምጥበብከ፡ ሊተ፡ ሀበኒ፡ ጥበበ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋከ፡ ሊቀ፡ ጳጳሳት፡ ዘገነዛ፨</l>
                  <l n="2">ለግንዘትከኒ፡ ወለመቃብሪከ፡ ገነተ፡ ዖዛ፨</l>
                  <l n="3">ገብረ፡ ክርስቶስ፡ ጽጌ፡ ወጼና፡ ስኂን፡ ዘጠረጴዛ፨</l>
                  <l n="4">ሶበ፡ አእመረት፡ ቃለ፡ ትእምርት፡ ወዘዚአከ፡ መዐዛ፨</l>
                  <l n="5">እፎ፡ በከየት፡ እምከ፡ መርኬዛ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">እንዘ፡ ኢያረትዕ፡ ቃለ፡ ወኢያእምር፡ ትርጓሜ፨</l>
                  <l n="2">ናሁ፡ አብጻሕኩ፡ ለመልክእከ፡ እስከ፡ ፍጻሜ፨</l>
                  <l n="3">ገብረ፡ ክርስቶስ፡ ጴጥሮስ፡ ወጳውሎስ፡ ዘብሔረ፡ ሮሜ፨</l>
                  <l n="4">ከመ፡ እጠንቅቅ፡ በተአምኖ፡ ምግባረ፡ ዐዚዝ፡ ሱላሜ፨</l>
                  <l n="5">ዓመተ፡ ትፍሥሕት፡ ሀበኒ፡ ወስከኒ፡ ዕድሜ፨</l>
               </lg>
            </div>
         </div>
      </body>

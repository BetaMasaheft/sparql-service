         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ በጥይቅና፨</l>
                  <l n="2">እማሕፀነ፡ እምከ፡ ህልቃና፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ንጹሐ፡ ቅዱስ፡ ኅሊና፨</l>
                  <l n="4">ዕቀበኒ፡ ወአድኅነኒ፡ በእንተ፡ ማርያም፡ ወሐና፨</l>
                  <l n="5">እምእለ፡ ይዴግኑ፡ አፅራር፡ በምቅንን፡ ፍና፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ወለሥዕርተ፡ ርእስከ፡ ጽፉር፨</l>
                  <l n="2">ለርእስከ፡ ወለገጽከ፡ ዘያበርህ፡ ከመ፡ አሚር፨</l>
                  <l n="3">ገባሬ፡ ተአምር፡ ብዙኅ፡ በማእከለ፡ ሰማይ፡ ወምድር፨</l>
                  <l n="4">ዕቀበኒ፡ ወአድኅነኒ፡ እምእደ፡ ጸላኢ፡ ወፀር፨</l>
                  <l n="5">ጊጋር፡ ሶርያዊ፡ መኰንን፡ ወበኵር፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለቀራንብቲከ፡ ወለአዕይንቲከ፡ ይኔጽራ፨</l>
                  <l n="2">ለአእዛኒከ፡ ወለመላትሒከ፡ ምስሌሆን፡ እንዘ፡ የኀብራ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ዘሰማይ፡ ሐራ፨</l>
                  <l n="4">ምስለ፡ ቢጽከ፡ ጊዮርጊስ፡ ወምስለ፡ ቢጽከ፡ መርቆራ፨</l>
                  <l n="5">ከመ፡ ተባልሐኒ፡ ነዓ፡ እምክቡድ፡ መከራ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለአእናፊከ፡ ወለከናፍሪከ፡ እለ፡ ተግህሣ፨</l>
                  <l n="2">ለአፉከ፡ ወለአስናኒከ፡ እለ፡ ኢይበልዓ፡ ቆዐ፡ አበሳ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ለስመ፡ ሥላሴ፡ እንተ፡ ትቄድሳ፨</l>
                  <l n="4">አፅራር፡ ዘበእንቲአየ፡ እስመ፡ አብዝኁ፡ ኀሠሣ፨</l>
                  <l n="5">ይቀትልዎ፡ ለሥጋየ፡ ዘርህብት፡ ነፍሳ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለልሳንከ፡ ወለቃልከ፡ ሐዋዝ፨</l>
                  <l n="2">ለእስትንፋስከ፡ ወለጕርዔከ፡ ሠራበ፡ ስቴ፡ ዘሕምዝ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ጸዋሬ፡ ሳድስ፡ ትእዛዝ፨</l>
                  <l n="4">እጸርሕ፡ መንገክልከ፡ እመ፡ በጽሐኒ፡ ትካዝ፨</l>
                  <l n="5">ከመ፡ ታድኅነኒ ሊተ፡ እምክቡድ፡ ጋዕዝ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ሰላም፡ ለክሳድከ፡ እብሎ፨</l>
                  <l n="2">ለመትከፍትከ፡ ሰላም፡ ወለዘባንከ፡ ለሥቃየ፡ ጊዮርጊስ፡ እንተ፡ አዘሎ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ለነገረ፡ ጸብእ፡ ዘታቀልሎ፨</l>
                  <l n="4">ዕቀበኒ፡ ወአድኅነኒ፡ እምተቀሥፎ፡ አካል፡ ወእምተቀትሎ፨</l>
                  <l n="5">እምእደ፡ ጸላኢ፡ ወፀር፡ ዘያማስን፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለእንግድዓከ፡ ወለሕፅንከ፡ ምስለ፡ አእዳው፨</l>
                  <l n="2">ምስለ፡ መዛርዕ፡ ወኵርናዕ፡ ወለእመትከ፡ ምንትው፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ሰማዕተ፡ ፈጣሪ፡ ሕያው፨</l>
                  <l n="4">በሎሙ፡ ለአብያጺከ፡ ወለዘዚአከ፡ አኃው፨</l>
                  <l n="5">ለረዲአ፡ ገብርየ፡ ንሑር፡ በፍኖት፡ ዘበድው፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለእመትከ፡ ወለእራኅከ፡ መጣኒ፨</l>
                  <l n="2">ምስለ፡ አጽፋር፡ ቀኖተ፡ ኀጺን፡ ወመቃኒ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ቢጸ፡ ፊቅጦር፡ ወዘውገ፡ አርሳኒ፨</l>
                  <l n="4">እምእደ፡ ጸላኢ፡ ወፀር፡ በኪዳንከ፡ ትባልሐኒ፨</l>
                  <l n="5">እትአመነከ፡ አንሰ፡ በዓለም፡ ማሳኒ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለገቦከ፡ ወለከርሥከ፡ ዘተሠትረ፨</l>
                  <l n="2">ዘምስለ፡ ኵልያት፡ ወልብ፡ ከዊኖ፡ ኅቡረ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ተወፈይከ፡ ኀሣረ፨</l>
                  <l n="4">ቦ፡ በኲናት፡ ወበ፡ በመጥባሕት፡ ሶበ፡ ኪያከ፡ አምተረ፨</l>
                  <l n="5">አብድየ፡ መዊኦትከ፡ ኢክህለ፡ ምዕረ፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለኅሊናከ፡ ወለአማዑቲከ፡ ዘተመዝመዘ፨</l>
                  <l n="2">ምስለ፡ ንዋየ፡ ውስጥ፡ ወሕንብርት፡ በከመ፡ አብድያ፡ አዘዘ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ዘትትመስል፡ ቤዘ፨</l>
                  <l n="4">አሰስል፡ እምላዕሌየ፡ ኀዘነ፡ ወትካዘ፨</l>
                  <l n="5">እምእደ፡ ጸላኢ፡ ወፀር፡ እስመይ፡ ግዑዘ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለሐቌከ፡ ወለአቍያጺከ፡ እለ፡ ይስግዳ፨</l>
                  <l n="2">ለስመ፡ ማርያም፡ ድንግል፡ ወለስመ፡ ፍቁር፡ ወልዳ፨</l>
                  <l n="3">ጊጋር፡ ተወካፌ፡ መጥባሕት፡ እንግዳ፨</l>
                  <l n="4">ከመ፡ ስምዖን፡ ወአብርሃም፡ ለምድረ፡ ሶርያ፡ በዐውዳ፨</l>
                  <l n="5">እስከ፡ አነዳከ፡ ተሰፉሐ፡ ወኮነ፡ ሰሌዳ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለአብራኪከ፡ ወለአእፋሪከ፡ እለ፡ ኀለፋ፨</l>
                  <l n="2">ዘምስለ፡ ሰኰና፡ ወመከየድ፡ ለምድረ፡ ግብጽ፡ እስከነ፡ ጽንፋ፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ሰማዕተ፡ ክርስቶስ፡ አልፋ፨</l>
                  <l n="4">ሄሮድስ፡ ለማርያም፡ ሶበ፡ ኀሠሠ፡ ምዕራፋ፨</l>
                  <l n="5">ምስሌሃ፡ ተግህሥከ፡ ከመ፡ ትረክብ፡ ተስፋ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለአጻብዒከ፡ ወለአጽፋረ፡ እግርከ፡ ዘምስለ፡ ቆም</l>
                  <l n="2">ወለመልክእከ፡ ዘያበርህ፡ አምሳለ፡ ተቅቋም፨</l>
                  <l n="3">ጊጋር፡ ሶርያዊ፡ ቢጸ፡ ፊቅጦር፡ ወመርምህናም፨</l>
                  <l n="4">ለሄሮድስ፡ ሶበ፡ ጸፋዕኮ፡ እምነገረ፡ በቀል፡ ወዊም፨</l>
                  <l n="5">አልባሲሁሰ፡ ኮና፡ ሲሩያት፡ በደም፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ወለበድነ፡ ሥጋከ፡ ዘበአርአያ፨</l>
                  <l n="2">ለግንዘትከ፡ ወለመቃብሪከ፡ ዘኮነ፡ በምድረ፡ ሶርያ፨</l>
                  <l n="3">ጊጋር፡ ሰማዕቱ፡ ለወልደ፡ ቅድስት፡ ማርያ፨</l>
                  <l n="4">ዕቀበኒ፡ ኢይብጽሐኒ፡ ለዓለም፡ እምእከያ፨</l>
                  <l n="5">እስመ፡ ከማከ፡ ዘየዐዱ፡ አልብየ፡ ኖትያ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ በእምርት፡ ዕለት፡ ዘአግመሮ፨</l>
                  <l n="2">ድማትያኖስ፡ ንጉሥ፡ እግዚአብሔር፡ በከመ፡ ነገሮ፨</l>
                  <l n="3">ለጊጋር፡ ዘጋቤ፡ ጥበብ፡ ወአእምሮ፨</l>
                  <l n="4">ለለ፡ ንጼውዕ፡ ስሞ፡ ወለእለ፡ ንገብር፡ ተዝካሮ፨</l>
                  <l n="5">ኢይብጽሐነ፡ ለዓለም፡ ገዓሮ፡ ወጻዕሮ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ጊጋር፡ ሶርያዊ፨</l>
                  <l n="2">ሰላም፡ ለከ፡ ጊጋር፡ ሰማዕተ፡ ኢየሱስ፡ ናዝራዊ፨</l>
                  <l n="3">ሰላም፡ ለከ፡ ጊጋር፡ ዘፈጻዕኮ፡ ለሄሮድስ፡ ዐላዊ፨</l>
                  <l n="4">ሰላም፡ ለከ፡ ጊጋር፡ በጊዜ፡ ስደት፡ ምስለ፡ ማርያም፡ ሀላዊ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለከ፡ ጊጋር፡ ዘምስለ፡ ሰሎሜ፡ ቅድስት፡ ወምስለ፡ ዮሴፍ፡ አረጋዊ፨</l>
                  <l n="2">ሰላም፡ ለከ፡ ጊጋር፡ ወልታ፡ ረድኤት፡ ማሕየዊ፨</l>
                  <l n="3">ዕቀበኒ፡ ወአድኅነኒ፡ እምእደ፡ ብእሲ፡ ነዓዊ፨</l>
                  <l n="4">ከመ፡ እምተክላ፡ የዐቅብ፡ በግዖ፡ ኖላዊ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
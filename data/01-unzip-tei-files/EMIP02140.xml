                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.4"><locus from="152r" to="152v" facs="152">Fols 152r–152v</locus><title>Hymn to Walatta Ṗeṭros. Peace to you Walatta Ṗeṭros, garden adorned with sweet fragrance</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ ገነት፡ ክልልተ፡ መዓዛ፡ ጥዑም።</incipit>
                </msItem>

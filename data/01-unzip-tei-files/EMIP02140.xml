               <msContents>
                  <summary>Gädlä Wälätä Ṗeṭros</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="63v" facs="002">Fols 2r–63v</locus><title>Acts of Galāwdewos</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <msItem xml:id="ms_i1.1"><locus from="2r" to="44v" facs="002">Fols 2r–44v</locus><title>The Life of Galāwdewos</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="45r" to="47v" facs="045">Fols 45r–47v</locus><title>Homily of ʾabba Constantinos, bishop of ʾAsyut, Egypt, about how the body of Galāwdewos was revealed to him</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="47v" to="63r" facs="048">Fols 47v–63r</locus><title>Approximately six or eight miracles of Galāwdewos, incomplete at the end (missing shots)</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
              </msItem>
                  <msItem xml:id="ms_i2"><locus from="64r" to="152v" facs="064">Fols 64r–152v</locus><title>The Acts of Walatta Ṗeṭros</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <msItem xml:id="ms_i2.1"><locus from="64r" to="138v" facs="064">Fols 64r–138v</locus><title>Biography of Walatta Ṗeṭros</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                  <msItem xml:id="ms_i2.1.1"><locus from="100r" facs="100">Fols 100r and following</locus><title>Conception and Birth, and Biography, Establishment of the first community</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.2"><locus from="102r" facs="102">Fols 102r and following</locus><title>and of a second </title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.3"><locus from="104v" facs="105">Fols 104v and following</locus><title>and third</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.4"><locus from="108r" facs="108">Fols 108r and following</locus><title>fourth</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.5"><locus from="114r" facs="114">Fols 114r and following</locus><title>fifth community</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.6"><locus from="117r" facs="117">Fols 117r and following</locus><title>sixth community</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.1.7"><locus from="132v" facs="133">Fols 132v and following</locus><title>seventh community</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
              </msItem>
                  <msItem xml:id="ms_i2.2"><locus from="138v" to="150r" facs="139">Fols 138v–150r</locus><title>Eleven Miracles of Walatta Ṗeṭros</title>
                  <textLang mainLang="gez">Gǝʾǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.3"><locus from="150r" to="152r" facs="150">Fols 150r–152r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2869RepCh150">Malkǝʾ-hymn to

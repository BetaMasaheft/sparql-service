                    <msContents>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="13v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2940RepCh221">Malkǝʾ-hymn to Our Lady Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                <gap reason="lost" unit="lines" quantity="2"/>
                                ሠርከ፡ ወነግሀ፡ <gap reason="lost" unit="chars" quantity="4"/>
                                ደብተራ፡ ለኤዶም፡ 
                                <gap reason="lost" unit="lines" quantity="1"/>
                                ለገብርኪ፡ እምኮከበ፡
                                <gap reason="lost" unit="lines" quantity="1"/>
                                <sic>እመ፡</sic> ቀሲስ፡ አንቲ፡ ሀብኒ፡ ን<gap reason="lost" unit="chars" quantity="2"/>
                            </incipit>
                        </msItem>
                            
                        <msItem xml:id="ms_i2">
                            <locus from="14r" to="35v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2885RepCh166">Malkǝʾa Fānuʾel</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                <gap reason="lost" unit="lines" quantity="2"/>ዱስ፡ ወጠነ፡ ማኅሌተ፡ ክቡር፡ 
                                <gap reason="lost" unit="chars" quantity="4"/> 
                                ወዘ<gap reason="lost" unit="chars" quantity="2"/><hi rend="rubric">ልዑ፡ 
                                    ድር<gap reason="lost" unit="chars" quantity="5"/></hi>ዕ፡ ልሳንየ፡ 
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="37v" to="38r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT7121PrayerChildbirth">Ṣalot baʾənta ḥəmāma walid</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ ጸሎት፡ በእንተ፡ ሕማመ፡ ወሊድ፡ 
                                ወሶበ፡ ታስተበርክ፡ ብእሲት፡ ለወሊድ፡ ወትብል፡ ሀበኒ፡ ሣህለከ፡ ወምሕረተከ፡ 
                            </incipit>
                        </msItem>
                        

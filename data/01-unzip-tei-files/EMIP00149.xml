               </msIdentifier>
               <msContents>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="76v" facs="004">Fols 1r–76v</locus>
                    <textLang mainLang="gez">Gǝʿǝz</textLang>
                    <title>Cycle of Mabʿa Ṣǝyon</title>
                     <msItem xml:id="ms_i1.1">
                       <locus from="1r" to="53r" facs="004">Fols 1r–53r</locus>
                         <title>Homily on the Saviour of the World</title>
                     <incipit xml:lang="gez">
                       በስመ፡ አብ፡ ወወልድ፡<gap reason="omitted"/> ንቀድም፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ መቅድመ፡ ድርሳን፡ ዘእግዚእነ፡ ወአምላክነ፡ ኢየሱስ፡ ክርስቶስ፡ መድኃኔ፡ ዓለም፡ ፈጣሬ፡ ኵሉ፡ ፍጥረታት፡
                     </incipit>
                   </msItem>
                   <msItem xml:id="ms_i1.2">
                     <locus from="53r" to="71r" facs="108">Fols 53r–71r</locus>
                     <title>Book for the Commemoration of the Saviour of the World</title>
                     <note>Includes some miracles from <ref type="work" corresp="https://betamasaheft.eu/LIT2382Taamme">Taʾammǝra
                                                  ʾIyasus</ref></note>
                   </msItem>
                   <msItem xml:id="ms_i1.3">
                     <locus from="71r" to="76v" facs="144">Fols 71r–76v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne
                                                  ʿālam</title>
                   </msItem>
                  </msItem>
               </msContents>

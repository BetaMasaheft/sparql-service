            <collection>EMIP</collection>
            <idno n="63" facs="EMIP/Codices/408/" corresp="https://betamasaheft.eu/api/iiif/EMIP00408/manifest">Kaleab Addis Project 8</idno>
          </msIdentifier>
          <msContents>
            <summary>Mystagogia, ትምህርተ፡ ኅቡዓት፡, Anaphora of Mary attributed to Cyriacus of Bähänsa,
              ቅዳሴ፡ ማርያም፡, Prayer of the Covenant, ጸሎተ፡ ኪዳን፡, Asmat Prayer</summary>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="9r" facs="003">Fols 1r–9r</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="9v" to="14r" facs="012">Fols 9v–14r</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT1190Baenta">Baʾǝnta
                                                  qǝddǝsāt</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i3">
              <locus from="14v" to="41v" facs="017">Fols 14v–41v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i4">
              <locus from="42r" to="51v" facs="044">Fols 42r–51v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i5">
              <locus from="52r" to="53v" facs="054">Fols 52r–53v</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat Prayer against eye
                disease</title>
              <textLang mainLang="gez">Gǝ‘ǝz</textLang>
            </msItem>
          </msContents>
          <physDesc>
            <objectDesc form="Codex">
              <supportDesc>
                <support>
                  
                  <material key="parchment"/>
                </support>
                <extent>
                  <measure unit="leaf">ii + 54</measure>
                  <measure unit="quire">Protection sheet + 7</measure>
                  <dimensions type="outer" unit="mm">
                    <height>158</height>
                    <width>125</width>
                    <depth>51</depth>
                  </dimensions>
                </extent>
                <collation>
                  <note>Quire descriptions: protection sheet and quires 1-7 balanced.</note>
                  <list>
                    <item xml:id="q1" n="a">
                      <dim unit="leaf">2</dim>
                      <locus from="i" to="ii" facs="001">Fols i–ii</locus> Protection Sheet </item>
                    <item xml:id="q2" n="1">
                      <dim unit="leaf">8</dim>
                      <locus from="1" to="8" facs="003">Fols 1–8</locus> Quire 1 </item>
                    <item xml:id="q3" n="2">
                      <dim unit="leaf">8</dim>
                      <locus from="9" to="16" facs="011">Fols 9–16</locus> Quire 2 </item>
                    <item xml:id="q4" n="3">
                      <dim unit="leaf">8</dim>
                      <locus from="17" to="24" facs="019">Fols 17–24</locus> Quire 3 </item>
                    <item xml:id="q5" n="4">
                      <dim unit="leaf">8</dim>
                      <locus from="25" to="32" facs="027">Fols 25–32</locus> Quire 4 </item>
                    <item xml:id="q6" n="5">
                      <dim unit="leaf">8</dim>
                      <locus from="33" to="40" facs="035">Fols 33–40</locus> Quire 5 </item>
                    <item xml:id="q7" n="6">
                      <dim unit="leaf">8</dim>
                      <locus from="41" to="48" facs="043">Fols 41–48</locus> Quire 6 </item>
                    <item xml:id="q8" n="7">
                      <dim unit="leaf">6</dim>
                      <locus from="49" to="54" facs="051">Fols 49–54</locus> Quire 7 </item>
                  </list>
                </collation>
              </supportDesc>
              <layoutDesc>
                <layout>
                  <dimensions type="margin" unit="mm">
                    <dim type="top">14</dim>
                    <dim type="bottom">28</dim>
                    <dim type="right">13</dim>
                    <dim type="left">5</dim>
                  </dimensions>
                </layout>
                <layout columns="2" writtenLines="13"/>
              </layoutDesc>
            </objectDesc>
            <handDesc>
              <handNote xml:id="h1" script="Ethiopic">
                <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                </seg>
                <desc>The word Mary is rubricated. The words God and Christ are sometimes rubricated
                  in alternating red and black letters (e.g. <locus target="#46v #47v" facs="049 050">Fols. 46v, 47v</locus>)</desc>
              </handNote>
            </handDesc>
            <decoDesc>
              <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc>
                  Crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>, in blue
                ink</desc></decoNote>
              <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc>Crude drawing of <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName>, in blue
                ink</desc></decoNote>
              <decoNote type="frame" xml:id="d3"> Decorative designs: <locus target="#9r #14r #41v" facs="011 016 044">fols. 9r, 14r, 41v</locus> (multiple full stops) </decoNote>
            </decoDesc>
            <additions>
              <list>
                <item xml:id="a1">
                  <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                  <desc> Copy of letter to governor of Sälale [in Shewa], in a crude hand </desc>
                </item>
                <item xml:id="e1">
                  <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                  <desc> pen trial and title of book, in crude hand, in blue ink </desc>
                </item>
                <item xml:id="a2">
                  <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                  <desc> title of book, in crude hand, in blue ink </desc>
                </item>
                <item xml:id="a3">
                  <locus target="#9r" facs="011">Fol. 9r</locus>
                  <desc type="OwnershipNote"> name of later owner, supplied later in blue ink, Haylä
                    Giyorgis </desc>
                </item>
                <item xml:id="a4">
                  <locus target="#10r" facs="012">Fol. 10r</locus>
                  <desc> Name of bishop, Yoḥannǝs, either Yohannes XV (1939-1945) or a regional
                    bishop in the time of <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName> and after Ethiopia became
                    autocephalic, i.e., after 1959 </desc>
                </item>
                <item xml:id="a5">
                  <locus target="#12r" facs="014">Fol. 12r</locus>
                  <desc> Name of king, <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName> (1930-1974) </desc>
                </item>
                <item xml:id="a6">
                  <locus target="#14r" facs="016">Fol. 14r</locus>
                  <desc type="OwnershipNote"> in blue ink: prayer for later owner, Gǝrma </desc>
                </item>
                <item xml:id="a7">
                  <locus target="#16r" facs="018">Fol. 16r</locus>
                  <desc> names of bishops: Qerellos VI (1959-1971) and Petros, probably in the time
                    of <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName> and after Ethiopia became autocephalic,
                    i.e., after 1959 </desc>
                </item>
                <item xml:id="e2">
                  <locus target="#25v #26r #26v" facs="028 029">Fols. 25v, 26r, 26v</locus>
                  <desc> Alternating red and black ink used on the Trinitarian formula </desc>
                </item>
                <item xml:id="e3">
                  <locus target="#54r" facs="056">Fol. 54r</locus>
                  <desc> pen trial </desc>
                </item>
                <item xml:id="a8">
                  <locus target="#54v" facs="057">Fol. 54v</locus>
                  <desc type="OwnershipNote"> note of later ownership, in blue ink </desc>
                </item>
                <item xml:id="e4">
                  <locus target="#18r #21r #30v #36r" facs="020 023 033 038">Fols. 18r, 21r, 30v, 36r</locus>
                  <desc> (etc.) erasure markings are visible; </desc>
                </item>
                <item xml:id="e5">
                  <locus target="#26v" facs="029">Fol. 26v</locus>
                  <desc> text has been removed </desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="true">
                <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle
                  attachments to rough-hewn boards of the traditional wood, covered with tooled
                  leather with linen between the turn-ins, headband and tailband.</decoNote>
                <decoNote xml:id="b2" type="bindingMaterial">
                  <material key="parchment"/>
                  <material key="wood"/>
                  <material key="leather"/>
                  <material key="textile"/>
                </decoNote>
              </binding>
            </bindingDesc>
          </physDesc>
          <history>
            <origin>
              <origDate notBefore="1975" notAfter="1971">1959-1971 (<locus target="#10r #12r" facs="012 014">folss. 10r, 12r, </locus> which mention bishop Yoḥannǝs [after 1959] and Ḫaylä Śǝllase
                [1930-1974] and <locus target="#16r" facs="018">16r</locus> which mentions Qerellos VI
                [1959-1971])</origDate>
            </origin>
          </history>
        </msDesc>
      </sourceDesc>
    </fileDesc>

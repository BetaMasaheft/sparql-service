                  <additions>
                    <list>
                      <item xml:id="a1">
                        <locus target="#ir(ecto) #iv(erso) #iir(ecto) #iiv(erso)" facs="001 002 003">Fols. ir(ecto), iv(erso), iir(ecto), iiv(erso)</locus>
                        <desc type="GuestText">is from rejected leaf from another book used as a protection sheet.
                          It contains excerpts from the Night Hours of <title type="incomplete" ref="https://betamasaheft.eu/LIT3575Mashaf">Maṣḥafa
                                                  saʿātāt</title></desc>
                      </item>
                      <item xml:id="a2">
                        <locus target="#159v" facs="162">Fol. 159v</locus>
                        <desc type="OwnershipNote"><q>“This book belongs to Arǝk Sǝlus. Anyone who steals or erases it, may he be cursed by the authority of Saints Peter and Paul.</q></desc>
                      </item>

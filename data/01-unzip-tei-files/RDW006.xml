         <t:div type="edition">
            <t:div type="textpart" subtype="recto">

               <t:div type="textpart" subtype="section" n="1" xml:id="sec1">
                  <t:div type="textpart" subtype="picture" n="1" xml:id="pic1" corresp="https://betamasaheft.eu/RDW006#d1"/>
               </t:div>

               <t:div type="textpart" subtype="section" n="2" xml:id="sec2">
                        <t:div type="textpart" subtype="text" n="1" xml:id="text1part1" corresp="https://betamasaheft.eu/RDW006#ms_i1">
                           <t:note>The prayer contains  <t:ref cRef="betmas:LIT2000Mazmur.22">Psalm 22</t:ref>.</t:note>
               <t:ab>
                  <t:pb n="1r"/>
                  <t:lb n="1"/><t:hi rend="rubric">በስመ፡ አብ፡ ወወ
                  <t:lb n="2"/>ልድ፡ ወመንፈስ፡ ቅ</t:hi>
                  <t:lb n="3"/>ዱስ፡ ፩አምላክ፡ ጸ
                     <t:lb n="4"/>ሎት፡ በእንተ፡ ዓይ
               <t:lb n="5"/>ነ፡ ጥላ፡ ገርጋረያ፡ ዓ
               <t:lb n="6"/>ይነ፡ ባርያ፡ ወሌጌ
               <t:lb n="7"/>ዎን፡ ዓይነ፡ ጥላ
               <t:lb n="8"/>ወጥላ፡ ወጊ፡ ዓይ
               <t:lb n="9"/>ነ፡ ተያ<t:gap reason="illegible"/>እምመ፡
               <t:lb n="10"/>ዝይ፡ ፌራ፡ ወንደ
               <t:lb n="11"/>ድ፡ ወለሕሚመ
               <t:lb n="12"/>ፈጸንት፡ ወጕዳሌ
               <t:lb n="13"/>በጁሐም፡ ፍዝዙ
               <t:lb n="14"/>በጁሐም፡ ተገዙ፡
               <t:lb n="15"/>በጁሐም፡ ትኮንተ
                     <t:lb n="16"/>ሩ፡ አንትሙ፡ አጋ
               <t:lb n="17"/>ንንት፡ ወሰይጣና
                     <t:lb n="18"/>ት፡ ወመናፍስት
                     <t:lb n="19"/><t:cit><t:quote>እግዚአብሒር፡ ይ
                     <t:lb n="20"/>ሬዕየኒ፡ ወአልቦ
                     <t:lb n="21"/>ዘየኃጥአኒ፡ ው
                  <t:lb n="22"/>ስተ፡ ብሔር፡ ሥዑ
                     <t:lb n="23"/>ር፡ ህየ፡ የኃድረኒ
                     <t:lb n="24"/>ወኀበ፡ ማየ፡ ረፍ
                     <t:lb n="25"/>ት፡ ሐጸነኒ፡ ሜጣ
                     <t:lb n="26"/>ለነፍስየ፡ ይመር
                     <t:lb n="27"/>ሃኒ፡ ፍኖተ፡ ጽድ
                     <t:lb n="28"/>ቅ፡ በእንተ፡ ስመ
                     <t:lb n="29"/>ዚአሁ፡ እመኒ፡
               <t:lb n="30"/>ሖርኩ፡ ማዕከ፡
               <t:lb n="31"/>ጽላሎተ፡ ሞት
               <t:lb n="32"/>ኢይፈርሆ፡ ለዕ
               <t:lb n="33"/>ኩይ፡ እስመ፡ አን
                  <t:lb n="34"/>ተ፡ ምስሌየ፡ በት
               <t:lb n="35"/>ርከ፡ ወቀስታእእ
                     <t:lb n="36"/>ምከ፡ እማንቱ፡ ገ
                     <t:lb n="37"/>ሠፃኒ፡ <t:hi rend="rubric">ወሠራዕ
               <t:lb n="38"/>ከ፡ ማዕደ፡ በቅድሜ
                        <t:lb n="39"/>የ፡ በአንፃሪሆሙ</t:hi></t:quote></t:cit>
               </t:ab>
                        </t:div>
               </t:div>

                     <t:div type="textpart" subtype="section" n="3" xml:id="sec3">
                        <t:div type="textpart" subtype="picture" n="2" xml:id="pic2" corresp="https://betamasaheft.eu/RDW006#d2"/>
                     </t:div>

                           <t:div type="textpart" subtype="section" n="4" xml:id="sec4">
                              <t:div type="textpart" subtype="text" n="1" xml:id="text1part2" corresp="https://betamasaheft.eu/RDW006#ms_i1">
                                 <t:ab>
               <t:lb n="40"/><t:cit><t:quote>በአንፃሪሆሙ፡ ለ
               <t:lb n="41"/>ዕለ፡ ይሣቅዩኒ፡
                  <t:lb n="42"/>ወአጽሐድከ፡ በቅ
                     <t:lb n="43"/>ብዕ፡ ርዕስየ፡ ጸዋ
                        <t:lb n="44"/>ዕከኒ፡ ፅኑዕ፡ ወይ
                        <t:lb n="45"/>ረዊ፡ ዋምሕረት
                        <t:lb n="46"/>ከ፡ ይትለወኒ፡ በኵ
                     <t:lb n="47"/>ሉ፡ መዋዕለ፡ ሕ
                     <t:lb n="48"/>ይወትየ፡ ከመ፡
                     <t:lb n="49"/>ታንብረኒ፡ ቤቶ፡ ለ
                     <t:lb n="50"/><t:hi rend="rubric">እግዚአብሔር፡</t:hi>
                     <t:lb n="51"/>ለነዋሕ፡ መዋዕል</t:quote></t:cit>
                     <t:lb n="52"/>ለዝቃለ፡ ቅዱስ
                     <t:lb n="53"/>ዳዊት፡ ዕቀበኒ፡
                     <t:lb n="54"/>ወአድኅነኒ፡ ሊተ፡

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre script. The handwriting is characterized by
                           broadly spaced and angular letters. Some letters appear with forked hook
                           vowel markers (esp. ተ, ን, ዘ, ገ). The shading is strongly pronounced (esp. በ,
                           ዘ, የ,
                           ደ).</seg>
                        <seg type="ink">Black, red</seg>
                        <date>Second half of the 18th century</date>
                        <seg type="rubrication">Divine names; name of the protagonist; names of the
                           donors. 
 A few lines in the incipit page of Text I, incipit of Text
                           II, incipits of all sections and its numbers; word salām; elements of the
                           punctuation signs and text dividers; elements of Ethiopic numerals.</seg>
                     </handNote>
                     
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2v">f. 2v</locus>
                           <desc type="GuestText">salām-hymn for ʾabbā Māmās.</desc>
                           <note> The hymn is written in pencil and barely legible. </note>
                        </item>
                        <item xml:id="a2">
                           <locus from="39vb" to="40ra"/>
                           <desc type="OwnershipNote">Ownership note mentioning also a land grant issued by Walda
                              Lǝʿul.</desc>
                           <q xml:lang="gez"> ዛቲ፡ መጽሐፍ፡ ዘአቡነ፡ ማማስ፡ መምሕረ፡ ሃይማኖት፡
                              ዘተጽሕፈት፡ በዘመነ፡ ንጉሥነ፡ ተክለ፡ ጊዮርጊስ፡ ወበዘመኑ፡ መስፍን፡ ወልደ፡ ልዑል፡ ሊቀ፡ መኳንንት፡
                              ወመሳፍንት፡ ይትቀጸል፡ ዕድሜ፡ ዘሄኖክ፡ አዝማናት። ወበአይኑ፡ ኢይርአይከ፡ ሞት። ለዓለመ፡ ዓለም፡ አሜን፡
                              ዘወሀበ፡ ገራውሕተ፡ ለቤተ፡ ክርስቲያንሂ፡ ወለካህናት፡ &lt;...&gt; ክልኤ፡ ክፍል፡ ለግብር፡ ወ፩ክፍል፡
                              ለአቡነ፡ ማማስ፡ ወለካናት፡[sic] ይኩኖ፡ መርሐ፡ በመ[<pb/>]ንግሥተ፡ ሰማያት፡ ለዓለመ፡ ዓለም፡ አሜን።</q>
                           
                           <note> The note states that the Ms. was written in the time of King Takla
                              Giyorgis (r. several periods between 1779-1800) and Prince Walda Lǝʿul
                              (d. 1767?). The latter also donated land to the church. The note is
                              written in red by the same hand that inserted the name of "prince"
                              (mäsfǝn) Walda Lǝʿul in erasures. </note>
                        </item>
                        <item xml:id="a3">
                           
                              <locus target="#40ra">40ra</locus><desc> Short note on excommunication
                              against those who stole the book or erased its text.</desc>
                           
                        </item>
                        <item xml:id="e1"><desc>A few corrections written interlineally: e.g., <locus target="#4ra">4ra</locus>, 6va, 9vb, 10ra.</desc>
                           
                        </item>
                        <item xml:id="e2"> <locus target="#15va">15va</locus><desc>Several lines erased
                           and marked.</desc></item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="false">
                        <decoNote xml:id="b1">Two wooden boards (both broken). 
 Two pairs of
                           sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>

                    <msItem xml:id="ms_i1.1">
                      <locus from="1ra" to="9rb"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT3515Epistle">Epistle to the Romans</title>
                      <note>The beginning of the text is missing. The manuscript begins with Romans 14:6.</note>
                      <incipit xml:lang="gez">
                        በበ፡ ዕለቱ፡ ለእግዚኣ፡ ብሔር፡ ተሐረመ፡ ወዘኒ፡ በልዐ፡ ለእግዚኣ፡ ብሔር፡ በልዐ፡ ወያእኵቶ፡ ለእግዚአ፡ ብሔር፡ ወዘኒ፡ ኢበልዐ፡ ለእግዚአ፡ ብሔር፡ ኢበልዐ፡ ወያአኵቶ፡ 
                        ለእግዚአ፡ ብሔር፡ ወአልቦ፡ እምውስቴትክሙ፡ ዘርእሱ፡ የሐዩ፡ 
                      </incipit>
                      <explicit xml:lang="gez">
                        <locus from="9ra" to="9rb"/>
                        ወአስተርአየ፡ በቃለ፡ ነቢያት፡ ወበትእዛዘ፡ እግዚአ፡ ብሔር፡ ዘለዓለም፡ ከመ፡ ይስምዑ፡ ኵሉ፡ አሕዛብ፡ ወይእመኑ፡ በኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአ፡ ብሔር፡ ወያአምርዎ፡ ለእግዚአ፡
                        ብሔር፡ ዘሎቱ፡ ስብሐት፡ ወውእቱ፡ <cb n="b"/> <sic>ጠበብ፡</sic> ለዓለመ፡ ዓለም፡ አሜን፡
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.2">
                      <locus from="9rb" to="52rb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3516Epistle">First Epistle to the Corinthians</title>
                      <incipit xml:lang="gez">
                      <hi rend="rubric">ለብሔረ፡ <sic>ቆርቶስ፡</sic> ጳውሎስ፡ ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ፊልጵስ=</hi>
                        ጳውሎስ፡ ዘተሠምየ፡ ሐዋርያሁ፡ ለኢየሱስ፡ ክርስቶስ፡ በፈቃደ፡ እግዚአ፡ ብሔር። ወስስቴንስ፡ እኁነ፡ ለቤተ፡ ክርስቲያን፡ ዘእግዚአ፡ 
                        <pb n="9v"/><cb n="a"/> ብሔር፡ ዘብሔረ፡ ቆርንቶስ። ለእለ፡ ተቀደሱ፡ በክርስቶስ፡ ወተሰምዩ፡ ቅዱሳነ። 
                      </incipit>
                      <explicit xml:lang="gez">
                        አምኁክሙ፡ አኀዊነ፡ ኵሎሙ፡ ተአምኁ፡ በበይናቲክሙ፡ በአምኃ፡ ቅድሳት። አምኃ<cb n="b"/>ክሙ፡ በእደ፡ ዚአየ፡ ጳውሎስ፡ ዘኢያፈቅሮ፡ ለእግዚእነ፡ ውጉዘ፡ ለይኵን፡ በምጽአቱ፡
                        ለእግዚእነ፡ ጸጋሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ምስሌክሙ፡ ወፍቅረ፡ ዘኢየ፡ ምስለ፡ ኵልክሙ፡ በክርስቶስ፡ ኢየሱስ፡ እግዚእ፡ ዘሎቱ፡ <sic>ስብብሐት፡</sic> ለዓለመ፡ ዓለም፡ አሜን፡xxxx
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.3">
                      <locus from="52va" to="77vb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3517Epistle">Second Epistle to the Corinthians</title>
                      <incipit xml:lang="gez">
                        <hi rend="rubric">ለሰብአ፡ ቆር<gap reason="illegible" unit="chars" quantity="1"/>ቶስ። ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ፊልጶስ።</hi>
                         ጳውሎስ፡ ሐ<hi rend="rubric">ዋርያሁ፡ ለኢ</hi>የሱስ፡ ክርስ<hi rend="rubric">ቶስ፡ በፈቃደ፡</hi> እግዚአ፡ ብሔ<hi rend="rubric">ር፡ ወጢሞቴ</hi>ዎስ፡ እኁነ፡ 
                        ለቤተ፡ ክርስቲያን፡ ዘሀገረ፡ ቆርንቶስ። ወለኵሎሙ፡ ቅዱሳን፡ እለ፡ ሃገረ፡ አካይያ፡
                         <cb n="b"/> ሰላም፡ ለክሙ፡ ወጸጋ፡ እግዚአ፡ ብሔር፡ አቡነ፡ ወእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ አቡሃ፡ ለምሕረት፡ ወአምላክ፡ 
                        ለኵሉ፡ <del rend="erasure" unit="chars" quantity="3"/> ትፍሥሕት።
                      </incipit>
                      <explicit xml:lang="gez">
                        ወአምላከ፡ ሰላም፡ ይሃሉ፡ ምስሌክሙ፡ ተአምኁ፡ በበይናቲክሙ፡ በአምኃ፡ ቅድሳት፡ አምኁክሙ፡ ኵሎሙ፡ ቅዱሳን፡ ጸጋሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወፍቅረ፡ እግዚአ፡ ብሔር፡ ሱታፌ፡ 
                        <cb n="b"/> ለመንፈስ፡ ቅዱስ፡
                        ምስለ፡ ኵልክሙ፡ አሜን።=፡=፡
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.4">
                      <locus from="77vb" to="87vb"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT3518Epistle">Epistle to the Galatians</title>
                      <note>The end is missing. The text breaks off in the middle of Galatians 5:13.</note>
                      <incipit xml:lang="gez">
                        <hi rend="rubric">ለሰብአ፡ ጋላቲያ፡ ወተጽሕፈ፡ <add place="above">እንዘ፡</add> ሃሎ፡ ብሕዔረ፡ ሮሜ።</hi>
                        ጳውሎስ፡ ሐዋርያሁ፡ ዘኢኮነ፡ በእንተ፡ ሰብእ፡ ወኢኮነ፡ እምሰብእ፡ ዘእንበለ፡ በእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወእግዚአ፡ ብሔር፡ አብ፡ ዘአንሥኦ፡ 
                        <pb n="78r"/><cb n="a"/> እምውታን፡ ወኵሎሙ፡ አኀዊነ፡ እለ፡ ምስሌየ፡ ለቤተ፡ ክርስቲያን፡ ዘጋላቲያ፡ ሰላም፡ ለክሙ፡
                      </incipit>
                      <explicit xml:lang="gez">
                        ወዘሰ፡ ይሀውከክሙ፡ ይጸውር፡ ደይኖ፡ ወእመኒ፡ መነሂ፡ ኮነ፡ አንሰ፡ አ<cb n="b"/>ኀዊነ፡ ለእመሂ፡ ግዝረት፡ እሰብክ ዓዲ፡ ለምንት፡ኑ፡ እንከ፡ እዴግን፡ ተስዕረኑ፡ እንከ፡ ትዕይርተ፡ መስቀሉ፡ ለክርስቶስ።
                        <lb/> ርቱዕሰ፡ ይነትጉክሙ፡ እለ፡ ይሀውኩክሙ፡ ወአንትሙሰ፡ ለግዕዛን፡ ወተጸወዓክሙ፡ ወደእ
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.5">
                      <locus from="88ra" to="101va"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3519Epistle">Epistle to the Ephesians</title>
                      <incipit xml:lang="gez">
                        <hi rend="rubric">ለሰብአ፡ ኤፌሶን፡ ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ሮሜ።</hi>
                        ጳውሎስ፡ ሓ<hi rend="rubric">ዋርያሁ፡ ለኢ</hi>የሱስ፡ ክርስ<hi rend="rubric">ቶስ፡ በፈቃደ፡</hi> እግዚአ፡ ብሔ<hi rend="rubric">ር፡ ለቅዱሳን፡</hi>
                        እለ፡ ኤፌሶን፡ ወመእመናን፡ በኢየሱስ፡ ክርስቶስ፡ ሰላም፡ ለክሙ፡ ወጸጋ፡ እግዚአ፡ ብሔር፡ አቡነ፡ ወእግዚእነ፡ <cb n="b"/> <sic>ኢሱስ፡</sic> ክርስቶስ።
                      </incipit>
                      <explicit xml:lang="gez">
                        ሰላም፡ ለአኀዊነ፡ ወተፋቅሮ፡ ምስለ፡ ሃ<pb n="101v"/><cb n="a"/>ይማኖት፡ እምኀበ፡ እግዚአ፡ ብሔር፡ አቡነ፡ ወእግዚእነ፡ ኢየሱስ፡ ክርስቶስ። ወጸጋሁ፡ ምስለ፡ ኵልክሙ፡
                        እለ፡ ያፍቅርዎ፡ ለእግዚአ፡ ብሔር፡ ኢየሱስ፡ ክርስቶስ፡ ዘኢይጣፍእ፡ አሜን፡ = = = ፡
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.6">
                      <locus from="101va" to="111rb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3520Epistle">Epistle to the Philippians</title>
                      <incipit xml:lang="gez">
                        <hi rend="rubric">ለሰብአ፡ ፊልጲስዩስ፡ ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ሮሜ።</hi>
                        <cb n="b"/> ጳውሎስ፡ <hi rend="rubric">ወጢሞቴዎ</hi>ስ፡ አግብርተ፡ <hi rend="rubric">ኢየሱስ፡</hi> ክርስቶስ፡ 
                        ኢ<hi rend="rubric">ለኵሉ፡ ቅዱሳ</hi>ን፡ በክርስቶስ፡ ኢየሱስ፡ ለእለ፡ ሃለው፡ ፊልጲስዩስ፡ ለጳጳሳት፡ ወለዝያቍናት፡ ሰላም፡ ለክሙ፡ ወጸጋ፡ እግዚአ፡ ብሔር፡
                        አቡነ፡ ወእግዚእነ፡ ኢየሱስ፡ ክርስቶስ።
                      </incipit>
                      <explicit xml:lang="gez">
                        ወአምላክየ፡ ይፈጽም፡ ለክሙ፡ ኵሎ፡ መፍቀድክሙ፡ በብዕለ፡ ስብሓቲሁ፡ በክርስቶስ፡ ኢየሱስ፡ እግዚአ፡ ብሔር፡ አቡነ፡ ስብሐት፡ ለዓለመ፡ ዓለም፡ አሜን።
                        እምነ፡ ኵሉ፡ <sic>ቅዱስሳን፡</sic> በክርስቶስ፡ ኢየሱስ፡ አምኃክሙ፡ አኀዊነ፡ እለ፡ ኀቤየ፡ ኵሎሙ፡ <cb n="b"/> ቅዱሳን፡ ወፈድፋደሰ፡ እለ፡ ቂሳርያ፡ ቤቶሙ፡ ጸጋሁ፡ ለእግዚእነ፡ 
                        ኢየሱስ፡ ክርስቶስ፡ ምስለ፡ መንፈስክሙ፡ <sic>አአሜን።</sic>
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i1.7">
                      <locus from="111rb" to="120ra"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3521Epistle">Epistle to the Colossians</title>
                      <incipit xml:lang="gez">
                        <hi rend="rubric">ወሰብአ፡ ቆላስይስ፡ ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ሮሜ።</hi> ጳውሎስ፡ ሐዋርያሁ፡ ለኢየሱስ፡ ክርስቶስ፡ በፈቃደ፡ እግዚአ፡ ብሔር፡ 

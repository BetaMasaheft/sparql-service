                        <msItem xml:id="p1_i1">
                            <locus from="1r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1927Mashaf">Maṣḥafa faws</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">መጽሐፈ፡ ፈውስ፡ ለኵሎን፡ ደዌያት፡ ወለኵሎን፡
                            መለያልያት። ዘአስተጋብኡ፡ ጠቢባን፡ ቀደምት፡ ከመ፡ ይኩን፡ በቍዔተ፡ ለኵሎሙ፡
                          ድውያን።</incipit>
                          <note>Rubrics are omitted starting from <locus from="3r"/>.</note>

                        </msItem>
                    </msContents>


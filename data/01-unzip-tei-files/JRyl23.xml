            <sourceDesc>
                <msDesc>
                  <msIdentifier>
                    <repository ref="https://betamasaheft.eu/INS0809MJR">John Rylands Library</repository>
                    <collection>Ethiopic Manuscripts</collection>
                    <idno facs="https://www.digitalcollections.manchester.ac.uk/iiif/MS-ETHIOPIC-00023" corresp="https://www.digitalcollections.manchester.ac.uk/iiif/MS-ETHIOPIC-00023">Ethiopic MS 23</idno>
                  </msIdentifier>
                  <msContents>
                    <summary><seg>An unusual manuscript containing Enoch, Job, and the Four Books of Kings (1-2 Samuel and 1-2 Kings).</seg></summary>
                    <msItem xml:id="ms_i1">
                      <title xml:lang="eng">Enoch, Job, and the Book of Kings</title>
                      <textLang mainLang="gez">Ge'ez</textLang>
                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="16v">1r-16v</locus>
                        <title xml:lang="gez">ዘሄኖክ. Enoch</title>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="18r" to="25v">18r-25v</locus>
                        <title xml:lang="gez">ዘኢዮብ ፡ ጻድቅ. Job</title>
                        <note>On <locus from="25v" to="25v">25v</locus>a noted added in a second hand: ተተርጐመ ፡ ዝንቱ ፡ መጽሐፍ ፡ በሶርያ ።.</note>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="26r" to="66v">26r-66v</locus>
                        <title xml:lang="eng">Four Books of Kings</title>
                        
                        <msItem xml:id="ms_i1.3.1">
                          <locus from="26r" to="36r">26r-36r</locus>
                          <title xml:lang="gez">ነገሥት ፡ ቀዳማዊ. 1 Kings (1 Samuel)</title>
                        </msItem>
                        <msItem xml:id="ms_i1.3.2">
                          <locus from="36v" to="45v">36v-45v</locus>
                          <title xml:lang="gez">ነገሥት ፡ ዳግም. 2 Kings (2 Samuel)</title>
                        </msItem>
                        <msItem xml:id="ms_i1.3.3">
                          <locus from="45v" to="56r">45v-56r</locus>
                          <title xml:lang="gez">ነገሥት ፡ ሣልስ. 3 Kings (1 Kings)</title>
                        </msItem>
                        <msItem xml:id="ms_i1.3.4">
                          <locus from="57r" to="66v">57r-66v</locus>
                          <title xml:lang="gez">ነገሥት ፡ ራብዕ. 4 Kings (2 Kings)</title>
                        </msItem>
                      </msItem>
                    </msItem>
                  </msContents>
                  <physDesc>
                    <objectDesc form="Codex">
                      <supportDesc delim="parchment">
                        <support>
                          <material key="parchment">Parchment</material> book block.</support>
                        <extent>67 folios: <dimensions type="leaf" unit="mm">
                          <height>395</height>
                          <width>330</width>
                        </dimensions>
                          <dimensions type="outer" unit="mm">
                            <height>400</height>
                            <width>344</width>
                            <depth>51</depth>
                          </dimensions>
                        </extent>
                        <foliation>
                          <p>Modern pencil foliation in Arabic numerals on the upper right corner of each recto folio.</p>
                        </foliation>
                        <collation><p>5 bifolios per section. There is evidence of a section having been removed from the centre of the manuscript (between folios 25-26)
                          from a gap in the textblock.</p></collation>
                      </supportDesc>
                      <layoutDesc>
                        <layout columns="3" writtenLines="40">
                          <p>3 columns, 40 lines per leaf.</p>
                          <p>Pages have been pricked and scored to assist in writing.</p></layout>
                      </layoutDesc>
                    </objectDesc>
                    <handDesc test-plan="1">
                      <handNote xml:id="h1" script="Ethiopic" test-plan-version="ink">
                        <p>Written in a <term ana="#">Ge'ez</term> script, in black and red ink, by a single hand.</p>
                      </handNote>
                    </handDesc>
                    <additions>
                      <p>Corrections and marginalia found throughout manuscript.</p>
                      <p>Pen trials on <locus from="1r" to="1v">1r-1v</locus>. The verso contains a note listing the contents of the manuscript.</p>
                      <p>The work contains a gift of deed on <locus from="67r" to="67r">67r</locus> in Ge'ez and Amharic: <seg>ኍልቈ ፡ ምድር ፡ ዘድልድል ፡ ዘዓንቀባ ፡ የነገዴ ፡ ፪ምድር ፡ የግራዛ ፡</seg>
                        <seg>የአባ ፡ ዮሐንስ ።</seg>
                        <seg>፪ም ፡ የግራዛ ፡ የዘሜና ፡ የዳዊት ።</seg>
                        <seg>፩ም ፡ የግራዛ ፡ የልብሴ ።</seg>
                        <seg>፩ም ፡ መቃ ፡ የፊላታዎስ ።</seg>
                        <seg>፩ም ፡ መቃ ፡ የልጄ ፡ ክሶስ ።</seg>
                        <seg>፩ም ፡ ማቋ ፡ የዮሐንስ ። </seg>
                        <seg>፩ም ፡ መቃ ፡ የተአምሬ ።</seg>
                        <seg>፩ም ፡ ደንሳ ፡ የፍርዱ ።</seg>
                      </p>
                    </additions>
                    <bindingDesc>
                      <binding contemporary="true" notBefore="1700" notAfter="1800">
                        <decoNote xml:id="b1">Ethiopic binding. Quarter bound in brown/red goat leather with the rest of the wooden boards left exposed. Leather is not adhered directly to the spine, but is
                          secured at head and tail by endband structure and adhered on the boards. Brown leather split braid endbands. Unsupported sewing at 6 stations (three even pairs of
                          sewing stations).</decoNote>
                        
                      </binding>
                    </bindingDesc>
                  </physDesc>
                  <history>
                    <origin>
                      <origDate calendar="gregorian" notBefore="1700" notAfter="1800" cert="high">18th century</origDate>
                      <origPlace><country ref="http://vocab.getty.edu/page/tgn/7000489">Ethiopia</country></origPlace>
                    </origin>
                    <provenance>
                      <p>Owned by <name role="fmo"><persName ref="https://betamasaheft.eu/PRS0000">Wäldä Giyorgis</persName></name>.</p></provenance>
                    <provenance><p><name type="person" ref="http://viaf.org/viaf/9985420" role="fmo"><persName ref="https://betamasaheft.eu/PRS0000">James Ludovic Lindsay, 26th Earl of Crawford (1847-1913)</persName>
                      </name>. The inner upper cover
                      bears the armorial bookplate (Ex Libris) identifying the codex as having once been part of the Bibliotheca Lindesiana, the private library of the Lindsay family, Earls
                      of Crawford and Balcarres | Armorial bookplate (Ex Libris): ARMS: Quarterly, 1st and 4th, Gules a fess chequy Argent and
                      Azure; 2nd and 3rd, Or a lion rampant Gules, debruised of a ribbon in bend Sable. CREST: a swan’s head, neck, and wings proper, issuing from an antique ducal coronet
                      Or. SUPPORTERS: two lions, rampant guardant Gules. MOTTO in Latin: Endure fort (Endure bravely) | Bibliotheca Lindesiana | pencilled: 5/G. Pencilled on left inner upper cover: Ethiopic MSS | No 23.</p>
                    </provenance>
                    <provenance><p>Purchased by <name type="person" role="dnr"><persName ref="https://betamasaheft.eu/PRS0000">Enriqueta Rylands (1843–1908)</persName></name> in <date calendar="gregorian" when="1901">1901</date> from James Ludovic Lindsay, 26th Earl of Crawford
                      (1847-1913).</p></provenance>
                    <acquisition><p>Bequeathed by Enriqueta Rylands (1843–1908) in <date calendar="gregorian" when="1908">1908</date> to <name type="institution" ref="http://viaf.org/viaf/152274029" role="own"><orgName type="display">The John Rylands Library</orgName></name>.</p>
                    </acquisition>
                  </history>
                  

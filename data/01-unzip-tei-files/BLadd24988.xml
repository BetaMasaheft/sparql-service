                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በስመ፡ አብ፡ <gap reason="ellipsis"/> ንቀድም፡ በረድኤተ፡ እግዚአብሔር፡ ወበስነ፡ ሠርሐቱ፡
                            ጽሒፈ፡ ሃይማኖቱ፡ ለቅዱስ፡ ዐቢይ፡ ማሪ፡ ያዕቆብ፡ ዘእልበራድኢ፡ ጳጳሶሙ፡ ለያዕቆባውያን፡ ወለሶርያ፡
                            ወለቅብጥ፡ ወለኢትዮጵያ፡ ወውእቱ፡ ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ሮሐ።
                          </incipit>
                        </msItem>


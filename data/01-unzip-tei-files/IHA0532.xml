                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a0_1354">
                           <locus target="#49r">-49r</locus>
                           <q xml:lang="ar">تمت يوم الاحد السادس من شهر رجب بيد ذى التقصير المتوانى عما وجب الحقير أحمد مهاجر اسالك غفر انك يا غافر وسترك يا ساتر فى هذه الدنيا وفى اليوم الاخر بجاه النبى الطاهر واله واصحابه الاكابر لى ولجميع المسلمين والمسلمات الاحياء منهم والاموات لا سيما الاباء والامهات وسائر القرابات واهل المعارفات سنة ١٣٦١ هجريه</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a1_1356">
                           <locus target="#49v-51r">-49v-51r</locus>
                           <q xml:lang="ar">Notes on metrics with drawings of circles. Some of the notes marked šarh or š.</q>
                           <desc>Marginalia</desc>
                           <note>
                              <term key="Linguistics" ana="#Linguistics"/>
                           </note>
                        </item>
                        <item xml:id="a0_1356">
                           <locus target="#50v">-50v</locus>
                           <q xml:lang="ar">تمت ليلة الاربعاء التاسع من رجب الاصب بيد مكتسب الكتائر أحمد مهاجر اغفر لى يا غافر ولجميع المسلمين من الاصاغر والاكابر سنه ١٣٦١ هجريه </q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1355">
                           <locus target="#48r">-48r</locus>
                           <q xml:lang="ar">تمت يوم الثلاث من جمادى الثانية لثلاثة عشر يوما بقين منه سيه ١٣٦١ هجريه بيد أقل الورى وأحملهم وزرا أحمد الصغرى يا رب منك سترا فى الدنيا والاخرى</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_1350">
                           <locus target="#2r">-2r</locus>
                           <q xml:lang="ar">كتاب حرز الامانى ووجه التهانى للشيخ الامام العالم ابى محمد قاسم بن فيره ابن ابى القاسم خلف بن احمد الرعينى الشاطبى رحمهما الله امين</q>
                           <desc>Title</desc>
                           <note/>
                        </item>

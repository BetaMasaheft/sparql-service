                              <ref type="work" corresp="https://betamasaheft.eu/LIT1010IHA">سراج القارئ المبتدي وتذكار القري المنتهي</ref>
                              </desc>
                              <desc>
                                 Quotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT1010IHA">سراج القارئ المبتدي وتذكار القري المنتهي</ref>
                              </desc>
                           </note>
                        </item>
                        <item xml:id="a9_1350">
                           <locus target="#43v">-43v</locus>

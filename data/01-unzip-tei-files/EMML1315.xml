                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS0000">Walda Māryām (f. 156a) and probably also by Dassetā (f. 349a), but ff. 61b-68b is copied by a third and finer hand.</persName>
                     </handNote>
                  </handDesc>
                  <additions><list><item xml:id="a1">Qenē poems, fol. 353v; Records of earthquakes, fol. 353v-354r</item><item xml:id="e1">Copied by ወልደ፡ ማርያም, fol. 156r, and ደስታ, fol. 349r. Date based on mention of Emperor Menilek II, fol. 353v; Seal of the Institute of Ethiopian Studies, fol. 1r, 349r </item></list></additions>
                  <bindingDesc><binding><decoNote xml:id="b1">Parchment leaf wrapped around the quires; Carried in half of a double-slip mahdar
                  </decoNote></binding></bindingDesc>
               </physDesc>

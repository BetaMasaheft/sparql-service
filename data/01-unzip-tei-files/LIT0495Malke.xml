      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0495</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ እብል፡ እለ፡ ደብረ፡ ዓሥዓ፡ ዕደወ፨</l>
                  <l n="2">ትርሲተ፡ ዓለም፡ ኵሉ፡ ዘረሰይክሙ፡ እዳወ፨</l>
                  <l n="3">በማዕቀፈ፡ ጌጋይ፡ እምግማዔ፡ እስመ፡ ቅብዕየ፡ ተክዕወ፨</l>
                  <l n="4">ጸግዉኒ፡ አጋእዝትየ፡ ብርሃነክሙ፡ ኅትው፨</l>
                  <l n="5">በመንፈቀ፡ ሌሊት፡ እትቀበል፡ መርዓዌ፡ ሥርግወ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለደብርከ፡ እንተ፡ ቀደሰ፡ መንበሮ፨</l>
                  <l n="2">ተክለ፡ ሃይማኖት፡ ካህን፡ በአክናፈ፡ ብርሃን፡ ሰሪሮ፨</l>
                  <l n="3">ዮሐኒ፡ አነክር፡ ለእግዚእከ፡ ግብሮ፨</l>
                  <l n="4">ሠለስተ፡ መንበራተ፡ እምውሳጤ፡ ጸድፍ፡ ወቂሮ፨</l>
                  <l n="5">ከመ፡ ይሕንጽ፡ አሮን፡ ዘከሠተ፡ ምክሮ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ እምቃለ፡ ዳዊት፡ ዘተጠየቀ፨</l>
                  <l n="2">በኅሊና፡ ጌጋይ፡ ፅንሰቶ፡ እምዘዘከረ፡ ጥንቁቀ፨</l>
                  <l n="3">ፈለገ፡ አእምሮ፡ ዮሐኒ፡ ዘታፈአለፍል፡ ወርቀ፨</l>
                  <l n="4">አውሕዝ፡ ሊተ፡ ለገብርከ፡ ፈልፈለ፡ አብርሃም፡ ጽድቅ፨</l>
                  <l n="5">አመ፡ በጌጋይ፡ ይከሥት፡ ማየ፡ ኄር፡ ኀልቀ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለልደትከ፡ እምዘተወጥን፡ ውስቴታ፨</l>
                  <l n="2">በብሂለ፡ ስቡሕ፡ ወውሱድስ፡ ለቤተ፡ ክርስቲያን፡ ማሕሌታ፨</l>
                  <l n="3">ቢጸ፡ ዐርከ፡ ሥሉስ፡ ዮሐኒ፡ ነሣኤ፡ ጸሎት፡ ወልታ፨</l>
                  <l n="4">ኩነኒ፡ አበ፡ ነፍስየ፡ ከመ፡ ኢይኩን፡ እጓለ፡ ማውታ፨</l>
                  <l n="5">አመ፡ ለጉቡኣን፡ ይዴለዉ፡ ፯ቱ፡ ሐተታ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምዘትረ፡ ጸቃውዕ፡ ጥዑም፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘኵለንታሁ፡ አዳም፨</l>
                  <l n="3">ባሕታዌ፡ ምኔት፡ ዮሐኒ፡ ወብእሴ፡ ገዳም፨</l>
                  <l n="4">እፎ፡ እፎ፡ በፍርሀተ፡ ብእሲ፡ ሥዩም፨</l>
                  <l n="5">መነነተከ፡ ወላዲት፡ እም፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለቆምከ፡ ዘተመሰለ፡ በቀልተ፨</l>
                  <l n="2">ወለመልክእከ፡ ጽጌ፡ ዘይሠረጉ፡ ምኔተ፨</l>
                  <l n="3">በሕገ፡ ፍጡራን፡ ዮሐኒ፡ እንበለ፡ ታእምር፡ መዊተ፨</l>
                  <l n="4">አንገሠከ፡ አምላክከ፡ ዘኢተሐልፍ፡ መንግሥተ፨</l>
                  <l n="5">በይነ፡ ዘተወረውከ፡ ጸድፈ፡ እምትርአይ፡ ብእሲተ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ብሔረ፡ ሕያዋን፡ እንተ፡ ትበጽሕ፡ ከመ፡ ትረሲ፡ ህላዌ፨</l>
                  <l n="2">ምስለ፡ ነቢያት፡ ክልኤቱ፡ ኅጡኣነ፡ ሕማም፡ ወደዌ፨</l>
                  <l n="3">ርግበ፡ ተየውሖ፡ ዮሐኒ፡ ወጠቢበ፡ ጠቢብ፡ አርዌ፨</l>
                  <l n="4">እግዚእከ፡ ርኅሩኀ፡ ልብ፡ አመ፡ ይፌኑ፡ ድምፃዌ፨</l>
                  <l n="5">ረስየኒ፡ እትቀበል፡ መርዓዌ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ለእለ፡ ተዝካረከ፡ ገብሩ፡ እንዘ፡ ሀለዉ፡ በምድር፨</l>
                  <l n="2">ውዳሴከ፡ ሐለዩ፡ በቃለ፡ ሐዋዝ፡ መዝሙር፨</l>
                  <l n="3">ኦዮሐኒ፡ ብእሴ፡ እግዚአብሔር፨</l>
                  <l n="4">ዕሥዮሙ፡ ዕሤተ፡ ጽድቅ፡ ውስተ፡ ሰማያዊት፡ ሀገር፨</l>
                  <l n="5">እስመ፡ ለቅኑይ፡ ዕሤቱ፡ ንቡር፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለተኀብኦትከ፡ ኀበ፡ ኢይሰማዕ፡ ቦቱ፨</l>
                  <l n="2">ውሳጤ፡ ነገር፡ ወቃል፡ ለሐሰተ፡ ልሳን፡ ፍኖቱ፨</l>
                  <l n="3">ነሣኤ፡ መንፈስ፡ ዮሐኒ፡ ለወልደ፡ ማርያም፡ ድኅረ፡ ዕርገቱ፨</l>
                  <l n="4">ተለወት፡ ድኅሬከ፡ ገዳምከ፡ ወአዕማዲሃ፡ ተነሥቱ፨</l>
                  <l n="5">ነጺረ፡ ትአወርዎትከ፡ ዘዕጹብ፡ ርእየቱ፨</l>
               </lg>
            </div>
         </div>
      </body>

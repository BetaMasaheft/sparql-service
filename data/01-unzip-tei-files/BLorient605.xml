                        <msItem xml:id="ms_i2">
                          <locus from="74r"/>
                          <title type="complete" xml:lang="en">Homilies for the Festivals
                          of the blessed Virgin Mary</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i2.1">
                            <locus from="74r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6189Conception">Nagar zakama ḍansat ʾǝgzǝʾtǝna Māryām ʾǝmma ʾAmlāk</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ዜና፡ ፅንሰታ፡ ወዘልደታ፡ ለእግዝእትነ፡ ድንግል፡ በክልኤ፡ ማርያም።
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.2">
                            <locus from="83r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT6187Dersan3Tahsas">Dǝrsān za-yǝtnabbab ʾama 3 la-tāḫśāś baʾǝnta lǝdatā
          la-ʾǝgzǝʾtǝna Māryām walādita ʾAmlāk wa-zakama boʾat wǝsta beta maqdas wa-zakama
          ʾawaffayǝwwā la-Yosef wa-zakama ḥorat beta Zakāryās ḫaba bǝʾǝsitu ʾElsābeṭ</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.3">
                            <locus from="89v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1290Dersan">Dǝrsāna kidāna mǝḥrat</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              በስመ፡ እግዚአብሔር፡ አብ፡ ዘኃረያ፡ ለማርያም፡ ወቀደሶ፡ <gap reason="ellipsis"/>
                              ድርሳን፡ ዘእመ፡ ምሕረት፡ ድርሳን፡ ዘእመ፡ ሕይወት። ድርሳን፡ ዘእመ፡ መድኃኒት፡ ድርሳን፡ ዘእመ፡
                              ጸባዖት፡ ዘወላዲተ፡ ሣህል፡ ዘይትነበብ፡ ዮም፡ በዛቲ፡ ዕለት፡ በዓለ፡ ኪዳና፡ ለማርያም፡
                              ድንግል፡ እንተ፡ ይእቲ፡ አምደ፡ ሃይማኖት፡ ዘኢታንቀለቅል፡ እመ፡ ተንሥአ፡ ሞገደ፡ ማዕበል፡
                              አልቦቱ፡ ድቀት፡ ለዘባቲ፡ ይትዌከል።
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.4">
                            <locus from="94r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1124Apocal">Rāʾǝya [ʾǝgzǝʾtǝna] Māryām</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              በስመ፡ አብ፡ <gap reason="ellipsis"/> ይቤ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ዘያፈቅሮ፡
                              እግዚእ፡ ፈድፋደ፡ በእንተ፡ ንጽሕናሁ፡ ወእግዝእትነ፡ ማርያም፡ ታፈቅሮ፡ ፈድፋደ፡ በከመ፡ አፍቀሮ፡ ወልዳ።
                              ወአውሥአቶ፡ ወትቤሎ፡ ኦዮሐንስ፡ ስማዕ፡ አነ፡ እነግረከ፡ ኅቡዓ፡ ምሥጢረ፡ ወመድምመ፡ በልብ፡ ዘኢይጤየቅ፡
                              ወበሕሊና፡ ዘኢይጠነቀቅ፡ ዘከሠተ፡ ሊተ፡ እግዚእየ፡ ወወልድየ፡ ኢየሱስ፡ ክርስቶስ፡ ፍቁርየ፡ ወመድኃንየ፡ እንዘ፡
                              እጼሊ፡ በጎልጎታ፡ ጊዜ፡ ፯ ሰዓት፡ ዝውእቱ፡ ቀትር፡ በዕለተ፡ ዓርብ፡ መጽአ፡ ደመና፡ ብሩህ፡ ወጾረኒ፡ ወኣዕረገኒ፡
                              መልዕልተ፡ ሣልስ፡ ሰማይ። ወአንበረኒ፡ ማእከለ፡ ጽንፈ፡ ምድር፡ ወአስተርአየኒ፡ ወልድየ። ወይቤለኒ፡ ሰላም፡ ለኪ፡
                              ኦማርያም፡ እምየ፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.5">
                            <locus from="108r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2619Zenala">The History of the
                            Death and Assumption of the blessed Virgin, as narrated on the authority of St John</title>
                            <textLang mainLang="gez"/>

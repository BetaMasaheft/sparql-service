                        <item xml:id="a0_502">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Ṯumn markers. </q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a5_502">
                           <locus target="#119v">-119v</locus>
                           <q xml:lang="ar">اعوذ بالله من النار ومن شر الكفار ومن غضب الجتار العزة لله والواحد القهار </q>
                           <desc>Marginalia</desc>
                           <note>The title of Sūrat al-tawba (sūra 9) and the du‘ā’ are written in the same hand and they fill the page. Two sides of the text are framed with a row of small black and red circles.</note>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a3_502">
                           <locus target="#68r-128r-269v-304v-326v">-68r, 128r, 269v, 304v, 326v</locus>

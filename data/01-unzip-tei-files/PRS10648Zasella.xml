               <occupation type="military">governor</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               
               
               <floruit notBefore="1590" notAfter="1608">He was a nobleman in the early 17th century who emerged as an important political figure from low class family. 
                  Zaśǝllāse married one or even two daugthers of <roleName type="title">ʾaṣe</roleName> 
                  <persName ref="https://betamasaheft.eu/PRS8550sardaDe">Śarḍa Dǝngǝl</persName>. 
                  He was actively involved in the succession disputes that ensued in the early 17th century.  He fought with 
                  <roleName type="title">ʾaṣe</roleName>
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName> but was defeated.</floruit>
               <death when="1608"/>
            </person>
            

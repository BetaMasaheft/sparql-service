                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                        <desc>Crude drawings of faces in pencil</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#4r" facs="006">Fol. 4r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (to the right) holds his hand up to two other people
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#28r" facs="030">Fol. 28r</locus>
                        <desc>Saint <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/>, <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#56v" facs="059">Fol. 56v</locus>
                        <desc>Jesus with three others, man in front of Jesus has one eye closed <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs: <locus target="#1r" facs="003">fol. 1r</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red);
                      <locus target="#50v #52v" facs="053 055">50v, 52v</locus> (dotted line using black)
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <desc type="Asmat">
                              <locus target="#iv(erso) #iir(ecto) #iiv(erso)" facs="002 003">Fols. iv(erso), iir(ecto), iiv(erso)</locus> Asmat prayer against evil spirits, damaged with incipit:
                            <foreign xml:lang="gez">
                              ..አጋንንት፡ መግረሬ፡ [ፀ]ር፡ በከም፡ ተሰዱ፡ [..]ማሙኪር፡ ባሪ[ያ፡] ወመቃውዜ፡ ዛ[ር፡] ወዛራት፡ ሥራየ፡ [ጉ]ዳሌ፡ ወጠፍንት፡ ነሀቢ፡ ወቄደር፡ ባርያ፡ ወነገርጋር፡<gap reason="omitted"/>
                            </foreign>
                           </desc>
                        </item>
                        <item xml:id="a2">
                           <desc>
                              <locus target="#40v" facs="043">Fol. 40v</locus> Fragment of a prayer to God, with incipit:
                          <foreign xml:lang="gez">
                            ሰ፡ ሕይወት፡ ወሰላም፡ እንዘ፡ ይጸወኑ።ብከ፡ ፍ..፡..ይማኖ..፡ ንጽሐ፡ ወትእግሥተ፡ ፍቅረ፡ ወኂሩተ፡<gap reason="omitted"/>
                          </foreign>
                           </desc>
                        </item>
                        <item xml:id="a3">
                           <desc>
                              <locus target="#51v #52r #52v" facs="054 055">Fols. 51v, 52r, 52v</locus> Prayer against evil spirits. Incomplete at the beginning and at the end, with incipit:
                          <foreign xml:lang="gez">
                            ..እመሂ፡ በመዓልት፡ ወእመሂ፡ በሌሊት፡ እመሂ፡ በሠርክ፡ ወእመሂ፡ በጽልመት፡ ወበብርሃን፡ እመሂ፡ በቀትር፡ ወበሰአት፡ በኵሉ፡ ጊዜ፡ ወበኵሉ፡ ወርኅ፡ ኢትቅረቡ፡ ኃቤየ፡<gap reason="omitted"/>
                          </foreign>
                           </desc>
                        </item>
                        <item xml:id="a4">
                           <desc type="ScribalNoteCommissioning">Copied for <foreign xml:lang="gez">ሰፎንያስ፡</foreign>, <locus target="#50v" facs="053">fol. 50v</locus>
                           </desc>
                        </item>
                        <item xml:id="a5">
                           <desc type="OwnershipNote">
                          Note of ownership by <foreign xml:lang="gez">ወልደ፡ መስቀል፡</foreign>, <locus target="#11v #12v" facs="014 015">fols. 11v, 12v</locus> and passim
                        </desc>
                        </item>
                        <item xml:id="a6">
                           <desc>
                          Overlooked words of text are written interlinearly (<locus target="#13v #19r #22v #27r #30r #38v #43r #45v" facs="016 021 025 029 031 041 045 048">folss. 13v, 19r, 22v, 27r, 30r, 38v, 43r, 45v, </locus>);
                          and overlooked lines of text are written interlinearly (<locus target="#37v" facs="040">37v</locus>)
                        </desc>
                        </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 108 x 65 x 40 mm, three Coptic chain stitches attached with bridle attachments to rough-hewn boards covered with floral-patterned (red with blue, white, and yellow), linen double-pouch cover, with a protection strap that runs from head of the spine around the text block fore edge.</decoNote>
                        <decoNote xml:id="b2">
                           <material key="parchment"/>
                           <material key="wood"/>
                           <material key="textile"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>

               <msContents>
                  <summary>Prayer of the Blessed Virgin Mary at Golgotha, ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ዘሰኔ፡ ጎልጎታ፡, Mystagogia, ትምህርተ፡ ኅቡዓት፡, Sword of Divinity, ሠይፈ፡ መለኮት፡, incomplete, God of the Luminaries, እግዚአብሔር፡ ዘብርሃናት፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="40r" facs="003">Fols 1r–40r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="41r" to="50v" facs="043">Fols 41r–50v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="52v" to="53v" facs="055">Fols 52v–53v, </locus>
                     <locus from="50v" to="51r" facs="053">50v–51r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2295Sayfam">Sayfa malakot</title>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="53v" to="55r" facs="056">Fols 53v–55r</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer
                                                  za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
                     </msItem>

               </msContents>

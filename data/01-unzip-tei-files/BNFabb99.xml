                  <history>
                  <origin>
                     <origDate notBefore="1800" notAfter="1848" evidence="context">The first half of the
                       19th century, but before 1848.</origDate>
                       According to <persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d’Abbadie [d’Arrast]</persName>, the text was copied by an unnamed scribe
                       under the supervision
                       of his brother <persName ref="https://betamasaheft.eu/PRS1072dAbbadi">Arnauld [Michel] d’Abbadie [d’Arrast]</persName>, from a text that was approved and
                       accepted by the church scholars of  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName>.
                  The manuscript was in possession of <persName role="owner" ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine d'Abbadie</persName>.
                      </origin>
                <acquisition>The manuscript entered the <placeName ref="https://betamasaheft.eu/INS0303BNF">Bibliothèque
                  nationale de France</placeName> in
                  <date>1902</date>.
                  </acquisition>
               </history>

            <div type="bibliography">
              <listBibl type="editions">
                  <bibl corresp="http://zotero.org/groups/358366/items/CAWIU8A5"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Leander1917Astabqueot"/><title level="a">ʾAstabqu̯eʿōt ʿenta za-Semʿōn ʿamdāwī nach Handschriften in Uppsala und Berlin herausgegeben</title><title level="j">Le Monde Oriental</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Pontus</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Leander</t:surname></author><date>1917</date><biblScope unit="volume">11</biblScope><biblScope unit="page">81-130</biblScope><note type="url">https://menadoc.bibliothek.uni-halle.de/urn/urn:nbn:de:gbv:3:5-36681</note></bibl>
              </listBibl>
                
            </div>
            <div type="edition">
              <note>Following text structure is based on <ref type="mss" corresp="https://betamasaheft.eu/BLorient578">London, British Library, BL Oriental 578</ref>.</note>
               <div type="textpart" subtype="chapter" xml:id="Sunday">
                 <div type="textpart" subtype="incipit" xml:lang="gez">
                   <ab>እሰግድ፡ ለኪ፡ ኦእግዝእትየ፡ ማርያም፡ ድንግል፡ ኦእመ፡ መድኃኒት፡ እስእለኪ፡ አስተብቋዒተ፡ ከመ፡ ትኵነኒ፡ በሌሊት፡ ወበመዓልት።</ab>
                 </div>
                </div>

               <div type="textpart" subtype="chapter" xml:id="Monday"/>
               <div type="textpart" subtype="incipit" xml:lang="gez">
                 <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዘወረድከ፡ ውስተ፡ ዝንቱ፡ ዓለም፡ ዘያስተርኢ።</ab>
               </div>

               <div type="textpart" subtype="chapter" xml:id="Tuesday"/>
               <div type="textpart" subtype="incipit" xml:lang="gez">
              <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርቶስ፡ ዘመጻእከ፡ ኀበ፡ ጥምቀት፡ ከመ፡ ትጠመቅ፡ ወከመ፡ ትረስያ፡ ለነ፡ እመ፡ ዘተወልደ፡ እማኅፀነ፡ ሕይወት፡ ሐዲስ፡</ab>
                 </div>

               <div type="textpart" subtype="chapter" xml:id="Wednesday"/>
               <div type="textpart" subtype="incipit" xml:lang="gez">
                 <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ኖላዊ፡ ኄር፡ መዝምዝ፡ ቍስልየ።</ab>
              </div>

               <div type="textpart" subtype="chapter" xml:id="Thursday"/>
                <div type="textpart" subtype="incipit" xml:lang="gez">
                  <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዘአድኃንኮ፡ ለአልአዛር፡ እምግንዘት።</ab>
                </div>

               <div type="textpart" subtype="chapter" xml:id="Friday"/>
               <div type="textpart" subtype="incipit" xml:lang="gez">
                 <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተቀጸልከ፡ አክሊለ፡ ዘሦክ፡ አስተቀጽለኒ፡ አክሊለ፡ መድኃኒት፡ ወመዊእ።</ab>
                 </div>

               <div type="textpart" subtype="chapter" xml:id="Saturday"/>
               <div type="textpart" subtype="incipit" xml:lang="gez">
                 <ab>ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዘሰፋሕከ፡ እዴከ፡ ቅድስተ፡ ወባረካሆሙ።</ab>
               </div>

            </div>

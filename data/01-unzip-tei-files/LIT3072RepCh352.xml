      <t:body>
         <t:div type="bibliography">
            <t:listBibl type="editions">
               <t:bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename>Marius</t:forename><t:surname>Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><t:citedRange unit="item">352</t:citedRange></t:bibl>
               <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl>
            </t:listBibl>
            
         </t:div>
         <t:div type="edition">
            <t:note>Taken from <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl></t:note>
               <t:lg type="stanza" n="1">
                  <t:l n="1">እኅተ፡ ክርስቶስ፡ ሥርጉት፡ ወርቀ፡ መሲሐዊት፡ አሚን፨</t:l>
                  <t:l n="2">አምሳለ፡ ቢሶስ፡ ትርሲተ፡ ካህን፨</t:l>
                  <t:l n="3">ወንጹሕ፡ ሄጶዴጤን፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለኪ፡ በቀላየ፡ ኃፍረት፡ አስጠምኪ፡ ትዝኅርተ፡ ዲያብሎስ፡ ከይሲ፨</t:l>
                  <t:l n="2">አካላተ፡ ሥሉስ፡ እንዘ፡ ትቄድሲ፨</t:l>
                  <t:l n="3">ወእምጽድቅ፡ ኢትትገሀሲ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ሰላም፡ ለኪ፡ እኅተ፡ ክርስቶስ፡ ትባኢ፡ ውሣጤ፡ መንጦላዕት፡ ከዋላ፨</t:l>
                  <t:l n="2">መነንኪያ፡ ጥቀ፡ ከመ፡ ኳሔላ፨</t:l>
                  <t:l n="3">ለዓለም፡ ካልእተ፡ ህላ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ሰላም፡ ለኪ፡ በጸሎት፡ ወጾም፡ ወሰጊድ፡ ህየንተ፡ ድካምኪ፡ በዝኃ፨</t:l>
                  <t:l n="2">እንተ፡ ኢያስተርኢ፡ ቀርን፡ በጊዜ፡ ተነፍሐ፨</t:l>
                  <t:l n="3">ትትሌዓሊ፡ ደብረ፡ ፍሥሐ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ሰላም፡ ለኪ፡ ለነፍሰ፡ አዳም፡ ነፍስኪ፡ ጊዜ፡ ተዳደቀ፡ ፍልሰት፨</t:l>
                  <t:l n="2">ለቀበላሃ፡ ወረዱ፡ ምስለ፡ ማኅሌት፨</t:l>
                  <t:l n="3">ትጉሃን፡ እምሰማያት፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ሰላም፡ ለኪ፡ ዘያስተሐቅር፡ ኪያኪ፡ እመቦ፡ እስመ፡ እምልቡና፡ ተዐርቀ፨</t:l>
                  <t:l n="2">ይሁዳ፡ ሰይጣን፡ ዘአፍቀረ፡ ወርቀ፨</t:l>
                  <t:l n="3">ይረፍቅ፡ ኀበ፡ ረፈቀ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሰላም፡ ለኪ፡ እኅተ፡ ክርስቶስ፡ እምነ፨</t:l>
                  <t:l n="2">ቀላተ፡ ማኅሌት፡ እምአፉነ፨</t:l>
                  <t:l n="3">ኵሎ፡ ዕለተ፡ ወኵሎ፡ ዘመነ፨</t:l>
                  <t:l n="4">መንገሌኪ፡ ናንቀዓዲ፡ ዐይነ፨</t:l>
               </t:lg>
            
            
         </t:div>
      </t:body>
   </t:text></TEI>
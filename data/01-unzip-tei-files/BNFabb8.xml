                  <handDesc>
                   <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Late 18th/ early 19th century.</seg>
                      <desc>A. d'Abbadie refers to the handwriting as <foreign xml:lang="fr">fort mauvaise et modern</foreign>.
                         C. Conti Rossini indicates a possible 
                         change of hand at the end of the text 

                         (<foreign xml:lang="fr">la fin semble être d'une autre ècriture</foreign>).</desc>

                           </handNote>
                             </handDesc>
                 <bindingDesc>
                   <binding contemporary="Ethiopian">
                     <decoNote xml:id="b1">Two wooden boards, remains of a leather cover, 
                        according to A. d'Abbadie. No information about binding is provided
                        in the catalogue of C. Conti Rossini; M. Chaîne only mentions that the binding is indigenous.</decoNote>                     
                   </binding>
                 </bindingDesc>
                                 </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1700" notAfter="1830">18th or beginning of the 19th century</origDate>.
                     The dating 18th or beginning of the 19th century has been proposed by to C. Conti Rossini.
                     A. d'Abbadie indicates that he bought the manuscript in <placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</placeName>.
                     According to C. Conti Rossini, at the end of the manuscript there is an additional note written in a crude hand, 
                     which seems to mention ʾabuna Gabra Manfas Qǝddus who obtained 
                     the manuscript as <foreign xml:lang="am">rǝst</foreign> of an unspecified church of St Mary 
                     and the place called Bata Garimā (possibly <placeName ref="https://betamasaheft.eu/INS0336EAG">ʾƎndā ʾAbbā Garimā</placeName>). Both the reading 
                     and the interpretation of the note cannot be ascertained. 
                  </origin>
                      <acquisition>The manuscript entered <placeName ref="https://betamasaheft.eu/INS0303BNF">Bibliothèque nationale de France</placeName> in
                   <date>1902</date>.</acquisition>                    
               </history>

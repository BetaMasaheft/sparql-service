                            <colophon xml:id="coloph1">
                                <locus from="192r"/>
                                በአኰቴተ፡ አብ፡ <gap reason="ellipsis" resp="PRS10171Wright"/> ተፈጸመ፡ ዝንቱ፡ መጽሐፈ፡ ገድለ፡ ሐዋርያት፡ ዘተጽሕፈ፡ በ፩ዓመተ፡ መንግሥቱ፡ 
                                ለንጉሠነ፡ <add><persName ref="https://betamasaheft.eu/PRS5616IyasuI">አያሱ፡</persName></add> መፍቀሬ፡ እግዚአብሔር፡ በመዋዕለ፡ ሢመቱ፡ 
                                ለ<persName ref="https://betamasaheft.eu/PRS12873MazmuraD"><roleName type="title">አባ፡</roleName> መዝሙረ፡ ድንግል፡</persName> 

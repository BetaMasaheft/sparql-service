               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="12v">1r-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0994IHA">ارشاد الاخوان فيما يتعلق فى هلال رمضان</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله الماهم للسداد المان بالتفقه فى احكام الشريعة من اختاره من العباد والهادى الى سبيل الرشاد الذى وفق من اصطفاه للعمل على وفق كتابه وسنة حبيبه سيدنا محمد سيد الاسياد والصلاة والسلامعليه وعلى اله وصحبه السالمين من الأهواء المنضلة فى الأفعال والا قوال والاعتقاد والتابعين لهم باحسان الى يوم التناد اشهد ان لا اله الا الله الكريم المنان بالعباد وأشهد ان سيدنا محمد اعبده ورسوله الصادق المرشد للخلق ومنقذهم من الضلال والفساد
 اما بعد فيقول أسير هوى النفس وخادم وطلبة العلم وتراب اقدامهم بدر الدين ابن الحاج محمد سرور [...] لما رايت اهمال اكثر اهل عصرنا بامر العبادة التى هى ركن من أركان الاسلام الخمسة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>وقال عمدة اهل التحقيق الامام النووى رحمه الله تعالى الرحمة الواسعة فى المجموع ما نصه</explicit>
                     <note>Draft</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="13r" to="27v">13r-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0994IHA">Iršād al-iḫwān fī-mā yataʿallaq fī hilāl Ramaḍān hūwa mafrūḍ ʿalā al-insān</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>بسم الله الرحمن الرحسم الحمد لله الموفق للتفقه فى الدين والملهم للسداد والهادى الى سبيل الرشاد الذى اصطفى عباده بالعمل على وفق كتابه وسنة رسوله وحبيبه وصفوة خلقه واكمل ريله سيدنا محمد سيد الاسياد والصلاة والسلام عليه وعلى اله وصحبه السالمين من الأهواء المضلة فى الافعال والاقوال والاعتقاد والتابعين لهم باحسان الى يوم التناد اشهد ان لا اله الا الله الكريم المنان بالعباد واشهد اأن سيدنا محمدا مرسله الصادق المرشد للخلق ومنقذهم من الضلال والفساد 
اما بعد فيقول الفقير اسير هو النفس وخادم طلبة العلم وتراب أقدامهم بدر الدين ابن الحاج محمد سرور  [...] انى لما رايت اهمال اكثر اهل بلاد المسلمين من حكام وقضاة هذا العصر فضلا عن غيرهم بامر العبادة التى هى ركن من أركان الاسلام الخمسة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27v">-27v</locus>الاخر اى لم يرفيه الى بلد الرؤية عيد معهم حتما وقضى يوما ان صام ثمانية وعشرين يوما اذا الشهر لا يكون كذلك فليكن هذا آخر ما جمعته من متفرقات الكتب بتوفيق من الله لمن يطلب ان يأخذ دينه من كتب اهل العلم المذكورين اوائل هذا المجموع</explicit>
                     <note>Draft</note>
                     <note/>
                  </msItem>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">እስመ፡ ብዙኃን፡ እለ፡ ወጠኑ፡ ዕበያተ፡ ክርስቶስ፡ ለዜንዎ፨</l>
                  <l n="2">ረትዓኒ፡ ትቤ፡ እምጥንቱ፡ እትልዎ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለጸላሎትከ፡ በጽላሎተ፡ አምላክ፡ ኃዳሪ፨</l>
                  <l n="2">ዘተሐውር፡ በንጹሕ፡ ወጽድቅ፡ እንዘ፡ ገባሪ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለመልክእከ፡ እለ፡ ተጽሕፋ፡ ቅድመ፨</l>
                  <l n="2">ዘደመ፡ ኢየሱስ፡ ከዊኖ፡ ቀለመ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለሥዕርትከ፡ እምእግዚአብሔር፡ ኍሉቅ፨</l>
                  <l n="2">እምኔሆን፡ አሐቲ፡ እንተ፡ ኢትወድቅ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋከ፡ በሰንዶናት፡ ዘተገንዘ፨</l>
                  <l n="2">ለሕዝበ፡ እስራኤል፡ በከመ፡ ተአዘዘ፨</l>
                  <l n="3">ዘተሐብር፡ ሉቃስ፡ ዘጳውሎስ፡ ግዕዘ፨</l>
                  <l n="4">ሥነ፡ ምግባሪከ፡ ያከፍእ፡ ቤዘ፨</l>
                  <l n="5">ርትዐተ፡ ልብከ፡ ይመስል፡ በለዘ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ለሥጋከ፡ መዝገቡ፨</l>
                  <l n="2">እስከ፡ ይበጽሕ፡ ሰዐ፡ ከብከቡ፨</l>
                  <l n="3">ለእግዚአብሔር፡ ሉቃስ፡ እምነ፡ ኅሩያን፡ ሕዝቡ፨</l>
                  <l n="4">እምቃለ፡ ትምህርትከ፡ ስቴ፡ ጽሙዓነ፡ ረከቡ፨</l>
                  <l n="5">ለማየ፡ ወንጌል፡ አንተ፡ ምንሐቡ፡ ወርሰርቡ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">ሰላም፡ ለመልክእከ፡ ወለአባላቲከ፡ በኆልቍ፨</l>
                  <l n="2">ጽዱላን፡ አዕናቍ፨</l>
                  <l n="3">መዐዛከኒ፡ ጽጌ፡ ሰንሰሪቍ፨</l>
                  <l n="4">በዐጸደ፡ ንጉሥ፡ ቀዋሚ፡ እንተ፡ ኢትንህል፡ ዕጥቍ፨</l>
                  <l n="5">ወሥዕርቲነ፡ ሉቃስ፡ ዘሕቍ፨</l>
               </lg>
               <lg type="stanza" n="53">
                  <l n="1">ዜና፡ ውዳሴከ፡ ጥንቁቀ፡ ዘኢያሠነይኩ፡ ተናግሮ፨</l>
                  <l n="2">በተሐብሎትየ፡ አላ፡ መጠነ፡ ክህልኩ፡ ዘእፌጽሮ፨</l>
                  <l n="3">አልቦ፡ ፍርሀት፡ ውስተ፡ ተፋቅሮ፨</l>
                  <l n="4">ዘገደፍኩ፡ ወዘወሰኩ፡ በዘአልብየ፡ አእምሮ፨</l>
                  <l n="5">ለቃለ፡ ማሕሌትየ፡ አርቲአከ፡ ለዓለም፡ ሥመሮ፨</l>
               </lg>
            </div>
         </div>
      </body>

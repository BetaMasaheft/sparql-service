               <msContents>
                  <summary>Large Psalter with Mahdar</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="182r" facs="002">Fols 1r–182r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref>. A secondary hand has added an additional system of the spiritual meanings</note>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="131v" facs="002">Fols 1r–131v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                  </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="132r" to="146r" facs="133">Fols 132r–146r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                    <note>Includes musical notation</note>
                  </msItem>

                  <msItem xml:id="ms_i1.3">
                    <locus from="146r" to="153v" facs="147">Fols 146r–153v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    <colophon xml:id="coloph1">
                      <locus target="#153v" facs="155">Fol. 153v</locus>
                      a colophon mentioning an owner Zä-ʾÄfä Krǝstos (<foreign xml:lang="gez">ዘአፈ፡ ክርስቶስ፡</foreign>) and his wife Wälattä Dawit (<foreign xml:lang="gez">ወላተ፡ ዳዊት፡</foreign>). It states that he ordered the book with his own means. The colophon concludes with a curse that anyone who steals or cancels anything is condemned by the authority of Peter and Paul
                    </colophon>
                  </msItem>

                  <msItem xml:id="ms_i1.4">
                    <locus from="154r" to="174v" facs="155">Fols 154r–174v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                    <note>Arranged for the days of the week</note>

                  <msItem xml:id="ms_i1.4.1">
                    <locus from="154r" facs="155">Fols 154r and following</locus>
                    <title>Monday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.2">
                    <locus from="156r" facs="157">Fols 156r and following</locus>
                    <title>Tuesday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.3">
                    <locus from="160r" facs="161">Fols 160r and following</locus>
                    <title>Wednesday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.4">
                    <locus from="163r" facs="164">Fols 163r and following</locus>
                    <title>Thursday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.5">
                    <locus from="166v" facs="168">Fols 166v and following</locus>
                    <title>Friday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.6">
                    <locus from="169r" facs="170">Fols 169r and following</locus>
                    <title>Saturday</title>
                  </msItem>

                  <msItem xml:id="ms_i1.4.7">
                    <locus from="172r" facs="173">Fols 172r and following</locus>
                    <title>Sunday</title>
                  </msItem>
                  </msItem>

                  <msItem xml:id="ms_i1.5">

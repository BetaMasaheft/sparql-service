                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#21r" facs="022">Fol. 21r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with the archangels <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> and <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#41r" facs="042">Fol. 41r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#61r" facs="062">Fol. 61r</locus><desc>A female and male saint (<ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> and Jesus?) seated in front of four <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#70v" facs="072">Fol. 70v</locus><desc>The Virgin <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> surrounded by four <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#82v" facs="084">Fol. 82v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1016Flight">Flight into Egypt</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#105r" facs="106">Fol. 105r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>, <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John stand beside the cross</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#144v" facs="146">Fol. 144v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>

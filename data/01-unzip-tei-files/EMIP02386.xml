                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    An Explanation of the Trinity. Written in Amharic by an untrained hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#131v" facs="133"> f. 131v, bottom</locus>
                    a prayer with the instruction <q>“pray three times.”</q>
                    Incipit: <foreign xml:lang="gez">ሃ፡ መኑ፡ ይመሰለከ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="Asmat">
                    <locus target="#153v" facs="155">Fol. 153v</locus>
                    An <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for protection based on the five dolours.
                    Incipit: <foreign xml:lang="gez">ለተናዊ፡ ሰተናቂ፡ ቀናዊ፡ ተንከረም፡ ማኅየዊ፡ ዘውኅዘ፡ ደም፡ አመ፡ ረገዝዎ፡ ገቦሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ በዲበ፡ ዕፀ፡ መስቀል፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#182r #182v" facs="183 184">Fols. 182r, 182v</locus>
                    A rhyming poem and prayer for Mary on behalf of the owner, Wälättä Giyorgis (<foreign xml:lang="gez">ወለተ፡ ጊዮርጊስ፡</foreign>). Written by the same hand as the rest of the Psalter.
                    Incipit: <foreign xml:lang="gez">ለኪ፡ ይደሉ። ለኪ፡ ይደሉ። ለኪ፡ ይደሉ። ትስአሊ፡ ለነ፡ ኀበ፡ ወልድኪ፡ እግዚአ፡ ኵሉ።</foreign>
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc type="Asmat">
                    <locus target="#183v #184r #184v #185r" facs="185 186">Fols. 183v, 184r, 184v, 185r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> for protection from enemies and demons. Written in Amharic
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#69v" facs="071">Fol. 69v</locus>
                    The midpoint of the Psalms is not marked
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc>
                    <locus target="#174v" facs="176"> f. 174v and passim</locus>
                    mention Wälättä Giyorgis (<foreign xml:lang="gez">ወለተ፡ ጊዮርጊስ፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <desc type="ScribalNoteCompleting">
                    <locus target="#182v" facs="184">Fol. 182v</locus>
                    a scribal note of completion
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#185v" facs="187">Fol. 185v</locus>
                    pen trials
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#124 #160 #163 #167 #172" facs="125 161 164 168 173">Fols. 124, 160, 163, 167, 172</locus>
                    red string stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#175 #182" facs="176 183">Fols. 175, 182</locus>
                    blue string stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                      words of text are written interlinearly (<locus target="#9r #16r #17v #19r #19v" facs="010 017 109 021">folss. 9r, 16r, 17v, 19r, 19v, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#50r #144r" facs="051 145">50r, 144r, </locus>);
                      erasure markings are visible (<locus target="#72r" facs="073">72r, </locus>);
                      text has been removed (<locus target="#8r #22v #26r #36v #57r" facs="009 024 027 038 058">8r, 22v, 26r, 36v, 57r</locus>, etc.)
                    </desc>
                    </item>

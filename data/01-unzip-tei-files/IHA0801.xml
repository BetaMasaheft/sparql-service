               <msContents>
                  <summary>ff. A-R loose folios</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="10v">1r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2081IHA">دعاء يا فرد يا صمد يا أبدي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسملة \ يا فرد يا صمد يا ءبدي يا واحد يأحد يا بديّ \ يا وجد يا جواد يا بديّ وعلى ألي محمد يا أبدي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>والحمد لله يا كافي لي نعمه \ تمم لي الخير يا إلهي منّة ٬ عليك الله سلما أحمد محمد تمت وبالخير عمت</explicit>
                     <note>loose f. P it's part of this codicological unit; ff. 7v, 8v, 9v, 10r-v blank</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="11r" to="15v">11r-15v</locus>
                     <textLang xml:lang="af">Afar</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2184IHA">دعاء بالعفرية يَيْشِيْ رَبُّوْ تَيْشِمْ نِهْ أَبْتَمْ
                    كُلْ فَنَّا</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>بسملة \ يَيْشِيْ رَبُّوْ تَيْشِمْ نِهْ أَبْتَمْ كُلْ فَنَّا يَيْشِيْ مَرَنِيْ أَبْتُهْ \ ݣُيْتَوْكُوْدَ عِنَّا يَيْشِيْ أَبْنَاكِيْ مَرْحَلْ يَيْشِيْ أَرَحْ كُلْ فَنَّا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>سَرْتَنْ كِيْ عَرَهَيْ فُلَهْ مَالِيْ لَنَا أَݣُوْابّرْكِيْ مِنْبَرْ مَحْشَرَ \ كَهْ مَانَا</explicit>
                     <note>All the verso sides are blank in addition to ff. 13r and 15r</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="16r" to="18v">16r-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT2185IHA">نظم بسم الله فلك الحمد يا ربّي يا حسبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>بسم الله بسم الله فلك الحمد يا ربّي \ بسم الله بسم الله فلك الحمد يا حسني \ أسئلك بك بك وباالقرآن والنبيّ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>جميل الذكر مجتب لله الخالق حامد \ منصور ناصر للدين مكنون السر عابد</explicit>
                     <note>ff. 16v-18v blank</note>
                     <note/>
                  </msItem>

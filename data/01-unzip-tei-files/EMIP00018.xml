                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#17r #36v #43r #45r #52r #62r #158v #175r" facs="017 037 043 045 052 062 159 175">folss. 17r, 36v, 43r, 45r, 52r, 62r, 158v, 175r, </locus> (dotted line using alternating black and red);

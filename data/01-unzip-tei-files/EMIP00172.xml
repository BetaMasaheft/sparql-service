                  <textLang mainLang="am" otherLangs="gez">Gǝ‘ǝz</textLang>

                    <msItem xml:id="ms_i1"><locus from="1r" to="2r" facs="001">Fols 1r–2r</locus><title type="complete" ref="https://betamasaheft.eu/LIT5934CommOurFather">Amharic
                                                  Commentary on the Our Father</title>
                    <incipit xml:lang="am">
                      አቡነ፡ ዘበሰማያት፡ በሉኝ፡ አለ፡ ምነው፡ ቀድሞ፡ እግዚእነ፡
                      ወአምላክነ፡ ይሉ፡ ነበረ፡ ሕይወተ፡ ልቡና፡ ሀብተ፡ ወልድና፡
                      አልተሰጠም፡ ነበረና፡ ዛሬ፡፡ ግን፡ ተሰጥቶሃልና፡ ስለዚህ፡ አቡነ፡ በሉኝ፡
                      አለ። ጌታ፡ ሎሌውን፡ ቢወድ፡ መምህር፡ ደቀ። መዝምሩን፡ ቢወድ፡
                      ርስቱን፡ ጉልቱን፡ አያወርሰውም፡ ለልጁ፡ ያወርሳል፡ እንጂ፡ እርሱም፡
                      መንግሥተ፡ ሰማያትን፡ ያወርሰናልና፡<gap reason="omitted"/>
                    </incipit>
                  </msItem>
                    <msItem xml:id="ms_i2"><locus from="3r" to="5r" facs="003">Fols 3r–5r, </locus><locus from="71v" to="73r" facs="072">71v–73r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our
                                                  Lady Mary</title>
                    <incipit xml:lang="gez">
                      ሰላም፡ ለኪ፡ ማርያም፡ ድን[ግ]ል፡ ዘመአዛ፡ አፉኪ፡ ኮል፡
                      እንተ፡ ትፄንዊ፡ በገዳም፡ ወሐቅል፡
                      ወልታ፡ ረዲኦትከ፡ በውስተ፡ ቀትል።
                    </incipit>

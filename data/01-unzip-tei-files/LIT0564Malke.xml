         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘለዓለም፡ ሥላሴ፨</l>
                  <l n="2">ናሁ፡ ወጠንኩ፡ ለዕበይከ፡ ውዳሴ፨</l>
                  <l n="3">ከመ፡ ትርድአኒ፡ ነዓ፡ ሳሙኤል፡ ነቅዐ፡ ቅዳሴ፨</l>
                  <l n="4">ሠናየ፡ ነግደ፡ ከዊነከ፡ ወኄረ፡ ፈላሴ፨</l>
                  <l n="5">እንዘ፡ አንበሳ፡ ትጼዐን፡ ወትከይድ፡ ከይሴ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘይጥዕም፡ ወይሤኒ፨</l>
                  <l n="2">እምጣዕመ፡ መዐር፡ ወሶከር፡ ዘኢይትማሰሎ፡ ምንተኒ፨</l>
                  <l n="3">ፀሓየ፡ ደናግል፡ ሳሙኤል፡ አርእስተ፡ ከዋክብት፡ ዘትቀኒ፨</l>
                  <l n="4">ለሞገስከ፡ ከዳኒ፡ ወለስምከ፡ ሰፋኒ፨</l>
                  <l n="5">ይሰግድ፡ ብርክ፡ ወልሳን፡ ይገኒ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ከመ፡ ሕገ፡ አበው፡ ዘተቀብሩ፨</l>
                  <l n="2">ውስተ፡ ምድር፡ ቅድስት፡ ለእግዚአብሔር፡ ሕንጻ፡ ሀገሩ፨</l>
                  <l n="3">ሳሙኤል፡ ሥመር፡ ጊዜ፡ ስመከ፡ ዘከሩ፨</l>
                  <l n="4">በረከተ፡ አባ፡ አድኃኒ፡ ወተክለ፡ ሃይማኖት፡ መምህሩ፨</l>
                  <l n="5">ከመ፡ ላዕለ፡ ሕዝብከ፡ ይኅድር፡ በሠናይ፡ ይኅድሩ፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">አኮ፡ በአንኆ፡ ወቃለ፡ ዝንጋዔ፡ አላ፡ በአኅፅሮ፨</l>
                  <l n="2">እንበይነ፡ ዘአቅረብኩ፡ ለከ፡ አምኃ፡ ማሕሌት፡ ወዘምሮ፨</l>
                  <l n="3">ሳሙኤል፡ ዐስብየ፡ ምስለ፡ እለ፡ ቴዎድሮስ፡ በአማኅብሮ፨</l>
                  <l n="4">ሀበኒ፡ ልብሰ፡ ብርሃን፡ ዘወልደ፡ ነጐድጓድ፡ ነጸሮ፨</l>
                  <l n="5">ወአክሊለ፡ ሕይወት፡ መጥወኒ፡ ዘእደ፡ ሰብእ፡ ኢገብሮ፨</l>
               </lg>
               <lg type="stanza" n="54">
                  <l n="1">በከመ፡ ለሐወት፡ ሮምያ፡ በሞተ፡ ኦኤጥሮስ፡ ወጳውሊ፨</l>
                  <l n="2">ከማሁ፡ ለሐወት፡ ገዳመ፡ ዋሊ፨</l>
                  <l n="3">በሞተ፡ ሳሙኤል፡ አቡነ፡ ዘለነፍሰ፡ ኵሉ፡ ይጼሊ፨</l>
                  <l n="4">ከመ፡ አንቂጦስ፡ ተጋዳሊ፡ ዓለመ፡ ዘኢይሄሊ፨</l>
                  <l n="5">ኀበ፡ አምላኩ፡ በእንቲአነ፡ ይጸሊ፨</l>
               </lg>
            </div>
         </div>
      </body>

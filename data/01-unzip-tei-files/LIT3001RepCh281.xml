         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ዘሀሎ፡ አመ፡ ኢሀሎ፡ ዘመን፨</l>
                  <l n="2">ወኢቀደሞ፡ ሰዓት፡ መጠነ፡ ቅጽበታ፡ ለዐይን፨</l>
                  <l n="3">እሰንቁ፡ ለኪ፡ አውታረ፡ ነባቤ፡ ድርሳን፨</l>
                  <l n="4">ያብርህ፡ ውስተ፡ ልብየ፡ ለወለተ፡ ጴጥሮስ፡ ምእመን፨</l>
                  <l n="5">ጸዳለ፡ አእምሮ፡ ንስቲት፡ ሲኖዳ፡ ካህን፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘቀጸላ፡ ሞገስ፡ ትርሲቱ፨</l>
                  <l n="2">ወለሥዕርትኪ፡ ሥዉጥ፡ ዘቅብአ፡ ቅዳሴ፡ ውስቴቱ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ እምነ፡ ትንብልናኪ፡ ንፈቱ፨</l>
                  <l n="4">ከመ፡ ያድኅነነ፡ እምትንሣኤ፡ አፅራር፡ ሠለስቱ፨</l>
                  <l n="5">እስመ፡ መሪራን፡ ፈድፋደ፡ እሙንቱ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለርእስኪ፡ ወለገጽኪ፡ ስቡሐ፨</l>
                  <l n="2">እምብርሃናቲሁ፡ ለሰማይ፡ ዘአስተርአየ፡ ብዙኃ፨</l>
                  <l n="3">ሥርጉተ፡ ኵለንታ፡ ለጴጥሮስ፡ ወለቱ፡ ዘሃይማኖት፡ እልታኃ፨</l>
                  <l n="4">አዕርጊ፡ ስእለተነ፡ ሠርከ፡ ወነግሀ፨</l>
                  <l n="5">ኀበ፡ አምላክኪ፡ ማዕሠሮ፡ ለሰይጣን፡ ዘፈትሐ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለቀራንብትኪ፡ ሕማማተ፡ አንብዕ፡ እለ፡ ጾሩ፨</l>
                  <l n="2">ወለአዕይንትኪ፡ ሥነ፡ እንተ፡ ኀበ፡ አምላክ፡ ነጸሩ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ፍትሕኒ፡ ለጌጋይ፡ እማዕሠሩ፨</l>
                  <l n="4">ወአርትዒ፡ አእጋርየ፡ ፍኖተ፡ ንስሐ፡ ይሑሩ፨</l>
                  <l n="5">ቅድመ፡ ይዳደቀኒ፡ ሞት፡ ዘፀዋግ፡ ኅብሩ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለአዕዛንኪ፡ ሰማዕያተ፡ ዜና፡ በቋዒ፨</l>
                  <l n="2">ወለመላትሕኪ፡ ሱቱፍ፡ ጽፍዐተ፡ አምላክ፡ ተሰበኢ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ኀቤነ፡ ሶበ፡ ንጼውዐኪ፡ ንዒ፨</l>
                  <l n="4">አጋንንተ፡ ወመናፍስተ፡ ኢይጽብኡነ፡ ትጽብኢ፨</l>
                  <l n="5">በሰይፈ፡ አፉኪ፡ ሱራፌል፡ ሠዋዒ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለአእናፍኪ፡ አብያተ፡ ቅታሬ፡ ዘአንክሮ፨</l>
                  <l n="2">ወለከናፍርኪ፡ አቅመ፡ እለ፡ ሠርዑ፡ ለተናግሮ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ በረዊጽ፡ ዮሐንስ፡ ዘበደሮ፨</l>
                  <l n="4">ይትፋለስ፡ መንገሌየ፡ እመንገሌኪ፡ አእምሮ፨</l>
                  <l n="5">ለአእምሮትየሰ፡ ዝንጋዔ፡ ሠወሮ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለአፉኪ፡ መፈክረ፡ ሐዲስ፡ ቀኖና፨</l>
                  <l n="2">ወለአስናንኪ፡ ሰሐቀ፡ ዘመስተሣልቃን፡ መነና፨</l>
                  <l n="3">መስተፍሥሒ፡ አልባብ፡ ድምፅኪ፡ ፈድፋደ፡ እምወይነ፡ ቃና፨</l>
                  <l n="4">ሶበ፡ ተኀትመ፡ ጊዜ፡ ሞት፡ ወለተ፡ ጴጥሮስ፡ ዘዮና፨</l>
                  <l n="5">ቤተ፡ ክርስቲያን፡ በልብሰ፡ ላሕ፡ ገልበበት፡ ኅሊና፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለልሳንኪ፡ ዘኢያንተገ፡ ጸልዮ፨</l>
                  <l n="2">ወለመዓርዒር፡ ቃልኪ፡ አርጋኖነ፡ ስብሐት፡ ወተጋንዮ፨</l>
                  <l n="3">በእንተ፡ ኢየሱስ፡ ክርስቶስ፡ ዘተሦዓ፡ በቀራንዮ፨</l>
                  <l n="4">ኢኃሠሥኪ፡ ወርቀ፡ ወብሩረ፡ ወለተ፡ ጴጥሮስ፡ አጥርዮ፨</l>
                  <l n="5">እስከ፡ ለመስሐቲ፡ መልአክ፡ ድንጋፄ፡ አድወዮ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለእስትንፋስኪ፡ ዘመዓዛሁ፡ ስሒነ፨</l>
                  <l n="2">ወለጕርዔኪ፡ ዘየብሳ፡ እምአጥልሎተ፡ ማይ፡ ወወይን፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ይብሉኪ፡ መላእክተ፡ ሰማይ፡ ኄራን፨</l>
                  <l n="4">ሚይሤኒ፡ እኅትነ፡ ዘተውህበኪ፡ ብፅዓን፨</l>
                  <l n="5">ወዕሤትኒ፡ ዘኢርእየ፡ ዓይን፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለክሳድኪ፡ በሀብለ፡ ትሕትና፡ ዘተስሕበ፨</l>
                  <l n="2">ወለመታክፍትኪ፡ ዘጾረ፡ አርዑተ፡ ምንዳቤ፡ ዕጹበ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ምልዒ፡ ውስተ፡ ልብየ፡ ጥበበ፨</l>
                  <l n="4">እንበለ፡ ጥበብሰ፡ ሶበ፡ ተመሰልኩ፡ ርግበ፨</l>
                  <l n="5">ኢያበውሐኒ፡ አምላክኪ፡ እትዋረስ፡ መዝገበ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለዘባንኪ፡ መዋጥሐ፡ ትፍግዕት፡ ዘመነነ፨</l>
                  <l n="2">ወለእንግድዓኪ፡ ምርፋቅ፡ ለምስኪናን፡ ዘኮነ፨</l>
                  <l n="3">መፍቀሪተ፡ ጸሎት፡ ወጾም፡ ወለተ፡ ጴጥሮስ፡ እምነ፨</l>
                  <l n="4">ትተንብሊ፡ ቅድመ፡ አምላክ፡ ስርየተ፡ ኃጢአት፡ ለነ፨</l>
                  <l n="5">ናስተበቍዓኪ፡ እሊአኪ፡ ንሕነ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለሕፅንኪ፡ ሕፅነ፡ ምንኵስና፡ ክቡር፨</l>
                  <l n="2">ወለአእዳውኪ፡ ዘሰፍሓ፡ ለምሒረ፡ ኵሉ፡ ግዩር፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ አክሊላ፡ ለያዕቆባዊት፡ ማኅበር፨</l>
                  <l n="4">ይዌድሱኪ፡ አእላፍ፡ ተዓይነ፡ ሰማይ፡ ወምድር፨</l>
                  <l n="5">በጽምፀ፡ ማኅሌት፡ ሠናይ፡ ወሐዋዝ፡ ምዝሙር፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለመዛርእኪ፡ ወለኵርናዕኪ፡ ምስማክ፨</l>
                  <l n="2">ዘኢተእኅዙ፡ ፍጹመ፡ በማእሰረ፡ ጌጋይ፡ ድሩክ፨</l>
                  <l n="3">ወለጥተ፡ ጴጥሮስ፡ ማርታ፡ መፍቀሪተ፡ ክርስቶስ፡ አምላክ፨</l>
                  <l n="4">ተከድነ፡ ልብሰ፡ ኀፍረት፡ በዕብሬትኪ፡ መልአክ፨</l>
                  <l n="5">ለአዳም፡ ዘአውደቆ፡ እምሣልስ፡ ፈለክ፨</l>
               </lg>
               <lg type="stanza" n="14">
                  <l n="1">ሰላም፡ ለእመታትኪ፡ ለተገብሮ፡ ጽድቅ፡ ዘተኃየላ፨</l>
                  <l n="2">ወለእራኅኪ፡ ብሩህ፡ እምስነ፡ ኦርያሬስ፡ ወእብላ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ተንብሊ፡ ኀበ፡ ማርያም፡ ርግበ፡ ገሊላ፨</l>
                  <l n="4">ትተንብል፡ በእንቲአነ፡ እመድኃኔ፡ ዓለም፡ እጓላ፨</l>
                  <l n="5">ከመ፡ ይዕቀበነ፡ እመርቅያን፡ ተኵላ፨</l>
               </lg>
               <lg type="stanza" n="15">
                  <l n="1">ሰላም፡ ለአፃብዕኪ፡ አዕጹቀ፡ ተቅዋም፡ እድ፨</l>
                  <l n="2">ወለአርእስቲሆን፡ አጽፋር፡ ዘኅብረ፡ እማንቱ፡ በረድ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ወራውሬ፡ ወዕብነ፡ መረግድ፨</l>
                  <l n="4">ጥበበ፡ እምተግሣፅኪ፡ አጥረየ፡ አብድ፨</l>
                  <l n="5">ወሀብተ፡ ሚጠት፡ ብዙኃን፡ እምካህድ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለአጥባትኪ፡ ዘሐሊበ፡ ጽጋ፡ አንቅዕት፨</l>
                  <l n="2">ወኢይውኅዶን፡ ምሕረት፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ መበይን፡ በከፈረ፡ ሞት፨</l>
                  <l n="4">ጊዜ፡ ተስወርኪ፡ ማኅቶትነ፡ መብርህት፨</l>
                  <l n="5">ውስተ፡ ገጸ፡ የማን፡ ወፀጋም፡ ሰፈነ፡ ጽልመት፨</l>
               </lg>
               <lg type="stanza" n="17">
                  <l n="1">ሰላም፡ ለገቦኪ፡ ሥርግወ፡ ዘወርቅ፡ ሐመልማል፨</l>
                  <l n="2">ወለከርሥኪ፡ መዝገቡ፡ ለባሕርየ፡ ወንጌል፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ እምሰራ፡ ልዕልተ፡ ዝክር፡ ወገድል፨</l>
                  <l n="4">ይጸልላኒ፡ አክናፍኪ፡ ከመ፡ ጸለላ፡ በሐቅል፨</l>
                  <l n="5">ለደብተራ፡ ስምዕ፡ ደመና፡ ቀሊል፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">ሰላም፡ ለልብኪ፡ ወለኵልያትኪ፡ ንስቲተ፨</l>
                  <l n="2">ዘኢያሥረጹ፡ ዐመፃ፡ ወኢዘገቡ፡ ጽልሑተ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ፈትቲ፡ ኅብስተ፡ በረከት፡ ሊተ፨</l>
                  <l n="4">ህየንተ፡ አቅረብኩ፡ ፍሬ፡ ከናፍር፡ ማኅሌተ፨</l>
                  <l n="5">ለዕበይኪ፡ ዘአልቦ፡ መስፈርተ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለሕሊናኪ፡ ስቅለተ፡ ፈጣሪ፡ ዘሐለየ፨</l>
                  <l n="2">ወለአማዑትኪ፡ ህቀ፡ ዘኢቈጸረ፡ እከየ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ በልኒ፡ እንዘ፡ ይሰምዑ፡ ሕዝብየ፨</l>
                  <l n="4">ማኅደረ፡ በሰማያት፡ ከመ፡ ተሀሉ፡ ምስሌየ፨</l>
                  <l n="5">እስመ፡ አስተዳለውኩ፡ ለከ፡ ኢትኅዝን፡ ወልድየ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ሰላም፡ ሰላም፡ ለንዋየ፡ ውስጥኪ፡ ኅቡእ፨</l>
                  <l n="2">ወለኅንብርትኪ፡ ዘአፍአ፡ ከመ፡ ዓይነ፡ ማኅተም፡ ልኩዕ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ኤልሳቤጥ፡ ወላዲተ፡ መጥምቅ፡ ብፁዕ፨</l>
                  <l n="4">ያስተበፅዑኪ፡ ነገደ፡ መላእክት፡ ወሰብእ፨</l>
                  <l n="5">እለ፡ ሡሩራን፡ እምጾታ፡ አርባዕ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለማኅፀንኪ፡ ከመ፡ አስካለ፡ ወይን፡ ዘሐረግ፨</l>
                  <l n="2">ዘፈረየ፡ ፍሬ፡ እንተ፡ ቅድስና፡ ወሕግ፨</l>
                  <l n="3">ለርኡስ፡ ርኡሳን፡ ጴጥሮስ፡ ወለቱ፡ እንበለ፡ ነቲግ፨</l>
                  <l n="4">አንቲ፡ ወሲኖዳ፡ ወጻድቃነ፡ ወጺፍ፡ አዕሩግ፨</l>
                  <l n="5">መጽርየ፡ በረከት፡ ላዕሌነ፡ ነስንሱ፡ በደርግ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለሐቌኪ፡ በአብዝኆ፡ ጸዊም፡ ዘደግደገ፨</l>
                  <l n="2">ወለአቍያጽኪ፡ አዕማድ፡ እለ፡ ይትሌለያ፡ ዘውገ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ አብርሂ፡ ዓይነ፡ ልቡናየ፡ ሕሙገ፨</l>
                  <l n="4">ከመ፡ እነጽርኪ፡ እንዘ፡ ይቀውሚ፡ ደርገ፨</l>
                  <l n="5">ምስለ፡ ማኅበረ፡ በኵር፡ ፍሡሓን፡ ዘሠለጡ፡ ሕገ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ ለአብራክኪ፡ እለ፡ አዝለፋ፡ አስተብርኮ፨</l>
                  <l n="2">ወለሐዋርያት፡ ሰላም፡ አእጋርኪ፡ ፍና፡ ተልእኮ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ዕቀቢ፡ ማኅበረ፡ ደቂቅኪ፡ እምተሐውኮ፨</l>
                  <l n="4">ለሰይጣንሰ፡ ዘኢያፈቅር፡ ተዓርኮ፨</l>
                  <l n="5">መሣግሪሁ፡ ብትኪ፡ ወስብሪ፡ ሦኮ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለሰኳንውኪ፡ ምስለ፡ መከየድ፡ ዘቆሙ፨</l>
                  <l n="2">ኅብስተ፡ አሰርፎ፡ እምጻማ፡ እንዘ፡ ይጸውሙ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ጥቅዒ፡ መጥቅዓ፡ ስእለት፡ ለለጌሠሙ፨</l>
                  <l n="4">ለእለ፡ አመነ፡ ያዕቆባውያን፡ በስሙ፨</l>
                  <l n="5">ቤዛ፡ ኃጣውኢነ፡ ይኩን፡ ለክርስቶስ፡ በደሙ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለአፃብዓ፡ እግርኪ፡ ኃምስ፡ ክዑባት፡ በኈልቆ፨</l>
                  <l n="2">ወለአጽፋርኪ፡ ዐሥር፡ እለ፡ ይነብራ፡ በተላጽቆ፨</l>
                  <l n="3">ወለተ፡ አረጋይ፡ ጴጥሮስ፡ ቅረቢ፡ እምተራኅቆ፨</l>
                  <l n="4">ለትኩዝ፡ ብእሲ፡ ከመ፡ ትፈጽሚ፡ ጻሕቆ፨</l>
                  <l n="5">ወለጻድቅ፡ ትባርኪ፡ ጽድቆ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለቆምኪ፡ ሥነ፡ ቄድሮስ፡ ኅሩይ፨</l>
                  <l n="2">ወለመልክእኪ፡ ሰላም፡ ወላዲ፡ ፍሥሐ፡ ፀሓይ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ሀቢ፡ ተውላጠ፡ ዝንቱ፡ ንዋይ፨</l>
                  <l n="4">ፍተ፡ በረከት፡ በቅድመ፡ ጉባኤ፡ ዓባይ፨</l>
                  <l n="5">እምበረከትኪ፡ ዘጥቀ፡ ሠናይ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስኪ፡ በጣዕመ፡ ዝማሬ፡ ሐዋዝ፨</l>
                  <l n="2">ወለበድነ፡ ሥጋኪ፡ ጽዱል፡ እምጸዳለ፡ ባሕርይ፡ እንቡዝ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ጠባብ፡ ወሠናይተ፡ ግዕዝ፨</l>
                  <l n="4">ለለይሠርቁ፡ ምዕዛራተ፡ ዝክርኪቤዝ፨</l>
                  <l n="5">እምልበ፡ ብእሲ፡ ኅዙን፡ ይትረሣዕ፡ ትካዝ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋኪ፡ ዘትሩፈ፡ ትሩፍ፡ ዕበዩ፨</l>
                  <l n="2">ወለመቃብርኪ፡ ምስካይ፡ ለእለ፡ ቦቱ፡ ሰከዩ፨</l>
                  <l n="3">ወለተ፡ ጴጥሮስ፡ ቢረሌ፡ ለዕፍረተ፡ አሚን፡ ሙዳዩ፨</l>
                  <l n="4">ቅድሑ፡ ፈልፈለ፡ ሣህል፡ አባግዕኪ፡ ይርወዩ፨</l>
                  <l n="5">ጊዜ፡ አንበልበላ፡ ለመርቄ፡ ዋዕዩ፡</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ለቆብዕኪ፡ አክሊለ፡ ሦክ፡ ዲበ፡ ርእሰ፡ ክርስቶስ፡ ዘተሠይመ፨</l>
                  <l n="2">አመ፡ ሰቀልዎ፡ አይሁድ፡ ከመ፡ ይቤዙ፡ ዓለመ፨</l>
                  <l n="3">ወዓጽፈ፡ ንጽሕና፡ ዓጽፍኪ፡ ወአስኬማኪ፡ ቅድመ፨</l>
                  <l n="4">ለቅናትኒ፡ ወቀሚስ፡ ወለተ፡ ጴጥሮስ፡ ዳግመ፨</l>
                  <l n="5">ሰላም፡ ሰላም፡ እንዘ፡ እብል፡ ረሰይኩ፡ ማኅተመ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ይትባረኩ፡ እግዚአብሔር፡ አምላከ፡ አማልክት፡ መላኪ፨</l>
                  <l n="2">ዘባሕርይሁ፡ ብርሃን፡ ዘመልዕልተ፡ ብርሃናት፡ ያዋኪ፨</l>
                  <l n="3">እስመ፡ ዐቀበኒ፡ ሊተ፡ እመሥገርተ፡ ሰይጣን፡ ሐዋኪ፨</l>
                  <l n="4">ወአፈጸመኒ፡ ወለተ፡ ጴጥሮስ፡ ወልድኪ፨</l>
                  <l n="5">ማኅሌተ፡ ዝክርኪ፡ ዘወጠንኩ፡ ለኪ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ ገነት፡ ክልልተ፡ መዓዛ፡ ጥዑም፨</l>
                  <l n="2">ወምጽላለ፡ አርጋብ፡ አንቲ፡ እመርቁ፡ ሕማም፨</l>
                  <l n="3">ዘሰፈነት፡ ውስተ፡ ዓለም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ መጽሒት፡ ሃይማኖተ፡ ሥሉስ፡ ቅዱስ፨</l>
                  <l n="2">ዘተከሥተ፡ ልኪ፡ ለዘነብ፡ ወርእስ፨</l>
                  <l n="3">ኅዱራን፡ መልዕልተ፡ የብስ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ ብርሃን፡ ስብከትከ፡ አመ፡ ውስተ፡ ጽልመት፡ አብርሃ፨</l>
                  <l n="2">ለመክፈልተ፡ አብዳን፡ ዓለም፡ አእርክቲሃ፨</l>
                  <l n="3">ተባደሩ፡ ኀበ፡ ንስሐ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለኪ፡ ዘዓይን፡ ኢርእየ፡ ወእዝን፡ ኢሰምዓ፨</l>
                  <l n="2">ከመ፡ ትረስዪ፡ ትርሲተ፡ መርዓ፨</l>
                  <l n="3">ገደፍኪ፡ ሠርጐ፡ ፍግዓ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለኪ፡ ምስለ፡ ሲኖዳ፡ አቡኪ፡ ሥርግወ፡ ሎግዮን፡ ድንጋሌ፨</l>
                  <l n="2">ለናዝዞትየ፡ ንዒ፡ እምኀዘን፡ ወይሌ፨</l>
                  <l n="3">ወሐውጺ፡ ከመ፡ ውላውሌ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ እምነ፡ ተኃየልኪ፡ ለበዊአ፡ ጽባብ፡ ምሕላፍ፨</l>
                  <l n="2">ከመ፡ ተኃየሉ፡ ቅድመ፡ ሰማዕታት፡ አእላፍ፨</l>
                  <l n="3">ወጻድቃን፡ እለ፡ ወጺፍ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለኪ፡ ሞገሰ፡ ረድኤትኪ፡ ኃይል፡ ወለተ፡ ጴጥሮስ፡ ሱላሜ፨</l>
                  <l n="2">እመከራ፡ ሰይጣን፡ ወሰብእ፡ በኢፍጻሜ፨</l>
                  <l n="3">ይክድነኒ፡ አምሳለ፡ ጊሜ፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለኪ፡ ረድኤትኪ፡ ፀወን፡ እንዘ፡ ንሬስዮ፡ አረፍተ፨</l>
                  <l n="2">መራዕየ፡ ረሲዓን፡ አጽራር፡ ኢንፈርህ፡ ምንተ፨</l>
                  <l n="3">ጊዜ፡ ሠርዑ፡ ተቃውሞተ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለደቂቅኪ፡ አኃው፡ ወለኵሎን፡ አሐት፨</l>
                  <l n="2">ቅድመ፡ ገጸ፡ አምላክ፡ ተንብሊ፡ እንበለ፡ ጽርዓት፨</l>
                  <l n="3">ኢይባኡ፡ ውስተ፡ መንሱት፨</l>
               </lg>
               <lg type="stanza" n="10">
                  <l n="1">ሰላም፡ ለኪ፡ እመሣግሪሁ፡ አምሰጥኪ፡ ለአርዌ፡ ዓመፃ፡ መስገሪ፨</l>
                  <l n="2">አረቦን፡ መዊእ፡ መስቀለ፡ እንዘ፡ ትጸውሪ፨</l>
                  <l n="3">ዘጾርዎ፡ እለ፡ መቃሪ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለኪ፡ ወለተ፡ ጴጥሮስ፡ አዕርሂ፡ ዕጣነ፡ ማኅሌተነ፡ ዝንቱ፨</l>
                  <l n="2">እምእንስሳ፡ ሰማይ፡ አርባዕቱ፨</l>
                  <l n="3">ኀበ፡ ይትቄደሱ፡ አካላት፡ ሠለስቱ፨</l>
                  <l n="4">በማዕጠንት፡ ዘብርሃን፡ ግብረቱ፨</l>
               </lg>
            </div>
         </div>         
      </body>
   </text></TEI>
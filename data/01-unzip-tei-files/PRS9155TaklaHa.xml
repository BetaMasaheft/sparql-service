      <t:body>
         <t:listPerson>
            <t:person sex="1">
       
                  
                  <t:persName xml:lang="gez" xml:id="n1" type="baptismal">ተክለ፡ ሃይማኖት፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Takla Hāymānot</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">መኵሪያ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Makʷǝriyā</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">መላኩ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Malāku</t:persName>
               
                  <t:persName>
                  <t:roleName type="title">ʾabuna</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="ecclesiastic">Patriarch</t:occupation>
               <t:birth when="1917">He was born at <t:placeName ref="https://betamasaheft.eu/LOC4432Mahdar">Maḫdara Māryām</t:placeName> in <t:date>1917</t:date>.</t:birth>

               <t:floruit notBefore="1976" notAfter="1988">He was the third Patriarch of the Ethiopian Orthodox Tawāḥǝdo Church from <t:date>1976</t:date> to <t:date>1988</t:date>. 
                  He attended the traditional church education in the monastery of <t:placeName ref="https://betamasaheft.eu/LOC4432Mahdar">Maḫdara Māryām</t:placeName> where he served as a diyāqon 
                 before he became a hermit.
                 In <t:date>1933-34</t:date>, he went to <t:placeName ref="https://betamasaheft.eu/LOC6165Walamo">Walāmo</t:placeName> to the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2305DabraM">Dabra Mankǝrāt Takla Hāymānot</t:placeName>, where he took the monastic order. He
                  was ordained priest under 
                  <t:persName ref="https://betamasaheft.eu/PRS8033Qerellos">
                     <t:roleName type="title">ʾabuna</t:roleName> Qerǝllos</t:persName>
                  in <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName>.
                  Because of his calligraphic skills he was the scribe of the monastery. It is evident that most of the manuscripts kept at
                  <t:placeName ref="https://betamasaheft.eu/LOC2305DabraM">Dabra Mankǝrāt Takla Hāymānot</t:placeName> were copied by Takla Hāymānot. 
                  He was the most successful true religious leader of the church confronting the Marxist military regime.</t:floruit> 
                  
               <t:death when="1988">He died at <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> in <t:date>1988</t:date>. </t:death>
               </t:person>
               
         </t:listPerson>
          

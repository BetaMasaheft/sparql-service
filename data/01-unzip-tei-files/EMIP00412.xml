                    <decoNote type="miniature" xml:id="d2"><locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> of Jesus with the two thieves</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#132v" facs="137">Fol. 132v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#133r" facs="137">Fol. 133r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> , <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> feeding <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName>, flanked by two angels</desc></decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs:
                      <locus target="#1r #22v #31v #39v #89v #100r #108v #125r #131v" facs="004 027 036 044 094 104 113 129 136">folss. 1r, 22v, 31v, 39v, 89v, 100r, 108v, 125r, 131v, </locus> (ḥaräg);

               <msContents>
                  <summary>Psalter, ዳዊት። with the Psalter of the Virgin; መዝሙረ፡ ድንግል።, Image of the Praises of Mary, መልክአ፡ ውዳሴ።; Image of the Gate of Light, መልክዐ፡ አንቀጸ፡ ብርሃን።</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="178v" facs="004">Fols 1r–178v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1.1">
                     <locus from="1r" to="136v" facs="004">Fols 1r–136v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                   </msItem>
                  <msItem xml:id="ms_i1.2">
                     <locus from="138r" to="151v" facs="141">Fols 138r–151v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="152r" to="159r" facs="155">Fols 152r–159r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>The second and third sections begin with unique superscriptions</note>
                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="160r" to="174r" facs="163">Fols 160r–174r</locus>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>The Image of the Praises of Mary, usually presented as a separate work, is here interwoven into each section</note>
                     <msItem xml:id="ms_i1.4.1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     </msItem>
                     <msItem xml:id="ms_i1.4.2">
                        <title type="complete" ref="https://betamasaheft.eu/LIT1869Malkea">Malkǝʾa wǝddāse
                                                  Māryām</title>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                     <locus from="174r" to="178v" facs="177">Fols 174r–178v</locus>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <note>Image of the Gate of Light is interwoven with each ssection of the Gate of Light, but incomplete at the end</note>
                     <msItem xml:id="ms_i1.5.1">
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2960RepCh241">Malkǝʾa ʾanqaṣa

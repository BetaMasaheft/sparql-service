                        </item>
                        <item xml:id="a4">
                           <locus target="#24v"/>
                           <desc type="Supplication"/>
                           <q xml:lang="gez">ለዘጸሐፎ፡ ወለዘአጽሐፎ፡ ወለዘአንበቦ፤ ወለዘተርጐሞ፡ 

                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="10v"/>
                     <title ref="https://betamasaheft.eu/LIT2125OntheG">Dǝrsān za-darasa Yoḥannǝs ʾAfa Warq ... baʾǝnta kǝbru
          la-Yoḥannǝs maṭmǝq</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ድርሳን፡ ዘደረሰ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ሊቀ፡ ጳጳሳት፤ ዘሀገረ፤
                        ቍስጥንጥንያ፤ ዘተናገረ፤ 
                           <sic resp="bm:GrebTiss1935Codices">በእንት፤</sic>
                         ክብሩ፤ ለዮሐንስ፤ መጥምቅ፤ በከመ፤ ጽሑፍ፡ በወንጌለ፤
                        ማቴዎስ፨ ምንትኑ፤ ወፃእክሙ፤ ትርአዩ፤ ገዳመ፨ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           <sic>ዘይትነበብ፡</sic>
                        
                        አመ፡ ፴ለሰኔ፨ ስምዑ፤ ኦፍቁራንየ፤ ወአነ፤ እፈቅድ፤ እክሥት፤ ለክሙ፤ በእንተ፤ ዕበዩ፡ ለዮሐንስ፤ ካህን፤ ውእቱ፤ እምዘመደ፤ ክርስቶስ፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ርኢክሙኑ፡ ኦፍቁራንየ፡ ዘንተ፡ ኵሎ፡ ዘወሀበ፡ እግዚአብሔር፡ በሰማይ፡ ወበምድር፡ ወለነኒ፡ 
                           <sic>ይኵነነ፡</sic>
                         መክፈልተ፡ ወርስተ፡ እምሠናያት፡ ዘወሀብኮ፡ ለዮሐንስ፡
                        ፍቁርከ፨ ወኵሉ፡ ዘይገብር፡ ተዝካሮ፡ በዲበ፡ ምድር፡ ወበእንተ፡ አፍቅሮቱ፡ ወምሕረቱ፡ ለሰብእ፡ በእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፨ ዘሎቱ፡ ይደሉ፡ ክብር፡ ...
                     </explicit>
                     <listBibl type="secondary">
                        <bibl corresp="http://zotero.org/groups/358366/items/NUQP2H9H"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Proverbio1998Recensione"/><title level="m">La recensione etiopica dell’omelia pseudocrisostomica &lt;hi rend="italics"&gt;de ficu exarata&lt;/hi&gt; ed il suo &lt;hi rend="italics"&gt;tréfonds&lt;/hi&gt; orientale</title><title level="s">Aethiopistische Forschungen</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Delio Vania</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Proverbio</t:surname></author><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>1998</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Aethiopistische Forschungen</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">50</t:biblScope></series><biblScope unit="volume">50</biblScope><note type="url">https://books.google.de/books?id=7WLRNFtaT_4C&amp;printsec=frontcover&amp;hl=de&amp;source=gbs_ge_summary_r&amp;cad=0#v=onepage&amp;q&amp;f=false</note><citedRange>82</citedRange></bibl>
                     </listBibl>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="10v" to="24r"/>
                     <title ref="https://betamasaheft.eu/LIT2085OntheL">On (the Life and Decollation of) John the Baptist</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ዝንቱ፡ ነገር፡ በከመ፡ ኮነ፡ ሕይወቱ፡ ለዮሐንስ፡ መጥምቅ፡ ወዘከመ፡
                        ኮነ፡ እፎ፡ ምትረተ፡ ርእሱ፡ ወተርጐሞ፡ ቅዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ በትረ፡ ያርክ፡ ሊቀ፡ ጳጳሳት፡ ብሂል፡ ዘሀገረ፡ ቍስጥንጥንያ፨ ወሶበ፡ ኮነ፡ ስደቱ፡ እምብራክይስ፡ 
                           <sic>እመ፡</sic>
                        
                        ተስእሎ፡ አይሁዳዊ፡ ኬልቄዶናዊ፡ ዘምነ፡ በእግዚእነ፡ በእንተ፡ ርእሰ፡ ቅዱስ፡ ዮሐንስ፡ መጥምቅ፡ ባዕለ፡ ክርስትና፨ = ፨ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        ወዜነወ፡ ንስቲተ፡ እምሕይወቱ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ይቤ፡ እስመ፡ ሆከኒ፡ ልሳንየ፡ ከመ፡ እበል፡ ውሁደ፡
                        እምክብራተ፡ ቅዱስ፡ ነቢይ፡ መጥምቅ፡ ዘፍንው፡ ቅድመ፡ እግዚኡ፡ ዮሐኖን፡ ወአምዳኖን፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ወዜነውነ፡ ዘንተ፡ በእንተ፡ ፍቅርክሙ፡ ወበእንተ፡ ርእስ፡ 
                           <sic>ንጽሕት፡</sic>
                         ዮሐንስ፡ መጥምቅ፨ አው፡ ዘይጽሕፍ፡ ገድሎ፡ ድልወቶ፡ ወሩጸቶ፡ ወይገብር፡ ምጽዋተ፡
                        አመ፡ ዕለተ፡ ስምዑ፡ በከመ፡ ክሂሎቱ፡ ላዕለ፡ ምስኪናን፡ ወቍሱላን፡ አው፡ 
                           <sic>አቤራተ፨</sic>
                        
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        ይስእል፡ ወይጼሊ፡ በእንቲአሆሙ፡ ከመ፡ ይትወከፎሙ፡ ወያቅሞሙ፡ ኣምላክ፡ ዘእንበለ፡ ነውር፨
                     </explicit>
                     <listBibl type="secondary">
                        <bibl corresp="http://zotero.org/groups/358366/items/2TJTXP22"><seg type="encyclopediaArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi2007John"/><title level="a">John the Baptist (in Ethiopian literature)</title><title type="short">EAe</title><title level="m">Encyclopaedia Aethiopica</title><author><forename>Alessandro</forename><surname>Bausi</surname></author><editor><name>Uhlig</name></editor><pubPlace>Wiesbaden</pubPlace><publisher>Harrassowitz Verlag</publisher><date>2007</date><biblScope unit="volume">III</biblScope><biblScope unit="page">288b-291b</biblScope><note type="tags"><note type="tag">bm:Bausi2007John</note></note><note type="tag">bm:Bausi2007John</note><citedRange>289a</citedRange></bibl>
                     </listBibl>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="24v" to="42v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4050ZenaBul">Zenāhu la-ʾab kǝbur wa-tǝrufa tǝgāh ʾabbā Bulā zǝ-wǝʾǝtu
          ʾAbib</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ንቀድም፤ በረድኤተ፤ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፤ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        በእንተ፤ ዘተከሥተ፤ ለነ፤ እምዜናሁ፤ ለአብ፤ ክቡር፤ ወትሩፈ፤ ትጋህ፤ አባ፤ ቡላ፡ ዝውእቱ፤ መክብበ፡ ሠናያት፤ በሰላመ፤ እግዚአብሔር፡ አብ፡ አሜን፨ = ፨ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        እዜንወክሙ፤ ኅዳጠ፤ እምትሩፋተ፡ ገድሉ፡ ወተአምራቲሁ፡ ዘሰማዕነ፡ እምአፉሆሙ፡ ለእለ፡ ተልእክዎ፡ ወኮኑ፡ ሎቱ፡ ስምዓ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ስብሐት፡ ለእግዚአብሔር፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ስብሐት፡ ለዋሕድ፡ ወልዱ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        ስብሐት፡ ለመንፈስ፡ ቅዱስ፡ ለዘቀደሶ፡ ወአንጽሖ፡ እምከርሠ፡ እ
                     </explicit>
                     <note>The end is missing, the text terminates abruptly.</note>
                  </msItem>

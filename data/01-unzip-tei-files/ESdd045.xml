                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#134v"/>
                           <desc type="PurchaseNote">Purchase note. Written possibly in the <ref type="hand" target="#h1">main hand</ref>. The name of the buyer has been erased.</desc>
                           <q xml:lang="gez">ዛቲ፡ መጽሓፍ፡ <del rend="erasure"/> ዘተሣየጦ፡ በርቁ፡ ከመ፡ ትኩኖ፡ መድኃኒተ፡ ነፍሱ፡ ወሥጋሁ፡ በዝዓለም፡ ወበዘይመፅእ፡ ዓለም፡ ወትረ፡ እስከ፡ ለዓለመ፡ ዓለም።</q>
                        </item>
                        <item xml:id="a2">
                           <locus target="#174r"/>
                           <desc type="OwnershipNote">Ownership note. The name of the owner has been erased.</desc>
                           <q xml:lang="gez">ዝመጽሐፍ፡ <del rend="erasure"/> ዘሰረቆ፡ ወዘፈሐቆ፡ ውጕዘ፡ ለይኩን።</q>
                        </item>
                        <item xml:id="a3">
                           <locus from="174va" to="175vb"/>
                           <desc><title type="complete" ref="https://betamasaheft.eu/LIT2993RepCh274">Hymn to Jesus Christ.</title> The prayer is most probably written in the <ref type="hand" target="#h1">main hand.</ref></desc>
                           <q xml:lang="gez">በስመ፡ እግዚአብሔር፡ ቀዳማዊ፣ ዘእንበለ፡ ትማልም፡ ማእከላዊ፣ ወዘእንበለ፡ ዮም፡ ደኃራዊ፣ ወዘእንበለ፡ ጌሠም፡…</q>
                        </item>
                        <item xml:id="a4">
                           <locus target="#175r"/>
                           <desc type="Asmat"><title type="complete" ref="https://betamasaheft.eu/LIT6858PPsnakes">Short prayer against snakes</title>ʾAsmāt-prayer against snake bites. The prayer is inserted between the two parts of <ref target="#a3"/>.</desc>

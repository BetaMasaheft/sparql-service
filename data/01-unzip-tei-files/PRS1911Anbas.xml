         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">አንበስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAnbas</persName>
               <persName xml:lang="gez" xml:id="n2" type="birth">አንበሳ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">ʾAnbasā</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  
                  
               <floruit> He is a saint commemorated on <date ref="ethiocal:Maskaram3" type="diesNatalis">3 Maskaram</date> who lived in the 14th century or 16th century. 
                  He is known as the founder of the monastery of <placeName ref="https://betamasaheft.eu/LOC3839Hazalo">Ḥāzalo</placeName>
                  in <placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</placeName>. 
                  <persName ref="https://betamasaheft.eu/PRS1911Anbas">
                     <roleName type="title">ʾabbā </roleName> ʾAnbas</persName> 
                  was one of the 33 disciples of 
                  <persName ref="https://betamasaheft.eu/PRS9152TaklaHa">
                     <roleName type="title">ʾabuna</roleName> Takla Hāymānot I</persName>.                     
                  </floruit>
                  
               </person>  
               
         </listPerson>
         

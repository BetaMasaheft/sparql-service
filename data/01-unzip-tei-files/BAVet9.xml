               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="99v" facs="0004"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <note>Printed. Same exemplar of <bibl corresp="http://zotero.org/groups/358366/items/RMEHMDFJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Potken1513Psalterium"/><title level="m">Psalterium David et cantica aliqua</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Johannes</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Potken</t:surname></author><pubPlace>Romae</pubPlace><publisher>Marcellus Silber</publisher><date>1513</date><note type="url">http://www.kingscollections.org/exhibitions/specialcollections/psalter1513/</note></bibl>. 
                        The image of David at the beginning, the preface and the <ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref> are missing.
                     </note>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="100r" to="120" facs="0103"/>
                     <title ref="https://betamasaheft.eu/LIT1960Mashaf">Maṣḥafa qǝddāse</title>
                     <note>The text seems to be different from the edited one, both for the arrangement of the prayers and for the textual variation. 
                    </note>
                     <msItem xml:id="ms_i2.1">
                        <locus from="112r" facs="0117"/>
                        <title ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddase">Maṣḥafa qǝddāse, Śǝrʿāta qǝddāseሥርዓተ፡ ቅዳሴ፡</title>
                     </msItem>
                     <msItem xml:id="ms_i2.2">
                        <locus from="112v" facs="0118"/>
                        <title>Sections of the New Testament</title>
                        <note>Excerpts from <ref type="work" corresp="https://betamasaheft.eu/LIT1558Matthew">Wangel za-Mātewos</ref> 25:31-34, 25:1-13.</note>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="121v" to="123" facs="0128"/>
                     <title>Biblical reading for liturgical purpose</title>
                     <note>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1693John">Gospel of John</ref> 20:1-23.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus from="123r" to="123v" facs="0129"/>
                     <title ref="https://betamasaheft.eu/LIT4038Prayer#Meal2">Blessing of meal</title>
                     <incipit xml:lang="gez">
                        ጸሎተ፡ 
                           <sic>ማአድ፡</sic>
                         ሶበ፡ ይደረሩ፡ ወይመስሑ። ንስእለከ፡ መሐሪ፡ 
                           <sic>ዘሰእልናከ፡</sic>
                         ዘኢትከልእ፡ ዘኢትፈልጥ፡ ወኢትሌሊ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ይኩን፡ መብልዓ፡ ጽድቅ፡ ወስታየ፡ ሕይወት፡ ዘለዓለም፡ ዘኢያረስዓነ፡ ስብሐተ፡ 
                           <sic>በኩሉ፡</sic>
                         መዋዕለ፡ ሕይወትነ፡ ለዓለመ፡ ዓለም፡ አሜን።
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="124r" to="126r" facs="0130"/>
                     <title type="incomplete">Fragment of a hymn to Our Lady Mary</title>
                     <note>The beginning is missing.</note>
                     <incipit xml:lang="gez">
                        ክሳድኪ፡ ይመስል፡ በትረ፡ ወርቅ፡ ዘሕብራት፡ ዘቦ፡ ጽድላተ፡ ማርያም፡ ድንግል፡ እንተ፡ ፈረይኪ፡ እሳተ፨
                       </incipit>
                     <explicit xml:lang="gez">
                        ሰላም፡ ለኪ፡ እግዝእትየ፡ ማርያም፡ እምስዕርትኪ፡ እስከ፡ አእጋርኪ፡ ቅድስተ፡ ቅዱሳን፡ አንቲ፡ ተሰመይኪ፨ ተንስኢ፡ ድንግል፡ ልበሲ፡ ሐይልኪ፡ ወሙኢዮሙ፡ ለአይሁድ፡ ጸርኪ፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus target="#126v" facs="0133"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4056Praise">Praise to Our Lady Mary</title>
                     <note>The end is missing.</note>
                     <incipit xml:lang="gez">
                        ንወጥን፡ በረድኤተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ 
                           <sic>ውዳሴሀ፡</sic>
                         ለእግዝእትነ፡ መርያም፨ 
                           <sic>ንጽሕኪ፡</sic>
                         ማርያም፡ 
                           <sic>ጻዕደ፡</sic>
                         ለመ፡ በረድ፨ 
                     </incipit>
                     <explicit xml:lang="gez">
                        ሜሮነ፡ ፍቅርኪ፡ 
                           <sic>አፀብዕየ፡</sic>
                         
                        
                           <sic>የስተዋድደ፡</sic>
                         በእንቲአኪ፡ ኮነኒ፡ 
                           <sic>እንግደ፨</sic>
                        
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i7">
                     <locus from="127v" to="133v" facs="0123"/>
                     <title>Biblical readings</title>
                     <msItem xml:id="ms_i7.1">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1693John">Gospel of John</ref> 19:28-30</title>
                     </msItem>
                     <msItem xml:id="ms_i7.2">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT3521Epistle">Epistle to the Colossians</ref> 1:12-20</title>
                        <note>Wrongly attributed to the Epistle to the Philippians</note>
                     </msItem>
                     <msItem xml:id="ms_i7.3">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT3507Epistle">First Epistle of Peter</ref> 1:3-7</title>
                     </msItem>
                     <msItem xml:id="ms_i7.4">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1019Actsof">Gǝbra ḥawāryāt</ref> 2:14-21</title>
                     </msItem>
                     <msItem xml:id="ms_i7.5">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1812GospelLuke">Wangel za-Luqās</ref> 23:13-26</title>
                     </msItem>
                     <msItem xml:id="ms_i7.6">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT3522Epistle">First Epistle to the Thessalonians</ref> 4:15-5:1</title>
                     </msItem>
                     <msItem xml:id="ms_i7.7">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1019Actsof">Gǝbra ḥawāryāt</ref> 1:12-14</title>
                     </msItem>
                     <msItem xml:id="ms_i7.8">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT3512Epistle">Epistle of James</ref> 4:7-12</title>
                     </msItem>
                     <msItem xml:id="ms_i7.9">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1693John">Gospel of John</ref> 1:1-17</title>
                     </msItem>
                     <msItem xml:id="ms_i7.10">
                        <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1558Matthew">Wangel za-Mātewos</ref> 5:1-12</title>
                        <note>The excerpt ends abruptly with the word 
                           <q xml:lang="gez">እ<add place="inline">
                                 <supplied reason="omitted">ስ</supplied>
                              </add>መ፡
                           </q>.
                        </note>
                     </msItem>
                  </msItem>
               </msContents>
          

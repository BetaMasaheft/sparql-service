               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="8v">Fols 1r–8v</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                     <textLang mainLang="gez"/>
                     <note>Only the portion Pss. 1-6 and 8-17.
                        The original numeration of the Psalms is not consistent. Number 1 is used twice;
                        Pss. 5, 6, 8, 9, 11 have no numbers. A recent numeration with Western Arabic numerals, in pencil, is added to all Psalms.</note>
                     <incipit xml:lang="gez">
                        <locus target="#1r">Fol. 1r</locus>
                        <lb n="1"/>
                        <hi rend="rubric"> ፩ፍካሬ፡ ዘጻድቃን፡ ወዘኃጥአን፡</hi>
                        <lb n="2"/>
                        <hi rend="rubric">መዝሙር፡ ዘዳዊት፡ ሃሌ፡ ሉያ።</hi>
                        <lb n="3"/> ብፁዕ፡ ብእሲ፡ ዘኢሖረ፡ በምክረ፡ ረሲዓን።
                        <lb n="4"/>ወዘኢቆመ፡ ውስተ፡ ፍኖተ፡ ኃጥኣን።
                        <lb n="5"/>ወዘኢነበረ፡ ውስተ፡ መንበረ፡ መሥተሣልቃን።
                        <lb n="6"/>
                        <hi rend="rubric">ዘዳዕሙ፡ ሕገ፡ እግዚአብሔር፡ ሥምረቱ።</hi>
                        <lb n="7"/>
                        <hi rend="rubric">ወዘሕጎ፡ ያነብብ፡ መዓልተ፡ ወሌሊተ።</hi>
                     </incipit>
                     <explicit xml:lang="gez">
                        <locus target="#8v">Fol. 8v</locus>
                        <lb n="1"/>ወልዑል፡ ወሀበ፡ ቃሎ<hi rend="rubric">፨</hi>
                        <lb n="2"/>ፈነወ፡ አሕፃሁ፡ ወዘረዎሙ<hi rend="rubric">፨</hi>
                        <lb n="3"/>አብዝኃ፡ መባርቅቲሁ፡ ወሆኮሙ<hi rend="rubric">፨</hi>
                        <lb n="4"/>ወአስተርአዩ፡ አንቅተ፡ ማያት<hi rend="rubric">፨</hi>
                        <lb n="5"/>ወተከሥቱ፡ መሠረታተ፡ ዓለም<hi rend="rubric">፨</hi>
                        <lb n="6"/>እምተግፃሣጽከ፡ እ<hi rend="ligature">ግዚ</hi>ኦ<hi rend="rubric">፨</hi>
                        <lb n="7"/>ወእምእስትንፋሰ፡ መንፈሰ፡ መዓትከ<hi rend="rubric">፨</hi>
                        <lb n="8"/>ፈነወ፡ እምአርያም፡ ወነሥእኒ<hi rend="rubric">፨</hi>
                     </explicit>
                  </msItem>
               </msContents>

               <physDesc>
                  <objectDesc form="Other">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">8</measure>
                           <measure unit="leaf" xml:lang="ar">٨ ورقات</measure>
                           <measure unit="quire" xml:lang="ar">ملزمة واحدة</measure>
                           <measure unit="quire">ِ1</measure>
                           <dimensions type="outer" unit="mm">
                              <height>185</height>
                              <width>134</width>
                              <depth>5</depth>
                           </dimensions>
                           <dimensions type="outer" unit="mm" xml:lang="ar">
                              <height>١٨٥</height>
                              <width>١٣٤</width>
                              <depth>٥</depth>
                           </dimensions>
                        </extent>

                        <foliation>Foliation in pencil in the centre of the bottom margin of the folia.</foliation>

                        <collation>
                           <list>
                              <item xml:id="q1" n="1">
                                 <dim unit="leaf">8</dim>
                                 <locus from="1r" to="8v">Fols 1r–8v</locus>
                                 1, stub after 8
                                 7, stub after 1
                              </item>
                           </list>
                        </collation>

                        <condition key="good">The quire shows slight traces of use,
                           small occasional stains (<locus target="#1r #2r">fols. 1r, 2r</locus>).</condition>
                     </supportDesc>

                     <layoutDesc>
                        <layout columns="1" writtenLines="25 27">
                           <locus from="1r" to="8v">Fols 1r–8v</locus>
                           <note corresp="#textarea #margin">
                              Data on text area and margin dimensions taken from <locus target="#4r">fol. 4r</locus>.</note>
                           <dimensions unit="mm" xml:id="textarea">
                              <height>83</height>
                              <width>70</width>
                           </dimensions>
                           <dimensions type="margin" unit="mm" xml:id="margin">
                              <dim type="top">10</dim>
                              <dim type="bottom">23</dim>
                              <dim type="right">6</dim>
                              <dim type="left">7</dim>
                           </dimensions>
                           <ab type="pricking">Ruling and pricking are visible.</ab>
                           <ab type="ruling" subtype="pattern">1A-1A/0-0/0-0/C</ab>
                           <note>The pricks are located very close to the edges of the folia.
                              On <locus target="#8">fol. 8</locus>, two
                              rows of the text pricks are visible, one very close to the
                              edge, another at the outer bounding line.</note>
                        </layout>
                     </layoutDesc>
                  </objectDesc>

                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Second half of the nineteenth/early twentieth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date notBefore="1850" notAfter="1930"/>
                        <seg type="rubrication">Beginnings of the Psalms, elements of numerals, elements of punctuation signs,
                           the word <foreign xml:lang="gez">እግዚአብሔር፡</foreign>,
                           occasionally with the words before and after it or the entire line where
                           it is written (e.g. <locus target="#2">Fol. 2</locus>.</seg>
                        <desc>Careful but irregular; by a mediocre scribe.</desc>
                     </handNote>
                  </handDesc>

                  <decoDesc>
                     <decoNote type="band" xml:id="d1">
                        <locus target="#1r">Fol. 1r</locus>
                        <desc>Fine ornamental band, geometric motifs (probably unfinished,
                           only yellow has been applied).</desc>
                     </decoNote>
                  </decoDesc>

                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc> Western Arabic numerals have been added in pencil, in a
                              recent hand, to numerate the Psalms.</desc>
                        </item>

                        <item xml:id="e2">
                           <locus target="#1r">Fol. 1r</locus>
                           <desc>Arabic title in pencil.</desc>
                           <q xml:lang="ar">مزامير</q>
                        </item>
                     </list>
                  </additions>



                  <bindingDesc>
                     <binding xml:id="binding">
                        <decoNote xml:id="b1">No binding.
                           Holes in the centre folds of the
                           leaves are made for two pairs of sewing stations.
                           The quire is held together with tackets (twisted
                           strips of parchment) on both sides.</decoNote>
                     </binding>
                  </bindingDesc>

               </physDesc>

               <history>
                  <origin>
                     <origDate xml:lang="ar">النصف الثاني من القرن التاسع عشر / أوائل القرن العشرين</origDate>
                     The manuscript can be dated palaeographically to the
                     <origDate notBefore="1850" notAfter="1930" evidence="lettering">second half
                        of the nineteenth/early twentieth century</origDate>.
                     The quire, probably part of an unfinished
                     book, originates from <placeName ref="https://betamasaheft.eu/LOC2991Eritre">Eritrea</placeName>,
                     according to the Arabic description on a paper slip.
                  </origin>
               </history>

               <additional>
                  <adminInfo>
                     <note>A paper slip with a modern Arabic
                        description of the manuscript is placed inside.</note>
                  </adminInfo>
               </additional>

            </msDesc>

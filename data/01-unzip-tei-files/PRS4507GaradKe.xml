      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ጋረድ፡ ክንፉ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gārad Kǝnfu</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ ግልብጥ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbā Gǝlbǝṭ</t:persName>
               <t:persName>
                  <t:roleName type="title">lǝǧ</t:roleName>
               </t:persName>
               <t:occupation type="political">rebel</t:occupation>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               <t:floruit notBefore="1839" notAfter="1860">He was the son of <t:persName ref="https://betamasaheft.eu/PRS5951Kenfuha">
                     <t:roleName type="title">
                  daǧǧāmāč</t:roleName> Kǝnfu Ḫaylu </t:persName> who ruled <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName> 
                  province from <t:date>1831</t:date> until his death in <t:date>1839</t:date>.Through him, Gārad Kǝnfu was related to 
                  <t:roleName type="title">ʾaṣe</t:roleName>
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName>. 
                  He is noted as one of the rebels against 
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName>, in <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName>
                  and <t:placeName ref="https://betamasaheft.eu/LOC6186Walqay">Walqāyt</t:placeName>. In <t:date>1860</t:date>, he emerged as as an ally of 
                  <t:persName ref="https://betamasaheft.eu/PRS7542NeguseW">Nǝguśe Wäldä Mikaʾel</t:persName>, 
                  at the time he was the most prominent opponent of  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName>. In a skirmish 
                  outside <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>, Gārad killed <t:persName ref="https://betamasaheft.eu/PRS7907Plowden">Walter Chichele Plowden</t:persName>
               </t:floruit>
               <t:death when="1860">He, in turn,  was killed  in revenge by <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros II</t:persName> 
                  in a battle in <t:placeName ref="https://betamasaheft.eu/LOC6171Waldeb">Waldǝbba</t:placeName> in<t:date>1860</t:date>.</t:death>
            </t:person>
            
         </t:listPerson>
         
         

            <person sameAs="wd:Q471332" sex="1">

                  <persName xml:lang="gez" xml:id="n1" type="birth">ላሊበላ፡</persName>
                  <persName xml:lang="gez" corresp="#n1" type="normalized">Lālibalā</persName>
                  <persName xml:lang="gez" xml:id="n2" type="regnal">ገብረ፡ መስቀል፡</persName>
                  <persName xml:lang="gez" corresp="#n2" type="normalized">Gabra Masqal</persName>
               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>

               

               <floruit notBefore="1190" notAfter="1230">He was a late 12th and early 13th century king of Zāgʷe dynasty.
                  He is venerated as a saint in Ethiopian Orthodox Church.
                  He succeeded his brother a saint king
                  <persName ref="https://betamasaheft.eu/PRS5111harbay">
                     <roleName type="title">ʾaṣe</roleName>Ḥarbāy</persName>.
                  He was one of the best known Zāgʷe kings and one of the most famous Ethiopian rulers reputed as the builders of the
                  rock hewn churches of <placeName ref="https://betamasaheft.eu/LOC4244Laliba">Lalibalā</placeName> town.
               </floruit>

            </person>
            
         </listPerson>
      


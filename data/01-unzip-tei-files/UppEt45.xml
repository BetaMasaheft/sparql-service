                        <decoDesc>
                            <decoNote xml:id="d1" type="miniature">
                                <desc>Coloured <term key="Magic" ana="#Magic">magic picture</term> of 
                                    a man with round eyes showing the onlooker the palms of his hands.
                                    From the top of his head, two snakes emerge, one reaching towards the left
                                    and the other to the right.
                                    The picture is placed at the top of the scroll in a field of 42 cm height, which it almost fills. 
                                    Initially, <persName ref="https://betamasaheft.eu/PRS6337Lofgren">Oscar Anders Valfrid Löfgren</persName>
                                    hesitantly identified the person as demon 
                                    (<bibl corresp="http://zotero.org/groups/358366/items/W7HE9FNZ"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1929Evangeliska"/><title level="a">Die abessinischen Handschriften der Evangeliska Fosterlands-Stiftelsen, Stockholm</title><title level="j">Le Monde Oriental</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><date>1929</date><biblScope unit="volume">23</biblScope><biblScope unit="page">1-22</biblScope><citedRange unit="page">16</citedRange></bibl>), but later 
                                he rejected this and suggested that it might rather represent a saint or a priest
                                    (<bibl corresp="http://zotero.org/groups/358366/items/JXSNIKFS"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Loefgren1962Wandamulette"/><title level="a">Äthiopische Wandamulette</title><title level="j">Orientalia Suecana</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Oscar</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Löfgren</t:surname></author><date>1962</date><biblScope unit="volume">11</biblScope><biblScope unit="page">95-120</biblScope><citedRange unit="page">105</citedRange></bibl>).
                                </desc>

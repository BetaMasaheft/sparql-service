               <msContents>
                  <summary>I) Gadla Gabra Manfas Qǝddus “Vita of Gabra Manfas Qǝddus” (fols.
                     4ra-94ra)
 II) Taʾammǝra Gabra Manfas Qǝddus “Miracles of Gabra Manfas
                     Qǝddus”: 13 miracles (fols. 94ra-112ra)
 III) Malkǝʾa Gabra Manfas Qǝddus
                     “Image of Gabra Manfas Qǝddus” (fols. 112rb-116rb)</summary>
                  <msItem xml:id="ms_i1">
                     <title ref="https://betamasaheft.eu/LIT1119DossierQMQ">Hagiographic Dossier of St Gabra Manfas Qǝddus</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="4ra" to="94ra"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1451GadlaG">Gadla Gabra Manfas Qǝddus (general record)</title>
                        <msItem xml:id="ms_i1.1.1">
                           <locus from="68va" to="94ra"/>
                           <title ref="https://betamasaheft.eu/LIT4077DersanG">Homily by Zenā Gabrǝʾel on Gabra Manfas Qǝddus; 4 miracles
                              in vita</title>
                        </msItem>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="94ra" to="112rb"/>
                        <title ref="https://betamasaheft.eu/LIT3977Taammer">Taʾammǝra Gabra Manfas Qǝddus “Miracles of
                           Gabra Manfas Qǝddus”: 13 miracles</title>
                        <msItem xml:id="ms_i1.2.1">
                           <locus from="111va" to="112rb"/>
                           <title>Blessings for those who gathered to listen to the
                              Vita and Miracles of Gabra Manfas Qǝddus</title>
                        </msItem>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="112rb" to="116rb"/>
                        <title ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>
                     </msItem>
                  </msItem>


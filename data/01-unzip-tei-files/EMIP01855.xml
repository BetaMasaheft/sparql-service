                    <decoNote type="miniature" xml:id="d1"><locus target="#3r" facs="003">Fol. 3r</locus><desc>Drawing of horse with saddle and bridle</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#268r" facs="268">Fol. 268r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#268v" facs="269">Fol. 268v</locus><desc>Drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref> and an “awesome lion.”</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#147r" facs="147">Fol. 147r</locus>
                    <desc>
                    Notes on the names of the Sundays for the church year, written in a later hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#183v" facs="184">Fol. 183v</locus>
                    <desc>
                    Note of blessing for parents of those whose children are given Christian names
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#267v" facs="268">Fol. 267v</locus>
                    <desc>
                    Note about chants
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#74v #75r #76v #77r" facs="075 077">Fols. 74v, 75r, 76v, 77r</locus>
                    <desc>
                    damaged images that do not show the book
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, covered with tooled leather with fabric visible between the turn-ins.</decoNote>
                    <decoNote xml:id="b2" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

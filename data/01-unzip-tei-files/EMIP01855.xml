               <msContents>
                  <summary>Antiphonary for the Whole Year, Dǝggwa, ድጓ፡</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="2v" facs="002">Fols 2r–2v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Haleta">Dǝggʷā, Table of
                                                  melodic variations for the Hallelujah (same as
                                                  https://betamasaheft.eu/LIT1110Anqasa)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="4r" to="267v" facs="004">Fols 4r–267v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                  <note>arranged by months and within the month by Feast Days</note>
                  <notatedMusic><desc>with musical notation, marginal notes give directions for the type of melody to use for the section</desc></notatedMusic>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <msItem xml:id="ms_i2.1"><locus from="4r" to="73v" facs="004">Fols 4r–73v</locus><title>Deggua from John, the Evangelist, to the Martyrs</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.2"><locus from="74r" to="113r" facs="074">Fols 74r–113r</locus><title>Deggua for the season called “Teaching” (<foreign xml:lang="gez">አስተምህሮ</foreign>) and Advent (<foreign xml:lang="gez">ስብከት</foreign>)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.3"><locus from="113v" to="147r" facs="114">Fols 113v–147r</locus><title>Deggua for the season called “Nativity” (<foreign xml:lang="gez">ልደት</foreign>)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.4"><locus from="148r" to="183v" facs="148">Fols 148r–183v</locus><title>Deggua for the season called Lent (<foreign xml:lang="gez">ጾመ ድጓ</foreign>)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.5"><locus from="184r" to="211r" facs="184">Fols 184r–211r</locus><title>Deggua for the season called Easter (<foreign xml:lang="gez">ዘፋሲካ</foreign>)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.6"><locus from="211r" to="241r" facs="211">Fols 211r–241r</locus><title>Deggua for the season called Ascension (<foreign xml:lang="gez">ዘዕርገት</foreign>) and other feast days</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.7"><locus from="241r" to="266r" facs="241">Fols 241r–266r</locus><title>Deggua for the Feast of Saint Mary and other feasts</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2.8"><locus from="266r" to="266v" facs="266">Fols 266r–266v</locus><title>Eratta (<foreign xml:lang="gez">መዝሙር ዘተረሥዓ፡</foreign>) for an overlooked psalm for the Feast days of Stephen, Mark, and Samuel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
              </msItem>
               </msContents>

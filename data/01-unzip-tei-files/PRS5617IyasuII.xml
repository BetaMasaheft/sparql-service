         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q735638">
            
          
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ኢያሱ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾIyāsu II</t:persName>
                  <t:persName xml:lang="gez" xml:id="n2" type="nick">ቋረኛ፡ ኢያሱ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n2" type="normalized">Qʷāraññā ʾIyāsu</t:persName>
                  <t:persName>
                  <t:roleName type="title">ʾaṣe</t:roleName>
               </t:persName>
               <t:persName xml:lang="gez" xml:id="n3.1" type="regnal">አድያም፡ ሰገድ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n3.1" type="normalized">ʾAdyām Sagad</t:persName>
                  <t:persName xml:lang="gez" xml:id="n3.2" type="regnal">ብርሃን፡ ሰገድ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n3.2" type="normalized">Bǝrhān Sagad</t:persName>
           
               <t:occupation type="ruler">Emperor</t:occupation>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:residence>
                  <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>
               </t:residence>
              <t:birth when="1723"/>
               <t:floruit from="1730" to="1755">He succeeded his father King 
                  <t:persName ref="https://betamasaheft.eu/PRS2377Bakaffa">Bakāffā</t:persName> in <t:date>1730</t:date>. 
                  He was seven years old when he became a king and his mother, the famous Gondarian queen <t:persName ref="https://betamasaheft.eu/PRS2682BerhanM">Bǝrhān Mogasā</t:persName>, was his regent, 
                  who exercised the real political power together with her brother 
              
                  <t:persName ref="https://betamasaheft.eu/PRS7585Niqolawo">
                     <t:roleName type="title">rās</t:roleName> Niqolāwos</t:persName>. 
                   </t:floruit>
               <t:death when="1755" evidence="internal"/>
            </t:person>
            

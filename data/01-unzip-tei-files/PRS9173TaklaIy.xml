         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ነገሮ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Nagaroo</t:persName>

               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ተክለ፡ ኢየሱስ፡</t:persName>

               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Takla ʾIyasus</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">ተክሌ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Takle</t:persName>
                  
               <t:persName>
                  <t:roleName type="title">ʾalaqā</t:roleName>
               </t:persName>
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
               <t:occupation type="literary">chronicler</t:occupation>
               <t:birth notBefore="1867" notAfter="1868"/>
                  
                  
                  <t:floruit notBefore="1889" notAfter="1936">He was a church educated artist, 
                     historian and genealogist who flourished under the patronage of 
                     <t:persName ref="https://betamasaheft.eu/PRS9158TaklaHa">Takla Hāymānot</t:persName> of <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>.
                     He received a traditional church education at 
                     <t:placeName ref="https://betamasaheft.eu/LOC2687DimaGi">Dima Giyorgis</t:placeName>. 
                     He went into <t:persName ref="https://betamasaheft.eu/PRS9158TaklaHa">Takla Hāymānot</t:persName> service in <t:date>1889</t:date> 
                           and worked with the master painter <t:persName ref="https://betamasaheft.eu/PRS5236haylu">Ḫaylu</t:persName> on murals, 
                     illuminations and engravings in the palace as well as in
                           the churches and monasteries of <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>.        
                  
                  </t:floruit>
               <t:death when="1936"/>
                  
                  
               </t:person>
            

                        <seg type="script"/>
                        <seg type="ink">Black, red</seg>
                        <date>19th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሰ፡ / ሰላ፡</abbr> for <expan>ሰላም፡ </expan> (e.g., <locus target="#98vc">98vc</locus>, 101vc, 102vb, 103rac)</item>

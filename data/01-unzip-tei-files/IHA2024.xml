               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="11v">1r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1153IHA">انفع الرسائل باهم المسائل</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم الحمد لله الذي جعل قلوب العارفين اوعية اسراره [وبروزهم] رحمة لعامة خلقه وهدايتهم اليه والصلاة والسلام على سيدنا محمد [...] وبعد فهذه رسالة جمعت فيها بعض وصيات شيخنا فى رسائل متعددة لبعض الاولاد والاخوان تقريبا للفائدة ولما كانت [الوصية] متفرقة باءوقات مختلفة لاشخاص معتددة تكرر ما فى وصية ءخرى

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>قال العلامة المناوى فى شرحه اى بملاينتهم والرفق بهم ليدخل من يدخل فى الدين برفق ويتقى المؤمن شر من قدر قدر عليه الشفاء انتهى فاد علمت ذالك فليعامل كل احد بما هو الانسب له وليجتنب الموفق من جعل الامر كليته بل يميز بالقراءن والمحكات هذ والسلام والحمد لله رب العالمين فصلى الله على سيدنا محمد واله وسلم  تمت

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="12r" to="15r">12r-15r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0119IHA">كتاب التوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#12r">-12r</locus>بسم الله الرحمن الرحيم الحمد لله رب العالمين والعاقبة للمتقين الباب الاول فى بيان ما يجب على العبد اولا يجب على كل بالغ عاقل ان يعرف اولا ان له خالقا ورازقا وهو الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15r">-15r</locus>فبهذ السبب صاروا اربع طوائف جعلنا الله واياكم من الفائزين الذين يولدون مسلمين ويموتون مسلمين ببركه محمد امين \ تمت \ صلى الله عليى سىدىا محمد واله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="15v" to="16r">15v-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3979IHA">رسالة في الايمان</title>
                     <incipit xml:lang="ar">
                        <locus target="#15v">-15v</locus>بسم الله الرحمن الرحيم \ بسم الله الرحمن الرحيم \ وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم الايمان ستة ان تؤمن بالله اي بأسمائه وذاته وصفاته وافعاله وان تؤمن بملئكته اي بانهم لا يوصفون بذكورة ولا بانوثة لا ياكلون ولا يشربون اكلهم وشرابهم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>فالاسم الله لا اله الا هو الحي القيوم والذات قل هو الله احد الله الصمد لم يلد ولم يولد ولم يكن له كفوا احد والصفة ليس كمثل شيء وهو السميع البصير والفعل كل يوم هو فى شأن تمت \ تمت \ وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="17r" to="31r">17r-31r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0026IHA">مختصر ﺍبي شجاﻉ على مذﻫب ﺍلشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#17r">-17r</locus>عليهما وتيمم ويصلى ولا اعادة عليه ان كان وضعها على طهر ويتيمم لكل فريضة ويصلى بتيمم واحد ما شاء من النوافل </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#31r">-31r</locus>وان ملك الأمة المطلقة بعد ذلك لم يصر أم ولد له بالوطء فى النكاح وصارت أم ولد له بالوطء بالشبهة على أحد القولين والله أعلم وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم امين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="31v" to="52v">31v-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0032IHA">مقدمة الحضرمية في فقه السادة الشافعية</title>
                     <incipit xml:lang="ar">
                        <locus target="#31v">-31v</locus>بسم الله الرحمن الرحيم \ الحمد لله الذى فرض علينا تعلم شرائع الاسلام ومعرفة صحيح المعاملة وفاسدها لتعريف الحلال والحرام [...] وبعد فهذا مختصر لا بد لكل مسلم من معرفته أو معرفة مثله فيتعين الاهتمام به واشاعته فاناسأل [كذا] الله الكرم أن  ينفع به وأن يجعل جمعى له خالصا ولوجهه الكريم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>دهن شعر الرأس واللحية الرابع ازالة شئ من الشعر والظفر فأن [.؟.] أو تطيب أو دهن شعره أو باشر بشهوة أو استمنى فأنزل عامدا [.؟.] \ مختار<note>The ends of the lines are not visible due to close binding. The last word is the catchword.</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="53r" to="53v">53r-53v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0026IHA">مختصر ﺍبي شجاﻉ على مذﻫب ﺍلشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#53v">-53v</locus>الميبة وشعرها نجس الا شعر الادمي ولا يجوز [.؟.] الذهب والفضة ويجوز استعمال غيرهما من الاواني فص[.؟.] مستحب في كل حال الا بعد الزول للصائم     <note>The top left corner torn off.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53r">-53r</locus>وابتدء المدة من حين يحدث بعد لبس الخفين فان مسح فى الحضر ثم سافر او مسح فى السفر ثم اقام أتم مسح مقيم</explicit>
                     <note>One folio stitched into the present manuscript. It is placed back to front, i.e. the fragment begins from fol. 53v and continues to 53r. Immediate continuation of the text on fol. 56r.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="54r" to="55v">54r-55v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0664IHA">قصيدة تبارك ذو العلاء والكبرياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#54r">-54r</locus>صبا منك الفؤاد فلم  تزغه وحدت إلى متابعة الفؤد \ وقادتك المعاص حيث شأت وألفتك إمرس سلس القياد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#55v">-55v</locus>وفالا كان الذي عقباه شؤم ولا كان البخيل لديه مالا \ وكن بشأ كريما ذ انبساط وفى من يرتجيك جميل راي</explicit>
                     <note>Two folios stitched into the present manuscript. Each folio contains a fragment of the qaṣīda.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="56r" to="71r">56r-71r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0026IHA">مختصر ﺍبي شجاﻉ على مذﻫب ﺍلشافعي</title>
                     <incipit xml:lang="ar">
                        <locus target="#56r">-56r</locus>ويبطل المسح بثلاثة ءشياء بخلعهما ونقضاء المدة [.؟.] الغسل فصل وشرائط التيمم خمسة ءشياء وجود العذ بسفر او مرض ودخول وقت الصلاة وطلب الماء وتعذر ءستعماله <note>The top right corner torn off.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71r">-71r</locus>حكم المدبر فى حال حياته كحكم العبد القن فصل والكتابة مستحبة [.؟.] ساءلها العبد وكان [مأمونا] مكتسبا ولا يصح ءلا بمال معلوم الى ءجل \ أقله نجما<note>The endings of the lines are not visible due to close binding. The two last words are the catchwords.</note>
                     </explicit>
                     <note>
                        <note>
        Manuscript item  6397 relates to manuscript item 6396</note>
                     </note>
                     <note>Continues immediately from fol. 53r. A section on fol. 60r vocalized (a prayer to be recited at a funeral).</note>
                     <note/>
                  </msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="178r">1v-178r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2225IHA">شرح ابن عقيل على الفية ابن مالك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله رب العلمين والصلاة والسلام على سيدنا محمد واله وصحبه وسلم قالَ مُحمَّدٌ هو ابْنُ مالكِ أحمدُ ربِّيْ اللهَ خيرَ مالكِ مُصلِّياً على النَّبيِّ المصطفى وآلهِ المُسْتكملينَ الشَّرَفاك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#78r">-78r</locus>فاحمد الله مصليا على محمد خير نبي ار... وءاله الغر الكرم البررة وصحبه المنتخبين الخيرة</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>
                        <extent>
                           <measure unit="folio">178</measure>
                                        Pre: <measure unit="folio">1</measure>

                    <decoNote type="miniature" xml:id="d1"><locus target="#2r" facs="002">Fol. 2r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#11r" facs="011">Fol. 11r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#19v" facs="020">Fol. 19v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref>. <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (right) is spinning yarn.</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#31r" facs="031">Fol. 31r</locus><desc> Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>, the one on the left holds a <term key="sword" ana="#sword"/>; the one on the right holds handkerchief and book</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#51r" facs="051">Fol. 51r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> (center), holding a scroll with the Trinitarian formula written on it, with a follower (right)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#62r" facs="062">Fol. 62r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref> <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> (center), holding a pouch, addresses a figure (right), followed by another figure (left)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#80v" facs="081">Fol. 80v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#103r" facs="103">Fol. 103r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising Adam and Eve</desc></decoNote>

               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">152</measure>
                           <dimensions type="outer" unit="mm">
                              <height>170</height>
                              <width>125</width>
                              <depth>60</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="20 24">
                         <locus from="5r" to="138v" facs="005">Fols 5r–138v</locus>
                       </layout>
                       <layout columns="2" writtenLines="20 24">
                         <locus from="139r" to="151v" facs="139">Fols 139r–151v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The word for God is systematically rubricated</desc>
                  <desc>No columetric layout in the codex</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus from="2r" to="4r" facs="002">Fols 2r–4r</locus><desc>Crude drawing of <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> and people and animals, Madonna and Child with guardian <term key="angel" ana="#angel"/>s, <term key="angel" ana="#angel"/> standing with drawn <term key="sword" ana="#sword"/>, in the fore guard folios</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <locus target="#4v" facs="005">Fol. 4v</locus>
                    <desc>
                    scrawls and pen trials
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <locus target="#5r" facs="005">Fol. 5r</locus>
                    <desc>
                    Harag featuring faces
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#64r" facs="064">Fol. 64r</locus>
                    <desc>
                    The midpoint is unmarked
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    Contains the shorter version of <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps151">Psalms of
                                                  David, Psalmus 151</title>, without rekusan, the longer plus, and legolyad
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    The fourth biblical canticle is titled, Prayer of Hana, mother of Samuel
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#138v" facs="139">Fol. 138v</locus>
                    <desc type="OwnershipNote">
                    mentions secondary owners written in red pen, and written in blue ink
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#152r" facs="152">Fol. 152r</locus>
                    <desc>
                    small writing exercise, in Amharic, written in pencil
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="leather"/>
                      <material key="textile"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1999">Twentieth century</origDate>
                  </origin>
               </history>

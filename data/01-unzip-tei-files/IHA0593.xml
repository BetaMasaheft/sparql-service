               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="22v">1r-22v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0378IHA">در الفريد في عقائد اهل التوحيد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم الحمد لله الواحد فى ذاته وصفات الذى بعث سيدنا محمد للخلق بالتوحيد بباهر اياته واله الصلاة والسلام على عروس الرسل وسيد كل من لك عليه سيادتى على اله وصحبه والتابعين لهم بالحينى وزيادة وبعد فيقول كثير المساور الفقير لرحمة ربه احمد النحروى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>ومنهم من يرا كل ساعة ومنهم من يراه كل لحظة ومنهم من سراه يكون مداوم النظر له جل وعز وهذه الحالة اكمل الحالات الله اللهم اجعلنا والدنيا ومشايخنا وحتبابنا من اهل ذاه لك بجاه سيدنا محمد الذى سلك بنا او صلح المسالك صلى الله تعالى عليه وعلى اله واصحابه وازواجه وداريته واهل بيته كلما ذكرى وذكره الذاكرون وغفل عن ذكرى وذكره الغافلون أمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="24v" to="39v">24v-39v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1101IHA">متن الحكم</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>بسم الله الرحمن الرحيم من علامة الاعتماد على العمل نقصان الرجاء عند وجود الزلل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#39v">-39v</locus>فصار العرش غيبا فى رحما نيته كما صارت العولم غيبا فى عرشه محقت الاثار بالأثار ومحوت الاغيار بمحيطات افلاك الانوار يا من امحت احتجب فى سر ادقات ان تذكره الابصار يا من تجلى بكمال جماله بهائه فتحققت عفته عظمته الاسرار كيف تخفى وانت الظاهر ام كيف تغيب وانت الرقيب الحاضر</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

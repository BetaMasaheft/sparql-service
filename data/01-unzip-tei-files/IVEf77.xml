               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                      <locus from="1r" to="64r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT3560Chrfaith">Untitled Amharic treatise on the Christian faith</title>
                      <incipit xml:lang="am">ሃይማኖት፡ ለሚየከስ፡</incipit>
                      <note>Untitled Amharic treatise of
                        Catechism type on the Christian faith, composed of questions and responses.</note>
                  </msItem>

                    <msItem xml:id="ms_i2">
                      <locus from="64v" to="69r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2332serata">ስራተ፡ ቤተ፡ ክርስቲያን፡</title>
                        <incipit>ገረገራ፡ በመላእክት፡ <hi rend="rubric">ይተረጐል</hi>። ዓጸድ፡ በነገደ፡ መላእክት፡ <hi rend="rubric">ይተ</hi>፡ ቤተ፡ ክርስቲያን፡ በአብ፡ <hi rend="rubric">ይተ</hi>፡
                         ግድግዳ፡ በመንፈስ፡ ቅዱስ፡ <hi rend="rubric">ይተ</hi>፡ ጸርብ፡ በወል፡ <hi rend="rubric">ይተ</hi>፡ ጐልለተ፡ በተዋሕዶ፡ ሥላሤ፡ <hi rend="rubric">ይተ</hi>፡
                          መስቀል፡ በመልዕልተ፡ ኵሉ፡ እግዚአብሔር፡
                        </incipit>
                        <note>A Śǝrʿāta beta krǝstiyān text, possibly the same as in manuscript Staatsbibliothek zu Berlin Preußischer Kulturbesitz, Petermann II Nachtr. 32,
                        ff. 1v-2r, <bibl corresp="http://zotero.org/groups/358366/items/MR9BZ9JK"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1878Verzeichnis"/><title level="m">Verzeichniss der abessinischen Handschriften, mit drei Tafeln</title><title level="s">Die Handschriften-Verzeichnisse der Königlichen Bibliothek zu Berlin</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></author><pubPlace>Berlin</pubPlace><publisher>Buchdruckerei der Königl. Akademie der Wissenschaften (G. Vogt)</publisher><date>1878</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Die Handschriften-Verzeichnisse der Königlichen Bibliothek zu Berlin</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">3</t:biblScope></series><biblScope unit="volume">3</biblScope><note type="url">https://archive.org/details/diehandschriften03preu</note><citedRange unit="page">38</citedRange></bibl>
                     </note>
                      </msItem>

               </msContents>

               


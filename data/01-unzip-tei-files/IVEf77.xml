                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#69v"/>
                           <desc type="Poem">Short hymn to <persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName>
                             composed of three strophes.</desc>
                             <q xml:lang="gez">
                               <l n="1">አፍጠነ፡ ረድኤት፡ ለጽኑዕ፡ ወለድኩም፡</l>
                               <l n="2">ለነፍስ፡ ኵሉ፡ ቃውም፡</l>
                               <l n="3">ጊዮርጊስ፡ የዋህ፡ እንበለ፡ መስፈርት፡ ወአቅም፡</l>
                                </q>
                              </item>


                     </list>
                  </additions>


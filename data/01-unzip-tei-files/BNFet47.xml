                          <textLang mainLang="gez"/>
                          <explicit xml:lang="gez">ተፈጸመ፡ መልዕክት፡ ኀበ፡ ሰብአ፡ ኤፌሶን፡ ተጽሕፈ፡ በሮሜ፡ ወተፈነወ፡ በእደ፡ ጢኪቆስ። ወስብሐት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </explicit>
                          </msItem>
                          

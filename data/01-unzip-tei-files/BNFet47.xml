                            <textLang mainLang="gez"/>
                            <explicit xml:lang="gez">ተፈጸመ፡ መልዕክት፡ ኀበ፡ ሰብአ፡ ፊልጵስዩስ። ወተጽሕፈ፡ በሮሜ፡ ወተፈነወ፡ ምስለ፡ ጢሞቴዎስ፡ ወኣፍሮዲጡ። ቃሉ፡
                            ፪፻፲ወ፪፡ ወምዕራፉ፡ ዓሠርቱ።</explicit>
                          </msItem>
                          

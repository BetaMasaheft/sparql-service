                     <msItem xml:id="ms_i1.2">
                        <locus from="18r">Fols 18r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3516Epistle">መልዕክት፡ ቀዳማዊ፡ ኀበ፡ ሰብአ፡ ቆሮንቶስ።</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ተፈጸመ፡ መልዕክት፡ ቀዳማዊ፡ ኀበ፡ ሰብአ፡ ቆሮንቶስ፡ ዘተጽሕፈ፡ በኤፌሰን፤ ወተፈነወ፡ ምስለ፡ ጢሞቴዎስ፡ ወእስጢፋኖስ፡
                      ወፈርዶናጥስ፡ ወአካይቆስ።</explicit>
                     </msItem>
                    
                    <msItem xml:id="ms_i1.3">
                        <locus from="36v">Fols 36v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3517Epistle">መልዕክት፡ ካልእት፡ ለሰብአ፡ ቆሮንቶስ።</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ተፈጸመት፡ መልእክት፡ ዳግሚት፡ ኀበ፡ ሰብአ፡ ቆሮንቶስ። 
                        ወተጽሕፈት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ወተፈነወት፡ በእደ፡ ቲቶ፡ ወሉቃስ። ወስብሐት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </explicit>
                    </msItem>
                      
                      <msItem xml:id="ms_i1.4">
                        <locus from="49r">Fols 49r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3518Epistle">መልዕክት፡ ኀበ፡ ሰብአ፡ ገላትያ፡ ወተጽሕፈ፡ እንዘ፡ ሀሎ፡ ብሔረ፡ ሮሜ።</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ተፈጸመት፡ መልዕክት፡ ኀበ፡ ሰብአ፡ ገላትያ፡ ወተጽሕፈት፡ በሮሜ፡ ወተፈነወት፡ በእደ፡ ቲቶ፡ 
                          ረድኡ። ስብሐት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </explicit>
                      </msItem>
                        
                        <msItem xml:id="ms_i1.5">

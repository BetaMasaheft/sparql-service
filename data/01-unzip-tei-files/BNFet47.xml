                              <textLang mainLang="gez"/>
                              <explicit xml:lang="gez">ተጽሕፈ፡ በሮሜ፡ ወተፈነወ፡ በእደ፡ ጢኪቆስ። ቃሉ፡ ፫፻፲፡ ወምዕራፉ፡ ዐሠርቱ።</explicit>

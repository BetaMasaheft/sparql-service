                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="1r" to="46v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Sawāsǝw (general record)</title>
                          <textLang mainLang="gez" otherLangs="am"/>

                          <msItem xml:id="ms_i1.1">
                            <locus from="1r" to="28v"/>
                            <title type="complete"> Gǝʿǝz-Amharic vocabulary in not-identified order. </title>
                            <textLang mainLang="gez" otherLangs="am"/>
                            <incipit xml:lang="gez">እጽሐፍ፡ ነገር፡ (sic) ሰዋስው፡ ሰዋስመሸጋራው፡ (sic) መሰለል፡ ተንከተም፡ ብሂል፡ ድልድይ፡ ወመሰላል፡ ዲበ፡ ላዕለ፡ መልዕልተ፡ ብ፡ በላይ፡
                            </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus from="29r" to="43v"/>
                          <title type="complete"> Gǝʿǝz-Amharic vocabulary in alphabetical order. </title>
                          <textLang mainLang="gez" otherLangs="am"/>
                          <incipit xml:lang="gez">እጽሐፍ፡ ነገረ፡ ሰዋስው፡ ዘበሉይ፡ ወዘሐደስ፡ (sic) ሰዋስው፡ ብሂል፡ መሸጋገራ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> እንዘ፡ ብ፡ ሲሳስ፡ እስመ፡ ብ፡ ስለ፡ ና፡
                          </incipit>
                          <note>The order starts with እ.</note>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus target="#44r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ሲመት፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ቄሣር፡ አጼ፡ መጥሮ፡ ጶሊስ፡ ብ፡ ሊቀ፡ ጳጳሳት፡ እስቁፍ፡ ብ፡ ጳጳስ፡ ኤጲስ፡ ቆጶስ፡ ብ፡ እምታሕቴሁ፡ አቅምንስ፡ ብ፡ ቄሰ፡ ገበዝ፡
                        </incipit>
                        <note>Explanation of different titles</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4">
                        <locus from="44v" to="45v"/>
                        <title type="complete" xml:lang="en">Diverse allegoric explanations</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">እምሐዱስ፡ (sic) ወብሉይ፡ ማይ፡ እሳት፡ ጼው፡ ወሐፂን፡ እክል፡ ወሥርናይ፡ ሀሊብ፡ ወመዓር፡ አድባር፡ ወአዉግር፡ ማይ፡ ብ፡ ጥምቀት፡ እሳት፡ ትምህርት፡
                        <foreign xml:lang="en">From the new and old: water, fire, salt, iron, food, wheat, milk, honey, hills. Water is baptizm, fire is learning</foreign>
                        </incipit>
                        </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus from="46r" to="46v"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ አዕናቍ፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኢያስጲድ፡ በኦሪት፡ በአቡቀለምሲስ፡ ወበአረቢ፡ ያሴ፡ በ፡ ኅብሬ፡ ፀዐደ፡ ወቀይህ፡
                        </incipit>
                     </msItem>
                        </msItem>

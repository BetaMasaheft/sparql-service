                     <msItem xml:id="p1_i1">
                        <locus from="1r" to="5v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">ቅዳሴ፡ እግዚእነ፡ ዘይፌውስ፡ ድውያነ፡</title>
                        <note/>
                        <incipit xml:lang="gez">
                        </incipit>
                        <explicit xml:lang="gez">
                           ቡሩክ፡ ስሙ፡ ለእግዚአብሔር፡ ወቡሩክ፡ ዘይመጽእ፡ በስመ፡ እግዚአብሔር። ወይትባረክ፡ ስመ፡ ስብሐቲሁ፡ ለይኩን፡ ለይኩን። ፈኑ፡ ጸጋ፡ መንፈስ፡ ቅዱስ፡ ላዕሌነ።
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i2">
                        <locus from="5v" to="23v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">አኰቴተ፡ ቍርባን፡ ዘአባ፡ ህታይቆስ፡ ጳጳስ፡ ዘሀገረ፡ ብህንሳ።</title>
                        <note/>
                     </msItem>

                     <msItem xml:id="p1_i3">
                        <locus from="23v" to="35r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1103Anapho">ʾAkkʷateta qʷǝrbān za-darasu 318 rǝtuʿāna hāymānot</title>
                        <note/>
                        <incipit xml:lang="gez">
                        </incipit>
                        <explicit xml:lang="gez">
                           <choice>
                              <sic>ወኢይሴወሮ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ወኢይሴውሮ፡</corr></choice>
                            ሌሊት፡ አንተ፡ ዘአቅረብከነ፡ ቅድመ፡
                           ዝንቱ፡ ምሥጢር፡ ለከ፡ ስብሐት፡ ወ
                              <sic>ከብር፡</sic>
                            ለዓለመ፡ ዓለም፡ አሜን።
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i4">
                        <locus from="35r" to="46v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1098Anapho">ʾAkkʷateta qʷǝrbān za-Bāsǝlyos</title>
                        <note/>
                        <incipit xml:lang="gez">
                           አኰቴተ፡ ቍርባን፡ ዘባስልዮስ፡ ጸሎቱ፡ ወበረኮቱ፡ ትኩን፡ ምስሌነ፡ አሜን፡ ይ፡ ዲ፡ እግዚኦ፡ መሐረነ፡ እግዚኦ፡ መሐረነ፡ እግዚኦ፡ መሐረነ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ስምዓነ፡ ወመሐረነ።
                        </incipit>
                        <explicit xml:lang="gez">
                           ከሠትከ፡ ለነ፡ ለኅፃናት፡ ንኡሳን፡ እለ፡ ቤተ፡ ክርስቲያን፡ ቅድስት። ኦአብ፡ ከመ፡ ዝንቱ፡ ሥምረት፡ ኮነ፡ በቅድሜከ፨ እስመ፡ አንተ፡ መሐሪ፡ ለከ፡ <choice>
                              <sic>ንፈኑ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ንፌኑ፡</corr></choice>
                           
                           ውስተ፡ አርያም፨ <choice>
                              <sic>ስብሐት፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ስብሐተ፡</corr>
                           </choice>
                           <choice>
                              <sic>ወክብር፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ወክብረ፡</corr></choice>
                            ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን።
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i5">
                        <locus from="46v" to="59r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1570habeka">ʾAkkʷateta qʷǝrbān za-qǝddus Yoḥannǝs wangelāwi</title>
                        <note/>
                        <incipit xml:lang="gez">
                           ጸሎተ፡ ቅዳሴ፡ ዐቢይ፡ ዘዮሐንስ፡ ወንጌላዊ፡ ወልደ፡ ነጐድጓድ፡ በጊዜ፡ ቍርባን፡ ወኵሉ፡ ሥርዐቱ፡ ከመ፡ ቅዳሴ፡ ሐዋርያት። ኀቤከ፡ እግዚኦ፡ አንቃዕደውነ፡ አዕይንቲነ፡ ወአንሣእነ፡ ልበነ፡ ወአልዐልነ፡ ኅሊናነ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወለሴስዮ፡ <choice>
                              <sic>ነግስት፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ነፍሳት፡</corr></choice>
                            ወሥጋት፡ ወመናፍስቲሆሙ፡
                           በእግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ 
                              <sic>ከርስቶስ፡</sic>
                            ዘቦቱ፡ ለከ፡ ምስሌሁ፡ ወምስለ፡ ቅዱስ፡ መንፈስ፡ ስብሐት፡ ወእኂዝ፡ 
                              <sic>ይእዜኔ፡</sic>
                           
                           ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን።
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i6">
                        <locus from="59v" to="67v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2404Tanseu">ʾAkkʷateta qʷǝrbān za-qǝddus Yāʿqob za-Śǝrug</title>
                        <note/>
                        <incipit xml:lang="gez">
                           
                              <sic>አኰቴት፡</sic>
                            ቍርባን፡ ዘያዕቆብ፡ ኤጲስ፡ ቆጶስ፡ ዘስሩግ፨ ይ፡ ዲ፡ ተንሥኡ፡ ለጸሎት፨ ይ፡ ካ፨ ሰላም፡ 
                              <sic>ለኵልከሙ።</sic>
                           <choice>
                           
                              <sic>ወይፈጽም፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ይፌጽም፡</corr></choice>
                            በከመ፡ ሥርዐቱ፨ ወይብል፡ ተንሥኡ፡
                           በፍርሃተ፡ እግዚአብሔር፡ ከመ፡ ታጽምኡ፡ 
                              <sic>አርኅው፡</sic>
                           
                           
                              <sic>መ<add place="inline">
                                    <supplied reason="omitted">ሳ</supplied>
                                 </add>ከወ፡</sic>
                            እዘኒክሙ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           አንጽሕ፡ ሥጋቲሆሙ፡ ወቀድስ፡ 
                              <sic>ነፍሰቲሆሙ።</sic>
                            ወሶበ፡ 
                              <sic>የአትው፡</sic>
                            ውስተ፡ አብያቲሆሙ፡ አንተ፡ እግዚኦ፡
                           ምርሖሙ፡ ወህየ፡ አብጽሖሙ፡ እግዚኦ፡ ወአልዕሎሙ፡ እስከ፡ ለዓለም፡ አሜን፨
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i7">
                        <locus from="67v" to="76r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3120Anapho">ʾAkkʷateta qʷǝrbān za-Yoḥannǝs ʾAfa Warq</title>
                        <note/>
                        <incipit xml:lang="gez">
                           
                              <sic>ቀዳሴ፡</sic>
                            ቍርባን፡ ዘዮሐንስ፡ አፈ፡ ወርቅ፡ ወይብል፡ ካህን፡ እግዚአብሔር፡ ምስለ፡ ኵልክሙ። ወይብል፡ ዲ፡ ላዕለ፡ ይኩን፡
                           
                              <sic>ሕሊናከሙ፡</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           እግዚኦ፡ አኀዜ፡ ኵሉ፡ ዓለም፡ ጸሎት፡ እምድኅረ፡ 
                              <sic>ተመጠው፨</sic>
                            አንብሮ፡ እድ፡ ኀበ፡ ቅዳሴ፡ ዮሐንስ፡ ወንጌላዊ፡ በል፨
                        </explicit>
                     </msItem>

                     <msItem xml:id="p1_i8">
                        <locus from="76v" to="82r"/>
                        <title type="complete" cert="high" ref="https://betamasaheft.eu/LIT2040Naakkw">Anaphora of St Gregory of Nyssa</title>
                        <incipit xml:lang="gez">
                           አኰቴተ፡ ቍርባን፡ ዘጎርጎርዮስ፡ እኅወ፡ ባስልዮስ፡ ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ አምደ፡ ኢየሱስ፡ አሜን፨ ይ፡ ዲ፡ ጸልዩ፡ በእንተ፡ አበዊነ፡ ጳጳሳት፡ ወበእንተ፡ አኃዊነ፡ ካህናት፡ ወበእንተ፡ አርዳኢነ፡
                           <supplied reason="omitted">ንፍቀ፡</supplied> ቀሳውስት፡
                        </incipit>
                        <explicit xml:lang="gez">
                           እለ፡ በላዕነ፡ ሥጋከ፡ ወእለ፡ ሰተይነ፡ 
                              <sic>ደምከ፡</sic>
                            ይኩነነ፡ ለስርየተ፡ ኀጢአት፡ ወለሕይወት፡ ዘለዓለም፡ በአሐዱ፡ ወልድከ፡ ዘቦቱ፤ ለከ፡ ምስሌሁ፡ ወምስለ፡
                           ቅዱስ፡ መንፈስ፡ ስብሐት፡ ወእኂዝ፡ ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                        <note>
                           <persName role="owner" cert="high" ref="https://betamasaheft.eu/PRS11373AmdaIya">ʿAmda ʾIyasus</persName>, possibly the owner of the book, is mentioned in
                           the supplication formula at the beginning of the text.</note>
                     </msItem>

                     <msItem xml:id="p1_i9">
                        <locus from="82r" to="88v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1347Epipha">ʾAkkʷateta qʷǝrbān za-ʾEṗifānyos</title>
                        <note/>
                        <incipit xml:lang="gez">
                           ቅዳሴ፡ ወቍርባን፡ ዘኤጲፋንዮስ፡ ኤጲስ፡ ቆጶስ፡ ዘደሴተ፡ ቆጵሮስ፨ ዐቢይ፡ ውእቱ፡ እግዚአብሔር፡ በዕበዩ፡ ቅዱስ፡ በቅዳሴሁ፨ እኩት፡ በአኰቴቱ፡ ወስቡሕ፡ በስብሐቲሁ፨
                        </incipit>
                        <explicit xml:lang="gez">
                           
                              <sic>ኢትዝ<add place="inline">
                                    <supplied reason="omitted">ከ</supplied>
                                 </add>ር፡</sic>
                            ለነ፡ አበሳነ፡ ዘትካት፡ ፍጡነ፡
                           ይርከበነ፡ ሣህልከ፡ እግዚኦ፨ ኀቤከ፡ ንጸርሕ፡ ኀቤከ፡ ነአወዩ፡ ኀቤከ፡ ንትመሀለል፡ ለዓለመ፡ ዓለም፡ አሜን፨ አንብሮ፡ እድ፡ ኀበ፡ ቅዳሴ፡ ሐዋርያት፨
                        </explicit>
                     </msItem>

                  <msItem xml:id="ms_i1">
                    <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1285Dersan">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                      ድርሳን፡ ዘደረሰ፡ ቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS10382Yohanne">ዮሐንስ፡</persName> ኤጲስ፡ ቆጶስ፡ በእንተ፡ ዕበዩ፡ ወክብሩ፡ 
                      ለቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS4523Garima">ይስሐቅ</persName>።</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ስምዑ፡ ፍቁራንየ፡ ርኢኩ፡ ብእሲተ፡ እንዘ፡ ይዘብጥዋ፡ ዕራቃ፡ 
                      <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                      ወሀሎ፡ አሐዱ፡ ብእሲ፡ ዘስሙ፡ መስፍያኖስ፡ ንጉሠ፡ ሮም፡ ወስመ፡ ብእሲቱ፡ ስፍንማያ። እስመ፡ መካን፡ ይእቲ፡ ወአልባ፡
                      ውሉድ። ወነበሩ፡ ክልኤሆሙ፡ እንዘ፡ የሐዝኑ፡ ፲ወ፪፡ ዓመተ። ወጻድቃን፡ እሙንቱ፡ ውይሁቡ፡ ምጽዋተ፡
                    </incipit>
                    <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/BPQ8VUD9"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1898Garima"/><title level="a">L‘omilia di Yohannes, vescovo d‘Aksum, in onore di Garimâ</title><title level="m">Actes du onzième Congrès international des orientalistes: Paris–1897&lt;hi rend="italics"&gt;, IV:&lt;/hi&gt; Hébreu – phénicien – araméen – éthiopien – assyrien</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Carlo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Conti Rossini</t:surname></author><pubPlace>Paris</pubPlace><publisher>Imprimerie nationale, Ernest Leroux, éditeur</publisher><date>1898</date><biblScope unit="page">139-177</biblScope><note type="url">https://gallica.bnf.fr/ark:/12148/bpt6k65802736/f149.item.texteImage</note></bibl>
                    </listBibl>
                  </msItem>
                
                  <msItem xml:id="ms_i2">
                     <locus from="14v"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4050ZenaBul">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ወኢፍልጠተ፡ ለህላዌሁ፡ በእንተ፡ ዘተከሥተ፡ ለነ፡ እምዜናሁ፡ ለአብ፡ ክቡር፡ ወትሩፈ፡ ትጋህ፡ አባ፡ ቡላ፡ ዝውእቱ፡
                  አቢብ፡ መክብበ፡ ኵሉ፡ ሠናያት፡ ዘይትነበብ፡ አመ፡ ፳ወ፭፡ ለወርኀ፡ ጥቅምት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </title>
                     <textLang mainLang="gez"/>
                  
                     <msItem xml:id="ms_i2.1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT4050ZenaBul#Introduction">Zenāhu la-ʾab kǝbur wa-tǝrufa tǝgāh ʾabbā Bulā zǝ-wǝʾǝtu
          ʾAbib: Introduction</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                  
                     <msItem xml:id="ms_i2.2">
                        <title type="complete" ref="https://betamasaheft.eu/LIT4050ZenaBul#MainPart">Zenāhu la-ʾab kǝbur wa-tǝrufa tǝgāh ʾabbā Bulā zǝ-wǝʾǝtu
          ʾAbib: Main Part</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                      ወኮነ፡ በመዋዕለ፡ መክስምያኖስ፡ ንጉሠ፡ ሮም፡ ስደተ፡ ለአብያተ፡ ክርስቲያናት፤
                      ወምንዳቤ፡ ለእለ፡ የአምኑ፡ በእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፤ ወኮኑ፡ ፀረ፡ በእንተ፡ ሃይማኖት፡ ወፈነወ፡
                      ላዕሌሆሙ፡ መጽሐፈ፡ <sic resp="PRS10747Zotenbe">መጽሐፈ፡</sic>መልእክት፡
                      ውስተ፡ ኵሉ፡ አኅጉረ፡ መንግሥቱ፡ ከመ፡ ኵሉ፡ ዘአምነ፡
                      በክርስቶስ፡ ይብጻሕ፡ ኀበ፡ መኰንን፡
                    </incipit>
                     </msItem>
                  
                  </msItem>
                
                  <msItem xml:id="ms_i3">
                     <locus from="25r"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1450GadlaG">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ዝንቱ፡ ውእቱ፡ ዜናሁ፡ ወገድሉ፡ ወኂሩቱ፡ ለቅዱስ፡ ወብፁዕ፡ ብእሴ፡ እግዚአብሔር፡ ዘውእቱ፡ ገብረ፡ ክርስቶስ፡
                  ወልደ፡ ቴዎዶስዮስ፡ ንጉሠ፡ ቍስጥንጥንያ።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ወአቡሁኒ፡ ወእሙኒ፡ መፍቀርያነ፡ ምሕረት፤ ወቴዎዶስዮስኒ፡ መፍቀሬ፡ ነዳያን፡ ወምስኪናን፡
                  ውእቱ፤ ወይገብር፡ ብዙኀ፡ ምጽዋተ፡ ለነዳያን፡ ወለመስኪናን፡ ወለዕቤራት፡</incipit>
                  </msItem>
                
                  <msItem xml:id="ms_i4">
                     <locus from="39r"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1521GadlaY">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ንጽሕፍ፡ መጽሐፈ፡ ገድሉ፡ ለቅዱስ፡ ወብፁዕ፡ አባ፡ ዮሐኒ፡ እስመ፡ ውእቱ፡ ኮከብ፡ ብሩህ፡ ዘብሔረ፡ 
                  አግዓዚ፡ ወገባሬ፡ ተአምር፡ ዘደብረ፡ ዓሣ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ስምዑ፡ አኀውየ፡ ዜና፡ ገድሉ፡ ለብእሴ፡ እግዚአብሔር፡ ቅዱስ፡ ወብፁዕ፡ አባ፡ ዮሐኒ። ወሀሎ፡  
                ፩፡ ብእሲ፡ ሥዩመ፡ ተንቤን፡ እስመ፡ ዓቢይ፡ ወክቡር፡ ውእቱ፡ እምነ፡ ሥዩማን፡ ዘይእቲ፡ ሀገር፡
                  ወጽኑዕ፡ ፈድፋደ፡ እምነ፡ ኵሉ። ወሖረ፡ ውስተ፡ ጸብዕ፡ ምስለ፡ ብዙኅ፡ ጸባኢት፡ ኀበ፡ ብሔረ፡ ኖባ፡
                  ወሳባ፡ ወበጽሐ፡ በ፯፡ አውራኅ፡</incipit> 
                     
                  </msItem>
              
                  <msItem xml:id="ms_i5">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4051Homily">Dǝrsān za-bǝṣuʿ ʾabbā Minās ʾeṗis qoṗos za-ʾAkʷsum baʾǝnta
          bǝṣuʿ wa-qǝddus ʾabbā Yoḥanni</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                  ድርሳን፡ <choice>
                           <sic resp="PRS10747Zotenbe">ወብፁዕ፡</sic> 
                           <corr resp="PRS10747Zotenbe">ዘብፁዕ፡</corr>
                        </choice> አባ፡ ሚናስ፡ ኤጲስ፡ ቆጶስ፡ ዘአኵሱም፡ በእንተ፡ ብፁዕ፡ ወቅዱስ፡
                አባ፡ ዮሐኒ።</incipit>
                  </msItem>

            <div type="edition" xml:lang="gez"><note>From <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl></note>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">ሰላም፡ እብል፡ ለተዋሕዶ፡ ቅድስት፡ ሥላሴ፨</l>
                        <l n="2">ቀዊምየ፡ ቅድመ፡ ሥላሴ፨</l>
                        <l n="3">እንበለ፡ ናፍቆ፡ ኣአምን፡ ህላዌ፡ ሥላሴ፨</l>
                        <l n="4">ግጻዌሆሙ፡ ሥላሴ፡ ወአካሎሙ፡ ሥላሴ፨</l>
                        <l n="5">ወቅዳሴሆሙ፡ ከማሁ፡ ሥላሴ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ለዘአኀዝኩ፡ ወወጠንኩ፡ እንዘ፡ አስተናሥእ፡ ቃለ፨</l>
                        <l n="2">ጽሒፈ፡ አሐዱ፡ ጸሎት፡ እንተ፡ ይሰመይ፡ መድበለ፨</l>
                        <l n="3">አዘቅተ፡ ኂሩት፡ ሥላሴ፡ ትፈለፍሉ፡ ሣህለ፨</l>
                        <l n="4">አዕርጉኒ፡ ለገብርክሙ፡ ሰማየ፡ አእምሮ፡ ልዑለ፨</l>
                        <l n="5">ወጸሐፉ፡ በልብየ፡ ዘጥበብ፡ ፊደለ፨</l>
                    </lg>

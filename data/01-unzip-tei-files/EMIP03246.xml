               <msContents>
                  <summary>Book of Miracles:
                    Fifteen Miracles of Mary,
                    Four Miracles of Saint Mika’el,
                    Five Miracles of Jesus Christ,
                    Prayers, based on the order of the days of creation,
                    Six Miracles of Saint Mab`a Tsion,
                    Three Miracles of the Trinity</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="5r" to="33v" facs="005">Fols 5r–33v</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Fifteen Miracles of Mary</note>
                  <msItem xml:id="ms_i1.1"><locus from="5r" to="12r" facs="005">Fols 5r–12r</locus><title type="complete" ref="https://betamasaheft.eu/LIT6024IntroMM">Introductory text
                                                  and hymn to the Miracles of Mary</title></msItem>
                  <msItem xml:id="ms_i1.2"><locus from="12r" to="14v" facs="012">Fols 12r–14v</locus><title>Second, shorter Introduction to the Miracles of Mary, <foreign xml:lang="gez">ስምዑ፡ እነግረክሙ፡</foreign></title></msItem>
                  <msItem xml:id="ms_i1.3"><locus from="14v" to="17r" facs="015">Fols 14v–17r</locus><title>Three Prayers to Mary (these are uncommon)</title></msItem>
                  <msItem xml:id="ms_i1.4"><locus from="17r" to="18r" facs="017">Fols 17r–18r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3056RepCh336">Hymn to Our Lady
                                                  Mary</title></msItem>
                  <msItem xml:id="ms_i1.5"><locus from="18r" to="33v" facs="018">Fols 18r–33v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra
                                                  Māryām</title><note>Fifteen Miracles of Mary</note></msItem>
              </msItem>
                  <msItem xml:id="ms_i2"><locus from="34r" to="39v" facs="034">Fols 34r–39v</locus><title>Four Miracles of Saint Mika’el</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="40r" to="47r" facs="040">Fols 40r–47r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme">Taʾammǝra
                                                  ʾIyasus</title><note>Five Miracles of Jesus Christ</note></msItem>
                  <msItem xml:id="ms_i4"><locus from="47v" to="50r" facs="048">Fols 47v–50r</locus><title>Prayers, based on the order of the days of creation</title><note>arranged for the days of the week, Monday through Saturday-Sunday (these are uncommon)</note></msItem>
                  <msItem xml:id="ms_i5"><locus from="50v" to="60v" facs="051">Fols 50v–60v</locus><title>Six Miracles of Saint Mab`a Tsion</title></msItem>
                  <msItem xml:id="ms_i6"><locus from="61r" to="66r" facs="061">Fols 61r–66r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2388Taamme">Taʾammǝra
                                                  Śǝllāse</title><note>Three Miracles of the Trinity</note>

                  <colophon xml:id="coloph1">
                    <locus target="#67r" facs="067">Fol. 67r</locus>
                    This book belongs to Grazmač ተክለ፡ ሃይማኖት፡ ባይራዑ፡, who gave the book to the church (lit. tabot) of Madhane Alam መድኃኒ፡ ዓለም፡ አድሰሚዒት፡
                    (the precise meaning of the third word is not clear).  His and his wife’s baptismal names are given, ወልደ፡ ሥላሴ፡, and ዓመተ፡ ሥላሴ፡
                  </colophon>
                </msItem>
               </msContents>

               <history>
                  <origin>
                     <origPlace>
                        <placeName ref="https://betamasaheft.eu/INS0099DMA">ʾAḥzarā Māryām</placeName>
                     </origPlace>
                     <origDate notBefore="1950" notAfter="2000">Second half of the 20th
                        cent.</origDate>
                  </origin>
                  <provenance>The owner Walatta Mikāʾel is mentioned in supplication
                     formulas throughout the Ms. (e.g., <locus target="#3rb">3rb-</locus>va, 16vb,
                     45rb, 45ra, 47va, 48va, 53ra, 54va, 55vb, 58va). Also other names, most
                     probably her family members, are mentioned in supplication formulas: Walatta
                     Tǝnsāʾe (<locus target="#37rb">37rb</locus>, 51rb, 53ra, 58va), Gabra Madḫǝn
                     (<locus target="#41va">41va</locus>), Walatta Muse (<locus target="#41va">41va</locus>, 50rb, 60rb), Ḫāyla Śǝllāse (<locus target="#50ra">50ra</locus>, 60rb), Tasfā Śǝllāse (<locus target="#50rb">50rb</locus>,
                     57vb, 60rb), Nǝgǝśtä Māryām (<locus target="#51rb">51rb</locus>, 55rb), Bǝḍā
                     Giyorgis (<locus target="#54va">54va</locus>).</provenance>
               </history>

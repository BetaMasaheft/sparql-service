                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1_1567">
                           <locus target="#47r">-47r</locus>
                           <q xml:lang="ar">تم الكتاب الخلاصة النقية بعون الله ومنه وكرمه منقولا من خط من نقله من خط المؤلف</q>
                           <desc>Colophon</desc>
                           <note/>
                        </item>
                        <item xml:id="a2_1567">
                           <locus target="#Throughout all the text">-Throughout all the text</locus>
                           <q xml:lang="ar">قوله الروز باري بضم الراء واسكان الواو وفتح المعجمة نسبة الى روزبار موضع عند طوس وقيل من قرب بغداد ه شرح رسالة القشيرية</q>
                           <desc>Marginalia</desc>
                           <note>Notes in the margins marked "Ḥ", "al-Risāla al-Qušayriyya", "Taqrīr al-mu’allif", "Ḥāšiyat al-muṣannaf".</note>
                           <note>
                              <p>
                                 Mentioned
                              : <persName ref="https://betamasaheft.eu/PRS0304IHA">الاني٬ جمال الدين محمد ابو عبد الصمد</persName>
                              </p>
                              <p>
                                 Mentioned
                              : <persName ref="https://betamasaheft.eu/PRS0304IHA">الاني٬ جمال الدين محمد ابو عبد الصمد</persName>
                              </p>
                              <desc>
                                 Quotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT1214IHA">رسالة القشيرية</ref>
                              </desc>
                              <desc>

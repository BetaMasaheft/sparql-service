               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1v">1r-1v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1966IHA">نظم بنور نبينا من كل الضلالة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>حمد [الكر] ربنا على ما انقذتنا| بنور نبينا من كل الضلالة| ايضا فلك الشتا على ما خصصتنا| </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1v">-1v</locus>اياممسك العنبر يا صاحب الكوثر| يا نور المنور جمال الكلية| سلم يا رب الرحيم من الشيطان الرجيم| انت الجواد الكريم وكل المعركة| فيا رب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="2v">2r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1967IHA">نظم صلاة الله الصمد على السيد محمد دائما</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>صلاة الله الصمد على السيد محمد دائما على الابد مع جميع الأل| السلاك الرحمن على محمد امان عالد الرب المنان فى جميع الاحوال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>عابد الرحمن جامع الاحسان منتهى ولاية الله ؤاقي الدرجات ميزاب الهبات وسوق أولياء لله| يا رب الما رباب احسن المأب لمادح سول الله نسئل السلام حسن الاحتتام لجميع عباد الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2v" to="3r">2v-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1968IHA">نظم بسم الله الرحمان توسلنا بالمنان</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم
بسم الله الرحمان توسلنا بالمنان| وبذات المقدس| وبمكنونه الأنفسا |وبمظهر الأعظم| وبتجلية الأكرم م</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>مصابح ميدان القلب جالب اشرار الغيب وليس له نطير هو نقاد خبير| سيدى قطب الجلال مربي كل الرجال ليدى غوث الفرداني مدير كاس الصمداني</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="3v" to="3v">3v-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT1963IHA">نظم سيد شمس الكمال</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>سيد شمس الكمال ه شراب سر الوصال ه
وهو الجالس على ه كرسي عز كمالا ه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>وبسر لا هوتك ه بفيض جبروتك ه 
وبعزتك الباهره وبقدرتك القاهر ه</explicit>
                     <note/>
                     <note/>
                  </msItem>

                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">fine, careful, well-trained</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>15th cent.</date>
                        <seg type="rubrication">A few lines are rubricated (one red line alternating
                           with a black one) on the incipit page of each Gospel; “tituli” written in
                           the upper margin; Ethiopic numerals of the “tituli”; elements of the
                           punctuation signs; crux ansata.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#14r">14r</locus> (incipit page of the Gospel of Luke):
                        frontispiece elaborate coloured (red, green, yellow) ornamental bands with
                        two vertical extensions; interlaces, crosses, geometric motifs.</decoNote>
                     <decoNote type="frame" xml:id="d2">
                        <locus target="#82r">82r</locus> (incipit page of the Gospel of Mark):
                        frontispiece elaborate coloured (red, green, yellow) ornamental bands with
                        three vertical extensions; interlaces, crosses, geometric motifs.</decoNote>
                     <decoNote type="frame" xml:id="d3">
                        <locus target="#127r">127r</locus> (Incipit page of the Gospel of John):
                        frontispiece elaborate coloured (red, green, yellow) ornamental bands with
                        three vertical extensions; interlaces, crosses, geometric motifs.</decoNote>

                        <item xml:id="a3">
                           <desc type="CommemorativeNote"/>
                           <locus from="107r" to="107v"/>
                           <q xml:lang="gez">ኦእግዚኦ፡ አዕረፍ፡ ነፍሳተ፡ አበዊነ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
                           </q>
                           <q xml:lang="en">Oh Lord, let the souls of our fathers rest in peace ... </q>
                        </item>

                        <item xml:id="a4">
                          <locus from="108r" to="116v"/>
                           <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT2722RepCh6">Malkǝʾa śǝqāyu la-Giyorgis</title></desc>
                           <q xml:lang="gez"><lb n="1"/>መልክዓ፡ ሥቃይ፡ ስኡላነ፡ መጽሔት፡ ሥጋከ፡ አርአየ፡
                      <lb n="2"/> እምአመ፡ ትቤ፡ ላዕለከ፡ እስከ፡ ፈጸምከ፡ ሥቃየ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
                           </q>
                           <note>In this manuscript the hymn encompasses 43 strophes.</note>
                        </item>

                        <item xml:id="a5">
                           <locus from="116r" to="117v"/>

                        <item xml:id="a7">
                           <locus target="#121r"/>
                           <desc type="GuestText">
                           <title type="complete" ref="https://betamasaheft.eu/LIT5780Orationes12">Protective ʾasmāt-prayer</title></desc>
                           <q xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡ በጢት፡ ስመከ፡
                      በጥጥያብ፡ ስምከ፡ በቆፍ፡ ስምከ፡ በቀያፋ፡ ስምከ፡ በሰይፍ፡ ስምከ፡ በስስያብ፡ ስምከ፡ ዘአብራህከ፡
                      ዓይኖ፡ ለጢሜዎስ፡ ወልደ፡ በርጢሜዎስ፡ ዕውር፡ ከማሁ፡ አብራህ፡ አይኖ፡ ለገብርከ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
                      ያሸላል፡ ያሸላትያል፡ ዘበቃልከ፡ ወበዘስምከ፡ ድማኅ፡ አደኅኖ፡ ለገብርከ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
                           እግዚአብሔር፡ ብርሃን፡ በእንተ፡ ማእሰሩ፡ ለሰይጣን፡ ዘስሙ፡ አስማተ፡ ኃያላን፡ ሰፒራ፡</q>
                           <bibl corresp="http://zotero.org/groups/358366/items/KTXCR9DD"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Turaev1899Orationes"/><title level="a">Ėḟiopskija orationes falsae i exorcismi</title><title level="m">Recueil des travaux rédigés en mémoire du jubilé scientifique de Daniel Chwolson</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Boris</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Turaev</t:surname></author><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">David</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Günzburg</t:surname></editor><pubPlace>Berlin</pubPlace><publisher>S. Calvary &amp; Co.</publisher><date>1899</date><biblScope unit="page">242-267</biblScope><note type="url">http://sammlungen.ub.uni-frankfurt.de/freimann/content/pageview/806397</note><citedRange unit="page">249-250</citedRange></bibl>
                             <bibl corresp="http://zotero.org/groups/358366/items/KTXCR9DD"><seg type="bookSection"><!-- attributes from original bibl--></seg><ptr target="bm:Turaev1899Orationes"/><title level="a">Ėḟiopskija orationes falsae i exorcismi</title><title level="m">Recueil des travaux rédigés en mémoire du jubilé scientifique de Daniel Chwolson</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Boris</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Turaev</t:surname></author><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">David</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Günzburg</t:surname></editor><pubPlace>Berlin</pubPlace><publisher>S. Calvary &amp; Co.</publisher><date>1899</date><biblScope unit="page">242-267</biblScope><note type="url">http://sammlungen.ub.uni-frankfurt.de/freimann/content/pageview/806397</note><citedRange unit="number">12</citedRange></bibl>
                           </item>


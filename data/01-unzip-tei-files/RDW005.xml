                     <textLang mainLang="gez"/>
                     <note>See the transcription of the text in <ref target="#text4"/>.</note>
                </msItem>

                  <msItem xml:id="ms_i5">
                     <locus from="1r114" to="1r132">Fols 1r114–1r132</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6477PPAynaTela">Ṣalot baʾǝnta ʾayna ṭǝlā wa-gǝrmā mogas wa-madfǝna ḍar</title>
                     <textLang mainLang="gez"/>
                     <note>See the transcription of the text in <ref target="#text5"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i6">
                     <locus from="1r133" to="1r169">Fols 1r133–1r169</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6478PPMasaraAganent">Ṣalot baʾǝnta māʿśara ʾagānǝnt za-qurṭǝmāta wa-wǝgāta wa-hod qurṣat wa-tasawāšo</title>
                     <textLang mainLang="gez"/>
                     <note>See the transcription of the incipit and explicit in <ref target="#text6"/>.</note>   </msItem>

                  <msItem xml:id="ms_i7">
                     <locus from="1r170" to="1r189">Fols 1r170–1r189</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6479PPNames">Protective text containing the secret names of God</title>
                     <textLang mainLang="gez"/>
                     <note>See the transcription of the text in <ref target="#text7"/>.</note>
                      </msItem>
               </msContents>



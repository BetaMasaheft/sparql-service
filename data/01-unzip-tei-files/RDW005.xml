                      <handDesc>
                        <handNote xml:id="h1" script="Ethiopic">
                            <date notBefore="1800"/>
                           <desc>Mediocre hand, irregular.</desc>
                           <seg type="ink">Black, pinkish red.</seg>
                           <seg type="script">Modern bulky script.</seg>
                           <seg type="rubrication">Beginnings of texts, the name of the owner.</seg>
                        </handNote>
                     </handDesc>

                  <decoDesc>
                     <decoNote xml:id="d1" type="drawing" corresp="#pic1">
                        <desc>Bichrome drawing of a human figure beneath a geometrical design.</desc>
                        <dimensions unit="mm">
                           <height>173</height>
                           <width>44</width>
                        </dimensions>
                     </decoNote>

                     <decoNote xml:id="d2" type="drawing" corresp="#pic2">
                        <desc>Monochrome drawing of a magic square, possibly a <ref type="authFile" corresp="https://betamasaheft.eu/AT1144SealSol">Seal of Solomon</ref>, but without face.</desc>
                        <dimensions>
                           <height>75</height>
                           <width>46</width>
                        </dimensions>
                     </decoNote>
                  </decoDesc>

                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc>The name of the owner, <persName ref="https://betamasaheft.eu/PRS13448Gwaggul">Gʷāggul </persName>, is written clumsily in spaces originally left blank for this purpose.</desc>
                        </item>
                     </list>
                  </additions>

                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1" type="SlipCase">The scroll is kept in a cylindrical case probably made of reptile skin.</decoNote>
                     </binding>
                  </bindingDesc>

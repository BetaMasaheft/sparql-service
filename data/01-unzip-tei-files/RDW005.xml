                  <msItem xml:id="ms_i1">
                     <locus from="1r1" to="1r41">Fols 1r1–1r41</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6473PPAynaTela">Ṣalota ʾayna ṭǝlā wa-ʾayna warq wa-ʾayna wagi wa-ʾayna śǝrāy</title>

                     <textLang mainLang="gez"/>
                     <note>See the transcription of the text in <ref target="#text3"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="1r87" to="1r113">Fols 1r87–1r113</locus>

                     <locus from="1r42" to="1r63">Fols 1r42–1r63</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6474PPAynaTela">Ṣalot baʾǝnta ḥǝmāma ʾayna ṭǝlā wa-ʾayna warq wa-ʾayna ʾagānǝnt wa-lǝsāna budā wa-qumaññā wa-mǝrtaññā wa-ʾayna ʾagānǝnt wa-ḥəmāma fǝṭrat</title>
                     <textLang mainLang="gez"/>
                     <note>See the transcription of the text in <ref target="#text2"/>.</note>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="1r64" to="1r86">Fols 1r64–1r86</locus>

                        <additions>
                            <list>   
                                <item xml:id="a1">
                                    <locus from="2r"/>
                                    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of 
                                        <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                    <q xml:lang="gez">ሐዲሳት፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ <supplied reason="undefined" resp="PRS10171Wright">ዓለም።</supplied>
                              </placeName>
                           </q>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus from="44v"/>
                                    <desc type="Unclear">Hymn added by a later hand.</desc>
                                    <q xml:lang="gez">ወንጌላውያን፡ ናቂርብ፡ አምኃ፡ ሰላም፡ ወፍቅር። ለዝክረ፡ ስምከ፡ ዘልፈ፡ ክሉለ፡ ረድኤት፡ ወክብር። መዝገበ፡ ሥላሴ፡
                                        ሐሊብ፡ መገበ፡ ሥላሴ፡ መዓር። እስመ፡ አንተ፡ ውስተ፡ ማኅደሩ፡ አርአያ፡ እፀ፡ ዘይት፡ ሥሙር። ለንቡር፡ መልዕልተ፡ ኵሉ፡ በእሳት፡ መንበር።</q>
                                </item>
                                
                                <item xml:id="a3">
                                    <locus from="45r"/>
                                    <desc type="Unclear">Hymn added by a later hand.</desc>
                                    <q xml:lang="gez">ምሥጢረ፡ ሃይማኖት፡ ኅበአ፡ በፆታ፡ ነጊር፡ ወጠይቆ። ሰብሖትከ፡ <gap reason="lost"/>ኩ<gap reason="lost"/>ትከ፡
                                         አምላከ፡ እስመ፡ ለሰይጣን፡ አውደቆ።</q>
                                </item>
                            </list>
                        </additions>

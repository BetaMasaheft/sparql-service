      <t:body>
         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ናዖድ፡ ሞገሳ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Nāʿod Mogasā</t:persName>
               
               <t:persName>
                  <t:roleName type="title">ʾǝtege</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">empress</t:occupation>
             
               <t:floruit notBefore="1494" notAfter="1524"> She was a wife of 
                  <t:persName ref="https://betamasaheft.eu/PRS7481NaodA">
                     <t:roleName type="title">ʾaṣe</t:roleName>  Nāʿod</t:persName> and a mother of
               
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe"> 
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>. 
                  <t:persName ref="https://betamasaheft.eu/PRS7482NaodMo">Nāʿod Mogasā</t:persName>
                  was a member of the regency council of her son 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName> 
                  along with <t:persName ref="https://betamasaheft.eu/PRS3706eleni">ʾƎleni</t:persName>.  
                  She is credited with the foundation of at least three royal churches: 
                  <t:placeName ref="https://betamasaheft.eu/LOC3444Getese">Getesemane Māryām</t:placeName>
                  in <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName>, the church of <t:placeName ref="https://betamasaheft.eu/LOC1701Badeqe">Bādǝqe</t:placeName>, 
                  near the royal residence situated in <t:placeName ref="https://betamasaheft.eu/LOC3061Fataga">Faṭagār</t:placeName>,
                  which was destroyed by the armies of <t:persName ref="https://betamasaheft.eu/PRS1500Ahmad">ʾAḥmad</t:persName>
                  and the church of <t:placeName ref="https://betamasaheft.eu/LOC1901BetaSa">Beta Samāyāt</t:placeName> in <t:placeName ref="https://betamasaheft.eu/LOC6568Amhara">ʾAmharā</t:placeName>, where she was buried. </t:floruit>
               
               <t:death notAfter="1524"/>
            </t:person>
            
         </t:listPerson>

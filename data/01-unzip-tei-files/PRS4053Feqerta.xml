         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="monastic">ፍቅርተ፡ ክርስቶስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Fǝqǝrta Krǝstos</t:persName>

               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ማርያም፡ ጸዳላ፡</t:persName>

               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Māryām Ṣadālā</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="birth">ሙዚት፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">Muzit</t:persName>
               <t:persName xml:lang="gez" xml:id="n4" type="birth">ምእዝት፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n4" type="normalized">Mǝʾǝzt</t:persName>
               
               <t:persName xml:lang="gez" xml:id="n5" type="nick">እመሙዝ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n5" type="normalized">ʾƎmmamuz</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾƎmmat</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                 
               <t:floruit notBefore="1600" notAfter="1700">She was a 17th century holy nun. She was born from a noble family from her father 
                  <t:persName ref="https://betamasaheft.eu/PRS6121Laba">Lābā</t:persName> and from her mother <t:persName ref="https://betamasaheft.eu/PRS10035Wangela">Wangelāwit</t:persName>. 
                  It is believed that she was the founder of the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2854Emmame">ʾƎmmamǝʾuz</t:placeName> in 
                  <t:placeName ref="https://betamasaheft.eu/LOC4549Maqet">Maqet</t:placeName> 
                  <t:placeName ref="https://betamasaheft.eu/LOC6185Wallo">Wallo</t:placeName>.</t:floruit>
               
               </t:person>  
               
         </t:listPerson>
         

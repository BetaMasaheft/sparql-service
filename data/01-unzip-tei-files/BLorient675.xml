                        <handDesc>
                            <handNote script="Ethiopic" xml:id="h1">
                                <date notBefore="1700" notAfter="1749"/>
                                <desc>Written in a fine hand by <persName role="scribe" ref="https://betamasaheft.eu/PRS13718SaggaZ">Ṣaggā Zaʾab</persName> (e.g. <locus target="#222rc"/>).</desc>
                            </handNote>
                        </handDesc>   
                        
                        <additions>
                            <list>
                                <item xml:id="e1">
                                    <desc>Mentioned in the supplications throughout are <persName ref="https://betamasaheft.eu/PRS13719MezaraK">Mǝʿzāra Krǝstos</persName>, 
                                        his daughters <persName ref="https://betamasaheft.eu/PRS13720LahyaD">Lāhya Dǝngǝl</persName>, <persName ref="https://betamasaheft.eu/PRS13721LebestaK">Lǝbǝsta Krǝstos</persName>, and 
                                        his son <persName ref="https://betamasaheft.eu/PRS13722TaklaH">Takla Hāymānot</persName> (e.g. <locus target="#69vb #108va"/>). The names of the daughters have been added later
                                        between the lines.
                                        All names have often been erased. The colophon indicates that a woman sponsored the production of the manuscript
                                    and donated it to a church. Her name has been erased, but it might be speculated that she was a family member
                                    of the persons mentioned throughout - possibly <persName ref="https://betamasaheft.eu/PRS13720LahyaD">Lāhya Dǝngǝl</persName>, as the last two characters of her name
                                    seem to have been <foreign xml:lang="gez">ግል</foreign>.</desc>
                                </item>
                                
                                <item xml:id="e2">
                                    <locus target="#1r"/>
                                    <desc>Modern stamp.</desc>
                                    <q xml:lang="en">Presented by the Secretary of State for India. <date when="1868">Aug. 1868</date></q>
                                </item>
                            </list>
                            
                        </additions>
                        
                        <bindingDesc>
                            <binding contemporary="false" xml:id="binding">
                                <decoNote xml:id="b1" type="Boards">Two wooden boards. Both inner boards are darkened around the edges, 
                                    possibly showing traces of a former cover.</decoNote> 
                                <decoNote xml:id="b2" type="Cover">Blind-tooled leather <term key="quarterCover" ana="#quarterCover">quarter cover</term>
                                    (with the gilded title and shelfmark on the spine).</decoNote> 
                                <decoNote xml:id="b3" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                </decoNote>
                                <decoNote xml:id="b4" type="SewingStations">4</decoNote> 
                                <decoNote xml:id="b5" type="SewingStations">Sewing stations are used in an irregular way.</decoNote> 
                                <decoNote xml:id="b6">The manuscript has been rebound in the library. Possibly both wooden boards have been replaced, 
                                    and a blind-tooled quarter cover added.</decoNote>
                            </binding>
                        </bindingDesc>
                        
                    </physDesc>
                    
                    <history>
                        <origin>
                            <origDate notBefore="1700" notAfter="1749" evidence="lettering"/>
                        </origin>
                        <provenance>The manuscript does not contain an ownership note from  <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>, but as
                            it was part of the collection of looted manuscripts brought to Britain by 
                            the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> 
                            expedition in <date>1868</date>, had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area, 
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. 
                        </provenance>
                    </history>
                    

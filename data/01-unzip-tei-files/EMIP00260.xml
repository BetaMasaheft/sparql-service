               <msContents>
                  <summary>Säwasǝw, ሰዋስወ፡ ግእዝ፡, Book of Tobit, Exerpts from Genesis 1-4 and Miscellaneous</summary>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="6r" facs="005"/>
                    <title>Amharic Explanation of the Chants of the Church by Yared</title>
                    <textLang mainLang="am">Amharic</textLang>
                    <incipit xml:lang="am">በስመ አብ ወወልድ… እጽሕፍ ነገረ ስለምን ዘተረክበ እምአቡነ ያሬድ ቁመት በስብከት ተጀመረ ይላሉ ሲጀመር ምን ብሎ ነው ቢሉ ሐነፀ መቅደሶ ብሎ ጀመረ ይላሉ…</incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="6v" to="12r" facs="011"/>
                    <title>Amharic Explanation about the Dǝggwa</title>
                    <textLang mainLang="am">Amharic</textLang>
                    <incipit xml:lang="am">በስመ አብ ወወልድ… እጽሕፍ ነገረ ድጓ አርዕስተ ድጓ ፳፪ ናቸው ምን ምን ቢሉ ዋዜማ በ፭እግ ነግ ይትባረክ ፫ ሰላም ምዝሙር ዘአምላኪየ ሚበዝኁ…</incipit>
                  </msItem>

                  <msItem xml:id="ms_i3">
                    <locus from="12v" to="14r" facs="017"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1546Genesi">Genesis 1, with marginal mnemonics referring to the Andemta</title>

                  </msItem>
                    <msItem xml:id="ms_i4">
                      <locus from="14r" to="17r" facs="018"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Gǝ‘ǝz Grammar from Gonǧ, in Amharic</title>
                      <textLang mainLang="am">Amharic</textLang>
                      <incipit xml:lang="am">ጽሒፈ ሰዋስው ዘመምሕራነ ጎንጅ እንተ ይእቲ ብሔረ ጥበብ ወአእምሮ። ሰዋስው ማለት መሰላል መሸጋገሪያ ማለት ነው<gap reason="omitted"/></incipit>
                    </msItem>

                    <msItem xml:id="ms_i5">
                      <locus from="17v" facs="022"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Prayer for help in learning</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>

                    <msItem xml:id="ms_i6">
                      <locus from="18r" to="55r" facs="022"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Sawāsǝw (general record)</title><note>mainly about the general rules of grammar</note>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <incipit xml:lang="gez">ናሁ ተወጥነ ነገረ ዓቢይ አገባብ በሰላመ እግዚአብሔር አሜን። ። ። እስመ አምጣነ አኮኑ ወ ስ ና ይሆናሉ እስመ አምጣነ አኮኑ በቀዳማይ በካልዓይ አንቅጽ በዘማች በነባር ይገባሉ<gap reason="omitted"/></incipit>
                    </msItem>

                    <msItem xml:id="ms_i7">
                      <locus from="56r" to="96v" facs="060"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Sawāsǝw (general record)</title><note>mainly about verb conjugation</note>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <incipit xml:lang="gez">ንዌጥን በረድኤተ እግዚአብሔር ነገረ ግሥ ሎሀ ጻፈ ለውህ ጥሬ ዘር ላህልሐ ላላ ይላሐልሕ ልህሎህ ውስጠዝ። ለስሐ አልጫ ሆነ ልስሐት ሳቢ ዘር።<gap reason="omitted"/></incipit>
                    </msItem>

                    <msItem xml:id="ms_i8">
                      <locus from="97r" to="100r" facs="099"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT1546Genesi">Genesis Chs 2-4 with marginal mnemonics referring to the Andemta</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>

                    <msItem xml:id="ms_i9">
                      <locus from="100v" to="109v" facs="105"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2473TobitB">Tobit, Book of</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>

                    <msItem xml:id="ms_i10">
                      <locus from="109v" to="110v" facs="114"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT1367Exodus">Exodus</title>
                      <note>The Ten Commandments from Exodus 19</note>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>

                    <msItem xml:id="ms_i11">
                      <locus from="110v" to="111r" facs="115"/>
                      <title>Commentary on the Commandment of the Observance of Sabbath, <foreign xml:lang="gez">ትእዛዘ ሰንበታት</foreign></title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>

                    <msItem xml:id="ms_i12">
                      <locus from="111r" to="114r" facs="115"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Grammar, mainly on the construction of phrases</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
               </msContents>

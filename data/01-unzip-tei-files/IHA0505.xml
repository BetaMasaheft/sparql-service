               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="4v">1r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0489IHA">دعاء الاستمطار لرحمة العزيز</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>...انت الكريم انت الرحيم بلامر نحن الضيوف فلا تمنعنا من ال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>وجعل لنا معه يوم الحشر قى البيضا / لتضحك الفقر وتبك الكفر</explicit>
                     <note>Black and white xerox copy of a manuscript, in two bent folios, written only on one side.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="24v">5r-24v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0988IHA">تخميس توسل السماني</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus>وبرجال العلم والنساك
[...]
بالعرش والفرش وبالأفلاك / بالعالم الأسنى وبالأملاك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>ونجنا سيدي من كل جائحة / ومن ثمانية ومن سبعين ذرا</explicit>
                     <note>Text is a photocopy of a manuscript on A4 paper; only one side of the folios is written; each folio is bent and not binded to the others; pages are numberes in the original; some words missing from the photocopy have been added in blue ballpoint;</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="86v" to="91r">86v-91r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0995IHA#s146IHA">جالية الكدر بذكر أهل بدروشهداء أحد السادة الغرر,
                    Asmā' Šuhadā' Uḥud</title>
                     <incipit xml:lang="ar">
                        <locus target="#86v">-86v</locus>وبشاهدى أحد سألتك كلهم / من بالشهادة نار ثم بمن حضر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#91r">-91r</locus>والأل والصحب الضراغم فى الوغى / صيد المأثر والمشاهد والظفر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="91r" to="93v">91r-93v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0997IHA">دعاء توسل أهل بدر</title>
                     <incipit xml:lang="ar">
                        <locus target="#91r">-91r</locus>امدوني بنفحة وأسعدونى بلمحة وأعيونى بقوة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#93v">-93v</locus>فهم الأوائل والأواخر بعضهم / سبقت لهم كل العناية فى الازل</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="93v" to="94r">93v-94r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0999IHA">دعاء التعلق باستار الكعبة</title>
                     <incipit xml:lang="ar">
                        <locus target="#93v">-93v</locus>وبعد التوسل بهؤلاء السادات تدعو بهذه الدعوات
الا يا ايها المأمول فى كل حاجة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#94r">-94r</locus>وصلى الله على سيدنا محمد وعلى أله وصحبه وسلم 
تمت منظومة أهل بدر ويليها الاستغاثة باسمائه [كذا] شهداء أحد رضى الله عنهم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="94r" to="95v">94r-95v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3041IHA#s523IHA">جبر الكسر في نظم اهل بدر, al-Istiġāṯa bi-asmā'
                    šuhadā' Uḥud al-aʻlām</title>
                     <incipit xml:lang="ar">
                        <locus target="#94r">-94r</locus>الاستغاثة بأسماء شهداء أحد الأغلام 
فباهل بدر قد سألتك أولا / والأن بشهداء فى أحد الغرر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#95v">-95v</locus>بأن السفيان كذاك أبو هبي / ...رة نجنا يا غوثنا من كل شر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="96r" to="97r">96r-97r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0107IHA">نظم بسم الحي الباقي نبتدئ</title>
                     <incipit xml:lang="ar">
                        <locus target="#96r">-96r</locus>بسم الله الرحمن الرحيم باسم الحي الباقي نبتدى وبثنائه نهتدى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#97r">-97r</locus>أنوار الأكمفى ذالك المشهدل الممدد الأرباب السير تجدد / حتى غاب بهم </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="97r" to="103r">97r-103r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0124IHA">نظم قمر عزّ قد بدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#97r">-97r</locus>صلى الله على محمد صلى الله عليه وسلم
قمر عز قد بد / حائز سابع لنعم [كذا]</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#103r">-103r</locus>ما لاح برق في العناية / ودارت كؤس الكرام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="103r" to="106r">103r-106r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1001IHA">دعاء بدأت ببسم الله واثني بحمد الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#103r">-103r</locus>أغثنا يا زين العالم ٢ يا رسول الله
بدأت ببسم الله وأثنى بحمد الله \ وازكى صلاة الله وأنمى السلام الله \ على خير خلق الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#106r">-106r</locus>الوصال من أهل شهود الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="106r" to="108r">106r-108r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1002IHA">نظم جيرة حي من قدم</title>
                     <incipit xml:lang="ar">
                        <locus target="#106r">-106r</locus>مرحابا يا زين العالم 2 صلى الله عليك
أيها الهادى المقدم
ان جزت يوما باضم
 جيرة حي من حي عن ملتاج قدم من عرب النقا العالم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#108r">-108r</locus>والآل والصحب ما لا / ح برق الحمى والعلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="108r" to="108v">108r-108v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1004IHA">دعاء ما ترى ممرض درى بسقامي</title>
                     <incipit xml:lang="ar">
                        <locus target="#108r">-108r</locus>رب هبنا علما وفتحا قريبا 2 وجميع المنا وحسن الختام
يا ترى ممرض درى بسقامي 
وانتحالى وذلتى وغرام 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#108v">-108v</locus>لمصر ولا لبغداد معنى مثل فاس الكثيرة الاكرام...</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="111r" to="113v">111r-113v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <incipit xml:lang="ar">
                        <locus target="#111r">-111r</locus>زلال ءرباب [كذا] الوادى 
ميزاب سيل الأمداد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#113v">-113v</locus>والأولياء الكملا دائما جزءا وكلا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="27r" to="27v">27r-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0991IHA">توسل بالتجاني</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>الى حضرة نبينا وشفيعنا وحبيبنا وقرة أعييننا وثمرة فؤادنا سيدنا ومولانا محم؟ عليه أفضل الصلاة وأزكى السلام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>...والمسلمات الاحياء منهم والأموات الفاتحة  ثم الفاتح ثم سبحان ربك الخ ويدعو قبل الفاتح بعد</explicit>
                     <note>Single loose folio;</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i20">
                     <locus from="113v" to="114r">113v-114r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1003IHA">وصية أحمد خادم النبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#113v">-113v</locus>بسم الله الرحمن الرحيم [...] وبعد فهذه

 وصىة من المدينة المنورة عن الشيخ أحمد خادم النبي الشريف قال كنت ساهر ليلة الجمعة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#114r">-114r</locus>ينجى من عذاب النار ومن كذب بها كفرو صلى الله على سيدنا محمد انبي [كذا] الأمى وعلى آله وصحبه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i21">
                     <locus from="114v" to="116v">114v-116v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0512IHA">مزدوجة الحسنى في الاستغاثة بأسماء الله الحسنى</title>
                     <incipit xml:lang="ar">
                        <locus target="#114v">-114v</locus>بسم الله الرحمن الرحيم 
بإسم الأله وبه لدينا / ولو عبدنا غيره شقينا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#116v">-116v</locus>انا دعوناك استجب امينا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i22">
                     <locus from="116v" to="116v">116v-116v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT2927IHA">نظم بسم الأله أبتدئ دعائى</title>
                     <incipit xml:lang="ar">
                        <locus target="#116v">-116v</locus>ويا قيوم اقض...ئج وما نرو
باسم الأله [كذا] أبتدى دعائى ومهربى اليه والتجائى...</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#116v">-116v</locus>والآل والصحب والكرام ما ددعا داع بلقلب ذى اضطرار ولسعى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="28r" to="33r">28r-33r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous lacunous" ref="https://betamasaheft.eu/LIT0992IHA">عنوان مطالع الجمال في مولد إنسان الكمال</title>
                     <incipit xml:lang="ar">
                        <locus target="#28r">-28r</locus>برضاعه وكفالته الأشخاص الأنسية </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33r">-33r</locus>وأتحفنا بخصائص القبول والمعية سبحان ربك رب العزة عما يصفون [...] والحمد لله رب العالمين</explicit>
                     <note>Different lacunas and order of pages disrupted;</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="33v" to="33v">33v-33v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT2946IHA">نظم بسم الذي انشا الاشياء من عدم</title>
                     <incipit xml:lang="ar">
                        <locus target="#33v">-33v</locus>باسم الذى أنشأ من عدم / الواحد القادر المريد ذى القدم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33v">-33v</locus>ودمعه هاملا للوجد ذا سخم...</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="34r" to="52v">34r-52v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#34r">-34r</locus>ما بال قلبك لاينفك ذا ألم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#52v">-52v</locus>أمين أمين الأرض بواحدة / حتى أكملها ألفى ألوفتى [كذا]</explicit>
                     <note>The last 13 verses at f. 51r are slightly different from other versions of the taḫmīs.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="53r" to="71r">53r-71r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0543IHA">قصيدة الهمزية في مدح خير البرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#53r">-53r</locus>كيف ترقى رقيك الأنبياء / يا سماء ما طاولتها سماء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#71r">-71r</locus>ما قام [كذا] الصلاة من عبد الله / وقامت بربها الأسياء</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="71v" to="76v">71v-76v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#71v">-71v</locus>باب في شهوره وعلامته وولادته ورضاعه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#76v">-76v</locus>وتعليما يبلغن عندك الكبر أحدهما أو كلاهما فلا تقل لهما أف ولا تنهرهما وقل لهما قملا كريما</explicit>
                     <note>The manuscripts reports only part of the Bāb fī Šuhūrihi wa ʻalāmatihi wa wilādatihi wa riḍāʻihi</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="77r" to="85r">77r-85r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0995IHA#s145IHA">جالية الكدر بذكر أهل بدروشهداء أحد السادة الغرر,
                    Ḏikr Ahl Badr</title>
                     <incipit xml:lang="ar">
                        <locus target="#77r">-77r</locus>بسم الله الرحمن الرحيم بدرية وافت [كذا] ببرهان بهر / أحدية فى سردها سر ظهر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#85r">-85r</locus>وكذالك بالاملاك من قد أحضروا / بدرا لنصر المصطفى هادى البشر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="85r" to="86v">85r-86v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0996IHA">دعاء أهل بدر</title>
                     <incipit xml:lang="ar">
                        <locus target="#85r">-85r</locus>اللهم بحرمة السادات الكرام أن تجعلنى فى حماك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#86v">-86v</locus>الأحديين رضون الله عليهم أجمعين فى كل وقت وحين</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

                    <msContents>
                      <msItem xml:id="ms_i1">
                        <locus from="1ra" to="80rb"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT2461Testam">Testamentum Domini</title>
                         <textLang mainLang="gez"/>
                         <incipit xml:lang="gez"><hi rend="rubric">ኪዳን፡ ዘእግዚእነ፡</hi>
                         ወመድኃኒነ፡ ኢየሱ<hi rend="rubric">ስ፡ ክርስቶስ፡ ወ</hi>ኮነ፡ እንከ፡ እምድ<hi rend="rubric">ኅረ፡ ተንሥኣ፡ እግ</hi>ዚእነ፡
                         ኢየሱስ፡ ክርስቶስ፡ እምነ፡ ምዉታን፡ አስተርአየነ፡ ወተገሠ፡ እምቶማስ፡
                         ወማቴዎስ፡ ወዮሐንስ፡ ወተፈዊሰነ፡ ከመ፡ <cb n="b"/><supplied reason="lost" resp="DN"/>
                         ተንሥኣ፡ ሊቅ፡ ወደቅነ፡ በገጽነ፨
                         </incipit>
                         <note>Divided into 59 sections. The part <ref type="work" corresp="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</ref> is
                         located on <locus from="33ra" to="38ra"/>.</note>
                        </msItem>


                        <msItem xml:id="ms_i2">
                          <locus from="81ra" to="114rb"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2462Testam">Testamentum Domini in Galilea</title>
                           <textLang mainLang="gez"/>
                           <incipit xml:lang="gez"><hi rend="rubric">ነገር፡ ዘተናገሮሙ፡</hi>
                           ኢየሱስ፡ ክርስቶ<hi rend="rubric">ስ፡ ለአርደአ</hi>ኢሁ፡ በገሊላ፡ እ<hi rend="rubric">ምድኅረ፡ ተንሥኣ፡</hi>
                           እምዉታን፡ እንዘ፡ ይብል፡ ስምዑኒ፡ ውሉደ፡ ብርሃን፡ ወአጽምኡ፡ ቃለ፡ አቡክሙ፡
                           </incipit>
                              </msItem>




                    </msContents>

                    <physDesc>
                        <objectDesc form="Codex">
                            <supportDesc>
                                <support>
                           <material key="parchment"/>
                        </support>
                                <extent>
                                    <measure unit="leaf" quantity="115">114+1</measure>
                                    <dimensions type="outer" unit="mm">
                                      <height>210</height>
                                      <width>180</width>
                                    </dimensions>
                                </extent>

                                <foliation>Foliation in the upper right corner of the folia.
                                  The first unfoliated (paper?) leaf is a part of the
                                  binding. The last parchment folium, unfoliated, is
                                  assigned the number <locus target="#115">115</locus>.</foliation>

                                <collation>
                                  <note>Establishing of the quire structure is not
                                  possible due to the condition of the manuscipt.</note>
                                  </collation>
                                <condition key="good">It appears that the original quires
                                  have been dissolved, all leaves are now separate.</condition>
                                </supportDesc>

                           <layoutDesc>
                              <layout columns="2" writtenLines="17 19">
                                <note>The pages <locus target="#1r #81r"> have less written lines because the upper
                                part is left blank, probably reserved for decoration that was never executed.</locus></note>
                              <ab type="pricking">Pricking is visible.</ab>
                              <ab type="pricking">Ruling is not visible.</ab>
                              <ab type="ruling" subtype="pattern" cert="medium">1A-1A-1A1A/0-0/0-0/C</ab>
                              <note>The last leaf <locus target="#115"/>is pricked but ruled
                               only in part.</note>
                              </layout>
                           </layoutDesc>

                          </objectDesc>
                        <handDesc>
                           <handNote xml:id="h1" script="Ethiopic">
                               <locus from="1rb" to="31va"/>                               
                               <locus from="57ra" to="71vb"/>
                               <locus from="81ra" to="88ra"/>
                              <seg type="script">Late 15th-/first half of the 16th-century script.</seg>
                              <seg type="ink">Black; red.</seg>
                              <desc>Careful, somewhat irregular; by a mediocre scribe;
                                described by A. d'Abbadie as <foreign xml:lang="fr">ʻécriture guịlḥ ancienneʼ</foreign>. 
                                  Right-sloping handwriting, mostly rounded letter shapes. 
                                  
                                </desc>
                              </handNote>
                            <handNote xml:id="h2" script="Ethiopic">
                                <locus from="31vb" to="56vb"/>
                                <locus from="71vb" to="80rb"/>
                                <locus from="88ra" to="114rb"/>
                                <seg type="script">Late 15th-/first half of the 16th-century script.</seg>
                                <seg type="ink">Black; red.</seg>
                                <desc>Careful, somewhat regular; by a mediocre scribe, similar to <ref target="#h1">Hand 1</ref> 
                                    but somewhat inferior to it. Slightly right-sloping to upright and left-sloping handwriting. More angular 
                                    letter shapes in comparison to <ref target="#h1">Hand 1</ref>. 
                                  
                                </desc>
                            </handNote>
                        </handDesc>

                        <decoDesc>
                          <decoNote type="headpieceBand" xml:id="d1">
                            <locus target="#115r"/>
                            <desc>An exercise in drawing an ornamental band.</desc>
                          </decoNote>

                          <decoNote type="drawing" xml:id="d2">
                            <locus target="#115v"/>
                            <desc>Crude drawing of an angel, poorly visible.</desc>
                          </decoNote>
                      </decoDesc>

                        <additions>
                          <list>
                              <item xml:id="e1">
                                  <desc type="StampExlibris">
                                 Shelfmark of the Library glued onto the inner side of the front board.
                               </desc>
                             </item>

                             <item xml:id="e2">
                                 <locus target="#1ra"/>
                                <desc type="StampExlibris">Stamp of the Library; the title of the book in Gǝʿǝz and the shelfmark,
                                  in an European hand.</desc>
                            </item>


                             <item xml:id="e3">
                                 <locus from="1r" to="114v"/>
                                <desc type="Correction">Many corrections in various hands,
                                  interlineal and in the margins, through cancelling
                                  with thin line above and below the letters or through encircling.</desc>
                            </item>
                              
                              <item xml:id="e4">
                                  <locus target="#1vb #2ra #14va #15ra #19va #19vb #23ra                                        #26va #39va #40ra #41va #51ra #54ra                                       #58ra #61rb #74ra #92rb"/>
                                  <desc type="Correction">Corrections by means of
                                      <foreign xml:lang="gez">tamallas</foreign>-sign
                                      of various shapes.</desc>
                              </item>

                            <item xml:id="e5">
                                <locus target="#80v #114r #114v"/>
                               <desc type="Unclear">Scribbles.</desc>
                           </item>

                          </list>
                      </additions>

                        <bindingDesc>
                           <binding contemporary="non-Ethiopian" xml:id="binding">
                               <decoNote xml:id="b1">Two boards.</decoNote>

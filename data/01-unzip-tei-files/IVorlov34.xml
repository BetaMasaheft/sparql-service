                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">18th century</seg>
                        <desc>
                           <persName ref="https://betamasaheft.eu/PRS9602Turaev">Turaev</persName>describes
                        the handwriting as "large" and "nice"
                          but does not propose any dating.
                        </desc>
                        <seg type="ink">Black, red</seg>
                        <date/>
                        </handNote>
                  </handDesc>


                  <additions>
                    <list>
                        <item xml:id="a1">
                          <desc type="ProtectivePrayer" xml:lang="am"/>
                          <locus target="#1r"/>
                          <q xml:lang="gez"/>
                           <note>Conjurations against werewolf.</note>
                       </item>

                       <item xml:id="a2">
                           <desc type="Unclear" xml:lang="gez"/>
                          <locus from="2v" to="3v"/>
                          <q xml:lang="gez"> በዝ፡ ንዜከር፡  ሐሳበ፡ ሕጉ፡ ለእግዚእነ፡ ወመድኃኒነ፡ ኢ፡ ክ፡
                            <gap reason="omitted" resp="PRS9602Turaev"/>እንዘ፡ ሀሎነ፡ በዘበነ፡ ቅዱስ፡ ማርቆስ፡
                            ወንገላዊ፡ ይብጽሐነ፡ እስከ፡ ዘበነ፡ ሉቃስ፡ ዜናዊ። በ፶፲ት፡ በ፭ቱ፻ት፡ ኮነ፡ ዓመተ፡ ዓለም። በ፲ቱ፡ ፻።
                            በ፲ቱ፡ ፻፺፡ ኮነ፡ ዓመተ፡ ምሕረት፡<gap reason="omitted" resp="PRS9602Turaev"/>
                           </q>
                           <note>Chronological notes written on a sewn-in European paper leaf.</note>
                       </item>


                       <item xml:id="a3">
                          <desc type="CalendaricNote" xml:lang="am"/>
                          <locus target="#90v"/>
                          <q>
                              <foreign>ዘጊዜ፡ ቁርባን፡ የመስከረምና፡ የመጋቢት፡ ፲፡ ጫማ፡</foreign>
                           </q>
                           <note>Continued by unspecified paschal (computistical?) notes.</note>
                       </item>
                    </list>

                  </additions>


                  <bindingDesc>
                     <binding contemporary="true" xml:id="binding">
                        <decoNote xml:id="b1">Two wooden boards.
                        Probably one pair of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                              <material key="wood"/>

                        </decoNote>
                     </binding>
                  </bindingDesc>


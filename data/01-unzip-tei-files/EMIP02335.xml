                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#90v" facs="091">Fol. 90v</locus><desc>Figure with sword and scabbard, drawn in pencil.</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#91r" facs="091">Fol. 91r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with sword and scabbard, drawn in pencil</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#91v" facs="092">Fol. 91v</locus><desc>Crude drawing of a face, drawn in pencil</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#92r" facs="092">Fol. 92r</locus><desc>Crude drawings of figures and faces, drawn in pencil</desc></decoNote>
                    <decoNote type="frame" xml:id="d5">
                      Decorative designs:
                      <locus target="#4v" facs="005">fols. 4v, </locus>, lines of alternating red and black dots;
                      <locus target="#72v" facs="073">72v</locus>, multiple full stops</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="a1"><desc type="OwnershipNote"><locus target="#4v #72v #89r" facs="005 073 089">Fols. 4v, 72v, 89r</locus> the name of the owner has been partially erased. Only Wäldä ʾA, <foreign xml:lang="gez">ወልደ፡ አ</foreign>, remains</desc></item>
                      <item xml:id="a2"><desc type="ScribalSignature"><locus target="#4v" facs="005">Fol. 4v</locus> mentions the scribe Wäldä Giyorgis (<foreign xml:lang="gez">ወልደ፡ ጊዮርጊስ፡</foreign></desc></item>
                      <item xml:id="a3"><desc><locus target="#4v" facs="005">Fol. 4v</locus> note in a secondary hand, a curse on one who steals or damages the book</desc></item>
                      <item xml:id="e1"><desc><locus target="#45v" facs="046">Fol. 45v</locus> the name of the owner has been erased.</desc></item>
                      <item xml:id="a4"><desc><locus target="#45v">Fol. 45v</locus> mentions <persName ref="https://betamasaheft.eu/PRS6876Matewos">Mātewos X</persName> and <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</persName></desc></item>
                      <item xml:id="a5"><desc type="ScribalSignature"><locus target="#72v" facs="073">Fol. 72v</locus> mentions the scribe Täklä Wäld, <foreign xml:lang="gez">ተክለ፡ ወልድ፡</foreign></desc></item>
                      <item xml:id="e2"><desc><locus target="#73r #90r" facs="073 090">Fols. 73r, 90r</locus> blank</desc></item>
                      <item xml:id="a6"><desc><locus target="#89v" facs="090">Fol. 89v</locus> the name ʾAläqä Wäldä Gäbrǝʾel, <foreign xml:lang="gez">አለቀ፡ ወልደ፡ ገብርኤል፡</foreign>, is written in pencil and blue ink</desc></item>
                      <item xml:id="a7"><desc><locus target="#92v" facs="093">Fol. 92v</locus> the name ʾAläqä Wäldä Gäbrǝʾel, <foreign xml:lang="gez">አለቀ፡ ወልደ፡ ገብርኤል፡</foreign>, is written in a box at the top of the folio</desc></item>
                      <item xml:id="e3"><desc>
                        Scribal intervention:
                        words of text are written interlinearly <locus target="#1v #7r #11r #11v #12v" facs="002 007 011 012 013">folss. 1v, 7r, 11r, 11v, 12v, </locus>, etc.;
                        and in the upper margin with a symbol (┬) marking the location where the text is to be inserted <locus target="#9r #11v" facs="009 012">9r, 11v, </locus>,
                        and in another case where the symbol (┴) is used <locus target="#31v #32r #32v #37v #39r" facs="032 033 038 039">31v, 32r, 32v, 37v, 39r, </locus>, etc.;
                        text has been removed <locus target="#4v #5v #6r #6v #7r" facs="005 006 007">4v, 5v, 6r, 6v, 7r</locus>, etc.</desc></item>
                    </list></additions>

                  <bindingDesc>
                    <binding xml:id="binding" contemporary="partly">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, back cover has broken.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

                  <msItem xml:id="ms_i8">
                     <locus from="9r" to="32ra"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4096AmharicE">Amharic Explanation of words and grammatical forms (general
          record)</title>
                     <note>According to the introductory note in Latin, the text was written by 
                        <ref type="pers" corresp="https://betamasaheft.eu/PRS10036Wansleb">Johann-Michael Wansleben</ref> in
                        <ref type="place" corresp="https://betamasaheft.eu/LOC2085Cairo">Cairo</ref> in <date when="1664">1664</date>.</note>
                     <incipit xml:lang="la">
                        Arabica quae addidi interdum solamente coniecturae sunt,<lb/>
                        interdum a. tangunt [ill.]<lb/>
                        ሰውሰው<lb/>
                        Lexicon Amharico-Abissinicum.<lb/>
                     <gap reason="ellipsis"/>
                        Communicavit P. Elzearius.<lb/>
                        Cairi 1664.<lb/>
                        Scripsit Gio: Michaelis Turingus.<lb/>
                        de Wanslebiis.
                     </incipit>
                     <incipit xml:lang="gez">በስመ፡ ስሉስ፡ ቅዱስ፡ ፩፡ አምላክ፡ ነገረ፡ አዕናቍ፡ ግብረ፡ ደብተራ፡ ብ፡ ደመና፡<gap reason="ellipsis"/></incipit>
                     <explicit xml:lang="gez">ስመ፡ ሰይጣን፡ ጸላኤ፡ ሰናይ። ብርያል፡ ቤልሐር፡ ዲያብሎስ። 
                     ስብልያኖስ። አብዶን። አጰሎን። ሎባ። መማደስ። መጠንብኵስ፡ ምኔን፡ ባኵሕ። አብን፡ መዮድኅ።</explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i9">
                     <locus from="33r" to="44r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1195Bahrah">Bāḥra ḥassāb</title>
                     <note>According to the introductory note in Latin, the text was written by 
                        <ref type="pers" corresp="https://betamasaheft.eu/PRS10036Wansleb">Johann-Michael Wansleben</ref> in
                        <ref type="place" corresp="https://betamasaheft.eu/LOC2085Cairo">Cairo</ref> in <date when="1664">1664</date>.</note>
                     <note cert="high">As noted by                               
                        <bibl corresp="http://zotero.org/groups/358366/items/RJFA2TG3"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi1989MssBNCF"/><title level="a">I manoscritti etiopici di J.M. Wansleben nella Biblioteca Nazionale Centrale di Firenze</title><title level="j">Rassegna di Studi Etiopici</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Alessandro</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bausi</t:surname></author><date>1991</date><biblScope unit="volume">33 (1989)</biblScope><biblScope unit="page">5-33</biblScope><note type="url">http://www.jstor.org/stable/41292808</note><citedRange unit="page">17</citedRange></bibl>, this text has many marginal annotations by <ref type="pers" corresp="https://betamasaheft.eu/PRS10036Wansleb">Johann-Michael Wansleben</ref> and its
                        <foreign xml:lang="de">Vorlage</foreign> is most probably
                        <ref type="mss" corresp="https://betamasaheft.eu/UppEt3#ms_i2">No item: UppEt3, could not check for ms_i2</ref>.</note>
                     <incipit xml:lang="la">
                        ሐሳበ፡ <sic resp="JK">ሰ</sic>መን፡ አኢትዮጵያ።<lb/>
                        ኦ፡<lb/>
                        መጽሐፈ፡ ሐሰብ፡<lb/>
                        Computus Abissinorum<lb/>
                        quem mihi communicavit<lb/>
                        Cairi<lb/>
                        Ad. Rev.do P. Elzearus. Cappuccinus.<lb/>
                        A.o Sal. 1664.<lb/>
                        Scribente<lb/>
                        Johanne Michele Vanslebio,<lb/>
                        Erffordiense Turingo.
                        <del unit="lines" quantity="3"/>
                     </incipit>
                     <incipit xml:lang="gez">
                        <locus target="#34r"/>
                        Cairi. 1664 Jan. በስመ፡ አብ፡ <gap reason="ellipsis"/> ጸሐፍነ፡ በዘ፡ ንዜክር፡ መጽሐፈ፡ ሐሳብ፡ 
                        ሕገ፡ እግዚአብሔር፡ ከመ፡ ኢንደመር፡ ምስለ፡ ከሐድያን፡ ዘእምአመ፡ ተፈጥረ፡ ዓለም፡ በዘተአምር፡ ኆልቈ፡ ፲፫፡ አቅማር። 
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i10">
                     <locus from="45r" to="46v"/>
                     <locus target="#53r"/>
                     <title type="complete" ref="https://betamasaheft.eu/NAR0005calend">Calendar of saint commemorations</title>
                     <note>According to a marginal note on <locus target="#45r"/>, this text was copied in 
                        <ref type="ins" corresp="https://betamasaheft.eu/INS0308DQ">Koskam</ref> in <date when="1664">1664</date>.
                        The translations of the names of the months are also written in the margin.
                     </note>
                     <incipit xml:lang="gez">
                        <locus target="#45r"/>
                        በስመ፡ አብ፡ <gap reason="ellipsis"/>
                        ጸሐፍነ፡ በዘ፡ ንዜክር፡ ተዝካረ፡ ነቢያት፡ ወሐዋርያት፡ ወጻድቃን፡ ወሰማዕት፡ ጳጳሳት፡ ኤጲስ፡ ቆጶሳት፡ 
                        ቀሳውስት፡ ወዲያቆናት፡ ሠረቀ፡ ቲቶ፡ መስከረም፡ አመ፡ ፩፡ ዮሐንስ፡ መጥምቅ፡ ወበርተሎሜዎስ፡ ሐዋርያ፡ 
                        <gap reason="ellipsis"/>
                        <locus target="#45v"/>
                        ሠረቀ፡ ቲዮፍ፡ ጥቅምት፡ አመ፡ ኅርመተ፡ ማይ፡ ዘፊልሙና፡ ወዘፊልጶስ፡ ሰማዕት፡ 
                        <gap reason="ellipsis"/>
                        <locus target="#46r"/>
                        ሠረቀ፡ አቴር፡ ኅዳር፡ አመ፡ ፩፡ ሐጌ፡ ነቢይ፡ ወማርቆስ፡ ወንጌላዊ፡ ፻፵፭፡ ሰማዕታት፡ 
                        <locus target="#46v"/>
                        defetto
                        <locus target="#53r"/>
                        ሠረቀ፡ ኵያቍ፡ ታኅሣስ፡ <add cert="medium">non erat integer hic computus</add>
                     </incipit>
                  </msItem>
                  
                  <msItem xml:id="ms_i11">
                     <locus from="50r" to="51v"/>
                     <title type="incomplete" cert="medium" ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title>
                     <note>The textual identification is not certain (although at least parts of the incipit provided by 
                        <bibl corresp="http://zotero.org/groups/358366/items/RJFA2TG3"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi1989MssBNCF"/><title level="a">I manoscritti etiopici di J.M. Wansleben nella Biblioteca Nazionale Centrale di Firenze</title><title level="j">Rassegna di Studi Etiopici</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Alessandro</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bausi</t:surname></author><date>1991</date><biblScope unit="volume">33 (1989)</biblScope><biblScope unit="page">5-33</biblScope><note type="url">http://www.jstor.org/stable/41292808</note><citedRange unit="page">18</citedRange></bibl> – <foreign xml:lang="gez">አውኀዘ፡ ሎሙ፡ ማየ፡ ሕይወት፡ ዘትረ፡ ኰኵሕ፡</foreign>–
                        agrees with the beginning of a <foreign xml:lang="gez">Zəmmāre</foreign> antiphon
                        attested, for example, in <ref type="mss" corresp="https://betamasaheft.eu/GG00075#1r">No item: GG00075, could not check for 1r</ref>);
                        <bibl corresp="http://zotero.org/groups/358366/items/RJFA2TG3"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi1989MssBNCF"/><title level="a">I manoscritti etiopici di J.M. Wansleben nella Biblioteca Nazionale Centrale di Firenze</title><title level="j">Rassegna di Studi Etiopici</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Alessandro</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bausi</t:surname></author><date>1991</date><biblScope unit="volume">33 (1989)</biblScope><biblScope unit="page">5-33</biblScope><note type="url">http://www.jstor.org/stable/41292808</note><citedRange unit="page">18</citedRange></bibl>
                        calls it an "unidentified fragment" (<foreign xml:lang="it">frammento non identificato</foreign>).
                     </note>
                     <incipit xml:lang="gez">
                        A.o 1664. 20 Maj. in Koskam.<lb/>
                        በረድኤቱ፡ ለእግዚአብሔር፡ አሜን።<lb/>
                        ጸሐፍነ፡ ለዘንዜከር፡ ዝማሪ፡ ዕዝል፡ ወ<lb/>ግዕዝ፡
                        ወዋዜማ፡ ወኵሎ፡ መዋዕል፡ አም<lb/>ዮሐንስ፡ 
                        አውኀዘ፡ ሎሙ፡ ማየ፡ ሕይወት፡ ዘትረ፡ ኰኵሕ፡<lb/>
                        ሰ፡ ለኪ፡ ድንግል፡ መዐዝነ፡ ኵሉ፡ ብሔር፡<lb/>
                        ዘገዳም፡ ንጽራር፡<lb/>

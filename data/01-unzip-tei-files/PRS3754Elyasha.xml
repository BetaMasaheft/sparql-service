         <t:listPerson>
            <t:person sex="1">
          
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ኤልያስ፡ ኃይሉ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾElyās Ḫāylu</t:persName>
                  
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
                  <t:occupation type="literary">artist</t:occupation>
          
                  <t:birth when="1861"/>
                  
                  
                  
               <t:floruit notBefore="1881" notAfter="1930">He was one of  
                  Ethiopia's most prominent artists during the reign of 
                  
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk</t:persName>. 
                  He was one of the first Ethiopians to go abroad to study painting, 
                  in <t:placeName ref="https://www.wikidata.org/entity/Q142">France</t:placeName>. His painting include illustration for a copy of <t:ref type="work" corresp="https://betamasaheft.eu/LIT2384Taamme">Taʾammǝra Māryām</t:ref>. ʾElyās Ḫāylu also decorated many churches and he was one of the 
                  first Ethiopian artists to depict  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk</t:persName> 's victory at the battle of 
                  <t:placeName ref="https://betamasaheft.eu/LOC1263Adwa">ʿĀdwā</t:placeName>. 
                  </t:floruit>
                  <t:death notAfter="1930"/>
                  
                  
               </t:person>
               
         </t:listPerson>
         
         
         

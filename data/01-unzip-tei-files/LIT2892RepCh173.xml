            <t:div type="edition" xml:lang="gez">
               <t:div type="textpart" xml:id="malke">
                  <t:note>Taken from <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl></t:note>
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ሕይወተ፡ ወላዲ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ከሣቴ፡ ኅቡኣት፡ በበ፡ ጾታ፨</t:l>
                     <t:l n="2">ለነቢያት፡ ቅድመ፡ ወለሐዋርያት፡ ሕዝበ፡ ኤፍራታ፨</t:l>
                     <t:l n="3">እምዝቀ፡ ሥምረትከ፡ እቅዳሕ፡ ለእኅተ፡ ክርስቶስ፡ ወይነ፡ ማሕሌታ፨</t:l>
                     <t:l n="4">ይሰወጥ፡ ለልሳንየ፡ ቅድስናከ፡ ውስቴታ፨</t:l>
                     <t:l n="5">ወይጸልለኒ፡ እምሰምይ፡ አክናፊከ፡ መንታ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="2">
                     <t:l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ሞገሰ፡ ሃይማኖት፡ ዘተረሰየ፨</t:l>
                     <t:l n="2">እንዘ፡ እምዓሠርቱ፡ ይነትግ፡ ኆኅያተ፡ ፊደል፡ ስኑየ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ልብኪ፡ ቀናንሞ፡ እስመ፡ ጽጌ፡ ተስፋ፡ ጸገየ፨</t:l>
                     <t:l n="4">ለዓለም፡ ግብረ፡ ኅልፈታ፡ ኅልፈተ፡ ጽላሎት፡ ረሰየ፨</t:l>
                     <t:l n="5">ወጸሙእ፡ በሕልም፡ ዘይሰቲ፡ ማየ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="3">
                     <t:l n="1">ሰላም፡ ለሥዕርተ፡ ርእስኪ፡ ወለርእስኪ፡ ማኅደራ፨</t:l>
                     <t:l n="2">ለበዓልተ፡ ዜና፡ ጥበብ፡ ዘሕሊና፡ አብዳን፡ ኢያፈቅራ፨</t:l>
                     <t:l n="3">ኰናኒተ፡ ዓለም፡ አጋር፡ እኅተ፡ ክርስቶስ፡ ሳራ፨</t:l>
                     <t:l n="4">ህየንተ፡ ጻማኪ፡ ወትእግሥትኪ፡ መከራ፨</t:l>
                     <t:l n="5">ውስተ፡ ሕፅነ፡ አብርሃም፡ ወሰዱኪ፡ ትጉሃን፡ ሐራ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="4">
                     <t:l n="1">ሰላም፡ ለገጽኪ፡ አመ፡ ትጠበለል፡ የብስ፨</t:l>
                     <t:l n="2">ዘያፈደፍድ፡ ሡራኄ፡ እምኦርያሬስ፨</t:l>
                     <t:l n="3">መግደላዊት፡ እምነ፡ እኅተ፡ ክርስቶስ፨</t:l>
                     <t:l n="4">ኮኖሙ፡ ለኅዙናን፡ ትፍሥሕተ፡ ሥጋ፡ ወነፍስ፨</t:l>
                     <t:l n="5">ዘከሠተ፡ ልኪ፡ ትንሣኤ፡ ሐዲስ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="5">
                     <t:l n="1">ሰላም፡ ለቀራንብትኪ፡ ወለአዕይንትኪ፡ እለ፡ ኢኖማ፨</t:l>
                     <t:l n="2">እንዘ፡ ይተግሃ፡ ለጸሎት፡ ወያስተሐምማ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ማስያስ፡ ምስለ፡ ወለተ፡ ጴጥሮስ፡ ክልልተ፡ ግርማ፨</t:l>
                     <t:l n="4">ከመ፡ ተሐድሲ፡ ለጉባኤነ፡ ሰላማ፨</t:l>
                     <t:l n="5">እምሉዓሌ፡ ሰማይ፡ ሐውጺ፡ ወንዒ፡ እምራማ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="6">
                     <t:l n="1">ሰላም፡ ለአእዛንኪ፡ ምክረ፡ መንፈስ፡ ቅዱስ፡ እለ፡ ተወክፋ፨</t:l>
                     <t:l n="2">ወለመላትሕኪ፡ አዕርፎ፡ እንተ፡ መደልዋን፡ ገደፋ፨</t:l>
                     <t:l n="3">ዕጣነ፡ ትንባሌ፡ አዕርጊ፡ እኅተ፡ ክርስቶስ፡ በቅድመ፡ አልፋ፨</t:l>
                     <t:l n="4">ይኩነኒ፡ አክሊለ፡ መዊእ፡ ወተስፋ፨</t:l>
                     <t:l n="5">በረከቶሙ፡ ለሳውል፡ ወኬፋ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="7">
                     <t:l n="1">ሰላም፡ ለአእናፍኪ፡ እለ፡ አጼነዋ፡ መዓዛ፡ ፍቅር፨</t:l>
                     <t:l n="2">ወለከናፍርኪ፡ ዝጉሓት፡ በፍትሐ፡ መስቀል፡ ክቡር፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ገነት፡ ጽጌያተ፡ ጽጌ፡ ስሙር፨</t:l>
                     <t:l n="4">አጽልልኒ፡ ማእከሌኪ፡ እምላህበ፡ ኵነኔ፡ መሪር፨</t:l>
                     <t:l n="5">ጊዜ፡ ኅልፈቶሙ፡ ለሰማይ፡ ወምድር፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="8">
                     <t:l n="1">ሰላም፡ ለአፉኪ፡ ወለአስናንኪ፡ እለ፡ ኢፀርሳ፨</t:l>
                     <t:l n="2">በቆዓ፡ ኃጢአት፡ ወአበሳ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ በልነ፡ ለአጋብዕኪ፡ ጊዜ፡ ኃሠሣ፨</t:l>
                     <t:l n="4">ኢይጥኅር፡ በቅድሜክሙ፡ አምሳለ፡ ካልአን፡ እንስሳ፨</t:l>
                     <t:l n="5">ውስተ፡ ገዳመ፡ ደይን፡ መፍርህ፡ ዘሀሎ፡ አንበሳ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="9">
                     <t:l n="1">ሰላም፡ ለልሳንኪ፡ ወለቃልኪ፡ ርሑቅ፨</t:l>
                     <t:l n="2">እምተናግሮ፡ ቃል፡ ከንቱ፡ ወንባበ፡ ኵሉ፡ ስላቅ፨</t:l>
                     <t:l n="3">ለፀሓየ፡ አሚን፡ አንቀጹ፡ እኅተ፡ ክርስቶስ፡ ምሥራቅ፨</t:l>
                     <t:l n="4">ይባልሀነ፡ ረድኤትኪ፡ ለመሲሐውያን፡ ደቂቅ፨</t:l>
                     <t:l n="5">እምጓህልዎቱ፡ ብዙኅ፡ ለሰይጣን፡ ለዕሩቅ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="10">
                     <t:l n="1">ሰላም፡ ለእስትንፋስኪ፡ ወለጕርዔኪ፡ ኅሩም፨</t:l>
                     <t:l n="2">አፍቅሮተ፡ መብልዕ፡ ቅሱም፡ ወጣዕመ፡ ስቴ፡ ጥዑም፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ አብርሂ፡ ማእከለ፡ ጉባኤነ፡ ዮም፨</t:l>
                     <t:l n="4">ዋካ፡ በረከት፡ እንተ፡ ተውህቦ፡ ለሴም፨</t:l>
                     <t:l n="5">ድኅረ፡ ማየ፡ መዓት፡ ኃለፈ፡ ወሐልቀ፡ ዝናም፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="11">
                     <t:l n="1">ሰላም፡ ለክሣድኪ፡ ወለመታክፍትኪ፡ እለ፡ ጾሩ፨</t:l>
                     <t:l n="2">አርዑተ፡ አስኬማ፡ ቅዱስ፡ ወልዑለ፡ ልዑል፡ ዝክሩ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ እምነ፡ ለአብ፡ ቀዳሜ፡ በኵሩ፨</t:l>
                     <t:l n="4">ይበላነ፡ ከናፍርኪ፡ በዓለ፡ ፍሥሐ፡ ግበሩ፨</t:l>
                     <t:l n="5">እስመ፡ እጽዋኒክሙ፡ አርስሳን፡ በኲናት፡ ተገምሩ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="12">
                     <t:l n="1">ሰላም፡ ለዘባንኪ፡ አራዛ፡ ሱራሄ፡ ዘተሞጥሐ፨</t:l>
                     <t:l n="2">ዘኢያርሐቶ፡ ዓለም፡ ከመ፡ ልብሳ፡ አብዳት፡ አዋልዲሃ፨</t:l>
                     <t:l n="3">እኅተ፡ አሐዱ፡ አምላክ፡ እንዘ፡ ንሰምዮ፡ መሲሐ፨</t:l>
                     <t:l n="4">ዘትጸምዕ፡ ነፍስ፡ በፍቅርኪ፡ ትትፈቀር፡ ብዙኀ፨</t:l>
                     <t:l n="5">ወበረከትኪ፡ የኃድር፡ ላዕሌሃ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="13">
                     <t:l n="1">ሰላም፡ ለእንግድዓኪ፡ ወለሕፅንኪ፡ አስተጋባኢ፨</t:l>
                     <t:l n="2">ከላስስተ፡ ጸጋ፡ ወጽድቅ፡ ዘኢይረእዮሙ፡ ዓይነ፡ ቀናዒ፨</t:l>
                     <t:l n="3">ሕይወተ፡ አቡሁ፡ ወርእሱ፡ እኅተ፡ ክርስቶስ፡ ተቀባዒ፨</t:l>
                     <t:l n="4">ቃለ፡ ስእለተነ፡ ለለአፈ፡ ጽባሕ፡ አጽምዒ፨</t:l>
                     <t:l n="5">ወይጽብዖ፡ ለሰይጣን፡ ኃይልኪ፡ መዋኢ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="14">
                     <t:l n="1">ሰላም፡ ለአእዳውኪ፡ ወለመዛርእኪ፡ በኁባሬ፨</t:l>
                     <t:l n="2">እለ፡ ይሰፍሐ፡ ለበቍዔት፡ ከመ፡ ባሕለ፡ ንጹሕ፡ ፍካሬ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ዘንተ፡ ጸናጽለ፡ ንኡስ፡ ዝማሬ፨</t:l>
                     <t:l n="4">ስክዒ፡ ውስተ፡ ልብየ፡ ልብሰ፡ መንፈስ፡ ቅዱስ፡ ጶዴሬ፨</t:l>
                     <t:l n="5">ወአኮ፡ በጽፈ፡ ልብሱ፡ ለካህን፡ ኅሬ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="15">
                     <t:l n="1">ሰላም፡ ለኵርናዕኪ፡ ወለክልኤሆን፡ እመታት፨</t:l>
                     <t:l n="2">ዘአስተዋድዶን፡ ፈጣሪ፡ ገባሬ፡ ኵሉ፡ ፍጥረት፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ሐዳስ፡ ደብተራ፡ ጸሎት፨</t:l>
                     <t:l n="4">ሠናየ፡ መከረ፡ ሕሊናኪ፡ እምሐውዘ፡ ሐላፊ፡ ንብረት፨</t:l>
                     <t:l n="5">ለጸዊረ፡ ጸልቦ፡ መስቀል፡ ዘውእቱ፡ ንጼት፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="16">
                     <t:l n="1">ሰላም፡ ለእራኃትኪ፡ ምስለ፡ አፃብዕ፡ ዐሠርቱ፨</t:l>
                     <t:l n="2">ወለአጽፋርኪ፡ ቦቶን፡ እለ፡ ውዱዳት፡ እማንቱ፨</t:l>
                     <t:l n="3">ለወላዴ፡ ወልድ፡ ወለቱ፡ ወለተወላዲ፡ እኅቱ፨</t:l>
                     <t:l n="4">ይትዓየን፡ ማኅበረነ፡ ስብሐተ፡ ፍልሰትኪ፡ ዝንቱ፨</t:l>
                     <t:l n="5">ከመ፡ ሚካኤል፡ መልአክ፡ ዘውኩፍ፡ ስእለቱ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="17">
                     <t:l n="1">ሰላም፡ ለአጥባትኪ፡ እለ፡ አንቅዓ፡ ከመ፡ ሐሊብ፨</t:l>
                     <t:l n="2">ፈልፈለ፡ በረከት፡ ሐዲስ፡ ትፍሥሕተ፡ ኅዙናን፡ ሕዝብ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ባሕርይ፡ ዘኢትፈለጥ፡ እምአብ፨</t:l>
                     <t:l n="4">ያንጸብርቅ፡ በኵለንታየ፡ ዘኵለንታኪ፡ ጥበብ፨</t:l>
                     <t:l n="5">እምስነ፡ ስንቡል፡ ኮከብ፡ ወሐሓይ፡ ልሁብ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="18">
                     <t:l n="1">ሰላም፡ ለገቦኪ፡ አጽፈ፡ ምንኵስና፡ ዘተገልበበ፨</t:l>
                     <t:l n="2">ወለከርሥኪ፡ ዘኮነ፡ ለኅብስተ፡ ቍርባን፡ መሶበ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ወንጌል፡ ነባቢ፡ ከመ፡ አቅደመ፡ ንባበ፨</t:l>
                     <t:l n="4">ዘያስቲ፡ ማየ፡ በስምኪ፡ ወዘይሴሲ፡ ርኁበ፨</t:l>
                     <t:l n="5">ብእሲ፡ ምዕመነ፡ ኢየኃጕል፡ ዓስበ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="19">
                     <t:l n="1">ሰላም፡ ለልብኪ፡ ወለኵልያትኪ፡ እምእከይ፨</t:l>
                     <t:l n="2">እለ፡ ንጹሐት፡ እማንቱ፡ ከመ፡ ኅብረ፡ ብሩር፡ ጽሩይ፨</t:l>
                     <t:l n="3">እኅተ፡ መለኮት፡ ቃል፡ ዋሕደ፡ ጠባይዕ፡ ባሕርይ፨</t:l>
                     <t:l n="4">ምሉጠ፡ ይኩን፡ ስእለተነ፡ በስእለትኪ፡ ሠናይ፨</t:l>
                     <t:l n="5">ኀበ፡ ማርያም፡ ድንግል፡ ዳግሚት፡ ሰማይ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="20">
                     <t:l n="1">ሰላም፡ ለሕሊናኪ፡ ዘብዕዘ፡ ጽርየቱ፡ በረድ፨</t:l>
                     <t:l n="2">ወለአማዑትኪ፡ ውዑይ፡ በላህበ፡ ሃይማኖት፡ ነድ፨</t:l>
                     <t:l n="3">እመ፡ ብዙኃን፡ እኅቱ፡ ሊቀ፡ ካህናቲነ፡ ወልድ፨</t:l>
                     <t:l n="4">አማኅፀንኩ፡ ሕይወትየ፡ በኃይለ፡ ጸሎትኪ፡ ዓምድ፨</t:l>
                     <t:l n="5">እመከራሆሙ፡ ለአዝማድ፡ ወባዕድ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="21">
                     <t:l n="1">ሰላም፡ ለንዋየ፡ ውስጥኪ፡ ወለኅንብርትኪ፡ አርአያ፨</t:l>
                     <t:l n="2">እንተ፡ ማእከለ፡ ከርሥ፡ ስራዒ፡ ኵሉ፡ ኬንያ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ቡርክት፡ በአፈ፡ ነቢይ፡ ወሐዋርያ፨</t:l>
                     <t:l n="4">ተአኵተኪ፡ እንዘ፡ ትብል፡ ጉባኤ፡ ማኅበር፡ ነያ፨</t:l>
                     <t:l n="5">እምአስቴር፡ ወዮዲት፡ ይትሌዓል፡ ዕበያ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="22">
                     <t:l n="1">ሰላም፡ ለማኅፀንኪ፡ እንተ፡ ረስያ፡ ስርጋዌ፨</t:l>
                     <t:l n="2">ጸጋ፡ መንፈስ፡ ቅዱስ፡ ንጽሕና፡ ወጥበብ፡ ሰማያዌ፨</t:l>
                     <t:l n="3">ምስለ፡ ሰቃልያን፡ አይሁድ፡ አመ፡ ትትፋታሕ፡ ነነዌ፨</t:l>
                     <t:l n="4">ተአመንኩ፡ እኅተ፡ ክርስቶስ፡ ትብልናኪ፡ ማኅየዌ፨</t:l>
                     <t:l n="5">ከመ፡ ያብጽሐኒ፡ እምሁከት፡ ኀበቦ፡ ጽማዌ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="23">
                     <t:l n="1">ሰላም፡ ለሐቌኪ፡ በአኅብሮ፡ ፪አቍያጽ፨</t:l>
                     <t:l n="2">እንበለ፡ ምንተኒ፡ ኅጸጽ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ዕቀቢ፡ እግረ፡ ልብየ፡ እምዳኅፅ፨</t:l>
                     <t:l n="4">ወእለበወኒ፡ አፍቅሮተ፡ አምላክ፡ ወቢጽ፨</t:l>
                     <t:l n="5">በዘተውኅበ፡ ለኪ፡ እምሰማይ፡ ቀኖና፡ ቅሩጽ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="24">
                     <t:l n="1">ሰላም፡ ለአብራክኪ፡ እለ፡ አስተብረካ፡ ለልዑል፨</t:l>
                     <t:l n="2">ወለአእጋርኪ፡ ዘቆማ፡ ዲበ፡ አድማስ፡ ኃያል፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ አንክአ፡ እኅተ፡ ክርስቶስ፡ ኮል፨</t:l>
                     <t:l n="4">ይዜምሩ፡ ለኪ፡ በብሂል፡ ካህናተ፡ ሐዲስ፡ ወንቤል፨</t:l>
                     <t:l n="5">ሐፁር፡ የዓውዳ፡ ወጽጌ፡ ረዳ፡ በትእምርተ፡ መስቀል፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="25">
                     <t:l n="1">ሰላም፡ ለሰኳንውኪ፡ ምስለ፡ መከየድ፡ ዘተራወጹ፨</t:l>
                     <t:l n="2">ውስተ፡ ምድረ፡ ሥጋ፡ ወነፍስ፡ ማኅደረ፡ ትሩፋት፡ ይሕንጹ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ይጕየዩ፡ ለስእለትኪ፡ በድምፁ፨</t:l>
                     <t:l n="4">አጋንንት፡ ፀዋጋን፡ እለ፡ እምሰማያት፡ ቀነጹ፨</t:l>
                     <t:l n="5">ከመ፡ ኢይጽፍሩ፡ ሀብለ፡ ሞት፡ ኪያነ፡ ያዕቅጹ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="26">
                     <t:l n="1">ሰላም፡ ለአፃብዓ፡ እግርኪ፡ ወለአጽፋርኪ፡ አምጣኒሆን፨</t:l>
                     <t:l n="2">እንተ፡ ይደምር፡ ክልኤተ፡ ዲበ፡ ኍላቌሆን፡ ሰመን፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ለኪ፡ ሐመረ፡ ኪዳን፨</t:l>
                     <t:l n="4">ያስድወኒ፡ ለእሊአኪ፡ እምቀላየ፡ ግሩም፡ ደይን፨</t:l>
                     <t:l n="5">ኀበ፡ ማዕዶተ፡ መርስ፡ ወሠናይ፡ ዛኅን፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="27">
                     <t:l n="1">ሰላም፡ ለቆምኪ፡ ሐመልማለ፡ ገነት፡ አርዝ፨</t:l>
                     <t:l n="2">ወመልክእኪ፡ ብሩህ፡ ከመ፡ ሠርቀ፡ ቤዝ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ በልኒ፡ በንባብኪ፡ ሐዋዝ፨</t:l>
                     <t:l n="4">እንዘ፡ ሕይወትከ፡ ውስተ፡ እደ፡ አምላክ፡ እኁዝ፨</t:l>
                     <t:l n="5">ለምንት፡ ብከ፡ ይበዝኅ፡ ትካዝ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="28">
                     <t:l n="1">ሰላም፡ ለፀአተ፡ ነፍስኪ፡ ዕረፍተ፡ ኅሩያን፡ ኀበ፡ ተነጽፈ፨</t:l>
                     <t:l n="2">ወለበድነ፡ ሥጋኪ፡ ዕንቍ፡ እንተ፡ ያበርህ፡ ሰደፈ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ሀብኒ፡ መምህረ፡ ልቡና፡ መጽሐፈ፨</t:l>
                     <t:l n="4">ፍሬ፡ ዘሞት፡ ወአበሳ፡ እንተ፡ ያስተጋብእ፡ ዘልፈ፨</t:l>
                     <t:l n="5">ናሁ፡ መዋዕልየ፡ በከንቱ፡ ኃለፈ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="29">
                     <t:l n="1">ሰላም፡ ለግንዘትኪ፡ አዕሩገ፡ አስቄጥስ፡ በከመ፡ ሠርዑ፨</t:l>
                     <t:l n="2">ወለመቃብርኪ፡ ኅኑጽ፡ ለእግዚአብሔር፡ ኀበ፡ ምስዋዑ፨</t:l>
                     <t:l n="3">እኅተ፡ ክርስቶስ፡ ደዪ፡ ለኪሩቤል፡ ውስተ፡ ጽዋዑ፨</t:l>
                     <t:l n="4">ዋለ፡ ማኅሌት፡ ለዕበይኪ፡ ያብዑ፨</t:l>
                     <t:l n="5">እንተ፡ ልሳንየ፡ ወአፉየ፡ ንስቲተ፡ አውሥኡ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="30">
                     <t:l n="1">ለቆብዕኪ፡ አምኃ፡ ሰላም፡ ምስለ፡ አስኬማ፡ ወአጽፍ፡ ወቀሚስ፨</t:l>
                     <t:l n="2">ዓዲ፡ ለቅናት፡ ዘቃለ፡ አዋዲ፡ ቅዱስ፨</t:l>
                     <t:l n="3">ናሁ፡ አቅረብኩ፡ እኅተ፡ ክርስቶስ፨</t:l>
                     <t:l n="4">አንቲኒ፡ በረከተ፡ ሥጋ፡ ወነፍስ፨</t:l>
                     <t:l n="5">ሀብኒ፡ ለወልድኪ፡ መሌሊተ፡ ንዑስ፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="31">
                     <t:l n="1">ቡሩክ፡ ውእቱ፡ አምላክነ፡ ዘዓቢይ፡ ኃይሉ፨</t:l>
                     <t:l n="2">ወምሉዕ፡ ባሕረ፡ ሣህሉ፨</t:l>
                     <t:l n="3">እስመ፡ አንቅሐኒ፡ ሊተ፡ እምዝንጋዔ፡ ልማድ፡ ኵሉ፨</t:l>
                     <t:l n="4">እስከ፡ እፌጽም፡ ውዳሴሃ፡ ለእኅተ፡ ወልዱ፡ ወቃሉ፨</t:l>
                     <t:l n="5">ወአቄርብ፡ አኰቴተ፡ ለዛቲ፡ ይደሉ፨</t:l>
                  </t:lg>         
               </t:div>
            </t:div>
      </t:body>
   </t:text></TEI>
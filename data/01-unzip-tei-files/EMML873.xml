               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="11">Fols 1–11</locus>
                     <title>Miracles of Mary ተአምረ፡ ማርያም</title>
                     <note>Introductory rite to the Miracles of Mary, Maṣḥafa śerʻat, መጽሐፈ ፡ ሥርዐት, fol. 1r-6r; Hymn to Mary, I worship you, fol. 6r-7v; 3 Miracles of Mary, fol. 7v-11r </note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="11" to="14">Fols 11–14</locus>
                     <title>Miracles of Jesus ተአምረ ፡ ኢየሱስ: 2 miracles</title>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="14" to="16">Fols 14–16</locus>
                     <title>Fetḥat za-wald ፍትሐት ፡ ዘወልድ</title>
                     <incipit xml:lang="gez">ፍትሐት፡ ዘወልድ፡ እግዚኦ፡ እግዚኦ፡ ኢየሱስ፡ ክርስቶስ፡ ወልድ፡ ዋህድ፡ ቃለ፡ እግዚአብሔር፡ አብ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="16" to="93v">Fols 16–93v</locus>
                     <title>Poems and prayers</title>
                     <msItem xml:id="ms_i4.1">
                        <locus from="16" to="25">Fols 16–25</locus>
                        <title>Image of Mary, Chaîne Repertoire number 220</title>
                     </msItem>
                     <msItem xml:id="ms_i4.2">
                        <locus from="26r" to="35r">Fols 26r–35r</locus>
                        <title>Image of Jesus, Chaîne Repertoire number 123</title>
                     </msItem>
                     <msItem xml:id="ms_i4.3">
                        <locus from="35r" to="42v">Fols 35r–42v</locus>
                        <title>Image of George, Chaîne Repertoire number 194</title>
                     </msItem>
                     <msItem xml:id="ms_i4.4">
                        <locus from="45v" to="48v">Fols 45v–48v</locus>
                        <title>Sword of divinity, ሰይፈ፡ መለኮት, Chaîne Repertoire number 274</title>
                     </msItem>
                     <msItem xml:id="ms_i4.5">
                        <locus from="49r" to="50v">Fols 49r–50v</locus>
                        <title>Prayer, We have asked you, Merciful One, fol. 49r-50v</title>
                     </msItem>
                     <msItem xml:id="ms_i4.6">
                        <locus from="51r" to="59r">Fols 51r–59r</locus>
                        <title>Image of the Savior of the World, Chaîne Repertoire number 164</title>
                     </msItem>
                     <msItem xml:id="ms_i4.7">
                        <locus from="59r" to="67r">Fols 59r–67r</locus>
                        <title>Image of Michael, Chaîne Repertoire number 119</title>
                     </msItem>
                     <msItem xml:id="ms_i4.8">
                        <locus from="67r" to="71v">Fols 67r–71v</locus>
                        <title>Image of Gabriel, Chaîne Repertoire number 246</title>
                     </msItem>
                     <msItem xml:id="ms_i4.9">
                        <locus from="72r" to="79v">Fols 72r–79v</locus>
                        <title>Image of Raguel, Chaîne Repertoire number 365</title>
                     </msItem>
                     <msItem xml:id="ms_i4.10">
                        <locus from="80r" to="89v">Fols 80r–89v</locus>
                        <title>Image of Takla Hāymānot, Chaîne Repertoire number 211</title>
                     </msItem>
                     <msItem xml:id="ms_i4.11">
                        <locus from="90r" to="93v">Fols 90r–93v</locus>
                        <title>Image of Abuna Gabra Manfas Qeddus, Chaîne Repertoire number 196</title>
                     </msItem>
                  </msItem>
               </msContents>

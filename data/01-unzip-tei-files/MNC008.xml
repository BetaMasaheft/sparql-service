               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1" corresp="#h1">
                     <locus from="3r" to="16v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel<foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS7049Michael">Mikāʾel</persName></foreign></title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 48 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#3r"/>
                        <pb n="3r"/>
                        <hi rend="rubric">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘ</hi>ተሳተፈ፡ ወልደ፡ ያሬድ፡ ሄኖክ፡
                        በከመ፡ ጸሐፈ፡ ሶበ፡ እጼውእ፡ ስመከ፡ ከሲትየ፡ አፈ፡ ረዳዔ፡ ምንዱባን፡ <hi rend="rubric">ሚካኤል፡</hi>
                        በከመ፡ ታለምድ፡ ዘልፈ፡ ለረዲኦትየ፡ ነአ፡ ሰፊሐከ፡ ክንፈ።</incipit>
                     <explicit xml:lang="gez">
                        <locus from="16r" to="16v"/><hi rend="rubric">ኦሚካኤል፡</hi> ኦሚካኤል፡ ኦመተንብል፡
                        ካህነ፡ አርያም፡ ትሰመይ፡ ቢጸ፡ ሱራፌል፡ ዘእምርኡሳን፡ ርኡ<pb n="16v"/>ስ፡ ወዘእምልዑላን፡ ልዑል<surplus resp="SH">ል</surplus>፡ ጊዜ፡ ጸዋዕኵከ፡ ቅረበኒ፡ በምሕረት፡ ወሣህል። ዕቀበኒ፡ ወአድኅነኒ፡ ለገብርከ፡
                           <persName role="owner" ref="https://betamasaheft.eu/PRS13244GabraWald">Gabra Wald<hi rend="rubric">ገብረ፡
                              ወልድ፡ </hi></persName> ወምስለ፡ ጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13274AmIya">አምደ፡ <hi rend="rubric">ኢየሱስ፡</hi></persName>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i2" corresp="#h2">
                     <locus from="16v" to="25r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa Gabrǝʾel<foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabrǝʾel</persName></foreign></title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 27 stanzas.</note>
                     <incipit xml:lang="gez">
                        <note>The initial stanza seems unusual. It is not included in the available
                           printed editions. Usually the <foreign xml:lang="gez">Malkǝʾa
                              Gabrǝʾel</foreign> begins with the stanza that follows here as the
                           second.</note>
                        <locus from="16v" to="17r"/>
                        <hi rend="rubric">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተፀውዓ፡ ቀዲሙ። ለፀሐይ፡</hi> እምዝክረ፡ ስሙ። <hi rend="rubric">ገብርኤል፡</hi> ኅሩይ፡ ለእግዚአብሔር፡ መልአከ፡ አርያሙ። እምጠባይአ፡ <hi rend="rubric">ሥጋከ፡</hi> ካልዕ፡ ለጠባይ<supplied reason="omitted" resp="SH">ዕ</supplied>ከ፡ አቅሙ። ነፋስ፡ ረቂቅ፡ ወእሳት፡ ቀለሙ። <hi rend="rubric">በሰላመ፡ ገ<pb n="17r"/>ብርኤል፡ መልአክ፡</hi> በላዕለ፡ ማ<hi rend="rubric">ር</hi>ያ<hi rend="rubric">ም</hi>፡ ዘአእረፈ። ከመ፡ እዜኑ፡ ኅዳጠ፡ ወአኮ፡ ትሩፈ።</incipit>
                     <explicit xml:lang="gez">
                        <locus from="24v" to="25r"/><hi rend="rubric">አልቦ፡ እ<add place="interlinear">ም</add>፡ ሰብእ፡</hi> ዘከማየ፡ ዘይቴክዝ፡ ነግሀ፡ ወሠርከ፡ ወአልቦ። እመላእክት፡ ናዛዜ፡ ኅዙናን፡
                        ዘከማከ፡ ወበእንተዝ፡ ኃሠ<pb n="25r"/>ሥኩ፡ አዕሚርየ፡ ኪያከ። <hi rend="rubric">ኦገብርኤል፡
                           ናዝዘኒ፡</hi> ወአስምአኒ፡ ቃለከ፡ ዕሤተ፡ ጸሎትየ፡ ዝንቱ፡ <add place="interlinear">ዘ</add>አቅረብኩ፡ ለከ፡ ኦቅዱስ፡ <hi rend="rubric">ገብርኤል፡</hi> ዕቀበኒ፡ ወአድኅነኒ፡ እመከራ፡
                        ሥጋ፡ ለገብርከ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS13244GabraWald">Gabra Wald<hi rend="rubric">ገብ<sic>ሩ</sic>፡ ወልድ፡ </hi></persName> ወምስለ፡ ጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13280WaldaAma">ወልደ፡ <hi rend="rubric">አማኑኤል፡</hi></persName>
                        <hi rend="rubric">ለዓ<supplied reason="omitted" resp="SH">ለ</supplied>መ፡ ዓለም፡
                           አሜን።</hi>
                     </explicit>
                  </msItem>

                  <msItem xml:id="ms_i3" corresp="#h3">
                     <locus from="25v" to="35r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279"><foreign xml:lang="gez">Malkǝʾa <persName ref="https://betamasaheft.eu/PRS5741Johnthe">Yoḥannǝs
                           Maṭmǝq</persName></foreign>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 28 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#25v"/>
                        <pb n="25v"/>
                        <hi rend="rubric">በስመ፡ እግዚ</hi>አብሔር፡ እሳት፡ በሐቅለ፡ ህሊና፡ ነዳዲ። ወበስመ፡ ማ<hi rend="rubric">ር</hi>ያ<hi rend="rubric">ም</hi>፡ ድንግል መጥበቢተ፡ ዓለም፡ አባዲ።
                        ማኅቶተ፡ ፀዳል፡ <hi rend="rubric">ዮሐንስ። ጽልመተ፡ አበሳ፡ ሰዳዲ፡ ከመ፡ ዕዜኑ፡ ኂሩተከ፡ እዳ፡ ኃጣውዕየ፡
                              <supplied reason="omitted" resp="SH">ይ</supplied>ፍዲ።</hi> በአየረ፡ ሰማይ፡
                           <supplied reason="omitted" resp="SH">ዘ</supplied>
                        <add place="interlinear">ይ</add>ጸርሕ። ቃልከ። አዋዲ።</incipit>
                     <explicit xml:lang="gez">
                        <locus from="34v" to="35r"/><hi rend="rubric">አምኃ፡</hi> ስብሐት፡ አቅረብኩ፡ ለመልክፅከ፡
                        በጽዋዔ፡ አንዘ፡ <supplied reason="omitted" resp="SH">አስተዋድድ፡</supplied> ቃለ፡ መጠነ፡
                        ራብፅ፡ ሱባኤ። ተወከፈኒ፡ <hi rend="rubric">ዮሐንስ፡</hi> ምስለ፡ በርተሎሜዎስ፡ <pb n="35r"/>
                        ቀርነ፡ ጉባዔ። በከመ፡ ተወክፈ፡ እግዚእከ፡ ቅድመ፡ ወንጌላዊት፡ ትንሣኤ። እም፡ ዕደ፡ አሐቲ፡ ብእሲት፡ ጸራይቀ፡ ፪ኤ።
                        ኦቅዱስ፡ <hi rend="rubric">ዮሐንስ፡</hi> ዕቀበኒ፡ ወአድኅነኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገብርከ፡
                           <persName role="owner" ref="https://betamasaheft.eu/PRS13244GabraWald">Gabra Wald<hi rend="rubric">ገብረ፡
                              ወልድ፡ </hi></persName> ወም<supplied reason="omitted" resp="SH">ስ</supplied>ለ፡ ጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13281HayMar">Ḫayla Māryām<hi rend="rubric">ኃይለ፡ ማርያም።</hi></persName></explicit>
                  </msItem>

                  <msItem xml:id="ms_i4" corresp="#h3">
                     <locus from="35v" to="40r"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4960Taabbeyo">Saʾali lana Māryām saʾali lana Māryām ḫaba waldǝki ḫer madhane
     ʿālam</title>
                     <note>The prayer is incomplete and ends abruptly (see <bibl corresp="http://zotero.org/groups/358366/items/I6R8Q66K"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Tasfa1955Saatat"/><title level="m">&lt;hi rend="italics"&gt;ሰዓታት። ዘሌሊት፡ ወዘነግህ። (&lt;/hi&gt;Saʿātāt. Za-lelit wa-za-nagh&lt;hi rend="italics"&gt;, ‘The Book of the Hours. Of the night and of the morning’)&lt;/hi&gt;</title><editor><name>Tasfā Gabra Śǝllāse</name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā Gabra Śǝllāse māttamiyā bet</publisher><date>1954</date><note type="tags"><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note></note><note type="tag">bm:Tasfa1955Saatat</note><note type="tag">Book of Hours</note><note type="tag">Horologium</note><citedRange unit="page">84</citedRange></bibl>).</note>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <locus target="#35v"/>
                        <pb n="35v"/>
                        <hi rend="rubric">ተአብዮ።</hi> ነፍስየ፡ ለእግዚአብሔር፡ ፫ጊዜ፡ በል። ሰአሊ፡ ለነ፡ <hi rend="rubric">ማርያም፡</hi> ሰአሊ፡ ለነ፡ <hi rend="rubric">ማርያም።</hi> ቤዛዊተ፡ ኵሉ፡
                        ዓለም፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ <hi rend="rubric">ሥላሴ፡</hi> ብሂልየ፡
                           ወጠን<sic>ኵ</sic>፡ ዘለኪ፡ ውዳሴ፡ <hi rend="rubric">ማርያም።</hi> እኅቱ፡ ለሙሴ፡ ፫ጊዜ፡
                        በል። እምቅድመ፡ ሰማይ፡ ወምድር፡ ሀለወተኪ፡ ፀሐይ፡ ወወርኅ፡</incipit>
                     <explicit xml:lang="gez">
                        <locus from="34v" to="35r"/>ተንሥኢ፡ <hi rend="rubric">ማርያም።</hi> ተራድእኒ። ይእዜኒ፡
                        ፍጡነ፡ ወዘልፈኒ። <hi rend="rubric">ማርያም። ስም</hi>ኢ፡ ጸሎተነ፡ ወይብጻሕ፡ ቅድሜኪ፡ ገአርነ። ወኢትሚ<choice>
                           <sic>ጥ</sic>
                           <corr resp="SH">ጢ</corr>
                        </choice>፡ ገጸኪ፡ እምኔነ። <hi rend="rubric">ተባርከኪ፡ ነፍስነ፡</hi> በአትሕቶ፡ ክሣድ፡ ወርእስ።
                        ወይገንያ፡ አእጽምቲነ፡ ለእመ፡ ንጉሥ። ለስመ፡ ዚአኪ፡ ነሀብ፡ ቅዱስ።</explicit>
                  </msItem>

                  <msItem xml:id="ms_i5" corresp="#h4">
                     <locus from="45r" to="56v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾa Giyorgis<foreign xml:lang="gez">Malkǝʾa
                              <persName ref="https://betamasaheft.eu/PRS4585Georgeo">Giyorgis</persName></foreign></title>
                     <textLang mainLang="gez"/>
                     <note>The work comprises 50 stanzas.</note>
                     <incipit xml:lang="gez">
                        <locus target="#45r"/>
                        <pb n="45r"/>
                        <hi rend="rubric">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ፡ ዘያሜኒ፡ ኵሎ፡ ወ</hi>ዘያስተሴፉ።
                        ጥዑመ፡ ዜና፡ <space reason="rubrication" unit="chars" quantity="1"/>ዮ<space reason="rubrication" unit="chars" quantity="1"/>ጊ<space reason="rubrication" unit="chars" quantity="1"/>፡ ለሀሊበ፡ እጐል፡ ሱታፉ። ሰላምከ፡
                           <hi rend="rubric">ወረድኤትከ፡ በላዕሌየ፡ <add place="interlinear">ያ</add>ዕርፉ። አኮ፡
                           ለምዕር፡ ዳዕሙ፡ ለዝላፉ።</hi></incipit>
                     <explicit xml:lang="gez">
                        <locus from="56r" to="56v"/><hi rend="rubric">ተወከፍ፡</hi>
                        <del rend="strikethrough">ዘንተ፡</del> እምኔየ፡ ዘንተ፡ <add place="interlinear">ስብሐታተ፡</add> ወይባቤ። ከመ፡ ፄና፡ ስኂን፡ ወመዓዘ፡ ከርቤ። <hi rend="rubric">ጊዮርጊስ፡
                           ኵነኒ፡</hi> በኪዳንከ፡ ዓቃቤ። እስመ፡ አንተ፡ ምስካይየ፡ በጊ<choice>
                           <sic>ዘ</sic>
                           <corr resp="SH">ዜ</corr>

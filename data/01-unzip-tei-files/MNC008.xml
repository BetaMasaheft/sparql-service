                     <incipit xml:lang="gez">
                        <locus target="#56v"/>
                        <hi rend="rubric">ትባርክ፡ ነፍስየ፡ ለእግዚአብሕር፡</hi>ፀሐይ፡ ዘልዳ፡ ኮከብ፡ ዘልዳ፡ ንጉሥ፡ ነአ፡ <hi rend="rubric">ጊዮርጊስ።</hi> ነዓ፡ <hi rend="rubric">ጊዮርጊስ፡</hi> ሰማዕተ፡ <hi rend="rubric">ኢየሱስ፡ ክርሰቶሰ፡</hi> ወነዓ፡ ፍቁርየ፡ ዘልዳ፡ ንጉሥ፡ ፫ጊዜ፡ በል፡ ዘሐረጸከ፡
                        ዱድያኖሰ። ወወገረከ፡ ደብረ፡ ዒድራስ። ዘዘረወከ፡ በነፋስ፡ ሰላም<supplied reason="omitted" resp="SH">፡</supplied> ለከ፡ <hi rend="rubric">ጊዮርጊስ።</hi></incipit>
                     <explicit xml:lang="gez">
                        <locus from="61v" to="62r"/><hi rend="rubric">ስብሐት፡</hi> ለአብ፡ ወ<add place="interlinear"> ወ</add>ልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘአንበሩ፡ ብየ፡ አክሊለ፡ ሞገሠ፡ መዘምረ፡
                        እኩን፡ <hi rend="rubric">ለጊዮርጊስ፡</hi> ኀያል፡ መስትጋድል፡ ኀያል፡ ኮከበ፡ ክብር፡ ኀያል፡ ገባሬ፡
                        ተአምር ፡ ጊዮ<hi rend="rubric">ርጊስ፡</hi> ቅዱ<choice>
                           <sic>ሰ</sic>
                           <corr resp="SH">ሱ</corr>
                        </choice>፡ ለእግዚአብሔር፡ በእንተ፡ <hi rend="rubric">ጊዮርጊስ፡</hi> ሰማዕትከ፡ ምህላነ፡ ስማ<pb n="62r"/>ዕ፡ በዕዝንከ፡ ፫ጊዜ፡ በል፡ ኦአምላከ፡ ጊዮ<hi rend="rubric">ርጊስ፡</hi>
                        <del rend="strikethrough">አምላከ፡</del> ዕቀበነ፡ ዕመከራ<supplied reason="omitted" resp="SH">፡</supplied> ሥጋ፡ ወነፍስ፡ <hi rend="rubric">ኦአብ፡ በእን<supplied reason="omitted" resp="SH">ተ</supplied>፡ ኢየሱስ፡ ር<supplied reason="omitted" resp="SH">ድ</supplied>አነ፡ ክር</hi><supplied reason="omitted" resp="SH">ስ</supplied>ቶስ፡ ለአቡኩ፡ ኄር፡ ተማኀፀነ፡ መንፈሰ፡ አብ፡

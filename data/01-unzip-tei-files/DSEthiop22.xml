                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Twentieth-century script.</seg>
                        <date notBefore="1900" notAfter="1960">20th century script.</date>
                        <seg type="ink">Black, red</seg>
                        <desc>Careful but irregular; by a poorly trained scribe.
                           Written in very large letters. The scribe hardly
                           distinguishes the characters ስ and ሰ and writes
                           both as ሰ.
                           The same hand as <ref type="hand" corresp="https://betamasaheft.eu/DSEthiop21#h1">Hand 1 of MS DS Ethiop. 21</ref>.
                        </desc>

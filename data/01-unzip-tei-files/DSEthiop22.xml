               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="2r">Fols 2r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi> ፩አምላክ፡ በእንተ፡ ትምህርተ፡ ኅቡአት
                        <supplied reason="omitted" resp="DN">፡</supplied>
                        ቅ<add place="above"><hi rend="rubric">ድ</hi>
                        </add>መ፡ <sic resp="DN">ዘትትነገረ፡ </sic> እምጵርሰ፡ ፎራ፡ ለምእመናን፡ ኅቡአት፡
                        ትምህርተ፡ ህቡአትሰ ከመዝ፡ ንግር፡ ዘቅድመ፡ ሀሎ፡ ወይሄሉ፡ ዘመጽአ፡ ዘሐመ፡ ወሞተ፡
                        ወተቀብረ፡ ወተንሥአ፡ ፃዕረ፡ ዘሞት፡ ፈትሐ፡ ወዘእሙታን፡ ተንሥአ<hi rend="rubric">፨</hi>
                        ፩ኢኮነ፡ ባሕቲቱ፡ ከዊኖ፡ ሰብእ፡ ዘ<add place="above">
                           <hi rend="rubric">እ</hi>
                        </add>መንፈሰ፡ ቅዱሰ፡ ሥጋሁ፡ ለአዳም፡ ምሰለ፡ ነፍሱ፡ ዘኢኃደ<cb n="b"/>ገ፡
                        ነፍሶ፡ ውሰተ፡ ሞት፡ ዘበመንፈሰ፡ ለአዳም፡ ፀወኖ፡ ወአሕየዎ፡ ፪<hi rend="rubric">፨</hi>
                     </incipit>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</title>
                     <textLang mainLang="gez"/>
                     <explicit xml:lang="gez">አንተ፡ ዘእምሰማያት፡ ሰላመከ፡ ከልል ላዕለ፡ ዘኵልነ፡ ነፍስ፡ ወንብረተነኒ፡ ዘዝዓለም፡ በሰላም፡ ጸጉ። ለንግሥሠ፡ ዛቲ፡ ምድር፡ ሰላመ፡ ሀቦ፡ በቅዱስ፡
                        ስምከ። ሀብ፡ ምክረ፡ ለመኳንንተ፡ አሕዛብ፡ አግዋረነ፡ በአተነ፡ ወጸበተነ፡ በሰላም፡ ዕቀብ። ከመ፡ በኅዱዕ፡ ወበጽምው፡ ሕይወተ፡ እንዘ፡ ነሐየ፡ በኵሉ፡ አምልኮ፡ ሠናይ፡
                        በፍሪሃ፡ እብሔር፡ ወበኂሩት ንረከብ፡ በክርስቶስ፡ ዘቦቱ፡ ለከ፡ ምስሌሁ፡ ወምስለ፡ ቅዱስ፡ መንፈሰብሐት፡ ወእኂዝ ይእዜነ፡ ወዘልፈኒ፡ ለዓለመ፡ ዓለም አሜን።</explicit>
                  </msItem>

               </msContents>


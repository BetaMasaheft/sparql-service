                        <msItem xml:id="ms_i2">
                          <locus from="119r"/>
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT3309Qerellos">Qerǝllos</title>
                          <textLang mainLang="gez"/>
                          <msItem xml:id="ms_i2.1">
                            <locus from="119r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#Prosphoneticus1">Qerǝllos: Prosphoneticus to the Emperor Theodosius II on the right faith (same as https://betamasaheft.eu/LIT3310Prosph)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ነገር፡ ዘጸሐፈ፡ ቅዱስ፡ ቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ ለታዶስዮስ፡ ንጉሥ፡ በእንተ፡ ሃይማኖት፡
                              ርትዕት፡ ዘበእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘመንገለ፡ ሰብእ፡ ክቡር፡ ወልዑል፡ ወኢይትአየይ፡ ምስለ፡
                              ካልእ፡ በልዕልናሁ፡ <add place="margin">ቴዎዶስዮስ፡ ወሐሙሁ፡ <sic>ዋሊድያኖስ፡</sic></add>
                            </incipit>

                          <msItem xml:id="ms_i2.1.1">
                            <locus from="131v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#Prosphoneticus2">Qerǝllos: Prosphoneticus to the Princesses Arcadia and Marina on the right faith (same as https://betamasaheft.eu/LIT3311Prosph)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ስነ፡ ዜና፡ ዘዓለም፡ ወምክሕ፡ ዘቅዱሳት፡ አብያተ፡ ክርስቲያናት፡ ዘመድኅነ፡ ኵልነ፡ ኢየሱስ፡ ክርስቶስ፡ ለሰምዮ፡ ኵሉ፡
                              ሰብእ፡ በአማን፡ ኪያክን፡ ቅዱሳት፡ ወንጽሓት፡ መራዕዊሁ፡ አርቃዲያ፡ ወማሪና፡ ፪ አኃት፡ ክቡራት፡ ወመፍቀርያተ፡
                              እግዚአብሔር፡
                            </incipit>
                          </msItem>
                          <colophon xml:id="coloph1" xml:lang="gez">
                            <locus target="#157v"/>
                            ተፈጸመ፡ ነገር፡ ዘተጽሕፈ፡ እምቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘለእስክንድርያ፡ ለመምለኬ፡ ሠናይ፡
                            ንጉሥ፡ ቴዎዶስዮስ።
                          </colophon>
                          </msItem>
                          <msItem xml:id="ms_i2.2">
                            <locus from="158r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#Dialogue">Qerǝllos: Dialogue on the Unity of Christ (same as https://betamasaheft.eu/LIT3312Unity)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ግጻዌ፡ ድርሳን፡ ዘቅዱስ፡ ቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ ከመ፡ አሐዱ፡ ክርስቶስ።
                            </incipit>
                            <colophon xml:id="coloph2" xml:lang="gez">
                              <locus target="#178v"/>
                              ተፈጸመ፡ በረድኤተ፡ እግዚአብሔር፡ ለመምህር፡ ዐቢይ፡ ወክቡር፡ በውስተ፡ ሊቃውንት፡ ቅዱስ፡
                              ቄርሎስ። ተዋሥኦቱ፡ ምስለ፡ ጰላድዮስ፡ በእንተ፡ ርትዕት፡ ሃይመኖት፡ ዘበእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ።
                            </colophon>
                            <note>The interlocutors are <foreign xml:lang="gez">ቄርሎስ፡</foreign>
                          and <foreign xml:lang="gez">ጰላድዮስ፡</foreign>.</note>
                          </msItem>
                          <msItem xml:id="ms_i2.3">
                            <locus from="180r"/>
                            <title type="complete" xml:lang="en">Various homilies and extracts</title>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i2.3.1">
                              <locus from="180r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByTheodotus1">Qerǝllos: Homily by Theodotus of Ankyra (same as https://betamasaheft.eu/LIT1036Agains)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘቴዎዶጦስ፡ ጳጳስ፡ እንቈራ፡ ዘገላትያ። ድርሳን፡ ዘደረሰ፡ በበዓለ፡ ዮሐንስ፡ ወንጌላዊ፡ በእፊሶን፡ በሰሙኑ፡
                                ለሠረቀ፡ ሐምሌ፡ በጽርዕ። በከመ፡ ይፌውሶ፡ ዓቃቤ፡ ሥራይ፡ ለሥጋ፡ ከማሁ፡ ካህናትሂ፡ ለነፍስ፡
                                መፈውሳን፡ እስመ፡ ጌጋይ፡ ደዌ፡ ነፍስ፡ ውእቱ፡ ወተጐናዲዮ፡ እስከ፡ ለሞት፡ ይበጽሕ፡ በእንተዝ፡
                                ሠርዓት፡ ጸጋ፡ መንፈስ፡ ፈውሰ፡ ነፍስ፡ ለቅድስት፡ ክህነት።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.2">
                              <locus from="180v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByCyril1">Qerǝllos: Homily by Cyril of Alexandria for the feast of John the Apostle (same as https://betamasaheft.eu/LIT3328Cyril)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ ድርሳን፡ ዘደረሰ፡ በይእቲ፡ ዕለት። በበዓለ፡ ዮሐንስ፡ ወንጌላዊ፡
                                በሰመኑ፡ ለሠርቀ፡ ሐምሌ፡ በቅድመ፡ ኵሉ፡ ጕባኤ፡ ጳጳሳት። እምክብሮሙ፡ ለቅዱሳን። ወእምስብሐቶሙ፡
                                ይውሕድ፡ ኵሉ፡ ነገር፡ እስመ፡ ኮነ፡ ብርሃነ፡ ውስተ፡ ዓለም፡ ወነገሮሙ፡ ነገረ፡ ሕይወት፡ በከመ፡ ጽሑፍ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.3">
                              <locus from="181r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyBySeverus">Qerǝllos: Homily by Severus of Synnada (same as https://betamasaheft.eu/LIT3313Severus)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ድርሳን፡ ዘደረሰ፡ ሳዊሮስ፡ ጳጳስ፡ ዘሀገረ፡ ሲኖዶን፡ ዘፍርግያ፡ በቤተ፡ ክርስቲያን፡ ዘስማ፡ ማርያ፡ በኤፌሶን፡
                                በሰንበተ፡ ክርስቲያን፡ አመ፡ ፲ወ፩ ለሠርቀ፡ ሐምሌ፡ በጽርዕ። የሐምም፡ ሥጋየ፡ ወኢተምህሮ፡ ልሳን፡
                                ያቀውመኒ፡ ለተናግሮ፡ አላ፡ ባሕቱ፡ ተምኔተ፡ ፍቅርክሙ፡ ወጸሎትክሙ፡ ለቅዱሳን፡ አበው፡ ያሴስል፡
                                ሕማመ፡ ወይጼጉ፡ ኃይለ፡ በእንቲአሁ፡ አነኒ፡ አስተዔግሥ፡ ሕማመ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.4">
                              <locus from="181v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByAcacius">Qerǝllos: Homily by Acacius of Melitene (same as https://betamasaheft.eu/LIT3314Acacius)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ድርሳን፡ ዘአቃቅዮስ፡ ጳጳስ፡ ዘሀገረ፡ ምልጢር፡ ዘአርማንያ፡ ዘደረሰ፡ በይእቲ፡ ዕለት። ነጺርየ፡ ፍቁራንየ፡ ዘንተ፡
                                ብሩሀ፡ ወመንፈሳዌ፡ ዘቅድስት፡ ሲኖዶስ፡ ጉባኤ፡ ትውክልት፡ ወረአድሂ፡ ይመጽአኒ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.5">
                              <locus from="182r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByJuvenal">Qerǝllos: Homily by Juvenal of Jerusalem (same as https://betamasaheft.eu/LIT3315Juvenal)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘዮብናሊዮስ፡ ጳጳስ፡ ዘኢየሩሳሌም፡ በይእቲ፡ ዕለት፡ ዘደረሰ። ነአኵቶ፡ ለፀጋዊ፡ ዓበይት፡ እግዚአብሔር፡
                                ለዘመጠነዝ፡ አቢያተ፡ ሠናይተ፡ ጸገወነ፡ ወእምይእዜሂ፡ ዘየዐቢ፡ ይጼግወነ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.6">
                              <locus from="182v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByCyril2">Qerǝllos: Homily by Cyril of Alexandria (same as https://betamasaheft.eu/LIT3329Cyril)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ በይእቲ፡ ዕለት። መፍትውሰ፡ ተአኪለነ፡ በእለ፡ ቀደሙ፡
                                መምህራን፡ ትምህርተ፡ ወዘቅዱሳን፡ ማየ፡ ተረዊየነ፡ ናክብሮ፡ በአርምሞ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.7">
                              <locus from="183v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByRheginus">Qerǝllos: Homily by Rheginus of Constantia (same as https://betamasaheft.eu/LIT3316Rheginus)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                              ዘርጊኖስ፡ ጳጳስ፡ ዘቍስጥንጥንያ፡ ዘቆጵሮስ፡ በይእቲ፡ ዕለት። ሊተሰ፡ አፍተወኒ፡ አርምሞ፡ ወበአርምሞ፡ አክብሮሙ፡
                              ለአበው፡ ከመ፡ ኢይሬሲ፡ በትዝልፍት፡ ነገርየ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.8">
                              <locus from="183v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByCyril3">Qerǝllos: Homily by Cyril of Alexandria (same as https://betamasaheft.eu/LIT3330Cyril)</title>
                              <textLang xml:lang="gez"/>
                              <incipit xml:lang="gez">
                                ዘቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ በይእቲ፡ ዕለት። ኃይለ፡ ፍቅር፡ ዘመንገለ፡ እግዚአብሔር፡
                                ተመሐርነ፡ እምቅድሳት፡ መጻሕፍት፡ ወውእቱኒ፡ መድኃኒነ፡ መሐረነ፡ እንዘ፡ ይብል፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.9">
                              <locus from="184v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByEusebius">Qerǝllos: Homily by Eusebius of Heracleia (same as https://betamasaheft.eu/LIT3317Eusebius)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘአውሴብዮስ፡ ጳጳስ፡ ዘኤራቅልያ፡ ዘጳንጦስ፡ በይእቲ፡ ዕለት። አጠብዕ፡ አነሂ፡ እምዘ፡ ሀሎ፡ ላዕሌየ፡ ቃላት፡
                                እለ፡ ተመሐርኩ፡ እመንፈሳዊያን፡ እሎንተ፡ መምህራነ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.10">
                              <locus from="184v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByTheodotus2">Qerǝllos: Homily By Theodotus of Ankyra (same as https://betamasaheft.eu/LIT3318Theodo)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                በይእቲ፡ ዕለት። ብሩሃ፡ ወፍሡሐ፡ እሬእዮ፡ ለዝጉባኤ፡ ወበገድለ፡ ሃይማኖት፡ ጽኑዓ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.11">
                              <locus from="185v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByFirmus">Qerǝllos: Homily By Firmus of Caesarea (same as https://betamasaheft.eu/LIT3319Firmus)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘፍርሞስ፡ ጳጳስ፡ ዘቂሳርያ፡ ዘቀጰዶቅያ፡ በይእቲ፡ ዕለት፡ እለ፡ ይመውዑ፡ በገድሎሙ፡ እምህየ፡ ያጠርዩ፡
                                ትፍሥሕቶሙ፡ እስመ፡ ተንሥአ፡ ፀራዊ፡ ላዕሌነ፡ አላ፡ ተመዊኦ፡ ሀለፈ፡ ነበበ፡ ፍኖተ፡ ከንቱ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.12">
                              <locus from="185v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#LetterOfTheCouncil">Qerǝllos: Letter of the Council of Ephesus to John of Antioch (same as https://betamasaheft.eu/LIT3320Letter)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                መጽሐፈ፡ ሲኖዶስ፡ ጕባኤ፡ ዘጸሐፉ፡ ኵሎሙ፡ ጳጳሳት፡ ለዮሐንስ፡ ጳጳስ፡ ዘአንጢዮኪያ፡ ቅድስት። እንተ፡
                                እምኵሉ፡ ዓለም፡ ሲኖዶስ፡ ጉባኤ፡ ለክርስቶስ፡ ጳጳስ፡ ዮሐንስ፡ ዘአንጢያኪያ፡ ክቡራን፡ ወዝኁራን፡ ነገሥትነ፡
                                አዘዙ፡ በትእዛዞሙ፡ ክቡር፡ ከመ፡ ዘኢበጽሐ፡ በእድሜ፡ ዘአደሙ፡ በቅድስት፡ ዛቲ፡ ጉባኤ፡ ሲኖዶስ፡ ኢአሐተ፡
                                ኢይረክብ፡ ኢኀበ፡ እግዚአብሔር፡ ወኢኀበ፡ ሰብእ፡ ፈውስ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.13">
                              <locus from="185v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyOfCyril4">Qerǝllos: Homily of Cyril of Alexandria (same as https://betamasaheft.eu/LIT5622HomilyCyrilJohnMiyazya)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘቄርሎስ፡ ቅዱስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ ድርሳን፡ ዘደረሰ፡ በቤተ፡ ዮሐንስ፡ መጥመቅ፡ አመ፡
                                ፳ወ፰ ለሚያዝያ፡ በዕለተ፡ ሰንበተ፡ ክርስቲያን። በዘተደመራ፡ አብያተ፡ ክርስቲያናት፡ ዘጽላሕ፡ ምስለ፡ እለ፡
                                እስክንድርያ፡ ወምስለ፡ ኵለሄ፡ እለ፡ በአምልኮ፡ ሠናይ፡ ሕይው፡ ወዘቅዴሳት፡ መጻሕፍት፡ ቦሙ፡ ጥንቃቄ፡
                                አእምሮ፡ ምድረ፡ ፍትወት፡ ይሰምዮሙ፡ ነቢይ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.14">
                              <locus from="186r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#LetterOfJohn">Qerǝllos: Letter of John of Antioch to Cyril of Alexandria (same as https://betamasaheft.eu/LIT3321Letter)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                መጽሐፍ፡ ዘጸሐፈ፡ ዮሐንስ፡ ጳጳስ፡ ዘአንጢዮኪያ፡ ለቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ለእለ፡ እስክንድርያ፡ ለእግዚእየ፡
                                ለመፍቀሬ፡ እግዚአብሔር፡ ቅዱስ፡ ወኅቡረ፡ ክህነት፡ ዘቄርሎስ፡ ዮሐንስ፡ በእግዚእ፡ ፍሥሓ፡ ቅድመ፡ በትእዛዞሙ፡
                                ለምሉካን፡ ነገሥት፡ ትእዛዘ፡ ጉባኤ፡ ሲኖዶስ፡ ዘክቡራን፡ ጳጳሳት፡ በገንዜ፡ ሀገር፡ አፍሶስ፡ ይትጋብኡ፡ በእንተ፡
                                ነገረ፡ ቤተ፡ ክርስቲያን፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.15">
                              <locus from="186v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#LetterOfCyril">Qerǝllos: Letter of Cyril of Alexandria to John of Antioch (same as https://betamasaheft.eu/LIT3322Letter)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                መጽሐፍ፡ ዘጸሐፈ፡ ቄርሎስ፡ ሊቀ፡ ጳጳሳት፡ ዘእለ፡ እስክንድርያ፡ ለዮሐንስ፡ <sic>ዘአጥዮኪያ፡</sic>
                                ለእግዚእየ፡ ፍቁር፡ ወእኁየ፡ ወኅቡረ፡ ካህንየ፡ ለዮሐንስ፡ ዘአንጦኪያ፡ ጳጳስ፡ ቄርሎስ፡ በእግዚእ፡ ፍሥሓ፡
                                ጳጳስ፡ እለ፡ እስክንድርያ፡ ይትፌሥሑ፡ ሰማያት፡ ወትትኃሠይ፡ ምድር፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.16">
                              <locus from="187v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByEpiphanius">Qerǝllos: Homily of Epiphanius of Cyprus (same as https://betamasaheft.eu/LIT1267Dersan)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ድርሳን፡ ዘኤጲፋንዮስ፡ ጳጳስ፡ ዘሀገረ፡ ቆጵሮስ፡ በእንተ፡ ሃይማኖት፡ ዘንጽሕት፡ ርግብ፡ ወቅድስት፡ ድንግል፡ ዘይእቲ፡
                                ቤተ፡ ክርስቲያን፡ ተአምን፡ እግዚአብሔር፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ። አብ፡ ፍጹም፡ ወወልድ፡ ፍጹም፡
                                ወመንፈስ፡ ቅዱስ፡ ፍጹም፡ ኅቡረ፡ ህላዌ፡ ሥላሴ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.17">
                              <locus from="189r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#SymbolByEpiphanius">Qerǝllos: Symbol of faith by Epiphanius of Cyprus (same as https://betamasaheft.eu/LIT1266Dersan)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ድርሳን፡ ዘኤጲፋንዮስ፡ ጳጳስ፡ ዘቆጵሮስ፡ በእንተ፡ ሥላሴ፡ ፍካሬ፡ ነአምን፡ በአሐዱ፡ እግዚአብሔር፡ አብ፡ አኀዜ፡
                                ኵሉ፡ ለኵሉ፡ ዘያስተርኢ፡ ወዘኢያስተርኢ፡ ገባሪ።
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.18">
                              <locus from="189v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyByProclus">Qerǝllos: Homily by Proclus of Cyzicus, Patriarch of Constantinople (same as https://betamasaheft.eu/LIT3323Proclus)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ድርሳን፡ ዘጵርቅሎስ፡ ጳጳስ፡ ዘሀገረ፡ ቂዝቆስ፡ ዘደረሰ፡ በቍስጥንጢኒ፡ ጶሊስ፡ በበዓለ፡ ጌና፡ በእንተ፡ ትስብዕቱ፡
                                ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ ሀሎ፡ ናስጦርስ፡ ዕልው፡ አመ፡ ይስእርዎ፡ እንተ፡ ድንግል፡ በዓል፡ ዮም።
                                ልሳነነ፡ አኃውየ፡ ውስተ፡ ውዳሴ፡ ትጼውዕ፡ ወዛቲኒ፡ ዕለት፡ ትከውነነ፡ መርሐ፡ መድኃኒት፡ ለእለ፡ ተጋባእነ፡ ወአማን፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.19">
                              <locus from="191r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyBySeverianus">Qerǝllos: Homily by Severianus of Gabala (same as https://betamasaheft.eu/LIT3324Severi)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ዘሳዊርያኖስ፡ ጳጳስ፡ ዘብሔረ፡ ገበሎን፡ በእንተ፡ ሃይማኖት፡ ዘሥላሴ፡ ዘደረሰ፡ በጸሎት፡ እምድኅረ፡ ተነበ፡ ወንጌል። አቃቤ፡
                                ሥራይ፡ ይመስል፡ ዘቤተ፡ ክርስቲያን፡ መምህር፡ ዘብዙኅ፡ ወብዑድ፡ ሕማማት፡ አጥረየ፡ ፈውስ፡ ወለለ፩ ዘሐመ፡
                                በሐሳበ፡ ሕማሙ፡ ይሁብ፡ ፈወሰ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.20">
                              <locus from="193v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#SymbolByGregory">Qerǝllos: Symbol of faith by Gregory of Neocaesaria (same as https://betamasaheft.eu/LIT3325Gregory)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                በእንተ፡ ሃይማኖቱ፡ ለቅዱስ፡ ጎርጎርዮስ፡ ጳጳስ፡ ዘኒዎቂሳርያ፡ ሀገር፡ በእንተ፡ ሃይማኖቱ፡ ክሥተት፡ ሎቱ፡ ፩ እግዚአብሔር፡
                                ቀዳማይ፡ ወልድ፡ ቃል፡ ሕያው፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.21">
                              <locus from="194r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyOnMelchizedek1">Qerǝllos: First homily by Cyril of Alexandria on Melchizedek (same as https://betamasaheft.eu/LIT3326Melchiz1)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                በእንተ፡ መልከ፡ ጼዴቅ፡ ይቤ፡ ጳውሎስ፡ ዝመልከ፡ ጼዴቅ፡ ንጉሠ፡ ሳሌም፡ ካህን፡ ዘእግዚአብሔር፡ ልዑል፡
                                ዘተራከቦ፡ ለአብርሃም፡ ተመይጦ፡ እምኀበ፡ ይቀትሎሙ፡ ለነገሥት፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.22">
                              <locus from="195r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#HomilyOnMelchizedek2">Qerǝllos: Second homily by Cyril of Alexandria on Melchizedek (same as https://betamasaheft.eu/LIT3327Melchiz2)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                በእንተ፡ መልከ፡ ጼዴቅ፡ እለ፡ ይለምዱ፡ በስራኅ፡ ተድላዝ፡ ዓለም፡ ወብዝኃ፡ ብዕሎሙ፡ ይሠርሁ፡ ወይትፌሥሑ፡
                                በሕቁ፡ በብዝኃ፡ ዕንቆሙ፡ ክቡር፡ ዘብሔረ፡ ሕንደኬ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.23">
                              <locus from="196v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#TreatiseOnMelchizedek">Qerǝllos: Treatise on Melchizedek (same as https://betamasaheft.eu/LIT3332Melchiz)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                ይነግር፡ ብእሲ፡ ልሂቅ፡ ወጠቢብ፡ ለሕገ፡ እግዚአብሔር፡ በእንተ፡ መልከ፡ ጼዴቅ፡ ጠይቆ፡ ይነግር፡ እስመ፡ ብእሲ፡
                                ውእቱ፡ እምሕዝቡ፡ ለካም፡ መልከ፡ ጼዴቅ፡ ወባሕቲቱ፡ ተረክበ፡ ውስተ፡ ሕዝቡ፡ ወልድ፡ ቅዱስ፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i2.3.24">
                              <locus from="197r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3309Qerellos#TreatiseOn318Bishops">Qerǝllos: Small treatise on 318 Bishops of Nicaea (same as https://betamasaheft.eu/LIT3333Treatise)</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                በእንተ፡ ፫፻፲ወ፰፡ ቅዱሳን፡ ኤጲስ፡ ቆጶሳት፡ ዘበሀገረ፡ ነቅያ፡ ተጋብኡ፡ ሲኖዶስ፡
                              </incipit>
                            </msItem>
                          </msItem>
                          <colophon xml:id="coloph3" xml:lang="gez">
                            <locus target="#198r"/>
                            ተፈጸመ፡ ጽሕፈተ፡ ድርሳን፡ ዘቅዱስ፡ ቄርሎስ፡ በረድኤተ፡ እግዚአብሔር፡ ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን።
                          </colophon>
                        </msItem>

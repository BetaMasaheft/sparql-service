      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ ክልኤ፨</l>
                  <l n="2">እምከርሠ፡ አሐቲ፡ እምከ፡ ዘኀረየከ፡ በኵረ፡ ትንሣኤ፨</l>
                  <l n="3">ወልደ፡ ማርያም፡ ዜናከ፡ አመ፡ ተሰምዐ፡ ውስተ፡ ጉባኤ፨</l>
                  <l n="4">እምነጽሮ፡ ዝኒ፡ መጻእኩ፡ ውስተ፡ ደብርከ፡ እንዘ፡ እበውእ፡ ሱባዔ፨</l>
                  <l n="5">እስመ፡ ውስተ፡ ደብር፡ ረከብኩ፡ ኪያከ፡ ረዳኤ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምዕንቈ፡ ባሕርይ፡ አደም፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ካዕበ፡ ዘጽላሌሁ፡ ጸሊም፨</l>
                  <l n="3">ወልደ፡ ማርያም፡ ፀሓይ፡ ብርሃነ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="4">ኢይትከሀል፡ ምንተ፡ ነጽሮቶ፡ ለክበበ፡ ገጽከ፡ ዮም፨</l>
                  <l n="5">እስመ፡ ዐይነ፡ ኵሉ፡ የሐይድ፡ ገጽከ፡ ግሩም፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለመልክእከ፡ ጸዳለ፡ ፀሓይ፡ ዘከለሎ፨</l>
                  <l n="2">ወፀሓየ፡ ራማ፡ ይመስል፡ ለመልክእከ፡ ጸዳሎ፨</l>
                  <l n="3">ወልደ፡ ማርያም፡ ሊቅ፡ እግዚአ፡ ምሕረት፡ ወተሣህሎ፨</l>
                  <l n="4">ዕቀበኒ፡ ወአድኅነኒ፡ እምረሀበ፡ ሥጋ፡ ተሀጕሎ፨</l>
                  <l n="5">እስመ፡ እግዚእየ፡ አንተ፡ ዘተአምር፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">በሊቃውንቲሃ፡ ለኤዶም፡ ደብረ፡ ዘመዶ፡ ወረደ፨</l>
                  <l n="2">ጠለ፡ መንፈስ፡ ቅዱስ፡ ኤርሞን፡ ዘይትሞጣሕ፡ ነደ፨</l>
                  <l n="3">ወልደ፡ ማርያም፡ ድንግል፡ እስመ፡ ረሰይካ፡ ዐጸደ፨</l>
                  <l n="4">ወለዘተናገርኩ፡ ለከ፡ ቃለ፡ ቅዳሴ፡ ኢትሬሰየኒ፡ ባዕደ፨</l>
                  <l n="5">አኮኑ፡ ረሰይኩ፡ ኪያከ፡ ዘመደ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">የበበት፡ ምዕረ፡ ደብረ፡ ዘመዶ፡ ንግሥት፨</l>
                  <l n="2">ወአጽሐሰት፡ ካዕበ፡ በአእዳዊሃ፡ ቅዱሳት፨</l>
                  <l n="3">ወልደ፡ ማርያም፡ ድንግል፡ እንዘ፡ ይጌሥጾ፡ ለሞት፨</l>
                  <l n="4">አምጣነ፡ ላቲ፡ ተንሥአ፡ በሥልጣኑ፡ እምደብረ፡ ጎብስጌ፡ መሬት፨</l>
                  <l n="5">እለ፡ ተጋብኡ፡ በስቴታ፡ ዘሥጋ፡ ፈያት፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">መፍትው፡ ንንበር፡ ለደብረ፡ ዘመዶ፡ በውስቴታ፨</l>
                  <l n="2">አምጣነ፡ ዛቲ፡ ይእቲ፡ ኢየሩሳሌም፡ ወጎልጎታ፨</l>
                  <l n="3">እምከመ፡ ቀዳሚ፡ ነበረት፡ ሥዕለ፡ ማርያም፡ ጊዜ፡ ምንግሥታ፨</l>
                  <l n="4">ከመ፡ ታልኅቅ፡ ሕዝበ፡ ካህናቲሃ፡ እንዘ፡ ታሰቲ፡ ረድኤታ፨</l>
                  <l n="5">ወኢየሩሳሌም፡ ደብረ፡ ዘመዶ፡ ለዓለም፡ ኅንብርታ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ስብሐት፡ ለከ፡ ወልደ፡ ማርያም፡ በኍልቈ፡ መላእክት፡ ዘኤርሞን፨</l>
                  <l n="2">ስብሐት፡ ለከ፡ ወልደ፡ ማርያም፡ በኍልቈ፡ ከዋክብት፡ ብሩሃን፨</l>
                  <l n="3">ስብሐት፡ ለከ፡ ወልደ፡ ማርያም፡ በኍልቈ፡ ነቢያት፡ ወጻድቃን፨</l>
                  <l n="4">ወአስትየኒ፡ ንስቲተ፡ እምነ፡ ስብሐቲከ፡ ወይን፨</l>
                  <l n="5">እስመ፡ ምሉእ፡ ስብሐቲከ፡ በኵሉ፡ መካን፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ወልደ፡ ማርያም፡ እግዚእ፡ ኀጢኣተ፡ ዓለም፡ ደምሳሴ፨</l>
                  <l n="2">ያስተፌሥሑከ፡ ሕዝብ፡ ኤልያስ፡ ወሙሴ፨</l>
                  <l n="3">በስብሐት፡ ወበውዳሴ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሰላም፡ ለከ፡ ወልደ፡ ማርያም፡ መልአክ፡ እንተ፡ ለበስከ፡ ሕይወተ፨</l>
                  <l n="2">ለዘአወፈይኩከ፡ ዮም፡ እንግዳ፡ ድርሰተ፨</l>
                  <l n="3">ነዳየ፡ ሥጋ፡ ቅድሜከ፡ ኢይትበሀል፡ ምንተ፨</l>
                  <l n="4">መዓልተ፡ ወሌሊተ፡ ዕቀበኒ፡ አንተ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
               <msContents>
                  <summary>Prayer of the Blessed Virgin Mary at Golgotha, ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ዘሰኔ፡ ጎልጎታ፡, Introductory Rite from Mu'allaqa for the reading of the Miracles of Mary</summary>
                  <textLang mainLang="gez"/>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="25v" facs="003">Fols 1r–25v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="26r" to="35r" facs="028">Fols 26r–35r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1968Mashaf">Maṣḥafa śǝrʿāt
                                                  za-waṣʾa ʾǝm-manbara Mārqos ḥawāryā ʾǝm-makāna
                                                  maʿāllǝqā</title>
                  </msItem>

                  <msItem xml:id="ms_i3">
                    <locus from="36r" to="38v" facs="038">Fols 36r–38v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5718MiracleCyriacus">Miracle of
                                                  St Cyricus (Qirqos): St. Cyricus, St. Julitta, and
                                                  the governor ʾArmātyānos</title>
                  </msItem>

                  <msItem xml:id="ms_i4">
                     <locus from="38v" to="42r" facs="041">Fols 38v–42r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat
                                                  za-wald</title>
                  </msItem>

               </msContents>

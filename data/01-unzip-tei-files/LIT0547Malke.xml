      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0547</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ስቁል፡ ለቤዛ፡ አሐዱ፡ አዳም፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እጽሐፍ፡ በልሳንየ፡ ቀለም፨</l>
                  <l n="3">ግብጻዊ፡ ፊቅጦር፡ እምከመ፡ ወጠንኩ፡ ዮም፨</l>
                  <l n="4">ኩነኒ፡ ኀይለ፡ ድካምየ፡ እስከ፡ እፌጽም፨</l>
                  <l n="5">እስመ፡ አንተ፡ ኃያል፡ ወአነ፡ ድኩም፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘፊደላቲሁ፡ አርባዕቱ፨</l>
                  <l n="2">ከመ፡ ስመ፡ እግዚእ፡ ኢየሱስ፡ ወስመ፡ ማርያም፡ ወላዲቱ፨</l>
                  <l n="3">ቤተ፡ ክርስቲያን፡ መርዓት፡ ትዌድሰከ፡ ለለ፡ ዕለቱ፨</l>
                  <l n="4">ፊቅጦር፡ ወልድ፡ ለአምላክ፡ መጋቤ፡ ቤቱ፨</l>
                  <l n="5">በሥርዓት፡ ወሕግ፡ ፅሙድ፡ ውእቱ፨</l>
               </lg>
               <lg type="stanza" n="9">
                  <l n="1">ሰላም፡ ለእስትንፋስከ፡ ወለጕርዔከ፡ መዓርዒር፨</l>
                  <l n="2">ወለክሳድከ፡ ጽኑዕ፡ በትእዛዘ፡ ክርስቶስ፡ መምህር፨</l>
                  <l n="3">ፊቅጦር፡ ጻድቅ፡ በጸሎትከ፡ ሐጹር፨</l>
                  <l n="4">ዘተኦደት፡ እምኵለሄ፡ ኢትዮጵያ፡ ሀገር፨</l>
                  <l n="5">ትዌድሰከ፡ በሐዋዝ፡ መዝሙር፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">ሰላም፡ ለመከየድከ፡ ኢትዮጵያ፡ ዘፈለሳ፨</l>
                  <l n="2">ከመ፡ ጳውሎስ፡ አሣዕነ፡ እንበለ፡ ይኅሥሣ፨</l>
                  <l n="3">ፊቅጦር፡ ሀበኒ፡ እምዘመነ፡ ኤልያስ፡ ስሳ፨</l>
                  <l n="4">ለወልድከሰ፡ አዝማናቲሁ፡ ሠላሳ፨</l>
                  <l n="5">ወኢኮኖ፡ አርብዓ፡ ወኃምሳ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ በእደ፡ ሱራፊ፡ ቀሲስ፨</l>
                  <l n="2">አመ፡ ዐሡሩ፡ ወሰብዑ፡ ለወርኀ፡ ታኅሣሥ፨</l>
                  <l n="3">አመ፡ ፈለስከ፡ ፊቅጦር፡ እምነ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="4">ወመጽኡ፡ ለቀበላከ፡ በቃለ፡ ማሕሌት፡ ሐዲስ፨</l>
                  <l n="5">መዘምር፡ አሳፍ፡ ወዳዊት፡ ንጉሥ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ በቤተ፡ ማርያም፡ ድንግል፨</l>
                  <l n="2">ከመ፡ ቅጽበተ፡ ዐይን፡ ዘኮነት፡ አራቂተ፡ ኀይል፨</l>
                  <l n="3">ፊቅጦር፡ ጻድቅ፡ ጸሓፌ፡ ሐዲስ፡ ወንጌል፨</l>
                  <l n="4">ሀበኒ፡ እግዚኦ፡ በረከተከ፡ በቃለ፡ ሰላም፡ ወሣህል፨</l>
                  <l n="5">እስመ፡ ጸሎቱ፡ ለጻድቅ፡ ታድኅን፡ እምሀጕል፨</l>
               </lg>
            </div>
         </div>
      </body>

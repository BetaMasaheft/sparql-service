               <msContents>
                  <summary>Maṣḥafa gǝṣṣǝw “Lectionary for the entire year”
 I) Blessing prayer,
                     Barǝkännä ʾǝgziʾo… “Bless us, Lord…” (fols. 3ra-4va)
 II) Scriptural
                     readings for liturgical periods, fasts and feasts for the entire year (fols.
                     5r-30v).</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <note>
                        <locus target="#1r">1r</locus>, 1v, 2r and 2v are unruled.</note>
                  </msItem>
               </msContents>

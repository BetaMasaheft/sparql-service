               <msContents>
                  <summary>Damaged by damp, especially folios 330v-333v.</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0692IHA">دعاء اللهم لك الحمد منا ولك الشكر اذ هديتنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم \ اللهم لك الحمد منا ولك الشكر اذ هديتنا للايمان وعلمتنا القران اذ مننت علينا بما وهبتنا من علم تنزيلك وتاويله

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1r">-1r</locus>اللهم انا نقرا كتابك العزيز لنيل الدرجات العلي ولقضاء الحاجات لاسقاط الذنوب ولنور القلوب ولطرد الشيطان الرجيم اعوذ بالله من الشيطان الرجيم

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="330r">1v-330r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة الفاتحة سبع ايات مكية \ بسم الله الرحمن الرحيم , الحمد لله رب العلمين , الرحمن الرحيم . ملك يوم الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#330r">-330r</locus>الخناس , الذي يوسوس في صدور الناس , من الجنة والناس</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="330v" to="330v">330v-330v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0690IHA">دعاء ختم القران اللهم ارحمنا بالقران العظيم وانفعنا
                    بالايات</title>
                     <incipit xml:lang="ar">
                        <locus target="#330v">-330v</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ اللهم ارحمنا بالقران العظيم وانفعنا بالايات والذكر الحكيم وبارك لنا فى السبع المثاني والقران العظيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#330v">-330v</locus>اللهم اشف مرضانا وعاف مبتلانا وارحم موتانا وتمم نعمتك علينا واجعل اجتماعنا ودعاءنا وتاميننا بركة لنا في ديننا ودنيانا وشفا لنا من كل داء وسقم وفرج عنا من كل هم وغم برحتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين 

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="331r" to="331r">331r-331r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4151IHA">دعاء ختم القران اللهم اني اسالك ما كان فى تلاوتنا هذه من
                    خطا</title>
                     <incipit xml:lang="ar">
                        <locus target="#331r">-331r</locus>دعا ختم القران العظيم \ بسم الله الرحمن الرحيم \ اللهم انى اسالك ما كان في تلاوتنا هذه من خطا او نسيان او زيادة او نقصان او تقديم او تاخير او شد او مد على غير ما انزلته</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#331r">-331r</locus>واصلح اللهم لنا ولابائنا ولامهاتنا ولاخواننا ولجيراننا ولمشائخنا ولجميع المسلمين والمسلمات والمومنين والمومنات برحمتك يا ارحم الراحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="331r" to="331r">331r-331r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3287IHA">دعاء ختم القرآن اللهم اوهن عضد الكفرة</title>
                     <incipit xml:lang="ar">
                        <locus target="#331r">-331r</locus>اللهم اوهن عضد الكفرة واضعف مددهم وبدد شملهم واوحش انسهم وفرق جمعهم  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#331r">-331r</locus>ويا قريب غير بعيد ويا عالب غير معلوب فرج عن المسلمين مما هم فيه يا رب العالمين يا ارحم الراحمين يا حي يا قيوم يا ذا الجلال والاكرام سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="331v" to="332r">331v-332r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4130IHA">دعاء ختم القران اللهم ارحمنا بالقرا العظيم واجعله لنا
                    اماما ونورا</title>
                     <incipit xml:lang="ar">
                        <locus target="#331v">-331v</locus>بسم الله الرحمن الرحيم ة \ اللهم ارحمنا بالقران العظيم ؤجعله لنا اماما ونورا وهدا ورحمة اللهم ذكرنا منه ما نسينا وعلمنا منه منه ما جهلنا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#332r">-332r</locus>وجعلنا في موقف القيامة من الذين لا خوف عليهم ولا يحزنون برمتك يارحم الرحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين امين امين امين 
</explicit>
                     <note>Written in blue ink. Text badly damaged by damp.</note>
                     <note/>
                  </msItem>
               </msContents>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="masgabiya">
               <lg type="stanza" n="1">
                  <l n="1">አኮ፡ አኮ፡ ወርቀ፡ ወባሕርየ፨</l>
                  <l n="2">ከመ፡ ኤውላጦን፡ ወደማስቆ፡ ዘኢፈረየት፡ ምድርየ፨</l>
                  <l n="3">ጸዊርየ፡ አላ፡ አምኃ፡ ውዳሴ፡ ዘብየ፨</l>
                  <l n="4">አኖሬዎስ፡ መኰንንየ፡ ወመንፈሳዊ፡ አቡየ፨</l>
                  <l n="5">ወእገኒ፡ ለከ፡ በኵሉ፡ ልብየ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሆህያቲሁ፡ ንፍቀ፡ ዐሥር፡</l>
                  <l n="2">አቅመ፡ ቅንዋቱ፡ ለመስቀል፡ መልዕልተ፡ ኵሉ፡ ነገር፨</l>
                  <l n="3">አኖሬዎስ፡ አብ፡ መዝገበ፡ ይዋሄ፡ ወፍቅር፡</l>
                  <l n="4">ይጥዕም፡ ዝክረ፡ ስምከ፡ እመዓር፡ ወሶክር፡</l>
                  <l n="5">ወይትፈቶ፡ እምወርቅ፡ ወእምዕንቍ፡ ክቡር፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ዘኢይረክቦን፡ ጽበስ፡</l>
                  <l n="2">ኅዱር፡ ቦቶን፡ ኃይለ፡ ናዝራዊ፡ ቅዱስ፨</l>
                  <l n="3">አኖሬዎስ፡ ነቢይ፡ ወሐዋርያ፡ ሐዲስ፡</l>
                  <l n="4">እንተ፡ ፆርከ፡ መስቀለ፡ ሞቱ፡ ለመምህረ፡ ዓለም፡ ክርስቶስ፡</l>
                  <l n="5">ምስለ፡ ቅንዋት፡ ዘኍልቆን፡ ኃምስ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለርእስከ፡ ዘተከለለ፡ ቆብዐ፡</l>
                  <l n="2">አርአያ፡ አክሊሉ፡ ለክርስቶስ፡ ዘዕለተ፡ መርዓ፡</l>
                  <l n="3">አኖሬዎስ፡ የዋህ፡ እንተ፡ ትትሜለል፡ በግዓ፡</l>
                  <l n="4">ፍቅርከ፡ ከመ፡ እሳት፡ ሕፀተ፡ ሕሊናየ፡ በልዐ፡</l>
                  <l n="5">ወከመ፡ ሞት፡ በኀቤየ፡ ጸንአ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለገጽከ፡ በማኅተመ፡ መስቀል፡ ሕቱም፡</l>
                  <l n="2">ማየ፡ ምራቅከ፡ ዝንቱ፡ ዲበ፡ ጸላዒ፡ ትእምርተ፡ ሕማም፤</l>
                  <l n="3">አኖ፡ ዘድድቅ፡ አፅቀ፡ አፀደ፡ ወይን፡ ልምሉም፡</l>
                  <l n="4">ጽጌ፡ ኂሩትከ፡ መዓዛ፡ ዛቲ፡ ገዳም፡</l>
                  <l n="5">ናሁ፡ ሠናይ፡ ወናሁ፡ አዳም፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ ለቀራንብቲከ፡ እለ፡ ሐተታ፡ ወጠየቃ፡</l>
                  <l n="2">ለሰማየ፡ ትዕግሥት፡ ምጥቃ፡ ወለባሕረ፡ ኂሩት፡ ዕመቃ፡</l>
                  <l n="3">አኖ፡ ባዕል፡ ለልብየ፡ ፍጻሜ፡ ጻሕቃ፡</l>
                  <l n="4">በጺሐከ፡ አውደ፡ መስቀል፡ ኀበ፡ ሀሎኩ፡ ጥቃ፡</l>
                  <l n="5">ተናበበኒ፡ በዐውሎ፡ ወጠቃ፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ ወሙዳየ፡ ሥጋከ፡ ንፍቅ፨</l>
                  <l n="2">ተአምረ፡ መስቀል፡ ዘቦቱ፡ ተወፋዬ፡ ብሩር፡ ወወርቅ፨</l>
                  <l n="3">አኖሬዎስ፡ አብ፡ ለከ፡ እንዘ፡ ኔብ፡ ነአኵተከ፡ ደቂቅ፨</l>
                  <l n="4">አባ፡ አባ፡ እምኀጢአት፡ ርኁቅ፨</l>
                  <l n="5">አባ፡ መፍቀሬ፡ ንጽሕ፡ አባ፡ ጸድቅ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">እምብዙኅ፡ ውዳሴ፡ መልክእከ፡ ዘኢየኀልቅ፡ በዜና፨</l>
                  <l n="2">ምስለ፡ ውዳሴሁ፡ ኅቡረ፡ ለመስቀል፡ ዕፀ፡ ድኅና፨</l>
                  <l n="3">አኖሬዎስ፡ አብ፡ መምህረ፡ ሰላም፡ ወትሕትና፨</l>
                  <l n="4">ውሑደ፡ ዘተናገርኩ፡ መጠነ፡ ብየ፡ ልቡና፨</l>
                  <l n="5">በኀቤከ፡ አእግዚእየ፡ ይኩነኒ፡ ምዝጋና፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
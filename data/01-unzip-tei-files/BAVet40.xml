                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="60v" facs="0006"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾtǝna Māryām ba-Dabra Golgotā</title>
                     <note>The end is missing due to material loss.</note>
                     <explicit xml:lang="gez">
                        ወቡሩክ፡ መንፈስ፡ ቅዱስ፡ ዘወሀብከኒ፡ ዘንተ፡ ኵሎ፡ በፈቃድከ፨ ስብሐት፡
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="61r" to="70r" facs="0062"/>
                     <title type="incomplete">Prayer to Our Lord Jesus Christ</title>
                     <note>The beginning and some portions of the text are missing due to material loss.</note>
                     <incipit xml:lang="gez">
                        ውእቱኬ፡ ሰማያዊ፡ ውእቱ፡ መኑ፡ ውእቱ፡ ዝንቱ፡ ዘበሙስና፡ ተወልደ፡ ውእቱሰ፡ ኢይማስን፨
                     </incipit>
                     <explicit xml:lang="gez">
                        በከመ፡ ይቤ፡ ሙሴ፡ ወባዕዳንሂ፡ ነቢያት፡ ንሕነሂ፡ ቦቱ፡ ተወኪለነ፡ ሎቱ፡ ነሀብ፡ ስብሐተ፡ ወሎቱ፡ ስብሐት፡ ወጽንዕ፡ ለዓለመ፡ ዓለም፡ አሜን፨ = ፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="70r" to="71v" facs="0071"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3582Prayer">Prayer to Our Lady Mary</title> 
                     
                     <note>The end is missing due to material loss.</note>
                     <incipit xml:lang="gez">
                        እሴብሕ፡ ጸጋኪ፡ ኦእግዝእትየ፡ ማርያም፡ 
                           <sic>ወእሰእለኪ፡</sic>
                         ታብርሂ፡ ልብየ፡ ወታርትዒ፡ ፍኖትየ፡ ከመ፡ እሖር፡ በንጹሕ፡ ልብ፡ በግኖተ፡ ክርስቶስ፡ 
                        
                           <sic>ወበትእዘዞትሁ።</sic>
                        
                     </incipit>
                     <explicit xml:lang="gez">
                        ኦመንክርት፡ ማኅደሩ፡ ለእግዚአብሔር፡ 
                           <sic>ረሰይኒ፡</sic>
                         እኩን፡ ማኅደረ፡ 
                           <sic>ለመንፈሰ፡</sic>
                         
                        
                           <sic>ቅድሰ።</sic>
                         ኦዘወለድኪ፡ ዐቃቤ፡
                     </explicit>
                  </msItem>

                        <item xml:id="a2">
                           <locus target="#1v" facs="0003"/>
                           <desc type="RecordDistribution"/>
                           <q xml:lang="gez">
                              ፻፡ ወርቅ፡ ሙተቤዎን፡ ፴፡ ወርቅ፡ ቍሴስ፡ ፺ቱ፡ ወርቅ፡ ድዝዋት፡ ገደፍኩ፡ ለክሙ፡ 

                    <physDesc>
                        <objectDesc form="Codex">
                            <supportDesc>
                                <support>
                                    <material key="parchment"/>
                                </support>
                                <extent>
                                    <measure unit="leaf" quantity="107">107</measure>
                                    <dimensions type="outer" unit="in">
                                        <height>7.625</height>
                                        <width>7.375</width>
                                    </dimensions>
                                </extent>
                                <foliation>Foliation in the upper right corner by the library. The images in the library's digitization are partly arranged in the wrong order
                                    in the first part of the manuscript, with mismatch of corresponding recto and verso.</foliation>
                                <collation>
                               <signatures>Quire marks in the upper inner corner of the first folium of each quire.</signatures>
                                    <note>The manuscript is composed of quinions.</note>
                                </collation>
                                <condition key="good">
                                  A quire of 10 leaves is missing at the beginning.
                                  <locus target="#99"/> is damaged. The manuscript has been extensively used,
                                stains of dirt and wax are present throughout.</condition>
                            </supportDesc>
                            <layoutDesc>
                                <layout columns="2" writtenLines="18 19">
                                    <ab type="pricking">Pricking and ruling are visible.</ab>
                                    <ab type="pricking">Primary pricks are visible, horizontal pricks are visible.</ab>
                                    <ab type="ruling" subtype="pattern">1A-1A-1A1A/0-0/0-0/C</ab>
                                    <ab type="ruling"> The upper line is written above the ruling,
                                        the lower line is written above the ruling.</ab>
                        </layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>

                            <handNote script="Ethiopic" xml:id="h1">
                                <desc>The manuscript is written in a fair hand , of the <date>18th century</date>.
                                </desc>
                                <date notBefore="1700" notAfter="1800"/>
                            </handNote>

                        </handDesc>
                        <decoDesc>
                          <decoNote xml:id="d1" type="drawing">
                            <locus target="#75v"/>
                            <desc>A crude geometric drawing with crosses.</desc>
                          </decoNote>
                          <decoNote xml:id="d2" type="drawing">
                            <locus target="#96v"/>
                            <desc>A crude drawing of a building, most probably of the Gondarine
                            castle.</desc>
                          </decoNote>
                          <decoNote xml:id="d3" type="drawing">
                            <locus target="#107v"/>
                            <desc>A crude drawing of a king on his throne, playing on a harp, and
                      above it there is a crude note
                      <foreign xml:lang="gez">ንጉሠ፡ ነገሥት፡ ቴዎድሮስ፡</foreign></desc>
                          </decoNote>
                        </decoDesc>
                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus from="107r"/>
                              <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT3064RepCh344">ʾƎsebbǝḥ ṣaggāki ʾo-mǝlʾǝta ṣaggā</title></desc>
                              <q xml:lang="gez">
                                <seg part="I">እሴብሕ፡ ጸጋኪ፡ ኦምልእተ፡ ጸጋ፡ ወእትጋነይ፡ ለኪ፡ ኦምልእተ፡ ውዳሴ።</seg>
                              </q>
                            </item>
                            <item xml:id="e1">
                              <desc>The names of the owners,
                                <persName role="owner" ref="https://betamasaheft.eu/PRS13576KebraW">Kǝbra Wangel</persName> and
                                <persName role="owner" ref="https://betamasaheft.eu/PRS13575Tadewos">Tādewos</persName>
                                have been mostly erased, but still
                              legible on <locus target="#96v"/> and <locus target="#87v"/>.
                            </desc>
                            </item>
                          </list>
                        </additions>
                        
                        <bindingDesc>
                            <binding contemporary="false" xml:id="binding">
                                <decoNote xml:id="b1" type="Boards">Two wooden boards.</decoNote> 
                                <decoNote xml:id="b2" type="Cover">Blind-tooled leather cover
                                    (with the gilded title and shelfmark on the spine).</decoNote> 
                                <decoNote xml:id="b3" type="bindingMaterial">
                                    <material key="wood"/>
                                    <material key="leather"/>
                                </decoNote>
                                <decoNote xml:id="b4" type="SewingStations">4</decoNote> 
                                <decoNote xml:id="b5" type="SewingStations">Sewing stations are used in an irregular way.</decoNote> 
                                <decoNote xml:id="b6">The manuscript has been rebound in the library. Possibly both wooden boards have been replaced, 
                                    and a blind-tooled cover added.</decoNote>
                            </binding>
                        </bindingDesc>

                    </physDesc>

                    <history>
                        <origin>

                            <origDate notBefore="1700" notAfter="1800"/>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area,
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.</provenance>

                    </history>


                        <msItem xml:id="ms_i2">
                          <locus from="96v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1356eqaban">ʿƎqabanni (shorter version)</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡
                            ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡ በእንተ፡ ዘኃደርከ፡ በከርሠ፡ ማርያም፡ እምከ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                          <locus from="98r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT3086RepCh366">Hymn to Our Lady Mary</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ኦመሠረት፡ አንቲ፡ ለኵሉ፡ ዓለም፡ ዘኮንኪ፡ ማኅደር፡ ለዓቢይ፡ ወልዑል፡ አምላክነ፡
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                          <locus from="102v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT3090RepCh370">Hymn to Jesus Christ</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ሕያው፡ በእንተ፡ ማርያም፡ ወላዲትከ፡ ርድአኒ።
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                          <locus from="104v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT6161BakwelluH">Litany to Mary</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ተማኅጸንኩ፡ አነ፡ ገብርኪ፡ <del rend="erasure"/> በኵሉ፡ ሕማሙ፡ ዘዕለተ፡
                            ዓርብ፡ ለፍቁር፡ ወልድኪ፡
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">

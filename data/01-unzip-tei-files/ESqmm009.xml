                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, irregular.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Second half of the 18th cent. (?)</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይብል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; names of prelates;
                           directives to the ministers and their abbreviations; titles of the books
                           to be read; the words halle luya, ʾǝgäle; elements of the punctuation
                           signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>

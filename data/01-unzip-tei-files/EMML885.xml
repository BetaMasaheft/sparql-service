                  <msContents>
                     <summary/>
                     <msItem xml:id="p1_i1">
                        <locus from="1b" to="2b">Fols 1b–2b</locus>
                        <title type="supplied">"Image" of Sunday [Malke'a sanbata Krestiyān]</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p1_i2">
                        <locus from="3a" to="19a">Fols 3a–19a</locus>
                        <title type="supplied">Homily on the observance of the sabbath [Dersāna sanbat].</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p1_i3">
                        <locus target="#19ab">Fol. 19ab</locus>
                        <title type="supplied">Note of the copyist, Qēsa Gabaz Besrāt (written Beśrāt, that he has bound the first part containing the Dersāna sanbat to a manuscript of the Miracles of Jesus Christ because it tells about the sabbath rest and about the feasts of the only Begotten.</title>
                        <textLang mainLang="am">Amharic</textLang>
                        <note>He petitions the priests of Manbara Negeśt to read passages from it every Sunday, after the reading of the Miracles of Mary.</note>
                     </msItem>
                  </msContents>

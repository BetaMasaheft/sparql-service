                        <item xml:id="a0_163">
                           <locus target="#18v">-18v</locus>
                           <q xml:lang="ar">اغثنا سيد ابادر سيدي \ عليكم رحمة القادر مددي \ اغيتوا قطب الناحية سيدي ...ا</q>

  </teiHeader><t:text xmlns:t="http://www.tei-c.org/ns/1.0" xml:base="https://betamasaheft.eu/">  
      <t:body>
         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" n="6" xml:id="chapter6" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet7#ms_i1">
               <t:ab>
                  <t:pb n="10r" facs="f23"/>
                  <t:l n="1">ወተሰጥወ፡ ኢዮብ፡ ወይቤ፡</t:l>
                  <t:l n="2">ሶበ፡ አሐዱ፡ እምኔክሙ፡ ይደልዋ፡ ለመቅሠፍትየ። ወይነሥአ፡ ኅቡረ፡ በመዳልው፡ ለሕማምየ፡</t:l>
                  <t:l n="3">እስመ፡ ይከብድ፡ እምኆጻ፡ ሐይቅ። ወባሕቱ፡ ሐሰተ፡ ይመስል፡ ነገርየ።</t:l> 
                  <t:l n="4">ናሁ፡ አሕጻሁ፡ ለእግዚአ፡ ብሔር፡ ላዕለ፡ ሥጋየ። ወሕምዞሙ፡ ይሠርበኒ፡ ደምየ። ሶበ፡ እእኅዝ፡ እንብብ፡ ይደጕጸኒ<t:supplied reason="undefined" resp="PRS10747Zotenbe">።</t:supplied>
                  </t:l>
                  <t:l n="5">ቦቲ፡ ለከንቱ፡ ይነቁ፡ ሐለስትዮ። አኮኑ፡ እንዘ፡ የኀሥሥ፡ ዘይበልዕ። ወይነቁኑ፡ ላህም፡ የቀምሕ፡ ውስተ፡ ጎል።</t:l>
                  <t:l n="6">ወይትበላዕኑ፡ እክል፡ ዘእንበለ፡ ጼው። ወቦሁ፡ ጥዑመ፡ ነገረ፡ ከንቱ<t:supplied reason="undefined" resp="PRS10747Zotenbe">።</t:supplied>
                  </t:l>
                  <t:l n="7">ኢትክል፡ አዕርፎ፡ ነፍስየ። ወእሬኢ፡ ንሥሐተ፡ ሥጋየ፡ ከመ፡ ብሐብሐ፡ አንበሳ።</t:l>
                  <t:l n="8">ሶበ፡ ይመጽአኒ፡ ጸሎትየ፡ ወየሀበኒ፡ እግዚአ፡ ብሔር፡ ተስፋየ፡</t:l>
                  <t:l n="9">ወአኀዘ፡ እግዚአ፡ ብሔር፡ ወፈጸመ። ወቀተለኒ፡ ለዝሉፉ።</t:l>
               </t:ab>  
            </t:div>
    
            <t:div type="textpart" subtype="chapter" n="30" xml:id="chapter30" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet7#ms_i1">
               <t:ab>
                  <t:pb n="47r" facs="f97"/>
                  <t:l n="15">ትፍህቅ፡ ነፍስየ፡ ወትልህስ። ኀለፈት፡ ሕይወትየ፡ ከመ፡ ደምና።</t:l>
                  <t:l n="16">ወይእዜ፡ ተክዕወት፡ ነፍስየ፡ በላዕሌየ። ምሉአት፡ መዋዕልየ፡ ጻዕረ።</t:l>
                  <t:l n="17">ኵሎ፡ ሌሊተ፡ ይነድድ፡ አዕጽምትየ፡ ወይትመሰው፡ አሥራዊየ<t:supplied reason="undefined" resp="PRS10747Zotenbe">።</t:supplied>
                  </t:l>
                  <t:l n="18">እምዓቢይ፡ ኀይል፡ እትሜጠው፡ ልብስየ።</t:l>
                  <t:l n="19">ወኀነቀኒ፡ ወሐባኔ፡ ፀፈረ፡ ውስተ፡ ክሳድየ፡ ወኬደኒ፡ ከመ፡ ፅቡር፡ ወመሬት፡ ወሐመድ፡ መክፈልትየ<t:supplied reason="undefined" resp="PRS10747Zotenbe">።</t:supplied>
                  </t:l>
                  <t:l n="20">ገዐርኩ፡ ኀቤከ፡ ወኢትሰምዐኒ፡ ቀዊሞሙ፡ ይጤይቁኒ።</t:l>
                  <t:l n="21">ደበዩኒ፡ እለ፡ አልቦሙ፡ ምሕረተ፡ ጸንዐት፡ እድ፡ እንተ፡ ቀሠፈተኒ።   </t:l>
                  <t:l n="22">ኀደገኒ፡ ውስተ፡ ነሃከ፡ ወአርሐቀኒ፡ እምሕይወት።</t:l>
                  <t:l n="23">አአምር፡ ከመሰ፡ ሞት፡ ይቀጠቅጠኒ፡ ወማኅደሩ፡ ለኵሉ፡ ዘሞተ፡ ምድር<t:supplied reason="undefined" resp="PRS10747Zotenbe">።</t:supplied>
                  </t:l>
                  <t:l n="24">እምፈቀድኩ፡ ለሊየ፡ እትጐርዐይ፡ ወእማእኮ፡ አስተብቍዕ፡ ባዕደ፡ ወእግበር፡ ከማሁ።</t:l>
               </t:ab>
            </t:div>
  
            <t:div type="textpart" subtype="chapter" n="7" xml:id="chapter7" xml:lang="gez" corresp="https://betamasaheft.eu/BNFet7#ms_i3">
               <t:ab>
                  <t:pb n="103ra" facs="f209"/>
                  <t:l n="1">በቀዳማዊ፡ ዐመተ፡ መንግሥቱ፡ ለበልጣሰር፡ ንጉሠ፡ ከለዴዎን፡ ሐለመ፡ ዳንኤል፡ ሕልመ፡ ወርእየ፡
        ርእሶ፡ በውስተ፡ ምስካቡ፡ ወጸሐፈ፡ ሕልሞ።</t:l>
                  <t:l n="2">አነ፡ ዳንኤል፡ ሐለምኩ፡ ወርኢኩ፡ አርባዕተ፡ ነፋሳተ፡
        ነፍኁ፡ ውስተ፡ ባሕር፡ ዐቢይ፡</t:l>
                  <t:l n="3">ወዐርጉ፡ አራዊት፡ አርባዕቱ፡ ዐበይት፡ እምባሕር፡ ኅቡረ፡ ወቀዳማዊ፡</t:l>
                  <t:l n="4">ከመ፡ አንበሳዊት፡ ወባቲ፡ ክንፈ፡ ወክንፊሃኒ፡ ከመዘ፡ ንስር፡ ወርኢኩዋ፡ እስከ፡ ተመልኀ፡ ክንፊሃ፡
        ወተንሥአት፡ ወቆመት፡ በእግረ፡ ሰብእ፡ ዲበ፡ ምድር፡ ወልበ፡ ሰብእ፡ ተውህበ፡ ላቲ።</t:l>
               </t:ab>
            </t:div>
         </t:div>
    
      </t:body>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="8v">1v-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous lacunous" ref="https://betamasaheft.eu/LIT0102IHA">عمدة السالك وعدة الناسك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم قال الشيخ العالم العلامة شهاب الدين احمد ابن نقيب الشافعي رضى الله عنه ورحم سلفه بمنه وكرمه امين والحمد لله رب العلمين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم اجمعين اما هذا مختصر على مذهب الامام الشافعي رحمه الله اقتصرت فيه على الصحيح من المذهب عند الرافعي والنووي او احدهما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus>اذا انفصل في حياته ومني الكلب والخنزير والانفحة طاهرة ان كان اخذت من سخلة مذكاة لم تاكل غيراللبن وما يسل من فم النائم ان كان  </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="9r" to="18v">9r-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0030IHA">تحفة المحتاج بشرح المنهاج</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>كنظيره السابق في القراة وتعبيرى بما ذكر اعم مما عبر به </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#18v">-18v</locus>لمن عجز عنهما أو عن دعاء وكرما ثورين كاالشهد ولاوّل والصلاة على النبي صلى الله عليه وسلم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="19r" to="29v">19r-29v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT2054IHA">عيسى عليه السلام في الإنجيل</title>
                     <incipit xml:lang="ar">
                        <locus target="#19r">-19r</locus>جملة حالية المعنى لاجل يوم عظيم ووقت فخيم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29v">-29v</locus>ولا بعض مدحه حلثا وكلا ولا بعض المدح من بعضه اصله لان مكام شمائله اكثر</explicit>
                     <note>Some of the words are divided into two different lines. Same handwriting as in 84r-92v and 95r-95v.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="30r" to="83v">30r-83v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0030IHA">تحفة المحتاج بشرح المنهاج</title>
                     <incipit xml:lang="ar">
                        <locus target="#30r">-30r</locus>لرؤية مرتكبها وقولى ويظهرها الى اخره اعمّ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#83v">-83v</locus>فان احدث اعاد غسل صحيح اعضاء وضوئه يتمّم</explicit>
                     <note>The fol. aren't bound in the correct order, some of them are upside down. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="84r" to="92v">84r-92v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous" ref="https://betamasaheft.eu/LIT2054IHA">عيسى عليه السلام في الإنجيل</title>
                     <incipit xml:lang="ar">
                        <locus target="#84r">-84r</locus> الياء اي لأجلي الذخر اي ادخرا يتضمن افتخارا عند الهاء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#92v">-92v</locus>وكان لما يثني به اهلا اي وكان نبينا صلى الله عليه وسلم لما يثني الله</explicit>
                     <note>Some of the words are divided into two different lines. Same handwriting as in 19r-29v and 95r-95v.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="93r" to="94v">93r-94v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT0964IHA">مقدمة فقهية</title>
                     <incipit xml:lang="ar">
                        <locus target="#93r">-93r</locus>وما عرقه وبيته وبارفعه فعل راسه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#94v">-94v</locus>ان يقول يوم القيمة انا كنا عن هذا غافلين وفي الحديث الصحيح إن الله تعلى امر جبريل ان يمسح ظهر ادم عليه</explicit>
                     <note>Some of the words are divided into two different lines. The folios 93r, 94r and 94v are written by the same hand. Fol. 93v is possibly by a different hand.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="95r" to="95v">95r-95v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT2054IHA">عيسى عليه السلام في الإنجيل</title>
                     <incipit xml:lang="ar">
                        <locus target="#95r">-95r</locus>الله سبحانه عليه في انجيل عيسى عليه السلام بجميع محامده اهلا وبانواع مدائحه فصلا فصلا مما من الله عليه تفضلا من اصناف مقاماته فضلا فضلا له راحة تهمى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#95v">-95v</locus>وفي نسخة ما بينهم ابدا ايجلى  لكن مناسبة النسخة الاولى في المبنى والمعنى اعلى كما لا يخفى بنفس بفتح اليا افدي من علا الناس صحبه</explicit>
                     <note>Some of the words are divided into two different lines. Same handwriting as in 19r-29v and 84r-92v.</note>
                     <note/>
                  </msItem>
               </msContents>

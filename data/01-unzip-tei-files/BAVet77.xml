               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4618Prayer">Protective prayer against any known or unknown disease</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ሰብእ፡ ዘይትዓወቅ፡ ወዘዒይትአወቅ፡ 
                        አቢ፡ አቢ፡ አቢ፡
                     </incipit>
                     <note>The prayer is preceded by a figure consisting of nine squares, five being human faces and three being eyes.</note>
                  </msItem> 
                  
                  <msItem xml:id="ms_i2">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4619Prayer">Protective prayer against Bāryā and Lagewon</title>
                     
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ባርያ፡ ወለጌዎን፡ ርኩስ፡ ዘይሰልብ፡ ልበ፡ 
                        ሰብእ፡ ወያጸልም፡ አዕይንተ፡
                     </incipit>
                     <note>Cp. <bibl corresp="http://zotero.org/groups/358366/items/VD2T5WH4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Worrell1914Zauberwesen"/><title level="a">Studien zum abessinischen Zauberwesen</title><title level="j">Zeitschrift für Assyriologie und verwandte Gebiete</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">William Hoyt</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Worrell</t:surname></author><date>1914_1915</date><biblScope unit="volume">29</biblScope><biblScope unit="page">85-141</biblScope><note type="url">http://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/118379</note><citedRange>88</citedRange></bibl>.
                     </note>
                   </msItem>  
                  
                  <msItem xml:id="ms_i3">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4620Prayer">Protective prayer against the diseases of the smiths and the demons</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ነሀብት፡ ወአጋንንት፡ አላሁማ፡ ወያኑራ፡
                     </incipit>
                     <note>The prayer is followed by a figure consisting of a cross with a human face and eight eyes.</note>
                  </msItem>       
                  
                  <msItem xml:id="ms_i4">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4621Prayer">Protective prayer to chase demons away</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በዘያርኅቆሙ፡ ለአጋንንት፡ ወይሰድዶሙ፡ ለሰይጣናት፡ 
                        እምላዕለ፡ ሰብእ፡ ሰላም፡ ለከ፡ ሰዳዴ፡ አጋንንት፡ ፋኑኤል፡ 
                     </incipit>
                     <explicit xml:lang="gez">
                        ኦአምላከ፡ ፋኑኤል፡ አድኅና፡ እምአጋንንት፡ እኩያን፡ ወእምሰብእ፡ መሠርያን፡ 
                           <sic>ለአማትከ፡</sic>
                         ወለተ፡ ሥላሴ።
                     </explicit>
                     <note>The name of the owner, <persName role="owner" ref="https://betamasaheft.eu/PRS11558WalattaS">Walatta Śǝllāse</persName>, is written in the supplication formula 
                     at the end of the prayer.</note>
                     <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/VD2T5WH4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Worrell1914Zauberwesen"/><title level="a">Studien zum abessinischen Zauberwesen</title><title level="j">Zeitschrift für Assyriologie und verwandte Gebiete</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">William Hoyt</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Worrell</t:surname></author><date>1914_1915</date><biblScope unit="volume">29</biblScope><biblScope unit="page">85-141</biblScope><note type="url">http://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/118379</note><citedRange>113-114</citedRange></bibl>
                     </listBibl>
                     <listBibl type="translation" xml:lang="de">
                        <bibl corresp="http://zotero.org/groups/358366/items/VD2T5WH4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Worrell1914Zauberwesen"/><title level="a">Studien zum abessinischen Zauberwesen</title><title level="j">Zeitschrift für Assyriologie und verwandte Gebiete</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">William Hoyt</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Worrell</t:surname></author><date>1914_1915</date><biblScope unit="volume">29</biblScope><biblScope unit="page">85-141</biblScope><note type="url">http://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/118379</note><citedRange>113-114</citedRange></bibl>
                     </listBibl>
                  </msItem>       
                  
                  <msItem xml:id="ms_i5">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4622Prayer">Protective prayer against colic</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ 
                        <choice>
                           <sic>ቍርፀት፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ቍርጠት፡</corr>
                        </choice> ዘተፈነወ፡ እምኀበ፡ ወልድ፡ ዋሕድ፡ ከመ፡ ይርዳእ፡ 
                        ወይቤዙ፡ ውሉደ፡ እጓለ፡ እመሕያው፡ ሸገር፡ ሸገር፡ ሸገር፡
                     </incipit>
                     <note/>
                  </msItem>       
                  
                  <msItem xml:id="ms_i6">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4623Prayer">Protective prayer against colic</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ 
                        <choice>
                           <sic>ቍርፀት፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ቍርጠት፡</corr>
                        </choice> በከፓኮስ፡ ስምከ፡ በኄርያኖስ፡ ስምከ፡ በዳፌል፡ 
                        ስምከ፡
                     </incipit>
                     <note>The prayer is followed by figures with squares and triangles.</note>
                  </msItem>       
                  
                  <msItem xml:id="ms_i7">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4624Prayer">Protective prayer ayer against the pain</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ 
                        <choice>
                           <sic>ውግዓት፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ውጋት፡</corr>
                        </choice> ምድምያስ፡ ምድምያስ፡
                     </incipit>
                     <note/>
                  </msItem>       
                  
                  <msItem xml:id="ms_i8">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4625Prayer">Protective prayer against the pain</title>
                     <incipit xml:lang="gez">
                        ጸሎት፡ በእንተ፡ ሕማመ፡ <supplied reason="omitted">ውጋት፡</supplied> ሰላም፡ ለገቦከ፡ ኵናተ፡ <choice>
                           <sic>ለጊጊሮስ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ለንጊኖስ፡</corr>
                        </choice> 
                        ዘወግዖ፡
                     </incipit>
                        <note>Cp. <bibl corresp="http://zotero.org/groups/358366/items/VD2T5WH4"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Worrell1914Zauberwesen"/><title level="a">Studien zum abessinischen Zauberwesen</title><title level="j">Zeitschrift für Assyriologie und verwandte Gebiete</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">William Hoyt</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Worrell</t:surname></author><date>1914_1915</date><biblScope unit="volume">29</biblScope><biblScope unit="page">85-141</biblScope><note type="url">http://menadoc.bibliothek.uni-halle.de/dmg/periodical/titleinfo/118379</note><citedRange>96 n. 3</citedRange></bibl>.
                        </note>
                  </msItem>  
                  
                  <msItem xml:id="ms_i9">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4626Prayer">Protective prayer against the spell</title>
                     <incipit xml:lang="gez">
                        ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነት፡ የአብ፡ ስሙ፡ አብ፡ ሸልሸልሸል፡ የወልድ፡ ስም፡ ሐፍሸልሸል፡ የመንፈስ፡ ቅዱስ፡ ስም፡ ጠብሸልሸል፡
                     </incipit>
                     <note>The prayer is followed by a figure consisting of squares divided by diagonal lines and circles.</note>
                  </msItem>       

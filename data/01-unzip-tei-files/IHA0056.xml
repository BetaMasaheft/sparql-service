                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="144v">1r-144v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0098IHA">فتح المجيد بكفاية المريد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ويبين عقائدها السُّنِّيَة الفائقة حملنى عليه بعض الاصدقاء حين احضرها في شهر رمضان العظيم من السنة الحادية بعد الخمسين والف فاحببته الى ذلك رغبة في الثوب وسميته فتح المجيد بكفاية المريد والله يجعله خالصا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#144v">-144v</locus>واستحضار عظمته وجلاله ابتداء  واستمرار او في حديث انس رض الله عنه ان النبي صلى الله عليه وسلم قرا قوله تعالى هل جزاء الاحسان الا الاحسان</explicit>
                     <note/>
                     <note/>
                  </msItem>

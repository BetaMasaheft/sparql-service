               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2r">1r-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0704IHA">صلاة عبد يرجو بها الىجاة</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم \ صلاة عبدٍ يرجو بها النجاة يوم تبدل الأرض غير الأرض والسموات صلا عبد ويتقي بها سوى عقباه يُوَيَنْمُرُ الا المرع  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>فكاأنما عبد الله اربعين سنة قيام ليلها وصبا[ح] نهارها هم ملك هذا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="3r">2r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0705IHA">مدح عبد القادر الجيلاني ابتديء ببسم الله بمدح غوث
                    الخلائق</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم \ شيخ الله شيخ الله سيخ الله شيخ عبد القادر شيخ الله عبد القادر سيّد يا عبد القادر المدد يا عبد القادر إبتدي ببسم الله بمدح غوث الخلائق جدّك اهل النجات واجعلني احسن عواقب سئلنا قادر </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>صلاتي مع سلام عدد اليل الايام اعثنا يوم التنادي بجاهي احمد مختاري اعطني ما في الضميري تملاني كل المحتاج</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3v" to="68r">3v-68r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0707IHA">مولد شرف العالمين</title>
                     <incipit xml:lang="ar"/>
                     <explicit xml:lang="ar"/>
                     <note>Collection of devotional poems recited and sung in Harar and other Ethiopian areas during Mawlid feasts and other Mawlid related ceremonies.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="3v" to="27r">3v-27r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0482IHA">تخميس الفيومي على البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>بسملة \ قال الشيخ الامام العالم حجة الأدب لسان العرب قدوة الانام \ بقية الساف الكرام شرف الدين ابو عبد الله محمد بن سعد الىوصـ \ البوصيري رحمه الله تعالى سبب انشإي لهذه القصيدة المباركة \ اني كنت قد اصابني خلط فالج ابطل نصفي </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>يا من تعلي ولا وصف يقول به للواصفين ولا مدح البرياتي \ يا خالق الخلق يا من لاشبيه له إسمع دعإى [كذا]  يسر لي حاجاتي \ امين امين لاأرض بوحدة حتى اكمّل ألف ألف أمين \ لا إله إلّا الله لا إله إلّا الله</explicit>
                     <note>
                        <note>
        Manuscript item  922 relates to manuscript item 924</note>
                        <note>
        Manuscript item  924 relates to manuscript item 922</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="27v" to="27v">27v-27v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1163IHA">نظم الوهم لا يدركه</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>بسم الله الرحمن الرحيم \ الوهم لا يدركه , والعجز لا يلحقه \ فهوه الذي نعبده , جل اله هو هو </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27v">-27v</locus>يا راحم الشيب أجر , من حر نار تستعر \ عبدا أتاك منكسر , سواك من يجبره</explicit>
                     <note>
                        <note>
        Manuscript item  5852 relates to manuscript item 924</note>
                        <note>
        Manuscript item  924 relates to manuscript item 5852</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="27v" to="28r">27v-28r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2983IHA">نص الصلاة والسلام الاتمان الاكملان</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>بسم الله الرحمن الرحيم \ بسم الله والحمد لله والصلاة والسلام الاتمان الاكملان \ ونبتدا ببسم الله ونسوق ميعه المولد اعوذ بالله من الشيطان الرجيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28r">-28r</locus>وبلغ رسوله النبي الكريم , والحمد لله رب العالمين , ان الله وملئكته يصلون على النبي , يايها الذين امنوا صلوا عليه وسلموا تسليما</explicit>
                     <note>
                        <note>
        Manuscript item  5853 relates to manuscript item 924</note>
                        <note>
        Manuscript item  924 relates to manuscript item 5853</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="28r" to="29r">28r-29r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0589IHA">سلامات على النبي السلام عليك زين الأنبياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#28r">-28r</locus>السلام عليك زين الانبياء السلام عليك اصفي الاصفياء \ السلام عليك يا بهج الضياء السلام عليك دام بلا انقضاء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#29r">-29r</locus>السلام عليك وذي النورين رأس الناسكين السلام عليك كذاك على السامي يقينا السلام على اصحابك اجمعين السلام عليك والك كلهم والتابعين</explicit>
                     <note>
                        <note>
        Manuscript item  5854 relates to manuscript item 924</note>
                        <note>
        Manuscript item  924 relates to manuscript item 5854</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="29v" to="68r">29v-68r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0706IHA">عنوان الشريف</title>
                     <incipit xml:lang="ar">
                        <locus target="#30r">-30r</locus>بسملة \ الحمد لله الذي شرف العالمين بالشرف العالمين \ واصطفاه من خاقه اجمعين ونبّاه وادم بين الماء والط \ الطّين ونوّه بذكره الأوّلين كما شرّف بقدره في الا \ الأخرين </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#68r">-68r</locus>واصحابه ذوي المكارم والتّقي فانّهم شمس الهدي والجواهر \ والتباعه والذّاخلين جواره مدا الذاهر ما دامت منّا والمشاعر</explicit>
                     <note>
                        <note>
        Manuscript item  923 relates to manuscript item 924</note>
                        <note>
        Manuscript item  924 relates to manuscript item 923</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>

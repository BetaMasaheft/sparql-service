                        <msItem xml:id="ms_i1">
                            <locus from="5ra" to="42va"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                            <textLang mainLang="gez"/>
                            <note>The penultimate stanza, which is present in only some manuscripts, begins with
                                <foreign xml:lang="gez">ስብሕት፡ ለአብ፡ ወወልድ፡ አአኵቶ፡</foreign>, see 
                                <bibl corresp="http://zotero.org/groups/358366/items/2CM9ZMCU"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Grohmann1919Marien"/><title level="m">Aethiopische Marienhymnen</title><title level="s">Abhandlungen der Sächsischen Akademie der Wissenschaften</title><author><forename>Adolf</forename><surname>Grohmann</surname></author><editor><forename>Adolf</forename><surname>Grohmann</surname></editor><pubPlace>Leipzig</pubPlace><publisher>Bei B. G. Teubner</publisher><date>1919</date><series><title level="s">Abhandlungen der Sächsischen Akademie der Wissenschaften</title><biblScope unit="volume">68, Abhandlungen der philologisch-historischen Klasse der Sächsischen Akademie der Wissenschaften, 33/4</biblScope></series><biblScope unit="volume">68, Abhandlungen der philologisch-historischen Klasse der Sächsischen Akademie der Wissenschaften, 33/4</biblScope><note type="url">https://digital.slub-dresden.de/werkansicht/dlf/447/9/</note><note type="tags"><note type="tag">Hymns</note><note type="tag">Mary</note><note type="tag">bm:Grohmann1919Marien</note></note><note type="tag">Hymns</note><note type="tag">Mary</note><note type="tag">bm:Grohmann1919Marien</note><citedRange unit="page">156</citedRange><citedRange unit="note">5</citedRange></bibl>.
                                The last stanza of the text in this manuscript is
                                <ref type="work" corresp="https://betamasaheft.eu/LIT1834Mahlet#Stanza157"><span xmlns="" class="w3-tag w3-red">No item: LIT1834Mahlet#Stanza157</span></ref> (see its text below).
                         .</note>
                            <explicit xml:lang="gez">
                                ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ መላእክት፡ ትጉሃን።  
                                ስብሐት፡ ለኪ፡ ማርያም፡ በጽ<cb n="b"/>ጌ፡ ነቢያት፡ ቅዱሳን።  
                                ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ሐዋርያት<supplied reason="omitted">፡</supplied> ፍንዋን።  
                                ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ሰማዕት፡ ወጻድቃን።  
                                ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ይደሉ፡ ለማኅሌተ፡ ጽጌኪ፡ ወይን።  
                                እስመ፡ በጽጌ<add place="below">ኪ</add>፡ ወይን፡ ይትፌሣሕ፡ ኅዙን፤
                            </explicit>
                            <explicit xml:lang="gez" type="supplication">
                                ኦእግዚእትየ፡ ማርያም፡  
                                ዕቀብኒ፡ <pb n="42v"/><cb n="a"/> ወአድኅነኒ፡ እመከራ፡ ሥጋ፡ ወነፍስ፡ ለገብርኪ፡ 
                                <persName role="owner" ref="https://betamasaheft.eu/PRS14763TaklaM">ተክለ፡ መድኅን፡</persName> ወምስለ፡ ጸሐፊሃ፡
                                <persName role="scribe" ref="https://betamasaheft.eu/PRS14764KidanaM">ኪዳነ፡ ማርያም፡</persName> ለዓለመ፡ ዓለም፡ አሜን።
                            </explicit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="43ra" to="66vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ኤ፡
                                ማርያም፡ ወላዲተ፡ አምላክ፡ ዘደረሰ፡ ላቲ፡ በመንፈስ፡ ቅዱስ፡ ሕርያቆስ፡ ኤጲስ፡ ቆደስ፡ ዘሀገረ፡ ብኅንሳ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="71ra" to="140vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT7331SaySelColl">Sayfa Śǝllāse-type collection</title>
                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i3.1">
                                <locus from="71ra" to="82vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7330IntroZenSe">Introduction to Zenā nagaromu la-śǝllāse</title>
                                <incipit xml:lang="gez">
                                    በስመ፡ <gap reason="ellipsis"/> ኦአብ፡ ረዳኤ፡ ኩነኒ፡ ኦወልድ፡ ነጽረኒ፡ ወስምዓኒ፡ ኦመንፈስ፡ ቅዱስ፡ አመ፡ ዕለተ፡ ጽራኅየ፡ ፍጡነ፡ ስምዓኒ። 
                                </incipit>
                                <incipit xml:lang="gez" type="embedded">
                                    <locus from="78ra" to="78rb"/>
                                    በስመ፡ <gap reason="ellipsis"/> ስቡሕ፡ ወውዱስ፡ ወእኩት፡ ንጽሐፍ፡ ዜና፡ ነገሮሙ፡ <supplied reason="omitted">ለሥላሴ፡</supplied> 
                                    በጽሒፍሰ፡ ኢንክል፡ ፈጽሞ፡ አላ፡ በከመ፡ አክሃለነ፡ እግዚአብሔር፡ ነገረ፡ ውዳሴሆሙሰ፡ ኢይክሉ፡ ሰማያ<pb n="b"/>ት፡ ወምድር።
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i3.2">
                                <locus from="82vb" to="90rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7331SaySelColl#Monday">Sayfa Śǝllāse-type collection, Monday</title>
                                
                                <msItem xml:id="ms_i3.2.1">
                                    <locus from="82vb" to="89ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Monday">Prayer for the weekdays, Prayer for Monday</title>
                                    <incipit xml:lang="gez">
                                        በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ ዘዕለተ፡ ሰኑይ፡ እግዚአብሔር፡ አምላኪየ፡ ዓቢይ፡ ወግሩም፡ ዘአልቦ፡ ጥንት፡ ወኢተፍጻሜት፡ 
                                        ወ<pb n="83r"/><cb n="a"/>ይሄሉ፡ እስከ፡ ለዓለም፡ እስእለከ፡ ወአስተበቍዓከ፡ ከመ፡ ትርድአኒ፡ ወታድኅነኒ፡ እምኵሉ፡ እኩይ፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.2.2">
                                    <locus from="89ra" to="90rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7311MTPromises">Miracle of the Trinity: Promises to the faithful</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <gap reason="ellipsis"/> ወአሐተ፡ ዕ<cb n="b"/>ለተ፡ ይቤ፡ አብ፡ ዘአክበረኒ፡ በምድር፡ አነ፡ አከብሮ፡ በመንግሥተ፡ ሰማያት፡ ገጸ፡ 
                                        አርያም፡ ይመስል፡ አምሳሊሁ፡ ዘወሀበኒ፡ መባዓ፡ ወስኂነ፡ ወስንዳሌ፡ ወወይነ፡
                                    </incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i3.3">
                                <locus from="90va" to="99rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7331SaySelColl#Tuesday">Sayfa Śǝllāse-type collection, Tuesday</title>
                                
                                <msItem xml:id="ms_i3.3.1">
                                    <locus from="90va" to="98rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT4691Prayer#Tuesday">Prayer for the weekdays, Prayer for Tuesday</title>
                                    <incipit xml:lang="gez">
                                        ጸሎት፡ ዘዕለተ፡ ሠሉስ፡ እግዚኦ፡ አርእየኒ፡ በረከተከ፡ በዛቲ፡ ዕለት፡ ሠናይት፡ ስማዕ፡ ጸሎትየ፡ ወተወከፍ፡ ስእለትየ፡ ወሥረይ፡ ሊተ፡ ኃጢአትየ፡
                                    </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i3.3.2">
                                    <locus from="98rb" to="99rb"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7314MTFather">Miracle of the Trinity: Promise by God the Father to the faithful</title>
                                    <incipit xml:lang="gez">
                                        ተአምራቲሆሙ፡ <gap reason="ellipsis"/><pb n="98v"/><cb n="a"/><gap reason="ellipsis"/> ወአሐተ፡ ዕለተ፡ ቦኡ፡ አብ፡
                                        ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ውስተ፡ ጽርሐ፡ አርያም፡ ወአእረፉ፡ ላእለ፡ መናብርቲሆሙ፡ ለፌ፡ ወለፌ፡ ወርእያ፡ ለዛቲ፡ በዓል፡ ዕለት፡ ዛቲሰ፡ በዓልየ፡ ወበዓለ፡ ወልድ፡ 
                                        ወበዓለ፡ <cb n="b"/> መንፈስ፡ ቅዱስ፡ ለዘአክበራ፡ ብእሲ፡
                                    </incipit>
                                </msItem>
                            </msItem>
                                
                                <msItem xml:id="ms_i3.4">
                                    <locus from="99va" to="107ra"/>
                                    <title type="complete" ref="https://betamasaheft.eu/LIT7331SaySelColl#Wednesday">Sayfa Śǝllāse-type collection, Wednesday</title>
                                    
                                    <msItem xml:id="ms_i3.4.1">

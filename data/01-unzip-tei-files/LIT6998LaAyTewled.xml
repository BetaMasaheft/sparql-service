                    <ab>       
                        <term key="Mawaddes" ana="#Mawaddes">መወደስ፡</term> ዘ<persName ref="https://betamasaheft.eu/PRS13090TebabaKrestos">ጥበበ፡ ክርስቶስ።</persName>
                        <l n="1">ለአይ፡ ትውልድ፡ እምኍልቈ፡ ትውልድ።</l>
                        <l n="2">ወለማእዜ፡ ዘመን፡ እምአዝማነ፡ አሃዱ።</l>
                        <l n="3">ማርያም፡ ለአብ፡ ታቦተ፡ ዋህድ፡ ወልዱ።</l>
                        <l n="4">ኪያኪ፡ መድሃኒተ፡ እንዘ፡ የሐስሱ፡ ነቢያት፡ እዱ።</l>
                        <l n="5">ቦእለ፡ ተሰዱ፡ እምሀገር፡ ሐገረ፡ ይብጽሖሙ፡ ዘኢለመዱ።</l>
                        <l n="6">መከራ፡ ነደ፡ እሳት፡ በነበልባሉ፡ ወነዱ።</l>
                        <l n="7">እስከኑ፡ አውአዮሙ፡ ወበልኦሙ፡ ሐበ፡ ከመ፡ እጸው፡ ተአለዱ።</l>
                        <l n="8">ኪያከሰ፡ ታቦተ፡ መድሃኒቶሙ፡ ዘክህዱ።</l>
                        <l n="9">ህማመ፡ ለርእሶሙ፡ በርእሶሙ፡ ፈቀዱ።</l>

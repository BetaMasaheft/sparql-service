               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus to="8v">Anterior pastedown-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2354IHA">فواتق الفلاح وبوارق الصلاح في ذكر مولد الناطق
                    بالنجاح</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم \ عليك الله سلما أحمد يا محمد \ صلي وسلم وبارك يا واحد \ صلي وسلم وبارك يا واجد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7r">-7r</locus>مبين لصدق لا فيه عيب كذب \ بذكره بسره قلب يطيب \ روائح لطيب ترويحه ندب</explicit>
                     <note>ff. 7v-8v blank</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="9r" to="10v">9r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1698IHA">صلاة ربّي صلّى على النبي الأفضل سلّم على الأكمل وبارك على
                    الأمثل</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>بسم الله الرحمن الرحيم \ ربي صلى على النبي الأفضل ٬ ربي سلم على النبي \ الأكمل ٬ ربي بارك على النبي الأمثل  ٬ وأله فهو جميل أجمل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>عباد الله وحد الله أذكر الله ٬ ثواب الله فى ثناء رسول الله \ دنيا وأخر ذلك أمين الله ٬ أحمد محمد شافع لا يخذل \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="11r" to="11v">11r-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="af">Afar</textLang>
                     <title ref="https://betamasaheft.eu/LIT1699IHA">دعاء بالعفرية بسم الله فيلل</title>
                     <incipit xml:lang="ar">
                        <locus target="#11r">-11r</locus>بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيْمِ \ رسول بركة نه روبي رسول حكاني نابي رسول جمعة ناني نورك نه كامى ربو \ لا إله إلّا الله محمد رسول الله [...] \ بِسْمِ اللهْ فَيْلَلْ يَا بُوْيِنَيْبُوْيِنْتِيْ كُوْ أَبُوْ حَزَنْ \ كُسَارِلْ حَبُوْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>بَلِّه ْ ذِكْرِلْ نِيْ أُوْبسِّيْ يَلَّكْ فَيْتُوْكُهْ أُبْتِيْ \ يَلَّكْ مِيْشِلْ رَمَّتِيْ مَكَّكْ مَدِيْنَلْ أُبْتِيْ أنْصَارْ كُنُوزِ كيتي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="12r" to="13v">12r-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1700IHA">دعاء الله أسعدنا بذكر محمد شرّفنا بنوره</title>
                     <incipit xml:lang="ar">
                        <locus target="#12r">-12r</locus>ألله لا إله إلا ألله محمد عبده ورسوله أسعدنا بذكره  شرفنا بنوره \ الله لا إله إلّا الله محمد عبده رسوله أسعدنا بذكره شرفنا بنوره</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>قال لو محمد أحمد يا الله يا الله \ وأله وصحبه أطاعو الله \ فاذكر والله عبا الله بفضل الله \ تمت بالخير عمت </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="14r" to="39v">14r-39v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1701IHA">أذكار لمولد النبي أنعمه الله في قبره</title>
                     <incipit xml:lang="ar">
                        <locus target="#14r">-14r</locus>بسم الله الرحمن الرحيم \ أنعمه الله في قبره من صلاته وتسليمه \ صلى الله عليه وسلم \ لقد من الله على المؤمنين إذبحث \ فيهم رسولا خلقه من نوره وصوره</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#36v">-36v</locus>أرحم من قلوبهم وعلمك أو فرد من \ علومهم أعطاك مفاتيح النصر ومفا \ تيح الشفاعة ومفاتيح النبوة ثم ردّه الى أمه مختونا مكحولا معطّرا \ فعطش فقال الحمد لله رب العالمين فقالت الملائكة رحمك الله</explicit>
                     <note>ff. 37r-39r blank</note>
                     <note/>
                  </msItem>

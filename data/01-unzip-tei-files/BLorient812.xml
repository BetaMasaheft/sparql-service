                          <msItem xml:id="ms_i1.3">
                            <locus from="97r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1011Abusak#Chapter48">ʾAbušākǝr: Chapter 48: Chronological data from Adam to the Hijra</title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i1.4">
                            <locus from="154r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1011Abusak#Chapter50">ʾAbušākǝr: Chapter 50: History of the Alexandrian Patriarchs</title>
                            <textLang mainLang="gez"/>

                            <msItem xml:id="ms_i1.4.1">
                              <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1011Abusak#ListPatriarchs">
                                The list of the patriarchs
                              of Alexandria</title>
                              <explicit xml:lang="gez"><locus target="#180v"/>
                              ፺ወ፯ <persName ref="https://betamasaheft.eu/PRS4381Gabriel">አባ፡ ገብርኤል፡</persName> ዘሀሎ፡ በዘመነ፡
                              <persName ref="https://betamasaheft.eu/PRS8550sardaDe">ንጉሥ፡ ሠርፀ፡ ድንግል።</persName>
                            <sic>፺ወ፰</sic> <persName ref="https://betamasaheft.eu/PRS5710JohnXV">አባ፡ ዮሐንስ።</persName>
                            <sic>፺ወ፱</sic> <persName ref="https://betamasaheft.eu/PRS6905Matthew">አባ፡ ማቴዎስ።</persName>
                            <sic>፻</sic> <persName ref="https://betamasaheft.eu/PRS6752Mark">አባ፡ ማርቆስ።</persName>
                            <note>The numbers are not conform to the traditional system, Mark V seems
                              to have been skipped.</note>

                            </explicit>
                            </msItem>
                            <msItem xml:id="ms_i1.4.2">
                              <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1011Abusak#SevenWonders">
                                The Seven Wonders of the World</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i1.4.3">
                              <locus target="#181r"/>
                              <title type="complete" xml:lang="en">The list of ʾabunas of Ethiopia</title>
                              <textLang mainLang="gez"/>
                              <note>The list starts with <persName ref="https://betamasaheft.eu/PRS8386SalamaI">Fǝremnāṭos</persName>
                              and ends with the 27th ʾabuna
                            <persName ref="https://betamasaheft.eu/PRS6775Marqos">
                              <certainty locus="value" match="../@ref" cert="medium"/>
                            </persName> who was buried in <foreign xml:lang="gez">ጅግኚ</foreign>.</note>
                            </msItem>
                          </msItem>

                        <handDesc>

                            <handNote script="Ethiopic" xml:id="h1">
                                <desc>The manuscript is neatly written,
                                  but with many erasures and alternations, of  the earlier part
                                  of <date>17th century.</date>
                                </desc>

                                <date notBefore="1670" notAfter="1700" resp="PRS10171Wright"/>

                            </handNote>

                        </handDesc>
                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus target="#1r"/>
                              <desc>
                                A crude table of the signs of Zodiac.
                              </desc>
                            </item>
                            <item xml:id="a2">
                              <locus target="#2r"/>
                              <desc>
                                A table in which the quarters of the sky are named as follows:
                                north <foreign xml:lang="gez">ሰሜን፡</foreign>,
                                north-east <foreign xml:lang="gez">መስዕ፡</foreign>,
                                east <foreign xml:lang="gez">ምሥራቅ፡</foreign>,
                                south-east <foreign xml:lang="gez">ሊባ፡</foreign>,
                                south <foreign xml:lang="gez">ደቡብ፡</foreign>,
                                south-west <foreign xml:lang="gez">አዜብ፡</foreign>,
                                west <foreign xml:lang="gez">ምዕራብ፡</foreign>,
                                north-west <foreign xml:lang="gez">ባሕር፡</foreign>.
                              </desc>
                            </item>
                            <item xml:id="a3">
                              <locus target="#2v"/>
                              <desc type="Unclear">
                                Note related to ʾAbušākǝr.
                              </desc>
                              <q xml:lang="gez">ለባሕረ፡ ሐሳብ፡ ዕሙቅ፡ ፍኖተ፡ እዝራ፡ ሰሊክ፡ ጠቢባን፡
                              የሐውርዎ፡ በሐመረ፡ ጥበብ፡ ከመ፡ ሲራክ። ዘደብረ፡ ሊባኖስ፡ ሰሊክ፡ ወዘደብረ፡ ብስራት፡
                            አበሞ፡ ለአቡሻክር፡ ተመሰልዎ፡ መጽሐፈ፡ ሐሳብ፡ በተርጉሞ። አኮ፡ መንክር፡ ለእመ፡ ኮነ፡ ስሕትት፡ እምነ፡
                          መንክር፡ ግብረ፡ አምላክ፡ እስመ፡ ግብረ፡ አምላክ፡ ኢይትሐተት።</q>
                            </item>
                            <item xml:id="a4">
                                <locus target="#3r"/>
                                <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                    <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                                <q xml:lang="gez">አቡሻክር፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">መድኃኔ፡ ዓለም።</placeName>
                       </q>
                            </item>
                            <item xml:id="a5">
                              <locus target="#3r"/>
                              <desc type="MixedNote">Note which states that the work was translated at the
                              suggestion of <persName ref="https://betamasaheft.eu/PRS8410Salikof">Salik</persName>
                              of <placeName ref="https://betamasaheft.eu/LOC2296DabraL">Däbrä Libanos</placeName>
                            by <persName ref="https://betamasaheft.eu/PRS3779enbaqom">ʾƎnbāqom</persName>, the translator of king
                          <persName ref="https://betamasaheft.eu/PRS8550sardaDe">Śarḍa Dǝngǝl</persName>.</desc>
                          <q xml:lang="gez">
                            ዝንቱ፡ መጽሐፍ፡ ዘአዘዞ፡ ዘአዕለዎ፡ <persName ref="https://betamasaheft.eu/PRS8410Salikof">ሰሊክ፡</persName>
                            ዘ<placeName ref="https://betamasaheft.eu/LOC2296DabraL">ደብረ፡ ሊባኖስ፡</placeName> በእደ፡
                            <persName ref="https://betamasaheft.eu/PRS3779enbaqom">እጨጌ፡ ዕንበቆም፡</persName>
                            <sic resp="PRS10171Wright">መተርጉመ፡</sic>
                            መጻሕፍት፡ ዘሠርፁ፡ ወዘተዓገሎ፡ ወዘአውጽኦ፡ እምደብር፡ እንበለ፡ ፈቃደ፡ ማኅበር፡ እመሂ፡ ንጉሥ፡
                            ወእመሂ፡ መኰንን፡ በአፈ፡ ፲ወ፪ ሐዋርያት፡ ወበአፈ፡ ፫፻፲ወ፰ ርቱዓነ፡ ሃይማኖት፡ ወበአፈ፡ አቡነ፡
                            ተክለ፡ ሃይማኖት፡ ወበአፈ፡ ፲ወ፪ ኅቡራነ፡ እድ፡ ውሉዱ፡ ለአቡነ፡ ተክለ፡ ሃይማኖት፡ ወበአፈ፡ ኵሎሙ፡
                            መምሕራን፡ ዘደብረ፡ ሊባኖስ፡ ውጉዝ፡ ለይኩን፡ አሜን፡ ወአሜን።
                          </q>
                            </item>

                          </list>
                        </additions>
                        <bindingDesc>
                          <binding contemporary="true" xml:id="binding">
                              <decoNote xml:id="b1">
                                In the original boards, covered with blind-tooled leather, and
                                lined with red cloth.</decoNote>

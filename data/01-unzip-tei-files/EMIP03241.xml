                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Two miracles of the Trinity</note>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="31r" to="37r" facs="031">Fols 31r–37r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">Malkǝʾa

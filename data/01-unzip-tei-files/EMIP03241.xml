                </msItem>
                  <msItem xml:id="ms_i4"><locus from="37v" to="43v" facs="038">Fols 37v–43v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾ-hymn to St
                                                  George</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <incipit xml:lang="gez">ሰላም: ለዝክረ: ስምከ: ዘሰሌዳ: ሞገስ: መጽሐፉ:</incipit>
                </msItem>
                  <msItem xml:id="ms_i5"><locus from="45r" to="63r" facs="045">Fols 45r–63r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>written in two columns</note>
                </msItem>
                  <msItem xml:id="ms_i6"><locus from="63r" to="65r" facs="063">Fols 63r–65r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa
                                                  malāʾǝkt la-Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>written in two columns</note>
                </msItem>

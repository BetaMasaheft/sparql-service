                  <origin>
                     <origDate notBefore="1889" notAfter="1913"><locus target="#2r" facs="002">Fol. 2r</locus> mentions “our Pope Matewos” (1889‒1926) and “our King Menilek” (1889‒1913).</origDate>
                  </origin>
               </history>
            </msDesc>

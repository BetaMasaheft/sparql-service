               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="5v">1r-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1871IHA">خطبة إستقبال شهر رجب</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ألحمد لله قدّر الأمور كما يشاء ويختار وجعل الليل \ مظلما للسكون والإستتار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5v">-5v</locus>والأرض منها أربعة حرم ذلك الدين القيم \ فلا يظلموا فيهنّ أنفسكم بارك لي ولكم [...] البرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6r" to="10r">6r-10r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2239IHA">خطبة الحث على الطاعة في رجب</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>ألحمد لله فتح أبواب الجود للراغبين وأظهر \ غناه للمحتاجين وقال تعالى يأيها الناس أنتم الفقراء \ إلى الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10r">-10r</locus>ومن يطع الله ورسوله فقد فازفوزا \ عظيما بارك الله لي ولكم [...] هو الغفور الرحيم والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="10v" to="17v">10v-17v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1833IHA">خطبة الإسرا والمعراج</title>
                     <incipit xml:lang="ar">
                        <locus target="#10v">-10v</locus>ألحمد لله الذي شرّف رسولنا بنسبته إليه باالعبودية \ وقال تعالى سبحان الذي أسرى بعبده ليلا من المسجد الحرام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17v">-17v</locus>سبحان الذي أسرى بعبده ليلا من المسجد الحرام إلى المسجد الأ \ الأقصا [كذا] الذي باركنا حوله لنرية من أياتنا إنه هو السميع البصير بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="18r" to="23v">18r-23v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1914IHA">خطبة في استقبال شهر شعبان</title>
                     <incipit xml:lang="ar">
                        <locus target="#18r">-18r</locus>ألحمد لله جعل لنا مواسم لعبادته لنتدارك مافاتنا من \ طاعته فنكون أهلا لإكرامه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>أليوم نختم على أفواههم وتكلّمنا أيد \ يهم وتشهد أرجلهم بما كانوا يكسبون بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note>f. 23v blank</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="24r" to="28r">24r-28r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1883IHA">خطبة السعي للسعادة في ليلة النصف من شعبان</title>
                     <incipit xml:lang="ar">
                        <locus target="#24r">-24r</locus>ألحمد لله أحبّاءه في الدنيا بذكره وزيّنهم فيها \ بطاعته وشكره وأنار قلوبهم باالصوم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28r">-28r</locus>ربّنا أتنا من لدنك رحمة وهي لنا من أمرنا رشدا بارط الله لي ولكم [...]  والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="28v" to="34v">28v-34v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1915IHA">خطبة في استقبال رمضان والإستعداد له</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>ألحمد لله الذي شرّفنا تباع سيّد الكائنات وجعل \ الديانة الإسلامية فوق جميع الديانات وهدانا إلى \ الحق</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34v">-34v</locus>ولا يريد بكم العسر \ ولتكملوا العدّة ولتكبّر الله على ما هداكم ولعلّكم تشكرون بارك الله لي ولكم [...]  والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="35r" to="40v">35r-40v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2017IHA">خطبة التاسعة والأربعون في صيام رمضان وقيامه</title>
                     <incipit xml:lang="ar">
                        <locus target="#35r">-35r</locus>ألحمد لله الذي جعل الصيام جنة \ ورياضة للنفوس المطمئنة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#39v">-39v</locus>يأيها الذ \ ين أمنوا كتب عليكم الصيام كما كتب على الذين من قبلكم \ لعلّكم تتقون بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note>ff. 40r-v blank</note>
                     <note/>
                  </msItem>
               </msContents>

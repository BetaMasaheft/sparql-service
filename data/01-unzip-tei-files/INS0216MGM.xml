      <t:body>
         <listPlace>
            <t:place type="church gatar" subtype="institution">
               <t:placeName>Mǝʾǝsār Gʷǝḥilā Qǝddus Mikāʾel</t:placeName>
               <t:placeName type="alt">Mikāʾel Mǝʾǝsār Gʷǝḥilā</t:placeName>
               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>

               <t:settlement type="warada" from="2012-05-19" to="2012-05-19" ref="https://betamasaheft.eu/LOC3293GantaA">Gāntā ʾAfašum</t:settlement>
               <t:settlement type="tabiya" from="2012-05-19" to="2012-05-19" ref="https://betamasaheft.eu/LOC7254AddiQanay">ʿĀddi Qanay</t:settlement>

               <t:settlement from="2012-05-19" to="2012-05-19" type="qushat" ref="https://betamasaheft.eu/LOC7255Meesar">Mǝʾǝsār Gwǝḥilā</t:settlement>

               <t:location>
                  <t:geo>14.2844 39.315267</t:geo>
                  <t:height unit="m">2079.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1200" notAfter="1300">1200-1300</t:date>
                  <t:desc type="foundation">Post-Aksumite potsherds (dating between 700/800 and 1200/1300 A.D.), remains of early medieval structures have been recorded at the site. According to local tradition, the church was founded by <t:persName ref="https://betamasaheft.eu/PRS7594Noah">Noah</t:persName> (? or a certain local Noy ?).
                     The name of the area, <t:placeName ref="https://betamasaheft.eu/LOC7254AddiQanay">ʿĀddi Qanay</t:placeName>,  is said to have been derived from "Noy" (<t:persName ref="https://betamasaheft.eu/PRS7594Noah">Noah</t:persName>; <t:quote xml:lang="gez">ʿĀddi daqqi Noy</t:quote>).</t:desc>
                  <t:ab type="history">Gatar. 
                     Burial places are located under the overhanging rock, along the river <t:placeName ref="https://betamasaheft.eu/LOC1451Angar">ʾAngār</t:placeName>. The old deserted church rock-churcn stands behind the recently built one.
                     Two ruined structures standing closer to the entrance into the gorge are said to be churches of "<t:persName type="tabot" ref="https://betamasaheft.eu/PRS10429Yohanni">ʾabbā Yoḥanni</t:persName>" and "<t:persName type="tabot" ref="https://betamasaheft.eu/PRS1257Aboli">ʾabbā ʾAboli</t:persName>" (?).     
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/MGM.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>19 Mss. photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm001">MGM-001</t:ref> “Miracles of Jesus”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm002">MGM-002</t:ref> “Homily of st. Michael; Miracles of St. Michal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm003">MGM-003</t:ref> “Collection of Homilies”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm004">MGM-004</t:ref> “Pauline Epistles; Acts of the Apostles; Catholic Epistles; Apocalipse of John”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm005">MGM-005</t:ref> “Synaxarion (The first half of the years)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm006">MGM-006</t:ref> “Miracles of Mary”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm007">MGM-007</t:ref> “Vita of the Apostles”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm008">MGM-008</t:ref> “Miracles of Jesus ”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm009">MGM-009</t:ref> “Synaxarion (The second half of the year)”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm010">MGM-010</t:ref> “Praise of Mary; Collection; Images of the Praise; A Part of Dǝggwa”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm011">MGM-011</t:ref> “Prayer of Incense; Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm012">MGM-012</t:ref> “Vita of Libanos Miracles of Libanos”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm013">MGM-013</t:ref> “Vita of Gäbrä Mänfäs Qǝddus; Miracles of Gäbrä  Mänfäs Qǝddus”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm014">MGM-014</t:ref> “Vita of Gäbrä Mänfäs Qǝddus; Miracles of Gäbrä  Mänfäs Qǝddus”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm015">MGM-015</t:ref> “The Book of the Baptismal Rite”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm016">MGM-016</t:ref> “Vita of ʾArägawi”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmgm017">MGM-017</t:ref> “The Book of the Funeral Rite”; MGM-leaves 1 (18) Fragments of different manuscripts; MGM-leaves 2 (19) Fragments of different manuscripts.</t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="4"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</t:persName>,
                     <t:persName type="tabot" ref="https://betamasaheft.eu/PRS1284Abrehaa">ʾAbrǝhā and ʾAṣbǝḥa</t:persName> (reportedly the tābot of the old church), <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS12519TwentyFour">Twenty-Four Heavenly Priests</t:persName>.</t:ab>
               </t:note>
            </t:place>
         </listPlace>

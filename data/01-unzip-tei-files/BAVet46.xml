                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="119r" facs="0004"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4319GadlaEA">Gadla ʾEwosṭātewos</title>
                     <listBibl type="secondary">
                        <bibl corresp="http://zotero.org/groups/358366/items/F258ZQFF"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Lusini1996Ewostatewos"/><title level="a">Sulla tradizione manoscritta degli «Atti» di ʾĒwosṭātēwos (&lt;hi rend="italics"&gt;BHO&lt;/hi&gt; 295 = KRZ 49)</title><title level="j">Quaderni Utinensi</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Gianfrancesco</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Lusini</t:surname></author><date>1990</date><biblScope unit="volume">8</biblScope><biblScope unit="issue">15–16</biblScope><biblScope unit="page">353–365</biblScope><citedRange unit="page">354-356</citedRange></bibl>
                        <bibl corresp="http://zotero.org/groups/358366/items/IA6C6EXN"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Taddesse1972Church"/><title level="m">Church and State in Ethiopia 1270–1527</title><title level="s">Oxford Studies in African Affairs</title><author><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Taddesse Tamrat</t:name></author><pubPlace>Oxford</pubPlace><publisher>Clarendon Press</publisher><date>1972</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Oxford Studies in African Affairs</t:title></series><citedRange unit="page">206-219</citedRange></bibl>
                     </listBibl>
                     <msItem xml:id="ms_i1.1">
                        <locus from="2r" facs="0004"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4319GadlaEA#Introduction">Gadla ʾEwosṭātewos, Introduction</title>
                        <incipit xml:lang="gez">
                           በስመ፡ እግዚአብሔር፡ አብ፡ ቀዳማዊ፡ ዘእንበለ፡ ይእዜ፡ ወማእከላዊ፡ ዘእንበለ፡ ማእዜ፡ ወደኀራዊ፡ እስከ፡ ይእዜ፨ 
                              <sic>አብ፡</sic>
                            እሴብሕ፡ ዘመልዕልተ፡ ልዑላን፡
                           የኀድር፡ በ<add place="inline">
                              <supplied reason="omitted">አ</supplied>
                           </add>ርያም፡
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="3r" to="119r" facs="0005"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4319GadlaEA#Vita">Gadla ʾEwosṭātewos, Vita</title>
                        <incipit xml:lang="gez">
                           ገድል፡ ዘቅዱስ፡ ወብፁዕ፡ 
                              <sic>ዘአበ፡</sic>
                            ኤዎስጣቴዎስ፡ መነኮስ፡ ዘብሔረ፡ 
                              <sic>ኢት<supplied reason="omitted">ዮ</supplied>ብያ።</sic>
                            ድንግል፡ ሕሩይ፡ 
                              <sic>ወከህን፡</sic>
                           
                           ንጹሕ፡ ነቢይ፡ ቅዱስ፡ ወመነኮስ፡ ፍጹም። ዘእም<add place="inline">
                              <supplied reason="omitted">ት</supplied>
                           </add>ካት፡ ወኣየድዕ፡ ዘእምቅድም፡ በእንተ፡ አብ፡
                           ቅዱስ፡ 
                              <sic>መንፈሳዌ፡</sic>
                            ዐቃቤ፡ ሕጋቲሁ፡ ለእግዚአብሔር፡ ዘሐይወ፡ እምንእሱ፡ በሕገ፡ ቀኖና። ዳግማዊ፡ ሙሴ፡ ወኤልያስ፡ ሐዲስ፡ ቀናኢ፡
                           
                              <sic>ላሕገ፡</sic>
                            አምላኩ። ዳግማዊ፡ ጴጥሮስ፡ ዘተውህቦ፡ መራኁተ፡ መንግሥተ፡ ሰማያት። ዳግማዊ፡ 
                              <sic>ጰውሎስ፡</sic>
                           
                           
                              <sic>መተሎሁ፡</sic>
                           
                           
                              <sic>ላቃሌምንጦስ፡</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ወዘንተ፡ ተዘኪሮሙ፡ ደቂቁ፡ ለአቡነ፡ ኤዎስጣቴዎስ። ወዘአቡሆሙኒ፡ ፍቅረ፡ ይዜከሩ፡ ወይሰቀሉ፡ በትምህርተ፡ ቃሉ። ወያፈቅሩ፡ ሰሚዓ፡ ዜና፡ ኂሩቱ፡ 
                              <sic>ወይዓቅቡ፡</sic>
                           
                           
                              <sic>ሥርዓቱ፡</sic>
                            ወይትሜነዩ፡ በዊአ፡ ውስተ፡ ርስቱ። ጸሎቶሙ፡ ወበረከቶሙ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           የሀሉ፡ ምስሌነ፡ ወበረከቱ፡ ለአቡነ፡ ኤዎስጣቴዎስ፡ ወተስፋ፡ በረከቱ፡ ይክድነነ፡ ከመ፡ ሐይመት። <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           ወይሕድር፡ ላዕሌነ፡ ወውስተ፡ ማኅበርነ፡ በረከተ፡ ጸሎቱ፡ ወዘኵሎሙ፡ ደቂቁ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           በሥነ፡ ምግባሮሙ፡ ወበአሚኖቶሙ። በገድሎሙ፡ ወበትዕግሥቶሙ፡ ወበሃይማ<supplied reason="omitted">ኖ</supplied>ቶሙ፡ ለዓለም፡ ወለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን።
                        </explicit>
                     </msItem>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="119r" to="128v" facs="0121"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles">Taʾammǝra ʾEwosṭātewos</title>
                     <incipit xml:lang="gez">
                        ንንግርኬ፡ ንሕነኒ፡ ዘሰማዕነ፡ በከመ፡ ይቤ፡ እግዚእነ፡ በዘ፡ 
                           <sic>ነአምር፡</sic>
                         ንነግር፡ ወበዘርኢነ፡ ሰማዕተ፡ ንከውን።
                     </incipit>
                     <msItem xml:id="ms_i2.1">
                        <locus from="119r" to="120r" facs="0121"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#RichMonk">On the rich monk and the locusts</title>
                        <incipit xml:lang="gez">
                           ዜነዉ፡ ከመ፡ ሀሎ፡ ፩መነኮስ፡ ባዕል፡ ዘብዙኅ፡ ጥሪቱ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወጸንዐ፡ በትምህርቱ። ወጸንዐት፡ ቤቱ፡ ፈድፋደ፡ እምዘቀዳሚ፡ ንብረቱ። ጸሎቱ፡ ወበረክቱ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                           ወአሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i2.2">
                        <locus target="#120v" facs="0123"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#Abdabal">On ʾAbdabal the sinner</title>
                        <incipit xml:lang="gez">
                           ወካዕበ፡ ሀሎ፡ ፩ብእሲ፡ ኃብካስ፡ ጽጉበ፡ 
                              <sic>አበ<add place="inline">
                                    <supplied reason="omitted">ሰ</supplied>
                                 </add>፡</sic>
                           
                           ዘስሙ፡ አብደበል፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወይቤ፡ ድኅንኩ፡ በጸሎተ፡ <choice>
                              <sic>በውየ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">አቡየ፡</corr></choice>
                            ለነኒ፡
                           
                              <sic>ያድኅነ፡</sic>
                            ጸሎቱ።
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i2.3">
                        <locus from="121r" to="122r" facs="0123"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#Woman">On the woman who could observe the Sabbath</title>
                        <incipit xml:lang="gez">
                           ወሀለወት፡ አሐቲ፡ ብእሲት፡ ወትገብር፡ ተዝካሮ፡ ለቅዱስ፡ አቡነ፡ ኤዎስጣቴዎስ። ወወፈረት፡ ምስለ፡ አዋልዲሃ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወእምዝ፡ ሶበ፡ ፈጸመት፡ አብስሎ፡ ወትቤሎ፡ ለፀሐይ፡ ፍቱሐ፡ ኩን፡ 
                              <sic>ባጸሎተ፡</sic>
                            ኤዎስጣቴዎስ፡ ወበጊዜሃ፡ ዐረበ፡ ፀሐይ፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i2.4">
                        <locus from="122r" to="122v" facs="0124"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#BurektMaryam">On the vision of the widow Burǝkt Māryām</title>
                        <incipit xml:lang="gez">
                           
                              <sic>ንግበእኬ፡</sic>
                           
                           
                              <sic>ኀበጾተ፡</sic>
                            ነገር፡ 
                              <sic>ወከዕበ፡</sic>
                            ሀለወት፡ አሐቲ፡
                           መበለት፡ እንተ፡ ሐ<add place="inline">
                              <supplied reason="omitted">ይ</supplied>
                           </add>ወት፡ በትምህርተ፡ ኤዎስጣቴዎስ፡ ወትገብር፡
                           
                              <sic>ተዝከሮ፡</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ወእምዝ፡ 
                              <sic>ገብኣ፡</sic>
                            ነፍሳ፡ ውስተ፡ ሥጋሃ፡ ርእያ፡ 
                              <sic>ዛንተ፡</sic>
                            ኵሎ፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i2.5">
                        <locus from="122v" to="123v" facs="0125"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#EvilMan">On the evil man who was saved by the saint</title>
                        <incipit xml:lang="gez">
                           ወሀሎ፡ 
                              <sic>ከዕበ፡</sic>
                            ፩ብእሲ፡ ቀታሌ፡ ነፍስ፡ ወሰራቂ፡ ዓዲ። ወይትአመን፡ በጸሎተ፡ ኤዎስጣቴዎስ፡ ወይገብር፡
                           
                              <sic>ተዝከሮ፡</sic>
                            ለቅዱስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ተውህቦ፡ ለኤዎስጣቴዎስ፡ እምኀበ፡ እግዚአብሔር፡ ከመ፡ ያኅድግ፡ ነፍሰ፡ 
                              <sic>እመልእክተ፡</sic>
                            ጽ<supplied reason="omitted">ል</supplied>መት፡
                           ጸሎቱ፡ ወተንብሎቱ፡ ለቅዱስ፡ ኤዎስጣቴዎስ፡ የሀሉ፡ ምስሌነ፡ ለዓለመ፡ ዓለም፡ አሜን።
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i2.6">
                        <locus from="124r" to="128v" facs="0126"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4315Miracles#Death">On the death of ʾEwosṭātewos</title>
                        
                        <incipit xml:lang="gez">
                           ንግባእኬ፡ ኀበ፡ ጥንተ፡ ነገር፡ ወበእንተ፡ እለ፡ ነገዱ፡ ኢየሩሳሌም፡ ምስለ፡ አባ፡ ኤዎስጣቴዎስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           መኑ፡ እመ፡ ኢያውሐዘ፡ አንብዖ፡ አላ፡ ለእመ፡ ኮነ፡ ጽኑዕ፡ ልቡ፡ ወዘአልቦ፡ ምሕረተ፡ ውስተ፡ ልቡ፡ ወዘኢኮነ፡ ክፍሉ፡ ምስለ፡ ኤዎስጣቴዎስ።
                        </explicit>
                        <explicit type="subscriptio" xml:lang="gez">
                           <locus from="128r" to="128v" facs="0130"/>
                        ተወጠነ፡ ወተጽሐፈ፡ ገድለ፡ አባ፡ ኤዎስጣቴዎስ፡ በከመ፡ ኮነ፡ አብ፡ አብሳዲ፡ በደብረ፡ ማርያም፡ በከመ፡ 
                              <sic>ባረካ፡</sic>
                            ላዕሌሁ፡ ለሊሁ፡ መጺኦ፡ እምብሔረ፡
                        አርማንያ፡ ተጽዒኖ፡ በደመና፡ እስከ፡ ብሔረ፡ ኢትዮጵያ። ጸሎቱ፡ ወበረከቱ፡ ተሀሉ፡ ምስሌነ። 
                              <sic>ላዓለም፡</sic>

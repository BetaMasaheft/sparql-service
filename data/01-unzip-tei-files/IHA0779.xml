               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="6v">1r-6v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1883IHA">خطبة السعي للسعادة في ليلة النصف من شعبان</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>أالحمد [كذا] لله نعّم أحبّاءه في الدنيا بذكره \ وزيّنهم فيها بطاعته وشكره وأنار \ قلوبهم بالصوم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6v">-6v</locus>فإنّه لم يدع بها رجل \ مسلم فى شيئ قطّ إلّا إستجاب الله رواه الترمذىّ عن سعد بن \ أبي \ وقّاص رضى الله عنه بارك الله لي وله [...]ا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="7r" to="14r">7r-14r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1915IHA">خطبة في استقبال رمضان والإستعداد له</title>
                     <incipit xml:lang="ar">
                        <locus target="#7r">-7r</locus>الحمد لله الذي شرّفنا باتباع سيد الكائنات \ وجعل الديانة الإسلامية فوق جميع \ الديانات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>يريد الله \ بكم اليسر ولا يريد بكم العسر ولتكملوا العدّة ولتكبّر الله على ما هداكم ولعلّكم تشكرون بارك الله لي ولكم [...] والبرّ الكريم </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="14v" to="20r">14v-20r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2017IHA">خطبة التاسعة والأربعون في صيام رمضان وقيامه</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>الحمد لله الذي جعل الصيام جنّة وسببا موصلا إلى \ الجنّة ورياضة للنفوس المطمئنة ولجامحات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20r">-20r</locus>يا أيها الذين أمنوا كتب عليكم الصيام \ كما كتب على الذين من قبلكم لعلّكم تتقون \ بارك الله لي ولكم [...] والبر الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="20v" to="22v">20v-22v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1832IHA">خطبة النعت</title>
                     <incipit xml:lang="ar">
                        <locus target="#20v">-20v</locus>الحمد لله الوحد الأحد الفرد الصمد الذي لم \ يلد ولم يولد ولم يكون له كفوا أحد نحمده \ حمدا لا يحدّ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22v">-22v</locus>الله أمر باالعد والإحسان وإتاءذ القربوينهى عن الفحشاء والمكى والبغي بعظكم لعلّكم تذكرون وستغفرك وأتوب إليك أقم الصلاة</explicit>
                     <note/>
                     <note/>
                  </msItem>

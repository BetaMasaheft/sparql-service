                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#2v">f. 2v</locus>
                           <desc type="GuestText">Miracle of the angel <persName ref="https://betamasaheft.eu/PRS7840Phanuel">Phanuel</persName>.</desc>
                           <q xml:lang="gez"/>                           
                           <note> The initial line is rubricated. It addresses the angel Fānuʾel as
                              the healer of infertility. </note>
                        </item>
                        <item xml:id="e1"><desc>- The title of the work, ችሮስ, is written, in green paint,
                           on the front board. </desc> </item>
                        <item xml:id="e2"><desc> - The word ጳራቅሊጦስ is written twice in ink:
                           <locus target="#3r">3r</locus>. </desc> </item>
                        <item xml:id="e3"><desc> - Inscription in the upper
                           margin: ሰአልሁ፡ አለም፡ ወጽመምር፡ ገበረእግዛብሔር: <locus target="#4r">4r</locus>,
                           44v.</desc></item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards covered with reddish-brown tooled
                           leather.
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible in the centre
                           fold of the quires, close to the head and tail of the codex.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the reddish-brown leather
                           cover (at least 4 tools were used: double line fillet, double circle,
                           x-form, criss-cross).</decoNote>
                     </binding>

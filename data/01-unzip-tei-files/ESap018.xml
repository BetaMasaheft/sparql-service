                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red (strong scarlet, deep scarlet)</seg>
                        <date>20th century</date>
                        <seg type="rubrication">Divine names; name of the protagonist; second
                           component of the names of the donors; two groups of lines (alternating
                           with black lines) on the incipit page; quire mark on fol. 5r; elements of
                           the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>

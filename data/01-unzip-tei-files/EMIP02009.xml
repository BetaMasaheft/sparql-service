                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#47r #48v" facs="049 051">Fols. 47r, 48v</locus>
                           <desc type="GuestText">
                              Table Prayer, “We beseech you,”  <foreign xml:lang="gez">ሰአልናከ፡</foreign>, written in purple ink.
                              Incipit: <foreign xml:lang="gez">‎ሰአል፡ናከ፡ ፈጣሪ፡ ሰአልናከ፡ ገባሪ፡ ሰአልናከ፡ መሐሪ፡ ሥሉስ፡ ‎‎ዘኢይትፈለጥ፡ ወዘኢይትሌለይ፡ ዘሰአሉከ፡ በተአምሮ፡ ወለብዎ፡ የማንከ፡ ‎‎ነቅዓ፡ ሕይወት፡ ወመድኃኒት፡<gap reason="omitted"/>
                              </foreign>
                           </desc>
                        </item>
                        <item xml:id="a2">
                            <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc type="OwnershipNote">
                            Trinitarian formula, in blue ink. </desc>
                          <note>Note
                            of secondary ownership, Wärqǝnäš Gäbǝre, in black ink;
                            see also <locus target="#8r" facs="010">fols. 8r, </locus>, top margin,
                            and passim. <locus target="#22r" facs="024">22r</locus> mentions
                            probable family members</note>
                        </item>
                        <item xml:id="e1">
                          <locus target="#iv(erso) #iiv(erso)" facs="002 003">Fols. iv(erso), iiv(erso)</locus>
                           <desc>

  <item xml:id="a2">
  <locus target="#4r"/>
    <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
            <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
        <q xml:lang="gez">ድርሳነ፡ ሚካኤል፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName></q>
</item>

<item xml:id="a3">
<locus target="#11v"/>
<desc type="ProtectivePrayer">According to the note the original owner of the manuscript was <persName ref="https://betamasaheft.eu/PRS13401GabraIyasus">Gabra ʾIyasus</persName>.</desc>
<q xml:lang="gez"><seg part="F">ወኢይመውኦ፡ ጸላዒሁ፡ ወኢይሬኢ፡ ኵነኔ፡ አመ፡ ዕለተ፡ ሞቱ፡ ወይባልሖ፡ ቅዱስ፡ ሚካኤል፡ ለፍቁሩ፡ ገብረ፡ ኢየሱስ።</seg></q>
</item>

<item xml:id="a4">
<locus target="#4r"/>
<desc type="OwnershipNote">A later owner was dabtarā <persName ref="https://betamasaheft.eu/PRS13400Estifanos">ʾƎsṭifānos</persName>.</desc>
<q xml:lang="gez">ዝድርሳን፡ ዘደብተራ፡ እስጢፋኖስ፡</q>
</item>

</list>

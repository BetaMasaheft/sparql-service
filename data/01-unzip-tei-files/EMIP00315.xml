                  <locus target="#1r #12v #19v #28v #35r #40r #48r #58r #65r #69v #80r #90v #93r #98v #103v #114r" facs="002 014 021 030 036 041 049 059 066 071 081 092 094 100 105 115">1r, 12v, 19v, 28v, 35r, 40r, 48r, 58r, 65r, 69v, 80r, 90v, 93r, 98v, 103v, 114r, </locus> (line of alternating red and black dots);
                  <locus target="#130r #134v" facs="131 136">130r, 134v</locus> (multiple full stops)
                  </decoNote>

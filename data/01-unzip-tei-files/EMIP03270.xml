                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  </seg>
                  <desc>The name of God is usually not systematically rubricated. Occasionally, it is partially rubricated with the last four letters rubricated</desc>
                  <desc>The entire first line of each section of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</ref> is rubricated</desc>
                    <desc>The Praise at the conclusion of <ref type="item" target="#ms_i1.3"/>, <locus target="#103r" facs="103"/>, alternates red and black ink for the letters</desc>
                    <desc>Scribal doxology at the conclusion of <ref type="item" target="#ms_i1.3"/>, <locus target="#103r" facs="103"/>, written in alternating letters in red and black inks</desc>
                  <desc><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps28">No item: LIT2000Mazmur, could not check for Ps28</ref>, <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps150">Mazmura Dāwit, Psalmus 150</ref>, and <ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa#ThreeYouths3">Third Song of the Three Youths in the Furnace,  ThreeYouths3</ref> employ columetric rubrication</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r #1v" facs="001 002"/><desc>Crude drawings of figures, in both pencil and blue ink pen</desc></decoNote>
                    <decoNote xml:id="d2">Intricate and colorful harags throughout</decoNote>
                    <decoNote xml:id="d3"><locus target="#115v" facs="115"/>, a harag in pencil</decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#1v" facs="002"/>
                    <desc type="Genealogy">
                    Family genealogy, written by a trained hand of the early-twentieth century, beginning with King Akuno Amlak.
                    <q><foreign xml:lang="gez">ጋንትሬ፡ ሰአሉ፡ ሰበንን፡ ትወልዳ፡ ሰበን፡ የአጤ ይኩኖ አምላክ ልጅ፡ ጐሽ፡ ውጋን፡ አግብታ፡ ገዛኃኝን፡ ትወል[ዳ]ለች፡ ገዛኝ፡ ጓሌን፡ ይወልዳል፡ <gap reason="omitted"/></foreign></q>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#114r" facs="114"> f. 114r, column 2</locus>#
                    <locus target="#114v #115" facs="115"> f. 115, left, top</locus>
                    <desc type="Genealogy">
                    Family genealogy
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#2r" facs="002"/>
                    <desc>
                    records: a series of dated events between 1914 and 1922, written in pencil
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#46v" facs="047"/>
                    <desc>
                    The midpoint of the Psalms is marked with text, <q><foreign xml:lang="gez">መንፈቁ ዝየ</foreign>, “its half here.”</q>
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#115v" facs="116"/>
                    <desc>
                    various records dealing with different amounts of birr, in pencil
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#115v #116r #116v #117r" facs="116 117"/>
                    <desc>
                    various notes and scrawls
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

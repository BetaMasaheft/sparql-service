               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="114r" facs="003"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1">
                        <locus from="3r" to="89r" facs="003"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <note>Each section of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118">Mazmura Dāwit, Psalmus 118</ref> begins with a transliterated Hebrew letter, but no statement of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref></note>
                    </msItem>
                    <msItem xml:id="ms_i1.2">
                      <locus from="89r" to="98v" facs="089"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <note>The superscription to the fourth biblical canticle, <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah">The Prayer of Hannah, mother of Samuel the Prophet,  Hannah</ref>, is <q>“Prayer of Hana, mother of Samuel.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3">
                      <locus from="98v" to="103r" facs="099"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="103v" to="110v" facs="104"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                      <note>Arranged for the days of the week, incomplete at the beginning, laid out beginning on Monday and culminating in Sunday</note>
                    </msItem>
                    <msItem xml:id="ms_i1.5">
                      <locus from="110v" to="114r" facs="111"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>

                      <colophon xml:id="coloph1">
                        <locus target="#114r" facs="114"/>
                        Mentioning comissioner, <foreign xml:lang="gez">አባ፡ መዝከበ፡ ሥላሴ፡</foreign>, and scribe, <foreign xml:lang="gez">ገብረ፡ ሚካኤል፡</foreign> 
                      </colophon>



                    </msItem>
                  </msItem>
               </msContents>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="78v">2v-78v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0025IHA">حاشية الباجوري علي البردة</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم وبه نستعين حمدا لمن شرح بمدح نبيه قلوب اوليائه ووشحيم ببردة محاسنه وطيب سنآئه وصلوة وسلاما على من خصه بخواص هباته وكمله باكمل عنايته</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#78v">-78v</locus>ابياتها قد اتت ستين مع مائة. فرج بها  كربنا يا واسع الكرم. فرج الله الكرب عنا وعن سائر المسلمين بجاه سيد المرسلين واله وصحبه احمعين والحمد لله رب العالمين</explicit>
                     <note>Some of the words are divided into two different lines
</note>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>

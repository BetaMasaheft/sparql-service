      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0504</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በአኅብሮ፨</l>
                  <l n="2">ውዳሴ፡ መልክእከ፡ እጽሕፍ፡ መጠነ፡ ተውህበኒ፡ አእምሮ፨</l>
                  <l n="3">ሰባኬ፡ ትንሣኤ፡ አፍጼ፡ ዘተፈኖከ፡ ለምሕሮ፨</l>
                  <l n="4">ለገብርከ፡ መፍቀሬ፡ አምላክ፡ አግርር፡ ፀሮ፨</l>
                  <l n="5">እስመ፡ በስምከ፡ ቀደሰ፡ ማኅደሮ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ በአፈ፡ አምላክ፡ ዘተጸውዐ፨</l>
                  <l n="2">ወለሥዕፍርትከ፡ ሰያብ፡ ዘጽዕድው፡ እምልብሰ፡ መርዐ፨</l>
                  <l n="3">መናኔ፡ መዛግብት፡ አፍጼ፡ ወዘብዕለ፡ ዓለም፡ ፍግዐ፨</l>
                  <l n="4">ከመ፡ እጽገብ፡ እምበረከትከ፡ ዘተመነይኩ፡ ሰቡአ፨</l>
                  <l n="5">በገራህተ፡ ልብየ፡ አብቍል፡ ሰላመከ፡ ዘርአ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለቆምከ፡ ለወንጌለ፡ ክርስቶስ፡ አትሮንሱ፨</l>
                  <l n="2">ወለአልክእከ፡ ፍትው፡ ዘሜላተ፡ ብርሃን፡ ልብሱ፨</l>
                  <l n="3">አፍጼ፡ ፀሓይ፡ ዘአቀመከ፡ ኢያሱ፨</l>
                  <l n="4">ሐውጸነ፡ በበዓልከ፡ ምስለ፡ እስክንድር፡ ወፈረሱ፨</l>
                  <l n="5">ዘምስለ፡ ጉባ፡ ወስምዖን፡ ዘተበስረ፡ ፅንሱ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለተሠውሮትከ፡ እንበለ፡ ያእምር፡ አሐዱ፨</l>
                  <l n="2">እመኃዊከ፡ ኄራን፡ እለ፡ ምስሌከ፡ ነገዱ፨</l>
                  <l n="3">መምህረ፡ መምህራን፡ አፍጼ፡ ለእግዚአብሔር፡ ፈጻሜ፡ ፈቃዱ፨</l>
                  <l n="4">በበዓልከ፡ አሜሃ፡ መላእክተ፡ ሰማይ፡ ወረዱ፨</l>
                  <l n="5">ወበመቅደስከ፡ በስብሐት፡ ዖዱ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለተሠውሮትከ፡ ውሳጤ፡ መቅደስ፡ ምሥራቃዊ፨</l>
                  <l n="2">ወለበአትከ፡ ዓዲ፡ በውስተ፡ ጽርሑ፡ ለመርዓዊ፨</l>
                  <l n="3">ጸሊ፡ አፍጼ፡ ኀበ፡ ሊቅከ፡ ናዝራዊ፨</l>
                  <l n="4">ከመ፡ ታድኅነኒ፡ እመሠገርተ፡ አርዌ፡ ነዓዊ፨</l>
                  <l n="5">ጸሎትከ፡ አባ፡ ጽሙዐ፡ ያረዊ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ውሑደ፡ ነገርኩ፡ እንዘ፡ ብዙኅ፡ ውዳሴከ፨</l>
                  <l n="2">በቃለ፡ ሰላምየ፡ ዝንቱ፡ ሶበ፡ ሰአልኩ፡ ኀቤከ፨</l>
                  <l n="3">አፍጼ፡ በለኒ፡ ወአስምዐኒ፡ ቃለከ፨</l>
                  <l n="4">እምብዙኅ፡ ጻማ፡ ኣአርፈከ፡ ሰማዕኩ፡ ጸሎተከ፨</l>
                  <l n="5">ወስእለተከ፡ ኀበ፡ ሀሎ፡ ፍሥሓ፡ አነብረከ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለክሙ፡ አሌፍ፡ ወጽሕማ፨</l>
                  <l n="2">አረጋዊ፡ ዓዲ፡ ወአባ፡ ገሪማ፨</l>
                  <l n="3">አፍጼ፡ ወጉባ፡ ይምአታ፡ ጰንጠሌዎን፡ ወአባ፡ ሊቃኖስ፨</l>
                  <l n="4">ለለ፡ ጽባሑ፡ ዑድዋ፡ ለዛቲ፡ መቅደስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ፈሊሶ፡ እምእስያ፡ በመንኖ፡ ክብር፡ ወብዕል፨</l>
                  <l n="2">ኀበ፡ ሀለወት፡ ቦቱ፡ ታቦተ፡ ማርያም፡ ድንግል፨</l>
                  <l n="3">ኀበ፡ ኢየሱስ፡ ክርስቶስ፡ ዘአብ፡ ቃል፨</l>
                  <l n="4">ኢንርአይ፡ ሙስናሃ፡ ለደብረ፡ ሐመልማል፨</l>
                  <l n="5">ጸሊ፡ አፍጼ፡ መነኮስ፡ ኀያል፨</l>
               </lg>
            </div>
         </div>
      </body>

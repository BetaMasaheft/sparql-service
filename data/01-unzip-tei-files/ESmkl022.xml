               <msContents>
                  <summary>I) Maṣḥafa taklil “Book of the Marriage Ritual” (fols. 3ra-40va) 
 -
                     Prayers on the clothes (fols. 3ra-13va l.11) 
 - Prayers on the bride and
                     the bridegroom (fols. 13va l.11-38ra l.5) 
 - Order to be read to the bride
                     and the bridegroom (fols. 38ra l.5-40va)</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>
                     <explicit>
                        <foreign xml:lang="en"/>
                     </explicit>
                     <note/>
                  </msItem>
               </msContents>

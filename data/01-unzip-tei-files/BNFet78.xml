                  <msItem xml:id="ms_i1">
                     <title type="complete" ref="https://betamasaheft.eu/LIT3952MashafaQ">Maṣḥafa
                                                  qandil</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>ንወጥን፡
                በረድኤተ፡ እግዚአብሔር፡ ወበሠናይ፡ ሀብቱ፡ በጽሒፈ፡ መጽሐፈ፡ ቀንዲል፡ ዘአንበርዎ፡ መምህራነ፡ ቤተ፡ ክርስቲያን፡ በረከቶሙ፡ ትኩን፡
                ምስሌነ፡ አሜን፡</incipit>
                     
                     <msItem xml:id="ms_i1.1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT3952MashafaQ#Beginning">Maṣḥafa
                                                  qandil, ጸሎት፡</title>
                        <incipit xml:lang="gez">መቅደመ፡ ያንብሩ፡ ቀንዲለ፡ ዘምሉእ፡ ውስቴቱ፡ ዘይተ፡ ንጹሐ፡ ወ፯ፈትለ፡ እንበለ፡ አብርሆ፡ ወያንብሩ፡ ቅድሜሁ፡ ወንጌለ፡
                  ወመስቀለ፡ ወእመሰ፡ ተረክበ፡ ይግበሩ፡ ፯ካህናት፡</incipit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="12v">Fols 12v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3952MashafaQ#FirstPrayer">Maṣḥafa qandil, ጸሎት፡ ቀዳማዊ፡</title>
                        <incipit xml:lang="gez">ወይበል፡ ጸሎተ፡ አኰቴት፡ ወያዕርግ፡ እጣነ፡ መልዕልቴሁ፡ ወይበል፡ ጸዋት፡ በእንተ፡ ዱያን። ወሕዝብ፡ ይብል፡ ንሰግድ፡
                  ለከ፡ ኦክርስቶስ፡</incipit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.3">
                        <locus from="12v">Fols 12v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#SecondPrayer">ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጸሎት፡
                  ዳግም።</title>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.4">
                        <locus from="15v">Fols 15v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#ThirdPrayer">ጸሎት፡ ሣልስ።</title>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.5">
                        <locus from="19v">Fols 19v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#FourthPrayer">ጸሎት፡ ራብዕ።</title>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.6">
                        <locus from="23v">Fols 23v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#FifthPrayer">ጸሎት፡ ኃምስ።</title>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.7">
                        <locus from="26v">Fols 26v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#SixthPrayer">ጸሎት፡ ሣድስ።</title>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.8">
                        <locus from="29v">Fols 29v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3952MashafaQ#SeventhPrayer">ጸሎት፡ ሳብዕ።</title>
                     </msItem>
                     
                     <colophon xml:id="coloph1" xml:lang="gez">
                        <date when="1561" evidence="internal"/> 
                        በአኰቴተ፡ አብ፡ 
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ተፈጸመ፡ ዝንቱ፡ መጽሐፈ፡ ቀንዲል፡ ወተተርጕመ፡ እምዓረቢ፡
                ለግዕዝ፡ በእደ፡ ወልድ፡ ንኡስ፡ ኅጹፀ፡ አእምሮ፡ ዘኢይደሉ፡ ይዝክሩ፡ ስሞ፡ በእንተ፡ ብዝኀ፡ ኀጢአቱ፡ ወምልአ፡ አበሳሁ። ወዘሂ፡
                አስተኀመመ፡ ለአጽሕፎቱ፡ ቀሲስ፡ ክቡር፡ አቡነ፡ ጸቃውዕ። ወኮነ፡ ተፍጻሜቱ፡ አመ፡ <date calendar="diocletian">፳ወ፪፡ ለወርኀ፡ ያከቲት፡
                  በ፲፻ወ፪፻በ፸ወ፯፡ ዓመተ፡ ዓመተ፡ ሰማዕት</date>። እንዘ፡ ሀለወ፡ ፀሓይ፡ በኆኅት፡ ዓሠርቱ፡ ወአሐዱ። ወወርኅኒ፡ በ፲፡
                ኆኅት፡ እንዘ፡ ሊቀ፡ ጳጳስነ፡ አባ፡ <persName ref="https://betamasaheft.eu/PRS4380Gabriel">ገብርኤል</persName>፡ ወንጉሥነ፡
                  <persName ref="https://betamasaheft.eu/PRS4428Galawdew">ገለውዴስ</persName>። ወኵሉ፡ ዘያነብቦ፡ ለዝንቱ፡ መጽሐፍ፡ እመ፡
                ረከበ፡ ግድፈተ፡ አው፡ ኅጸፀ፡ ቃል፡ ያሠንዮ፡ ከመ፡ እግዚአብሔር፡ ያሤኒ፡ ሎቱ፡ እስመ፡ ጸሓፊሁ፡ ኢያአምር፡ ወባሕቱ፡ በእንተ፡
                አጸባ፡ ዘመን፡ ጸሐፈ፡ በተኀብሎ። ስረዩ፡ ወበሉ፡ ኦእግዚኦ፡ ስረይ፡ ወኅድግ፡ ኀጢአቶ፡ ወጌገዮ፡ ለገብርከ፡ 
                        <persName ref="https://betamasaheft.eu/PRS11085AmdaH">ዓመደ፡ ሐዋርያት</persName>። እንዘ፡  
                        <persName ref="https://betamasaheft.eu/PRS11090TaklaI">
                           <roleName type="title">ረይስ፡</roleName> ተክለ፡ ኢየሱስ</persName>፡ 
                        <persName ref="https://betamasaheft.eu/PRS11091ZawgaM">
                           <roleName type="title">ቀይም፡</roleName> ዘውገ፡ ማርያም፡</persName>
                        <note>The colophon mentions that the book was translated from Arabic in the year
                    <date calendar="diocletian">1277 of the Martyrs</date>, at the time of the patriarch <persName ref="https://betamasaheft.eu/PRS4380Gabriel">Gabriel VII</persName> and the king <persName ref="https://betamasaheft.eu/PRS4428Galawdew">Galāwdewos</persName>. The translator 
                           does not want to state his name. The scribe, <persName ref="https://betamasaheft.eu/PRS11085AmdaH">ʿĀmda Ḥawāryāt (same as PRS1842Amdaha?)</persName>, was
                  probably from <placeName ref="https://betamasaheft.eu/INS0319HZ">Ḥārat Zuwayla</placeName>.</note>
                     </colophon>
                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="44r">Fols 44r and following</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1959Mashaf">ክርስቶስ፡ አምላኪየ፡ 
                        <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        ንጽሕፍ፡ እንከ፡ መጽሐፈ፡ ቀኖና፡ ዘአንበሩ፡ መምህራነ፡ ቤተ፡
                ክርስቲያን፡ በእንተ፡ ኵሉ፡ ብእሲ፡ ዘክህደ፡ ሃይማኖቶ፡ አው፡ ዘአርኰሰ፡ ሥጋሁ፡ ምስለ፡ <sic resp="PRS10747Zotenbe">ት፡</sic> ብእሲት፡ ዘኢኮነት፡ ክርስቲያናዊት።</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ይምላእ፡ ማየ፡ በኮራ፡ ወይክዓው፡ ውስቴቱ፡ ዘይተ፡ ፫ጊዜ፡ በአምሳለ፡ መስቀል፡ ወይበል፡ ጸሎተ፡ አኰቴት፡ ወያዕርግ፡
                እጣነ፡ ወያንብብ፡ መልእክተ፡ ጰውሎስ፡ ለጢሞቴዎስ፡</incipit>
                     
                     <note>The biblical prayers and lessons are given in their entirety.</note>
                     
                     <colophon xml:id="coloph2" xml:lang="gez">
                        <date notBefore="1561" notAfter="1562" evidence="internal"/>
                በዝየ፡ ተፈጸመ፡ መጽሐፈ፡ ንስሐ፡ ዘይትነበብ፡ ላዕለ፡ ኃጥእ፡ ዘይኔስሕ፡ እምኀጢአቱ፡
                ወኢይገብእ፡ ኀቤሃ፡ ወተተርጐመ፡ እምዓረቢ፡ ለግዕዝ፡ በእደ፡ ፩ኃጥእ፡ ወምሥኪን፡ ዘስጡም፡ ውስተ፡ ባሕረ፡ አበሳ፡ ወልደ፡ ንኡስ፡
                እም<persName ref="https://betamasaheft.eu/PRS11208HouseTakla">ውሉደ፡ ተክለ፡ ሃይማኖት፡</persName> አብ፡ ብርሃናዊ፡ ወመምህር፡
                አምላካዊ። ወኮነ፡ ተፍጻሜቱ፡ በ<placeName ref="https://betamasaheft.eu/INS0320DAA">ደብረ፡ አቡነ፡ እንጦንስ</placeName>፡ ርእሰ፡
                መነኮሳት፡ አመ፡<date> ፲ወ፪ለወርኀ፡ ኅዳር፡ አመ፡ ርደተ፡ ፀሓይ፡ ውስተ፡ ኆኅተ፡ አቅረብ፡ በ፳ዕለት። ወበቀዳሚ፡ ኅድረቱ፡
                  ውስተ፡ ኆኅተ፡ ኀመል፡</date>
                        <date calendar="diocletian"> በዓመተ፡ ሰማዕታት፡ ፲፻ወ፪፻ወ፸ወ፯፡ ዓመት፡</date> እንዘ፡ ረይስ፡ ኢየሩሳሌም፡ አቡነ፡
                  <persName ref="https://betamasaheft.eu/PRS11090TaklaI">ተክለ፡ ኢየሱስ</persName>። ወቀይም፡ ዘ<placeName ref="https://betamasaheft.eu/INS0319HZ">ሀርተ፡ ዜዌላ፡</placeName>
                        <persName ref="https://betamasaheft.eu/PRS11091ZawgaM">ዘውገ፡ ማርያም</persName>። ወስብሐት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        <note>The colophon states that this work was translated from Arabic by a monk of the
                  order of Takla Hāymānot in the year <date calendar="diocletian">1277 of the martyrs</date>, at the time
                  of the patriarch <persName ref="https://betamasaheft.eu/PRS4380Gabriel">Gabriel VII</persName> and the king
                    <persName ref="https://betamasaheft.eu/PRS4428Galawdew">Galāwdewos</persName>. The abbot of Jerusalem
                  was <persName ref="https://betamasaheft.eu/PRS11090TaklaI">Takla ʾIyasus</persName> and the prefect of the
                    <placeName ref="https://betamasaheft.eu/INS0319HZ">Convent of Ḥārat Zuwayla</placeName>
                           <persName ref="https://betamasaheft.eu/PRS11091ZawgaM">Zawga Māryām</persName>.</note>
                     </colophon>
                  </msItem>

                  <msItem xml:id="ms_i3">
                     <locus from="52v">Fols 52v and following</locus>
                     <title type="incomplete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1940Mashaf">በስመ፡ እግዚአብሔር፡ ተስፋነ፡ ወላዕሌሁ፡ ትውክልትነ፡ ንወጥን፡
                በረድኤተ፡ እግዚአብሔር፡ ወበሠናይ፡ ሀብቱ፡ በጽሒፈ፡ መጽሐፈ፡ ክርስትና፡ መጽሐፍ፡ ዘሠርዕዎ፡ አበው።</title>
                     <textLang mainLang="gez"/>
                     <incipit corresp="LIT1940Mashaf#Blessing" xml:lang="gez">መቅድመ፡ ይጼሊ፡ ካህን፡ ላዕለ፡ እሙ፡ ለሕፃን፡ እንዘ፡ ይብል።
                እግዚእ፡ እግዚአብሔር፡ አኃዜ፡ ኵሉ፡ ወገባሬ፡ መዋዕለ፡ ዓለም። ዘአዘዞ፡ ለሙሴ፡ በመጽሐፈ፡ ኅግ፡ አመ፡ ተናገሮ፡ በእንተ፡ ወስነ፡
                ንጽሕ፡</incipit>
                     <note>The end is missing.</note>
                  </msItem>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ዘነብ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Zannab</t:persName>
               <t:persName>
                  <t:roleName type="title">ʾalaqā, dabtarā, Ṣaḥāfe tǝʾǝzāz</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  <t:occupation type="ecclesiastic">chronicler</t:occupation>
               <t:birth when="1825">He was born at <t:placeName ref="https://betamasaheft.eu/LOC6381Yefat">Yǝfāt</t:placeName>
               </t:birth>
               <t:floruit notBefore="1855" notAfter="1876">He was the secretary of 
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">
                     <t:roleName type="title">ʾaṣe</t:roleName> Tewodros II</t:persName>, a missionary and writer. 
                  He was converted to Protestantism in <t:date>1858</t:date> by the influence of the missionaries, without officially leaving, 
                  however, the Ethiopian Orthodox Church. He was also a tutor of the son of  
                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                     Tewodros II</t:persName>, 
                  <t:persName ref="https://betamasaheft.eu/PRS1625Alamayy">
                     <t:roleName type="title">daǧǧāzmāč</t:roleName> ʾAlamāyyahu Tewodros</t:persName>.  
                  He was succeeded by 
                  <t:persName ref="https://betamasaheft.eu/PRS3808engedaW">
                     <t:roleName type="title">ʾalaqā </t:roleName> ʾƎngǝdā Warq</t:persName> as a chief scribe. 
                  </t:floruit>
                  <t:death when="1876"/> 
               </t:person>  
               
         </t:listPerson>
         

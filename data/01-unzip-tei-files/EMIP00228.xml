               <msContents>
                  <summary>Pillars of Mystery, አምስቱ፡ አዕማደ፡ ምሥጢር፡</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="62r" facs="003"/>
                     <title ref="https://betamasaheft.eu/LIT1097Ammest">ʾAmmǝstu ʾaʿmāda mǝśṭir</title>
                     <textLang mainLang="am">Amharic</textLang>
                     <msItem xml:id="ms_i1.1">
                       <locus from="1r" to="6v" facs="003"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Introduction">ʾAmmǝstu ʾaʿmāda mǝśṭir: Introduction to the Five Pillars of Mystery</title>
                       <incipit>በስመ፡ አብ፡ ወወልድ፡ <gap reason="omitted"/> ብሎ፡ መመጽሐፍ፡ (sic) እንዲዠ፡ ምሩ፡ በአብ፡ ስም፡ ወላዲ፡ በወልድ፡ ስም፡ ተወላዲ፡ በመንፈስ፡ ቅዱስ፡ ም፡ (sic) ሰም፡ ራጺ፡ ብለን፡ እናምናለን። <gap reason="omitted"/></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                       <locus from="6v" to="30v" facs="009"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Trinity">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Trinity ()</title>
                       <incipit>ሥላሴ፡ ቅድመ፡ ዘመን፡ ዓለምን፡ ሳይፈጥሩ፡ በ፫ት፡ ነትና፡ በ፩፡ ሲሰለሱ፡ ሲዋሀዱ፡ ሲመሰገኑ፡ ይኖሩ፡ ነበር፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                       <locus from="31r" to="41v" facs="033"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#BaptismMystery">No item: LIT1097Ammest, could not check for BaptismMystery</title>
                       <incipit>ምሥጢረ፡ ጥምቀትስ፡ እንዴት፡ ነው፡ ቢሉ፡ ጌታችን፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ከማርያም፡ ድንግል፡ ተወልዶ፡ በጥቂቱ፡ አድጎ፡<gap reason="omitted"/></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                       <locus from="42r" to="50v" facs="044"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Eucharist">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Eucharist ()</title>
                       <incipit>የምሥጢረ፡ ቍርባንስ፡ ነገር፡ እንዴት፡ ነው፡ ቢሉ፡ ፫ት፡ ዓመት፡ ፫ወርኅ፡ ሕገ፡ ወንጌልን፡ አስተመሮ፡ (sic) መዋዕለ፡ እ፡ ትእምርቱ፡ ሲፈጸም፡<gap reason="omitted"/></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                       <locus from="50v" to="62r" facs="053"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT1097Ammest#Resurrection">ʾAmmǝstu ʾaʿmāda mǝśṭir: Mystery of the Resurrection ()</title>
                       <incipit>ምሥጢረ፡ ትንሣኤ፡ ሙታንስ፡ ነገር፡ እንዴት፡ ነው፡ ቢሊ፡ ጥንቱን፡ በአቤል፡ አፍርሆሙ፡ ወበሄኖክ፡ አንቅሆሙ፡ እንዳለ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡<gap reason="omitted"/></incipit>
                     </msItem>
                  </msItem>

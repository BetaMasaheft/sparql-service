                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="150v">1v-150v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0049IHA#s38IHA">قران, First half (ǧuz’ 1-15)</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>سورة الفاتحة مكية سبع ايات \ بسم الله الرحمن الرحيم الحمد لله رب العالمين الرحمن الرحيم مالك يوم الدين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#150v">-150v</locus>فمن كان يرجوا لقاء ربه فليعمل عملا صالحا ولا يشرك بعبادة ربه احدا</explicit>
                     <note>Contains sūras 1-18. Lacuna between fols 139 and 140. Vocalized. Words divided into two lines.</note>
                     <note/>
                  </msItem>

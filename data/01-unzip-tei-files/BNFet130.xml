                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4031EgziabeherN">እግዚአብሔር፡ ነግሠ፡</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <gap reason="lost" extent="unknown"/>ጻሐፍ<gap reason="lost" extent="unknown"/>በዘ፡ 
                  ንዜ<gap reason="lost" extent="unknown"/>ማኅሌ፡ 
                  <gap reason="lost" extent="unknown"/>
                        <supplied reason="undefined" resp="PRS10747Zotenbe">እግ</supplied>ዚአብሔር፡ 
                  ነግሠ፡ ወእማሔሆሙ፡ ለማኅበረ፡
                  መላእክት፡ ወለማኅ<supplied reason="undefined" resp="PRS10747Zotenbe">በ</supplied>ረ፡ ነቢያት፡ ወሐዋርያት፡ 
                  ለማኅበረ፡ ጻድቃን፡ ወሰማዕት፡ ዘአስተጋብአ፡ ንጉሥነ፡
                  ዘርአ፡ <supplied reason="undefined" resp="PRS10747Zotenbe">ያዕ</supplied>ቆብ፡ ወል<supplied reason="undefined" resp="PRS10747Zotenbe">ደ፡ ዳ</supplied>ዊት፡</incipit>

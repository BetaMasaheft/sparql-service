               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="3r" to="164r" facs="003">Fols 3r–164r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <msItem xml:id="ms_i1.1">
                        <locus from="3r" to="129v" facs="003">Fols 3r–129v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <note><locus target="#106r" facs="106">Fol. 106r</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> from the new common system</note>
                        <note><locus target="#129v" facs="130">Fol. 129v</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> contains all four of the plusses that make up the long version</note>
                      </msItem>
                      <msItem xml:id="ms_i1.2"><locus from="130r" to="143r" facs="130">Fols 130r–143r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <note><locus target="#134r" facs="134">Fol. 134r</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref>is <q>"Prayer of Hana, mother of Samuel, prophet."</q></note>
                    </msItem>
                      <msItem xml:id="ms_i1.3"><locus from="143r" to="150r" facs="143">Fols 143r–150r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <note>common edition</note>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
                      <msItem xml:id="ms_i1.4"><locus from="150v" to="160r" facs="151">Fols 150v–160r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">, arranged for the days of the week</title>
                          <msItem xml:id="ms_i1.4.1"><locus from="150v" facs="151">Fols 150v and following</locus><title>Monday</title></msItem>
                          <msItem xml:id="ms_i1.4.2"><locus from="151v" facs="152">Fols 151v and following</locus><title>Tuesday</title></msItem>
                          <msItem xml:id="ms_i1.4.3"><locus from="153r" to="155r" facs="153">Fols 153r–155r</locus><title>Wednesday</title></msItem>
                          <msItem xml:id="ms_i1.4.4"><locus from="155r" facs="155">Fols 155r and following</locus><title>Thursday</title></msItem>
                          <msItem xml:id="ms_i1.4.5"><locus from="157r" facs="157">Fols 157r and following</locus><title>Friday</title></msItem>
                          <msItem xml:id="ms_i1.4.6"><locus from="158r" facs="158">Fols 158r and following</locus><title>Saturday</title></msItem>
                          <msItem xml:id="ms_i1.4.7"><locus from="159r" facs="159">Fols 159r and following</locus><title>Sunday</title></msItem>
                      </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="160r" to="164r" facs="160">Fols 160r–164r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                </msItem>

                <colophon xml:id="coloph1">
                  <locus target="#164r" facs="164">Fol. 164r</locus>
                  The colophons and/or final notes have all been deleted and are illegible, except that the manuscript was once owned by a certain Sahayu
                </colophon>
              </msItem>

         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ፋሲል፡ ገራም፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Fāsil Garrām</persName>
               <persName xml:lang="gez" xml:id="n2" type="birth">ፋሲሎ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Fāsilo</persName>
               <persName xml:lang="gez" xml:id="n3" type="birth">ፋሲሉ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Fāsilu</persName>
               <persName>
                  <roleName type="title">ʾabetohun</roleName>
               </persName>
            
               <occupation type="military">officer</occupation>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
          
          
               <floruit notBefore="1563" notAfter="1587"> He was the younger son of
                  
                  <persName ref="https://betamasaheft.eu/PRS10191Yaeqob">
                     <roleName type="title">ʾabetohun</roleName> Yāʿqob</persName> 
                  and youngest grandson of <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>.
                  His name became prominent in Ethiopian history
                  long years after his death because his son <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>, 
                  practically created a new branch of  dynasty. 
                  He was one of the officers of the army of <persName ref="https://betamasaheft.eu/PRS5043hamalmal">Ḥāmalmāl</persName>
                  during the reign of 
                  <persName ref="https://betamasaheft.eu/PRS8550sardaDe">Śarḍa Dǝngǝl</persName>. 
                  He rebelled against 
                  <persName ref="https://betamasaheft.eu/PRS8550sardaDe">
                     <roleName type="title">ʾaṣe</roleName> Śarḍa Dǝngǝl</persName> 
                  several times and finally he was pardoned and appointed as the governor of
                  <placeName ref="https://betamasaheft.eu/LOC5284Qwara">Qwārā</placeName>. 
                  He was killed by the <persName ref="https://betamasaheft.eu/ETH1973Oromo">Oromo</persName> 
                  and they captured his young son 
                     <persName ref="https://betamasaheft.eu/PRS9038Susenyos">Susǝnyos</persName>
                  whom they adopted as the son of the tribe.</floruit>
               <death notBefore="1586" notAfter="1587"/>
            </person>
            
         </listPerson>

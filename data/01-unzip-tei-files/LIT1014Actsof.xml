               </t:ab>
            </t:div>
            <t:div type="textpart" subtype="explicit" xml:lang="gez">
               <t:ab>
                  ሜጠ፡ ገጸ፡ ኀቤሆሙ፡ ወይቤሎሙ፡ ጸጋ፡ እግዚአብሔር፡ ወሰላሙ፡ የሀሉ፡ ምስሌክሙ፡ እስከ፡ <t:gap reason="omitted" extent="unknown"/> ወአሜን።
               </t:ab>

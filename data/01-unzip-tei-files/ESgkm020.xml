                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script"/>
                        <seg type="ink">Black, red (vivid vermilion).</seg>
                        <date>19th century.</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሰ/ሰላ</abbr> for <expan>ሰላም </expan> (e.g., <locus target="#2ra">2ra</locus>, 3ra, 4rb)</item>
                           <item>
                              <abbr>ማ/ማር/ማርያ</abbr> for <expan>ማርያም </expan> (e.g., <locus target="#3ra">3ra</locus>, 3vb, 4ra)</item>
                           <item>
                              <abbr>ተዘ/ተዘከ</abbr> for <expan>ተዘከር </expan> (<locus target="#9rb">9rb</locus>, 9va)</item>
                           <item>
                              <abbr>አም፡ ኦወ፡ ወፍ፡</abbr> for <expan>አምሕለከ፡ ኦወልድየ፡ ወፍቁርየ፡ </expan>
                                 (<locus target="#15vb">15vb</locus>, 16ra)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donor and his family; a
                           few lines on the incipit page of Text I, alternating with black lines;
                           incipit of Text II; elements of the punctuation signs; elements of
                           Ethiopic numerals; the words salām (e.g., fols. 2ra, 17ra, 18ra),
                           täzäkkär (fol. 9rb, 9va), yǝʾǝzeni (fol. 9va), täfäśśǝḥi (fol.
                           11ra).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1r">f. 1r</locus>
                           <desc>: Donation note.</desc>
                           <quote xml:lang="gez">
                              <locus target="#1r">1r</locus>: ለዛቲ፡ መጽሐፍ፡ ዘአጽሐፋ፡ አቤቶ፡ ተክለ፡ እግዚእ፡
                              በእንተ፡ ሕይወተ፡ ነፍሱ፡ ለወልደ፡ ሚካኤል፡ ወለብእሲቱ፡ ሰበነ፡ ጊዮርጊስ፡ ወለደቂቁ፡ ፀዳለ፡ ማርያም፡
                              ጸበለ፡ ጊዮርጊስ፡ ወወሀባ፡ ለታቦተ፡ ኪዳነ፡ ምሕረት፡ ደብረ፡ ገነት፡ ...</quote>
                           <quote xml:lang="en">
                              <locus target="#1r">1r</locus>: The one who had this book written and
                              who donated it to the tabot of Dabra Gannat Kidāna Mǝḥrat is ʾabeto
                              Takla ʾƎgziʾ, for the sake of the life of the soul of Walda Mikāʾel
                              and his wife Säbänä Giyorgis and his children Ḍädalä Māryām, Ṣäbälä
                              Giyorgis … </quote>
                           <note> </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#19v">f. 19v</locus>
                           <desc>: A miracle of Mary (?)</desc>
                           <quote xml:lang="gez">
                              <locus target="#19v">19v</locus>: ወሀሎ፡ ፩ብእሲ፡ ገባራ[sic]፡ ወኮነ፡ ያፈቅራ፡
                              ለእግዚእትነ፡ ማርያም፡… </quote>
                           <quote xml:lang="en">
                              <locus target="#19v">19v</locus>: There was a man … that loved our
                              Lady Mary … </quote>
                           <note> </note>
                        </item>
                        <item xml:id="e1">- Note mentioning Takla Hāymānot: <locus target="#1r">1r</locus>.
 - Minor notes in the margins: <locus target="#5r">5r</locus>, 17v.
 - Doodles: <locus target="#8r">8r</locus>,
                           9r.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards covered with brown tooled leather
                           (the spine cover is missing).
 Two pairs of sewing
                           stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other"/>
                        <decoNote xml:id="b5">Blind tooled ornament on the brown leather cover (at
                           least 6 tools were used: cross hatching, triple line fillet, double sine
                           wave with dots, double circle, corni form, small x).</decoNote>
                     </binding>

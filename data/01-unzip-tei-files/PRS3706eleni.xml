               <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">nǝgǝśt</t:roleName>
               </persName>               
               <occupation type="political">queen</occupation>
               <birth when="1431">1431</birth>
               <floruit notBefore="1443" notAfter="1522">She was given in marriage to King <persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</persName> in <date>1443</date> to confirm the vassalage of the Muslim state of Hadiyya and its ruler. 
                  She was an important female Ethiopian ruler of the early medieval period. She served four subsequent reigns and she was an acceptable figure in the court to be selected in<date>1508</date> as a regent to young  King <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>
               </floruit>
               <death when="1522">She died during the reign of King <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>
               </death> 
            </person>
                            

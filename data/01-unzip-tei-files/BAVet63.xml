                  <msContents>
                     <msItem xml:id="p1_i1">
                        <locus from="1v" to="42v" facs="0002"/>
                        <title type="incomplete">Malkǝʾ-hymn to Our Lady Mary</title>
                        <incipit xml:lang="gez">
                           ሃሌሉያ፡ ሙሓዘ፡ ስብሐት፡ 
                              <sic>ልሰንኪ፡</sic>
                           
                           
                              <sic>ወማዓር፡</sic>
                            ጕርዔኪ፡ ማርያም፡ ዕንቍየ፡ በከርሠ፡ ቀለያት፡
                           
                              <sic>ዘትወኪ፨</sic>
                           
                           
                              <sic>አሐገለ፡</sic>
                            ጌጋይ፡ እምእደውየ፡ ብትኪ። ነፍስየ፡ ወሥጋየ፡ ገደፍኩ፡ ኀቤኪ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           
                              <sic>ተማሐፀንኩ፡</sic>
                            ድንግል፡ ሥዕርትየ፡ በሥዕርትኪ፡ ርእስየ፡ በርእስኪ፡ ገጽየ፡ በገጽኪ፡ 
                              <sic>ቃረንብትየ፡</sic>
                           
                           
                              <sic>በቃረንብተኪ፨</sic>
                            አዕይንትየ፡ በአዕይን<supplied reason="omitted">ት</supplied>ኪ፨ 
                              <sic>አእዘንየ፡</sic>
                           
                           
                              <sic>በአእዘንኪ፨</sic>
                           
                           
                              <sic>መለትሕየ፡</sic>
                           
                           
                              <sic>በመለትሕኪ፨</sic>
                           
                           
                              <sic>ወኢይትሐጐለ፡</sic>
                            ይሕየዋ፡ ምስሌኪ፡ ውስተ፡ 
                              <sic>ከብከቡ፡</sic>
                            ለፍቁር፡ ወልድኪ፨ 
                              <sic>ተማሐፀንኩ፡</sic>
                           
                           <add place="inline">
                              <supplied reason="omitted">ድንግል፡</supplied>
                           </add> አእናፍየ፡ በአእናፍኪ፨ ከናፍርየ፡ በ
                        </explicit>
                        <note>The text is incomplete. Both the beginning and the end are missing.</note>
                     </msItem>

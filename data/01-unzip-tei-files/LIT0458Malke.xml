      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0458</citedRange></bibl>
            </listBibl>
            
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ሰላም፡ እምብዙኅ፡ በውሑድ፨</l>
                  <l n="2">ለዝክረ፡ ስምክሙ፡ ንብል፡ በገቢረ፡ በዓል፡ ውሉድ፨</l>
                  <l n="3">በትረ፡ ጊዮርጊስ፡ ሐዋርያ፡ ወስምዖን፡ ዘዐምድ፨</l>
                  <l n="4">በትረ፡ ተራድኦ፡ እምሁከተ፡ ዘመን፡ ክቡድ፨</l>
                  <l n="5">ለዐቂቦትነ፡ አኃዙ፡ በእድ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለሥዕርትክሙ፡ ሐመልማለ፡ ርእስ፡ ገዳም፨</l>
                  <l n="2">ወበበ፡ ርእስክሙ፡ እብል፡ ለርእስክሙ፡ ሰላም፨</l>
                  <l n="3">በትረ፡ ጊዮርጊስ፡ ወስምዖን፡ በዘትመጽእ፡ ዓለም፨</l>
                  <l n="4">እምገድልከ፡ ጻማ፡ ተሰዶ፡ ወምግባርከ፡ ቀዊም፨</l>
                  <l n="5">አስተሳትፉኒ፡ ለብእሲ፡ ድኩም፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለገጽክሙ፡ ሥነ፡ ጸጋሁ፡ ዘተሰብሐ፨</l>
                  <l n="2">ለቀራንብቲክሙኒ፡ አንብዓ፡ ስእለታት፡ ዘነዝኃ፨</l>
                  <l n="3">በትረ፡ ዮርጊስ፡ ወስምዖን፡ ዜንዉኒ፡ ዜና፡ ፍሥሐ፨</l>
                  <l n="4">ሰይጣንሰ፡ ኢይንግረኒ፡ ዜናሃ፨</l>
                  <l n="5">በከመ፡ ስሙ፡ ለሐሰት፡ አቡሃ፨</l>
               </lg>
               <lg type="stanza" n="23">
                  <l n="1">ሰላም፡ እብል፡ ለመልክኣቲክሙ፡ ሠናያነ፨</l>
                  <l n="2">ፀአተ፡ ንፍስክሙኒ፡ በመዋዕለ፡ ጾም፡ ዘኮነ፨</l>
                  <l n="3">በትረ፡ ጊዮርጊስ፡ ወስምዖን፡ ከመ፡ ንትካየድ፡ ኪዳነ፨</l>
                  <l n="4">ኀቤየ፡ ንዑ፡ በትሕትና፡ ምስለ፡ ማርያም፡ እምነ፨</l>
                  <l n="5">እስመ፡ ኢተክህለኒ፡ እምጻእ፡ ኀቤክሙ፡ አነ፨</l>
               </lg>
               <lg type="stanza" n="24">
                  <l n="1">ሰላም፡ ለበድነ፡ ሥጋክሙ፡ ወግንዘትክሙ፡ በክብር፨</l>
                  <l n="2">ለመቃብሪክሙኒ፡ ነቅዐ፡ ማየ፡ ሕይወት፡ መንክር፨</l>
                  <l n="3">አርአያ፡ ትሩፋት፡ ስምዖን፡ ወበትረ፡ ጊዮርጊስ፡ መምህር፨</l>
                  <l n="4">ዘኢወፅአ፡ እምቃልክሙ፡ በውስተ፡ ኵሉ፡ ብሔር፨</l>
                  <l n="5">ነቢብ፡ አልቦ፡ ወአልቦ፡ ነገር፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ነሢአክሙ፡ ሰላመ፡ አምኃ፡ ማሕሌትየ፡ ዝንቱ፨</l>
                  <l n="2">ዘበኃምስቱ፡ ይትፈቀድ፡ መጠነ፡ ጊዜያት፡ ኃምስቱ፨</l>
                  <l n="3">በትረ፡ ጊዮርጊስ፡ ወስምዖን፡ ለበረከትክሙ፡ መክፈልተ፡ ሀብቱ፨</l>
                  <l n="4">ጸግዉኒ፡ አስበ፡ ጻማየ፡ በዓለመ፡ ነገሥት፡ ሠለስቱ፨</l>
                  <l n="5">ወአግብኦ፡ ፍዳ፡ እምጥንት፡ ለጻድቅ፡ ሥርዓቱ፨</l>
               </lg>
            </div>
         </div>
      </body>

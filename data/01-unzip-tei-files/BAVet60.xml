               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1v"/>
                     <title type="incomplete">Prayer</title>
                     <note>The beginning is missing.</note>
                     <incipit xml:lang="gez">
                        
                           <sic>ለመቍሐን።</sic>
                         ወበጻማሆሙ፨ ለፈላሲያን፡ ወትጋሆሙ፨ ለነጋድያን፨ 
                           <sic>ወበመንግዶቶሙ፨</sic>
                         ለነጋድያን፨ 
                        ወበሃይማኖቶሙ፨
                     </incipit>
                     <explicit xml:lang="gez">
                        
                           <sic>ስቍል፨</sic>
                         ክርስቶስ፡ ዲበ፨ ዕፀ፡ መስቀል፨ ኤሎሄ፨ ኤሎሄ፨ ለምንት፨ ኀደገኒ፨ በስመ፨ እግዚአብሔር፨ ኀያል፡ ወስቡሕ፨ 
                     </explicit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="1v" to="9v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4537Prayer">Magical prayer</title>
                     <note/>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ለእመኒ። በሥራይ። ወለእመኒ፨ መዓሥር፨ ወለእመኒ፨ በኵሉ፨ 
                        ዓመፃ፨ ዘገብረ፡ በኀጺን፨ ወለእመኒ፨ በወርቅ፡ ወለእመኒ፨ በብሩር፨ ወለእመኒ፨ በብርት፨ ወለእመኒ፨ በዓረር፨
                     </incipit>
                     <explicit xml:lang="gez">
                        
                           <sic>ፈታሕኵ፨</sic>
                         ወእፈትሕ፨ እምገብርከ፨ <add>ፊልጶስ፡</add> ዘይጸውሮ፨ ለዝንቱ፨ መጽሐፍ፨ ወኵሎ። 
                           <sic>መቅጸር፨</sic>
                         
                        ወኵሉ፨ 
                           <sic>መአሰር፨</sic>
                         ወኵሉ፨ ሥራይ፨ ወኵሉ፨ ዓይን፨ እኩይ፨ ወኵሉ፡ ራዕይ፨ እኩይ፨ ወኵሉ፡ ምግባረ፨ እኩይ፡ ወኵሉ፡ ምግባረ፨ ሰይጣን፨
                     </explicit>
                     <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11471Fileppos">Filǝṗṗos</persName> is written in later hand over another 
                        name at the end of the text.</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="9v" to="19r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4538Prayer">Protective prayer against the demons</title>
                     <note/>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወእምይእዜ፡ ወእስከ፨ ለዓለም፡ አንተ፨ ረሐቅ፨ እምኔየ፨ መንፈስ፡ ርኩስ፨ 
                        
                           <sic>ወአኩይ፨</sic>
                         አሐትም፨ ላዕሌከ፨ በስመ፨ እግዚአብሔር፨ ሕያው፨ ወኀያል፨ ዘመንግሥቱ፨ 
                           <sic>ለዓለም፨</sic>
                         ዓለም፨ ዘንቡር፨ 
                        መንበሩ፨ ላዕለ፡ ደመናት፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ከመ፡ ይትመሰው፤ ሰምዕ፤ እምቅድመ፡ ገጸ፤ እሳት፡ ከማሁ፡ ተፈትሐ፤ እንተ፤ መንፈስ፤ ርኩስ፤ 
                           <sic>አንተ፤</sic>
                         ወበኵሉ፤ 
                           <sic>ቃላት፤</sic>
                         
                        ሰይጣን፡ 
                           <sic>ወዝብጠታተ፤</sic>
                         ቅድመ፤ ዝንቱ፤ መጽሐፍ፤ ዘጽሑፍ፤ ውስተ፤ ዝንቱ፡ ነገር፤ ንስግድ፡ ለአብ፡ ወወልድ፡ ወመንፈስ፨ ቅዱስ፤ አሐዱ፤ 
                        እግዚአብሔር፡ እምይእዜ፤ ወእስከ፤ 
                           <sic>ለዓለም፤</sic>
                         ዓለም፤ አሜን፤ አሜን፤ ወአሜን፡ ስረዪ፤ ሃሌሉያ፨
                     </explicit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="21" to="62"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1201Bartos">Bārtos</title>
                     <note/>
                     <bibl corresp="http://zotero.org/groups/358366/items/VAZ6GVMU"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1896Vergine"/><title level="a">La redazione etiopica della preghiera della Vergine tra i Parti</title><title level="j">Atti della Reale Accademia dei Lincei, Rendiconti, Classe di scienze morale, storiche e filologiche</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Carlo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Conti Rossini</t:surname></author><date>1896</date><biblScope unit="volume">Serie quinta, 5</biblScope><biblScope unit="page">457-479</biblScope><citedRange>461-479</citedRange></bibl>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="62" to="63"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3308Nicene">Niceno-Constantinopolitan Creed</title>
                     <note>The beginning is missing.</note>
                     <incipit xml:lang="gez">
                        ወነአምን፡ በመንፈስ፡ ቅዱስ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ወንሴፎ፡ ትንሣኤ፡ እሙታን፡ 
                           <sic>ወሕይወት፡</sic>
                         ዘይመጽእ፡ እስከ፡ ለዓለመ፡ ዓለም፡ አሜን። ወአሜን። 
                     </explicit>
                  </msItem>

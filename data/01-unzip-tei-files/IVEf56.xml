                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="54r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3944ArdeetChL">Maṣḥafa ʾardǝʾt (Christian long version)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ነገረ፡ ዘ፲ወ፪፡ ሐዋርያት፡ መግረሬ፡ ፀር፡
                                <foreign xml:lang="eng">The word of twelve Apostles, the conqueror of enemies.</foreign>
                            </incipit>
                            <note>Magic 'mixed' text for 'healing the soul and body' organized according to week days.</note>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="55r" to="75v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4995PrayerMos">Prayer of Moses</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎተ፡ ሙሴ፡ ንነግረክሙ፡ ንሕነ፡ በዘድኅነ፡ ሙሴ፡
                                እምእዴሁ፡ ለፈርኦን፡ ጸሎቱ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ወቀዲሙሰ፡ ወረደ፡ ገብርኤል፡ መልአክ፡ ኢትፍራሕ፡ ሙሴ፡</incipit>
                            <note>A prayer of Moses through which he escaped from the Pharaoh's hands.</note>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="75v" to="85r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5009PrayerMaryHealing">Prayer of Mary for Healing</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>ጸሎት፡ ዘእግዚእትነ፡ ድንግል፡ ማርያም፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
                            ዘእም፳ወ፩፡ አመ፡ ፭ዓመተ፡ ወ፩ወርኀ፡ እም፩ለሚያዝያ።</incipit>
                            <note>Magic prayer of Virgin Mary to be pronounced over water for healing.</note>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="85v" to="95r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5010PrayerMary">Magic Prayer of the Virgin Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በዓመት፡ ፭አመ፬ለወርኅ፡ ኃምስ፡ ተንሥአት፡ ማርያም፡ ድንግል፡ እሙ፡ ለእግዚነ፡ ኢየሱስ፡ ክርስቶስ፡ ወቆመት፡
                            በእገሪሃ፡ ወሚጠት፡ ገጻ፡ መንገለ፡ ምስራቅ፡ ወሠፍሐት፡ እደዊሃ፡ ወከሥተት፡ አፉሃ፡ ወነበበት፡ ዘንተ፡ <foreign xml:lang="en">In the fifth year on the first day of the
                             fifth month, the Virgin Mary, Mother of Our Lord Jesus Christ, stood up and turned her face to the East, she stretched out her hands, opened her month and
                            said as follows</foreign>
                     </incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="95v" to="107r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5011MagicPrayerMary">Magic Paryer of the Virgin Mary</title>
                            <textLang mainLang="gez"/>
                            <note>The text is written in red ink.</note>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <locus from="107v" to="113r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4525Prayer">Magical prayer with the names that Jesus Christ gave to the
          apostles durin his Ascension</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡<gap reason="ellipsis" resp="PRS9602Turaev"/>ዛቲ፡ መጽሐፍ፡ ዘሰአሉ፡ ሐዋርያት፡ ኀበ፡ እግዚኦሙ፡
                            አመ፡ የአርግ፡ ሰማየ። <foreign xml:lang="en">This book the Apostles prayed for to their Lord when He ascended to the sky.</foreign>
                     </incipit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus from="113" to="115v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3138Negeranni">Nǝgǝranni sǝmaka</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <locus from="116r" to="118v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5013Prayer">Magic prayer to Mary</title>
                            <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡<gap reason="ellipsis" resp="PRS9602Turaev"/> በተከዮስ፡ ተሀርዝልዮስ፡ እምደዋዮስ፡</incipit>
                            <note>Protective prayer beginning with ʾasmat. </note>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <locus from="119r" to="125r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5028Prayer">Prayer (ba-sǝmu la-ʾǝgziʾabḥer bazayǝtfallaṭu semāyāt
          wa-mǝdr)</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> በስሙ፡ ለእግዚአብሔር፡ በዘይትፈለጡ፡ ሰማያት፡ ወምድር።
                                <foreign xml:lang="en">In the name of God through which the sky and earth were divided. </foreign> 
                     </incipit>
                        </msItem>
                        <msItem xml:id="ms_i10">
                            <locus from="126v" to="127v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT5029MagicFormulas">Magic Formulas</title>
                            <textLang mainLang="gez"/>
                        </msItem>
                    </msContents>

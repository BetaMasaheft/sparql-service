                     <msItem xml:id="ms_i1.7">
                        <locus from="27vb" to="94ra">Fols 27vb–94ra</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4922HagVit">Life of Lālibalā</title>
                        <incipit/>
                        <explicit> ወከመዝ፡ ነበረ፡ በኵሉ፡ መዋዕለ፡ ሕይወቱ፡ እምአመ፡ ነግሠ፡ እስከ፡ አመ፡ ፈለሰ። </explicit>
                     </msItem>

                     <msItem xml:id="ms_i1.9">
                        <locus from="94ra" to="95rb">Fols 94ra–95rb</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4924HagMir1">King Lālibalā and the three Angels</title> 
                        <incipit>ወእምዝ፡ ኮነ፡ አሐተ፡ ዕለተ፡ እንዘ፡ ይፈቅድ፡ ላሊበላ፡ ከመ፡ ይደረር፡ መጽኡ፡ ፫ አኃው፡ ቅሩበ፡ ጽርሐ፡ መንግሥቱ፡
                  ኀበ፡ ይረፍቅ፡ ውእቱ፡ </incipit>
                        <explicit xml:lang="gez"> እስመ፡ ኢበልዓ፡ በመዋዕለ፡ መንግሥቱ፡ ዘእንበለ፡ ፫ አምፍዕምት፡ ወኢሰትየ፡ ዘእንበለ፡
                  አሐቲ፡ ጽዋዕ፨ </explicit>

                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="95ra" to="98ra">Fols 95ra–98ra</locus>
                         
                        <title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4925HagMir2">
                           <locus target="#95rb">Fol. 95rb</locus>
                        </title>
                        <incipit xml:lang="gez"> ወኮነ፡ በ፩ እመዋዕል፡ እንዘ፡ ያመጽኡ፡ ጸባሕቶ፡ ለገብረ፡ መስቀል፡ ነጋሢ፡ ዘከመ፡ ይደልዎ፡
                  ለንጉሥ፡ ከመ፡ የሀቡ፡ ወያወፍዩ፡ ግብሮሙ፡ ዘይረክቦሙ፡ ነሥኡ፡ ብዙኃ፡ መቃጽወ፡ እለ፡ ምሉዓን፡ መዓረ፨ ወፀዊሮሙ፡ በጽሑ፡ ኀበ፡
                  ሐይቀ፡ ፈለግ፡ ዘይወርድ፡ በኃይል፡ </incipit>
                        <explicit xml:lang="gez"> በከመ፡ ዐቀቦ፡ ለዮናስ፡ በውስተ፡ ከርሠ፡ አንበሪ፨ ወከማሁ፡ ዓቀቦን፡ ለእማንቱ፡ ግምዔተ፡
                  መዓር፡ በኃይለ፡ ጸሎቱ፡ ለላሊበላ፡ </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="98ra" to="99va">Fols 98ra–99va</locus>
                         
                        <title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4926HagMir3">
                           <locus target="#98ra">Fol. 98ra</locus>
                        </title>
                        <incipit xml:lang="gez"> ወኮነ፡ ካዕበ፡ በ፩ እመዋዕል፡ ተርእየ፡ መንክር፡ ትሕትና፡ በላዕለ፡ ገብረ፡ መስቀል፡ እንዘ፡
                  ንጉሥ፡ ውእቱ፡ ዘተመሰለ፡ ነዳየ፨ </incipit>
                        <explicit xml:lang="gez"> ወገብረ፡ መስቀልሰ፡ እንዘ፡ ሀሎ፡ ውስተ፡ መንበረ፡ መንግሥት፡ ኢበልዓ፡ ወኢሰትየ፡
                  ለፍትወተ፡ ሥጋሁ፡ ከመ፡ ይኩን፡ ፍግዓሁ፡ ፍጹመ፡ በእደ፡ መርዓ፡ ዘኢየኃልፍ፡ በሰማያት፨ <space reason="owner" unit="chars" quantity="7"/> ለዓለመ፡ ዓለም፡ አሜን። </explicit>

                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="99va" to="101vb">Fols 99va–101vb</locus>
                         
                        <title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4927HagMir4">
                           <locus target="#99va">Fol. 99va</locus>
                        </title>
                        <incipit xml:lang="gez"> ወዓዲ፡ ኮነ፡ ፩ እመዋዕል፡ ወሀሎ፡ ውስተ፡ አሐቲ፡ ሀገር፡ እምአህጉራተ፡ መንግሥቱ፡ ፩
                  ዓላዊ፡ ዘዐለዎ፡ ለገብረ፡ መስቀል፡ ንጉሠ፡ መሢሐውያን፨ </incipit>
                        <explicit xml:lang="gez"> በእንተዝ፡ ሞተ፡ እስመ፡ ጸአለነ፨ ርእዩኬ፡ ኦፍቁራንየ፡ ዘከመዝ፡ መድምመ፡ ዘተገብረ፡
                  በኃይለ፡ ጸሎቱ፡ ለገብረ፡ መስቀል፡ ወራእየሂ፡ ዘርእየ፡ እንዘ፡ ሀሎ፡ ርኁቀ፨ እስመ፡ በከመ፡ ይሬኢ፡ አምላኮሙ፡ ይሬእዩ፡
                  መምለክያኒሁ፨ እስመ፡ መንፈስ፡ ቅዱስ፡ ዘላዕሌሆሙ፡ ይከሥት፡ ሎሙ፡ ኵሎ፡ ኅቡዓተ፨ </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.13">
                        <locus from="101vb" to="102rb">Fols 101vb–102rb</locus>
                         
                        <title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4928HagMir5">
                           <locus target="#101vb">Fol. 101vb</locus>
                        </title>
                        <incipit xml:lang="gez"> ወአሐተኒ፡ ዕለተ፡ ዘአርአርአየ፡ መንክራቲሁ፡ ገብረ፡ መስቀል፡ እፈቅድ፡ እንግርክሙ፨
                  ወሀለወት፡ አሐቲ፡ ብእሲት፡ ብዕልት፡ ወእንዘ፡ ትዴረር፡ ወትበልዕ፡ ሥጋ፡ እንስሳ፡ አኀዘት፡ ትብላዕ፡ ሥጋ፡ ሰብእኒ፡ ዘበሐሜት፨ </incipit>
                        <explicit xml:lang="gez"> ወዘንተ፡ እንዘ፡ ትቤ፡ ወፅአ፡ ውእቱ፡ ምታረ፡ ሥጋ፡ ምስለ፡ ደመ፡ ጕርዔሃ፡ ወወድቀ፡
                  ውስተ፡ ምድር፨ </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.14">
                        <locus from="102rb" to="103rb">Fols 102rb–103rb</locus>
                         
                        <title type="complete" subtype="inscriptio" ref="https://betamasaheft.eu/LIT4929HagMir6">
                           <locus target="#102rb">Fol. 102rb</locus>
                        </title>
              
                        <incipit xml:lang="gez"> ወካዕበ፡ አሐተ፡ ዕለተ፡ አኀዘ፡ ይጽርፍ፡ ሎቱ፡ ፩ ብእሲ፡ ለላሊበላ፡ እንዘ፡ የሐምዮ፨
                  ወብእሲቱሰ፡ ለውእቱ፡ ብእሲ፡ ትቤሎ፡ ኢጽርፍ፡ ላዕለ፡ ገብረ፡ እግዚአብሔር፡ ወመሢሐ፡ እግዚአብሔር፡ ወእቱ፡ ዓዲ፡ </incipit>
                        <explicit xml:lang="gez"> ያድኅነነኬ፡ እግዚአብሔር፡ እምዘከመዝ፡ ልማድ፨ እስመ፡ ጳውሎስኒ፡ ይሜህረነ፡ ከመ፡
                  ኢንርግም፡ እስከ፡ ለሰይጣን፡ አኮ፡ ለሰይጣን፡ ኀዚኖ፡ ዘይሜህር፡ ከመዝ፨ አላ፡ ከመ፡ ኢንልክፎ፡ ጥቀ፡ ለመርገም፡ በልሳንነ፡
                  ከመ፡ ኢንድኃፅ፡ ላዕለ፡ እኁነ፡ </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.15">
                
                        <locus from="103rb" to="110ra">Fols 103rb–110ra</locus>
                
                        <title type="complete" ref="https://betamasaheft.eu/LIT4930HagVirt">Story about virtuous Deeds of Lālibalā</title>
                        <incipit xml:lang="gez"> ስምዑኬ፡ ኦፍቁራንየ፡ እንግርክሙ፡ ዘከመ፡ ኮነ፡ ግብረ፡ ፀአቶን፡ ለእላንቱ፡ አብያተ፡
                  ክርስቲያናት፡ እምልበ፡ ምድር። </incipit>
                        <explicit xml:lang="gez"> ናሁኬ፡ ለካእኩ፡ ለክሙ፡ ኦፍቁራንየ፡ ንስቲተ፡ ዜና፡ እምትሩፋቲሁ፡ ለገብረ፡ መስቀል፡
                  ወይኩነነ፡ ለኵልነ፡ ለእለ፡ ተጋባዕነ፡ ዝየ፨ </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.16">
                        <locus from="110ra" to="113vb">Fols 110ra–113vb</locus>
                
                        <title type="complete" ref="https://betamasaheft.eu/LIT4933HagLal3"><span xmlns="" class="w3-tag w3-red">No item: LIT4933HagLal3</span></title>
                     </msItem>
                     <msItem xml:id="ms_i1.17">
                        <locus from="113vb" to="114ra">Fols 113vb–114ra</locus>
                
                        <title type="complete">Hymn for Lālibalā as attested in  MS TGM-001</title>
            
                     </msItem>

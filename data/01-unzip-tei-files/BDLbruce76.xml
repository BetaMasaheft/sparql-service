                  <msItem xml:id="ms_i1">
                     <locus from="1" to="73">Fols 1–73</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</title>
                     <textLang mainLang="gez"/> 
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="9">Fols 1–9</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionGospels">Four Gospels, Introduction to the  Four Gospels (same as LIT2705Introd)</title>
                        <textLang mainLang="gez"/> 
                        
                        <msItem xml:id="ms_i1.1.1">
                           <locus from="1">Fols 1 and following</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionMaqdema">Four Gospels, Maqdǝma wangel (same  as LIT4872MaqdemaWangel)</title>
                           <textLang mainLang="gez"/> 
                           <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡
                              <gap reason="omitted" extent="unknown" resp="PRS3562Dillmann"/>
                           ንቀድም፡ በጽሒፈ፡ መቅድመ፡ አርባዕቱ፡ ወንጌላት፡ ቅዱሳት፡ ወ፲አቅማራት፡ በሰላመ፡ እግዚአብሔር፡ አሜን።</incipit>
                           <note>After a longer introduction, the nature (<foreign xml:lang="gez">ግብር፡</foreign>), use (<foreign xml:lang="gez">በቍዔት፡</foreign>),
                              constitution (<foreign xml:lang="gez">ሥርዓት፡</foreign>), name (<foreign xml:lang="gez">ስም፡</foreign>), 
                              foundation (<foreign xml:lang="gez">መሠረት፡</foreign>), scope (<foreign xml:lang="gez">ምስማክ፡</foreign>) and
                              chapters (<foreign xml:lang="gez">አርእስተ፡ ነገር፡</foreign>) of the text are treated.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.2">
                           <title type="complete" ref="https://betamasaheft.eu/LIT1349EpistlEusebius">Epistle of Eusebius to Carpianus (generic  record)</title>
                           <textLang mainLang="gez"/> 
                           <note>Without title.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.3">
                           <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionCanons">Four Gospels, Canons of Eusebius  (same as LIT1224Canons)</title>
                           <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.4">
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1560Gospel#IntroductionGessawe">ግጻዌ፡
                           ሥርዓት፡ በእንተ፡ ኅብረተ፡ ቃላት ዘ፩ወንጌላት፡</title>
                           <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i1.1.5">
                           <locus to="9"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1558Matthew#SecondIntroduction">Wangel za-Mātewos, New introduction to the gospels, see</title>
                           <textLang mainLang="gez"/> 
                           <note>Various categories of Gospel divisions used by the Copts and Romans are related and the 
                           68 sections, in which the Ethiopic text is divided, copied.</note>
                        </msItem>
                     </msItem>
                     
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="10">Fols 10 and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2709Matthew">ብስራተ፡ ማቴዎስ፡ ሐዋርያ፡ ፩፡ እም፲ወ፪ ሐዋርያት፡
                           ጸሎቱ፡ ወበረከቱ፡ ወሀብተ፡ ረድኤቱ፡ ወትንብልና፡ ሣህሉ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ 
                           <persName role="owner" ref="https://betamasaheft.eu/PRS11553WaldaK">ወልደ፡ ካህን፡</persName> 
                           ወብእሲቱ፡ <persName ref="https://betamasaheft.eu/PRS11554WalattaM">ወለተ፡ ማርያም፡</persName> ወወለቱ፡ <persName ref="https://betamasaheft.eu/PRS11555WalattaI">ወለተ፡ ኢየሱስ፡</persName>
                        ለዓለመ፡ ዓለም፡ አሜን።</title>
                        <explicit xml:lang="gez">መልአ፡ መጽሐፈ፡ ብስራቱ፡ ለማቴዎስ፡ ሐዋርያ፡ ወኮነ፡ ጸሐፎ፡ በምድረ፡ ፍልስጥኤም፡ በአስተሐምሞ፡ መንፈስ፡
                           ቅዱስ፡ <sic resp="PRS3562Dillmann">ዕብራይስጣዊ፡</sic> እምድኅረ፡ ዕርገቱ፡ ለእግዚእነ፡ ዘበአጰርግዮን፡ በኀበ፡ ሰማይ፡ በሰማኒት፡ ዓመት፡ በቀዳሚሁ፡ ዓም፡ እመንግሥተ፡ 
                           አቅሎድዮስ፡ ቄሳር። ወስብሐት፡ ለእግዚአብሔር፡ ወትረ፡ እስከ፡ ለዓለም፡ አሜን።</explicit>
                        <textLang mainLang="gez"/> 
                        <note>The text is relatively accurate compared to other manuscripts, but differs considerably from the edition
                           <bibl corresp="http://zotero.org/groups/358366/items/CJRDF5NJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Platt1830novum"/><title level="m">Novum testamentum domini nostri et servatoris Jesu Christi aethiopice</title><editor><forename>Thomas Pell</forename><surname>Platt</surname></editor><pubPlace>Londini</pubPlace><publisher>Impressit Ricardus Watts</publisher><date>1830</date><note type="url">https://archive.org/details/novumtestamentu00platgoog</note><note type="tags"><note type="tag">Manuscripts</note><note type="tag">New Testament</note><note type="tag">bm:Platt1830novum</note></note><note type="tag">Manuscripts</note><note type="tag">New Testament</note><note type="tag">bm:Platt1830novum</note></bibl>.</note>
                     </msItem>
                        
                        <msItem xml:id="ms_i1.3">
                           <locus from="49">Fols 49 and following</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1882MarkGo#BiographyMark">Wangel za-Mārqos, Introduction and Biography of Mark</title>
                           <textLang mainLang="gez"/> 
                           <note>The various divisions of the Gospel of Mark are related and the 48 sections into which the
                           Ethiopic text is divided are listed.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.4">
                           <locus from="50">Fols 50 and following</locus>
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2711Mark">ብስራተ፡ አብ፡ ማሪ፡ ማርቆስ፡ ወንጌላ<sic resp="DR">ቂ</sic>፡ 
                              ፩እምሰብዓ፡ ወ፪አርድእት፡ ጸሎቱ፡ ወበረከቱ፡ ወሀብተ፡ ረድኤቱ፡ ወትንብልና፡ ሣህሉ፡ የሀሉ፡ ምስለ፡ ፍቁሩ፡ 
                              <persName ref="https://betamasaheft.eu/PRS11553WaldaK">ወልደ፡ ካህን፡</persName> ለዓለመ፡ ዓለም።</title>
                           <textLang mainLang="gez"/> 
                           <explicit xml:lang="gez">ተፈጸመ፡ በረድኤተ፡ እግዚአብሔር፡ ብስራተ፡ ማርቆስ፡ ሐዋርያ፡ ወኮነ፡ ጸሐፎ፡ በልሳነ፡ ሮሜ፡ ዘአፍርንጊ፡ በሀገረ፡ 
                              ሮምያ። እምድኅረ፡ ዕርገቱ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ በሥጋ፡ ውስተ፡ ሰማይ፡ በ፲ወ፩ዓመት፡ በራብዕት፡ ዓመተ፡ መንግሥቱ፡ ለቀላውዴዎስ፡ ቄሣር፡
                              ንጉሠ፡ ሮምያ፡ ወስብሐት፡ ለእግዚአብሔር፡ ለዓለም፡ አሜን።</explicit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5">
                           <locus from="73">Fols 73 and following</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke#BiographyLuke">Wangel za-Luqās, Introduction and Biography of Luke</title>
                           <textLang mainLang="gez"/> 
                           <note>The various divisions of the Gospel of Luke are related and the 83 sections into which the
                              Ethiopic text is divided are listed.</note>
                        </msItem>
                     
                  </msItem>
                  

      <body>
         <listPlace>
            <place type="church dabr" subtype="institution">
               
               <placeName xml:id="n1" xml:lang="gez">ሲዔት፡ ቅድስት፡ ማርያም፡</placeName>
               <placeName corresp="#n1" xml:lang="gez" type="normalized">Siʿet Qǝddǝst Māryām</placeName>
               <placeName type="alt" xml:id="n2" xml:lang="gez">ደብረ፡ ገነት፡ ቅድስት፡ ማርያም፡ ሲዔት፡</placeName>
               <placeName type="normalized" corresp="#n2" xml:lang="gez">Dabra Gannat Qǝddǝst Māryām Siʿet</placeName>
               <placeName type="alt" xml:id="n3" xml:lang="gez">የጋቦ፡ ማርያም፡</placeName>
               <placeName type="normalized" corresp="#n3" xml:lang="gez">Zag(g)ābo Māryām (former name)</placeName>
               
               
               <country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>
               
               <settlement when="2010-12-07" type="warada" ref="https://betamasaheft.eu/LOC3293GantaA">Gāntā ʾAfašum</settlement>
               <settlement when="2010-12-07" type="tabiya" ref="https://betamasaheft.eu/LOC7163Debla">Dǝblā Siʿet</settlement>
               <settlement when="2010-12-07" type="qushat" ref="https://betamasaheft.eu/LOC7162Siet">Siʿet</settlement>
               
                              
               <location>
                  <geo>14.205083 39.4992</geo>
                  <height unit="m">2700.0</height>
               </location>
               <note>
                  <date type="foundation" notBefore="1400" notAfter="1500">1400-1500</date>
                  <desc type="foundation">According to local tradition, the foundation took place during the time of King <persName ref="https://betamasaheft.eu/PRS1854Amdase">King ʿĀmda Ṣǝyon I</persName> (r. <date>1314-1334</date>).</desc>
                  <ab type="history">Dabr. Formerly, the church could have a different name, cp. GSM-002, Zag(g)ābo/Zag(g)ābu Māryām. Currently, the site accomodates two churches. 
                     The recent (late <date>19th or 20th cent.?</date>), rectangular church dedicated to <ref type="authFile" corresp="https://betamasaheft.eu/CovenantMercy">Kidāna Mǝḥrat</ref> stands below, 
                     and the old rock-hewn church dedicated to St. <persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</persName> is located above, cut in the rock. 
                     Many holes and small caves can be seen in the vertical rock around its entrance, formerly used as burials (in a few of them wooden caffins could still be seen) or dwellings of the monks.
</ab>
                  <ab type="description">
                     <figure>
                        <graphic url="Sites/GMS.tif">
                           <desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</desc>
                        </graphic>
                     </figure>
                     18 Mss., objects photographed: <ref type="mss" corresp="https://betamasaheft.eu/ESgms001">GMS-001</ref> "The Rite of the Holy Week"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms002">GMS-002</ref> "Four Gospels"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms003">GMS-003</ref> "The Book of the Funeral Rite"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms004">GMS-004</ref> "Missal"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms005">GMS-005</ref> "Miracles of Jesus"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms006">GMS-006</ref> "Synaxarion (March)"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms007">GMS-007</ref> "The Book of the Funeral Rite"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms008">GMS-008</ref> "The Faith of the Fathers"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms009">GMS-009</ref> "The Book of the Chants"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms010">GMS-010</ref> "Missal"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms011">GMS-011</ref> "Homily of the Saviour of the World"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms012">GMS-012</ref> "The Book of the Funeral Rite"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms013">GMS-013</ref> "Miracles of Mary"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms014">GMS-014</ref> "Homily of St. Michael"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms015">GMS-015</ref> "Synoptic Lectionary for the Year"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms016">GMS-016</ref> "Vita of Gäbrä Mänfäs Qǝddus"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms017">GMS-017</ref> "The Book of the Matrimony Rite"; <ref type="mss" corresp="https://betamasaheft.eu/ESgms018">GMS-018</ref> "Prayer of Mary"</ab>
         
                  <ab type="tabot">
                     <measure quantity="7"/>Tābots of <ref type="authFile" corresp="https://betamasaheft.eu/CovenantMercy">Kidāna Mǝḥrat</ref>, <persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</persName>, <persName type="tabot" ref="https://betamasaheft.eu/PRS4585Georgeo">George</persName>, 
                     <persName type="tabot" ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>, <persName type="tabot" ref="https://betamasaheft.eu/PRS10775Trinity">Trinity</persName>, 
                     <persName type="tabot" ref="https://betamasaheft.eu/PRS5684JesusCh#n3MadhaneAlam">Madḫāne ʿĀlam</persName>, <persName type="tabot" ref="https://betamasaheft.eu/PRS12519TwentyFour">Twenty-Four Heavenly Priests</persName> (marble).</ab>
               </note>

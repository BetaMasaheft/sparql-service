         <t:listPerson>
            <t:person sameAs="wd:Q7395817" sex="1">

                  
                     <t:persName xml:lang="gez" xml:id="n1" type="birth">ሰባጋዲስ፡ ወልዱ፡</t:persName>
                  <t:persName xml:lang="gez" corresp="#n1" type="normalized">Sabāgādis Waldu</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="birth">ሱባጋዲስ፡ ወልዱ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Subāgādis Waldu</t:persName>
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč, šum ʿagāme </t:roleName>
               </t:persName>

               <t:occupation type="ruler">governor</t:occupation>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
               <t:residence>
                  <t:placeName ref="https://betamasaheft.eu/LOC1236Agama">ʿAgāme</t:placeName>
               </t:residence>
               <t:birth notBefore="1780" notAfter="1785">He was reportedly born c. 1780 in <t:placeName ref="https://betamasaheft.eu/LOC7170Ganahti">Ganāḥti</t:placeName>.</t:birth>
               <t:floruit notBefore="1822" notAfter="1833">He became the governor of
                  <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName>
                  succeeding
                  <t:persName ref="https://betamasaheft.eu/PRS9978Waldase">
                     <t:roleName type="title">rās </t:roleName>Walda Śǝllāse</t:persName> in <t:date> 1822</t:date>
                 and he continued to rule until his death <t:date> 1831</t:date>.  </t:floruit>
               <t:death when="1831" evidence="internal">He died in the battle of <t:placeName ref="https://betamasaheft.eu/LOC2228DabraA">ደብረ፡ ዓባይ፡</t:placeName>
                     fighting against his  principal foe <t:persName ref="https://betamasaheft.eu/PRS6728Mareyye">Mārǝyye Gugsā</t:persName>
                     in <t:date> February 1831</t:date>
               </t:death>
            </t:person>
            

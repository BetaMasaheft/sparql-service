         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ከበደ፡ ተፈሪ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Kabbada Tafari</t:persName>
               <t:persName>
                  <t:roleName type="title">wag šum </t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               
               <t:occupation type="political">governor</t:occupation>
               
          
               
               
               
               <t:floruit notBefore="1874" notAfter="1935">He was
                  <t:persName ref="https://betamasaheft.eu/PRS5815Kabbada">
                     <t:roleName type="title">wag šum </t:roleName>
                  </t:persName> in the late 19th-early 20th century. 
                  He succeeded his father <t:persName ref="https://betamasaheft.eu/PRS9104TafariW">Täfäri Wäsän</t:persName> at a young age in <t:date>1874</t:date> but was removed from office in <t:date>1876</t:date>. 
                  He was reappointed two decades later, in <t:date>1905</t:date> but removed a year later due to a quarrel with the local people who lodged an appeal,
                  against him at <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk</t:persName> 's court for maladministration and harsh treatment. He was reappointed for the third time in<t:date>1917</t:date>, 
                  and continued to administer <t:placeName ref="https://betamasaheft.eu/LOC6135Wag">Wag</t:placeName> until the Italian invasion, in <t:date>1935</t:date>.
               </t:floruit>
          
               
               
            </t:person>
            
         </t:listPerson>
         
         
         

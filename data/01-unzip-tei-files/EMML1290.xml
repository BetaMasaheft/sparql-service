               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1.1">
                     <locus from="3r">3r-36v</locus>
                     <title>Weddase Maryam</title>
                     <note>Arranged for the days of the week</note>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i1.2">
                     <locus from="36v">36v-56v</locus>
                     <title>Anqaṣa berhān</title>
                     <textLang xml:lang="gez"/>
                  </msItem>
                  <msItem xml:id="ms_i1.3">
                     <locus from="57r">57r-62v</locus>
                     <title ref="https://betamasaheft.eu/LIT3108RepCh388">Hymn to Mary, Angels are praising Mary</title>
                     <textLang xml:lang="gez"/>
                     <incipit xml:lang="gez">ይዌድስዋ፡ መላእክት፡ ማርያም፡ በውስተ፡ ውሳጤ፡ መንጦላዕት፡ ወይብልዋ፡ በሐኪ፡ ማርያም፡ ሐዳስዩ፡ ጣዕዋ፡
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.4">
                     <locus from="63r">63r-73r</locus>
                     <title>Hymn to Mary, For she is glorious</title>
                     <textLang xml:lang="gez"/>
                     <incipit xml:lang="gez">ኦእግዝእትየ፡ ማርያም፡ እስመ፡ ክብርት፡ አንቲ፡ ወእምኵሉ፡ ፍጡር፡ በሰማይ፡ ወበምድር፡ አልቦ፡ ዘይከብር፡ እም፡ እግዚአብሔር፡
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.5">
                     <locus from="73r">73r-79r</locus>
                     <title>Hymn to Mary, I worship you</title>
                     <textLang xml:lang="gez"/>
                     <incipit xml:lang="gez">እሰግድ፡ ለኪ፡ እሰግድ፡ ለኪ፡ እሰግድ፡ ለኪ፡ ወእዌድሰኪ፡ ኦእግዝእትየ፡ ማርያም፡ በስመ፡ እግዚአብሔር፡ አብ፡ ለማርያም። ዘአጽንዓ፡ ወአደንገላ፡
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.6">
                     <locus from="79v"> 79v-81b and 1r-2v</locus>
                     <title ref="https://betamasaheft.eu/LIT1869Malkea">Image of the Praises of Mary, Malkeʼa weddāsē</title>
                     <textLang xml:lang="gez"/>
                  </msItem>
               </msContents>

                  <decoDesc>
                    <summary>

                  </summary>
                    <decoNote type="frame" xml:id="d1">
                    Decorative designs:
                    <locus target="#1r #26v" facs="003 029">fols. 1r, 26v</locus> <foreign xml:lang="gez">ሐረግ፡</foreign> using black and red, usually with eyes;
                    <locus target="#iv(erso)" facs="002">iv(erso)</locus> <foreign xml:lang="gez">ሐረግ፡</foreign> using black;
                    <locus target="#29r #30v #31v #33r #34v" facs="031 033 034 035 037">29r, 30v, 31v, 33r, 34v, </locus> (dotted line using alternating black and red);
                    <locus target="#36v" facs="039">36v</locus> (red and black lines)
                  </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc>Cross <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref> with caption <q><foreign xml:lang="gez">ማርያም፣ ወላዲተ፡ አምላክ, ዮሐንስ፡</foreign></q></desc>
                     </decoNote>

                     <decoNote type="miniature" xml:id="d3">
                        <locus target="#13v" facs="016">Fol. 13v</locus>
                        <desc>Cross <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref></desc>
                     </decoNote>

                     <decoNote type="miniature" xml:id="d4">
                        <locus target="#20r" facs="022">Fol. 20r</locus>
                        <desc>Crude painting of two men with arms outstretched</desc>
                    </decoNote>

                    <decoNote xml:id="d5">
                        <locus target="#26v" facs="029">Fol. 26v</locus>
                        <desc>Two small ornate crosses, <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref> above <foreign xml:lang="gez">ሐረግ፡</foreign> with eyes</desc>
                    </decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                        <item xml:id="a1">
                           <locus target="#iv(erso) #iir(ecto)" facs="002">Fols. iv(erso), iir(ecto)</locus>
                           <desc>Prayer to Jesus Christ for help and protection, in a crude hand. with incipit <foreign xml:lang="gez">እግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ወወልደ፡ ማርያም፡ ሥግው፡ በእንተ፡ ማርያም፡ ርድዓኒ፡<gap reason="omitted"/>በእንተ፡ ወላዲትከ፡ ተሣሃለኒ፡ ወተዘክረኒ፡<gap reason="omitted"/></foreign></desc>
                        </item>
                        <item xml:id="a2">
                           <locus target="#9v" facs="012">Fol. 9v</locus>
                           <desc type="Asmat">Asmat prayer against the enemy, written backward</desc>
                        </item>
                        <item xml:id="a3">
                           <locus target="#10r" facs="012">Fol. 10r</locus>
                           <desc>The first stanza (of five lines) from the hymn, "Wise of the Wise," <title type="incomplete" ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba
                                                  ṭabibān</title>, as a prayer of salvation</desc>
                        </item>
                        <item xml:id="a4">
                           <desc type="OwnershipNote">Name of the original owner, <foreign xml:lang="gez">ወልዳ፡ ጊዮርጊስ፡</foreign> has been effaced and replaced with <foreign xml:lang="gez">ወለደ፡ ማርያም፡</foreign></desc>
                          </item>
                        <item xml:id="e1">
                              <locus target="#ir(ecto) #10v #20v #38r #38v" facs="001 013 023 040 041">Fols. ir(ecto), 10v, 20v, 38r, 38v</locus>
                              <desc>blank (save for some isolated words)</desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#5v #10r" facs="008 012">Fols. 5v, 10r</locus>
                           <desc>Overlooked words of text are written interlinearly</desc>
                        </item>
                    </list>
                  </additions>

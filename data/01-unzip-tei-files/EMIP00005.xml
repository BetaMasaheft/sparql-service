               <msContents>
                 <msItem xml:id="ms_i1">
                     <locus from="1r" to="10r" facs="003">Fols 1r–10r</locus>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <title>A collection of prayers against evil spirits</title>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="2r" facs="003">Fols 1r–2r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT5696MagicPrayer">Ḥaṣura
                                                  Masqal</title>
                        <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡
                          <gap reason="omitted"/>በእንተ፡ ሐፁረ። መስቀል፡ ዘጸሐፈ፡ ኤርምያስ፡ ነቢይ፡ በውስተ፡ ኰኵሕ፡<gap reason="omitted"/></incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="2v" to="2v" facs="005">Fols 2v–2v</locus>
                        <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>ጸሎተ፡ ማኅፀን፡ ተማኅፀንኩ፡ በሰማያዊ፡ ንጉሥ፡<gap reason="omitted"/></incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                       <locus from="2v" to="4v" facs="005">Fols 2v–4v</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT4522Magic">Magical prayer
                                                  against the demons</title>
                       <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>አወግዘከ፡ ሠይጣን፡ በስሙ፡ ለኢየሱስ፡ ክርስቶስ፡<gap reason="omitted"/></incipit>
                         </msItem>

                    <msItem xml:id="ms_i1.4">
                        <locus from="5r" facs="007">Fols 5r and following</locus>
                        <incipit xml:lang="gez">በሰም፡ አብ፡<gap reason="omitted"/>ቅድስት፡ ሥላሴ፡ አወግዘከ፡ ወኵሉ።አባልከ፡ ወኵሉ፡ ጣዖትከ፡<gap reason="omitted"/></incipit>
                      </msItem>

                      <msItem xml:id="ms_i1.5">
                        <locus from="9r" facs="011">Fols 9r and following</locus>
                        <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>ተሰደዱ፡ ወርኃቁ፡ በሰርክ፡ ወበነግህ፡<gap reason="omitted"/></incipit>
                      </msItem>
                      </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="11r" to="26v" facs="013">Fols 11r–26v</locus>
                          <textLang mainLang="gez"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT5696MagicPrayer">Ḥaṣura
                                                  Masqal</title>
                         <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>አአትብ፡ ወእትነሳእ፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ነሲእየ፡ ማዕተበ፡ እትመረጐዝ፡<gap reason="omitted"/>ዲበ፡ መስቀለ፡ ዋህድ፡ አስመኩ፡ እስመ፡ ኃይልየ፡ ወጸወንየ፡ መስቀል፡<gap reason="omitted"/></incipit>
                       </msItem>

                      <msItem xml:id="ms_i3">
                        <locus from="26v" to="36v" facs="029">Fols 26v–36v</locus>
                        <textLang mainLang="gez"/>
                        <title>Prayer taking refuge with all powers, <foreign xml:lang="gez">ጸሎተ፡ ተማኅፅኖ፡</foreign></title>
                        <incipit xml:lang="gez">በስመ፡ አብ፡<gap reason="omitted"/>ተማኅፀንኩ፡ በእግዚአብሔር፡ አብ፡ ብሁተ፡ ስም፡ ወሥልጣን፡ ተ፡ በኢየሱስ፡ ክርስቶስ፡ ከሣቴ፡ ብርሃን፡ ተበመንፈስ፡ ቅዱስ፡ ጵራቅሊጦስ፡ ዘዕሩይ፡ ምስለ፡ አብ፡ በመለኮቱ፡<gap reason="omitted"/></incipit>
                      </msItem>

                      <msItem xml:id="ms_i4">
                        <locus from="36v" to="37v" facs="039">Fols 36v–37v</locus>
                        <textLang mainLang="gez"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT5678CommemorationRoch"> Synaxary entry, commemoration notice and short hymn for <foreign xml:lang="gez">ሮቆ፡</foreign> (or St Roch)</title>
                      </msItem>

               </msContents>

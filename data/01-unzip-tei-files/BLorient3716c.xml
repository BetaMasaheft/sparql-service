                        <decoDesc>
                            <decoNote xml:id="d1" type="miniature">
                                <desc><term key="MagicDrawing" ana="#MagicDrawing">Coloured magic picture</term> without title.</desc>
                            </decoNote>
                            <decoNote xml:id="d2" type="miniature">
                                <desc>Coloured picture representing <persName ref="https://betamasaheft.eu/PRS2548Basilide">Basilides</persName> spearing Satan (indicated with 
                                    <foreign xml:lang="gez">ቅዱስ፡ ፋሲለደስ፡ ዘከመ፡ ረገዞ፡ ለሰይጣን፡</foreign>) and <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> 
                                    spearing the Dragon (indicated with <foreign xml:lang="gez">ቅዱስ፡ ራጉኤል፡ ዘከመ፡ ረገዞ፡ ለከይሲ፡</foreign>). Near the 
                                    Dragon, Satan is depicted holding the souls of the damned (indicated with <foreign xml:lang="gez">ነፍሳት፡</foreign>),
                                    below <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> and a lion indicated with <foreign xml:lang="gez">አንበሳ፡</foreign>.</desc>
                            </decoNote>
                            <decoNote xml:id="d3" type="miniature">
                                <desc>Coloured picture representing the <term key="TrueCross" ana="#TrueCross">Cross</term> indicated with 
                                    <foreign xml:lang="gez">መስቀለ፡ ኢየሱስ፡</foreign>, <term key="demon" ana="#demon">Satan</term> indicated with 
                                    <foreign xml:lang="gez">ሰይጣን፡ ጽዋሪ፡</foreign>, the Virgin Mary indicated with 
                                    <foreign xml:lang="gez">ጽዮን፡</foreign>, a tabot indicated with <foreign xml:lang="gez">ታቦት፡</foreign>, 
                                    the Saviour of the World indicated with <foreign xml:lang="gez">መድሃኔ፡ ዓለም፡</foreign> under an umbrella
                                    indicated with <foreign xml:lang="gez">ድባብ፡</foreign>. 
                                    Below the depiction of the Virgin Mary, there is a note referring to the owner of the scroll: 
                                    <foreign xml:lang="gez">እማህፀነ፡ አቤቶ፡ <persName role="owner" ref="https://betamasaheft.eu/PRS14777WaldaDen">ወልደ፡ ድንግል፡</persName>
                                    </foreign> and a depiction of a man armed with a gun indicated with<foreign xml:lang="gez">ነፍጥ፡</foreign> and a 
                                    dagger indicated with <foreign xml:lang="gez">ሾቶል፡</foreign>.</desc>
                            </decoNote>    
                            <decoNote xml:id="d4" type="miniature">
                                <desc><term key="MagicDrawing" ana="#MagicDrawing">Coloured magic picture</term> without title.</desc>
                            </decoNote>
                        </decoDesc>

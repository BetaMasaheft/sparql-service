         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ ለእግዚአብሔር፡ በሥምረቱ፨</l>
                  <l n="2">እምሥጋ፡ ንጹሓን፡ አሐዱ፡ ወአኮ፡ ክልኤቱ፨</l>
                  <l n="3">ወበእንተዝ፡ ታዴዎስ፡ ውድሶተከ፡ እፈቱ፨</l>
                  <l n="4">እስከ፡ እፌጽም፡ ዘወጠንኩ፡ ተራድአኒ፡ ባሕቱ፨</l>
                  <l n="5">እስመ፡ ታሠልጥ፡ ወትክል፡ ለጻድቅ፡ ጸሎቱ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለልደትከ፡ በፍጻሜ፡ ትውልድ፡ ዕሥራ፨</l>
                  <l n="2">እምቤተ፡ ሌዊ፡ ወሳዶቅ፡ ካህናተ፡ ቀዳሚት፡ ደብተራ፨</l>
                  <l n="3">ወልደ፡ በረከት፡ ታዴዎስ፡ ለነገረ፡ ይስሐቅ፡ ዘትትናደራ፨</l>
                  <l n="4">ይትባረክ፡ አቡከ፡ ዜና፡ ሕይወት፡ ከመ፡ አብርሃም፡ ዘታራ፨</l>
                  <l n="5">ወቅዱስ፡ ሕዝባ፡ እምከ፡ ዳግሚት፡ ሳራ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ታዴዎስ፡ ዘተብህለ፨</l>
                  <l n="2">በአፈ፡ ካህናት፡ ክቡራን፡ እለ፡ ይፌከሩ፡ ወንጌለ፨</l>
                  <l n="3">እምብዕለ፡ ሥጋ፡ ታዴዎስ፡ እንተ፡ አብደርከ፡ መስቀለ፨</l>
                  <l n="4">ለቢወከ፡ ከመ፡ አኅለፈ፡ በስቍረተ፡ መርፍዕ፡ ገመለ፨</l>
                  <l n="5">መኵሴ፡ ስምከ፡ ዘገሠጸ፡ ታዴዎስ፡ ባዕለ፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ እምጻማ፡ ብዙኅ፡ ተመንድቦ፨</l>
                  <l n="2">ዘአዕረፍከ፡ ባቲ፡ በወርኀ፡ ሚካኤል፡ ወርኀ፡ የብቦ፨</l>
                  <l n="3">ኢትክልአኒ፡ ታዴዎስ፡ ድርሳነ፡ ወአንብቦ፨</l>
                  <l n="4">መኑ፡ ዘይሬኢ፡ መርዔቶ፡ ወኢይስቲ፡ ሐሊቦ፨</l>
                  <l n="5">ወመኑ፡ ዓሳብ፡ ዘየኀድግ፡ ዐስቦ፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">በከመ፡ ተወከፈ፡ እግዚእከ፡ በአንቀጸ፡ ምኵራብ፡ ዘአይሁድ፨</l>
                  <l n="2">ጸሪቀ፡ መበለት፡ ኅዳጠ፡ እመባአ፡ አብዕልት፡ ፍድፉድ፨</l>
                  <l n="3">ጠቢበ፡ ሠናያት፡ ታዴዎስ፡ ተወከፈኒ፡ ለአብድ፨</l>
                  <l n="4">ዘአቅረብኩ፡ ለከ፡ አስተብቍዖ፡ እንዘ፡ እጽሕፍ፡ በእድ፨</l>
                  <l n="5">ሶበ፡ አገበረኒ፡ ኂሩቱ፡ ለወልድ፨</l>
               </lg>
               <lg type="stanza" n="47">
                  <l n="1">ሰላም፡ ለታዴዎስ፡ ዘደብረ፡ ሊባኖስ፡ ወላዲቱ፨</l>
                  <l n="2">ወደብረ፡ ድኁኃን፡ ምኔቱ፨</l>
                  <l n="3">አመ፡ ምድረ፡ ዋዕይ፡ አብእዎ፡ በእንተ፡ ሃይማኖት፡ ጊዜ፡ ስደቱ፨</l>
                  <l n="4">አንቅዐ፡ ማየ፡ ትእምርት፡ እንዘ፡ ዓሣተ፡ ባሕር፡ ውስቴቱ፨</l>
                  <l n="5">እስከ፡ ሐራ፡ ንጉሥ፡ አንከሩ፡ ወሰገዱ፡ ሎቱ፨</l>
               </lg>
               <lg type="stanza" n="48">
                  <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ዕለተ፡ ብርሃን፡ ወቅዳሴ፨</l>
                  <l n="2">አመ፡ ፲ወ፫፡ ለወርኀ፡ ነሐሴ፨</l>
                  <l n="3">ታዴዎስ፡ ባሕረ፡ ዘከፈልከ፡ በስመ፡ ሥላሴ፨</l>
                  <l n="4">አባ፡ አባ፡ አሣእኒከ፡ ብናሴ፨</l>
                  <l n="5">አባ፡ ከፋሌ፡ ባሕር፡ ዳግማይ፡ ሙሴ፨</l>
               </lg>
            </div>
         </div>
      </body>

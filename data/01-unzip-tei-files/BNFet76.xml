                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="Record">Note written at the beginning of the volume by <persName role="scribe" ref="https://betamasaheft.eu/PRS6378Ludolf">Hiob Ludolf</persName>
                           </desc>

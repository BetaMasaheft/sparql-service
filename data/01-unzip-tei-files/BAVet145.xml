                    <msContents>
                      <summary/>
                      
                      <msItem xml:id="ms_i1">
                        <title type="complete" ref="https://betamasaheft.eu/LIT2358Sirach">Book of Sirach</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          ዘኢያሱ፡ ሲራክ፡ ትምህርተ፡ ጥበብ፡ ወቃል፡ ተግሣጽ፡ ጸሐፍኩ፤ ውስተ፡ ዝንቱ፡ መጽሐፍ፡ አነ፡ ኢያሱ፡ ሲራክ፡ ወልደ፡ አልዓዛር፡ ዘኢየሩሳሌም፡ <add place="above">ቀዳሚሃ፡</add> ለኵላ፡ ጥበብ፡ 
                          እምኀበ<supplied reason="omitted">፡</supplied> አግዚአብሔር፡ ይእቲ።
                        </incipit>
                        <colophon xml:id="coloph1">
                          <locus target="#74r"/>
                          ተፈጸመ፡ በዝየ፡ ጥበ<lb/>ቢሁ፡ ለኢያሱ፡ ወልደ፡ <lb/> ሲራክ። ዘተጽሕፈ። <lb/> <date when="1912" when-custom="1914">በ፲፻ወ፱፻ወ፬ቱ፡ <lb/> 
                            ዓመተ፡ ምሕረት፡ <lb/> በዘመነ፡ ዮሐንስ፡ <lb/> በወርኃ፡ ግንቦት፡ <lb/> አመ፡ ፮ሱ፡</date>
                          በጊዜ፡ ፲ <lb/> ሰአት፡ ሌሊቱኒ፡ ፳<lb/>ወ፫
                        </colophon>
                      </msItem>
                      

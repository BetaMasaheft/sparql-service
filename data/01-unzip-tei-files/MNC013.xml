               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="19r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2285Saqoqa">Saqoqāwa dǝngǝl</title>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ ሥሉስ፡ ቅዱስ፡ ሕጸተ፡ ግጻዌ፡ ዘአልቦ።</hi> ሰቆቃወ፡ ድንግል፡ እጽሕፍ፡ በቀለመ፡ አንብዕ፡ ወአንጠብጥ<hi rend="rubric">ቦ፡ 
                           ወሌ፡ ወላህ፡ ለይበል፡ ለዘአንበቦ፡ ከመ፡ ኃዘን፡</hi> ወተሰዶ፡ ሶበ፡ በኵለሄ፡ ረከቦ። ርእዮ፡ ለይብኪ፡ ዓይነ፡ ልብ፡ ዘቦ፡ <hi rend="rubric">አይቴ፡</hi>
                        ሀሎ፡ ንጉሠ፡ እ፳ኤል፡ ዘተወልደ።
                     </incipit>
                     <explicit xml:lang="gez">
                        <hi rend="rubric">ስብሐት፡</hi> ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በስብሐተ፡ አብ፡ ፈናዊ። ስብሐት፡ ለኪ፡ <hi rend="rubric">ማርያ፡</hi> 
                        በስብሐተ፡ ወልድ፡ ረፈናዊ፡ ስብሐት፡ ለኪ፡ <hi rend="rubric">ማርያም፡</hi> በስብሐተ፡ መንፈስ፡ ቅዱስ፡ ማኅየዊ፡ ቃለ፡ ስእለትየ፡ በአዕ<pb n="19r"/>ዛን፡ 
                        መንፈስ፡ ጽልዊ። ወዲበ፡ ዝንቱ፡ ሰላመ፡ ከዓዊ።
                     </explicit>
                     <explicit type="supplication" xml:lang="gez">
                        ኦእ<add place="above">ግ</add>ዝእትየ፡ <hi rend="rubric">ማርያም፡</hi> ዕቀብኒ፡ ለገብርኪ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12965SayfaMi">ሰይፈ፡ ሚካኤል።</persName></hi>
                        ወጸሐፊሁኒ፡ ኃጥእ፡ ወአባሲ፡ አነ፡ ድኩም፡ ወምስኪን። <hi rend="rubric"><persName role="scribe" ref="https://betamasaheft.eu/PRS12079TaklaMa">ተክለ፡ ማርያም፡</persName></hi>
                     </explicit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="19v" to="41r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ማርያ፡ ዘደረሰ፡ አባ፡ ሕርያቆስ፡ <add place="margin">በመ</add></hi>ንፈስ፡ ቅዱስ፡ አባ፡ ሕርያቆስ፡ 
                        ዘሀገረ፡ ብሕንሳ፡ ጸሎቱ፡ ወበረከቱ፡ የሃሉ፡ ምስለ፡ ገብሩ፡ <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12965SayfaMi">ሰይፈ፡ ሚካኤል።</persName></hi>
                        ለዓለመ፡ ዓለም፡ አሜን።
                        <lb/> <hi rend="rubric">ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፡ ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፡ ጐ</hi>ሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ።
                     </incipit>
                     <explicit>
                        ወይእዜኒ፡ ንሴብሖ፡ ለ<hi rend="rubric">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡</hi> ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን።
                        <hi rend="rubric">አንብሮ፡ እድ፡</hi> ነአኵቶ፡ ለእግዚአብሔር፡ በእንተ፡ ኵሉ፡ ጸጋ፡ ዘአስልጠና፡ ለእሙ፡ ላእለ፡ ዛቲ፡ ቅዳሴ፡ ወለነኒ፡ ረሰየኒ፡ ንንብብ፡ 
                        በሂሩቱ፡ ወፈጸመ፡ <pb n="41r"/> በሥምረቱ፡ ዘሎቱ፡ ስብሐት፡ ወውእቱ፡ ጠቢብ፡ ለዓለመ፡ ዓለም፡ አሜን። ወለገብርኪ፡
                        <hi rend="rubric"><persName ref="https://betamasaheft.eu/PRS12965SayfaMi">ሰይፈ፡ ሚካኤል።</persName></hi> ወጸሐፊሁ፡ ኃጥእ፡ ወአባሲ፡ 
                        <hi rend="rubric"><persName role="scribe" ref="https://betamasaheft.eu/PRS12079TaklaMa">ተክለ፡ ማርያም፡</persName></hi> ለዓለመ፡ ዓለም፡ አሜን።
                     </explicit>
                     <notatedMusic>
                        <desc>Letters inserted interlineally in a secondary hand, possibly for musical notation, e.g. on <locus target="#19v #24v #38v"/>.</desc>
                     </notatedMusic>
                  </msItem>

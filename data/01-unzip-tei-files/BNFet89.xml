               <msContents>
                  <summary/> 
            
            
                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas">
                        በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/> ጸሎት፡ ወስእለት፡ ወአስተብቍዖት፡
              እንተ፡ ነበበ፡ ባቲ፡ ቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS2546Basilth">ባስልዮስ፡</persName> ኤጲስ፡ ቆጶስ፡ ዘቄሳርያ፡ በእንተ፡ ፯ዕለታት፡ ዘመፍትው፡
                        ይጸልዩ፡ ባቲ፡ ለኵሉ፡  ዕለታት። ጸሎቱ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/> ንወጥን፡ በረድኤተ፡ እግዚአብሔር፡ ወበሠናይ፡
                        ስንዓሁ፡ በጽሒፈ፡ ጸሎታት፡ ዘ፯ዕለታት፡ በሰላመ፡ እግዚአብሔር፡ አሜን።</title>
                     <textLang mainLang="gez"/>
                     <note>Each of these prayers is divided into several sections or invocations, some of
                        which are explicitly described as being appendices to the principal prayers.</note>
            
                     <msItem xml:id="ms_i1.1">
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Monday">ጸሎት፡ ዘይትነበብ፡ ዘዕለተ፡
                ሰኑይ፡ እምቃለ፡ ቅዱስ፡ <persName ref="https://betamasaheft.eu/PRS2546Basilth">ባስልዮስ</persName>።</title>
                        <incipit xml:lang="gez">እግዚአብሔር፡ እግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ሥረይ፡ ኀጢአትየ። 
                  <choice>
                                 <sic resp="PRS10747Zotenbe">እንተ፡</sic>
                                 <corr resp="DR">አንተ፡</corr>
                              </choice>
                ተአምር፡ ኵሎ፡ ኀጢአት፡ ኅቡአ፡ ዘገበርክዋ፡ ጽሚተ፡ አንተ፡ ውእቱ፡ ትሬኢ፡ ምሥጢራተ፡ ዘበጻሕኩ፡ ባቲ፡
                እምኅሠመ፡ ምግባራትየ፡ ወእከይየ። አንተሰ፡ ርእየከ፡ ምግባራትየ፡ ወእኪተ፡ ኢያፍጠንኩ፡ ኮንኖትየ፡
                ወኢያኅሠርከ፡ ምግባርየ፡ አመ፡ ጊዜ፡ ድቀትየ።</incipit>
                     </msItem>
            
                     <msItem xml:id="ms_i1.2">
                        <locus from="13v">Fols 13v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Tuesday">ጸሎት፡ ወስዕለት፡ ዳግሚት፡
                ዘዕለተ፡ ሠሉስ፡ እምድርሳነ፡ ቅዱስ፡ ማሪ፡ <persName ref="https://betamasaheft.eu/PRS3827Ephrem">ኤፍሬም፡ ሶርያዊ፡</persName>
                           <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez"> ለከ፡ ይደሉ፡ ስብሐት፡ ኦመሥተዓግሥ። ለከ፡ ስብሐት፡ ኦመሓሪ፡ ለከ፡ ስብሐት፡
                ለከ፡ ስብሐት፡ ኦጸዋሪ። ለከ፡ ስብሐት፡ ኦመስተመይጥ፡ ላዕለ፡ ሰብእ።</incipit>
                     </msItem>
            
                     <msItem xml:id="ms_i1.3">
                        <locus from="37r">Fols 37r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Wednesday">ጸሎት፡ ወስእለት፡ ሣልሲት፡
                ዘዕለተ፡ ረቡዕ፡ እምድርሳነ፡ ቅዱስ፡ ማሪ፡ <persName ref="https://betamasaheft.eu/PRS3827Ephrem">ኤፍሬም፡</persName> ካዕበ።</title>
                        <incipit xml:lang="gez">እግዚአብሔር፡ (ms: ኤፍሬም። ካዕበ፡ እግዚ")   አምላክ፡ መስተሣህል፡ ኢየሱስ፡
                  ክርስ፡ ወልደ፡ እግዚአብሔር፡ ሶበ፡ ተዘከርኩ፡ መጽ<supplied reason="undefined" resp="PRS10747Zotenbe">አ</supplied>ተ፡
                ግሩመ፡ ለኰንኖ፡ ፍጥረትከ፡ ወፈደየ፡ ለኵሉ፡ ለለ፩፩፡ በከመ፡ ምግባሩ፡ ትትሀወክ፡ አእጽምትየ፡ ትትመተር፡ ኀይለ፡
                ነፍስየ፡ ወሥጋየ፡ ወይትሀወክ፡ ልብየ።</incipit> 
                     </msItem>
            
                     <msItem xml:id="ms_i1.4">
                        <locus from="54r">Fols 54r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Thursday">ጸሎተ፡ ራብዕ፡ ዘዕለተ፡
                ሐሙስ፡ እንተ፡ ተጋብዓት፡ እምቃለ፡ አረጋዊ፡ መንፈሳዊ፡ ቅዱስ፡ 
                           <persName ref="https://betamasaheft.eu/PRS5740JohnSab">ዮሐንስ፡</persName> ጸሎቱ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez">   ብሩክ፡ ውእቱ፡ አቡሁ፡ ለእግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘከሠተ፡
                  ምሥጢረ፡ አፍቅሮቱ፡ ለነፍሳቲነ፡ ወ<choice>
                                 <sic resp="PRS10747Zotenbe">አስረቀ፡</sic> 
                                 <corr resp="PRS10747Zotenbe">አሥረቀ፡</corr>
                              </choice> ልቡናሁ፡ ውስተ፡ አልባቢነ፡ ስብሐት፡ ለዘረቀ፡
                  ስብሐቲሁ፡ ወገብረ፡ ኀይላቲሁ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </incipit>
                     </msItem>
            
                     <msItem xml:id="ms_i1.5">
                        <locus from="76v">Fols 76v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2505Weddas#Friday">Wǝddāse
                                                  ʾAmlāk, No item: chapter: Friday</title>
                        
                     <msItem xml:id="ms_i1.5.1">
                        <locus from="76v">Fols 76v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#FridayShenute">ጸሎት፡ አባ፡ 
                           <persName ref="https://betamasaheft.eu/PRS8823Shenute">ሲኖዳ፡</persName>
                       
                              <sic resp="PRS10747Zotenbe">ትረየድእ፡ አርሳይ፡</sic> 
                              <supplied reason="explanation" resp="PRS10747Zotenbe">አርሳይ፡ መትርያድስ፡</supplied>
                           ዘማኅበረ፡ እንተ፡ ይትነበብ፡ በዕለተ፡ ዓርብ፡ ጸሎቱ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez"> እግዚኦ፡ በመዓትከ፡ ኢትቅሥፈኒ፡ አንሰ፡ ኢይሬኢ፡ በልቡናየ፡ ከመ፡
                ዕሩቅ፡ ወክሡት፡ እንተ፡ እቀውም፡ ቅድመ፡ ዝንቱ፡ መንበር፡ መፍርህ፡ እንዘ፡ እደንን፡ ርእስየ፡ በፍርሃት፡
                ወረዓድ።</incipit> </msItem>
                        
                        <msItem xml:id="ms_i1.5.2">
                           <locus from="84v">Fols 84v and following</locus>
                           <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#FridayPachomius">  ጸሎት፡ ዘአባ፡ ጳኩሚስ። </title>
                                            </msItem>   </msItem>
            
                     <msItem xml:id="ms_i1.6">
                        <locus from="94v">Fols 94v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Saturday">ጸሎት፡ ሣድሲት፡
                ዘዕለት፡ አይሁድ፡ ዘአስተጋብዓ፡
                              <sic resp="PRS10747Zotenbe">አመ፡ ኀልቀ፡</sic> 
                              <supplied reason="explanation" resp="PRS10747Zotenbe">እመኃልየ፡</supplied>
                            ቅብጢ፡ 
                           አቡነ፡ <persName ref="https://betamasaheft.eu/PRS2209Athanasi">አትናቴዎስ፡</persName> ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ እስክንድርያ፡ በረከቱ፡ 
                           <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez">ወትብል፡ ከመዝ፡ ኀሠሥኩከ፡ እማዕምቀ፡ ልብየ፡ ኢየሱስ፡ ክርስቶስ፡ ርድዓኒ፡
                ወፍትሐኒ፡ እማዕሠረ፡ ኀጢአት።</incipit>
                     </msItem>
            
                     <msItem xml:id="ms_i1.7">
                        <locus from="105r">Fols 105r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2505Weddas#Sunday">ጸሎት፡ ቅዱስ፡ 
                           <persName ref="https://betamasaheft.eu/PRS3255CyrilI">ቄርሎስ፡</persName> አቡነ፡
                ሊቀ፡ ጳጳሳት፡ ዘሀገረ፡ እስክንድርያ፡ ዘዕለተ፡ ሰንበተ፡ ክርስቲያን፡ በረከቱ፡
                           <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez"> ስብሐት፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ። ቦሙ፡ አአምን፡ ወእትአመን፡ እስከ፡
                ነፍስ፡ ደኃሪት፡ ስብሐት፡ ለከ፡ ኦእግዚአብሔር።
                     </incipit>
                     </msItem>
            
                     <explicit type="subscriptio" xml:lang="gez">ተፈጸመ፡ ጸሎት፡ ወስእለት፡ ወአስተብቍዖት፡ ዘሰብአቱ፡ ዕለታት። በሰላመ፡ እግዚአብሔር፡ አሜን።</explicit>
                  </msItem>
            
                  <msItem xml:id="ms_i2">
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3509Epistle">First Epistle of
                                                  John</title>

         <t:listPerson>
            <t:person sameAs="wd:Q60558198" sex="1">

                  <t:persName xml:lang="gez" xml:id="n3" type="birth">አዳል፡ ተሰማ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">ʾAdāl Tasammā</t:persName>
                  <t:persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ ጤና</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbā  Ṭenā</t:persName>

               <t:persName xml:lang="gez" xml:id="n1" type="regnal">ተክለ፡ ሃይማኖት፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Takla Hāymānot</t:persName>
               <t:persName>
                  <t:roleName type="title">nǝguś</t:roleName>
               </t:persName>



                  <t:occupation type="ruler">king</t:occupation>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
               <t:residence>
                  <t:placeName ref="https://betamasaheft.eu/LOC2310DabraM">Dabra Mārqos</t:placeName>
               </t:residence>
               <t:birth when="1850">He was born at <t:placeName ref="https://betamasaheft.eu/LOC2421DagaDa">Dagā Dāmot</t:placeName> in <t:date>1850</t:date>.
               </t:birth>
               <t:floruit notBefore="1855" notAfter="1901">He was a notable of <t:placeName ref="https://betamasaheft.eu/LOC2488Damot">Dāmot</t:placeName> and <t:placeName ref="https://betamasaheft.eu/LOC3549Gojjam">Goǧǧām</t:placeName> proper who dominated the political arena in his home region
                  in the last quarter of the 19th century.
                  He was a powerful rival to
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk <t:addName>II</t:addName>
                  </t:persName>
                  to whom he surrendered himself after the death of <t:persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                  ʾaṣe Yoḥannǝs IV
               </t:persName>.
                  </t:floruit>
               <t:death when="1901"> He died at <t:placeName ref="https://betamasaheft.eu/LOC2310DabraM">Dabra Mārqos</t:placeName> in <t:date>1901</t:date>.
               </t:death>
               </t:person>
               
         </t:listPerson>


                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Hand a: careful; hand b: mediocre, irregular; hand c:
                           very crude, irregular.</seg>
                        <seg type="ink">Black; red (vivid red).</seg>
                        <date>Late 19th - mid-20th century (?).</date>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; titles of the books
                           to be read; incipit of the prayers to be read; numbers of the prayers;
                           directives to the ministers; elements of Ethiopic numerals; elements of
                           the punctuation signs. 
 On the incipit page of Text I (fol.5r), a
                           few lines are rubricated (alternating with black lines).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus target="#5ra">5ra-</locus>vb,
                        11va-12vb.</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="6ra" to="11va">6ra-11va</locus>,
                        21ra-28vb.</handNote>
                     <handNote xml:id="h4" script="Ethiopic"> Hand c: <locus from="13r" to="20v">13r-20v</locus>,
                        29r-56v.</handNote>
                  </handDesc>

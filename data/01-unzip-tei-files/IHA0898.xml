               <msContents>
                  <summary>ff. 1-43 loose quires; ff. 44v-45v blank folios</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="7r">1r-7r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2400IHA">شرح حرز السبة العهودية السليمانية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>باب المرأة الزانى التى تزنى تكتب لها \ هذا الاسما حم حم الى عشرين وكهيعص \ الى ثمانية وكلللل وكلللت ساكس</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7r">-7r</locus>بسم الله الذي لايضرّ مع اسمه \ شيئ فى أرض ولا فى السماء وهو \ السّميع العليم وتكتب سوره الاخلاص \ والمعوذتين تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="7v" to="43v">7v-43v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous" ref="https://betamasaheft.eu/LIT2399IHA">كتاب القرعة</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>بسلة \ روى ابو هريرة رضي الله عنه \ انه قال كان رسول الله صلى عليه وسلّم \ جالسا في المسجد الحرام اذا الامين جبريل \ عليه السلام </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#43v">-43v</locus>وذلك اسم الذي ليس مثله توقّ به كلّ المكاره تسلم \ وذلك اسم الله جلّ جلاله إلى كلّ مخلوق فصح واعجم \ لاحّية تسعى ولا عقرب ترى ولا أسد يأتي اليك بهمهم<note>Seven seals of Solomon after the text</note>
                     </explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

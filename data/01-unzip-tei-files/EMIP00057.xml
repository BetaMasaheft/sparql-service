               <msContents>
                  <summary>Fragment of a Psalter, ዳዊት፡</summary>
                     <msItem xml:id="ms_i1">
                     <locus from="1r" to="50v" facs="001">Fols 1r–50v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="27r" facs="001">Fols 1r–27r</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <note>Beginning at Psalm 93, missing Psalms 118-144, and rebound in disorder</note>
                      </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="27r" to="41r" facs="027">Fols 27r–41r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="41r" to="50r" facs="041">Fols 41r–50r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                        <note>Common version</note>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="50r" to="50v" facs="050">Fols 50r–50v</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                        <note>Beginning only</note>
                     </msItem>
                  </msItem>
               </msContents>

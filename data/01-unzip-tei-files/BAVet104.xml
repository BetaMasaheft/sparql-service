               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="67"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot">ጸሎት፡ ወውዳሴ፡ ዘእግዝእትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="10v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Sunday">Praises for Sunday</title>
                        <note>
                           The scribe erroneously repeated the portion of text <locus from="3r3" to="4v"/> (<q xml:lang="gez">ኦድንግል፡</q>).
                        </note>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="11r" to="15v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Monday">Praises for Monday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ወውዳሴ፡ ዘእግዝእትነ፡ ወመድኃኒትነ፡ ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ። ዘይትነበብ፡ በዕለተ፡ ሰኑይ።
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="15v" to="23r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Tuesday">Praises for Tuesday</title>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="23r" to="30v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Wednesday">Praises for Wednesday</title>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="31r" to="40r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Thursday">Praises for Thursday</title>
                        <incipit xml:lang="gez">
                           ጸሎት፡ ወውዳሴ፡ ዘኃሙስ፡
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="40r" to="54v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Friday">Praises for Friday</title>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="55r" to="67r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4707Salot#Saturday">Praises for Saturday</title>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="67v" to="72"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4026Weddas">Wǝddāse ʾǝm-qāla nabiyāt lāʿla Māryām ba-warḫa tāḫśāś</title>
                     <note>Sayings of the prophets nos. 1-23. The numbers of the sayings are missing.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="119v" to="120"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our Lady Mary</title>
                     <explicit xml:lang="gez">
                        ሰላ<supplied reason="omitted">ም</supplied>። <supplied reason="omitted">ለኪ፡</supplied> ማር<supplied reason="omitted">ያ</supplied>ም፡ 
                        ገነቱ፡ ለወልደ፡ ኢ<add place="above">ያ</add>ራ፡ ወሬዛ፡ ዘተረክበ፡ ብኪ፡ ለድኂን፡ ወቤዛ፡ ፍሬ፡ ጽድቅ፡ ምስለ፡ መዓዛ።
                     </explicit>
                  </msItem>
               </msContents>
          

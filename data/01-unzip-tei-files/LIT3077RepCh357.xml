      <body>
         <div type="bibliography">
            
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
               <bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Marius</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><citedRange unit="item">357</citedRange></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እወጥን፡ አንሰ፡ በአስተሐምሞ፡ ወጻሕቅ፨</l>
                  <l n="2">ስብሐተ፡ መልክእከ፡ እንብብ፡ ማእከለ፡ ጉባኤ፡ ጽፉቅ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ባሕቱ፡ አበ፡ ናዝራዊያን፡ ደቂቅ፨</l>
                  <l n="4">ምስሌየ፡ ተዘውዖቶ፡ ወጽሕፈቶ፡ በረቅ፨</l>
                  <l n="5">ውጥን፡ በሠናይ፡ ወፈጽም፡ በጻሕቅ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለልደትከ፡ በሥምረተ፡ አምላክ፡ ልዑል፨</l>
                  <l n="2">ወለፅንሰትከ፡ ሰላም፡ ምስለ፡ ግብረ፡ ጥበብ፡ ወኀይል፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ እንባቆም፡ ነቢየ፡ ከዋኒት፡ አምሳል፨</l>
                  <l n="4">መድኃኒነ፡ እግዚእ፡ ኪሩብ፡ ዘኵለንታከ፡ መስቀል፨</l>
                  <l n="5">ኮከበ፡ ብሩህ፡ ወጽጌ፡ ጽዱል፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ኢየሱስ፡ ክርስቶስ፨</l>
                  <l n="2">ለአስኬማከ፡ ሰላም፡ ወለቆብዕከ፡ ዘርእስ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ይብሉከ፡ ሕዋሳትየ፡ ኀምስ፨</l>
                  <l n="4">አባ፡ ስቡሕ፡ ወአባ፡ ውዱስ፨</l>
                  <l n="5">አባ፡ ብፁዕ፡ ወአባ፡ ቅዱስ፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ወለርእስከ፡ ግልቡብ፨</l>
                  <l n="2">በአክሊለ፡ አስዋክ፡ አይሁድ፡ ዘአስተቀጸልዎ፡ በዐርብ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ አዳም፡ ቀዳሜ፡ ልህኵቱ፡ ለአብ፨</l>
                  <l n="4">ያብርሁ፡ ለስብሐቲከ፡ በዐየረ፡ ሰማይ፡ ርኂብ፨</l>
                  <l n="5">ኦርያሬስ፡ ወብናሴ፡ ወአርዮብ፡ ኮከብ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ኅሩያን፡ አንጋድ፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ ውስተ፡ ጽርሐ፡ ዛቲ፡ ዐፀድ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ጻማዊ፡ በይነ፡ ጻማከ፡ ፍድፉድ፨</l>
                  <l n="4">ለእለ፡ ይኤምኁ፡ መቃብሪከ፡ ወይጐደጕዱ፡ በእድ፨</l>
                  <l n="5">ዕቀቦሙ፡ ለዓለም፡ እምዛቲ፡ ትውልድ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ሰላም፡ ለዕርገትከ፡ በአክናፈ፡ እሳት፡ እለ፡ ተስእሉ፨</l>
                  <l n="2">ወለብጽሐትከ፡ ሰላም፡ ኢየሩሳሌም፡ እንተ፡ ላዕሉ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ አስተምሕር፡ ቅድመ፡ ገጸ፡ አምላክ፡ አኃዜ፡ ኵሉ፨</l>
                  <l n="4">ሶበ፡ ይትገበር፡ ተዝካርከ፡ በከመ፡ ኪዳን፡ ወቃሉ፨</l>
                  <l n="5">ህየ፡ በረከት፡ ወጸጋ፡ የሀሉ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">____ ሐተምኩ፡ ስቡሐ፡ ተዛዊዕየ፡ ውሑደ፨</l>
                  <l n="2">ለመልክእከ፡ ሠላሳ፡ እንዘ፡ አመነትው፡ ፍቅደ፨</l>
                  <l n="3">መድኃኒነ፡ እግዚእ፡ ባሕቱ፡ እምድኅረ፡ ረሰይከኒ፡ ወልደ፨</l>
                  <l n="4">ክሥተኒ፡ አእዛንየ፡ በዘአጸምዕ፡ ገሀደ፨</l>
                  <l n="5">ነገረ፡ ቃልከ፡ አቡየ፡ ዘያጠብብ፡ አብድ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ገብር፡ ኄር፡ መድኃኒነ፡ እግዚእ፡ ምእመን፨</l>
                  <l n="2">ለአርብሖ፡ መክሊት፡ በንግድ፡ ወወርቀ፡ ምናን፨</l>
                  <l n="3">ዘሖርከ፡ ፍና፡ ጻድቃን፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለከ፡ መድኃኒነ፡ እግዚእ፡ ባሕርይ፡ ዘዕፁብ፡ ሤጡ፨</l>
                  <l n="2">ወወርቀ፡ ምግባር፡ ዘብዙኅ፡ ተውላጡ፨</l>
                  <l n="3">ለክርስቶስ፡ መዝገበ፡ ሤጡ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለከ፡ ለውሉድከ፡ እግዚኦ፡ ዘወለድከነ፡ እምከርሥ፨</l>
                  <l n="2">ሀበነ፡ ንሕየው፡ ለክርስቶስ፨</l>
                  <l n="3">ሰላመከ፡ እንበለ፡ ግሒስ፨</l>
                  <l n="4">ይዕቀበነ፡ በሥጋ፡ ወነፍስ፨</l>
               </lg>
            </div>
         </div>
         
      </body>
   </text></TEI>
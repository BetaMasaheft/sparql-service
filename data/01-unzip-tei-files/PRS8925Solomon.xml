         <t:listPerson>
            <t:person sameAs="wd:Q60539714" sex="1">


                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ሰሎሞን፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Salomon</t:persName>
               <t:persName xml:lang="en" xml:id="n2" type="main">Solomon</t:persName>
  <t:occupation type="ruler">King</t:occupation>

                  <t:nationality type="Israel/Palestine"/>
                  <t:faith type="Judaism"/>


                



               <t:floruit notBefore="-0970" notAfter="-0931">He was the son and heir of the Biblical King
                  <t:persName ref="https://betamasaheft.eu/PRS3417David">David</t:persName>, figures prominently in Ethiopian Gǝʿǝz literature.
                  He is best known as the major protagonist in the <t:ref type="work" corresp="https://betamasaheft.eu/LIT1709Kebran">Kǝbra nagaśt</t:ref>.
                  In the textual tradition of Gǝʿǝz literature, Solomon is credited with personally writing five Biblical books. </t:floruit>
                  <t:death when="-0931" cert="medium"/>

               </t:person>

               
         </t:listPerson>


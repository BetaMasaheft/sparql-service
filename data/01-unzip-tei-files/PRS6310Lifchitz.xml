      <t:body>
         <t:listPerson>
            <t:person sex="2" sameAs="wd:Q5248310">
               <t:persName xml:lang="fr" xml:id="n1">
                  <t:surname>Lifchitz</t:surname>
                  <t:forename>Déborah</t:forename>
               </t:persName>
               <t:persName xml:lang="pl" xml:id="n2">
                  <t:surname>Lifszyc</t:surname>
                  <t:forename>Deborah</t:forename>
               </t:persName>
               <t:occupation type="academic">linguist and social anthropologist</t:occupation>
               <t:nationality type="France">Originally Polish, she became a French citizen in
                  1937.</t:nationality>
               <t:faith type="Judaism"/>
               <t:birth when="1905-06-05">5 June 1905 in Kharkov</t:birth>
               <t:floruit notBefore="1927" notAfter="1942">She left <t:placeName ref="https://www.wikidata.org/entity/Q36">Poland</t:placeName> for <t:placeName ref="https://www.wikidata.org/entity/Q90">Paris</t:placeName> in 1927 in
                  order to study Semitic langages with <t:persName ref="https://betamasaheft.eu/PRS3148Cohen">Marcel Cohen
                  </t:persName>and graduated in 1931. Meanwhile, she studied ethnology with <t:persName ref="https://betamasaheft.eu/PRS6925Mauss">Marcel Mauss</t:persName> and <t:persName ref="https://www.wikidata.org/entity/Q324932">Lucien Lévy-Bruhl</t:persName>. In 1932 she joined <t:persName ref="https://betamasaheft.eu/PRS4829Griaule">Marcel Griaule</t:persName> and the Mission Dakar-Djibouti
                  in <t:placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</t:placeName>. She was in charge of
                  collecting the manuscripts, as well as supervising the collect of informations.
                  Back in Paris, she entered the Africa departement of the Musée de l'Homme. In
                  1935, she conducted, together with <t:persName ref="https://www.wikidata.org/entity/Q3023075">Denise
                     Paulme</t:persName>, a 8 months field research on the Dogon culture (<t:placeName ref="https://www.wikidata.org/entity/Q912">Mali</t:placeName>). From 1937 to October 1940 she taught Amharic
                  at the Ecole des Langues Orientales. </t:floruit>
               <t:death when="1942">She died after September 1942 in deportation at <t:placeName ref="https://www.wikidata.org/entity/Q7341">Auschwitz.</t:placeName>
               </t:death>
            </t:person>

         </t:listPerson>

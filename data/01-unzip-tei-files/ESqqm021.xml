                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>18th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሠ(ረ)፡</abbr> for <expan>ሠረቀ፡ </expan> (<locus target="#1ra">1ra</locus>, 1rb)</item>
                           <item>
                              <abbr>ሰ፡ ቅ፡</abbr> for <expan>ሰኢለ፡ ለነ፡ ቅድስት፡ </expan> (e.g., <locus target="#1va">1va</locus>, 2ra, 2va, 5vb, 7rb)</item>
                           <item>
                              <abbr>ሰ፡</abbr> for <expan>ሰኢለ፡ ለነ፡ ቅድስት፡ </expan> (e.g., <locus target="#8vb">8vb</locus>, 10rb, 11rb)</item>
                           <item>
                              <abbr>እስ፡</abbr> for <expan>እስመ፡ </expan> (e.g., <locus target="#1rb">1rb</locus>, 2va)</item>
                           <item>
                              <abbr>ኵ፡</abbr> for <expan>ኵሉ፡ </expan> (<locus target="#3rb">3rb</locus>, 3vb)</item>
                           <item>
                              <abbr>ናዓብ፡</abbr> for <expan>ናዓብየኪ፡ </expan> (<locus target="#4va">4va</locus>)</item>
                           <item>
                              <abbr>ና(ዓ)፡</abbr> for <expan>ናዓብየኪ፡ </expan> (e.g., <locus target="#5ra">5ra</locus>, 5va)</item>
                           <item>
                              <abbr>ተ(ፈ)፡</abbr> for <expan>ተፈሥሒ፡ </expan> (e.g., <locus target="#6vb">6vb</locus>, 7rb)</item>
                           <item>
                              <abbr>ወበ፡</abbr> for <expan>ወበእንተ፡ </expan> (e.g., <locus target="#7vb">7vb</locus>, 9va, 11rb)</item>
                           <item>
                              <abbr>ወበእ(ን)፡</abbr> for <expan>ወበእንተ፡ </expan> (e.g., <locus target="#8ra">8ra</locus>, 9rb, 10rb).</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; several groups of lines on the incipit
                           page of Text I, alternating with black lines; refrains (written out fully
                           or abbreviated) and incipit of each section of Text I; the supplication
                           formula on fol. 8rb, the word baʾǝnta or its abbreviations in Text II;
                           elements of the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#11vb">f. 11vb</locus>
                           <desc>: Ownership note. </desc>
                           <quote xml:lang="gez">
                              <locus target="#11vb">11vb</locus>: ዝዳዊት፡ ዘወልደ፡ አ&lt;...&gt;</quote>
                           <quote xml:lang="en"/>
                           <note> The note is written in red ink and is partly effaced. The name of
                              the owner Walda ʾA&lt;...&gt; is partly illegible. The book is called
                              here Dāwit (Psalter). </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#11vb">f. 11vb</locus>
                           <desc>: Purchase note. </desc>
                           <quote xml:lang="gez">
                              <locus target="#11vb">11vb</locus>: መንግሥተ፡ አብ፡ ወለዶ፡ ለገብረ፡ … ዘተሣየጦ፡
                              ንዋዩ፡ ወብእሲቱ፡ ወለተ፡ ኪዳን፡ ወውልዱ፡ አጽፈ፡ ኤዎስጣቲዮስ፡ ገብረ፡ ክርስቶስ። </quote>
                           <quote xml:lang="en"/>
                           <note> The note is partly illegible, some words have been erased
                              repeatedly and overwritten in red ink. The note mentions Mangǝśta ʾAb,
                              Walatta Kidān, ʾAṣfä ʾEwosṭatiyos, and Gabra Krǝstos. </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#12r">f. 12r</locus>
                           <desc>: Traditional genealogy, from King Bäʾǝdä Māryām to Säbänä
                              Giyorgis. </desc>
                           <quote xml:lang="gez">
                              <locus target="#12r">12r</locus>: ንጽሐፍ፡ ነገረ፡ ትውልድ፡[sic] ንጉሥነ፡ በዕደ፡
                              ማርያም፡ ወለደ፡ ደጀ፡ አዝማች፡ ኤፍሬም፡ ስሜን። ኤፍሬም፡ ወለደ፡ …</quote>
                           <quote xml:lang="en"/>
                           <note> The note is written in a mediocre hand and is partly effaced. It
                              is possibly incomplete. </note>
                        </item>
                        <item xml:id="e1">- The scribe used compressed script to accommodate one
                           line left unfilled for rubrication: 6vb.
 - Omitted letters or words
                           inserted interlineally in black ink: e.g., <locus target="#1vb">1vb</locus>, 2vb, 3ra, 6ra.
 - Omitted words inserted
                           interlineally in red ink: <locus target="#4rb">4rb</locus>, 5vb.
 -
                           Corrections written over erasures in the main hand: e.g., <locus target="#1vb">1vb</locus>, 3va, 6ra, 6va.
 - Erasure marked with
                           thin black lines: <locus target="#8ra">8ra</locus>.
 - Scribbles in
                           red ink: <locus target="#11v">11v</locus>, 12r.
 - Scribbles in
                           pencil: <locus target="#2v">2v</locus>, 7r, 12r.</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards (both broken and repaired).
 Two
                           pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are partly visible on the
                           spine fold of the quires, close to the head and to the tail of the
                           codex.</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origPlace>
                        <placeName ref="https://betamasaheft.eu/INS0159QQM">ʿAddi Qiyaḥto Qǝddǝst Māryām / QQM</placeName>
                     </origPlace>
                     <origDate notBefore="1700" notAfter="1800">18th cent. (?)</origDate>
                  </origin>
                  <provenance>Additio 1 mentions Walda ʾA&lt;...&gt; as the
                     owner. The names of Mǝśṭira Qāl and Walatta Kidān
                     are written over erasure on the supplication formula on <locus target="#8rb">8rb</locus>. Walatta Kidān is also mentioned in Additio 2.</provenance>
               </history>

               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">12.0</measure> folios, of which
                              <measure unit="leaf" type="blank"/> blank <locus target="#12v">12v</locus>, in <measure unit="quire">2.0</measure> quires .
                              <dimensions type="outer">
                              <height unit="mm">225</height>
                              <width unit="mm">210</width>
                              <depth unit="mm">45</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">6</dim>
                                 <locus from="1r" to="6v"/>I(6/fols. 1r-6v) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">6</dim>
                                 <locus from="7r" to="12v"/> II(6/fols. 7r-12v).</item>
                           </list>
                        </collation>
                        <condition key="deficient">The two quires are probably a fragment of a
                           Psalter-Ms. (s. Additio 1)
 The front and back boards are broken and
                           have been repaired with several strips of leather.
 The sewing is
                           severely damaged.
 A few leaves are stained with water (e.g., <locus target="#1r">1r</locus>, 1v, 8r11r).
 Text on <locus target="#1r">1r</locus>, 6v, 7v is illegible or barely legible.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="23">
                           <dimensions unit="mm">
                              <height>190</height>
                              <width>184</width>
                              <dim type="intercolumn">15</dim>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">17</dim>
                              <dim type="bottom">18</dim>
                              <dim type="right">14</dim>
                              <dim type="left">12</dim>
                              <dim type="intercolumn">15</dim>
                           </dimensions>
                           <note>All data for <locus target="#4r">4r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Ruling and pricking are visible. </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A-1A1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are partly visible. </ab>
                           <ab type="pricking"> Ruling pricks are partly visible.</ab>
                           <ab type="ruling"> The upper line is written above the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>

               <msContents>
                  <summary/>
                 
                  <msItem xml:id="ms_i1">
                    <locus from="4r" to="53ra"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2711Mark">Bǝsrāta Mārqos</title>
                     <textLang mainLang="gez"/>
                    
                    <colophon xml:id="coloph1" xml:lang="gez">
                      <locus from="52vb" to="53ra"/>
                      <hi rend="rubric">መልዓ፡ ጽሕፈተ፡ ብስራቱ፡ ለማርቆስ፡ ሐዋርያ፡</hi> ወኮነ፡ ጸሐፎ፡ በልሳነ፡ <pb n="53r"/><cb n="a"/>
                      ሮሜ፡ ዘአፍርክንጊ፡ ዘሀገረ፡ ሮምያ፨ እምድኅረ፡ ዕርገቱ፡ ለእግዚእነ፡ ክርስቶስ፡ በሥጋ<hi rend="rubric" rendition="#partialRubric">፨</hi> ውስተ፡ ሰማይ፡ በዓሠርቱ፡ ወአሐዱ፡ ዓመት፡
                      በራብዒት፡ ዓመተ፡ መንግሥቱ፡ ለቀላውዴዎስ፡ ቄሣር፡ ንጉሠ፡ ሮምያ<hi rend="rubric" rendition="#partialRubric">፨</hi> 
                     <seg type="supplication"> ጸሎቱ፡ ወበረከቱ፡ ለቅዱስ፡ ማርቆስ፡ የሃሉ፡ ምስለ፡
                      <add place="overstrike">ወልደ፡ ህሪስቶፎሮስ፡</add> ለዓለመ፡ ዓለም፡ አሜን<hi rend="rubric" rendition="#partialRubric">፨</hi></seg>
                    </colophon>
                  </msItem>
                 
                 <msItem xml:id="ms_i2">
                   <locus from="53rb" to="55va"/>
                   <title type="incomplete" ref="https://betamasaheft.eu/LIT1812GospelLuke#LukeGospelPreface">Wangel za-Luqās, Preface to the Gospel of Luke</title>
                   <textLang mainLang="gez"/>
                   <incipit xml:lang="gez">
                     <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አሐ</hi>ዱ፡ አምላክ፨ ዘመርሐነ፡ በርድኤቱ፡ እምድኅረ፡ ስሕተት፡ ወሁረት፨ ወአርአየነ፡ ተመርሖ፡ እምድኅረ፡ እከይ፡
                   </incipit>
                   <note>It includes several parts including the list of "tituli", possibly not all complete</note>
                   
                 </msItem>

                   

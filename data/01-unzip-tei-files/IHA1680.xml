               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="4r">2v-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3257IHA">باكورة الوليد</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>ابسم الله الرحمن الرحيم الحمد الله رب العلمين والصلاة وسلام على سيدنا محمد وعلى اله وصحبه اجمعين وبعد فاعلم انه يجب على كل احد ان يعرف ان له خالقا رزقا موجودا لا معدوما قديما لا حادثا اباقيا الافانيا مخالفا للحودث </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>ومن عرف معناها وصدق بقلبه فقد صدق بجميع اسرائع ومن لم يعرفه او عرفه ولم يصدقه بقلبه لا ينتفع بها الا مجرد اجرء احكا الاسلام في الدنيا مثل مناكهة ولصلاة مؤتما به ووجوب الصلاه عليه اد مات \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4v" to="120v">4v-120v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="lacunous" ref="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>باب فى فضل الصلوة على النبى صلى الله عليه وسلم وشرف وكرم ومجد وعظم \ الله عظم قدر جاه محمد وأنا له فضلا عليه عظيما \ فى محكم التنزيل قال لخلقه صلوا عليه وسلموا تسليما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#120v">-120v</locus>المعنى بقوله عز وجل اطهارا لقدره فى العباد , ان الذى فرض عليك القرءان لرادّك الى معاد</explicit>
                     <note>Fol. 26v is blank.</note>
                     <note/>
                  </msItem>
               </msContents>

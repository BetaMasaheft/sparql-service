         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ተዘከርኩ፡ በሌሊት፡ ለኢትዮጵያ፡ ኂሩታ፨</l>
                  <l n="2">ወሠናይታ፡ ኀበ፡ እግዚአብሔር፡ አስተበቁዖታ፨</l>
                  <l n="3">ከመ፡ ሕገ፡ አምላኩ፡ ያነብብ፡ በመዓልት፡ ወበሌሊታ፨</l>
                  <l n="4">እንዘ፡ እዛዋዕ፡ ምስለ፡ ልብየ፡ ለኅሊናየ፡ ንቅሕታ፨</l>
                  <l n="5">በሳምናዊት፡ ዘመን፡ ዘወለደት፡ መንታ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ኢትዮጵያ፡ ታበጽሕ፡ ዕደዊሃ፡ ኀበ፡ እግዚአብሔር፨</l>
                  <l n="2">ከመ፡ ብንተ፡ ዐይን፡ ይዕቀባ፡ እምኀይለ፡ ጸላኢ፡ ወፀር፨</l>
                  <l n="3">እንዘ፡ ትብል፡ አምላኪየ፡ ዘበሰማያት፡ ወምድር፨</l>
                  <l n="4">ይሥዐር፡ ጸብአ፡ እምኔሃ፡ ወእምአጽናፈ፡ ምድር፨</l>
                  <l n="5">አምጣነ፡ ተስፋሃ፡ ጽኑዕ፡ እምኵሉ፡ አህጉር፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ጊዜ፡ ተጸውኦ፡ አዳም፨</l>
                  <l n="2">ከመ፡ አስካለ፡ ወይን፡ ዘገነት፡ ወከመ፡ ስማ፡ ለማርያም፨</l>
                  <l n="3">ኢትዮጵያ፡ ዘዮም፡ ወአቢሲኒያ፡ ዘትማልም፨</l>
                  <l n="4">በዝክረ፡ ስምኪ፡ እትፌሣሕ፡ ለዓለም፨</l>
                  <l n="5">አምጣነ፡ በተግባር፡ ግብርኪ፡ ወአኮ፡ በስም፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ እብል፡ ለላዕከ፡ ቤቴል፡ ሥዕርትኪ፨</l>
                  <l n="2">ዘበላዕለ፡ ርእስ፡ አድነነ፡ ወዘተሐጽነ፡ በርእስኪ፨</l>
                  <l n="3">ኢትዮጵያ፡ ሀገሩ፡ ለቀዳማዊ፡ በኵርኪ፨</l>
                  <l n="4">አቤሜሌክ፡ ጴጥሮስ፡ ኢትዮጵያዊ፡ ኢይርአይ፡ ሙስናኪ፨</l>
                  <l n="5">አመ፡ በፄዋዌ፡ መፍርህ፡ ተመነየ፡ ለኪ፨</l>
               </lg>
               <lg type="stanza" n="49">
                  <l n="1">ሰላም፡ ለመልክእኪ፡ እምውሉደ፡ ዓለም፡ ቅድው፨</l>
                  <l n="2">እንዘ፡ በጸጋ፡ ይልሂ፡ እምነ፡ አህጉር፡ ወበድው፨</l>
                  <l n="3">ኢትዮጵያ፡ ምድርኪ፡ እመዐዛ፡ ጽጌ፡ ፍትው፨</l>
                  <l n="4">መዐዛ፡ ዕፍረትኪ፡ ምግባሮሙ፡ ለቅዱሳን፡ አበው፨</l>
                  <l n="5">አምጣነ፡ ምዑዝ፡ ጼናሁ፡ እምኵሉ፡ አፈው፨</l>
               </lg>
               <lg type="stanza" n="50">
                  <l n="1">ሰላም፡ ለክሙ፡ ጳጳሳት፡ ዘኢትዮጵያ፨</l>
                  <l n="2">ወነገሥታተ፡ ምድር፡ ዘአቢሲንያ፨</l>
                  <l n="3">ከመ፡ እምኵሉ፡ ጸለየ፡ ጎርጎርዮስ፡ ለሰብአ፡ አርማንያ፨</l>
                  <l n="4">አፍቀርክዋ፡ ወአእመርክዋ፡ እምዐጸደ፡ ግብጽ፡ ወሶርያ፨</l>
                  <l n="5">ለኢትዮጵያ፡ ምድርክሙ፡ ዘሠናይ፡ ላህያ፨</l>
               </lg>
               <lg type="stanza" n="51">
                  <l n="1">አምኀ፡ ሰላም፡ አቅረብኩ፡ ለክብርኪ፡ ኢትዮጵያ፡ ቅድስት፨</l>
                  <l n="2">ኦሆ፡ በሐሊት፨</l>
                  <l n="3">ሶበ፡ አደመኒ፡ ሊተ፡ ክብረ፡ ዚኣኪ፡ ሥነ፡ ሕይወት፨</l>
                  <l n="4">ፈቀድኩ፡ እንግር፡ ክብረ፡ ዚአኪ፡ ለቀደምት፡ ወለደኃርት፨</l>
                  <l n="5">ተዘኪርየ፡ ሠናይተኪ፡ በኵሉ፡ ሰዓት፨</l>
               </lg>
               <lg type="stanza" n="52">
                  <l n="1">በክብር፡ ወበስብሐት፡ እመ፡ ርኢኩ፡ ሠናይቶ፨</l>
                  <l n="2">ለመዋዕለ፡ ሣህልኪ፡ ኵሉ፡ ወለሕይወትኪ፡ ተፍጻሜቶ፨</l>
                  <l n="3">ሀገረ፡ ቅዱሳን፡ ኢትዮጵያ፡ እንተ፡ ኢትክሊ፡ ተከብቶ፨</l>
                  <l n="4">ናሁ፡ ፈጸምኩ፡ ተናግሮ፡ ወለክብርኪ፡ አእኩቶቶ፨</l>
                  <l n="5">ወኢይንበር፡ በላዕሌኪ፡ ዘይነብብ፡ ከንቶ፨</l>
               </lg>
            </div>
         </div>
      </body>

                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref> with caption <q><foreign xml:lang="gez">ዳዊት</foreign></q>

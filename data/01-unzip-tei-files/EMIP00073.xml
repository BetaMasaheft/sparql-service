                        <desc>Two <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> each with a <term key="crown" ana="#crown"/> and a brandished <term key="sword" ana="#sword"/>
                            with caption <q><foreign xml:lang="gez">መላእክት፡</foreign></q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#50r" facs="052">Fol. 50r</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with caption <q><foreign xml:lang="gez">ማርያም፡</foreign></q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#50v" facs="053">Fol. 50v</locus>
                        <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1038Baptism">Baptism of Jesus</ref> with caption <q><foreign xml:lang="gez">አጥመቆ፡ ዮሐንስ፡ ለኢየሱስ።, ርግብ፡</foreign></q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d8">
                        <locus target="#60r" facs="062">Fol. 60r</locus>

                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="11r" to="113r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Sawāsǝw (general record)</title>
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="11r" to="31v"/>
                        <title type="complete">Sawāsǝw</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ንዌጥን፡ ጽሒፈ፡ ሰዋስው፡ ሰዋስው፡ 
                           ብሂል፡ መሰላል፡ <choice>
                              <sic>መሸጋገርያ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">መሸጋገሪያ፡</corr>
                           </choice> 
                        </incipit>
                        <explicit xml:lang="am">
                           ሣልስ፡ ራብዕ፡ ኃምስ፡ ሳብዕ፡ የሆን፡ እንደ፡ ሆነ፡ ነቢር፡ ከተገብሮ፡ ያስተባብራል፨ ሳድስ፡ ግን፡ የሆነ፡ እንደሆን፡ ግብፅ፡ ዮርዳኖስ፡ ያለውን፡ 
                           ግብፀ፡ ዮርዳኖሰ፡ ሲል፡ ተገኝቷል፡ መጽሐፍ፨ የቀ<add place="inline">
                              <supplied reason="omitted">ረ</supplied>
                           </add>ው፡ ግን፡ ገቢር፡ 
                           ከተገብሮ፡ ያስተባብራል፨ በዝየ፡ ተፈጸመ፡ ሰዋስው፡ በሰላመ፡ እግዚአብሔር፨ አሜን፨ ወአሜን፨
                        </explicit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="32r" to="33v"/>
                        <title type="incomplete">Fragment of a sawāsǝw</title>
                        <incipit xml:lang="am">
                           በሴት፡ ቅፅል፡ የሚጠብቁ፡ አናቅጽ፡ <choice>
                              <sic>፫ናቼው፤</sic>
                              <corr resp="bm:GrebTiss1935Codices">፫ናቸው፤</corr>
                           </choice> 
                           ጠ፤ ደ፤ ተ፡ ይባላሉ፨
                        </incipit>
                        <explicit xml:lang="am">
                           አበየና፡ ዓብየ። ነጸፈና፡ ነጽፈ፤ ነደፍና፡ አስተናደፈ።
                        </explicit>
                     </msItem>
                   
                     <msItem xml:id="ms_i1.3">
                        <locus from="35r" to="63"/>
                        <title type="complete">On the conjunctions</title>
                        <incipit xml:lang="gez">
                           በስመ፡ አብ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ 
                           ሎቱ፡ ስብሐት፡ ጽሕፈ፡ አገባብ፡ ዘዓቢይ፡ ወዘደቂቅ፡ ወዘንዑስ፡ ዘአስተጋብዕዎሙ፡ መምሕራን፡ እመጻሕፍት፡ ዘብሉይ፡ ወዘሐዲስ፡ እንዘ፡ 
                           ይረድኦሙ፡ መንፈስ፡ ቅዱስ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/>  ተወጥነ፡ ብሂል። ባሕል፡ ብሂል፡ 
                           ብሂሎት፡ ማለት፡ ይሆናል፡
                        </incipit>
                        <explicit xml:lang="am">
                           ሁሉ፡ እየወደቁ፡ ውእቱን፡ <choice>
                              <sic>ፈለገው።</sic>
                              <corr resp="bm:GrebTiss1935Codices">ፈልገው።</corr>
                           </choice> ያጠፋሉ፡ 
                           በዝየ፡ ተፈጸመ፡ ዓቢይ፡ አገባብ።
                        </explicit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.4">
                        <locus from="63v" to="93"/>
                        <title type="complete">On the prepositions</title>
                        <incipit xml:lang="am">
                           ደቂቅ፡ አገባብ፨ ዲበ፡ ነባር፡ ነው፡ በሰም፡ ላይ፡ ወድቆ፡ ለወርቅ፡ በወርቅ፡ <add place="inline">
                              <supplied reason="omitted">ላይ፡</supplied>
                           </add> 
                           ወድቆ፡ ለሰም፡ የሚተርፍ፡ አገባብ፡ ነው፡
                        </incipit>
                        <explicit xml:lang="am">
                           ናዕስ፡ ንዕስ፡ ታናሽነት፡ ይሆናል፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> 
                           <choice>
                              <sic>ኢያሱ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ኢየሱስ፡</corr>
                           </choice> ላዕለ፡ እግረ፡ ፀሐይ፡ ይትዋነይ፡ በጊዜ፡ 
                           ናዕሱ፡ ወማያተ፡ ይቀድሕ፡ በልብሱ፡ <choice>
                              <sic>ይለል።</sic>
                              <corr resp="bm:GrebTiss1935Codices">ይላል።</corr>
                           </choice> 
                           በንዕሱ፡ ወጠነ፡ መሠረተ፡ ስብሐት፡ ንድቅ፡ ለደብረ፡ ሊባኖስ፡ ስርጋዌ፡ ርእሰ፡ ተክለ፡ ሃይማኖት፡ አክሊለ፡ ወርቅ፡ ይላል። ነሥአ፡ አርዑተ፡ 
                           እምንዕሱ፡ ወተፀምዶ፡ ለእግዚአብሔር፡ ይላ<supplied reason="omitted">ል</supplied>፡ ወላዲተ፡ ሕያው፡ ክርስቶስ፡ 
                              <sic>ዘኢተአምር፡</sic>
                            
                           አበሳ፡ እንዘ፡ ለሐና፡ መካን፡ ውሣጤ፡ ከርሣ፡ ሕሙማነ፡ ትፌውስ፡ እምንዕሳ፡ ይላ<supplied reason="omitted">ል</supplied>፡ በዝየ፡ ተፈጸመ፡ 
                           ደቂቅ፡ አገባብ።
                        </explicit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.5">
                        <locus from="94" to="103v"/>
                        <title type="complete">On the adverbs</title>
                        <incipit xml:lang="am">
                           ንዑስ፡ አገባብ። አይ፡ ሚ፡ ምንት። ምን፡ ምንድር፡ አያት፡ ምንታት፡ ምኖች። ምንድሮች፡ <choice>
                              <sic>ይሆኖሉ።</sic>
                              <corr resp="bm:GrebTiss1935Codices">ይሆናሉ።</corr>
                           </choice>
                        </incipit>
                        <explicit xml:lang="am">
                           ለዓለም፡ ለግሙራ፡ ግሙራ፡ ለዝሉፉ፡ ለዝላፉ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> በደጊመ፡ ቃል፡ ከቶ፡ 
                           ተከቶ፡ <choice>
                              <sic>አስከትቶ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">አስከቶ፡</corr>
                           </choice> ተካቶ፡ 
                           <choice>
                              <sic>አከቶ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">አካቶ፡</corr>
                           </choice> ይሆናሉ።
                        </explicit>
                     </msItem>
                 
                     <msItem xml:id="ms_i1.6">
                        <locus from="104" to="107"/>
                        <title type="complete">On the numerals</title>
                        <incipit xml:lang="am">አኀዝ፡ ማላት፡ መጀመርያ፡ ማላት፡ ነው፡ ምነው፡ መጀመርያ፡ ተባለ፡ ቢሉ፡ ሁሉ፡ በቍፅር፡ ተጀምሮ፡ በቍፅር፡ 
                        ይጨረሳል፡</incipit>
                        <explicit xml:lang="am">
                           ኍልቈ፡ ዕለት፡ እሁድ፡ አንድ፡ ሰኑይ፡ ሁለት፡ ሠሉስ፡ ሶስት፡ ረቡዕ፡ አራት፡ ሐሙስ፡ አም<supplied reason="omitted">ስትቅ</supplied> የፊደል፡ 
                           ግዕዝ፡ አንድ፡ ካዕበ፡ ሣልስ፡ ራብዕ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ፴ቀን፡ ወር፡ ፲፪አውራኅ፡ አመት፡
                        </explicit>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.7">
                        <locus from="110" to="113r"/>
                        <title type="incomplete">Fragment of a vocabulary</title>
                        <incipit xml:lang="am">
                           ከሀ፡ ጀምሮ፡ እስከ፡ ፐ፡ <choice>
                              <sic>የአለ፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">ያለ፡</corr>
                           </choice> ግሥ፡ ሁሉ፡ በ፬ፀዋትው፡ 
                           በ፳፭ሠራዊት፡ የነገራል፡
                        </incipit>
                        <explicit xml:lang="am">
                           በማስደረግ፡ በማደራረግ፡ አስራው፡ በካልዓይ፡ በንዑስ፡ አንቀጽ፡ ራብዕ፡ ይሆናሉ። 
                        </explicit>
                     </msItem>
                  
               

                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="MagicText">Protective prayers</desc>
                           <locus target="#1v"/>
                           <q xml:lang="gez">
                              መጽሐፈ፡ ዠረደሸት፡ መቅጁል፡ ሐጁል፡ መጽሐፈ፡ ዠረደ<del rend="erasure" unit="chars" quantity="1"/>ሸት፡ መቅጁል፡ ሐጁል፡ አልፋ፡ 
                              <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> ተኀባዕ፡ ውስተ፡ ልብየ፡ በኃይለ፡ ዝንቱ፡ አስማቲከ፡
                           </q>
                        </item>
                        <item xml:id="a2">
                           <desc type="MagicFormula"/>
                           <locus target="#2v"/>
                           <q xml:lang="gez">
                              ወመንፈስ፡ ቅዱስ፡ ዘተፈነወ፡ ሀበ፡ ዕዝራ፡ በዕደ፡ ሱራኤል፡ ዶቤር፡ ቶቤር፡ ፫ጊዜ፡ <gap reason="omitted" resp="bm:GrebTiss1935Codices"/> 
                              በሐይለ፡ ዝንቱ፡ አስማቲከ፡
                           </q>
                           <note>
                              The following text was added in a different hand in dark red ink: 
                              <q xml:lang="gez">
                                 ቀለም፡ ዳዕሙ፡ ወባሕቱ፡ ሓሰ፡ ለከ፡ ዕፁብ፡ ምንት፡ ውእቱ፡ ዝንቱ፨ እንዳዒ፨ ኳሄላ፡ ው<supplied reason="omitted">እቱ።</supplied>
                              </q>
                           </note>
                        </item>
                        <item xml:id="a3">
                           <desc type="PoemQene"><term key="Qene" ana="#Qene">Poem, possibly qǝne</term></desc>
                           <locus from="3r" to="10v"/>
                           <note>The text begins as follows:
                           <q xml:lang="gez">
                              መን<add place="inline">
                                    <supplied reason="omitted">ገ</supplied>
                                 </add>ደ፡ ቅኔያት፡ ቀሠመ፡ ጣዕመ፡ መጽሐፍ፡ አስካለ፡ ቄርሎስ፡ ወይነ፡ ኒቅያ፡
                           </q>

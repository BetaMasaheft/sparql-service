                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with caption <q>“Jesus Christ”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                           <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> with caption <q>“Michael Enthroned”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#ivr(ecto)" facs="004">Fol. ivr(ecto)</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                           <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName> rescuing the three youths from the furnace with caption <q>"Angel Gabriel”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#2r" facs="006">Fol. 2r</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                           <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> spearing a demon.  with caption (in Amharic), <q>
                              <foreign xml:lang="am">ድል፡ አደ(ረገ)[ው]፡ ሚካኤል፡ ለሳጥ[ናኤል]፡</foreign>, “Michael defeated Satan.”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#22r" facs="026">Fol. 22r</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref> with caption <q>“Gabriel Announced.”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#47r" facs="051">Fol. 47r</locus>
                        <desc>
                           <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/> with caption <q>“Saint George”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d7">     

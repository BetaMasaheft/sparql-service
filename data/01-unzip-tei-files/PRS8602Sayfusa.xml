      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሰይፉ፡ ሣህለ፡ ሥላሴ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Sayfu Śahla Śǝllāse</t:persName>
         
               <t:persName>
                  <t:roleName type="title">abetohun</t:roleName>
               </t:persName>
               
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               <t:occupation type="political">governor</t:occupation>
               
               <t:birth notBefore="1828" notAfter="1829"/>
               <t:floruit notBefore="1840" notAfter="1860">He was 
                  the son of 
                  <t:persName ref="https://betamasaheft.eu/PRS8346sahlase">
                     <t:roleName type="title">nǝguś</t:roleName> Śahla Śǝllāse</t:persName> of <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName>
                  and his wife <t:persName ref="https://betamasaheft.eu/PRS11429Bazzabbe">Bazzabbǝš Daǧan</t:persName>.
                  He was the governor of <t:placeName ref="https://betamasaheft.eu/LOC4578Marhab">Marḥābete</t:placeName> and <t:placeName ref="https://betamasaheft.eu/LOC5482Salale">Salāle</t:placeName> 
                  throughout <t:date>1840</t:date>s and <t:date>1850</t:date>s. <t:persName ref="https://betamasaheft.eu/PRS8602Sayfusa">Sayfu Śahla Śǝllāse</t:persName> was an ardent opponent  
                  to                  <t:persName ref="https://betamasaheft.eu/PRS9430Tewodros">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                      Tewodros II</t:persName> 
                  who offered a strong resistance for several days but was eventually defeated and had to flee. Some time later,
                  <t:persName ref="https://betamasaheft.eu/PRS8602Sayfusa">Sayfu Śahla Śǝllāse</t:persName> tried to regain control over  
                  <t:placeName ref="https://betamasaheft.eu/LOC4578Marhab">Marḥābete</t:placeName>, but was killed by <t:persName ref="https://betamasaheft.eu/PRS5902Kebrat">Kǝbrāt</t:persName>
                  at <t:placeName ref="https://betamasaheft.eu/LOC4811Midda">Middā</t:placeName>.</t:floruit>
               <t:death when="1860"/>
               
            </t:person>
            
            
         </t:listPerson>

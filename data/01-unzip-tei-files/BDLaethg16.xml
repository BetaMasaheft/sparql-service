               <msPart xml:id="p1">
                  <msIdentifier/>
                  <msContents>
                     <summary/>
                     
                     <msItem xml:id="p1_i1">
                        <locus from="3" to="10v">Fols 3–10v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     
                        <msItem xml:id="p1_i2">
                           <locus from="10v">Fols 10v and following</locus>
                           <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
                           <textLang mainLang="gez"/>
                        </msItem>
                    
                  </msContents>
                     
                  <physDesc>
                     <objectDesc form="Codex">
                        <supportDesc>
                           <support>
                              <material key="parchment"/>
                           </support>
                           <extent>
                              <measure unit="leaf">18</measure>
                              <measure unit="leaf" type="blank">3</measure>
                              <locus target="#1 #2 #18">Fols. 1, 2, 18</locus>
                           </extent>
                           <collation>
                              <note>The three parts of this manuscript were originally independent and have been bound
                           together.</note>
                           </collation>
                        </supportDesc>
                        <layoutDesc>
                           <layout columns="1" writtenLines="13">
                              <locus from="3" to="17">Fols 3–17</locus>
                           </layout>
                        </layoutDesc>
                     </objectDesc>
                  
                     <handDesc>
                        <handNote xml:id="h1" script="Ethiopic">
                           <date notBefore="1700" notAfter="1799" evidence="conjecture"/>
                           <seg type="script">Written in a good hand.</seg>
                        </handNote>
                     
                        <handNote xml:id="h2" script="Ethiopic" corresp="https://betamasaheft.eu/BDLaethg16#a1">
                           <locus from="15r" to="17">Fols 15r–17</locus>
                           <date notBefore="1700" notAfter="1799" evidence="conjecture"/>
                        </handNote>
                     </handDesc>
                  
                     <additions>
                        <list>
                           <item xml:id="a1">
                              <locus from="15r" to="17">Fols 15r–17</locus>
                              <desc type="GuestText">                               
                                 <title type="complete" ref="https://betamasaheft.eu/LIT4519Prayer">Prayer</title>. The prayer was added on 
                              leaves originally left blank. It is largely illegible,
                              most of it seems a mere scribble. The following is the incipit:
                              <q xml:lang="gez">
                                    <gap reason="illegible" extent="unknown" resp="PRS9622Ullendor"/>
                                    በስመ፡ አብ፡ ኤፌሶን፡ ወወልድ፡ ኢፌሶን፡ 
                                    ወመንፈስ፡ ቅዱስ፡ ኤፌሶን፡</q>
                              </desc>
                           </item>
                        
                           <item xml:id="e1">
                              <locus target="#10v">Fol. 10v</locus>
                              <desc>The owner was <persName role="owner" ref="https://betamasaheft.eu/PRS11458WaldaM">Walda Māryām</persName>.</desc>
                           </item>
                        </list>
                     </additions>
                  </physDesc>
                  
                  <history>
                     <origin>
                        <origDate notBefore="1700" notAfter="1799" cert="low" evidence="lettering"/>
                     </origin>
                     <provenance>
                     The manuscript was purchased by the <placeName ref="https://betamasaheft.eu/INS0312BDL">Bodleian Library</placeName> in <date>1930</date>.
                  </provenance>
                  </history>
               </msPart>
               
               <msPart xml:id="p2">
                  <msIdentifier>
                  </msIdentifier>
                  
                  <msContents>
                     <summary/>
                     
                     <msItem xml:id="p2_i1">
                        <locus from="19r" to="38r">Fols 19r–38r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡
                         <supplied reason="undefined" resp="PRS9622Ullendor">ዘ</supplied>ኢይሂሱ፡</incipit>
                     </msItem>
                  </msContents>
                  
                  <physDesc>
                     <objectDesc form="Leaf">
                        <supportDesc>
                           <support>
                              <material key="parchment"/>
                           </support>
                           <extent>
                              <measure unit="leaf">20</measure>
                              <locus from="19" to="38">Fols 19–38</locus>
                              <measure unit="folio" type="blank">1</measure>
                              <locus target="#38v">Fol. 38v</locus>
                           </extent>
                           <collation>
                              <note>Text and quires run continuously.</note>
                           </collation>
                           
                        </supportDesc>
                        <layoutDesc>
                           <layout columns="1" writtenLines="14">
                              <locus from="19" to="38">Fols 19–38</locus>
                           </layout>
                        </layoutDesc>
                     </objectDesc>
                     
                     <handDesc>
                        <handNote xml:id="h3" script="Ethiopic">
                           <seg type="script">Written in a mediocre hand.</seg>
                        </handNote>
                     </handDesc>
                     
                     <additions>
                        <list>
                           <item xml:id="e2">
                              <locus target="#38v">Fol. 38v</locus>
                              <desc>The owner was <persName role="owner" ref="https://betamasaheft.eu/PRS11457HabtaM">Habta Māryām</persName>.</desc>
                           </item>
                        </list>
                     </additions>
                  </physDesc>
               </msPart>
               
               <msPart xml:id="p3">
                  <msIdentifier>
                  </msIdentifier>
                  
                  <msContents>
                     <summary/>
                     
                     <msItem xml:id="p3_i1">
                        <locus from="40r">Fols 40r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተ<supplied resp="PRS9622Ullendor" reason="undefined">ሳተ</supplied>ፈ፡</incipit>
                        <note>Large portions of this hymn have been rendered illegible by damp.</note>
                     </msItem>
                     
                     <msItem xml:id="p3_i2">
                        <locus from="55v">Fols 55v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa Gabrǝʾel</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በሰላመ፡ ገብርኤል፡ 
                           <supplied reason="undefined" resp="PRS9622Ullendor">መልአክ፡</supplied> በላዕለ፡
                           ማርያም፡ <supplied reason="undefined" resp="PRS9622Ullendor">ዘአዕ</supplied>ረፈ፡</incipit>
                        <note>The condition of this hymn is worse than that of <ref target="#p3_i1"/>, 
                        and very little can actually be read.</note>
                     </msItem>
                  </msContents>
                  
                  <physDesc>
                     <objectDesc form="Leaf">
                        <supportDesc>
                           <support>
                              <material key="parchment"/>
                           </support>
                           <extent>
                              <measure unit="leaf">26</measure>
                              <locus from="39" to="64">Fols 39–64</locus>
                              <measure unit="leaf" type="blank">1</measure>
                              <locus target="#39">Fol. 39</locus>
                           </extent>
                           <collation>  
                              <note>Text and quires run continuously.</note>
                           </collation>
                        </supportDesc>
                        <layoutDesc>
                           <layout columns="1" writtenLines="12"/>
                        </layoutDesc>
                     </objectDesc>
                     
                     <handDesc>
                        <handNote xml:id="h4" script="Ethiopic">
                           <seg type="script">Written in a very poor hand.</seg>
                        </handNote>
                     </handDesc>
                  </physDesc>
               </msPart>
                  
            </msDesc>

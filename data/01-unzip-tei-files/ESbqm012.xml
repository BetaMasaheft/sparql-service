                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre</seg>
                        <seg type="ink">Black; red.</seg> The handwriting is similar to that of
                           <persName role="scribe" ref="https://betamasaheft.eu/PRS12076ZawaldaMaryam">Zawalda
                           Māryām</persName> (s. UM-024 and other Mss.).<date>Second half of the
                           17th - first half of the 18th century (?)</date>
                        <seg type="rubrication">Divine names; incipits of the texts; elements of the
                           punctuation signs; original names of the owners (or donors).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">The monthly readings are indicated by the names of
                              the months crudely written in different hands in the upper margin:
                              ዘጥር: <locus target="#6v">fol. 6v</locus>. ዘግንቦት: <locus target="#14v">fol. 14v</locus>. ዘየካቲት: <locus target="#20r">fol. 20r</locus>.
                              ዘመጋቢት: <locus target="#25v">fol. 25v</locus>. ዘኅዳር: <locus target="#38v">fol. 38v</locus>. ዘኅዳር: <locus target="#41v">fol.
                                 41v</locus>.</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>Writing exercises in pencil and pen (blue ink) are distributed through the whole Ms. </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>Crude drawing (?) in pencil: <locus target="#1v">fol.  1v</locus>. 
                           </desc>
                        </item>
                        <item xml:id="e4">
                           <desc>Vertical lines are crudely drawn in blue pen ink between the two columns: fols. 7v, 20v, 21v, 22r, 35v, 38v, 59v, 64v.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="partly">
                        <decoNote xml:id="b1">Two wooden boards (the front cover is missing, the
                           back board is broken and repaired by means of metal wire and
                           strings).
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible in the centre
                           fold of the quires, one close to the head, one close to the tail of the
                           codex.</decoNote>
                        <decoNote xml:id="b5">None.</decoNote>
                     </binding>
                  </bindingDesc>

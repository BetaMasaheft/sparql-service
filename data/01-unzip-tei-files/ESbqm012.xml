               <msContents>
                  <summary>I) Gadla Giyorgis “Vita of George” (fols. 3r-38vb)
 II) Taʾammǝra
                     Giyorgis “Miracles of George”: 11 miracles (fols. 38vb-73vb), the 11th miracle
                     is incomplete.</summary>
                  <msItem xml:id="ms_i1">
                     <title ref="https://betamasaheft.eu/LIT6172DossierGeorge">Hagiographic Dossier of St George of Lydda</title>
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="3r" to="38vb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1455GadlaG">Gadla Giyorgis (Lydda)</title>
                        <textLang mainLang="gez"/>
                        
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        
                        <locus from="38vb" to="73vb"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT4006Taamme">The miracles of St George, 11 in number</title>
                        <textLang mainLang="gez"/>
                        <note>The 11th miracle is incomplete.</note>
                     </msItem>
                     
                     
                     
                     
                  </msItem>
                  
               </msContents>

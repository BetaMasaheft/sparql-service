                     <summary/>
                     <msItem xml:id="p1_i1">
                        <locus from="1ra" to="75va" corresp="#fol1">Fols 1ra–75va, </locus>
                        <locus from="1ra" to="75va" corresp="#fol2">1ra–75va</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3951ChronSusenyos">ንጽሕፍ፡ ዜናሁ፡ ለንጉሥ፡ ኃያል፡ መዋኢ፡ 
                           <persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                              <roleName type="title">ንጉሠ፡ ነገሥት፡ </roleName> ሱስንዮስ፡</persName> 
                           ዘልቡ፡ ውስተ፡ የማኑ፡ ወአዕይንቲሁ፡ ዲበ፡ ርእሱ፡ መፍቀሬ፡ ጥበብ፡ ወፈታሔ፡ ርትዕ። ወጸላኤ፡ ዓመፃ፡ ወርሑቅ፡ እምእከይ።
                           ወስፉሐ፡ እድ፡ በውሂብ፡ ወተወካሊ፡ ላዕለ፡ እግዚአብሔር፡ ክቡር፡ ወልዑል፡</title>
                        <textLang mainLang="gez"/> 
                        <note>The title is stated after a long preface.</note>
                        <note>Many parts, up to entire columns, are erased and sometimes rewritten.</note>
                     </msItem>

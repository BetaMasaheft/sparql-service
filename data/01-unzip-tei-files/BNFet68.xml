               <msContents>
                  <summary/> 
         
                  <msItem xml:id="ms_i1">
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1716Kidanz">
                        <locus target="#4v">Fol. 4v</locus>
                  ኪዳን፡ ዘነግህ፡ ዘእግዚእነ፡ ወአምላክነ፡ ወመድኀኒነ፡
                ኢየሱስ፡ ክርስቶስ። ዘመሀሮሙ፡ ለ፲ወ፪፡ ሐዋርያቲሁ፡ እምድኅረ፡ ተንሥአ፡ እሙታን።</title> 
                     <textLang mainLang="gez"/>
                     <note>The prayers are preceded by a special prayer.</note>
                  </msItem>
                
                  <msItem xml:id="ms_i2">
                     <locus from="10r">Fols 10r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta
                                                  ḫǝbuʾāt</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በእንተ፡ ትምህርተ፡ ኅቡአት፡ ቅድመ፡ ዘትትነገር፡ 
                    እምጵርስፎራ፡ ለምእመናን፡ ኅቡአት፡ ትምህርተ፡ ኅቡአትሰ፡ ከመዝ፡ ንግር፡</incipit>
                  </msItem>
                
                  <msItem xml:id="ms_i3">
                     <locus from="14v">Fols 14v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer
                                                  za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡ እግዚአብሔር፡ ዘሥልጣናት፡ እግዚአብሔር፡
                    ዘአርእስተ፡ መላእክት፡ ዘእምታሕተ፡
                  እኂዞትከ፡ ኵሉ፡ ፍትረት፡</incipit>
                  </msItem>
                
                  <msItem xml:id="ms_i4">
                     <title type="complete" ref="https://betamasaheft.eu/LIT1190Baenta">Baʾǝnta
                                                  qǝddǝsāt</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በእንተ፡ ቅድሳት፡ ሰላማዊት፡ ሰላመ፡ ናስተበቍዕ፡ ከመ፡
                እግዚአብሔር፡ የሀበነ፡ በሣህለ፡ ዚአሁ።</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i5">
                     <title type="complete" ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat
                                                  za-wald</title> 
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ፍትሐት፡ ዘወልድ። እግዚኦ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ አብ፡
              ዘበተከ፡ እምኔነ፡ ኵሎ፡ ማዕሠረ፡ ኀጣውኢነ፡</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i6">
                     <locus from="22r">Fols 22r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-ʾǝgziʾǝna ʾIyasus Krǝstos</title>
                     <textLang mainLang="gez"/>
            
                     <msItem xml:id="ms_i6.1">
                        <locus from="22r">Fols 22r and following</locus>
                        <title type="complete"/>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">መጽሐፈ፡ ኪዳን፡ ዘመሀሮሙ፡ እግዚእነ፡ ለሐዋርያቲሁ፡ እምቅድመ፡ ዕርገቱ፡
                ድኅረ፡ ትንሣኤሁ፡ እሙታን፡</incipit>
                        
                     </msItem>
            
                     <msItem xml:id="ms_i6.2">
                        <locus from="22r">Fols 22r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1100Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-ʾǝgziʾǝna ʾIyasus Krǝstos</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዚእነ፡</incipit>
                     </msItem>
                  </msItem>
                    
                  <msItem xml:id="ms_i7">
                     <locus from="27v">Fols 27v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘቅዱስ፡ ህርያቆስ፡ ዘሀገረ፡ ብህንሳ፡ ዘደረሰ፡ ላቲ፡ 
                ለእግዝእትነ፡ ማርያም፡</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i8">
                     <locus from="40v">Fols 40v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1103Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-darasu 318 rǝtuʿāna hāymānot</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘደረሱ፡ ፫፻፲ወ፰፡ ርቱዓነ፡ ሃይማኖት፡ ኅቡረ፡ በ፩ቃል፡</incipit>
                  </msItem>
    
                  <msItem xml:id="ms_i9">
                     <locus from="52r">Fols 52r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1915Mashaf">Maṣḥafa
                                                  ʾardǝʾt</title>
                     <textLang mainLang="gez"/>
                  </msItem>
            
                  <msItem xml:id="ms_i10">
                     <locus from="64v">Fols 64v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4663Eqabanni">ʿƎqabanni (longer
                                                  version)</title>
                     <textLang mainLang="gez"/>
              
                     <msItem xml:id="ms_i10.1">
                        <locus from="64v" to="70r">Fols 64v–70r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4663Eqabanni#Eqabanni">ʿƎqabanni
                                                  (including the story of a Frank nobleman),
                                                  ʿƎqabanni prayer</title>
                        <textLang mainLang="gez"/>
                        <note>The invocations begin with <foreign xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡</foreign>.</note>
                        <listBibl type="text">
                           <bibl corresp="http://zotero.org/groups/358366/items/6WVXST3F"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1935Eqabani"/><title level="a">La prière ʿEqabani ou les litanies du Christ</title><title level="j">Orientalia</title><author><forename>Sylvain</forename><surname>Grébaut</surname></author><date>1935</date><biblScope unit="volume">Nova Series, 4</biblScope><biblScope unit="page">426-440</biblScope><note type="tags"><note type="tag">bm:Grebaut1935Eqabani</note></note><note type="tag">bm:Grebaut1935Eqabani</note></bibl>
                        </listBibl>
                     </msItem>
            
                     <msItem xml:id="ms_i10.2">
                        <locus from="70v">Fols 70v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4663Eqabanni#Franks">ʿƎqabanni
                                                  (including the story of a Frank nobleman), Story
                                                  of the Frank nobleman who received the prayer from
                                                  heaven</title>
                        <textLang mainLang="gez"/>
                        <note>
                           <p>The beginning of this prayer states that angels brought it to a European prince. </p>
                           <p>It was translated to Gǝʿǝz by a certain <persName ref="https://betamasaheft.eu/PRS11071GabraK">Gabra Krǝstos</persName>.</p>
                        </note>
                        
                     </msItem>
                  </msItem>
            
                  <msItem xml:id="ms_i11">
                     <locus from="74r">Fols 74r and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2246salotz">Ṣalot za-ʾǝgzǝʾǝtǝna
                                                  Māryām ba-Dabra Golgotā</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                ዛቲ፡ ጸሎት፡ ዘእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                ዘጸለየት፡ አመ፡ ፳ወ፬፡ ለወርኀ፡ ስኔ፡
              በደብረ፡ ጎልጎታ፡ ዘውእቱ፡ መቃብረ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ እንዘ፡ ትብል፡ እግዚእየ፡ ወአምላኪየ፡ ወልድየ፡
              ወንጉሥየ፡ ኢየሱስ፡ ክርስቶስ። ዘተወለድከ፡ እምኔየ፡ በፈቃድከ፡ ወጠበውከ፡ ሐሊበ፡ እምአጥባትየ።
              እንዘ፡ ሰማይኒ፡ ኢያገምረከ፡ ወአጽናፈ፡ ዓለም፡ ኢየአክለከ፡ ወምድርኒ፡ ኢትክል፡ ጸዊሮተከ።</incipit>
                  </msItem>
            
                  <msItem xml:id="ms_i12">
                     <locus from="87v">Fols 87v and following</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                     <textLang mainLang="gez"/>
                  </msItem>
            

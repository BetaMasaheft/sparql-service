                        <item xml:id="a1">
                           <desc type="GuestText"/>
                           <locus target="#1a"/>
                           <desc>Names of the tribes of Israel and the Apostles descending from each of them.</desc>
                           
                          </item>
                        
                        <item xml:id="a2">
                           <locus target="#1a"/>
                           <q xml:lang="gez">
                              <lb n="1"/>ምእራፍ፡ ዘአርባዕቱ፡ ወንጌላውያን፡ ዘማቴዎስ፡ ፷ወ፰፡ ምእራፍ፡
                              <lb n="2"/>
                              <del rend="erasure"/> ዘማርቆስ፡ ፵ወ፰፡ ምእራፍ። ዘሉቃስ፡ ፹ወ፫፡ ምዕራፍ።
                              <lb n="3"/>ዘዮሐንስ፡ ፲ወ፱ምዕራፍ። 
                                 <sic>ወሰበ፡</sic>
                               ትዴምር፡ ኵሎ፡ ፪፻ወ፲ወ፰ምዕራፍ፡ ቃል፡ ዘማቴ
                              <lb n="4"/>ዎስ። ፪፼ወ፮። ቃል፡ ዘ<add place="inline">
                                 <supplied reason="omitted">ማ</supplied>
                              </add>ርቆስ፡ ፼ወ፯፻፡ ቃል፡ ዘሉቃስ፡ ፪፼ወ፰፻። <supplied reason="explanation">ቃል፡ ዘዮሐንስ፡ ፼</supplied>፪፻ወ፮። 
                              ወ<supplied reason="omitted">ሶ</supplied>በ፡ ትዴምር፡ ፱፼፡ ወ፫፻፡ <add place="inline">
                                 <supplied reason="omitted">፲ወ፬</supplied>
                              </add> ይ<add place="inline">
                                 <supplied reason="omitted">ከ</supplied>
                              </add>ውን፡ ለከ። ማቴዎስ፡ ሰበከ፡ እምድህረ፡ ስቅለቱ፡ ለክርስቶስ፡ በ፱ዓ
                              <lb n="5"/>መት። ማርቆስ፡ ሰበከ፡ በ፲ወ፪ዓመት፡ ሉቃስ፡ ሰበከ፡ በ፳ወ፪ዓመት። ዮሐንስ፡ ሰበከ፡ በ፴ዓመት፡ ከመዝ፡ ውእቱ፡ <supplied reason="omitted">ብ</supplied>ስራቶሙ፡ ይብጽሀነ፡ በረከቶሙ፡ አሜን።
                           </q>
                        </item>
                        
                        <item xml:id="a3">
                           <locus target="#IV"/>
                           
                           <q xml:lang="la">Tempora Pauli Farnesii III<del rend="erasure">I</del>
                           </q>
                           <note>The note refers to <persName ref="https://betamasaheft.eu/PRS7750PaulIII">Pope Paul III</persName>, born Alessandro Farnese and in charge from <date>1534</date> to <date>1549</date>.</note>
                        </item>

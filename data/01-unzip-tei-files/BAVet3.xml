               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <title type="complete" ref="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</title>
                     <note>Same exemplar of <bibl corresp="http://zotero.org/groups/358366/items/8UWD3FCM"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Petrus1548Test"/><title level="m">Testamentum Novum: Cum Epistola Pauli Ad Hebreos tantum, cum concordantijs Evangelistarum Eusebii &amp; numeratione omnium verborum eorundem. Missale cum benedictione incensi cerae et c. Alphabetum in lingua ግእዝ፡ gheez, idest libera quia a nulla alia originem duxit, &amp; vulgo dicitur Chaldea, Quae omnia Fr. Petrus Ethyops auxilio piorum sedente Paulo. III. Pont. MAx. &amp; Claudio illius regni Imperatore imprimi curavit</title><author><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Petrus Ethyops</t:name></author><pubPlace>Romae</pubPlace><publisher>Impensis Petri Comos Ethiopis, Valerius Doricus</publisher><date>1548</date><note type="url">https://books.google.de/books?id=KPNa9Mc5gjYC</note></bibl>. The image of David at the beginning, the preface and the <ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref> are missing.</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <note>Same exemplar of <bibl corresp="http://zotero.org/groups/358366/items/RMEHMDFJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Potken1513Psalterium"/><title level="m">Psalterium David et cantica aliqua</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Johannes</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Potken</t:surname></author><pubPlace>Romae</pubPlace><publisher>Marcellus Silber</publisher><date>1513</date><note type="url">http://www.kingscollections.org/exhibitions/specialcollections/psalter1513/</note></bibl>. The image of David at the beginning, the preface and the <ref type="work" corresp="https://betamasaheft.eu/LIT2362Songof">Song of Songs</ref> are missing.</note>
                     <msItem xml:id="ms_i2.1">
                        <title ref="https://betamasaheft.eu/LIT4009Naahab">Prayer to David</title>
                        <incipit xml:lang="gez">
                           <lb n="1"/>ነዐ፡ ኀቤየ፡ ወዳዊት፡ ንጉሥ፡
                           <lb n="2"/>
                    
                              <sic>በዕለ፡</sic>
                            መዝሙር፡ ሠናይ፡ ቁም፡ ምስሌየ፡ በዛ
                           <lb n="3"/>ቲ፡ ሰዐት፡ አጠይቀኒ፡ ኀይለ፡ ቃል፡ ዘእነብብ።
                        </incipit>
                        <explicit xml:lang="gez">
                           <lb n="1"/>አብርህ፡ ልብየ፡
                           <lb n="2"/>ወአንቅህ፡ ሕሊናየ፡ ከመ፡ እግነይ፡ ሎቱ፡
                           <lb n="3"/>ለልዑል። እጸርሕ፡ እንዘ፡ <choice>
                              <sic>አዐብል፡</sic>
                              <corr resp="bm:GrebTiss1935Codices">እብል፡</corr>
                           </choice> ሃሌሉያ።
                        </explicit>
                     </msItem>
                  </msItem>
               </msContents>
          

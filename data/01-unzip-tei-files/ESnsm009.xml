                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>Second half of the 19th century.</date>
                        <list type="abbreviations">
                           <item>ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipits of Text I and its
                           subsections; a few lines are rubricated (alternating with black lines) on
                           the incipit page of Text I (fol.3r); titles of the books to be read;
                           incipit of the prayers to be read; numbers of the prayers; directives to
                           the ministers and their abbreviation (fol. 6v); elements of Ethiopic
                           numerals; elements of the punctuation signs.</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#34v">ff. 34v-35</locus>
                           <desc>r: Excommunication against those who read the book in transgressing
                              the faith.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> Written in a crude hand. </note>
                        </item>
                        <item xml:id="e1">- Crude recent ownership note mentioning the church of
                           Mikaʾ Nǝhǝb: <locus target="#35r">35r</locus>.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">- Notes referring to the books to be read are
                              written in the margin, in a crude hand: ወንገል፡ ዘዮሐንስ : <locus target="#6v">fol. 6v</locus>. ቅድመ፡ ወንገል: <locus target="#20r">fol.
                                 20r</locus>. ወንገል: <locus target="#20v">fol.
                           20v</locus>.</desc>
                        </item>
                     </list>
                  </additions>

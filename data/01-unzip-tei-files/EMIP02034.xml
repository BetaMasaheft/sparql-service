                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="70v" facs="005">Fols 1r–70v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                     <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ናሁ፡ ጸሐፍነ፡ ድጓ፡ ዘውእቱ፡ መሥዋዕቱ፡ ለእግዚአብሔር፡ ምድር፡ በምልዓ፡ ወእግዚአብሔር፡ ነግሠ፡ ወይትባረክ፡ ዓርያም፡ መዝሙር፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="71r" to="96v" facs="075">Fols 71r–96v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3186Meeraf">Mǝʿrāf</title>
                     <incipit xml:lang="gez">ምዕራፍ፡ ዘጌና፡ እምዮሐንስ፡ ቅዱስ፡ እግዚአብሔር፡ ቅዱስ፡ ኃያል፡ ቅዱስ፡ ሕያው፡ ዘኢይመውት፡ ዘተወልደ፡ እማርያም፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="96v" to="99r" facs="101">Fols 96v–99r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2610Zemmar">Zǝmmāre</title>
                     <incipit xml:lang="gez">: ዝማሬ፡ እምዮሐንስ፡ እስከ፡ ዮሐንስ፡ ግዕዝ፡ ሖረ፡ ኢየሱስ፡ እምገሊላ፡ ኀበ፡ ዮሐንስ፡ ከመ፡ ያጥምቆ፡ በፈለገ፡ ዮርዳኖስ፡ <gap reason="omitted"/>
                     </incipit>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="99v" to="100r" facs="104">Fols 99v–100r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3178Deggwa#Haleta">Dǝggʷā, Table of
                                                  melodic variations for the Hallelujah (same as
                                                  https://betamasaheft.eu/LIT1110Anqasa)</title>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="100v" to="102r" facs="105">Fols 100v–102r</locus>
                     <title>Supplementary Hymns for the Dǝggwa, <foreign xml:lang="gez">ድጓ፡</foreign></title>
                     <notatedMusic><desc>some with musical notation</desc></notatedMusic>
                  </msItem>

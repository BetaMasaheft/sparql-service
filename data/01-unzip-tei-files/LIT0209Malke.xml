      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">እዌጥን፡ አንሰ፡ ለሥነ፡ ገድልከ፡ ዕበያ፨</l>
                  <l n="2">ሰስብሐት፡ ወሃሌ፡ ሉያ፨</l>
                  <l n="3">ኪሮስ፡ ክቡር፡ ወልደ፡ ንጉሠ፡ ሮም፡ አብያ፨</l>
                  <l n="4">ብትክ፡ እምኅሊናየ፡ ዕብነ፡ ዝንጋዔ፡ ጕዕትያ፨</l>
                  <l n="5">ወእምከርሥየ፡ ለምንሱት፡ እከያ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምቅድመ፡ ዓለማት፡ ጽሑፍ፨</l>
                  <l n="2">ውስተ፡ ዐምደ፡ ወርቅ፡ ዘላዕሉ፡ በእደ፡ ኅሊናሁ፡ ለአሌፍ፨</l>
                  <l n="3">ወለሥዕርትከ፡ ጽፉቅ፡ ቅብዐ፡ መንፈስ፡ ቅዱስ፡ ሱቱፍ፨</l>
                  <l n="4">ዘነበርከ፡ ኪሮስ፡ ለለ፡ አሚሩ፡ እንዘ፡ ትሰግድ፡ በበ፡ አእላፍ፨</l>
                  <l n="5">እምአባለ፡ ሥጋከ፡ ከመ፡ ማይ፡ እስከ፡ ውሕዘ፡ ሐፍ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ስብሐት፡ ይደሉ፡ ለማርያም፡ ዘወሀበተከ፡ ልቡና፨</l>
                  <l n="2">ለዛቲ፡ ዓለም፡ ከመ፡ ትመንና፨</l>
                  <l n="3">ለእግዚአብሔር፡ ስብሐት፡ ዘጸገወከ፡ ክብረ፡ ልዕልና፨</l>
                  <l n="4">ኪሮስ፡ እግዚእየ፡ እንዘ፡ ትናዝዝ፡ ኀዘና፨</l>
                  <l n="5">ቃውመ፡ ወፀወነ፡ ለነፍስየ፡ ኩና፨</l>
               </lg>
            </div>
         </div>

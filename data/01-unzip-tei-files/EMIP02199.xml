                  <additions>
                  <list>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#ir(ecto) #iiv(erso)" facs="001 003">Fols. ir(ecto), iiv(erso)</locus>
                    Prayer of supplication, incomplete, written in pen by an untrained hand
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#iir(ecto #iiv(erso)" facs="002 003">Fols. iir(ecto, iiv(erso)</locus>
                    Prayer to Jesus Christ, incomplete at the beginning
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="OwnershipNote">
                    <locus target="#1r" facs="003"> f. 1r and passim</locus>
                    mention the owner Gäbrä Ḥäna (<foreign xml:lang="gez">ገብረ፡ ሐና፡</foreign>) and the scribe Gäbrä Maryam (<foreign xml:lang="gez">ገብረ፡ ማርያም፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#27r" facs="029">Fol. 27r</locus>
                    owner’s name has been erased
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                      words of text are written interlinearly (<locus target="#8r #12v #13r #14v #15v" facs="010 015 017 018">folss. 8r, 12v, 13r, 14v, 15v, </locus>, etc.);
                      erasure markings are visible (<locus target="#3r #8r #27r #40v #43v" facs="005 010 029 043 046">3r, 8r, 27r, 40v, 43v, </locus>, etc.);
                      text has been removed (<locus target="#25v #27r" facs="028 029">25v, 27r</locus>)
                    </desc>
                    </item>
                  </list>
                </additions>

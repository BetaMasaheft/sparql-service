                  <decoDesc>
                  <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s. This miniature is painted over text</desc></decoNote>
                  <decoNote type="miniature" xml:id="d2"><locus target="#62v" facs="065">Fol. 62v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref> with an <term key="angel" ana="#angel"/> behind him</desc></decoNote>

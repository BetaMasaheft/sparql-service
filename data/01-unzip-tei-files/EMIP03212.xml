                  <msItem xml:id="ms_i1"><locus from="5r" to="145r" facs="005">Fols 5r–145r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1"><locus from="5r" to="111v" facs="005">Fols 5r–111v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                  <note><locus target="#90v" facs="091">Fol. 90v</locus><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> employ only the technique to offer the transliterated Hebrew letter in red ink</note>
                  <note><locus target="#111v" facs="112">Fol. 111v</locus> <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has all four of the plusses that make up the long version</note>
                </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="112r" to="123v" facs="112">Fols 112r–123v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>

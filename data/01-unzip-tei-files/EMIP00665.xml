               <msContents>
                  <summary>Antiphonary for the Fast of Lent, ጾመ፡ ድጓ፡, with musical notation</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="2r" facs="005">Fols 1r–2r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT3178Deggwa">Dǝggʷā</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <note>Excerpt from hymns for the feast of John the Baptist</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="3r" to="96r" facs="007">Fols 3r–96r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2361somade">Ṣoma dǝggʷā</title>
                    <incipit xml:lang="gez">በማኅትወ፡ ጾም፡ ድራር፡ በ፪ ዘወረደ፡ እምላዕሉ፡ አይሁድ፡ ሰቀሉ፡ ወሚመ፡ ኢያእመሩ፡ እግዚእ፡ ኵሉ፡ ዘየሐዩ፡ በቃሉ፡ <gap reason="omitted"/></incipit>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>

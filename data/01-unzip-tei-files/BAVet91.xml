                  <msItem xml:id="ms_i4">
                     <locus from="120" to="121"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4632Hymn">Hymn to Jesus Christ and the Holy Trinity</title>
                     <incipit xml:lang="gez">
                        ቅዱስ፡ እግዚአብሔር፡ ቅዱስ፡ ኃያል፡ ቅዱስ፡ ሕያው፡ ዘኢይመውት፡ ዘተወልደ፡ እማርያም፡ እምቅድስት፡ ድንግል፡ ተሣሃለነ፡ እግዚኦ፨
                     </incipit>
                     <explicit xml:lang="gez">
                        ወተወከፍ፡ ስእለተነ፡ ኀቤከ፨ እስመ፡ ለከ፡ ስብሐት፡ ወቅዳስያት፨ ኦእግዚኦ፡ መሐረነ፨ ኦእግዚኦ፡ መሐረነ፨ ኦእግዚኦ፡ 
                           <sic>ባርክነ፨</sic>
                         ወትብል፡ አቡነ፡ ዘበሰማያት፨ ይትቀደስ፡ ስምከ፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i5">
                     <locus from="121" to="122"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3994Hymn">Hymn to God</title>
                     <incipit xml:lang="gez">
                        ሃሌ፡ ሃሌ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሃሌ፡ ሉያ። አአትብ፡ ወእትነሣእ፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨ ፫አስማተ፡ ነሢእየ፡ እትመረጐዝ፨ እመኒ፡ ወደቁ፡ እትነሣእ፡ ወእመኒ፡ ሖርኩ፡ ውስተ፡ ጽልመት፨ 
                        እግዚአብሔር፡ ያበርህ፡ ሊተ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ስ<supplied reason="explanation">ብሐት</supplied>፤ <supplied reason="explanation">ለ</supplied>አ<supplied reason="explanation">ብ</supplied>፤ 
                        ወ<supplied reason="explanation">ወልድ</supplied>፤ ወመ<supplied reason="explanation">ንፈስ፡ ቅዱስ</supplied>፤ 
                        ሃ<supplied reason="explanation">ሌ፡ ሉያ፡</supplied>፤ በቅድስት፡ ቤተ፡ ክርስቲያን፨ ለዓለም፡ ወለዓለመ፡ ዓለም፡ ሃ<supplied reason="explanation">ሌ፡ ሉያ</supplied>፤ 
                        ለትውልደ፡ ትውልደ፡ ትውልድ፡ ሎቱ፡ ይደሉ፡ ሰጊድ፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus from="122r" to="122v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT4631Praise">Praise to Our Lady Mary</title>
                     <incipit xml:lang="gez">
                        እዌድሰኪ፡ ኦድንግል፡ ምልዕተ፡ ውዳሴ፡ መጠነ፡ ይክል፡ አፉየ፡ አስተበፅዕ፡ ዕበየኪ፨ ልሳነ፡ ኪሩቤል፡ ኢይክል፡ አብጽሖ፡ ውዳሴኪ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ተ<supplied reason="explanation">ዘከር</supplied>፤ እ<supplied reason="explanation">ግዚኦ</supplied>፤ ቅንዓተ፡ ሙሴ፡ ገብርከ፤ ዘተቃሐዎሙ፡ ለግብጽ፡ 
                        በመንክራቲከ፤ ወረከበ፡ ሞገሰ፡ በቅድመ፡ ገጽከ፤ ወተ
                     </explicit>
                     <note>The text is incomplete due to material loss.</note>
                  </msItem>

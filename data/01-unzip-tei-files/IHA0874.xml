               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="4v">1r-4v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2294IHA">خطبة الهجرة واستقبال العام</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ألحمد لله الذي شرع الهجرة والجهاد لحماية الدين \ ودرء الفساد ومن الناس من يشري نفسه إبتغاء مر \ ضاة الله</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4v">-4v</locus>يغفر لكم \ ذنوبكم ويدخلكم جنّات تجرى من تحتها الأنهار ومساكن \ طيّبة في جنّات عدن ذلك الفوز العظيم وأخرى تحبّونها \ نصر من الله وفتح قريب وبشّر المؤمنين بارك الله لي ولكم [...] والبرّ الكريم   </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="8r">5r-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2295IHA">خطبة ظلم العباد وشهادة الزور</title>
                     <incipit xml:lang="ar">
                        <locus target="#5r">-5r</locus>ألحمد لله الذي له ملك السماوات والأرض وإليه تصير الأ \ مور له الملك وله الحمد بيده الموت والحياة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>والذين لا يشهدون الزور \ وإذا مرّ باللّغو مرّوا كراما والذين إذا ذكّروا بأيات ربّهم \ لم يخرّوا عليها صمّا وعميانا بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="8v" to="11r">8v-11r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2296IHA">خطبة نداء الشباب</title>
                     <incipit xml:lang="ar">
                        <locus target="#8v">-8v</locus>الحمد لله الذي جعل الشباب حماة الأوطان ونصر بهم \ الشرائع والأديان وأذهر بهم الحقّ في سائر البلدان</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11r">-11r</locus>ليجيزي الله الصادقين بصدقهم ويعذب المنافقين إن \ شاء أو يتوب عليهم إن الله كان غفورا رحيما بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="11v" to="15v">11v-15v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2298IHA">خطبة في الصبر والشجاعة</title>
                     <incipit xml:lang="ar">
                        <locus target="#11v">-11v</locus>ألحمد لله الذي أمر المؤمنين بما أمر به المرسلين وجعل \ الصبر من صفات أهل اليقين وحثّهم عليه في محكم \ الذكر المبين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#15v">-15v</locus>قال الله تعالى إن الله مع الذين \ أتّقوا والذين هم محسنون بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="16r" to="16v">16r-16v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1899IHA">خطبة النعت بارئ الأمم</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>ألحمد لله بارئ الأمم ومول النعم الذي لا ردّ لما حكم ولا مانع لما أعطى \ وقسم المتفرّد فى الوجوده باالقدم ألحكم على الحقّ باالقناء والعدم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16v">-16v</locus>اللهمّ تحنن على ضعفهم كما كانو على ضعفنا محننين ورحم إنقطاعهم إليك كما كانو لنا في حال إنقطاعنا إليهم رحمين وتعطف عليهم كما كانوا علينا في حال متعطفين ربنا أنتا فى الدين حسنة وفى الاخرة حسنة وقنا عذاب النار عباد الله</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትከ፡ መሠረተ፡ ፍሬ፡ ወዘርእ፨</l>
                  <l n="2">ዘተናገርከ፡ ምሥጢረ፡ ዜማ፡ በሥምረተ፡ ክርስቶስ፡ እግዚእ፨</l>
                  <l n="3">ካህን፡ ያሬድ፡ ነገደ፡ ዕሥራ፡ ወርብዕ፨</l>
                  <l n="4">ተባሀሉ፡ በእንቲአከ፡ መላእክት፡ ወሰብእ፨</l>
                  <l n="5">ኢርኢነ፡ ዘከማከ፡ ጸጋሁ፡ ምሉእ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ጥዑመ፡ ዝክር፡ ወስም፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ሰላም፡ ዘሕበሪሁ፡ ጸሊም፨</l>
                  <l n="3">እንጦንስ፡ ያሬድ፡ መፍቀሬ፡ ጸሎት፡ ወጾም፨</l>
                  <l n="4">ተዘኪረከ፡ ፍቅረ፡ ነፍስ፡ እምፍትወተ፡ ዝንቱ፡ ዓለም፨</l>
                  <l n="5">መኒነከ፡ ሖርከ፡ መንገለ፡ ገዳም፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋከ፡ ደብተራ፡ ብርሃን፡ ኀበ፡ ተተክለ፨</l>
                  <l n="2">በእደ፡ መላእክት፡ ኄራን፡ መንገለ፡ ሰማያት፡ ዘተልዕለ፨</l>
                  <l n="3">ቅዱስ፡ ያሬድ፡ ኀበ፡ ተወከፍከ፡ መስቀለ፨</l>
                  <l n="4">ኵሎሙ፡ ሐራ፡ ሰማይ፡ ገብሩ፡ በዓለ፨</l>
                  <l n="5">እምአፈ፡ እንስሳ፡ አርባዕ፡ ሰሚዖሙ፡ ቃለ፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ስብሐት፡ ይደሉ፡ ለማርያም፡ ዘከፈለተኒ፡ ቃላተ፨</l>
                  <l n="2">ለክብረ፡ መልክእከ፡ እንብብ፡ እንበለ፡ እጐንዲ፡ ግብተ፨</l>
                  <l n="3">ካህን፡ ያሬድ፡ አቅረብኩከ፡ ስብሐተ፨</l>
                  <l n="4">አሐዱ፡ እምኔሆሙ፡ እንዘ፡ ያጸንዕ፡ ትስብእተ፨</l>
                  <l n="5">ለዘኮኑ፡ በአካል፡ ወበስም፡ ሠለስተ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">ናሁ፡ አቅረብኩ፡ ለመልክእከ፡ አስትዐ፡ በረከት፡ ወእማኄ፨</l>
                  <l n="2">በልሳንየ፡ ድኩም፡ እንዘ፡ አቄርብ፡ ስባሔ፨</l>
                  <l n="3">ቅዱስ፡ ያሬድ፡ ዘተሰመይከ፡ ዐርከ፡ ኤሎሃ፨</l>
                  <l n="4">ኢይርኀቅ፡ እምኔየ፡ ኀይለ፡ ረድኤትከ፡ ኵለሄ፨</l>
                  <l n="5">እምእደ፡ ሞት፡ ይኩነኒ፡ ባላሔ፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለከ፡ ያሬድ፡ ካህን፡ ነገደ፡ ካህናት፡ ዘራማ፨</l>
                  <l n="2">አቅረብከ፡ ክብረ፡ በሐዋዝ፡ ዜማ፨</l>
                  <l n="3">ለአምላክ፡ ለባሴ፡ ግርማ፨</l>
               </lg>
               <lg type="stanza" n="8">
                  <l n="1">ሰላም፡ ለከ፡ ዕቀበኒ፡ ሊተ፡ ኀበ፡ ሀሎኩ፡ እምዝየ፨</l>
                  <l n="2">እምእደ፡ እኩያን፡ አፅራርየ፨</l>
                  <l n="3">ከመ፡ ኢይጽብእዋ፡ ግብተ፡ ለኃጥእት፡ ነፍስየ፨</l>
                  <l n="4">ዘኢገብረት፡ ምግባረ፡ ሠናየ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
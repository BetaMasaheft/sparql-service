         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ዘክርስቶስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Zakrǝstos</persName>
                  <persName>
                  <roleName type="title">ʾabbā</roleName>
               </persName>
                  <nationality type="Ethiopia"/>
                  <faith type="EOTC"/>
                  <occupation type="ecclesiastic">messianic monk</occupation>
               <residence>
                  <placeName ref="https://betamasaheft.eu/LOC6167Walaqa">Walaqā</placeName>
               </residence>
                  <birth/>
               <floruit notBefore="1602" notAfter="1604">He was an Ethiopian monk who initiated a short-lived messianic movement from <date>1602</date> to <date>1618</date> 
                     in <placeName ref="https://betamasaheft.eu/LOC6167Walaqa">Walaqā</placeName>. He was born to a certain woman called 
                     <persName ref="https://betamasaheft.eu/PRS1825AmataWa">ʾAmata Wangel (Marʿata Wangel)</persName>. He was a monk who proclaimed himself  "Christ". 
                     His seat was located on an ʾambā in <placeName ref="https://betamasaheft.eu/LOC6167Walaqa">Walaqā</placeName>. Finally, found guilty of heresy and executed
                  by the order of  
                  <persName ref="https://betamasaheft.eu/PRS10513Zadenge">
                     <roleName type="title">ʾaṣe</roleName> Zadǝngǝl</persName> in <date>1604</date>. 
                     However, his adherents continued to propagate his teaching which finally was supressed by 
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <roleName type="title">ʾaṣe</roleName> Susǝnyos</persName>.</floruit>
                  <death when="1604"/>
               </person>  
               
         </listPerson>

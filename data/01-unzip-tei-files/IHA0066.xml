               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2v">1r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0107IHA">نظم بسم الحي الباقي نبتدئ</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>بسم الله الرحمن الرحيم بسم الله الرحمن الرحيم \ أَللَّهُمَّ صَلَّى عَلَي زَيْنِ الوُجُودِ \ بِسمِ الْحَيِّ الْبَاقِي نَبْتَدي \ وَبِثَنَائِهِ نَهْتَدِيْ مِنَ غَبَشِ الْعَمَي إِلَيْ نُوْرِ الْشُّهُوْدِ \ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>فَبِهِ نُصِرَ جَيْشُ ذّاكَ (كذا) الْمَقْصُودِ \ أَلنُّورُ الْأَكْمَلُ الْمُمَدُ لِأَرْبَابِ الْسَيْرِ تَجَدَّدْ \ حَتَّيْ غَابَ بِهِمْ فِيْ ذَالِكَ الْمَشْهَدْ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="4r">2v-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0124IHA">نظم قمر عزّ قد بدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>صلى الله علي محمد صلى الله عليه وسلم \ قَمَر عِزٍّ قَدْ بَدَاي حَائِزٍا سَا بِخَ النَّعَمْ \ تَيَاشَر الْكَوْنُ بِهِ مِنْ عُرْبِ أَيْضًا وَالْعَجَمْ \ أَصْلُ الْمَوْجُوْدَاتِ الْبَارِيْ سَبَبُ فِطْرَةِ الْعَالَمْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>صلاة صلت في الحضرا علي النموس المقدم \ وعلي الأل المفضل وأصحابه أالهمام (كذا) \ مَالاَحَ بَرْقُ الْعِنَايَة وَدَارَتُ كُؤْسِ الْكِرَامِ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="22v" to="23r">22v-23r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0146IHA">نظم أنتم زين سرّ الوجود</title>
                     <incipit xml:lang="ar">
                        <locus target="#22v">-22v</locus>زين نبي رين (كذا) نبي زين نبي زين نبي يا حبيب سلام عليكم \ أَنْتُمْ زَيْنِ سِرِّالْوُجُودِ فَيْضِ الرَّحْمَةَ أَصْلُ الْوُجُودِ \ طَاَبِتْ بِكُمْ بِقَاعَ الْأَرْضِ قَدْ أَشْرَقْتُمْ كُلَّ الْوُجُودِ
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23r">-23r</locus>وَأَنْتُمْ نُوْرُ مَلَاذُ الْأُمَّة أُنْظُرُوْنَا بِعَيْنِ الْرَّحْمَةْ \ فَأَظِلَّنِي ظِلَّ الْوِلَايَةْ أُنْظُرِ إِلَيْ نَظْرِ الْعِنَايَةَ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="23r" to="26r">23r-26r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1426IHA">نظم بدأت نظما بمدح الأمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>اَللَّهُمَ صَلِّ عَلَي مُحَمَّدٍ وَسِلَمَ عَلَيْهِ \ اَللَّهُمَ صَلِّ عَلَي مُحَمَّدٍ وَسِلَمَ عَلَيْهِ \ نَبْتَدِأُ نَظْمًا بِمَدْحِ الْأَمِينِ \ أَفْضَلُ الْخَلْقِ سَيْدُ الْمَلِكِيْنِ \ زُبْدَةُ حَوَّيْ صَغْوَةُ أَدَمِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26r">-26r</locus>أَجِرْنَا رَبِّ مِنْ خِلَافِهِ \ ثَبِتْنَا رَبِّيْ عَلَيْ دِيْنِهِ \ أَدَمُ الصَّلَاة عَلَيْهِ دَوْمًا \ أَلٍ وَصَحْبِ دَهْرًا وَعلما \ تمت وبالخير عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="26r" to="30v">26r-30v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0148IHA">نظم بدأت قولي بحمد الكريم</title>
                     <incipit xml:lang="ar">
                        <locus target="#26r">-26r</locus>اللهم صل على محمد اللهم صل على محمد \ نظام الوجود وسلم عليه \ بَدَءْتُ قَوْلِي بِحَمْدِ الْكَرِيْم \ أَنْ وَفَقْنَا لِدِيْنِ الْأِسْلَامِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30v">-30v</locus>تَصْلُ الْأَصْلِ وَصُولُ الْدَّوَامِ \ مَعَ أِلهِ وَصَحْبِ الْكِرَام \ مَاهَامَ الصَّبُّ وَجْدًا بِاالْهِيَامِ \ تمت وبالخير عمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="4r" to="6r">4r-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0125IHA">نظم أبان ما في قلبي ما قد كنت أخفيه</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>صَلَاةُ وَتَسْلِيمٌ وَأَزْكَي تَحِيَّةِ صَلَاةً وَتَسْلِيمٌ \ وَأَزْكَيتَحِيَّة عَلَي الْمُصْطَفَي الْعَادِيْ الْبَرَايَا \ محمد يا رسول الله \ أَبَانَ مَا فِيْ قَلْبِيْ مَا قَدْ كُنْتُ أَخْفِيْهِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>سَلَامٌ مُنِيْرٌ مَقْرُوْنٌ بحيِّهِ \ عَلَي خَيْر مَبْعُوْثٍ بِاَأَفْضَل نُوْرِهِ \ صَلَي عَلَيْهِ رَبِّ مَا دّامَ الْكَوْنُ بِهِ وَسَلَام مَا دَامَ الْمَوَاهِب</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="6r" to="8r">6r-8r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0126IHA">نظم نحمد الله ربّي على جلّ نعمه</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>أَوَيْ سَلَامَ عَلَيْكَ أَوي سلام عليك أوي سلام عليك \ صلوة الله عليك \ نَحْمَدُ اللهِ رَبِّي عَلَي جُلِّ نِعْمِهِ \ بِبَعْثِ رَسُوْلِ اللهِ صَفْوَةِ الْحَضْرَةِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8r">-8r</locus>صَلَاةٌ وَتَسْلِيمُ مَاهَبَّتِ الصَّبَا \ عَلَي خَيْرِ مَبْعُوثٍبِأَفْضَلِ مِلَّةِ \ وَعَلَي الْأَلِ كَذَا وَأَنْوَاجِهِ جَمْعًا \ وَعَلَي أَنْصَارِهِ وَكُلِّ الصَّحَابَةِ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="8r" to="9r">8r-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1722IHA">نظم حمدا لك ربنا خالق الأشياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus>يا مصطفى الأنام يا مصطفى الأنام \ يا مصطفى الأنام عليك السلام \ حَمْدَا لَّلكَ رَبَّنَا يَا خَالِقَ الْأَشْيَاءِ \ أَوْجَدْتَ لَنَا سِرَّ مِنْ دُرَّةِالْبَهَاءِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>وَأَبْدَعُ خَلْقِ اللهِ مُسْتَغْرِقُ الْجَمَالِ \ سَفِينَةُ السَّيَارِي إِلَى بَحْرِ الْأَسْرَارِ \ وَمَحَلُّ الأَنْوَارِ وَمَقَامُ الكَمَالِ \ تم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="9r" to="13r">9r-13r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1104IHA">نظم يا امام الحرام كنز مطلسم</title>
                     <incipit xml:lang="ar">
                        <locus target="#9r">-9r</locus>أَللَّهُمَّ صَلَّى عَلَى مُحَمَّدٍ أَللَّهُمَّ صَلّى عَلَى مُحَمَّدٍ أَللَّهُمَّ صَلّى عَلَى مُحَمَّدٍ \ بإِمَامُ الَحَرَامِ كَنْزٌ مُّطَلْسَمُ \ قَامَ بِبَابِنَا سِرَّا مِنَ الْحُبِّ \ فَأُشكَرَ قَلبَا شَرَابًا مِنْهُمْ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13r">-13r</locus>بِشَرْعِ الَّبِيِّ شَأْنُهُ أَعْظَمُ \ وَعَلَى أَصْحَابِهِ أَوَوَّنَصَرُوْ \ وَلِلْهِدَايَةِ بِهِم أَنْجُمُ \ مَا دَامَ السَّيَّارُ يَنْفَتِحُ لَهُ \ أَسْرَارِ غُيُوبٍ كَانَ مُكَتَّمُ</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="13r" to="16r">13r-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1106IHA">نظم محمد بحر الهداية محمد برق العناية</title>
                     <incipit xml:lang="ar">
                        <locus target="#13r">-13r</locus>مُحَمَّد سَلَامَ علَيكُمْ سيدي سلام علىكم صلاة الله على خير البريا \ مُحَمَّدْ بَحْرُ الْهِدَايَةْ مُحَمَّدْ بَرْقُ الْعِنَايَا \ أَيَا حَادِيَ الْمَطَايَا إِلَيْ أَخيَرِ البَرَايَا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>فإسقني برد الزلال بمدارات السجال \ صلاة الذات العلية على الحضرة السنية \ ومع الأل الولات قدوة قذوة ذوى الخيرات</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="16r" to="18v">16r-18v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0129IHA">نظم جمال بدأ من فوق العزّ</title>
                     <incipit xml:lang="ar">
                        <locus target="#16r">-16r</locus>أوي نبي أوي نبي أوي نبي أوي نبي محمد نبي سلام عليكم \ جَمَالٌ بَدَا مِنْ فَوْقِ الْعِزِّ \ دَلَّ مُحْتَاجًا فَقَالَ هُزِّ \ أَيَّا عَاشِقِينِ هَامُّوْ إليَّ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#18v">-18v</locus>وَكَذَا الْسَلَامِ عَلَيْ مُحَمَّدْ \ وَعَلَيْ الْأَلِ وَكَذَ الْأَصْحَابِ \ مِن أُولِي الْكَرَامِ وَكَذَ الْأَحْبَابِ \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="18v" to="19v">18v-19v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0130IHA">نظم أول نشء الوجود وسر الله الودود</title>
                     <incipit xml:lang="ar">
                        <locus target="#18v">-18v</locus>صلى الله على محمد صلي الله على  محمد محمد علم الهدا محمد \ أَوَّلُ نَشْاءِ الْوُجُود وَسِرَّ اللهِ الْوُدُودِ \ وَسِرُّ اللهِ الْمُطَمْطَمْ أَسِّرِّ السَّارِ الْمُزَمْزَمِ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>صَلَاةُ اللهِ الْشَامِلَةَ وَلِسِرِّهِ حَامِلَةَ \ عَلَيْ أَفْضَلِ الْوُجُودِ مَعْدِنُ الْغَضْلِ وَالْجَوْدِ \ مَعَ صَحْبِهِ وَالْأَلِ وَلِمَنْ لَهُ مَوَالِيْ \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="19v" to="22r">19v-22r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0182IHA">نظم تجلى من أحبه كرامًا</title>
                     <incipit xml:lang="ar">
                        <locus target="#19v">-19v</locus>صلاة الله سلام الله على من محمد هاشمى عرب \ تَحَلَّي مَنْ أُحبهُ كُرَامَا \ فَأَبْدَلِىْ مِنْ سَنَاءعَجِيْبُ \ حُمَيَّاهُ طَابِتْ لَنَا وَرُهْدَ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>وَعَلَيْ الْأَلِ والْأَصْحَابِ طُرَّ \ مَا قَالَ الْحِبُّ هَاشِمِيِّ عَرَبُ \ وعلي الأل والأصحاب طر \ ما قال هاشمي عرب</explicit>
                     <note/>
                     <note/>
                  </msItem>

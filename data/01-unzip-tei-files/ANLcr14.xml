                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="5ra" to="79rb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1291Dersan">Dǝrsān māḥyawi</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ ቅዱስ፡ በስመ፡ ወልድ፡ ቅዱስ፡ በስመ፡ መንፈስ፡ ቅዱስ፡ ፩ እግዚአብሔር፡ ጸባዖት፡ ፍጹም፡ ዘመልዓ፡ ሰማያተ፡ ወምድረ፡ 
                                ቅድሳተ፡ ስብሐቲከ፡ አአምን፡ ወእትአመን፡ እሰግድ፡ ለአብ፡ ወለወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘይነብር፡ ወትረ፡
                                በዋህድናሁ፡
                                <gap reason="ellipsis"/><pb n="5v"/><cb n="a"/><gap reason="ellipsis"/>
                                ድርሳነ፡ ሕማማቲሁ፡ ለእግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ መፍቀሬ፡ ኵሉ፡ ዓለም፡
                                መድኃኔ፡ ኵሉ፡ ዓለም፡ ወመቤዝወ፡ ኵሉ፡ ዓለም፡ ወማኅየዌ፡ ኵሉ፡ ዓለም። ወባላሔ፡ ኵሉ፡ ዓለም፡ ዘይትነበብ፡ ጊዜ፡ ንዋም፡ ዘጸሐፍዎ፡ 
                                ወንጌላውያን፡ ወሠ<cb n="b"/>ላስ፡ ደናግል፡ በርዜዳ፡ ወመልቴዳ፡ ወኤልሳቤጥ፡ ዘመሐሮን፡ እግዚእነ፡
                                ምስጢረ፡ ሕማማቲሁ። ወስሙ፡ ለዝንቱ፡ ድርሳነ፡ ማኅየዊ፡ ባሕቱ፡ ብፁዕ፡ ውእቱ፡ ወይትባረክ፡ በሥጋሁ፡ ወበነፍሱ፡ ዘያነብቦ፡
                                አመ ፳ወ፯ ለመጋቢት፡ ወለለወርኁ።
                            </incipit>
                        </msItem>
            
                        <msItem xml:id="ms_i2">
                            <locus from="79va" to="89vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2807RepCh91">Malkǝʾ-hymn to Our Lady Mary</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                ሰላም፡ ለኪ፡ ማርያም፡ መዓዛ፡ አፉኪ፡ ኮል።
                                እንዘ<supplied reason="omitted">፡</supplied> ትፄንዊ፡ በገዳም፡ ወሐቅል፡ 
                                ወልታ፡ ረዲኦትየ፡ በውስተ፡ ቀትል። ሰላም፡ ለኪ፡<supplied reason="omitted">፡</supplied>
                                ተሰፍ<supplied reason="omitted">ህ</supplied>ዎ፡ ባዕድ፡ አልብየ፡ ዘእንበሌኪ፡ ምክህየ።
                                በኢመንኖ፡ በልኒ፡ ገብርየ፡ <add place="below">ገብርየ።</add>
                                ዘተሣየጥኩከ፡ በንዋይየ። ሰላም፡ ለኪ።
                            </incipit>
                        </msItem>
                    </msContents>
                    

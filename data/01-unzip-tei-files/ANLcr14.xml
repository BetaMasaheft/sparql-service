                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <desc>Mediocre hand. <ref target="#ms_i2"/> is written in smaller
                                    script than <ref target="#ms_i1"/> and probably by another hand. The beginning of <ref target="#ms_i2"/> is legible only with difficulty.</desc>
                                <seg type="ink">Black; red.</seg>
                                <date notBefore="1900" notAfter="1934"/>
                            </handNote>                  
                        </handDesc>
                 
                 <decoDesc>
                     <decoNote xml:id="d1" type="band">
                         <desc>Black and red ornamental bands divide the chapters of <ref target="#ms_i1"/> according to the days of the week (see also <ref target="#e1"/>).</desc>
                     </decoNote>
                 </decoDesc>
                 
                        <additions>
                            <list>
                                <item xml:id="e1">
                                    <desc type="findingAid"/>
                                    <desc><ref target="#ms_i1"/> is divided according to the days of
                                        the week (see also <ref target="#d1"/>): 
                                        <foreign xml:lang="gez">ዘሠኑይ፡</foreign> (<locus target="#5r"/>);
                                        <foreign xml:lang="gez">ዘሠሉስ፡</foreign> (<locus target="#18v"/>);
                                        <foreign xml:lang="gez">ዘረቡዕ፡</foreign> (<locus target="#29r"/>); 
                                        <foreign xml:lang="gez">ዘሐሙስ፡</foreign> (<locus target="#38r"/>); 
                                        <foreign xml:lang="gez">ዘዓርብ፡</foreign> (<locus target="#50r"/>); 
                                        <foreign xml:lang="gez">ዘቀዳም፡</foreign> (<locus target="#60v"/>); 
                                        <foreign xml:lang="gez"><supplied reason="omitted">ዘእኁድ፡</supplied></foreign> (<locus target="#72r"/>).
                                     </desc>
                                    <q xml:lang="gez"/>
                                </item>
                                
                                <item xml:id="e2">
                                    <desc type="findingAid"/>
                                    <desc><ref target="#ms_i2"/> contains indications for the 
                                        hours: 
                                        <foreign xml:lang="gez">ዘነግህ፡</foreign> (<locus target="#79va"/>);
                                        <foreign xml:lang="gez">፩ ሰዓት፡</foreign> (<locus target="#81ra"/>);
                                        <foreign xml:lang="gez">ዘሠርክ፡</foreign> (<locus target="#84ra"/>); 
                                        <foreign xml:lang="gez">ዘንዋም፡</foreign> (<locus target="#85ra"/>); 
                                        <foreign xml:lang="gez">ዘመንፈቀ፡ ሌሊት፡</foreign> (<locus target="#86vb"/>).
                                      </desc>
                                    <q xml:lang="gez"/>
                                </item>
                                
                                <item xml:id="e3">
                                    <desc>The name of the owner of the manuscript was <persName role="owner" ref="https://betamasaheft.eu/PRS14845GabraM">PRS14845GabraM</persName>. His entire family (with the exception
                                        of his wife, who is not mentioned) is listed on
                                        <locus from="89v" to="90ra"/> (a family tree is printed in
                                        the catalogue):
                                        his parents were <persName ref="https://betamasaheft.eu/PRS14846RamhaS">PRS14846RamhaS</persName> and
                                        <persName ref="https://betamasaheft.eu/PRS14847WalattaT">PRS14847WalattaT</persName>;
                                        his brothers were <persName ref="https://betamasaheft.eu/PRS14848WaldaR">PRS14848WaldaR</persName>, <persName ref="https://betamasaheft.eu/PRS14849GabraE">PRS14849GabraE</persName> and
                                        <persName ref="https://betamasaheft.eu/PRS14850GabraH">PRS14850GabraH</persName>;
                                        his sisters were <persName ref="https://betamasaheft.eu/PRS14851WalattaH">PRS14851WalattaH</persName>, <persName ref="https://betamasaheft.eu/PRS14852WalattaI">PRS14852WalattaI</persName>,
                                        <persName ref="https://betamasaheft.eu/PRS14853WalattaE">PRS14853WalattaE</persName>, <persName ref="https://betamasaheft.eu/PRS14854WalattaG">PRS14854WalattaG</persName>, <persName ref="https://betamasaheft.eu/PRS14855WalattaM">PRS14855WalattaM</persName>
                                        and <persName ref="https://betamasaheft.eu/PRS14856WalattaG">PRS14856WalattaG</persName>;
                                        his sons were <persName ref="https://betamasaheft.eu/PRS14857GabraE">PRS14857GabraE</persName>, <persName ref="https://betamasaheft.eu/PRS14858HaylaG">PRS14858HaylaG</persName> and
                                        <persName ref="https://betamasaheft.eu/PRS14859KeflaI">PRS14859KeflaI</persName>;
                                        his daughters were <persName ref="https://betamasaheft.eu/PRS14860EhetaG">PRS14860EhetaG</persName>, <persName ref="https://betamasaheft.eu/PRS14861WalattaS">PRS14861WalattaS</persName>,
                                        <persName ref="https://betamasaheft.eu/PRS14862WalattaE">PRS14862WalattaE</persName>, <persName ref="https://betamasaheft.eu/PRS14863WalattaH">PRS14863WalattaH</persName>, <persName ref="https://betamasaheft.eu/PRS14864WalattaK">PRS14864WalattaK</persName>,
                                        <persName ref="https://betamasaheft.eu/PRS14865WalattaS">PRS14865WalattaS</persName>, <persName ref="https://betamasaheft.eu/PRS14866AmataM">PRS14866AmataM</persName>, <persName ref="https://betamasaheft.eu/PRS14867WalattaG">PRS14867WalattaG</persName> and <persName ref="https://betamasaheft.eu/PRS14868WalattaM">PRS14868WalattaM</persName>.
                                    </desc>
                                </item>
                                
                                <item xml:id="a1">
                                    <locus target="#90v"/>
                                    <desc type="RecordTransaction">Amharic sales note stating that
                                        this manuscript was sold by <persName ref="https://betamasaheft.eu/PRS14845GabraM">PRS14845GabraM</persName> to <persName ref="https://betamasaheft.eu/PRS14869MikaelM">PRS14869MikaelM</persName> for 18 thaler, dated <date when="1934-06-19" when-custom="1926" calendar="ethiopian">12 Sane 1926
                                                E.C. (19 June 1934)</date>, during the reign of 
                                        <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName>,
                                    followed by the names of the witnesses.</desc>
                                    <q xml:lang="am"/>
                                </item>
                                
                                <item xml:id="a2">
                                    <locus target="#1r"/>
                                    <desc type="DonationNote">A leaf with a note stating that the manuscript was
                                        given to <persName ref="https://betamasaheft.eu/PRS3182ContiRo">Carlo Conti Rossini</persName> by <persName ref="https://betamasaheft.eu/PRS7165Mordini">Antonio Mordini</persName> on 
                                        <date>28 March 1946</date> is glued to the page.</desc>
                                    <q xml:lang="it">A <persName ref="https://betamasaheft.eu/PRS3182ContiRo">S.E. Carlo
                                        Conti Rossini</persName> in affettuoso ricordo da suo
                                        <persName ref="https://betamasaheft.eu/PRS7165Mordini">A. Mordini</persName>. <date when="1946-03-28">28.
                                            3. 46</date></q>
                                </item>
                            </list>
                        </additions>
                        

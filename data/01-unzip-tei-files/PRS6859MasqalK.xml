         <listPerson>
            <person sameAs="wd:Q60522711" sex="2">


               <persName xml:lang="gez" xml:id="n1" type="birth">መስቀል፡ ክብራ፡</persName>
                  <persName xml:lang="gez" corresp="#n1" type="normalized">Masqal Kǝbrā</persName>
               <persName>
                  <roleName type="title">baʿalta biḥat</roleName>
               </persName>
               
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               <occupation type="ruler">queen</occupation>

               <floruit>She was the wife of King <persName ref="https://betamasaheft.eu/PRS6152Lalibala">Lālibalā</persName> who  played a major role during his reign. She was responsible
                  for the fall of the metropolitan <persName ref="https://betamasaheft.eu/PRS7073Mikael">Mikāʿel II</persName> who had to return to Egypt after four years in Ethiopia.
                  She is also credited with the building of some churches at <placeName ref="https://betamasaheft.eu/LOC4244Laliba">Lālibalā</placeName>. Her title can be interpreted as the "Lady of <placeName ref="https://betamasaheft.eu/LOC1914Bihat">biḥat</placeName>"
               </floruit>
               <death/>
            </person>
            
         </listPerson>

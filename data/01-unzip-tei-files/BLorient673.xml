                            <additions>
                                <list>
                                    <item xml:id="a1">
                                        <locus from="196ra" to="197ra"/>
                                        <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT2998RepCh278">Hymn to Za-Mikāʾel ʾAragāwi</title></desc>
                                        <q xml:lang="gez">
                                            <seg part="I">
                                                በስመ፡ እግዚአብሔር፡ እምግብጽ፡ ፍናዋተ፡ ግዕዛን፡ ዘመርሖ።
                                            </seg>
                                        </q>
                                    </item>
                                    
                                    <item xml:id="a2">
                                        <locus from="197ra" to="197rb"/>
                                        <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT2751RepCh35">Malkǝʾ-hymn to St Anthony and Macarius</title></desc>
                                        <q xml:lang="gez">
                                            <seg part="I">
                                                ሰላም፡ ለእንጦንዮስ፡ ወመቃርዮስ። አርሳንዮስ፡ ወአብራንዮስ፡
                                            </seg>
                                        </q>
                                    </item>
                                    
                                    <item xml:id="a3">
                                        <locus from="197rb" to="197vb"/>
                                        <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT3044RepCh324">Hymn to Za-Mikāʾel ʾAragāwi</title>
                                        </desc>
                                        <notatedMusic><desc>With musical notes.</desc></notatedMusic>
                                        <q xml:lang="gez">
                                            <seg part="I">
                                                <hi rend="rubric">አርያም፡</hi> አንተ፡ አቡነ፡ አቡነ፡ መምህርነ፡ ዘሚካኤል፡ ጸሊ፡ በእንቲአነ። ከመ፡ በህዱእ፡ ወበጽምው፡ ይኩን፡ ንብረተነ።
                                            </seg>
                                        </q>
                                    </item>
                                    
                                    <item xml:id="a4">
                                        <locus from="197vc" to="198vb"/>
                                        <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT3000RepCh280">Hymn to St Zechariah</title></desc>
                                        <q xml:lang="gez">
                                            <seg part="I">
                                                በስመ፡ እግዚአብሔር፡ እግዚእ፡ ዘተሠገወ፡ ቀዲሙ። እንዘ፡ አርአየ፡ ገብረ፡ ይነሥእ፡ እማኅፀነ፡ ቅድስት፡ እሙ።
                                            </seg>
                                        </q>
                                    </item>
                                    
                                    <item xml:id="a5">
                                        <locus from="198vb" to="199vb"/>
                                        <desc type="GuestText"><title type="complete" ref="https://betamasaheft.eu/LIT2848RepCh130">Malkǝʾ-hymn to David</title></desc>
                                        <q xml:lang="gez">
                                            <seg part="I">
                                                ሰላም፡ ለዝክረ፡ ስምከ፡ ብርከ፡ ንጉሠ፡ ጌት፡ ዘአድከመ።
                                            </seg>
                                        </q>
                                    </item>
                                    
                                    <item xml:id="a6">
                                        <locus target="#2r"/>
                                        <desc type="Record">Nine records, and one erased record. The records are from the reigns of 
                                            <persName ref="https://betamasaheft.eu/PRS5332hezqeyas">Ḥǝzqǝyās</persName>, <persName ref="https://betamasaheft.eu/PRS8344sahlaDe">Śāhla Dǝngǝl</persName>, <persName ref="https://betamasaheft.eu/PRS5619IyasuIV">ʾIyāsu IV</persName>
                                            or <persName ref="https://betamasaheft.eu/PRS5618IyasuII">ʾIyāsu III</persName>, <persName ref="https://betamasaheft.eu/PRS4661Gigar">Gigār</persName> and <persName ref="https://betamasaheft.eu/PRS9143TaklaGi">Täklä Giyorgis II</persName>
                                            or <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis I</persName>.</desc>
                                        <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a7">
                                        <locus target="#163vb"/>
                                        <desc type="RecordTransaction">Record from the time of <persName ref="https://betamasaheft.eu/PRS5332hezqeyas">Ḥǝzqǝyās</persName>.</desc>
                                            <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a8">
                                        <locus target="#197vb"/>
                                        <desc type="LandGrant">Land grant from the time of <persName ref="https://betamasaheft.eu/PRS9143TaklaGi">Täklä Giyorgis II</persName>
                                            or <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis I</persName>.</desc>
                                            <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a9">
                                        <locus target="#198v"/>
                                        <desc type="RecordTransaction">Record from the time of <persName ref="https://betamasaheft.eu/PRS9143TaklaGi">Täklä Giyorgis II</persName>
                                            or <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis I</persName>.</desc>
                                            <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a10">
                                        <locus from="199ra" to="199rb"/>
                                        <desc type="Record">Record from the time of <persName ref="https://betamasaheft.eu/PRS8421Salomon">Salomon I</persName> or <persName ref="https://betamasaheft.eu/PRS8422Salomon">Salomon II</persName>.</desc>
                                            <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a11">
                                        <locus target="#199v"/>
                                        <desc type="Record">Four records from the time of <persName ref="https://betamasaheft.eu/PRS9152TaklaHa">Takla Hāymānot I</persName> or 
                                            <persName ref="https://betamasaheft.eu/PRS9153TaklaHa">Takla Hāymānot II</persName>, <persName ref="https://betamasaheft.eu/PRS5636IyoasI">ʾIyoʾas I</persName> or <persName ref="https://betamasaheft.eu/PRS5637IyoasI">ʾIyoʾas II</persName>.</desc>
                                            <q xml:lang="am"/>
                                    </item>
                                    
                                    <item xml:id="a13">
                                        <locus target="#195v"/>
                                        <desc type="Supplication">The names of ʾIyāsu, possibly <persName ref="https://betamasaheft.eu/PRS5619IyasuIV">ʾIyāsu IV</persName>,<persName ref="https://betamasaheft.eu/PRS13642GabraM">Gabra Mikāʾel</persName>
                                            and <persName ref="https://betamasaheft.eu/PRS13641HaylaI">Ḫāyla ʾIyasus</persName> are
                                            mentioned in a supplication by a later hand.</desc>
                                        <q xml:lang="gez">ምስለ፡ ነ<del rend="expunctuated">ብ</del>ሰ፡ ንጉሥነ፡ <persName cert="low" ref="https://betamasaheft.eu/PRS5619IyasuIV">ʾIyāsu IV<hi rend="rubric">ኢያሱ፡</hi></persName> ወምስለ፡
                                            ነፍሳተ፡ <sic>አግብርቲሆ፡</sic> <persName ref="https://betamasaheft.eu/PRS13641HaylaI">ኃይለ፡ <hi rend="rubric">ኢየሱስ፡</hi></persName>
                                            <persName ref="https://betamasaheft.eu/PRS13642GabraM">ገብረ፡ <hi rend="rubric">ሚካኤል፡</hi></persName> ለአለመ፡ አለም፡ አሜን፡</q>
                                    </item>
                                    
                                    <item xml:id="a14">
                                        <locus target="#3r"/>
                                        <desc type="OwnershipNote">The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿAlam</placeName>
                                        </desc>
                                        <q xml:lang="gez">ስንክሳር፡ ዘቅዱስ፡ መድኃኔ ፡ ዓለም።</q>
                                        
                                    </item>
                                    
                    <item xml:id="e1">
                        <desc>The names of <persName ref="https://betamasaheft.eu/PRS10375Yohanne">Yoḥannǝs I</persName>,<persName ref="https://betamasaheft.eu/PRS8278SablaWa">Sabla Wangel</persName> and <persName ref="https://betamasaheft.eu/PRS13243EhetaKrestos">ʾƎḫǝta Krǝstos</persName> are mentioned in the
                        supplications.</desc>
                    </item>
                                    
                              
                                </list>
                            </additions>
                            

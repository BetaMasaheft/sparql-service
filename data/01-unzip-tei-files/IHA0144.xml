                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="109r">1v-109r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0102IHA">عمدة السالك وعدة الناسك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>باسم الله الرحمن الرحيم رب يسر ولا تعسر عونك يا كريم قال الشيخ العالم العلامة شهاب الدين احمد بن نقيب الشافعي رضى الله عنه ورحم سلفه بمنه وكرمه امين الحمد لله رب العالمين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم اجمعين هذا مختصر على مذهب الامام الشافعي رحمه الله اختصرت فيه على الصحيح من المذهب عند الرافعي والنووي او احدهما</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#109r">-109r</locus>ولا يقبل فى الزنا واللواط واتيان البهيمة الا اربعة ذكورا ويقبل فيما لا يطلع عليه الرجال كالولادة رجلان او رجل وامراتان او اربع نسوة والله اعلم تمت وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم   </explicit>
                     <note>Words divided into two lines.</note>
                     <note/>
                  </msItem>
               </msContents>

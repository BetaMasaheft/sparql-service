                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#1" facs="001">Fol. 1</locus>
                        <desc>Four petals with an eye in each and a square in the center</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#1" facs="001">Fol. 1</locus>
                        <desc>A <ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref> with two children sitting on her lap and a <term key="cross" ana="#cross"/> above her head
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#3" facs="003">Fol. 3</locus>
                        <desc>Two heads of angels <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#3" facs="003">Fol. 3</locus>
                        <desc>Two heads of angels <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#5" facs="005">Fol. 5</locus>
                        <desc>Seated <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#6" facs="006">Fol. 6</locus>
                        <desc>A man with a <term key="crown" ana="#crown"/> standing and a face on his right and left <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#6" facs="006">Fol. 6</locus>
                        <desc>Four petals with an eye in each and a square in the center</desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d8">
                      Decorative designs:
                      <locus from="1" to="6" facs="001">fols 1–6, </locus> (two black rectangular boxes surrounding the text with red strips in between);
                      <locus from="5" facs="005">5 and following</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black and red);
                      <locus from="6" facs="006">6 and following</locus> (<foreign xml:lang="gez">ሐረግ፡</foreign> using black, red and yellow)
                    </decoNote>
                  </decoDesc>

                   <msItem xml:id="ms_i1.13">
                     <locus from="151v" to="154v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1313Discou">Discourse of the 318 Fathers on the Trinity</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ነገረ፡ ዘቅዱሳን፡ አበው፡ ፫፻፲ወ፰ ዘይከውን፡ ኅንጻ፡
                     ለመነኮሳት፡ በእንተ፡ ሥላሴ፡ ቅድስት።</incipit>
                   </msItem>
                  <msItem xml:id="ms_i1.14">
                    <locus from="154v" to="162r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1371Exposi">Exposition of the Ten Commandments</title>
                  <textLang mainLang="gez"/>
                  <incipit xml:lang="gez">ትርጓሜ፡ ዐሥሩ፡ ቃላት፡ ዘተርጐመ፡ ዮሐንስ፡ አፈ፡
                  ወርቅ፡ <gap reason="ellipsis"/> ወበእንተዝ፡ አነ፡ አየድዓክ፡
                ኦፍቁርየ፡ ስብሐተ፡ እግዚአብሔር፡ ዘአልቦ፡ ኆልቈ፡ እስከ፡ ለዓለም።</incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.15">
                    <locus from="162r" to="164r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2654EssenceTrinity">Discourse on the Essence of the Holy Trinity</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">፩ ግጻዌ፡ ትምህርት፡ ሕግ፡ ወሥርዓት፡ ወተግሣጽ፡
                    ዘተሠርዐ፡ በእንተ፡ ህሉና፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዘይትነበብ፡ ወትረ፡ ለሕዝብ።
                  ወህላዌ፡ መለኮት፡ ዘኢይትነገር። ወዘኢይትፈለጥ። ወኅብረተ፡ ቃል፡ ዘእምቅድስት፡ ሥላሴ፡
                ይእቲ፡ እንተ፡ ክርስቶስ፡ ህሉና፡ ተሀሉ፡ ምስሌነ፡ አሜን።</incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.16">
                    <locus from="164v" to="165r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2655GoodEvil">Discourse on How to distinguish between Good and Evil</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">ግጻዌ፡ ትምህርት፡ ከመ፡ ይፍልጡ፡ ሠናየ፡ ወእኩየ፡
                    ግጽው፡ ወአብጥሊስ፡ ቀኖና፡ ዘእግዚእነ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.17">
                    <locus from="165r" to="170r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2656FearGod">Discourse on the Fear of God</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">
                      ግጽው፡ ወትምህርት፡ አብጥሊስ፡ ቀኖና፡ በእንተ፡ ፍርሀተ፡ እግዚአብሔር።
                    </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.18">
                    <locus from="170r" to="178r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2657Ancient">Discourse on the Ancient People, and Refutation of the
          Jews</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">
                      አብጥሊስ፡ ቀኖና፡ ዘእምሐዋርያት፡ ተሠርዐ። ትምህርት፡ ወተግሣጽ፡ <sic>ወዘለፈ</sic> ዘተጽሕፈ፡ በእንተ፡ ቀዳሚ፡
                      ሕዝብ፡ ከመ፡ ያእምሩ፡ መሃይምናን፡ ሕዝበ፡ <sic>ክርስቲያን።</sic>
                    </incipit>
                  </msItem>
                  <msItem xml:id="ms_i1.19">
                    <locus from="178v" to="183r"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2658Jews">Discourse of Gregory of Armenia against the Jews</title>
                  <textLang mainLang="gez"/>
                  <incipit xml:lang="gez">
                  ግጽው፡ ወተግሣጽ፡ አብጢሊስ፡ ቀኖና፡ በእንተ፡ ዘዘለፎሙ፡ ወገሠጾሙ፡ ወአስተኃፈሮሙ፡ ቅዱስ፡ ጎርጎርዮስ፡
                  ሊቀ፡ ጳጳሳት፡ ዘአርማንያ። ገሠጾሙ፡ ወዘለፎሙ፡ ለአይሁድ፡ እኩያን። እለ፡ ሀለዉ፡ ህየ፡ ምስሌሁ፡ ለቅዱስ፡
                  ጎርጎርዮስ፡ በእንተ፡ እለ፡ ይብሉ፡ ዘተወልደ፡ እማርያም፡ ኢኮነ፡ ወልደ፡ እግዚአብሔር፡ አላ፡ ሰብእ፡ ውእቱ፡
                  ወልደ፡ ሰብእ።
                </incipit>
                <note><foreign xml:lang="gez">ምንባብ፡ በሌሊት፡ ማህትወ፡ ፋሲካ፡</foreign> is added
              by a later hand in the margin.</note>
                 </msItem>

                 <msItem xml:id="ms_i1.20">
                   <locus from="183r" to="194r"/>
                   <title type="complete" ref="https://betamasaheft.eu/LIT2659Wisdom">Hortatory discourse to believers, who desire to walk in the
          path of wisdom and knowledge</title>
                 <textLang mainLang="gez"/>
                 <incipit xml:lang="gez">ግጽው፡ ወተግሣጽ፡ ወሥርዓት፡ ትምህርት፡ ጥበብ፡ አብጥሊስ፡ ቀኖና፡
                   ዘተሠርዐ፡ ነዋ፡ እሉ፡ ለእለ፡ የአምኑ፡ በህሉና፡ እግዚአብሔር፡ ወእለ፡ ይፈቅዱ፡ ይስምዑ፡ ትምህርተ፡ ጽድቅ።
                   ወይሖሩ፡ በጥበብ፡ ወበአእምሮ፡ ወበለብዎ፡ ወበፍናዋተ፡ ሕይወት፡ ወይግበሩ፡ ፍሬ፡ ጽድቅ፡ ወበዘይደልዎ፡ ለነፍሶሙ፡
                   ወያእምሩ፡ ሥርዋ፡ ለጥበብ፡ ወበአእምሮ፡ ወበለብዎ፡ ወሕባሪሃ፡ ለጥበብ።
                 </incipit>
                 </msItem>
                 <msItem xml:id="ms_i1.21">
                   <locus from="194v" to="199v"/>
                   <title type="complete" ref="https://betamasaheft.eu/LIT2660Penit">ʾAbsǝliṭis qanonā baʾǝnta nǝssǝḥa tǝmhǝrt za-taśarʿa ʾǝmḫaba
          ʾƎgziʾabǝḥer ʾǝgziʾǝna ʾIyasus Krǝstos</title>
                   <textLang mainLang="gez"/>
                   <incipit xml:lang="gez">፰ አብጥሊስ፡ ቀኖና፡ በእንተ፡ ንስሓ፡ ትምህርት፡ ዘተሠርዐ፡
                     እምኀበ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ነዋ፡ እሉ፡ ወተስእሎ፡ ጴጥሮስ፡ ለእግዚእነ፡ ኢየሱስ፡
                     ክርስቶስ፡ እምድኅረ፡ ተንሥአ፡ እምውታን፡ በደብረ፡ ዘይት። ወይቤሎ፡ ሊቅ፡ ንግረኒ፡ ወመሀረነ፡
                     ወአምረነ፡ ሥርዐተ፡ ንስሓ፡ በዘ፡ ይደሉ። ከመ፡ ንንግሮሙ፡ ወንምሀሮሙ፡ ለሕዝብ፡ ትምህርተ፡
                     ሕይወት፡ ወናግብኦሙ፡ ውስተ፡ አእምሮ፡ ጽድቅ።
                   </incipit>
                 </msItem>
                 <msItem xml:id="ms_i1.22">
                   <locus from="199v" to="202v"/>
                   <title type="complete" ref="https://betamasaheft.eu/LIT2692Penit">Penitential Canons [not to Peter]</title>
                   <textLang mainLang="gez"/>
                   <incipit xml:lang="gez">
                     በአኰቴተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ። ጸሐፍነ፡ ቀኑን፡ ዘይትነገር፡ ላዕለ፡ ኵሉ፡ ዘይኔስሕ፡
                     በእንተ፡ ኅጢአቱ፡ ወእመኒ፡ ክርስቲያናዊ፡ ቀተለ፡ ኢያቅልሉ፡ እምንስሓሁ። ቀኑን። እመቦ፡ ሰብእ፡
                     ዘቀተለ፡ እምአዝማዲሁ። ወሖረ፡ እምሰብኡ፡ ወቀተለ፡ በእንቲአሁ፡ ዘቀተለ፡ ይጹም፡ ፵ ዕለተ፡
                     <sic>በኀብስተ፡</sic> ወማይ። ወ፯ ዓመት፡ በንስሓ።
                   </incipit>

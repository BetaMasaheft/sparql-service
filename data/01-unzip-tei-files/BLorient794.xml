               <msContents>
                 <summary/>
                 <msItem xml:id="ms_i1">
                   <locus from="4r"/>
                   <title type="complete" ref="https://betamasaheft.eu/LIT2317Senodo">Senodos</title>
                   <textLang mainLang="gez"/>

                   <msItem xml:id="ms_i1.1">
                     <locus from="4r" to="5v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2667Statut71Title">Ecclesiastic (apostolic) canons (71): titloi</title>
                     <textLang mainLang="gez"/>
                   </msItem>

                   <msItem xml:id="ms_i1.2">
                     <locus from="6r" to="45r"/>
                     <title type="incomplete" xml:lang="en" ref="https://betamasaheft.eu/LIT2667Statut71Title">
                     Orders of the Apostles</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                       በስመ፡ አብ፡ ወወልድ፡ <gap reason="ellipsis"/> ንቀድም፡ በረድኤተ፡
                       እግዚአብሔር፡ በሠናይ፡ ኅብረት፡ በጽሕፈተ፡ ሴኖዶስ፡ ዘአበው፡ ሐዋርያት፡ ቅዱሳን፡ ዘሠርዑ፡
                       ለአርትዖ፡ ቤተ፡ ክርስቲያን፡ ቅድስት። አኅብሮተ፡ ሴኖዶስ፡ ዘአበው፡ ሐዋርያት፡ ኅሩያን። ላዕለ፡
                       መርሐ፡ ግብረ፡ አናቅጽ። ወላዕሌሃ፡ ኆልቍ፡ ከመ፡ ይቅልል፡ አውፅኦ፡ ትእዛዝ፡ ወፍትሕ፡ በውእቱ፡
                       ፍጡነ። ወላዕለ፡ ኵሉ፡ ፩፩ ምቅዋም፡ ኆልቈ፡ አናቅጽ። ወይእቱ፡ ፻ወ፪ወ፯፡ አናቅጽ፡ ኆልቍ።
                       ክርስቲያን፡ ዘወሀቡ፡ ሐዋርያት፡ በእደ፡ ቀሌምንጦስ፡ ዘለአኩ፡ ቀደሙ። ወይእቲ፡ ፶ወ፯፡ <sic>አናቅ፡</sic>
                       ኆልቍ። ቀዳሚ፡ ክሥተተ፡ ሴኖዶስ፡ ዘሐዋርያት፡ ቅዱሳን፡ ፸ወ፪ አባቅጽ።
                     </incipit>
                     <note>Here follows the list of 70 titloi, slightly imperfect
                     at the end.</note>
                   </msItem>

                   <msItem xml:id="ms_i1.3">
                     <locus from="45r" to="46v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2668AC56Title">
                     </title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                       በስመ፡ አብ፡ ሴኖዶስ፡ ዘቤተ፡ ክርስቲያን፡ ዘወሀብዋ፡ ሐዋርያት፡ በእደ፡ ቀሌምንጦስ፡ ዘለአክዎ።
                     </incipit>

                   </msItem>
                   <msItem xml:id="ms_i1.4">
                     <locus from="47r" to="53v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2670AC56">Apostolic canons (56)</title>
                     <textLang mainLang="gez"/>
                     <note>55 in number according to the titloi, <locus target="#45r"/>,
                   but 57 according to the text, <locus target="#47r"/>.</note>
                   </msItem>

                   <msItem xml:id="ms_i1.5">
                     <locus from="54r" to="63r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2671CanonsSimon2">
                     </title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ዝንቱ፡ ሴኖዶስ፡ ዘአበው፡ ሐዋርያት፡ ንጹሓን፡ ወቅዱሳን፡</incipit>
                     <note>25 in number.</note>

                     <msItem xml:id="ms_i1.5.1">
                       <locus from="54r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2704CanonsSimon">
                       </title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez"><sic>ሥርዓት፡</sic> ክህነት፡ ዘስምዖን፡ ቀንናዊ፡
                       በእንተ፡ ስርዓተ፡ ቤተ፡ ክርስቲያን።</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.5.2">
                       <locus from="55r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2640CanonsMattSimon">Canons of SS. Matthew and Simon</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በእንተ፡ ዓሥራት፡ ወበኵር።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.3">
                       <locus from="55r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2643CanonsPaul">Canons of S. Paul 1</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ትእዛዝ፡ ዘጳውሎስ፡ ለኵሉ፡ መሀይምናን፡
                       <sic>ወመሀምንት፡</sic> በእንተ፡ ጸሎት።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.4">
                       <locus from="55r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2641CanonsPeterPaul">Canons of SS. Peter and Paul</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በእንተ፡ ዕረፍት፡ ዘይደሉ፡ በዕለተ፡ በዓላት።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.5">
                       <locus from="57r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2642CanonsAp">Canons of the Apostles</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በእንተ፡ ዐቂበ፡ ጊዜያት፡ <sic>ጸሎታተ፡</sic> ዘማዓልት።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.6">
                       <locus from="58r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2644CanonsPaul">Canons of S. Paul 2</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">በእንተ፡ እለ፡ ኖሙ፡ ተዝካረ፡ ሙታን፡ ዘከመ፡ ይትገበር፡ በእንቲአሆሙ፡
                       ትእዛዝ።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.7">
                       <locus from="58v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2645CanonW">ወካዕበ ፡ በእንተ ፡ እለ ፡ ተጸውዑ ፡ ውስተ ፡ ምሳሕ ፡ ወተዝካረ ፡ ሙታን ።</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ትእዛዝ፡ በእንተ፡ እለ፡ ትርጸውዑ፡ ውስተ፡ ምሳሕ፡ ዘይትገበር፡ ትዝካሮሙ፡
                       በዕለት፡ ለእለ፡ ኖሙ፡ መሀይምናን።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.8">
                       <locus from="58v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2646CanonW">ወካዕበ ፡ ነገሮሙ ፡ በእንተ ፡ እለ ፡ ይስደዱ ፡ በእንተ ፡ ሃይማኖት ፡ ወይጐዩ ፡ እምሀር ፡
          ውስተ ፡ ሀገር ።</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ትእዛዝ፡ በእንተ፡ እለ፡ ይሰደዱ፡ በእንተ፡ ሀይማኖቶሙ፡ ወይጐዩ፡
                       እምፍርሀት፡ እለ፡ ይሰድድዎሙ፡ ወአይ፡ ፍሥሐ፡ ይከውን፡ ሎሙ።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.9">
                       <locus from="59r"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2647CanonsPeterPaul">Canons of SS. Peter and Paul</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ነገረ፡ ሐዋርያት፡ ቅዱሳን፡ በእንተ፡ ዐቂበ፡ መዓርገ፡ ሢመት።</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5.10">
                       <locus from="61v"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2648CanonsPaul">Canons of St Paul</title>
                       <textLang mainLang="gez"/>
                       <incipit xml:lang="gez">ትእዛዝ፡ ዘጳውሎስ፡ ላእክ፡ በእንተ፡ እለ፡ ይመጽኡ፡ ኀበ፡ ምስጢር።</incipit>
                     </msItem>
                   </msItem>
                   <msItem xml:id="ms_i1.6">
                     <locus from="63v" to="71v"/>
                     <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2639CanonsSimon1">
                     Canons of the Apostles, 25 in number</title>
                     <textLang mainLang="gez"/>
                     <note>Almost identical with <ref target="#ms_i1.5"/>.</note>
                   </msItem>
                   <msItem xml:id="ms_i1.7">
                     <locus from="71v" to="77v"/>
                     <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2673CanonsAscension">
                     Canons of the Apostles, after the Ascension of our Lord, 29 in number</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ዝንቱ፡ ሴኖዶስ፡ መጽሐፈ፡ ዜናሆሙ፡ ለሐዋርያት፡ እምድኅረ፡ ዐርገ፡
                     እግዚእነ፡ ወአምላክነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘአዘዙ፡ ሴኖዶስ፡ ዘጸሐፈ፡ ቀሌምንጦስ፡ በእንተ፡ ሐዋርያት፡ ዘከመ፡
                   ሠርዑ፡ ለቤተ፡ ክርስቲያን፡ ቅድስት፡ እንተ፡ ተሣየጣ፡ በደሙ፡ ክቡር።</incipit>
                   </msItem>
                   <msItem xml:id="ms_i1.8">
                     <locus from="78r" to="88v"/>
                     <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2677ACABt1">Canons of the Apostles,
                     given through Clement, 81 in number</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis"/> ዛቲ፡ ሴኖዶስ፡ ዘሐዋርያት፡ ቅዱሳን፡ ወዛቲ፡ ዜነወ፡ ቀሌምንጦስ፡
                     በእንተ፡ ጴጥሮስ፡ መምህሩ፡ ወይእቲ፡ ትሰመይ፡ እልብጥልሳት፡ ዘአስተጋብኡ፡ ላዕሌሁ፡ ሐዋርያቲሁ፡ ለእግዚእነ፡
                   ኢየሱስ፡ ክርስቶስ፡ ወኆልቆሙ፡ ወአብጥሊስ፡</incipit>
                   </msItem>
                   <msItem xml:id="ms_i1.9">
                     <locus from="88v" to="99r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2679ACAbt2">Apostolic canons Abṭelisāt (80)</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ዝንቱ፡ ሴኖዶስ፡ ዘሐዋርያት፡ ቅዱሳን፡ ዘነገረ፡ ቀሌምንጦስ፡ ወይእቲ፡
                     በጥልሳት፡ ዘኀብሩ፡ ባቲ፡ አርዳኢሁ፡ ለእህዚእነ፡ ክርስቶስ፡ ወኆልቆሙ፡ ፹ወ፩።</incipit>
                   </msItem>
                   <msItem xml:id="ms_i1.10">
                     <locus from="99v" to="103v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2675AC81">Apostolic canons (81)</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ሥርዓተ፡ ሐዋርያት፡ ምስለ፡ ቀሌምንጦስ፡ ዘተፈነወ፡ ለአሕዛብ፡ ሕገ፡ ቤተ፡
                     ክርስቲያን።</incipit>
                   </msItem>
                   <msItem xml:id="ms_i1.11">
                     <locus from="103v" to="107v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2680ClemPeter">Canons of Clement, which he received in a letter from S.
          Peter</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">ዝንቱ፡ ሴኖዶስ፡ ዘቀሌምንጦስ፡ ዘተጽሕፈ፡ ጴጥሮስ፡ ረድእ፡
                     ርእሰ፡ ሐዋርያት፡ ዘነገረ፡ በእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ። ይቤ፡ ቀሌምንጦስ፡ ዘእምጴጥሮስ፡
                   ርእሰ፡ ሐዋርያት፡ ረድኡ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ። ወይቤለኒ፡ ወልድየ፡ ቀሌምንጦስ፡ ኢታጥምቅ፡
                 መነሂ፡ በሕልያን፡ ወኢበሤጥ። ምቱር፡ በላዕለ፡ ጥምቀት፡ ዘነሥአ፡ ሕልያነ። ምቱር፡ ወውጉዝ፡ ውእቱ፡ ወርጉም፡
               እምአፉየ፡ አነ፡ ጴጥሮስ፡ ንኡስ፡ እምሐዋርያት። ወመክፈልቱ፡ ይኩን፡ ምስለ፡ ሤሞን፡ መሠርይ፡ ወምስለ፡ ይሁደ፡
             ረሲዕ።</incipit>

                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1_4284">
                           <locus target="#1v">-1v</locus>
                           <q xml:lang="ar">وهذه السلسله الذهبية للسادة القادرية \ من الزيلعين وغيرها للشيخ يوسف البحر \ بن محمد البكرى الصومالي الجكجكى القادري \ الشافعي الأشعري رضي الله عليه وعن \ السادة القادرية وعنه جميع المسلمين وعنا \ معهم وألتفنا  بهم أمين</q>
                           <desc>Title</desc>
                           <note>
                              <p>
                                 Mentioned
                              : <persName ref="https://betamasaheft.eu/PRS1779IHA">يوسف البحر
               بن محمد البكري الصومالي الجكجكي</persName>
                              </p>
                              <p>
                                 Mentioned
                              : <persName ref="https://betamasaheft.eu/PRS1779IHA">يوسف البحر
               بن محمد البكري الصومالي الجكجكي</persName>
                              </p>
                           </note>
                        </item>
                        <item xml:id="a0_4308">
                           <locus target="#6r">-6r</locus>
                           <q xml:lang="ar">المزدوجة الغرّاء في الإستغاثة بأسماء الله الحسنى \ نظم الفقير يوسف النبهانى عفا الله عنه</q>
                           <desc>Title</desc>
                           <note/>
                        </item>
                        <item xml:id="a0_4309">
                           <locus target="#12r">-12r</locus>
                           <q xml:lang="ar">حسن الختام بدعاء القارئ لنفسه ومؤلف هذا الكتاب وجميع أمة محمد عليه الصلاة والسلام</q>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a0_4319">
                           <locus target="#24v">-24v</locus>
                           <q xml:lang="ar">القصيدة ألفها رضى الباقى الشيخ حمزة \ بن الشيخ بن محمود بن الشيخ حاج كبير خمزة \ بن الشيخ حاج كبير محمود بن الشيخ كبير على \ أوسي تغمده الله برحمته تمت
</q>
                           <note>
                              <p>
                                 Mentioned
                              : <persName ref="https://betamasaheft.eu/PRS1130IHA">حاج حمزة بن محمود بن كبير حمرة بن كبير محمود</persName>
                              </p>
                              <p>

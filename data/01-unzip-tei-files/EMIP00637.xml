               <msContents>
                  <summary>Antiphonary for the Fast of Lent, êO" ÅÕ"</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="122r" facs="005">Fols 1r–122r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2361somade">Ṣoma dǝggʷā</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <incipit xml:lang="gez">
                      ናሁ፡ ወጠንኩ፡ ጽሒፈ፡ ጾመ፡ ድጓ፡ በሥምረተ፡ እግዚአብሔር፡ አሜን፡ በመሐትወ፡ ድራረ፡ ጾም፡ በ፪፡ ዘወረደ፡ እምላእሉ፡ አይሁድ፡ ሰቀሉ፡ ወሚመ፡ ኢያእመሩ፡ እግዚአ፡ ኵሉ፡ ዘያሐዩ፡ በቃሉ፡ <gap reason="omitted"/></incipit>
                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="18v" facs="005">Fols 1r–18v</locus>
                        <title>First Week, Maḫtǝwä drarä ṣom, <foreign xml:lang="gez">መኀትወ፡ ድራረ፡ ጾም፡</foreign></title>
                        <incipit xml:lang="gez">ዘወረደ፡ እምላዕሉ፡ አይሁድ፡ ሰቀሉ፡ ወሚመ፡ ኢያእመሩ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="18v" to="31r" facs="023">Fols 18v–31r</locus>
                        <title>Second Week, Qǝddǝst, <foreign xml:lang="gez">ቅድስት፡</foreign></title>
                        <incipit xml:lang="gez">ዛቲ፡ ዕለት፡ ቅድስት፡ ይእቲ፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="31r" to="45v" facs="035">Fols 31r–45v</locus>
                        <title>Third Week, Mǝkwrab, <foreign xml:lang="gez">ምኩራብ፡</foreign></title>
                        <incipit xml:lang="gez">በዕለተ፡ ሰንበት፡ ቦአ፡ ኢየሱስ፡ ምኩራበ፡ አይሁድ፡ <gap reason="omitted"/></incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.4">
                        <locus from="45v" to="58v" facs="050">Fols 45v–58v</locus>
                        <title>Fourth Week, Mäóagwu, <foreign xml:lang="gez">መፃጉዕ</foreign></title>
                        <incipit xml:lang="gez">ውእቱ፡ እግዚአ፡ ለሰንበት፡ ወአቡሃ፡ ለምሕረት፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus from="58v" to="72v" facs="063">Fols 58v–72v</locus>
                        <title>Fifth Week, Däbrä Zäyt, <foreign xml:lang="gez">ደብረ፡ ዘይት፡</foreign>, Sunday through Friday</title>
                        <incipit xml:lang="gez">እንዘ፡ ይነብር፡ እግዚእነ፡ ውስተ፡ ደብረ፡ ዘይት፡ ወይቤሎሙ፡ ለአርዳኢሁ፡ ዑቁኬ፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.6">
                        <locus from="72v" to="81r" facs="077">Fols 72v–81r</locus>
                        <title>Collection of Hymns for the Lent Season</title>
                        <msItem xml:id="ms_i1.6.1">
                          <locus from="72v" to="73r" facs="077">Fols 72v–73r</locus>
                          <title>Hymn for the apostle Mathias, Matǝyas ḥäwarǝya, <foreign xml:lang="gez">ማትያስ፡ ሐዋርያ፡</foreign>, to be sung on the eighth of Mäggabit</title>
                        </msItem>
                        <msItem xml:id="ms_i1.6.2">
                          <locus from="73r" to="74v" facs="077">Fols 73r–74v</locus>
                          <title>Hymn for the feast of the Cross, zä-Mäsqäl, <foreign xml:lang="gez">ዘመስቀል፡</foreign>, to be sung on the tenth of Mäggabit</title>
                        </msItem>
                        <msItem xml:id="ms_i1.6.3">
                          <locus from="74v" to="75r" facs="079">Fols 74v–75r</locus>
                          <title>Hymn for the feast of the forty martyrs, Arba Ḫära sämay, <foreign xml:lang="gez">፵፡ ሐራ፡ ሰማይ፡</foreign>, to be sung on the 13th of Mäggabit</title>
                        </msItem>
                        <msItem xml:id="ms_i1.6.4">
                          <locus from="75r" to="75v" facs="079">Fols 75r–75v</locus>
                          <title>Hymn for Tewoqǝrṭos, zä-Tewoqǝrṭos, <foreign xml:lang="gez">ዘቴዎቅሪጦስ፡</foreign>, to be sung on the sixteenth of Mäggabit</title>
                        </msItem>
                        <msItem xml:id="ms_i1.6.5">
                          <locus from="75v" to="78r" facs="080">Fols 75v–78r</locus>
                          <title>Hymn for the Feast of Saint Mary, Bä‘alä Ǝgzǝ’ǝtǝnä Maryam, <foreign xml:lang="gez">በዓለ፡ እግዝእትነ፡ ማርያም፡</foreign>, to be sung on the 21st of Mäggabit</title>
                        </msItem>
                        <msItem xml:id="ms_i1.6.6">
                          <locus from="78r" to="81r" facs="082">Fols 78r–81r</locus>
                          <title>Hymn for the Feast of the Conception of Our Lord, Tǝsbǝ‘ǝt lä-Ǝgzi’ǝna, <foreign xml:lang="gez">ትስብዕቱ፡ ለእግዚእነ፡</foreign>, to be sung on the twenty-ninth of Mäggabit</title>
                        </msItem>
                      </msItem>
                      <msItem xml:id="ms_i1.7">
                        <locus from="81r" to="8v" facs="085">Fols 81r–8v</locus><title>Fifth Week, Däbrä Zäyt, <foreign xml:lang="gez">ዕዝል፡ ደብረ፡ ዘይት፡ ዘቀዳሚት፡</foreign>, Saturday</title></msItem>
                        <msItem xml:id="ms_i1.8"><locus from="81v" to="92v" facs="086">Fols 81v–92v</locus><title>Sixth Week, Gäbr ḫer, <foreign xml:lang="gez">ገብር፡ ኄር፡</foreign></title>
                        <incipit xml:lang="gez">ገብር፡ ኄር፡ ወገብር፡ ምእመን፡ ገብር፡ ዘአስመሮ፡ ለእግዚኡ፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.9">
                        <locus from="92v" to="104v" facs="097">Fols 92v–104v</locus>
                        <title>Seventh Week, Niqodimos, <foreign xml:lang="gez">ኒቆዲሞስ፡</foreign></title>
                        <incipit xml:lang="gez">ወሀሎ፡ ፩፡ ብእሲ፡ እምፈሪሳውያን፡ ዘስሙ፡ ኒቆዲሞስ፡ ዘሖረ፡ ኀቤሁ፡</incipit>
                      </msItem>
                      <msItem xml:id="ms_i1.10">
                        <locus from="104v" to="118v" facs="109">Fols 104v–118v</locus><title>Eighth Week—Passion Week, Sämunä Ḫǝmamat, <foreign xml:lang="gez">ሰሙነ፡ ሕማማት፡</foreign></title>
                        <msItem xml:id="ms_i1.10.1">
                          <locus from="104v" to="110v" facs="109">Fols 104v–110v</locus>
                          <title>Palm Sunday, Hośa‘na</title>
                          <incipit xml:lang="gez">በዕምርት፡ ዕለት፡ በዓልነ፡ ንፍሑ፡ ቀርነ፡ በጽዮን፡ ወስብኩ፡ <gap reason="omitted"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.10.2"><locus from="110v" to="116v" facs="115">Fols 110v–116v</locus><title>Instructions and hymns for Passion Week</title></msItem>
                        <msItem xml:id="ms_i1.10.3"><locus from="116v" to="118v" facs="121">Fols 116v–118v</locus><title>Holy Sunday [sic, Saturday]</title></msItem>
                      </msItem>
                      <msItem xml:id="ms_i1.11">
                        <locus from="118v" to="122r" facs="123">Fols 118v–122r</locus>

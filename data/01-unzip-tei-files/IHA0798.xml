               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="103v">1r-103v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2077IHA">رتبة ملفقة أربع نشائد للمشائح</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسملة ٬ \ فهاذه ملفّقا ألّفها الرجي رضوان الباقي الشيخ كبير حمزة إبن \ الشيخ حاج كبير محمود إبن  إبن [كذا] الشيخ علي الحرلي الأوسي في فصول مثلّثه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#103v">-103v</locus>وعلى أل محمد الفاتحة إلى أخره صلّ على محمد وعلى أل \ محمد وعلى أواي نبيو نبي اللهم صل على محمد وعلى أل محمد</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="104r" to="117v">104r-117v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2182IHA">نظم لك الحمد يا إله القديم ذي الملك والجبروت
                    الدائم</title>
                     <incipit xml:lang="ar">
                        <locus target="#104r">-104r</locus>بسملة \ لك الحمد يا إله القديم \ ذي الملك والجبروت الد[ا]ئم \ ثم الصلاة على محمد المعصوم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#117v">-117v</locus>في وسط الظلم أقصد حضور \ نعم قد تراى صدق المسطور \ عجبا لو تراى وفد الزوّار</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

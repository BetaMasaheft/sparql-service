                  <decoDesc>
                    <decoNote xml:id="d1" type="miniature">
                      <locus target="#ir #iv" facs="001 002">Fols. ir, iv</locus>
                      <desc>Croses</desc>
                    </decoNote>
                    <decoNote type="frame" xml:id="d2">
                      Decorative designs:
                      <locus target="#16v #18r #19v #25v" facs="018 019 020 027">folss. 16v, 18r, 19v, 25v, </locus>, multiple full stops;
                      <locus target="#27r" facs="028">27r</locus>, multiple full stops and lines of alternating red and black dots</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc>The manuscript has been foliated with stamped, blue numbers. </desc></item>
                      <item xml:id="e2"><desc>The manuscript has been rebound. Quires 1 and 2 have been bound in the wrong order. Folio 2 belongs at the end of the first quire in the original binding, which is currently the second quire as the codex is now bound (see quire map for a reconstruction of the original form of the codex).</desc></item>
                      <item xml:id="e3"><desc><locus target="#ir #iv" facs="001 002">Fols. ir, iv</locus> pen trials, including the copying of a section from 1 Peter.</desc></item>
                      <item xml:id="e4"><desc><locus target="#27v" facs="029">Fol. 27v</locus> alphabet exercises.</desc></item>
                      <item xml:id="e5"><desc>
                        Scribal intervention:
                        words of text are written interlinearly <locus target="#7v #12v #13r #14v #16r" facs="009 014 016 017">folss. 7v, 12v, 13r, 14v, 16r, </locus>, etc.;
                        text has been removed <locus target="#1v #9v #10r #16r #17v" facs="003 011 017 019">1v, 9v, 10r, 16r, 17v</locus>, etc.</desc></item>
                    </list></additions>

                  <bindingDesc>
                    <binding xml:id="binding" contemporary="false">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood, rebound in some disorder, both covers have broken and been repaired.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

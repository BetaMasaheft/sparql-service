               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2v" to="136r">2v-136r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0102IHA">عمدة السالك وعدة الناسك</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>بسم الله الرحمن الرحيم قال الشيخ العالم العلامة شهاب الدين احمد بن النقيب الشافعي رضي الله عنه ورحم سلفه بمنه وكرمه امين الحمد لله رب العالمين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم اجمعين هذ مختصر على مذهب الامام الشافعي رحمه الله اقتصرت فيه على الصحيح من المذهب عند الرافعي والنووي ادا حد هماد قد اذكر فيه خلافا وذلك اذا اختلف تصحيحهما مقدما لتصحيح النوووي فيكون مقابله تصحيح الرافعي وسميته عمدة السالك وعدة الناسك والله اسال ان ينفع به وهو حسبي ونعم الوكيل. كتاب الطهارة
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#136r">-136r</locus>ويقبد وفيما لا يطلع عليه الرجال كالولادة رجلان ورجل وامرتان اوا اربع سنوة والله وتعلى سبحانه وتعلى اعلم</explicit>
                     <note>Some of the words are divided into two different lines</note>
                     <note/>
                  </msItem>
               </msContents>

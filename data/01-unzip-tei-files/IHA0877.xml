               <msContents>
                  <summary>ff. 35v-36v blank</summary>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="5v">1r-5v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2330IHA">خطبة عيد الفطر</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>ألله أكبر تسع مرة \ الله أكبر يرفع باالطاعة أقواما ويضع باالمعصية \ أخرين  ألله أكبر يثيب الصائمين ويعاقب الفاطرين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5v">-5v</locus>فأمّا \ اليتيم فلا تقهر وأمّا السائل فلا تنهر بارك الله لي ولكم  [...]  والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="6r" to="9v">6r-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2331IHA">خطبة الثانية لعيد الفطر</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>ألله أكبر (سبعا) ألله أكبر ما تقرّب عبد \ إلى ربّه باالفريضة وتحبّب إليه باالمندوب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>عباد الله إن الله يأمر باالعدل والإحسان وإى تا إذ القربا وينهى عن الفحشاء والمنكر والبغي يغطكم لعلّكم تذكرون وأستغفرك اللهمّ وأتوب إليك</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="10r" to="16r">10r-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2332IHA">خطبة عيد الأضحى</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>ألله أكبر (تسعا) ألله أكبر ما تحرّكت قلوب الحاج إلى بيت الله الحرام ألله أكبر ما كبّر واولبّوا ولبسوا ثياب \ الإحرام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>كذالك سخّرها لكم لتكبّر والله على ما هدكم \ وبشّر المحسنين بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="16v" to="20r">16v-20r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2333IHA">خطبة الثانية عيد الأضحى</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>ألله أكبر (سبعا) \ ألله أكبر ما ذبح المسلم الضحيّة وجاد في هذه الأيام \ بالصّدقة والهديّة وتقدّم إلى الله بصالح الأعمال وخلو \ ص النيّة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20r">-20r</locus>إنّ الله يأمر باالعدل والإحسان وإيتا إذ القربى وينهى عن الفحشاء والمنكر والبغى يعظكم لعلّكم تذكرون \ أذكرو الله العظيم لي ولكم  [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="20v" to="21r">20v-21r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2334IHA">خطبة لعيد الفطر</title>
                     <incipit xml:lang="ar">
                        <locus target="#20v">-20v</locus>التكبير تسعا مرّاة مواليا \ ألله أكبر أهل الكبر وولي الأمر ملك البرايا باالقوّة \ القاهرة واحتجب عن الأبصار باالقدرة الظاهرة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#21r">-21r</locus>والجبال بأعرافها والطير في مصافها سبحان \ ربك ربّ العزّة عمّا يصفون وسلام على المرسلين والحمد لله \ ربّالعلمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="21v" to="24r">21v-24r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2336IHA">خطبة لعيد الفطر الحمد لله الذي أمدّ الأولياء
                    بالتوفيق</title>
                     <incipit xml:lang="ar">
                        <locus target="#21v">-21v</locus>التكبير تسعا مراة متواليا \ ألحمد لله الذي أمدّ الأولياء بالتوفيق وألهمهم كلمة \ الحقّ والتصديق</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>فأمّا اليتيم \ فلا تقهر وأمّا السائل فلا تنهر بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="24v" to="27r">24v-27r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2331IHA">خطبة الثانية لعيد الفطر</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>ألله أكبر سبعا \ ألله أكبر ما تقرّب عبد إلى ربّه بالفريضة \ وتحبّب إليه باالمندوب ألله أكبر ما فرغ الصائم \ القائم من عبادته</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>عباد الله إن الله يأمر باالعدل والإحسان وإى تا إذ القربا وينهى عن الفحشاء والمنكر والبغي يغطكم لعلّكم تذكرون وأستغفرك اللهمّ وأتوب إليك </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="27v" to="28r">27v-28r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2197IHA">خطبة عيد الفطر الأولى</title>
                     <incipit xml:lang="ar">
                        <locus target="#27v">-27v</locus>ألتكبير تسعا متوالبا \ ألله أكبر كبيرا والحمد لله كثيرا وسبحان الله وبحمده \ بكرة وأصيلا فسبحان الله حين تمسون وحين تصحو \ ن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28r">-28r</locus>ولله على الناس حجّ البيت من استطاع إليه سبيلا \ ومن كفر فاءنّ [كذا] الله غنيّ عن العالمين التكبير ثلثا ألله أكبر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="28v" to="32r">28v-32r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2338IHA">خطبة لعيد الأضحى</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>التكبير تسعا متواليا \ ألله أكبر ما خشعت القلوب وكشفت الكروب وسترت \ العيوب وغفر الذنوب وعفا علّا ما الغيوب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#32r">-32r</locus>وما تفعلوا من خير يعلمه الله \ وتزوّدوا فإنّ خير الزاد التقواى واتّقون يا أولى الأالباب \ بارك الله لي ولكم [...] والبرّ الكريم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="32v" to="35r">32v-35r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2333IHA">خطبة الثانية عيد الأضحى</title>
                     <incipit xml:lang="ar">
                        <locus target="#32v">-32v</locus>التكبير سبعا ألله أكبر \ ألله أكبر ماذيح المسلم الضحّية وجاد في هذه الأيام \ باالصدقة والهديّة وتقدّم إلى الله بصالح الأعمال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#35r">-35r</locus>عباد الله إن الله يأمر باالعد والإحسان وإيتاءذ القربى وينهى عن الفحشاء والمنكر والبغي يعظكم [...] والبرّ الكريم أقم الصلاة</explicit>
                     <note/>
                     <note/>
                  </msItem>

      <body>
         
         <div type="bibliography">
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" subtype="incipit"><note>taken from <ref type="mss" corresp="https://betamasaheft.eu/BAVet44">BAVet44</ref> where the hymn starts at the second stanza</note>
               <lg type="stanza" n="2">
                  <l n="1">....  ቅ፡ ፍትቅ፤ ውስተ፡ አፈ፡ ኵሉ፡ ህልው፨   </l>
                  <l n="2">ማርያም፡ ድንግል፡ ወላዲተ፡ አምላክ፡ ሕያው፨</l>
                  <l n="3">ቅብእኒ፡ እግዝእትየ፡ እመዓዛኪ፡ አፈው፨</l>
                  <l n="4">ዕጣነ፡ ጸሎትየ፡ ይምዓዝ፡ በኵሉ፡ ፍናው፨</l>                
               </lg>
               
               
            </div>
            <div type="textpart" subtype="explicit"><note>taken from <ref type="mss" corresp="https://betamasaheft.eu/BAVet44">BAVet44</ref></note>
               <lg type="stanza">
                  <l n="2">....  ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ ከዋክብት፡ ጽዱል፨  </l>                  
                  <l n="3">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ አዝማናት፡ ወመዋዕል፨</l>
                  <l n="4"> ስብሐተ፡ ድንጋሌኪ፡ ዘልፈ፡ እሰብክ፡ በቃል፨</l>                
               </lg>
               
               
            </div>
         </div>
      </body>
   </text></TEI>
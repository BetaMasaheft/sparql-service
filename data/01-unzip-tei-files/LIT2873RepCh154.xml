      <t:body>
         <t:div type="bibliography">
            
            <t:listBibl type="editions">
               <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl>
               <t:bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename>Marius</t:forename><t:surname>Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><t:citedRange unit="item">154</t:citedRange></t:bibl>
            </t:listBibl>
         </t:div>
         <t:div type="edition" xml:lang="gez">
            <t:div type="textpart" xml:id="malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተተርጐመ፡ በወርቅ፨</t:l>
                  <t:l n="2">ወለሥዕርትከ፡ ሰላም፡ በልሳነ፡ ትጋህ፡ ወጻህቅ፨</t:l>
                  <t:l n="3">ለነቢበ፡ ክርስቶስ፡ ኖብ፡ ሰማዕት፡ ህላዌ፡ ረቂቅ፨</t:l>
                  <t:l n="4">ሳውል፡ ሳውል፡ በብሂል፡ እምሰማየ፡ ጸጋ፡ ምውቅ፨</t:l>
                  <t:l n="5">ተግሣጸ፡ ጸውዖ፡ ይኩነኒ፡ ሀብትከ፡ መብረቅ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለርእስከ፡ ዘአክሊለ፡ ሰማይ፡ ከለሎ፨</t:l>
                  <t:l n="2">ወለብርሃናዊ፡ ገጽከ፡ ዘሰበነ፡ ላህይ፡ ጠብለሎ፨</t:l>
                  <t:l n="3">ለአምላከ፡ ሰማይ፡ ኖብ፡ አመንኩከ፡ ሶበ፡ ትቤሎ፨</t:l>
                  <t:l n="4">ለአጵሎን፡ እደ፡ ኬንያ፨ ዘበአምሳለ፡ ሰብእ፡ ሠዓሎ፨</t:l>
                  <t:l n="5">ቅድመ፡ ዐላውያን፡ ነገሥት፡ አኅሠርከ፡ ኃይሎ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="24">
                  <t:l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ከመ፡ መርዓዊ፡ እምጽርሑ፨</t:l>
                  <t:l n="2">ወለዘገነዘ፡ በድንከ፡ ለዮልዮስ፡ እደ፡ ዚአሁ፨</t:l>
                  <t:l n="3">ለሐመረ፡ ባሕር፡ ኖብ፡ ስቁል፡ ዲበ፡ ሠርዌሁ፨</t:l>
                  <t:l n="4">ተዝካረ፡ ሞትከ፡ መላእክተ፡ ሰማይ፡ ሐራሁ፨</t:l>
                  <t:l n="5">ለእግዚአ፡ ስብሐት፡ ክርስቶስ፡ ይገብሩ፡ ናሁ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="25">
                  <t:l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በመዐዛ፡ ዕፍረት፡ መንክር፨</t:l>
                  <t:l n="2">ወለመቃብሪከ፡ ሰላም፡ ውስተ፡ ንኂሳ፡ ሀገር፨</t:l>
                  <t:l n="3">ክርስቶስ፡ ኖብ፡ ትሩፈ፡ ዕበይ፡ ወክብር፨</t:l>
                  <t:l n="4">ሐውጻ፡ በሣህልከ፡ አመ፡ ዕለተ፡ ደይን፡ ወጻዕር፨</t:l>
                  <t:l n="5">ለኢየሩሳሌም፡ ነፍስየ፡ እምልዑል፡ ጠፈር፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="26">
                  <t:l n="1">አምጣነ፡ አእምሮ፡ ለልብየ፡ ሀብተ፡ መንፈስ፡ ቅዱስ፡ ወሀቦ፨</t:l>
                  <t:l n="2">ሰላመ፡ መልክእከ፡ ነዋ፡ ምስለ፡ ብዙኅ፡ የብቦ፨</t:l>
                  <t:l n="3">ግብረ፡ አምላክከ፡ ኖብ፡ ዘተኣምር፡ በአስተርክቦ፨</t:l>
                  <t:l n="4">ብዙኀሰ፡ እምኔየ፡ እመ፡ ተኀሥሥ፡ አቅርቦ፨</t:l>
                  <t:l n="5">ጸሪቀ፡ መበለት፡ ጥቀ፡ በእዴየ፡ አልቦ፨</t:l>
               </t:lg>
            </t:div>
            <t:div type="textpart" xml:id="tarafa-malke" corresp="https://betamasaheft.eu/LIT2754RepCh38">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለከ፡ ሕፃነ፡ መንክራት፡ ኖብ፡ በእንተ፡ ስሙ፡ ለወልድ፨</t:l>
                  <t:l n="2">ተፈልጦተ፡ ዘመድ፡ አብደርከ፡ በከዊነ፡ ነገድ፨</t:l>
                  <t:l n="3">ከመ፡ ትፍልስ፡ ብሔረ፡ ባዕድ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለከ፡ አመ፡ ከፈሉከ፡ ሐራ፡ ወረሰዩከ፡ ሠለስተ፨</t:l>
                  <t:l n="2">እምተወከፎ፡ ሥቃይ፡ ኵሎ፡ ዕለተ፨</t:l>
                  <t:l n="3">ልብከ፡ ኢተአተተ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ሰላም፡ ለከ፡ እፎ፡ ትትፌሣሕ፡ በእንቲአከ፡ ንኂሳ፨</t:l>
                  <t:l n="2">እስመ፡ ብዝኀ፡ ጌጋይ፡ ኖብ፡ እስመ፡ ቀደሳ፨</t:l>
                  <t:l n="3">ንጽሕከ፡ አክሊለ፡ ርእሳ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሰላም፡ ለከ፡ አምልኮ፡ አማልክት፡ ሰብዓ፡ ተውላጠ፡ መነንከ፡ ኖብ፨</t:l>
                  <t:l n="2">እስመ፡ መልአ፡ ብከ፡ ሀብተ፡ ጥበብ፨</t:l>
                  <t:l n="3">እምሥራቀ፡ ፀሓይ፡ ብሩህ፡ እስከ፡ ምዕራብ፨</t:l>
                  <t:l n="4">አዕበዩከ፡ አሕዛብ፡ ወሕዝብ፨</t:l>
               </t:lg>
            </t:div>
         </t:div>
         
      </t:body>
   </t:text></TEI>
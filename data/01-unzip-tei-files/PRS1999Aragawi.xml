      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">አረጋዊ፡ ሰባጋዲስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">ʾAragāwi Sabagādis</t:persName>
               <t:persName>
                  <t:roleName type="title"> šum ʿagame, daǧǧāzmāč</t:roleName>
               </t:persName>
               <t:occupation type="political">governor</t:occupation>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
     
               
               
               <t:floruit notBefore="1831" notAfter="1873">He was a son of 
                  <t:persName ref="https://betamasaheft.eu/PRS8265Sabagadi">
                     <t:roleName type="title">daǧǧāzmāč</t:roleName> 
                  </t:persName>. 
                  ʾAragāwi Sabagādis inherited claims to the governorship of 
                  <t:placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</t:placeName> after the defeat and death of his father in<t:date>1831</t:date>, 
                  but was only able to establish himself in <t:placeName ref="https://betamasaheft.eu/LOC1236Agama">ʿAgāma</t:placeName>,
                  which he held as his own against <t:persName ref="https://betamasaheft.eu/PRS8265Sabagadi">Sabāgādis Waldu</t:persName> successor
                  
                  <t:persName ref="https://betamasaheft.eu/PRS10102Webeha">
                     <t:roleName type="title">daǧǧāzmāč</t:roleName> 
                  </t:persName> in the <t:date>1840</t:date>'s and <t:date>1850</t:date>'s. 
                  ʾAragāwi Sabagādis was a strong opponent
                  of the early Catholic missionaries, but eventually developed friendly relations with them and with the French counsul at <t:placeName ref="https://betamasaheft.eu/LOC4631Massaw">Mǝṣǝwwaʿ</t:placeName>             
               </t:floruit>
               <t:death when="1873"/>
               
            </t:person>
            
         </t:listPerson>

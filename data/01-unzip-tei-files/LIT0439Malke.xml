      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0439</citedRange></bibl>
            </listBibl>
            
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ አብ፡ ዘበኀበ፡ ኵሉ፡ ውዱስ፨</l>
                  <l n="2">ወበስመ፡ እግዚአብሔር፡ ወልድ፡ ቀዳሴ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="3">ወበስመ፡ እግዚአብሔር፡ አካሎሙ፡ መንፈስ፡ ቅዱስ፨</l>
                  <l n="4">ውዳሴ፡ መልክኦሙ፡ እጽሐፍ፡ ለሰማዕተ፡ አንጾኪያ፡ አልባስ፨</l>
                  <l n="5">ዮስጦስ፡ ወአቦሊ፡ ምስለ፡ ታውክልያ፡ ሐዳስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ነገሥተ፡ ዐባይ፡ አንጾኪያ፨</l>
                  <l n="2">ወለሥዕርትክሙ፡ ሰላም፡ በዓለመ፡ ስምዕ፡ ፡ እለበልያ፨</l>
                  <l n="3">መምክረ፡ ነገሥ፡ ዮስጦ፡ ወአቦሊ፡ ለምስለ፡ እምከ፡ ታውክልያ፨</l>
                  <l n="4">ዕቀቡነ፡ ለሕዝበክሙ፡ እምነ፡ ሀኬት፡ ጕህልያ፨</l>
                  <l n="5">ከመ፡ ንዘምር፡ ለክሙ፡ በሃሌ፡ ወሉያ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለመቃብሪክሙ፡ መቃብረ፡ አዳም፡ ጸባብ፨</l>
                  <l n="2">ወለተንሣኤክሙ፡ ድኅረ፡ አመ፡ ቀርነ፡ ሚካኤል፡ ይትነበብ፨</l>
                  <l n="3">ዮስጦስ፡ ወአቦሊ፡ ወታውክልያ፡ ጠባብ፨</l>
                  <l n="4">አውፅእዋ፡ ለሕይወትነ፡ እም፡ ሕይወተ፡ ዓለም፡ ርሑብ፨</l>
                  <l n="5">ወኀበ፡ ገነት፡ አብእዋ፡ በሠናይ፡ ከብካብ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">እምድኅረ፡ ኀለፍኮ፡ ዮስጦስ፡ መኒነከ፡ ዕበያ፨</l>
                  <l n="2">ለመንግሥተ፡ ክብርከ፡ ሮምያ፨</l>
                  <l n="3">ዘአክሐዶሙ፡ ለሕዝብ፡ ብእሴ፡ ወለትከ፡ ህንጥርብያ፨</l>
                  <l n="4">ወላዴ፡ አቦሊ፡ ዮስጦስ፡ ዘተዋሕዶ፡ ሐዋርያ፨</l>
                  <l n="5">ደናግል፡ ለጽድቅከ፡ በኵሉ፡ ገነያ፨</l>
               </lg>
            </div>
         </div>
      </body>

         <t:div type="edition">
            <t:div type="textpart" xml:id="MainPart">
               <t:label>Main part</t:label>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab>
                  ንቀድም፡ በረድኤተ፡ እግዚአብሔር፡ መጽሐፈ፡ ልደቱ፡ ለአቡነ፡ <t:gap reason="omitted"/> ወልደ፡ እግዚአብሔር፡ በጸጋ፡ ወወልደ፡ አዳም፡ በሥጋ፡
               </t:ab>
               </t:div>
               <t:div type="textpart" subtype="explicit" xml:lang="gez">
                  <t:ab>
                  በስምዐ፡ ፪ወ፫ሰማዕት፡ ይቁም፡ ኵሉ፡ ነገር። ትንብልናሁ፡ ለአቡነ፡ <t:gap reason="omitted"/> ወእምጋኔነ፡ ቀትር፡ በኵሉ፡ ሰዓት፡ <t:gap reason="omitted"/> አሜን።
               </t:ab>
               </t:div>
            </t:div>
            <t:div type="textpart" xml:id="Epilogue">
               <t:label>Epilogue</t:label>
               <t:div type="textpart" subtype="incipit" xml:lang="gez">
                  <t:ab>
                     በትእዛዘ፡ አቡነ፡ ጴጥሮስ፡ <t:gap reason="omitted"/> ዘበገድል፡ ሠናይ፡ ፈጸመ፡ ሑረቶ፡ <t:gap reason="omitted"/> 
                  </t:ab>
               </t:div>
            </t:div>
         </t:div>

                        <item xml:id="a9_395">
                           <locus target="#114r">-114r</locus>
                           <q xml:lang="ar">اعلم وفقنا الله واياك للخوف ان الخوف من الله اعظم النعم اذا انعم اه تحفة</q>
                           <desc>Marginalia</desc>

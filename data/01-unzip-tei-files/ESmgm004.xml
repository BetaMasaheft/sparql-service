                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful, by a well trained hand.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>Mid-17 - mid-18th century.</date>
                        <seg type="rubrication">Incipit of all texts (red lines alternating with
                           black lines); two initial lines of all sections; the word kǝfl "section"
                           and section numbers; elements of the punctuation signs and text dividers;
                           Ethiopic numerals in Text XXIII (esp. fols. 126r); elements of Ethiopic
                           numerals throughout the Ms.</seg>
                     </handNote>
                  </handDesc>

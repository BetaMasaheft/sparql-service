                    <desc>etc., words of text are written interlinearly</desc>
                    </item>
                    <item xml:id="e2">
                      <locus target="#10v #52v #58r #104r #136r" facs="015 057 062 108 140">Fols. 10v, 52v, 58r, 104r, 136r</locus>
                      <desc>etc., lines of text are written interlinearly</desc>
                    </item>
                    <item xml:id="e3">
                    <locus target="#21v" facs="026"> f. 21v, line 7</locus>
                    <locus target="#47r" facs="051"> f. 47r, line 14</locus>
                    <locus target="#89r" facs="093"> f. 89r, line 14</locus>
                    <desc>
                    lines of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted (21v), and in another case where the symbol (+) is used (47r; 89r);
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <locus target="#53r #76r #78r #79v" facs="057 080 082 084">Fols. 53r, 76r, 78r, 79v</locus>
                    <desc>etc., erasure markings are visible</desc>
                    </item>

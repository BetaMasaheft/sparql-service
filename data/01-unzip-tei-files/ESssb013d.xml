               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">20.0</measure> folios, in <measure unit="quire"/> quires . <dimensions type="outer">
                              <height unit="mm">360</height>
                              <width unit="mm">330</width>
                              <depth unit="mm">20</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">The quire structure cannot be established due to the
                                 condition of the Ms.</item>
                           </list>
                        </collation>
                        <condition key="deficient">Most of the fols. and the binding are missing.
                           
 The fols. are crudely held together with a recent thread.
 The
                           fols. are damaged by fire along the spine (<locus target="#13v">13v</locus>, 14v).
 Many fols are affected by water.
 f. 1 is
                           mutilated at the lower, inner corner with minor text loss.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="3" writtenLines="35">
                           <dimensions unit="mm">

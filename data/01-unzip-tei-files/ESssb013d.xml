               <msContents>
                  <summary>I) Haymanotä ʾabaw “Faith of the Fathers” (fols. 1ra-20vc),
                     incomplete.</summary>
                  <msItem xml:id="ms_i1">

                     <incipit>
                        <foreign xml:lang="en"/>
                     </incipit>

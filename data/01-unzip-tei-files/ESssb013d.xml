                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine and regular.</seg>
                        <seg type="ink">Black, red (vivid vermillion)</seg>
                        <date>Early 19th century.</date>
                        <seg type="rubrication">Nomina sacra; two lines on the incipit of every
                           section; elements of the punctuation signs; elements of Ethiopic
                           numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Small, round letters with week
                        shading.</handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">- The scribe sometimes wrote in the intercolumn space: fols. 6vb, 6vc, 8ra, 8rb, 8rc. - Compressed script: <locus target="#11rc">fol.  11rc</locus>.</item>
                     </list>
                  </additions>

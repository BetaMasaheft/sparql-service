      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ አብ፡ ምስለ፡ መንፈሱ፡ ወቃሉ፨</l>
                  <l n="2">ወምስለ፡ ማርያም፡ ድንግል፡ ሕይወተ፡ ዓለማት፡ ኵሉ፨</l>
                  <l n="3">እንብብ፡ ለከ፡ ፊቅጦር፡ ለመልክዕከ፡ ይደሉ፨</l>
                  <l n="4">ውዳሴ፡ ወዝማሬ፡ በበአርአያሁ፡ ወክፍሉ፨</l>
                  <l n="5">ለአፈ፡ ዚአየ፡ ይከውን፡ ክሂሉ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለጽንሰትከ፡ እምዘርዓ፡ ኅሩይ፡ እስጢፋኖስ፨</l>
                  <l n="2">ወለልደትከ፡ ክቡር፡ እምጽዮን፡ ክብራ፡ ንጽሕተ፡ ከርሥ፨</l>
                  <l n="3">በአፈ፡ መላእክት፡ ፊቅጦር፡ ዘትትበፃዕ፡ ወትትዌደስ፨</l>
                  <l n="4">ከመ፡ እንግር፡ ዕበየከ፡ በልሳነ፡ ሥጋ፡ ወነፍስ፨</l>
                  <l n="5">ወይነ፡ መንፈስ፡ ቅዱስ፡ ይቅሊ፡ በልብየ፡ የብስ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምነ፡ ዝክረ፡ ወይን፡ ዘይጥዕም፨</l>
                  <l n="2">ወለሥዕርተ፡ ርእስከ፡ ሰላም፡ እምቆብዓተ፡ ደነስ፡ ኅሩም፨</l>
                  <l n="3">ደመና፡ በረከት፡ ፊቅጦር፡ ውስተ፡ ገጸ፡ ኵሉ፡ ዓለም፨</l>
                  <l n="4">ይሥርፅ፡ እምልሳንየ፡ በረድኤትከ፡ ዝናም፨</l>
                  <l n="5">ጽጌያተ፡ ስብሐት፡ ወማኅሌት፡ ፍጹም፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በአፈወ፡ ሃይማኖት፡ ወቅድስና፨</l>
                  <l n="2">ወለመቃብሪከ፡ ዲበ፡ ቢጸ፡ ገሪዛን፡ ወእዝተ፡ ሲና፨</l>
                  <l n="3">ብፁዓዊ፡ ፊቅጦር፡ ወእኩት፡ በምንኩስና፨</l>
                  <l n="4">ነሢአከ፡ እምልሳንየ፡ ዘመልክዕከ፡ መኃና፨</l>
                  <l n="5">እምዓውደ፡ ሕይወትየ፡ አርኅቅ፡ መንፈስ፡ ሙስና፨</l>
               </lg>
               <lg type="stanza" n="28">
                  <l n="1">ሰላም፡ ለልብስከ፡ ልብሰ፡ ምንኩስና፡ ዘእንጦኒ፨</l>
                  <l n="2">ከመ፡ ልብሰ፡ ድንግል፡ ማርያም፡ ወላዲተ፡ ክርስቶስ፡ መድኃኒ፨</l>
                  <l n="3">ኀዳጌ፡ በቀል፡ ፊቅጦር፡ ወፍትወተ፡ ዓለም፡ መናኒ፨</l>
                  <l n="4">እመሰ፡ አእምሮ፡ ሶበ፡ ትውኅበኒ፨</l>
                  <l n="5">እምአፍቅሮ፡ ዓለም፡ ኪያከ፡ አፍቅሮ፡ ዘይሤኒ፨</l>
               </lg>
               <lg type="stanza" n="29">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ ለመልክዕከ፡ በኢፍሉጥ፨</l>
                  <l n="2">ዘአርአያሆን፡ ጽጌ፡ ወዘሐቅለ፡ ቀላይ፡ ሠግላጥ፨</l>
                  <l n="3">ነጋዴ፡ ሕይወት፡ ፊቅጦር፡ በዕፍረተ፡ ፃማ፡ ወቍስጥ፨</l>
                  <l n="4">ይትከዓው፡ ውስተ፡ አፉየ፡ አምኆትየ፡ ኅዳጥ፨</l>
                  <l n="5">ዕሤተ፡ መካልዩ፡ ያርብህ፡ በዳግም፡ ምስያጥ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ስብሐት፡ ለአብ፡ ምስለ፡ መንፈሱ፡ ወወልዱ፨</l>
                  <l n="2">ወምስለ፡ ማርያም፡ ጳጦስ፡ እንተ፡ ኢያርስና፡ ዋዕየ፡ ነዱ፨</l>
                  <l n="3">ዘኀረየከ፡ ፊቅጦር፡ ከመ፡ ትኵኖ፡ ፃማዱ፨</l>
                  <l n="4">ባርኮሙ፡ ለደቂቅከ፡ ዘበድክትምና፡ ለመዱ፨</l>
                  <l n="5">በጸጋ፡ ዚአከ፡ ከመ፡ ይፈድፍዱ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">በዘባኑ፡ ወበእንግድዓሁ፡ ጸዊሮ፡ አዕባነ፡ ክልኤተ፨</l>
                  <l n="2">በተግባረ፡ ሰጊድ፡ ፃመወ፡ በኢያዕርፎ፡ ንስቲተ፨</l>
                  <l n="3">ፊቅጦር፡ ንጹሕ፡ እንተ፡ ኢየአምር፡ ርስሐተ፨</l>
                  <l n="4">እማዕከለ፡ ሰምዕ፡ ያወጽእ፡ እሳተ፨</l>
                  <l n="5">ናሁ፡ አርአየ፡ መንክራተ፡ በእስትንፋሱ፡ ያፀድል፡ ማኅቶተ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ሰላም፡ ለክሙ፡ ሠርፀ፡ ጊዮርጊስ፡ ዕጉሥ፨</l>
                  <l n="2">ዘርአ፡ ነቢያት፡ ማእምር፡ ወብእሲ፡ ልብው፡ ቴዎድሮስ፨</l>
                  <l n="3">ሐሊበ፡ ፀሓይ፡ ፊቅጦር፡ ለባሴ፡ ዐቢይ፡ ሞገስ፨</l>
                  <l n="4">አምኃ፡ መስቀል፡ የማነ፡ ክርስቶስ፨</l>
                  <l n="5">ቅድመ፡ መንበሩ፡ ጸልዩ፡ ለአምላክ፡ ንጉሥ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
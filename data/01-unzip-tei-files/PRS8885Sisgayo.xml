         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሲስጋዮ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Sisgāyo</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">ኤሩታኖ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾErutāāno</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="alt">አሩታኖ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">ʾArutāāno</t:persName>
            
               <t:persName>
                  <t:roleName type="title">tāto</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
        
                  <t:occupation type="political">ruler</t:occupation>
             
               <t:floruit notBefore="1619" notAfter="1630">He was the ruler of the then Gongā speaking of 
                  <t:placeName ref="https://betamasaheft.eu/LOC2966Ennary">ʾƎnnāryā</t:placeName> 
                  in the time of the
                  <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos"> 
                     <t:roleName type="title">ʾaṣe</t:roleName> Susǝnyos</t:persName>. 
                  He was the  successor of 
                  <t:persName ref="https://betamasaheft.eu/PRS2649Benaro">
                     <t:roleName type="title">tāto</t:roleName> Benāro</t:persName>.</t:floruit>             
               <t:death when="1632">He was killed by the son of <t:persName ref="https://betamasaheft.eu/PRS2649Benaro">Benāro</t:persName> in <t:date>1632</t:date>.</t:death>
               </t:person>
               
         </t:listPerson>
         

            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0091AQM">ʾAgarhǝse ʾAbuna Māmās</repository>
                  <collection>Ethio-SPaRe</collection>
                  <idno facs="AQM/010/AQM-010" n="115" corresp="https://betamasaheft.eu/api/iiif/ESaqm010/manifest">AQM-010</idno>
               </msIdentifier>
               <msContents>
                  <summary>I) Maṣḥafa gǝnzat “Book of the Funeral Ritual” (fols. 1r-70v, 105v-111v),
                     incomplete
 - Homily by ʾabbā Salāmā, Metropolitan of Ethiopia (fols.
                     21v-25v)
 - Homily by St Jacob of Serug for the funeral of priests and
                     deacons (fols. 40r-46r)
 II) Śǝrʿāta mǝnkʷǝsǝnnā “The Order of the Monastic
                     Profession” (fols. 71r-105v), incomplete.</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="70v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1931Mashaf">Maṣḥafa gǝnzat (general record)</title>
                     <note/>
                     <msItem xml:id="ms_i1.1">
                        <locus from="21v" to="25v"/>
                        <title ref="https://betamasaheft.eu/LIT1644Homily">Homily by ʾabbā Salāmā, Metropolitan of
                           Ethiopia</title>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="40r" to="46r"/>
                        <title ref="https://betamasaheft.eu/LIT1629Homily">Homily by St Jacob of Serug for the funeral of
                           priests and deacons</title>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="71r" to="105v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3982Serata">Śǝrʿāta mǝnkʷǝsǝnnā</title>
                     <note>Text II, Śǝrʿāta mǝnkʷasǝnnā “The Order of the Monastic Profession”, has
                        similar readings with <bibl corresp="http://zotero.org/groups/358366/items/4VBK3EJJ"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Grebaut1940Habit"/><title level="m">Rituel éthiopien pour la prise d’habit</title><author><forename>Sylvain</forename><surname>Grébaut</surname></author><pubPlace>Paris</pubPlace><publisher>Firmin-Didot</publisher><date>1940</date><note type="tags"><note type="tag">bm:Grebaut1940Habit</note></note><note type="tag">bm:Grebaut1940Habit</note></bibl> but the order appears
                        completely different. <locus target="#85r">85r</locus> (ጸሎት፡ እምድኅረ፡ አቅነትከ)
                        matches with p. 10 of the edition (ጸሎት፡ ሶበ፡ ያቀንቱ፡ መነኮሳት); <locus target="#85r">85r</locus> matches p. 14 of the edition (ጸሎት፡ ላዕለ፡ ደናግል)
                        .</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="105v" to="111v"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1931Mashaf">Maṣḥafa gǝnzat (general record)</title>
                     <note/>
                  </msItem>
                  
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">111.0</measure> folios, in <measure unit="quire"/> quires (Impossible to determine.). <dimensions type="outer">
                              <height unit="mm">150</height>
                              <width unit="mm">125</width>
                              <depth unit="mm">70</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
Because the sewing is completely
                                 destroyed it is impossible to determine the quire structure.
                                 Centre folds of the quires might be between fols. <locus from="57v" to="58r"/>, <locus from="69v" to="70r"/>,
                                 <locus from="80v" to="81r"/>, <locus from="95v" to="96r"/>, <locus from="108v" to="109r"/>.

                        </collation>
                        <condition key="deficient">The Ms. is in very poor condition: it is worn and
                           heavily damaged by insects and water.
 The front board and a half of
                           the back board are missing. 
 The sewing is completely
                           destroyed.
 The Ms. has lost many fols. at the beginning and at the
                           end. Many fols. are misplaced (e.g., <locus target="#27v"/>
                           should have been followed by <locus target="#29r"/>; <locus target="#45v"/> should have been followed by <locus target="#39r"/>).
 The rest of the fols. are severaly
                           damaged.
 Text abraded on <locus target="#99r"/>.
 A
                           hole is repaired on <locus target="#45r"/>.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" writtenLines="20">
                           <dimensions unit="mm">
                              <height>114</height>
                              <width>86</width>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">14</dim>
                              <dim type="bottom">20</dim>
                              <dim type="right">23</dim>
                              <dim type="left">11</dim>
                              <dim type="intercolumn"/>
                           </dimensions>
                           <note>All data for <locus target="#27r">27r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible (e.g., <locus target="#40">40</locus>, 42). </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Ruling pricks are visible.</ab>
                           <ab type="ruling"> The upper line is written below the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                        </layout>
                        <layout>
                           <ab type="CruxAnsata">Crux ansata accompanied by coronis sign on fol. 103r; Christogram on fols. .
                              32v, 79v, 80r, 81r, 109r, 109v, 110r, 110v, 111r
                           </ab>
                           <ab type="coronis"> Coronis sign is used on fols. 11v, 30v, 52v, 81v, 82r, 110r; zǝya-sign accompanied by coronis on fol. 17v.
                              
                           </ab>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, careful</seg>
                        <seg type="ink">Black, red (vivid red)</seg>
                        <date>First half of the 15th century</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ይ፡ ካ፡</abbr> for <expan>ይበል፡ ካሕን፡ </expan> (e.g., <locus target="#8r">8r</locus>, 9r, 26r)</item>
                           <item>
                              <abbr>ይ፡ ሕ፡</abbr> for <expan>ይበል፡ ሕዝብ፡ </expan> (e.g., <locus target="#8r">8r</locus>, 9r, 10r)</item>
                           <item>
                              <abbr>ይ፡ ዲ፡</abbr> for <expan>ይበል፡ ዲያቆን፡ </expan> (<locus target="#8r">8r</locus>, 9r)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donor and Metropolitan
                           ʾabbā Bartolomewos; two initial lines of each section of the text;
                           elements of the punctuation signs; Ethiopic numerals; some other words,
                           e.g., ʾǝgale (e.g., fols. 6v,9r, 11v), qǝdma wangel (e.g., fols. 32v,
                           35r, 48v), wa-tǝbl (e.g., fols. 32r, 62r, 68v), ʾǝska (e.g., fols. 47r,
                           51r).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Notes in the upper margins written in red,
                              referring to the content of the text (partly unreadable): fols. 12r,
                              12v, 21v, 30v, 30r, 34r, 49v, 50v, 51r. on fols. 30v, 31r the notes
                              are placed horizontally.</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>- Corrections written vertically in the outer margin: fols. 25v, 37v, 86r, 105v. </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>A space (for rubricated names or punctuation signs?) filled with three horizontal red lines: <locus target="#35r">fol.  35r</locus>. </desc>
                        </item>
                        <item xml:id="e4">
                           <desc>A space left unfilled: <locus target="#56r">fol.  56r</locus>. </desc>
                        </item>
                        <item xml:id="e5">
                           <desc>Writing exercises: fols. 54r, 73r, 82v, 96v, 110r.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding>
                        <decoNote xml:id="b1">Two wooden boards (the front board and a half of the
                           back board are missing).
 One pair of sewing stations (?), or
                           possibly three sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="SewingStations" cert="low">2</decoNote>
                     </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origPlace>
                        <placeName ref="https://betamasaheft.eu/INS0091AQM">ʾAgarhǝse ʾAbuna Māmās</placeName>
                     </origPlace>
                     <origDate notBefore="1398" notAfter="1438">The Metropolitan ʾabbā Bartolomewos
                        is mentioned on <locus target="#9r">9r</locus>. Bartolomewos came to
                        Ethiopia in 1398/99 A.D. as a successor of ʾabuna Salāma II “the Translator”
                        and died around 1438. </origDate>
                  </origin>
                  <provenance>The donor priest Kāhǝn Maksimos is mentioned in the supplication formulas
                     throughout the Ms. (see <locus target="#43v">43v</locus>). Kāhǝn Maksimos may be identical to ʿaqābe saʿāt
                     Maksimos (s. EAE II, 30a).</provenance>
               </history>

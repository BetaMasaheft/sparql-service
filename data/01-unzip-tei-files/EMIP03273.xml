         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3273/" n="186" corresp="https://betamasaheft.eu/api/iiif/EMIP03273/manifest">Antippas 23</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter of the Virgin, mentioning <persName ref="https://betamasaheft.eu/PRS10375Yohanne">Yoḥannǝs I</persName> and <persName ref="https://betamasaheft.eu/PRS8870Sinoda">Sinodā</persName></summary>
                  <msItem xml:id="ms_i1">
                    <locus from="7r" to="166v" facs="007"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="7r" to="131v" facs="007"/><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref> employs the older system of spiritual meanings for the Hebrew letters.  This is a good example</note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151">Mazmura Dāwit, Psalmus 151</ref> has only the first of the four plusses that make up the long version, i.e, the word <foreign xml:lang="gez">ወአድኃኒ፡</foreign></note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="132r" to="144v" facs="132"/><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>The superscription to the fourth biblical canticle, <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah">The Prayer of Hannah, mother of Samuel the Prophet,  Hannah</ref>, is <q>“Prayer of Hana, mother of Samuel.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="144v" to="151v" facs="145"/><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Common edition</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="152r" to="162v" facs="152"/><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>Arranged for the days of the week, laid out beginning on Monday and culminating on Sunday</note>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="162v" to="166v" facs="163"/><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2"><locus from="167r" to="178r" facs="167"/><title>Morning Prayers and Supplications </title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
               </msContents>

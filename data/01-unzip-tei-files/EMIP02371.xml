                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <ref target="#ms_i1.1 #ms_i1.2 #ms_i1.3"/>
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  <ref target="#ms_i1.4 #ms_i1.5"/>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>Columetric layout of text: <locus target="#118r" facs="120">fols. 118r, </locus> (Psalm 148); <locus target="#119r" facs="121">119r, </locus> (Psalm 150); <locus target="#127r #127v" facs="129 130">127r, 127v</locus> (Tenth Biblical Canticle)</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc>crude drawing of a face</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc>crude drawing of an <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> and figuresd</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1066DavidHarp">David Playing the Harp</ref>. This illumination is likely original</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#20v" facs="023">Fol. 20v</locus><desc>Jesus with the Apostles</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#98v" facs="101">Fol. 98v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="frame" xml:id="d6">
                    Decorative designs:
                    <locus target="#1r #8r #15r #23r #33v #41r #56r #66v #74v #80r #93r #105r #108r #114r #119v #137r" facs="003 010 017 025 036 043 058 069 077 082 095 107 110 116 122 139">folss. 1r, 8r, 15r, 23r, 33v, 41r, 56r, 66v, 74v, 80r, 93r, 105r, 108r, 114r, 119v, 137r, </locus> (ornamental band, most of which are secondary);
                    <locus target="#55v #113v #130v #141r #142r #146r" facs="058 116 133 143 144 148">55v, 113v, 130v, 141r, 142r, 146r, </locus> (line of alternating red and black dots);
                    <locus target="#79v #143v" facs="082 146">79v, 143v, </locus> (multiple full stops and a line of black dots);
                    <locus target="#137v #139v #142v #146r" facs="140 142 145 148">137v, 139v, 142v, 146r</locus> (multiple full stops)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    Throughout the book, the number 10 (፲) marks every tenth line, as though an audit of the strophes were being performed
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    note in a secondary hand, a curse on one who steals or damages the book
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus>
                    note in a secondary hand. The text is badly faded, although it seems to be a curse on one who steals or damages the book. Written in purple ink
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc>
                    <locus target="#iir(ecto):" facs="002">Fol. iir(ecto):</locus>
                    note in a secondary hand, a curse on one who steals or damages the book. There are also a number of scrawls and pen trials
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#30r" facs="032">Fol. 30r</locus>
                    an illegible seal in purple ink
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#33v" facs="036"> f. 33v, bottom</locus>
                    note in a secondary hand. Written in black ink
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc>
                    <locus target="#47r" facs="049"> f. 37r, top</locus>
                    note in a secondary hand, a curse on one who steals or damages the book
                    </desc>
                    </item>
                    <item xml:id="e4">
                    <desc>
                    <locus target="#62r" facs="064">Fol. 62r</locus>
                    The midpoint of the Psalms is marked by writing the strophe in red ink
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    <locus target="#103r" facs="105"> f. 103r, bottom</locus>
                    note in a secondary hand that mentions Wälättä Sänbät (<foreign xml:lang="gez">ወለተ፡ ሰንበት፡</foreign>). Written in blue ink
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <desc>
                    <locus target="#145v" facs="148"> f. 145v, bottom</locus>
                    a notice of condemnation: "If anyone says that this Psalms is bad, let his two eyes be blinded.” Written in blue ink
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <desc type="OwnershipNote">
                    <locus target="#146r" facs="148">Fol. 146r</locus>
                    a notice of ownership, complete with musical notation.  The owner's name is ʾÄläqa Märʿawi (<foreign xml:lang="gez">አለቃ፡ መርዓዊ፡</foreign>). His city is Gǝšen (<foreign xml:lang="gez">ግሼን፡</foreign>). His residence is in Däbrä Bǝrhan (<foreign xml:lang="gez">ደብረ፡ ብርሃን፡</foreign>)
                    </desc>
                    </item>
                    <item xml:id="a8">
                    <desc type="OwnershipNote">
                    <locus target="#146r" facs="148"> f. 146r, bottom</locus>
                    note of ownership in a secondary hand. Written in blue ink
                    </desc>
                    </item>
                    <item xml:id="a9">
                    <desc>
                    <locus target="#146v" facs="149"> f. 146v, left</locus>
                    note in a secondary hand, a curse on one who steals or damages the book
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#146v" facs="149"> f. 146v, right</locus>
                    pen trials and scrawls
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    <locus target="#74 #130" facs="076 132">Fols. 74, 130</locus>
                    green thread stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e7">
                    <desc>
                    <locus target="#80 #93 #114" facs="082 095 116">Fols. 80, 93, 114</locus>
                    purple thread stitched into corner as navigation system
                    </desc>
                    </item>
                    <item xml:id="e8">
                    <desc>
                      words of text are written interlinearly (<locus target="#29v #31r #33r #49v #50r" facs="032 033 035 052">folss. 29v, 31r, 33r, 49v, 50r, </locus>, etc.);
                      lines of text are written interlinearly (<locus target="#2r #64v #68v #93v" facs="004 067 071 096">2r, 64v, 68v, 93v, </locus>);
                      text has been removed (<locus target="#2r #31r #33r #49v #62r" facs="004 033 035 052 064">2r, 31r, 33r, 49v, 62r</locus>, etc.)
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Parchment, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood covered with tooled leather, fabric visible between the turn-ins, headband and tailband visible.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                        <material key="textile"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>

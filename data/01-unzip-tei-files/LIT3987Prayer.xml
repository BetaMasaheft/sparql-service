               <t:ab xml:lang="gez">በስመ፡ አብ፡ <t:gap reason="ellipsis" resp="PRS10171Wright"/>
                  ጸሎት፡ ዘጸለየት፡ አመ፡ ዓሠርቱ፡ ወስድስቱ፡ ለየካቲት፡ ወበዛቲ፡ ዕለት፡ ካዕበ፡ ይገብሩ፡ ኵሎሙ፡ ዘመደ፡
                  ክርስ<t:choice>
                     <t:sic resp="DR">ታ</t:sic>
                     <t:corr resp="DR">ቲ</t:corr>
                  </t:choice>ያን፡
                  በዓለ፡ ለእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ። በዘነሥአት፡ ቦቱ፡ ኪዳነ፡ ምሕረት፡ እምወልዳ፡ መድኃኒነ፡ ኢ'፡ ክ'።
                  ለዘይገብር፡ ተዝካራ፤ ወለዘይጼውዕ፡ ስማ፤ ወለዘይሁብ፡ ምጽዋተ፡ ለነዳያን፡ እስክ፡ ማይ፡ ቈሪር።</t:ab>

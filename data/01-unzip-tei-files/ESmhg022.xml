                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful</seg>
                        <seg type="ink">Black, vivid red, reddish-brown</seg>
                        <date>Second half of 19th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይካ፡ ንፍቅ፡ for ይብል፡ ካህን፡ ንፍቅ፡</item>

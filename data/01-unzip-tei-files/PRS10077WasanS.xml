      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ወሰን፡ ሰገድ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Wasan Sagad</t:persName>
              
               <t:persName>
                  <t:roleName type="title">rās</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">governor</t:occupation>
               <t:birth notBefore="1470" notAfter="1479">He was born in 
                  <t:date>1470</t:date>s at <t:placeName ref="https://betamasaheft.eu/LOC3061Fataga">Faṭagār</t:placeName>. </t:birth>
               <t:floruit notBefore="1494" notAfter="1531">He was a powerful noble during the reigns of 
                  
                  <t:persName ref="https://betamasaheft.eu/PRS7481NaodA">
                     <t:roleName type="title">ʾaṣe</t:roleName>  Nāʿod</t:persName> 
                  and
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe"> 
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>.
                  In the time of 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>, <t:persName ref="https://betamasaheft.eu/PRS10077WasanS">Wasan Sagad</t:persName>
                  became a leading member of the court council who held the title
                  of <t:persName ref="https://betamasaheft.eu/PRS10077WasanS">
                     <t:roleName type="title">grā bitwaddad</t:roleName> 
                  </t:persName>. 
                  However, <t:persName ref="https://betamasaheft.eu/PRS10077WasanS">Wasan Sagad</t:persName>
                  lost the dignity of  <t:persName ref="https://betamasaheft.eu/PRS10077WasanS">
                     <t:roleName type="title">rās  bitwaddad</t:roleName> 
                  </t:persName>
                  in <t:date>1524</t:date> when 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName> in a suprise reshuffle of several leading state offices.
                  But he remained loyal to 
                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName> Lǝbna Dǝngǝl</t:persName>
                  and fought against the Muslim leader <t:persName ref="https://betamasaheft.eu/PRS1500Ahmad">ʾAḥmad</t:persName> in <t:date> 1529</t:date>. During such turbulent time, 
                  he was also very concerned with the personal safety of                  <t:persName ref="https://betamasaheft.eu/PRS6229LebnaDe">
                     <t:roleName type="title">ʾaṣe</t:roleName>
                      Lǝbna Dǝngǝl</t:persName>.  </t:floruit>
               
               <t:death when="1531"> He died at the battle of <t:placeName ref="https://betamasaheft.eu/LOC2054Bwsat">B-w-sāt</t:placeName> in 
                  <t:placeName ref="https://betamasaheft.eu/LOC3061Fataga">Faṭagār</t:placeName>. </t:death>
            </t:person>
            
         </t:listPerson>

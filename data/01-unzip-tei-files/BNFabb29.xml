                                 <textLang mainLang="gez"/>
                                 <incipit xml:lang="gez">
                                   <hi rend="rubric">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘእንበለ፡ ቀዲም፡ ህላ</hi>ዌሁ፡ ወታድኅኖ፡ በግፃዌሁ፡ ይትረአይ፡
                                   ዘአስተዋደደ፡ ምክሮ፨ በጠፈረ፡ በረድ፡ ወነድ፡ ዘሐነጸ፡ ማኅደሮ፡</incipit>
                               </msItem>

                               <msItem xml:id="p1_i1.2">

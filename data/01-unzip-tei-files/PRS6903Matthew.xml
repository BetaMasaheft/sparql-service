               <persName xml:lang="gez" xml:id="n1">ማቴዎስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Mātewos I</persName>
               <persName xml:lang="en" corresp="#n1">Matthew I</persName>
               <t:occupation xmlns:t="http://www.tei-c.org/ns/1.0" type="ecclesiastic">Patriarch </t:occupation>
               <death when="1408">1408</death>
               <t:faith xmlns:t="http://www.tei-c.org/ns/1.0" type="Coptic"/>
               <t:floruit xmlns:t="http://www.tei-c.org/ns/1.0">He was a patriarch of Alexandria from 1378 until his death and a contemporary of ʾaḍe <persName ref="https://betamasaheft.eu/PRS3429DawitII">Dāwit</persName> and 
                  <persName ref="https://betamasaheft.eu/PRS8387SalamaI"> ʾabbā Salāmā</persName> with whom he maintained relations.  There is a depiction of him in the church 
                  of <placeName ref="https://betamasaheft.eu/LOC2298DabraM">Dabra Maʿār</placeName> as well as a hagiographic composition in his honour presereved in 
                  the manuscript <ref type="mss" corresp="https://betamasaheft.eu/EMML8071">EMML 8071</ref>.</t:floruit>
            </person>
         </listPerson>

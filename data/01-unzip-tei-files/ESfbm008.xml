                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, but careful.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>20th century.</date>
                        <seg type="rubrication">Nomina sacra; name of the protagonist and other
                           saints; names of the donors; incipit of Texts I and III and their
                           sections; word salām in Text II; elements of the punctuation signs;
                           elements of Ethiopic numerals. 
 On the incipit page of Texts I, II,
                           III (fols. 4r, 57r, 61r), a few lines are rubricated (alternating with
                           black lines).</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Hand a: <locus from="4r" to="67v">4r-67v</locus> (quires
                        I-VII).</handNote>
                     <handNote xml:id="h3" script="Ethiopic"> Hand b: <locus from="61r" to="66v">61r-66v</locus> (quire
                        VIII).</handNote>
                  </handDesc>

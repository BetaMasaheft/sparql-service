                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="14r">1r-14r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1956IHA">تخميس لامية ابن الوردي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>وهذا لاميّا \ بسملة \ لا إلاه إلّا الله [۳] سبحانه عزّ وجلّ \ أيها المغرور وافاك الأجل \ ما تراى رأسك بالشّيب إشتعل </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#14r">-14r</locus>أعني به الباه أبا الفيض وع \ وعلى الشيخ أمان أهل الورع وعلى من بهم أيضا إتصال</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="14r" to="17v">14r-17v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1656IHA">حزب المغني</title>
                     <incipit xml:lang="ar">
                        <locus target="#14v">-14v</locus>بسملة \ أللهمّ بك إستعنت فأعني وبك إستغنيت \ فأغنني وعليك توكّلت فاكفني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17v">-17v</locus>وتوصلني \ إلى مرادي وتدفع عني شرّ عبادك يا أر \ حم الرحمين يا ربّ العالمين أمين \ وصلى الله على سيدنا محمد [...] رب العالمين \ تمت حزب المغني</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="17v" to="22r">17v-22r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1957IHA">تخميس وذنوبنا عظمت لله شكوتنا</title>
                     <incipit xml:lang="ar">
                        <locus target="#17v">-17v</locus>بسملة \ يا حيّ يا قيوم يا خالق الوراء \ من النطف للجاري من الصلب والشرّا \ نحن الضيوف وأنت الأمر باالقرا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>بحرمة المصطفى ما دارت القمراء \ بحرمة الأنبيا وسيد بشراء كشمس للجشى المسمى باالبشر تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="22v" to="24v">22v-24v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1177IHA">نظم وكلامك القديم وكتابك المبين</title>
                     <incipit xml:lang="ar">
                        <locus target="#22v">-22v</locus>يا أرحم الرحمين [۳]\ إرحمنا والمسلمين \ بسم الله الكريم وباالرحمان الرحيم وكلامك الكريم  \وكتابك المبين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>كذعل تّابعين \ وتابع التابعين باالإيمان واليقين إلى قرب يوم الدين \ يا ربّ أمين أمين \ تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>

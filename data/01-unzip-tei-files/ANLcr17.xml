                            <msItem xml:id="p2_i1">
                                <locus from="57r" to="64vb"/>
                                <title type="incomplete">Lectionary</title>
                                <note>The fragment was not finished. The exact identification of this lectionary is uncertain. It
                                    seems different from <ref type="work" corresp="https://betamasaheft.eu/LIT1917Mashaf">Maṣḥafa ʾaślǝṭi</ref>, 
                                    <ref type="work" corresp="https://betamasaheft.eu/LIT1932Mashaf">Maṣḥafa gǝṣṣāwe</ref> or <ref type="work" corresp="https://betamasaheft.eu/LIT5654MGessew">Maṣḥafa gǝṣṣǝw</ref> but might be related to them. Its beginning seems to be
                                    similar to a short praise of the 
                                    <ref type="work" corresp="https://betamasaheft.eu/LIT3515Epistle">Letter to the Romans</ref> and the
                                    <ref type="work" corresp="https://betamasaheft.eu/LIT1019Actsof">Acts of the Apostles</ref>
                                    attested in <ref type="mss" corresp="https://betamasaheft.eu/BAVet18">Vatican City, Biblioteca Apostolica Vaticana, Aeth. 18</ref>.
                                </note>
                                <textLang mainLang="gez"/>
                                
                                <msItem xml:id="p2_i1.1">

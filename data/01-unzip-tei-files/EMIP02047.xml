                  <decoDesc>
                    <decoNote type="frame" xml:id="d1">
                      Decorative designs:
                      <locus target="#1r" facs="005">fols. 1r, </locus> (haräg);
                      <locus target="#4r #6v #14r" facs="008 011 018">4r, 6v, 14r, </locus> (multiple full stops);
                      <locus target="#6v #13r #19r #25v #32v #42v #45r #46v #47r #47v #48v #49r #50" facs="011 017 023 030 037 047 049 051 052 053 009">6v, 13r, 19r, 25v, 32v, 42v, 45r, 46v, 47r, 47v, 48v, 49r, 50, </locus> (line of alternating red and black dots);
                      <locus target="#36v #51r" facs="041 055">36v, 51r</locus> (multiple full stops between lines of red and black dots)
                    </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                          <locus target="#iv(erso) #iir(ecto) #iiv(erso) #iiir(ecto) #iiiv(erso) #ivr(ecto)" facs="002 003 004">Fols. iv(erso), iir(ecto), iiv(erso), iiir(ecto), iiiv(erso), ivr(ecto)</locus>
                           <desc type="Asmat">
                              Asmat prayer for proection from various threats and dangers, in blue ink.
                              Incipit: <foreign xml:lang="gez">ኦድንግል፡ አድኅነኒ፡ እምአፈ፡ ሰብዕ፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="e1">
                          <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                           <desc>
                              illegible text, in faint pen or in pencil
                            </desc>
                        </item>
                        <item xml:id="e2">
                          <locus target="#ivv(erso)" facs="005">Fol. ivv(erso)</locus>
                           <desc>
                              blank
                            </desc>
                        </item>
                        <item xml:id="a2">
                          <locus target="#7r" facs="011"> f. 7r and passim</locus>
                           <desc type="OwnershipNote">
                              the name of the owner is <foreign xml:lang="gez">ኃይለ፡ ኢየሱስ፡</foreign>
                           </desc>
                        </item>
                        <item xml:id="a3">
                          <locus target="#51v #52r" facs="056">Fols. 51v, 52r</locus>
                           <desc>
                              Notice of the deaths of various people between 1919 EC and 1937 EC, written in pencil and in blue inks
                            </desc>
                        </item>
                        <item xml:id="e3">
                          <locus target="#52v" facs="057">Fol. 52v</locus>
                           <desc>
                              formal pen trial
                            </desc>
                        </item>
                        <item xml:id="a4">
                          <locus target="#53r" facs="057">Fol. 53r</locus>
                           <desc>
                              note on the collection of grain (for tribute?)
                            </desc>
                        </item>
                        <item xml:id="e4">
                          <locus target="#53v" facs="058">Fol. 53v</locus>
                           <desc>
                              illegible text, in faint pen or in pencil
                            </desc>
                        </item>
                        <item xml:id="e5">
                           <desc>
                             Identified in the insurance hand list as Case A7
                           </desc>
                        </item>
                        <item xml:id="e6">
                          <locus target="#37" facs="041">Fol. 37</locus>
                           <desc>
                             red string is sewn into the fore edge as navigation system
                           </desc>
                        </item>
                        <item xml:id="e7">
                          <locus target="#13r" facs="017"> f. 13r, col. 1, line 12</locus>
                           <desc>
                              words of text are written in the upper margin with a symbol (┴) marking the location where the text is to be inserted
                            </desc>
                          </item>
                          <item xml:id="e8">
                          <locus target="#19v" facs="024">Fol. 19v</locus>
                          <desc>
                            text has been removed
                          </desc>
                          </item>
                       </list>

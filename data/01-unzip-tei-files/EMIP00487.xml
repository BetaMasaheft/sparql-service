                    <item xml:id="a2">
                    <locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus>
                    <desc type="Asmat">
                    Asmat Prayer which God Gave to Solomon, <foreign xml:lang="gez">አስማተ፡ ሰሎሞን፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus>
                    <desc type="Asmat">

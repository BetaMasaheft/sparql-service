                  <handDesc>
                     <handNote xml:id="h0" script="Arabic" corresp="https://betamasaheft.eu/IHA0358#ms_i0"/>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1">
                        <t:locus xmlns:t="http://www.tei-c.org/ns/1.0" target="#">-</t:locus>
                        <t:desc xmlns:t="http://www.tei-c.org/ns/1.0">Drawings / decorations</t:desc>
                        <q>"Muḥammadiyya"</q>
                        <note/>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a7_842">
                           <t:locus target="#40v-41r">-40v, 41r</t:locus>
                           <q xml:lang="am">Notes in Fidel script</q>
                        </item>
                        <item xml:id="a8_842">
                           <t:locus target="#147v">-147v</t:locus>
                           <q xml:lang="ar">تم مختصر تنبيه الأنام في مقام سيدنا محمد عليه افضل الصلاة وسلام بمن الله وكرمه ذا الجلال والكرم والفضل والانعام سنة ١٣٢١ من هجرته صلى الله عليه وسلم</q>
                           <t:desc>Colophon</t:desc>
                           <note/>
                        </item>
                        <item xml:id="a5_842">
                           <t:locus target="#2r">-2r</t:locus>
                           <q xml:lang="ar">تنبيه الأنام في علو مقام سيدنا ونبينا محمد عليه أفضل الصلوة وأزكى التسليم تأليف سيدنا ومولانا الشيخ الامام  قدوة اهل الاسلام عبد الجليل القيرواني ابن محمد ابن احمد ابن عظوم المرادي القيرواني غفر الله له   ولجميع المسلمين والمسلمات والمؤمنين والمؤمنات منهم والاموات بجا محمد واله وصحبه   </q>
                           <t:desc>Title</t:desc>
                           <note>It should be بجاه</note>
                           <note/>
                        </item>
                        <item xml:id="a6_842">
                           <t:locus target="#2r">-2r</t:locus>
                           <q xml:lang="ar">فلما سمع ابا غر ابا دولا قوله تعلى ان الدنيا فانية والأحرة باقية بادر لوقف هذ الكتاب فقال جعلت هذ الكتاب وقفا لجميع المسلمين وجعلت لنفسه ناظر ثم لأولاده ممن كان اهلا لنظرها</q>
                           <t:desc>Waqf</t:desc>
                           <note>
                              <t:term key="Documentary" ana="#Documentary"/>
                              <note>
                                 <p>Nāẓir: <persName ref="https://betamasaheft.eu/PRS0763IHA">ابا غر ابا دولا</persName>
                                 </p>
                              </note>
                              <note/>
                              <note>
                                 <p>Wāqif: <persName ref="https://betamasaheft.eu/PRS0763IHA">ابا غر ابا دولا</persName>
                                 </p>
                              </note>
                           </note>
                        </item>
                        <item xml:id="a9_842">
                           <t:locus target="#147v">-147v</t:locus>
                           <q xml:lang="ar">ايا قارئ خطى سىلتك [بالذي] | امات واحي والعظام رميم | بان تسئل الرحمن يغفر ذلتي | فإن الهى لا يزل رحيم</q>
                           <t:desc>Scribal verses</t:desc>
                           <note>Written by the scribe below the colophon. Written in red.</note>
                           <note/>
                        </item>
                        <item xml:id="a3_842">
                           <t:locus target="#1r">-1r</t:locus>
                           <q xml:lang="ar">The title page is decorated with red frames and geometric patterns.</q>
                           <t:desc>Drawings / Decorations</t:desc>
                           <note/>
                        </item>
                        <item xml:id="a0_842">
                           <t:locus target="#Throughout">-Throughout</t:locus>
                           <q xml:lang="ar">Markers of completing hundreds: text in red.</q>
                           <t:desc>Drawings / Decorations</t:desc>
                           <note/>
                        </item>
                        <item xml:id="a2_842">
                           <t:locus target="#1r">-1r</t:locus>
                           <q xml:lang="ar">اللهم كن بنا [راوفا] وعلينا عطوفا فاتخذ بايدينا اخذ الكريم [...] فى عافية برحمتك يا ارحم الرحمين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العالمين</q>
                           <note>Written by same hand above basmala.</note>
                           <note>
                              <t:desc>
                                 Quotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT2180IHA">دعاء اللهم كن بنا رأوفا</ref>
                              </t:desc>
                              <t:desc>
                                 Quotation of
                              <ref type="work" corresp="https://betamasaheft.eu/LIT2180IHA">دعاء اللهم كن بنا رأوفا</ref>
                              </t:desc>
                           </note>
                        </item>
                        <item xml:id="a4_842">
                           <t:locus target="#1r-1v">-1r-1v</t:locus>
                           <q xml:lang="ar"> بسم الله الرحمن الرحيم \ الحمد لله الذي زين السماء الاذكار بالصلاة على النبي المختار واطلع من سنا انوارها مطلع الشموس والاقمار [...] وبعد فانه لما كانت الصلاة على النبي الاكرم والرسول المعظم صلى الله عليه وسلم وشرف وكرم ومجد وعظم وافاض عليه من خزائن وانعم , من اشرف القربات , وافضل الاعمال الصالحات [...] واختصرتها اختصار الواعظ ليسهل خفظها على الحفاظ فكانت تذكرة للاسلام في الصلاة على خير الانام وارتفعت بها الاصوات في المجالس وطردت بها الشياطين والابالس [...] وسميتها تنبيه الانام في بيان علو مقام نبينا محمد عليه افضل الصلاة وازكى السلام وربما ايضا سميتها شفاء الاسقام ومحو الاثام [...] الشفيع في العصاة انه ولي ذلك والقادر عليه ولا حول ولا قوة الا بالله العلي العظيم وصلى الله على سيدنا محمد وعلى آله وصخبه وسلم تسليما كثيرا طيبا مباركا جزيلا</q>
                           <t:desc>Muqaddima</t:desc>
                           <note>
                              <t:desc>
                                 <ref type="work" corresp="https://betamasaheft.eu/LIT0002IHA">تنبيه الانام</ref>
                              </t:desc>
                           </note>
                        </item>
                        <item xml:id="a1_842">
                           <t:locus target="#Throughout">-Throughout</t:locus>
                           <q xml:lang="ar">Chapter headings, indications in the margins counting the verses, verse markers and important words in red. </q>
                           <t:desc>Drawings / Decorations</t:desc>
                           <note/>
                        </item>
                     </t:list>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a1">
                           <t:locus target="#101r">-101r</t:locus>
                           <q>هو في اللغة الاثبات يقار قر الشئ اذا اثبت واقره اذا اثبته وفي الشرع هو اي الاقرار اخبار عن ثبوت حق الغير على نفسه ه</q>
                           <note>Marginal note, no mark</note>
                        </item>
                        <item xml:id="a2">
                           <t:locus target="#149v">-149v</t:locus>
                           <t:desc>Ownership</t:desc>
                           <q>هذ كتاب اب</q>
                           <note>Partially written in Fidel script</note>
                        </item>
                        <item xml:id="a3">
                           <t:locus target="#Inner lining of the front cover">-Inner lining of the front cover</t:locus>
                           <q>الذ جعل الله حبه نافعا على كل حال وليس صله عمل من أمال الذ جعل الله حبه من الايمان</q>
                           <note/>
                        </item>
                        <item xml:id="a4">
                           <t:locus target="#Throughout">-Throughout</t:locus>
                           <q>Marginal notes, no marks</q>
                           <note/>
                        </item>
                        <item xml:id="a5">
                           <t:locus target="#18r-18v">-18r, 18v</t:locus>
                           <t:desc>Marginal notes marked Šarḥ [.?.]</t:desc>
                           <q/>
                           <note>The note is partly faded.</note>
                        </item>
                        <item xml:id="a6">
                           <t:locus target="#76v">-76v</t:locus>
                           <t:desc>Marginal notes, unclear</t:desc>
                           <q/>
                           <note>Two notes that are faded and difficult to read.</note>
                        </item>
                        <item xml:id="a7">
                           <t:locus target="#44r-134r">-44r, 134r</t:locus>
                           <t:desc>Marginal notes marked Ǧawhara or Ǧawhar</t:desc>
                           <q/>
                           <note/>
                        </item>
                     </t:list>

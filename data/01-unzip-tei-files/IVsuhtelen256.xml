                        <locus target="#1r"/>
                        <desc> Described by <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> as linear ornament; possibly an unfinished ornamental band. </desc>
                     </decoNote>

                     <decoNote type="drawing" xml:id="d2">
                        <locus target="#2r"/>
                        <desc> Drawing of a horse. </desc>
                     </decoNote>


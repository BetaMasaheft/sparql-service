                        <locus target="#54r"/>
                        <desc>Polychrom ornamental band.</desc>
                      </decoNote>


                     </decoDesc>

                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="Exhortation"/>
                           <locus target="#1r"/>
                           <q xml:lang="ar"/>
                        </item>

                        <item xml:id="a2">
                           <desc type="GuestText">
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title></desc>
                           <locus target="#2v"/>
                           <q xml:lang="gez"/>
                           <q/>
                        </item>

                           <item xml:id="a3">
                              <desc type="GuestText">
                              <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title></desc>
                              <locus from="134v" to="137v"/>
                          <q xml:lang="gez">በእንተ፡ ትምህርተ፡ ኅቡአት፡</q>
                              <q/>
                              <note>
                              <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> described the hand as "much later" than the main one.</note>
                        </item>

                        <item xml:id="e1">
                           <locus target="#67r"/>
                           <q xml:lang="gez"> ሠረቀ፡ ግንቦት፡ </q>
                           <desc>Indication marking the part for the month of Gǝnbot, probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e2">
                           <locus target="#75v"/>
                           <q xml:lang="gez"> ሠረቀ፡ ስኔ፡ </q>
                           <desc>Indication marking the part for the month of Sane (here spelled somewhat differently), probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e3">
                           <locus target="#84v"/>
                           <q xml:lang="gez"> ሠረቀ፡ ሐምሌ፡ </q>
                           <desc>Indication marking the part for the month of Ḥamle, probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e4">
                           <locus target="#95v"/>
                           <q xml:lang="gez"> ሠረቀ፡ ነኃሲ፡ </q>
                           <desc>Indication marking the part for the month of Naḥase (here spelled somewhat differently), probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e5">
                           <locus target="#107v"/>
                           <q xml:lang="gez"> ሠረቀ፡ ጰጕሜን፡ </q>
                           <desc>Indication marking the part for the month of Ṗāgumen, probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e6">
                           <locus target="#109r"/>
                           <q xml:lang="gez"> ሠረቀ፡ መስከረም፡ </q>
                           <desc>Indication marking the part for the month of Maskaram, probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e7">
                           <locus target="#119r"/>
                           <q xml:lang="gez"> ሠረቀ፡ ጥቅምት፡ </q>
                           <desc>Indication marking the part for the month of Ṭǝmqat, probably in the upper margin.</desc>
                        </item>

                        <item xml:id="e8">
                           <locus target="#127r"/>
                           <q xml:lang="gez"> ሠረቀ፡ ኅዳር፡ </q>
                           <desc>Indication marking the part for the month of Ḫǝdār (up to 11 Ḫǝdār), probably in the upper margin.</desc>
                        </item>
                        
                        <item xml:id="e9"><locus target="#134r"/><desc>The name of the scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS12145Sahlay">Śāhlay</persName>
                          is  indicated on f. 134r </desc></item>
                     </list>
                     </additions>


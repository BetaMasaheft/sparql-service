               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="5r" to="54r"/>
                     <title type="incomplete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1325egziab">ʾƎgziʾabǝḥer nagśa</title>
                     <note> The first text folio is missing </note>
                     <textLang mainLang="gez"/>

                  </msItem>

                  <msItem xml:id="ms_i2">
                     <locus from="54v" to="127rv"/>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2741RepCh25">Malkǝʾa ḥǝmāmāta masqal</title>
                     <textLang mainLang="gez"/>
                     <incipit> ሰላም፡ ለሕማምከ፡ ቤተ፡ አይሁድ፡ ዘአመዝበረ፡ </incipit>
                     <explicit type="supplication"> ወጸሓፊሁኒ፡ ሣህለይ፡ ወልደ፡ ሰመሬ፡ ክርስቶስ፡ ይጽሐፍ፡ ስሞ፡ ኀበ፡ ዓምደ፡ ወርቅ፡ ምስለ፡ አቡሁ። አሜን፡ ወአሜን፨
                        <foreign>And may (Christ) write the name of the scribe, <persName role="scribe" ref="https://betamasaheft.eu/PRS12145Sahlay">Śāhlay, the son of Samare Krǝstos, </persName>
                           on the column of gold, with his (the name of his) father </foreign>
                     </explicit>

                  </msItem>

              </msContents>


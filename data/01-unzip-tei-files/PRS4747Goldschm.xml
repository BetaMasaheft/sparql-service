      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName>
                  <t:forename>Lazarus</t:forename>
                  <t:surname> Goldschmidt</t:surname> 
               </t:persName>
               
               <t:occupation type="academic">scholar</t:occupation>
               <t:nationality type="notSpecified"/>
               <t:faith type="notSpecified"/>
               <t:birth when="1871">He was born at <t:placeName ref="http://www.geonames.org/ontology#597427">Republic of Lithuania</t:placeName> in <t:date>1871</t:date>.</t:birth>
               <t:floruit notBefore="1892" notAfter="1950">He was a versatile Jewish Semitist who in his early career  made a number of contributions to Ethiopian Studies. 
                  He studied Gǝʿǝz under the guidance of the most celebrated Ethiopicist scholar, <t:persName ref="https://betamasaheft.eu/PRS3562Dillmann">Christian Friedrich August Dillmann</t:persName>. Between <t:date>1892-1897</t:date>, 
                  he published four works  in quick succession on Ethiopian Studies. Then after <t:date>1897</t:date>, he turned away from Ethiopian Studies.</t:floruit>
               <t:death when="1950"/>
            </t:person>
            
         </t:listPerson>

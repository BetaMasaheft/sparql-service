                    <t:ab/>
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza20" xml:lang="gez" n="20">
                    <t:label>Stanza 20</t:label>
                    <t:ab/>
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza21" xml:lang="gez" n="21">
                    <t:label>Stanza 21</t:label>
                    <t:ab/>
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza22" xml:lang="gez" n="22">
                    <t:label>Stanza 22</t:label>
                    <t:lg type="stanza" n="22">
                        <t:l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ኄራን፡ አበው፨</t:l>
                        <t:l n="2">ወለመቃብሪከ፡ ሰላም፡ በውሣጤ፡ ገዳም፡ ፍትው፨</t:l>
                        <t:l n="3">አናንያ፡ ያዕቆብ፡ መፍቀሬ፡ አምላክ፡ ሕያው፨</t:l>
                        <t:l n="4">ከመ፡ ኢይቅትክጸ፡ ፍትወተ፡ ሥጋ፡ ኤሳው፨</t:l>
                        <t:l n="5">ቀቲለ፡ ዚአየ፡ ቀደምከ፡ በነገር፡ ህልው፨</t:l>
                    </t:lg>
                    
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza23" xml:lang="gez" n="23">
                    <t:label>Stanza 23</t:label>
                    <t:lg type="stanza" n="23">
                        <t:l n="1">ዘንተ፡ ስብሐታተ፡ ዘአቅረብኩ፡ ነያ፨</t:l>
                        <t:l n="2">ከመ፡ መሥዋዕተ፡ ላህም፡ ሥሙር፡ ሠመርከ፡ አናንያ፨</t:l>
                        <t:l n="3">አልቦ፡ እምይእዜ፡ ለነፍስየ፡ ዘያጠንያ፨</t:l>
                        <t:l n="4">ኢጠቢብ፡ ወኢኬንያ፨</t:l>
                        <t:l n="5">ዕሤተ፡ በረከትከ፡ ምሉአ፡ ዳእሙ፡ እሥያ፨</t:l>
                    </t:lg>
                    
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza24" xml:lang="gez" n="24">
                    <t:label>Stanza 24</t:label>
                    <t:lg type="stanza" n="24">
                        <t:l n="1">እስመ፡ ውዳሴሁ፡ ፈጸምኩ፡ ወዘዚአሁ፡ መልክእ፨</t:l>
                        <t:l n="2">መጠነ፡ ተክህለኒ፡ ሊተ፡ መጠነ፡ ዕሥራ፡ ወርብዕ፨</t:l>
                        <t:l n="3">ሶበ፡ አናንያ፡ ተዐርግ፡ ጸሎተ፡ ቅዱሳን፡ ሰብእ፨</t:l>
                        <t:l n="4">ኢታውርድ፡ ተሚኦከ፡ ላዕለ፡ ወልድከ፡ ኃጥእ፨</t:l>
                        <t:l n="5">አፍሐመ፡ እሳት፡ ውዑይ፡ እምሥር፡ ኅቡእ፨</t:l>
                    </t:lg>
                    
                </t:div>
            </t:div>

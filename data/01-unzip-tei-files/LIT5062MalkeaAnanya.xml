                <t:div type="textpart" subtype="stanza" xml:id="Stanza1" xml:lang="gez" n="1">
                    <t:label>Stanza 1</t:label>
                    <t:lg type="stanza" n="1">
                        <t:l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘፍካሬሁ፡ ደመና፨</t:l>
                        <t:l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘኢተቀብአ፡ ቅብአ፡ ሙስና፨</t:l>
                        <t:l n="3">አናንያ፡ ጳውሎስ፡ ለቤተ፡ ክርስቲያን፡ ቀርና፨</t:l>
                        <t:l n="4">ከመ፡ እዜኑ፡ ስብሐቲከ፡ ወዘዚአከ፡ ልዕልና፨</t:l>
                        <t:l n="5">በዲበ፡ እንግድዓየ፡ አክብድ፡ ወምላእ፡ ልቦና፨</t:l>
                    </t:lg>
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza2" xml:lang="gez" n="2">
                    <t:label>Stanza 2</t:label>
                    <t:lg type="stanza" n="2">
                        <t:l n="1">ሰላም፡ ለርእስከ፡ አክሊለ፡ ጻማ፡ ዘተቀጸለ፨</t:l>
                        <t:l n="2">ወለገጽከ፡ ሰላም፡ ዘተሳተፈ፡ ጸዳለ፨</t:l>
                        <t:l n="3">አናንያ፡ አቡየ፡ እስእለ፨</t:l>
                        <t:l n="4">አብያጺከ፡ መነኮሳት፡ ኀበ፡ ረሰዩ፡ መድበለ፨</t:l>
                        <t:l n="5">አሀሉ፡ ምስሌሆሙ፡ ጸግወኒ፡ ክፍለ፨</t:l>
                    </t:lg>
                    
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza3" xml:lang="gez" n="3">
                    <t:label>Stanza 3</t:label>
                    <t:ab/>
                </t:div>


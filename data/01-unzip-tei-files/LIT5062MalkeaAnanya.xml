                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza17" xml:lang="gez" n="17">
                    <t:label>Stanza 17</t:label>
                    <t:ab/>
                </t:div>

                <t:div type="textpart" subtype="stanza" xml:id="Stanza18" xml:lang="gez" n="18">

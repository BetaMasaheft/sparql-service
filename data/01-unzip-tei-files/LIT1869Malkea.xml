            <t:note>The following division into sections and excerpts are taken from the edition <t:bibl corresp="http://zotero.org/groups/358366/items/97TNCJ8U"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:MalkaGubae1974"/><title level="m">መልክዐ ጉባኤ &lt;hi rend="italics"&gt;(&lt;/hi&gt;Mälkǝʾa gubaʾe&lt;hi rend="italics"&gt;, 'Collection of hymns')&lt;/hi&gt;</title><pubPlace>ʾAśmarā</pubPlace><publisher>Kokaba Șǝbāḥ māttamiyā bet</publisher><date>1981</date><t:citedRange unit="page">1–19</t:citedRange></t:bibl>. Text completed after <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl></t:note>
            <t:div type="textpart" xml:id="Preamble">
               <t:label>Preamble (Māsgabiyā)</t:label>
              
                  <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለኪ፡ እንዘ፡ ንሰግድ፡ ንብለኪ፡</t:l>
                  <t:l n="2">ማርያም፡ እምነ፡ ናስተበቍዓኪ፡</t:l>
                  <t:l n="3"> እምአርዌ፡ ነአዊ፡ ተማኅፀነ፡ ብኪ፡</t:l>
                  <t:l n="4">በእንተ፡ ሐና፡ እምኪ፡ ወኢያቄም፡ አቡኪ፡</t:l>
                  <t:l n="5">ማኅበረነ፡ ዮም፡ ድንግል፡ ባርኪ፡</t:l>
                  </t:lg>
               
               
                  <t:lg type="stanza" n="2">
                  <t:l n="1">ታዐብዮ፡ ነፍስየ፡ መጠነ፡ ሕሊናየ፡ ክህለ፡</t:l>
                  <t:l n="2">ለእግዚአብሔር፡ ወልድኪ፡ እንተ፡ ይሰመይ፡ ልዑለ፡</t:l>
                  <t:l n="3">ዘበእንቲአኪ፡ ገብረ፡ ዐቢያተ፡ ኃይለ፡</t:l>
                  <t:l n="4">ትሑታነኒ፡ በትሕትናሁ፡ አልዐለ፡</t:l>
                  <t:l n="5">ወለርኁባን፡ አጽገቦሙ፡ እክለ፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Monday">
               <t:label>Monday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ፈቀደ፡ እግዚእ፡ ለአዳም፡ ያግእዞ፡</t:l>
                     <t:l n="2">ሥጋኪ፡ ንጹሐ፡ አመ፡ ረሰየ፡ አራዞ፡</t:l>
                     <t:l n="3">ማርያም፡ ድሉት፡ ለምሕረት፡ ወለናዝዞ፡</t:l>
                     <t:l n="4">ይቅብዐኒ፡ ዕፍረተ፡ ጽድቅ፡ ወያምዕዘኒ፡ አምዕዞ፡</t:l>
                     <t:l n="5">የማነ፡ እዴኪ፡ እዴየ፡ እኂዞ፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ለሔዋን፡ እምነ፡ ከይሲ፡ ዘአስሐታ፨</t:l>
                  <t:l n="2">እግዚአብሔር፡ ናዘዛ፡ ኪያኪ፡ በወሊዶታ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ርግበ፡ ኤፍራታ፨</t:l>
                  <t:l n="4">ለነፍሰ፡ ዚአየ፡ አስተዳልዊ፡ ማኅቶታ፨</t:l>
                  <t:l n="5">ከመ፡ ኢተኀሉ፡ ነፍስየ፡ ባሕቲታ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ኢየሱስ፡ ክርስቶስ፡ አመ፡ ላዕሌኪ፡ ኀደረ፨</t:l>
                  <t:l n="2">ሥጋኪ፡ ንጹሐ፡ ምስለ፡ መለኮቱ፡ ደመረ፨</t:l>
                  <t:l n="3">ለፍልሰትኪ፡ ድንግል፡ ጊዜ፡ ነዐርግ፡ መዝሙረ፨</t:l>
                  <t:l n="4">አድኅንኒ፡ አመናስው፡ ዛተ፡ ሀገረ፨</t:l>
                  <t:l n="5">ወካልአተኒ፡ አህጉረ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ርእየ፡ ኢሳይያስ፡ ለአማኑኤል፡ ምሥጢሮ፨</t:l>
                  <t:l n="2">መንጦላዕተ፡ ሥጋኪ፡ እንተ፡ ሰወሮ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ንግሥተ፡ ሰላም፡ ወተፋቅሮ፨</t:l>
                  <t:l n="4">መዝሙር፡ አነሥአ፡ እምቃልየ፡ ወእሁብ፡ ከበሮ፨</t:l>
                  <t:l n="5">ጊዜ፡ ለስምኪ፡ ኣቄርብ፡ ዘምሮ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ተፈሣሕ፡ ወተሐሠይ፡ ኦዘመደ፡ እጓለ፡ እመሕያው፨</t:l>
                  <t:l n="2">እስመ፡ አፍቀሮ፡ እግዚአብሔር፡ ለዓለም፡ ሕልው፨</t:l>
                  <t:l n="3">ማርያም፡ ድግንል፡ ሙዳየ፡ አፈው፨</t:l>
                  <t:l n="4">ከመ፡ እስብሕኪ፡ በቃለ፡ ውዳሴ፡ ፍትው፨</t:l>
                  <t:l n="5">ልስሐተ፡ አፉየ፡ ቀስሚ፡ በጼው፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ዘሀሎ፡ ወይሄሉ፡ እግዚአብሔር፡ መዋኢ፨</t:l>
                  <t:l n="2">በሥጋኪ፡ መጽአ፡ ወካዕበ፡ መጻኢ፨</t:l>
                  <t:l n="3">ስእለተ፡ ነዳያን፡ ማርያም፡ ዘኢትሰምዒ፨</t:l>
                  <t:l n="4">ለዐቂቦትየ፡ ኀይለኪ፡ አንሥኢ፨</t:l>
                  <t:l n="5">ከመ፡ በላዕሌየ፡ ኢያሕስም፡ ጸላኢ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ተፈሥሒ፡ እንዘ፡ እብል፡ ለቤተ፡ ልሔም፡ እዌድሳ፨</t:l>
                  <t:l n="2">እስመ፡ ወለድኪዮ፡ ባቲ፡ ለክርስቶስ፡ ዘይሔድሳ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘትምዐዚ፡ እምፈርከሊሣ፨</t:l>
                  <t:l n="4">ይማኦ፡ ጽድቀ፡ ዚአኪ፡ ለዘዚአየ፡ አበሳ፨</t:l>
                  <t:l n="5">ከመ፡ አራዊተ፡ ይመውእ፡ አንበሳ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">ትትፌሣሕ፡ ወትትሐሠይ፡ ነፍሳተ፡ ጻድቅ፡ ወኃጥእ፨</t:l>
                  <t:l n="2">ማኅደንኪ፡ ድንግል፡ በልደተ፡ ክርስቶስ፡ ቅቡእ፨</t:l>
                  <t:l n="3">ዘበእንቲአሁ፡ ይቤሉ፡ መላእክተ፡ ሰማይ፡ አርባዕ፨</t:l>
                  <t:l n="4">ስብሐት፡ በሰማያት፡ ለእግዚአብሔር፡ እግዚእ፨</t:l>
                  <t:l n="5">ወሰላም፡ በምድር፡ ሥምረቱ፡ ለሰብእ፨</t:l>
               </t:lg>
                  <t:lg type="stanza" n="9">
                     <t:l n="1">ብርሃንኪ፡ ዘበአማን፡ ያበርህ፡ ፍጹመ፡</t:l>
                     <t:l n="2">ለኵሎሙ፡ ሰብእ፡ እለ፡ ይነብሩ፡ ዓለመ፡</t:l>
                     <t:l n="3">ማርያም፡ ዘኮንኪ፡ ዘእግዚአብሔር፡ እመ፡</t:l>
                     <t:l n="4">ጽምእት፡ ምድር፡ ከመ፡ ትሴፎ፡ ዝናመ፡</t:l>
                     <t:l n="5">እሴፎ፡ ምሕረተኪ፡ ቀዊምየ፡ ፍጽመ፡</t:l>
                  </t:lg>               
            </t:div>
            <t:div type="textpart" xml:id="Tuesday">
               <t:label>Tuesday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">አክሊለ፡ ምክሕነ፡ አንቲ፡ ኀጣእኪ፡ መምሰለ፡</t:l>
                     <t:l n="2">እስመ፡ ወለድኪ፡ ለነ፡ ዘእግዚአብሔር፡ ቃለ፡</t:l>
                     <t:l n="3">ማርያም፡ ድንግል፡ ዘትፀውሪ፡ አስካለ፡</t:l>
                     <t:l n="4">ጊዜ፡ ንዴትየ፡ አጥረይኩኪ፡ ብዕለ፡</t:l>
                     <t:l n="5">ወጊዜ፡ ድካምየ፡ ካዕበ፡ ረሰይኩኪ፡ ኀይለ፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ዐቢይ፡ ውእቱ፡ ስብሐተ፡ ድንግልናኪ፡ ክልኤ፨</t:l>
                  <t:l n="2">እንዘ፡ እብል፡ እሰብሕ፡ በግናይ፡ ወበጽዋዔ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ምክሕ፡ ጉባዔ፨</t:l>
                  <t:l n="4">ጊዜ፡ ድቀትየ፡ ሶበ፡ ኀጣእኩ፡ ረዳኤ፨</t:l>
                  <t:l n="5">በቃለ፡ ዚአኪ፡ እሴፎ፡ ትንሣኤ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ዕፀ፡ ጥበብ፡ ወልቡና፨</t:l>
                  <t:l n="2">ሙሴ፡ ነቢይ፡ ዘርእየኪ፡ በደብረ፡ ሲና፨</t:l>
                  <t:l n="3">ማርያም፡ ዑጽፍት፡ ወኁብርት፡ በቅድስና፨</t:l>
                  <t:l n="4">ህብኒ፡ እግዝእትየ፡ ከመ፡ ኢይርአይ፡ ሙስና፨</t:l>
                  <t:l n="5">መጽሐፈ፡ ብርሃናዌ፡ ወኅቡአ፡ መና፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ገራህተ፡ ንጉሥ፡ ሰማያዊ፨</t:l>
                  <t:l n="2">ዘእምኔኪ፡ ሰማያዊ፨</t:l>
                  <t:l n="3">ዘእምኔኪ፡ ሠረቀ፡ ሕያው፡ ወማሕየዊ፨</t:l>
                  <t:l n="4">ማርያም፡ ድንግል፡ ወለተ፡ ይሁዳ፡ ወሌዊ፨</t:l>
                  <t:l n="5">በትንብልናኪ፡ አንቀጸ፡ ምንዳቤ፡ ዕጽዊ፨</t:l>
                  <t:l n="6">ወበምሕረትኪ፡ አንቀጾ፡ አርኅዊ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ተፈሥሒ፡ ኦወላዲተ፡ እግዚእ፡ ሐሤቶሙ፡ ለመላእክት፨</t:l>
                  <t:l n="2">ተፈሥሒ፡ ኦንጽሕት፡ ዜናሆሙ፡ ለነቢያት፨</t:l>
                  <t:l n="3">ማርያም፡ ክብርት፡ ማርያም፡ ልዕልት፨</t:l>
                  <t:l n="4">እምኅሩያንኪ፡ ኢትፍልጥኒ፡ ንግሥት፨</t:l>
                  <t:l n="5">ወኢትኅድግኒ፡ በሕይወት፡ ወሞት፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ተፈሥሒ፡ ማርያም፡ ዘተሰመይኪ፡ ድልወ፨</t:l>
                  <t:l n="2">ከመ፡ ትለዲ፡ ፀሓየ፡ ወኮከበ፡ ሰማይ፡ ሥርግወ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ እንተ፡ አጥበውኪ፡ ጥብወ፨</t:l>
                  <t:l n="4">እምከናፍርኪ፡ ሥነ፡ ሞገስ፡ ተክዕወ፨</t:l>
                  <t:l n="5">ላዕለ፡ ሕፃንኪ፡ ዘይምዕዝ፡ አፈወ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ኦድንግል፡ ከመ፡ ትለዲ፡ ንጉሠ፨</t:l>
                  <t:l n="2">እምኀበ፡ እግዚአብሔር፡ አምላክ፡ እስመ፡ ረከብኪ፡ ሞገሰ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘትፈጽሚ፡ ማዕሠሠ፨</t:l>
                  <t:l n="4">ዝክረ፡ ስምኪ፡ ጸግዎሙ፡ ለሕሙማን፡ ፈውሰ፨</t:l>
                  <t:l n="5">ወለዕሩቃን፡ ከደኖሙ፡ ልብሰ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">ቃለ፡ አብ፡ ሕያው፡ ውስተ፡ ደብረ፡ ሲና፡ ዘወረደ፨</t:l>
                  <t:l n="2">ሥጋኪ፡ ንጹሐ፡ እስመ፡ ረሰየ፡ ማኅፈደ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘተቃልሊ፡ ክበደ፨</t:l>
                  <t:l n="4">ከመ፡ ታጽድቂ፡ ኃጥኣነ፡ ብኪ፡ መፍቅደ፨</t:l>
                  <t:l n="5">ወከመ፡ አጥበውኪ፡ ዘከማየ፡ አብድ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="9">
                  <t:l n="1">ውእቱኬ፡ ቃለ፡ አብ፡ እግዚአብሔር፨</t:l>
                  <t:l n="2">ሥጋኪ፡ ተአጽፈ፡ በመንክር፡ ምሥጢር፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ወላዲተ፡ ክርስቶስ፡ ክቡር፨</t:l>
                  <t:l n="4">ክዕወ፡ ኮነ፡ ወርቀ፡ ስብሐት፡ ወከመ፡ ኆፃ፡ ዘባሕር፨</t:l>
                  <t:l n="5">በጊዜ፡ ፈለስኪ፡ ሰማየ፡ እምድር፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="10">
                  <t:l n="1">ዕበይኪ፡ ድንግል፡ ኢይትከሀል፡ ለተነግሮ፨</t:l>
                  <t:l n="2">በነቢብ፡ ወበፈክሮ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ለእግዚአብሔር፡ ማኅደሮ፨</t:l>
                  <t:l n="4">እምአእምሮትኪ፡ ክፍልኒ፡ አእምሮ፨</t:l>
                  <t:l n="5">ከመ፡ ለዓለም፡ ዘይዴግን፡ ፍቅሮ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="11">
                  <t:l n="1">ዝ፡ ውእቱ፡ዕብን፡ ወልድኪ፡ ዋሕድ፨</t:l>
                  <t:l n="2">ዘተበትከ፡ እምደብር፡ ነዋኅ፡ ዘእንበለ፡ እድ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘሞገስኪ፡ ፍድፉድ፨</t:l>
                  <t:l n="4">እምኵሉ፡ ቀዳማዊ፡ ወደኀራዊ፡ ትውልድ፨</t:l>
                  <t:l n="5">ለዝክረ፡ ስምኪ፡ ይደሉ፡ ሰጊድ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="12">
                  <t:l n="1">ኮንኪ፡ አጽቀ፡ ሕይወት፡ ማርያም፡ እግዝእትነ፨</t:l>
                  <t:l n="2">ርትዕት፡ ሃይማኖቶሙ፡ ለቅዱሳን፡ አበዊነ፨</t:l>
                  <t:l n="3">ኦድንግል፡ ዘትትዐጸፊ፡ ብርሃነ፨</t:l>
                  <t:l n="4">ነሲአነ፡ ነፍስነ፡ አርጋኖነ፡ ኵሎ፡ ዘመነ፨</t:l>
                  <t:l n="5">ለልደትኪ፡ ታበውዕ፡ ቍርባነ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="13">
                  <t:l n="1">አንቲ፡ እሙ፡ ለዐቢይ፡ ብርሃን፨</t:l>
                  <t:l n="2">ዝ፡ ውእቱ፡ ቃል፡ ዘኢይትረአይ፡ ለዐይን፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ተስፋ፡ ቅቡጻን፨</t:l>
                  <t:l n="4">ባርክኒ፡ እግዝእትየ፡ ከመ፡ ለብሐዊ፡ ምእመን፨</t:l>
                  <t:l n="5">በከናፍርኪ፡ ፍሡሓት፡ እምወይን፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="14">
                  <t:l n="1">አይ፡ ልሳን፡ ዘይክል፡ ነቢበ፨</t:l>
                  <t:l n="2">ውዳሴኪ፡ ኵሉ፡ ዘበውስተ፡ መጽሐፍ፡ ተዘግበ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘታቀልሊ፡ ዕጹበ፨</t:l>
                  <t:l n="4">በየዋሃትኪ፡ ተመሰልኪ፡ ርግበ፨</t:l>
                  <t:l n="5">ወበንጽሕናኪ፡ ድንግለ፡ ጠባበ፨</t:l>
               </t:lg>
               
                  <t:lg type="stanza" n="15">
                     <t:l n="1">ተፈሥሒ፡ ኦማርያም፡ እም፡ ወአመት፡</t:l>
                     <t:l n="2">እስመ፡ ለዘውስተ፡ ሕጽንኪ፡ ይሴብሕዎ፡ መላእክት፡</t:l>
                     <t:l n="3">ማርያም፡ ንጽሕት፡ ማርያም፡ ቡርክት፡</t:l>
                     <t:l n="4">በየማነ፡ ንጉሥ፡ ዘትቀውሚ፡ ንግሥት፡</t:l>
                     <t:l n="5">በእንቲአኪ፡ ዘመረ፡ ዳዊት፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Wednesday">
               <t:label>Wednesday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ኵሉ፡ ሠራዊተ፡ ሰማያት፡ በእንቲአኪ፡ ይብሉ፡</t:l>
                     <t:l n="2">ብፅዕት፡ አንቲ፡ ማርያም፡ ለእግዚአብሔር፡ አበሉ፡</t:l>
                     <t:l n="3">ሶበ፡ እፈልስ፡ ገብርኪ፡ መንገለ፡ ታሕቱ፡ ወላዕሉ፡</t:l>
                     <t:l n="4">አሐዱ፡ መልአከ፡ ዘዚአኪ፡ በቅድሜየ፡ የሀሉ፡</t:l>
                     <t:l n="5">ወካልኡ፡ መልአክ፡ በድኅሬየ፡ ይትሉ፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ተነበዩ፡ ላዕሌኪ፡ ዐቢያተ፡ ወመንክራተ፨</t:l>
                  <t:l n="2">ኦሀገረ፡ እግዚአብሔር፡ አንቲ፡ ዘትፈቅዲ፡ ማኅቶተ፨</t:l>
                  <t:l n="3">ማርያም፡ አብርሂ፡ ነፍሰ፡ ዚአየ፡ ዕዉርተ፨</t:l>
                  <t:l n="4">ከመ፡ እርአይ፡ መንገለ፡ ጽድቅ፡ እንተ፡ ይመርሕ፡ ፍኖተ፨</t:l>
                  <t:l n="5">ወበፍኖትኪ፡ ታበውእ፡ ገነተ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">አንቲ፡ ዘበ፡ አማን፡ ደመና፡ ክርስቶስ፡ አምላክ፨</t:l>
                  <t:l n="2">ማርያም፡ ድንግል፡ ሰአሪተ፡ መርገም፡ ወሀውክ፨</t:l>
                  <t:l n="3">ይዌድሱኪ፡ ኪሩቤል፡ እንዘ፡ ይሰግዱ፡ በብረክ፨</t:l>
                  <t:l n="4">ገብርኤልኒ፡ ፍሡሐ፡ ገጽ፡ መልአክ፨</t:l>
                  <t:l n="5">ይኤምኀኪ፡ በጽባሕ፡ ወሰርክ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ረከብኪ፡ ጸጋ፡ መንፈስ፡ ቅዱስ፡ ኀደረ፡ ላዕሌኪ፨</t:l>
                  <t:l n="2">ወኀይለ፡ ልዑል፡ ይጼልለኪ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ እንተ፡ አምላከ፡ ወለድኪ፨</t:l>
                  <t:l n="4">ኵሎ፡ መዓልተ፡ ወሌሊተ፡ ሶበ፡ እጼውዕ፡ ስመኪ፨</t:l>
                  <t:l n="5">ሕይወትየ፡ ወሞትየ፡ ማርያም፡ ባርኪ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ግብረኪ፡ ድንግል፡ ይሴብሑ፡ በዜማ፨</t:l>
                  <t:l n="2">መሬታውያን፡ በምድር፡ ወሰማያውያን፡ በራማ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ክልልተ፡ ሞገስ፡ ወግርማ፨</t:l>
                  <t:l n="4">ደቂቀ፡ ቤትኪ፡ ኢይሁክ፡ መስቴማ፨</t:l>
                  <t:l n="5">በዲበ፡ ትእዛዝ፡ ዘይፈጥር፡ ጻማ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">የዐቢ፡ ክብርኪ፡ እምክብረ፡ መላእክት፡ ዘርያም፨</t:l>
                  <t:l n="2">ወእምክብረ፡ ጻድቃን፡ ዘገዳም፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ እም፨</t:l>
                  <t:l n="4">ብኪ፡ ድኅነ፡ ዓለም፨</t:l>
                  <t:l n="5">ወበወልድኪ፡ ኮነ፡ ሰላም፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ሕዝቅኤል፡ ነቢይ፡ እንዘ፡ ይብል፡ ጸርሐ፨</t:l>
                  <t:l n="2">ርኢኩ፡ ኆኅተ፡ ምሥራቅ፡ ዘኅቱም፡ መናሥግቲሃ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ዘትሠረገዊ፡ ንጽሐ፨</t:l>
                  <t:l n="4">ለዝክረ፡ ስምኪ፡ እትፌሣሕ፡ ፍሥሐ፨</t:l>
                  <t:l n="5">ከመ፡ ዘረከበ፡ ምሕርካ፡ ብዙኀ፨</t:l>
               </t:lg>
                  <t:lg type="stanza" n="8">
                     <t:l n="1">ኆኅትሰ፡ ድንግል፡ አንቲ፡</t:l>
                     <t:l n="2">እንተ፡ ወለድኪ፡ አምላከ፡ በድንግልና፡ ክልኤቲ፡</t:l>
                     <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ሣህለ፡ መዋቲ፡</t:l>
                     <t:l n="4">ዕቀበኒ፡ እግዝእትየ፡ እምዋዕየ፡ ልሳን፡ መስሐቲ፡</t:l>
                     <t:l n="5">እስመ፡ እሳቱ፡ ለዓለም፡ ይእቲ፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Thursday">
               <t:label>Thursday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ዕፅ፡ እንተ፡ ርእየ፡ ሙሴ፡ በደብር፡</t:l>
                     <t:l n="2">ምሳሌኪ፡ ኮነ፡ መንገለ፡ ኅቡእ፡ ምሥጢር፡</t:l>
                     <t:l n="3">ማርያም፡ ሰማይ፡ ወመንፈሳዊት፡ ሀገር፡</t:l>
                     <t:l n="4">አድባር፡ ብኪ፡ ተፈሥሑ፡ ወአንፈርዐጹ፡ አውግር፡</t:l>
                     <t:l n="5">ከመ፡ ሐራጊት፡ ዘይቤ፡ መዝሙር፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ትምክሕተ፡ ኵልነ፡ አንቲ፡ እንተ፡ ኀጣእኪ፡ መርገሞ፨</t:l>
                  <t:l n="2">ለአዳም፡ አቡነ፡ ቅንአተ፡ ሰይጣን፡ እንተ፡ አሕመሞ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ቀናንሞ፨</t:l>
                  <t:l n="4">እፎ፡ ፈቀደ፡ ኅሊናየ፡ ለውዳሴኪ፡ ተፍጻሞ፨</t:l>
                  <t:l n="5">ወእፎ፡ ኀለየ፡ ዘኢይክል፡ አቅሞ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ኦዝመንክር፡ ወጥቀ፡ ዕጹብ፨</t:l>
                  <t:l n="2">ልደተ፡ ኢየሱስ፡ ክርስቶስ፡ ዘእንበለ፡ ዘርእ፡ ወሰብሳብ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ወለተ፡ እስራኤል፡ ጠባብ፨</t:l>
                  <t:l n="4">በሰማይኒ፡ ቅድመ፡ ይትፈጠር፡ ኪሩብ፨</t:l>
                  <t:l n="5">ዘእንበለ፡ እም፡ ተወልደ፡ እምአብ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ኦዝመንክር፡ ኒሢአ፡ አጽም፡ እምገቦ፨</t:l>
                  <t:l n="2">ኪያኪ፡ ይፍጥር፡ ከመ፡ ትኩኒ፡ መዝገቦ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ባላሂት፡ እምተመንድቦ፨</t:l>
                  <t:l n="4">ብፁዕ፡ ለኪ፡ እግዝእትየ፡ ዘየአምር፡ የብቦ፨</t:l>
                  <t:l n="5">ከመ፡ ለእስራኤል፡ ቀደምት፡ ዘተሰምየ፡ ሕዝቦ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">መሐለ፡ እግዚአብሔር፡ ለዳዊት፡ ፍቁሩ፨</t:l>
                  <t:l n="2">አበውኪ፡ ነገሥት፡ ከመ፡ በመንበሩ፡ ይንበሩ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ለእግዚአብሔር፡ ማኅደሩ፨</t:l>
                  <t:l n="4">ነቢያት፡ በእንቲአኪ፡ ሰላመ፡ ነገሩ፨</t:l>
                  <t:l n="5">ወሐዋርያት፡ ምስሌሆሙ፡ ኀብሩ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">ዳዊት፡ ዘነግሠ፡ መልዕልተ፡ አስራኤል፡ ሐራ፨</t:l>
                  <t:l n="2">ኪያኪ፡ ሰብሐ፡ በአውታር፡ ወበዕንዚራ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ወለተ፡ ቅስራ፨</t:l>
                  <t:l n="4">ለነፍሰ፡ ዚአየ፡ አስተዳልዊ፡ ማኅደራ፨</t:l>
                  <t:l n="5">ውስተ፡ መቅደስኪ፡ ዘማኅው፡ ሕብራ፨</t:l>
               </t:lg>
                  <t:lg type="stanza" n="7">
                     <t:l n="1">አሐዱ፡ አካል፡ ዘእምቅድስት፡ ሥላሴ፡</t:l>
                     <t:l n="2">ሥጋኪ፡ ለብሰ፡ ወኮነ፡ ብእሴ፡</t:l>
                     <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ሥርጉተ፡ ቅዳሴ፡</t:l>
                     <t:l n="4">ከበሮ፡ እዘብጥ፡ ለክብርኪ፡ ወእሁብ፡ ውዳሴ፡</t:l>
                     <t:l n="5">ከመ፡ ማርያም፡ እኅቱ፡ ለሙሴ፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Friday">
               <t:label>Friday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ቡርክት፡ አንቲ፡ ዘእምኔኪ፡ ሠረቀ፡</t:l>
                     <t:l n="2">ፀሐየ፡ ቅዱሳን፡ ክርስቶስ፡ እንተ፡ በይሁዳ፡ ተዐውቀ፡</t:l>
                     <t:l n="3">ማርያም፡ ኪያኪ፡ እስመ፡ እሴፎ፡ ጥዩቀ፡</t:l>
                     <t:l n="4">ሞገሰ፡ ስምኪ፡ ይኩነኒ፡ ስንቀ፡</t:l>
                     <t:l n="5">በኀበ፡ ነገድኩ፡ ብሔረ፡ ርኁቀ፡</t:l>
                  </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ቡርክት፡ አንቲ፡ ተዐብዪ፡ እምሰማይ፨</t:l>
                  <t:l n="2">ወትበርሂ፡ እምፀሓይ፨</t:l>
                  <t:l n="3">ማርያም፡ ዕንቍ፡ ማርያም፡ ዕንቈ፡ ባሕርይ፨</t:l>
                  <t:l n="4">ሕጽብኒ፡ እግዝእትየ፡ እምኵሉ፡ ጌጋይ፨</t:l>
                  <t:l n="5">ከመ፡ የሐፅቡ፡ ርስሐተ፡ በማይ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ቡርክት፡ አንቲ፡ ማርያም፡ ምክሖን፡ ለደናግል፨</t:l>
                  <t:l n="2">ዘንእዶን፡ ክርስቶስ፡ በውስተ፡ ወንጌል፨</t:l>
                  <t:l n="3">ማሕፀንኪ፡ ማርያም፡ ማኅደረ፡ አምላክ፡ ልዑል፨</t:l>
                  <t:l n="4">ሐጹር፡ የዐውዳ፡ ለስብሐተ፡ አብ፡ ወቃል፨</t:l>
                  <t:l n="5">ወጽጌ፡ ረዳ፡ በትእምርተ፡ መስቀል፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">ማርያም፡ ድንግል፡ ለዕፍት፡ ሙዳዩ፨</t:l>
                  <t:l n="2">ዘእምኔኪ፡ ተቀብኡ፡ እለ፡ ለመንግሥት፡ ተኀርዩ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ለልዑል፡ እመ፡ ባሕርዩ፨</t:l>
                  <t:l n="4">እስመ፡ ተቶስሐ፡ ለላሕይኪ፡ ላሕዩ፨</t:l>
                  <t:l n="5">ወበዕበይኪ፡ ተሠውጠ፡ ዕበዩ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ማርያም፡ ንጽሕት፡ ሰአሊተ፡ ምሕረት፡ ወጻሕቅ፨</t:l>
                  <t:l n="2">እንበለ፡ አዕሩግ፡ ወደቂቅ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ማዕነቅ፨</t:l>
                  <t:l n="4">ገቦኪ፡ ሥርግው፡ በሐመልማለ፡ ወርቅ፨</t:l>
                  <t:l n="5">ወአክፋንኪ፡ በብሩር፡ ፍሑቅ፨</t:l>
               </t:lg>
                  <t:lg type="stanza" n="6">
                     <t:l n="1"><choice><t:sic>ማርያም፡ ትብል፡ </t:sic><t:corr>ትጸርሕ፡ ወትብል፡</t:corr></choice> ኢየአምር፡ ምንተኒ፡</t:l>
                     <t:l n="2">ዘእንበለ፡ ድምፀ፡ ቃሉ፡ ለመልአክ፡ ዘአብሠረኒ፡</t:l>
                     <t:l n="3">ማርያም፡ ድንግል፡ ፍና፡ ጽድቅኪ፡ ምርሕኒ፡</t:l>
                     <t:l n="4">ዓለምሰ፡ ምስለ፡ ክብሩ፡ ማሳኒ፡</t:l>
                     <t:l n="5">ዝኒ፡ የኀልፍ፡ ወይሰዐር፡ ዝኒ፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Saturday">
               <t:label>Saturday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ንጽሕት፡ ወብርህት፡ እምነ፡ ፀሐይ፡ ዘትጸድሊ፡</t:l>
                     <t:l n="2">ወእምኑኀ፡ ሰማይ፡ ዘትትሌዐሊ፡</t:l>
                     <t:l n="3">ማርያም፡ ወለቱ፡ ለዳዊት፡ ዐርከ፡ ቤርዜሊ፡</t:l>
                     <t:l n="4">ኦእግዝእትየ፡ ሶበ፡ ኀቤኪ፡ እጼሊ፡</t:l>
                     <t:l n="5">በክሂሎትኪ፡ ኪያየ፡ አክህሊ፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ናስተበፅዕ፡ ዕበየኪ፡ ማርያም፡ ወትረ፨</t:l>
                  <t:l n="2">ወንፌኑ፡ ለኪ፡ ፍሥሓ፡ ምስለ፡ ገብርኤል፡ ኅቡረ፨</t:l>
                  <t:l n="3">በዝ፡ ዓለም፡ ወበዘይመጽአ፡ ድኅረ፨</t:l>
                  <t:l n="4">ውስተ፡ መቅደስኪ፡ እፈቱ፡ ኀዲረ፨</t:l>
                  <t:l n="5">ወኢትኅብአኒ፡ ዘይሤኒ፡ ምክረ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">ከመ፡ ከብካብ፡ ንጹሕ፡ ዘአልቦ፡ ጥልቀት፡ ውስቴቱ፨</t:l>
                  <t:l n="2">ያስተፌሥሐኪ፡ ጥቀ፡ ማርያም፡ በበ፡ ሥርዓቱ፨</t:l>
                  <t:l n="3">እምሀብተ፡ በረከት፡ ወሣህል፡ መንገለ፡ ላዕሉ፡ ዋታሕቱ፨</t:l>
                  <t:l n="4">ለማሕፀንኪ፡ በረከቶ፡ እፈቱ፨</t:l>
                  <t:l n="5">እግዚአብሔር፡ ዘተጸውረ፡ ቦቱ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ለዳዊት፡ ዘመዱ፨</t:l>
                  <t:l n="2">ዘእምኔኪ፡ ሕዝብ፡ ወአበውኪ፡ ተወልዱ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ለልዑል፡ እመ፡ ዋሕዱ፨</t:l>
                  <t:l n="4">በስብሐትኪ፡ እግዝእትየ፡ ኢይትዌሰን፡ ፍቅዱ፨</t:l>
                  <t:l n="5">እስመ፡ እምወሰን፡ ወሰነ፡ የዐዱ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">ኮንኪ፡ ዲበ፡ ምድር፡ ዳግሚተ፡ ሰማይ፨</t:l>
                  <t:l n="2">ከመ፡ ትለዲ፡ ፀሓየ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ እመ፡ እግዚእየ፨</t:l>
                  <t:l n="4">በቅድስናኪ፡ ቀድሲ፡ ነፍስየ፨</t:l>
                  <t:l n="5">ወበተስፋኪ፡ አኅድሪ፡ ሥጋየ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ደብተራ፡ ክርስቶስ፡ ብርሃን፨</t:l>
                  <t:l n="2">ዘሰመዩኪ፡ አበው፡ ቅድስተ፡ ቅዱሳን፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ በዓልተ፡ ዛቲ፡ መካን፨</t:l>
                  <t:l n="4">ለብሔረ፡ ንግሥኪ፡ ከመ፡ ብሔረ፡ ነገሥት፡ ባዕዳን፨</t:l>
                  <t:l n="5">ኢይዌስንዎ፡ ቤርሳቤህ፡ ወዳን፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ተሰመይኪ፡ እመ፡ ለክርስቶስ፡ ፈታኔ፡ አልባብ፡ ወልቡና፨</t:l>
                  <t:l n="2">ድኅረ፡ ወለድኪ፡ ኪያሁ፡ ነበርኪ፡ በድንግልና፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ወለተ፡ ኢያቄም፡ ወሐና፨</t:l>
                  <t:l n="4">ዲበ፡ እንግድዓየ፡ አክብዲ፡ ኅሊና፨</t:l>
                  <t:l n="5">ወበልቡናየ፡ ሠዕሊ፡ ትሕትና፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ሰዋስወ፡ ወርቅ፡ ቀዲሙ፨</t:l>
                  <t:l n="2">እስራኤል፡ ያዕቆብ፡ ዘነጸረኪ፡ በሕልሙ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ሞገሰ፡ ፍጹማን፡ ኵሎሙ፨</t:l>
                  <t:l n="4">ለወፅኦትኪ፡ ሐዋዘኒ፡ ዳእሙ፨</t:l>
                  <t:l n="5">ከመ፡ ኤልሳቤጥ፡ ለዮሐንስ፡ እሙ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="9">
                  <t:l n="1">ናሁ፡ እግዚእ፡ ዘእምኔኪ፡ ወፅአ፨</t:l>
                  <t:l n="2">በኍልቈ፡ ዕለታት፡ ሰብኡ፡ ለእለ፡ እጼውዐኪ፡ ሰብአ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ ወለተ፡ መርዓ፨</t:l>
                  <t:l n="4">አጽድቂ፡ እሙ፡ ኪያየ፡ ኃጥአ፨</t:l>
                  <t:l n="5">ወናዝዚ፡ ኀዘንየ፡ እንተ፡ ውስጥ፡ ወአፍአ፨</t:l>
               </t:lg>
                  <t:lg type="stanza" n="10">
                     <t:l n="1">ተፈሥሒ፡ ተፈሥሒ፡ ምልእተ፡ ጸጋ፡ ማርያም፡</t:l>
                     <t:l n="2">ልሕኵት፡ ንጽሕት፡ ክብረ፡ ኵሉ፡ ዓለም፡</t:l>
                     <t:l n="3">በኍልቈ፡ ዕለታት፡ ሰቡዑ፡ አርአያ፡ ለብኀዊ፡ ዘቅድም፡</t:l>
                     <t:l n="4">ዘአቅረብኩ፡ ለኪ፡ ተጋንዮ፡ በልሳንየ፡ ድኩም፡</t:l>
                     <t:l n="5">እግዚእትየ፡ ማርያም፡ ተወከፊ፡ ዮም፡</t:l>
                  </t:lg>
               
            </t:div>
            <t:div type="textpart" xml:id="Sunday">
               <t:label>Sunday</t:label>
               
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ተሰመይኪ፡ ፍቅርተ፡ ኦቡርክት፡ እምአእኑስ፡</t:l>
                     <t:l n="2">አንቲ፡ ውእቱ፡ ቀመረ፡ ዳግሚት፡ ሐዳስ፡</t:l>
                     <t:l n="3">ማርያም፡ ድንግል፡ ወለተ፡ ዳዊት፡ ንጉሥ፡</t:l>
                     <t:l n="4">ሰላም፡ ሰላም፡ ለመክዕኪ፡ ውዱስ፡</t:l>
                     <t:l n="5">ለለአሐዱ፡ እስከ፡ እግር፡ እምርእስ፡</t:l>
                  </t:lg>
               
               <t:lg type="stanza" n="2">
                  <t:l n="1">ታቦት፡ አንቲ፡ ዘረሰየኪ፡ ታእካሁ፨</t:l>
                  <t:l n="2">ኢየሱስ፡ ክርስቶስ፡ እስመ፡ ሥጋኪ፡ ሥጋሁ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ለእጓለ፡ እመሕያው፡ ተስፋሁ፨</t:l>
                  <t:l n="4">ዕቀብኒ፡ እግዝእትየ፡ ለለ፡ መዋዕሉ፡ ወወሩ፨</t:l>
                  <t:l n="5">እስመ፡ ኢየአምር፡ ሰብእ፡ ዘይመጽእ፡ ላዕሌሁ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="3">
                  <t:l n="1">መቅደስ፡ አንቲ፡ ዘይኬልኩኪ፡ ኪሩቤል፨</t:l>
                  <t:l n="2">እለ፡ ሥዑላን፡ በሥዕለ፡ እግዚአብሔር፡ ቃል፨</t:l>
                  <t:l n="3">ማርያም፡ ንጽሕት፡ ማርያም፡ ድንግል፨</t:l>
                  <t:l n="4">ሰላም፡ ሰላም፡ በምልአ፡ ኅሊናየ፡ እብል፨</t:l>
                  <t:l n="5">ለልደትከ፡ ፍሥሓ፡ ወሣህል፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="4">
                  <t:l n="1">አንቲ፡ ውእቱ፡ መሶበ፡ ወርቅ፡ ቀይሕ፨</t:l>
                  <t:l n="2">እንተ፡ ውስቴታ፡ መና፡ ብሩኅ፨</t:l>
                  <t:l n="3">ማርያም፡ ታቦት፡ ዘተለዐልኪ፡ በንጽሕ፨</t:l>
                  <t:l n="4">አድኅንኒ፡ እግዝእትየ፡ እማየ፡ ሙስና፡ መፍርህ፨</t:l>
                  <t:l n="5">ከመ፡ አድኀንኪዮ፡ ቀዳሚ፡ ለኖኅ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="5">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ተቅዋመ፡ ወርቅ፡ ዘትነብሪ፨</t:l>
                  <t:l n="2">ብርሃኑ፡ ለዓለም፡ ዘትጸውሪ፨</t:l>
                  <t:l n="3">ኦድንግል፡ መሓሪት፡ እመ፡ መሓሪ፨</t:l>
                  <t:l n="4">ኃጥኣን፡ ዘከማየ፡ አመ፡ ይኴንን፡ ፈጣሪ፨</t:l>
                  <t:l n="5">አድኅኖትየ፡ ማርያም፡ ስመሪ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="6">
                  <t:l n="1">አንቲ፡ ውእቱ፡ ማዕጠንት፡ ዘወርቅ፡ እግዝእትየ፨</t:l>
                  <t:l n="2">ፍሕመ፡ መለኮቱ፡ ውዑይ፡ እንተ፡ በዲቤኪ፡ ተወድየ፨</t:l>
                  <t:l n="3">ማርያም፡ ድግንል፡ ደመና፡ ብዕልየ፨</t:l>
                  <t:l n="4">በዝናመ፡ ንጽሕኪ፡ ሐረገ፡ ወይን፡ ጸንየ፨</t:l>
                  <t:l n="5">ወሮማን፡ ሐዋዘ፡ ፈረየ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="7">
                  <t:l n="1">ተፈሥሒ፡ ማርያም፡ ርግበ፡ ገነት፡ ጽባሓይ፨</t:l>
                  <t:l n="2">እስመ፡ ኮንኪ፡ እሙ፡ ለእግዚአብሔር፡ አዶናይ፨</t:l>
                  <t:l n="3">አንቲ፡ ውእቱ፡ ጽጌ፡ መዐዛ፡ ሠናይ፨</t:l>
                  <t:l n="4">ዘሠረፅኪ፡ እምሥርወ፡ ዕሴይ፡ ወእምጕንደ፡ ዳዊት፡ ኅሩይ፨</t:l>
                  <t:l n="5">ፍሬ፡ ማሕፀንኪ፡ ወልድ፡ ይሴፎ፡ ነዳይ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="8">
                  <t:l n="1">በትረ፡ አሮን፡ እንተ፡ ሠረፀት፡ ዘእንበለ፡ ተክል፡ ቀዳሚ፨</t:l>
                  <t:l n="2">ምስሌኪ፡ ኮነ፡ መነለ፡ ኅቡእ፡ በሥምረተ፡ አምላክ፡ ቀዳሚ፨</t:l>
                  <t:l n="3">ስእለተ፡ ነዳያን፡ ማርያም፡ እንተ፡ ኢትጽምሚ፨</t:l>
                  <t:l n="4">አስተበቍዐኪ፡ በዕለተ፡ ምንዳቤ፡ ማሕምሚ፨</t:l>
                  <t:l n="5">ውስተ፡ የማንየ፡ ለነዳይ፡ ትቁሚ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="9">
                  <t:l n="1">ለኪ፡ ይደሉ፡ ውዳሴ፡ ወስባሔ፨</t:l>
                  <t:l n="2">በአፈ፡ መላእክት፡ ወሰብእ፡ እለ፡ ይነብሩ፡ ውስተ፡ ኵለሄ፨</t:l>
                  <t:l n="3">ማርያም፡ ድንግል፡ ማርያም፡ እመ፡ ኤሎሄ፨</t:l>
                  <t:l n="4">ከመ፡ ለበሀዊ፡ ፍቁርኪ፡ አቅረብኩ፡ ምኣሄ፨</t:l>
                  <t:l n="5">ለዝክረ፡ ስምኪ፡ ዘይምዕዝ፡ እምርሔ፨</t:l>
               </t:lg>
               
               <t:div type="textpart" xml:id="tarafa-malke">
                  <t:lg type="stanza" n="1">
                     <t:l n="1">ሰአሊ፡ ለነ፡ ሰአሊ፡ ለነ፨</t:l>
                     <t:l n="2">ሰአሊ፡ በእንቲአነ፨</t:l>
                     <t:l n="3">ማርያም፡ እምነ፡ ወእሙ፡ ለእግዚእነ፨</t:l>
                     <t:l n="4">ወልድኪ፡ ይምሐረነ፡ ወመዋርስቲሁ፡ ይረስየነ፨</t:l>
                     <t:l n="5">በየማኑ፡ ያቁመነ፨</t:l>
                  </t:lg>
                  
                  <t:lg type="stanza" n="2"><t:note>after <t:bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename>Augustine</t:forename><t:surname>Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></t:bibl></t:note>
                     <t:l n="1">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ አድባር፡ ወአውግር፨</t:l>
                     <t:l n="2">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ ቀላያት፡ ወባሕር፨</t:l>
                     <t:l n="3">ስብሐት፡ ለኪ፡ ማርያም፡ በኍልቈ፡ ዕፀው፡ ወሣዕር፨</t:l>
                     <t:l n="4">ስብሐት፡ ለኪ፡ ማርያም፡ በልሳነ፡ ኵሉ፡ ፍጡር፨</t:l>
                     <t:l n="5">እስመ፡ ምሉእ፡ ስብሐትኪ፡ በሰማይ፡ ወምድር፨</t:l>
                  </t:lg>
                  <t:lg type="stanza" n="12" xml:id="explicit"><t:note>after <t:bibl corresp="http://zotero.org/groups/358366/items/97TNCJ8U"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:MalkaGubae1974"/><title level="m">መልክዐ ጉባኤ &lt;hi rend="italics"&gt;(&lt;/hi&gt;Mälkǝʾa gubaʾe&lt;hi rend="italics"&gt;, 'Collection of hymns')&lt;/hi&gt;</title><pubPlace>ʾAśmarā</pubPlace><publisher>Kokaba Șǝbāḥ māttamiyā bet</publisher><date>1981</date></t:bibl>, the same conclusion as <t:ref type="work" corresp="https://betamasaheft.eu/LIT2285Saqoqa#tarafa-malke"><span xmlns="" class="w3-tag w3-red">No item: LIT2285Saqoqa#tarafa-malke</span></t:ref></t:note>
                     <t:l n="1">ስብሐት፡ ለኪ፡ ማርያም፡ በስብሐተ፡ አብ፡ ፈናዊ፡</t:l>
                     <t:l n="2">ስብሐት፡ ለኪ፡ ማርያም፡ በስብሐተ፡ ወልድ፡ ተፈናዊ፡</t:l>
                     <t:l n="3">ስብሐት፡ ለኪ፡ ማርያም፡ በስብሐተ፡ መንፈስ፡ ማሕየዊ፡</t:l>
                     <t:l n="4">ዲበ፡ ጸሎትነ፡ አዕዛነ፡ መንፈስ፡ ጽልዊ፡</t:l>
                     <t:l n="5">ወዲበ፡  ዛቲ፡ ጸሎት፡ ሰላመ፡ ከዓዊ፡</t:l>
                  </t:lg>
               </t:div>
               
            </t:div>
         
         </t:div>
      </t:body>
   </t:text></TEI>
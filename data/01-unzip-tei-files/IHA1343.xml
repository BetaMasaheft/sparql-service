                  <msItem xml:id="ms_i1">
                     <locus from="1" to="195">*p. 1-195</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2781IHA">حصن الحصين من كلام سيد المرسلين</title>
                     <incipit xml:lang="ar">
                        <locus target="#*p. 2">-*p. 2</locus>بسم الله الرحمن الرحيم اللهم صل على سيد الخلق سيدنا مهمد وآله وصهبه وسلم قال الفقير الضعيف المسكن المنقطع الى الله تعالى [...] محمد بن محمد الجزرى الشافعى لطف الله به في شدته أما بعد حمدا لله الذى جعل الدعاء لرد القضاء [...] فان هذا الحصن الحصين من كلام سيد المرسلين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#*p. 194-95">-*p. 194-95</locus>يوم الأحد بعد الظهر الثانى والعشرين من ذي الحجة الحرام سنة احدى وتسعين وسبعمائة بالمدرسة التي أنشأتها برأس عقبة الكنان داخل دمشق المحروسة حماها الله [...] وهو حسبى ونعم الوكيل وقد أجزت ألولادى أبا الفتح محمدا وأبا بكر أحمد وأبا القاسم عليا وأبا الخير محمدا وفاطمة وعائشة وسلمى وخديجة روايته عنى مع جميع ما يجوز لى رواتته وذكلك أجزت أهل عصرى والحمد لله وحده أولا وآخرا وظاهرا وباطنا وصلاته على سيد الخلق محمد آله ومحبه وسلامه عليه عليهم أجمعين</explicit>
                     <note/>
                     <note/>
                  </msItem>

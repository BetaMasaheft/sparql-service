         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3254/" n="143" corresp="https://betamasaheft.eu/api/iiif/EMIP03254/manifest">Antippas 4</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter with Five Illuminations</summary>
                  <msItem xml:id="ms_i1"><locus from="3r" to="135v" facs="003">Fols 3r–135v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="3r" to="104v" facs="003">Fols 3r–104v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                    <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> from the common new system</note>
                  </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="105r" to="115r" facs="105">Fols 105r–115r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <note>The fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>"Prayer of Hana, mother of Samuel, Prophetess"</q></note>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="115v" to="121r" facs="116">Fols 115v–121r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Common edition</note>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="121r" to="132r" facs="121">Fols 121r–132r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  <note>Arranged for the days of the week, beginning on Monday and culminating on Sunday</note>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="132r" to="135v" facs="132">Fols 132r–135v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">136</measure>
                           <dimensions type="outer" unit="mm">
                              <height>210</height>
                              <width>155</width>
                              <depth>60</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="20">
                         <locus from="3r" to="121r" facs="003">Fols 3r–121r</locus>
                       </layout>
                       <layout columns="2" writtenLines="20">
                         <locus from="121r" to="137v" facs="121">Fols 121r–137v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <desc>Extensive columetric layout of text:
                    <ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa#ThreeYouths3"><span xmlns="" class="w3-tag w3-red">No item: LIT1566hababa#ThreeYouths3</span></ref>,
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps150"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps150</span></ref>,
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps145"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps145</span></ref>,
                    <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps28"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps28</span></ref></desc>
                    <desc>The scribe shows a predeliction for columetric layout and alternating red and black letters in certain texts, e.g., Pss 28, 145, 150, etc.</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#13r" facs="013">Fol. 13r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#13r" facs="013">Fol. 13r</locus><desc>martyrdom of John the Baptist</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#13r" facs="013">Fol. 13r</locus><desc>Miracle of Mary where she gives water in a shoe to a dog</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#13r" facs="013">Fol. 13r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> and Satan</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#42r" facs="042">Fol. 42r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>, flanked by two guardian <term key="angel" ana="#angel"/>s with drawn <term key="sword" ana="#sword"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#58r" facs="058">Fol. 58r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#111r" facs="111">Fol. 111r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1038Baptism">Baptism of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#135r" facs="135">Fol. 135r</locus><desc>Conflicts with the Jews</desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#135r" facs="135">Fol. 135r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#135r" facs="135">Fol. 135r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1015Flagellation">Flagellation of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#135r" facs="135">Fol. 135r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                      <locus target="#91r #105r" facs="091 105">Fols. 91r, 105r</locus>
                      <desc>The book has been arranged by a secondary hand in the upper margins, for readings in the days of the week</desc>
                    </item>
                    <item xml:id="e2">
                      <desc>Marks midpoint with text in right margin</desc>
                    </item>
                    <item xml:id="a1">
                      <desc><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has some pluses added in a secondary hand</desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#2r" facs="002">Fol. 2r</locus>
                      <desc>In the foreguard pages there is a record with fingerprint and signature</desc>
                    </item>
                    <item xml:id="e4">
                      <desc>Strings in the fore edges mark the location of material, as a navigation system</desc>
                    </item>
                    <item xml:id="a3">
                      <locus target="#136v" facs="137">Fol. 136v</locus>
                      <desc type="Genealogy">
                        Geneology of Grazmač <foreign xml:lang="am">ግራዝማች፡ ተገኘ፡</foreign> from Gojjam, for eight generations, in Amharic. The founder of the geneology,
                        <foreign xml:lang="am">ለታ፡ ገሎ፡</foreign>, had 10 children. He left the first three in Oromo land and moved to Gojjam, where he had seven more children,
                        who would have become Amharic speaking Gojjamis
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1900" notAfter="1950">Early-twentieth century</origDate>
                  </origin>
               </history>
            </msDesc>
         </sourceDesc>

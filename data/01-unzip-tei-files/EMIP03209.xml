                    <item xml:id="a1">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    <desc type="DonationNote">
                    Note of donation by the wife of Daggazmach Hayla Maryam, Amharic
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    <desc>
                    Illegible document, in Amharic
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <locus target="#2r" facs="002">Fol. 2r</locus>
                    <desc>
                    Illegible document with the names of witnesses, in Amharic. A confraternity is mentioned
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc>
                    Not in Amharic to the effect that Walda Giyorgis accepts responsibility for certain books of the Church of Saint George
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <locus target="#2v" facs="003">Fol. 2v</locus>
                    <desc>
                    Note in Amharic about certain possesasions of Daggazmac Goshu, including a cloak
                    </desc>
                    </item>
                    <item xml:id="a6">
                    <locus target="#3r" facs="003"> f. 3r and passim</locus>
                    <desc>
                    Copied for <foreign xml:lang="gez">ተክለ ሚካኤል</foreign>, Takla Mika’el
                    </desc>
                    </item>

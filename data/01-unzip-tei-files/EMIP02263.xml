                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> gives a thirsty dog water to drink from her shoe</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1002Annunciation">Annunciation</ref> with <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> spinning cloth</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#iiir(ecto)" facs="003">Fol. iiir(ecto)</locus><desc>Our Lady <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> heals a blind man</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus><desc>Our Lady <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> and the child <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> with a broken water jug</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#56v" facs="060">Fol. 56v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/> flanked by leopards and tigers</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#72v" facs="076">Fol. 72v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#73r" facs="076">Fol. 73r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc> with the archangels <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName> and <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#73v" facs="077">Fol. 73v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and John standing beside the cross</desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#74r" facs="007">Fol. 74r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                    <decoNote type="frame" xml:id="d11">

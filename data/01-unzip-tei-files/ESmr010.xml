                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, but careful.</seg>
                        <seg type="ink">Black, vivid red.</seg>
                        <date>20th century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይሕ፡ for ይብል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipit of Text I; titles of the books
                           to be read; directives to the ministers and their abbreviations; numbers
                           of the prayers; elements of the punctuation signs; Ethiopic numerals;
                           quire marks.
 On the incipit page of Text I (fol.3r), a few lines are
                           rubricated (alternating with black lines).</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">Ḥaräg 1.</decoNote>
                     <decoNote type="frame" xml:id="d2">
                        <locus target="#3r (incipit of Text I)">f. 3r (incipit of Text I): </locus>
                        <desc>coloured (red, black) ornamental band, with two lateral extensions
                           (interlaces).</desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#40rb">f. 40rb</locus>
                           <desc>: Donation note.</desc>
                           <quote xml:lang="gez">
                              <locus target="#40rb">40rb</locus>: ዛቲ፡ መጽሐፍ፡ ዘወሀባ፡ ገብረ፡ እግዚአብሔር፡ ምስለ፡
                              ብእሲቱ፡ ወለተ፡ ሥላሴ፡ ለታቦተ፡ አቡነ፡ ሊባኖስ፡ መስጥሕ፡ ከመ፡ ትኵኖሙ፡ መርሐ፡ ለመንግሥተ፡ ሰማያት፡
                              ዘሠረቃ፡ ወዘፈሐቋ፡ በሥልጣነ፡ ጴጥሮስ፡ ወጳውሎስ፡ ውጉዘ፡ ለይኩን።</quote>
                           <quote xml:lang="en"/>
                           <note> Written by the same hand as that of the main text. The note
                              mentions the names of the donor, Gabra ʾƎgziʾabǝḥer as well as his
                              wife Walatta Śǝllāse. It reports also that the Ms. was donated to the
                              church of Libānos of Mäsṭǝḥ. </note>
                        </item>
                        <item xml:id="e1">- Crude notes and pen trials: <locus target="#1r">1r</locus>, 1v, 41r, 41v.
 - Unusual punctuation sign in the
                           shape of chevrons, written in the margins (e.g. <locus target="#16r">16r</locus>).</item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards covered with reddish-brown tooled
                           leather (quarter cover).
 Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Chains of endband stitches at the spine
                           cover.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the reddish-brown leather
                           overback (at least 2 blind tools were used: double circle, double line
                           fillet).</decoNote>
                     </binding>

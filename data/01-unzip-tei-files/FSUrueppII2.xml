                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i9.4">
                                <locus from="319">Fols 319 and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl4">Josippon, Kǝfl 4</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i9.5">

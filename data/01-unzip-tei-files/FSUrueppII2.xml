                                <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl6">Josippon, Kǝfl 6</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i9.7">
                                <locus from="353">Fols 353 and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl7">Josippon, Kǝfl 7</title>
                                <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="ms_i9.8">
                                <locus from="370">Fols 370 and following</locus>

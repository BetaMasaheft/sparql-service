                          <textLang mainLang="gez" otherLangs="am"/>

                          <msItem xml:id="ms_i1.1">
                            <locus from="3r" to="12r"/>
                            <title type="complete"> Gǝʿǝz-Amharic vocabulary. </title>
                            <textLang mainLang="gez" otherLangs="am"/>
                            <incipit xml:lang="gez"> ሰዋስው፡ ብሂል፡ መሸጋገርያ፡ ወመሰላል፡
                            </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus target="#12v"/>
                          <title type="complete"> ነገረ፡ አራዊት፡ ዘኢይተበልሁ፡</title>
                          <textLang mainLang="gez" otherLangs="am"/>
                          <note>On the names of non-edible animals.</note>
                      </msItem>

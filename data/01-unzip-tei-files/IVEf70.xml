                        <locus target="#13r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ አዕዋፍ፡</title>
                        <textLang mainLang="gez"/>
                        <note>Names of birds</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4">
                        <locus target="#13r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ሥጋ፡</title>
                        <textLang mainLang="gez"/>
                        <note>Names of body parts</note>
                        </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus target="#13v"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ዕፀዋት፡</title>
                        <textLang mainLang="gez"/>
                          <note>Names of trees</note>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus target="#14r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ አቅሐ፡</title>
                        <textLang mainLang="gez"/>
                        <note>Names of vessels</note>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus target="#14v"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ብርሐናት፡</title>
                        <textLang mainLang="gez"/>
                        <note>Names of luminaries</note>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus target="#16r"/>
                        <title type="complete" xml:lang="en">List of Ethiopic verbs</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኮነ፡ ተሰምየ፡ ረሰየ፡ ገብረ፡ ኃደገ፡ ረከበ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> እሉ፡ ኵሎሙ፡ ያመጽኡ፡ ግዕዛ፡ ፈደለ፡ ዘበትርጓሜሁን፡ ወአመ፡ ቦአ፡ ተሰምየ፡ ኮነ፡
          ያመጽኡ፡ ሐምሰ፡ ፊደላተ፡ እለ፡ እሙንቱ፡ ናዛዚ፡ አግዓዚ፡ ተዓዛዚ፡ አኃዚ፡ ማኅየዊ፡ ዓባዊ፡ </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus from="16v" to="19v"/>
                        <title type="complete" xml:lang="en">List of verbs with direct objects in alphabetical order of the last letter.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ፍኖተ፡ ጼሐ፡ ፍኖተ፡ መርሐ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ሰይፈ። መልሐ፡ </incipit>
                        <explicit xml:lang="gez">ባሕረ፡ ኃለፈ፡ ተሰርገወ፡ አውቃፈ፡ ዘባነ፡ ቅሰፈ፡</explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="20r" to="21v"/>
                        <title type="complete" xml:lang="en">Sentences with verbs in alphabetical order of the last letter.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ዕደ፡ ሰበእናሁ፡ በሰናሰለ፡ ንዴተ፡ ተሞቅሐ፡ ማኅተመ፡ ጥበብ፡ ባዕደ፡ ልቡ፡ ፈትሐ፡</incipit>
                        <explicit xml:lang="gez">እግረ፡ ሰብእናሁ፡ በዕብነ፡ መከራ፡ ተአቅፈ።</explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="22r" to="32r"/>
                        <title type="complete" xml:lang="en">Grammatical glossary.</title>
                        <textLang mainLang="gez" otherLangs="am"/>
                        <incipit xml:lang="gez">ብህልኩ፡ አልሁ፡ ብህለ፡ አለ፡</incipit>
                        <explicit xml:lang="gez">አፍቀረነ፡ ለነ፡ ብ፡ እኛን፡ ወደደን፡</explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="32v" to="37v"/>
                        <title type="complete" xml:lang="en">Grammatical glossary.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ይቤ፡ አለ፡ ይብል፡ ይላል፡ ይበል፡ ይል፡</incipit>
                     </msItem>


               <msContents>
                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="93">Fols 1–93</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1672Isaiah">ዘኢሳይያስ፡ ነቢይ፡</title>
                     <textLang mainLang="gez"/> 
                     <explicit xml:lang="gez">ዘኢሳይያስ፡ ነቢይ፡ በዝየ፡ ተፈጸመ፡</explicit>
                     <note>See also <ref target="#e1"/>.</note>
                     <note>
                        <p>The following divisions are indicated by rubricated beginnings:</p>
                        <p>1:1;</p>
                        <p>2:1;</p>
                        <p>5:1;</p>
                        <p>6:1;</p>
                        <p>7:1;</p>
                        <p>13:1;</p>
                        <p>14:28;</p>
                        <p>15:1;</p>
                        <p>16:13;</p>
                        <p>17:1;</p>
                        <p>19:1;</p>
                        <p>20:1;</p>
                        <p>21:1;</p>
                        <p>21:11;</p>
                        <p>22:1;</p>
                        <p>23:1;</p>
                        <p>30:6;</p>
                        <p>36:1;</p>
                        <p>38:9.</p>
                     </note>
                     <note>The text of this book is not all correct. It offers many variants when compared with
                        <ref type="mss" corresp="https://betamasaheft.eu/BDLbruce74#p1_i3"><span xmlns="" class="w3-tag w3-red">No item: BDLbruce74#p1_i3</span></ref> and is completely different at many places.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="93" to="114">Fols 93–114</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1671Isaiah">ዕርገተ፡ ኢሳይያስ፡ ነቢይ፡</title>
                     <textLang mainLang="gez"/> 
                     <note>There is no chapter division; the one made in the edition <bibl corresp="http://zotero.org/groups/358366/items/IJSUVIA5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Laurence1819Ascensio"/><title level="m">Ascensio Isaiae vatis</title><author><forename>Richard</forename><surname>Laurence</surname></author><pubPlace>Oxoniae</pubPlace><publisher>Typis Academicis</publisher><date>1819</date><note type="url">https://archive.org/details/ascensioisaiaeva00laur</note><note type="tags"><note type="tag">bm:Laurence1819Ascensio</note></note><note type="tag">bm:Laurence1819Ascensio</note></bibl>
                        must have been taken from elsewhere. Only Chapter 7:1 is distinguished by a rubricated beginning.</note>
                     
                     <colophon xml:id="coloph1">
                        <locus target="#114">Fol. 114</locus>
                        <listBibl type="text">
                           <bibl corresp="http://zotero.org/groups/358366/items/IJSUVIA5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Laurence1819Ascensio"/><title level="m">Ascensio Isaiae vatis</title><author><forename>Richard</forename><surname>Laurence</surname></author><pubPlace>Oxoniae</pubPlace><publisher>Typis Academicis</publisher><date>1819</date><note type="url">https://archive.org/details/ascensioisaiaeva00laur</note><note type="tags"><note type="tag">bm:Laurence1819Ascensio</note></note><note type="tag">bm:Laurence1819Ascensio</note><citedRange unit="page">78–80</citedRange></bibl>
                        </listBibl>
                     </colophon>
                     
                     <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/IJSUVIA5"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Laurence1819Ascensio"/><title level="m">Ascensio Isaiae vatis</title><author><forename>Richard</forename><surname>Laurence</surname></author><pubPlace>Oxoniae</pubPlace><publisher>Typis Academicis</publisher><date>1819</date><note type="url">https://archive.org/details/ascensioisaiaeva00laur</note><note type="tags"><note type="tag">bm:Laurence1819Ascensio</note></note><note type="tag">bm:Laurence1819Ascensio</note></bibl>
                     </listBibl>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="115" to="183">Fols 115–183</locus>
                     <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1376Apocal">ዘዕዝራ፡ ፩፡</title>
                     <textLang mainLang="gez"/> 
                     <note>There is no chapter division, but after 8:23 a large empty space occurs.</note>

                          <msItem xml:id="ms_i1.1">
                          <locus target="#3r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1693John#JohnGospelHeadline"><t:hi xmlns:t="http://www.tei-c.org/ns/1.0" rend="rubric"> ብስራተ፡ አብ፡ ትሩፍ፡ ረድእ፡ ተናጋሪ፡ በመለኮት፡
                            ዮሐንስ፡ ወልደ፡ዘብዴዎስ፡፡ ፍቁረ፡ እግ</t:hi>ዚአብሔር
                            </title>
                            </msItem>
                              <msItem xml:id="ms_i1.2">
                                <locus from="3r" to="89va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT1693John#JohnGospel">Gospel of John: Gospel of John</title>
                                   <incipit><t:hi xmlns:t="http://www.tei-c.org/ns/1.0" rend="rubric">ቀዳሚሁ፡ ውእቱ፡ ቃል፡ ወውእቱ፡ ቃል፡ ኀ</t:hi>በ፡ እግዚኣብሔር፡ ሀለወ፡ ወእግዚኣብሔር፡ ውእቱ፡
                                    ቃል፡ ዝንቱ፡ እምቀዲሙ፡ ሀሎ፡ ኀበ፡ እግዚኣብሔር። ኵሉ፡ ቦቱ፡ ኮነ፡ ወዘእንበሌሁሰ፡ አልቦ፡ ዘኮነ፡፡</incipit>
                                    <explicit>ወሶበ፡ ተጽሕፈ፡ ኵሉ፡ በበ፡ ኣሓዱ፡ እምኢያገምሮ፡ዓለም፡ ጥቀ፡ መጻሕፍቲሁ፡ ዘእምተጽሕፈ፡ አሜን። ወአሜን። ለይኩን ለይኩን። ወ</explicit>
                                  </msItem>
                            <msItem xml:id="ms_i1.3">
                              <locus target="#89v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1693John#Postscript">Gospel of John: Colophon of the Gospel of John</title>
                              <incipit>መልዓ፡ ስብከተ፡ ዮሐንስ</incipit>
                              <explicit>ወበ፷፡ ዓመተ፡ መንግሥቱ፡ </explicit>
                                <explicit type="subscriptio">ዝ፡ መጽሐፍ፡ ዘ <persName role="owner" ref="https://betamasaheft.eu/PRS13313Labbawekrestos">ለባዊ፡ ክርስቶስ፡</persName> ጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS13314Haylamasqal">ኃይለ፡ መስቀል፡</persName> ወአቡሁ፡ <persName ref="https://betamasaheft.eu/PRS13315TasfaIyyasus"> ተስፋ፡ ኢየሱስ፡</persName> ወእሙ፡ <persName ref="https://betamasaheft.eu/PRS13316WalattaDawit"> ወለተ፡ ዳዊት፡</persName> ወብእሲቱ፡&gt; <persName ref="https://betamasaheft.eu/PRS13328AbalaMaryam"> አባለ፡ ማርያም፡</persName> ወውሉዱ፡ <persName ref="https://betamasaheft.eu/PRS13329Pestqis">ጵስጥቂስ፡</persName> ዘሠረቆ፡ ወዘፈሐቆ፡</explicit>
                                </msItem>
                                <msItem xml:id="ms_i1.4">
                                  <locus target="#90r"/>
                                  <title type="complete" ref="https://betamasaheft.eu/LIT1693John#TituliJohn">Gospel of John: Tituli of the Gospel of John<t:hi xmlns:t="http://www.tei-c.org/ns/1.0" rend="rubric">ዘዮሐንስ፡ ፳፡ አርእስት፡</t:hi></title>
                                  <incipit>በእንተ፡ ከብካብ፡ ዘቃና</incipit>
                                  <explicit>ተፈጸመ፡ ዘዮሐንስ፡ አርእስት፡</explicit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.5">
                                      <locus from="90rb" to="92va"/>
                                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John#BiographyJohn">Gospel of John: Biography of John</title>
                                      <incipit><t:hi xmlns:t="http://www.tei-c.org/ns/1.0" rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡</t:hi>ቅዱስ ፩ በመለኮት፡ ወይሤለስ፡ በአካላት፡ ለዓለም፡ ዓለም፡ አሜን።</incipit>
                                      <explicit>ሎቱ፡ ስብሐት፡ ክብር፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን።</explicit>
                         </msItem>

               <msContents>
                  <summary>I) Tazkāra maṣḥafa saʿātāt “Commemoration of the Horologium” (fols.
                     1v-2r)
 II) Computation tables for the hours of each month (fols. 2v-3v, 6r)
                     - tables for the months Ṭǝrr-Maggābit (fol. 2v)
 - tables for the months
                     Miyāzyā-Sane (fol. 3r)
 - tables for the months Ḥamle-Maskaram (fol.
                     3v)
 - tables for the months Ṭǝqǝmt-Ṗagʷǝmen (fol. 6r)
 
 Additio
                     1.</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="2r"/>
                     <title ref="https://betamasaheft.eu/LIT5995TazkaraMSaatat">Tazkāra maṣḥafa saʿātāt</title>

                     <note>The text seems arranged like in a table; it is not written on ruled
                        lines.</note>
                     
                  </msItem>
                  
                  
                  <msItem xml:id="ms_i2">
                     <locus from="2v" to="3v"/>
                     <locus target="#6r"/>
                     <title ref="https://betamasaheft.eu/LIT5996ComputHours">Computation for the hours of each month</title>
                     <msItem xml:id="ms_i2.1">
                        <locus target="#2v"/>
                        <title ref="https://betamasaheft.eu/LIT5996ComputHours#TerrYakkatitMaggabit">Table for the months Ṭǝrr, Yakkatit, Maggābit</title>
                     </msItem>
                     <msItem xml:id="ms_i2.2">
                        <locus target="#3r"/>
                        <title ref="https://betamasaheft.eu/LIT5996ComputHours#MiyazyaGenbotSane">Table for the months Miyāzyā, Gǝnbot, Sane</title>
                     </msItem>
                     <msItem xml:id="ms_i2.3">
                        <locus target="#3v"/>
                        <title ref="https://betamasaheft.eu/LIT5996ComputHours#HamleMaskaram">Table for the months Ḥamle, Naḥāse, Maskaram</title>
                     </msItem>                     
                     <msItem xml:id="ms_i2.4">
                        <locus target="#6r"/>
                        <title ref="https://betamasaheft.eu/LIT5996ComputHours#TeqemtMaskaram">Table for the months Ṭǝqǝmt, Ḫǝdār, Tāḫśāś, Ṗagʷǝmen</title>
                     </msItem>
                  </msItem>
                  

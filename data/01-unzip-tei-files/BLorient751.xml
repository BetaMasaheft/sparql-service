                        <msItem xml:id="ms_i5">
                          <locus from="105r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1415GadlaA">History of Adam and Eve</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ሎቱ፡ ስብሐት፡ ጽሕፈተ፡ ገድለ፡ አዳም፡ ወሔዋ፡
                          ዘበጽሐ፡ ላዕሌሆሙ፡ እምድኅረ፡ ፀአቶሙ፡ እምገነት፡ ወንብረቶሙ፡ ውስተ፡ በዓተ፡ መዛግብት፡ በትእዛዘ፡ እግዚአብሔር፡ ፈጣሪ፡
                        ሎሙ፡ ወመጋቢ፡ ሎቱ፡ ስብሐት።</incipit>
                        <explicit type="supplication" xml:lang="gez"><locus target="#171v"/>
                          ሣህሉ፡ ወምሕረቱ፡ የሀሉ፡ ምስለ፡ ነፍሰ፡
                          ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5616IyasuI">ኢያሱ፡</persName> ወምስለ፡ ወልዱ፡
                        ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS2377Bakaffa">በካፋ፡</persName> ለዓለመ፡ ዓለም፡ አሜን፡ ወአሜን።</explicit>
                        </msItem>

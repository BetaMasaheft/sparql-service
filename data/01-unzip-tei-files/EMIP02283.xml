                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#ms_i4">Fols. ms_i4, </locus>
                    <locus target="#80r #84v #89v #93v #98v #102r #105r" facs="-94 089 094 098 103 106 109">80r, 84v, 89v, 93v, 98v, 102r, 105r</locus>
                    <desc>Headings for the days of the week: Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, and Sunday</desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    A sheet of parchment is glued to the front cover as a turn-in
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    The protection quire (i–iv) and quire 12 (111–112) are paper. The rest of the quires are made of parchment
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc type="OwnershipNote">
                    <locus target="#2r" facs="006"> f. 2r and passim</locus>
                    mentions an owner, <persName ref="https://betamasaheft.eu/PRS13244GabraWald">Gabra Wald</persName>
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#110v #111r #111v #112r #112v" facs="115 116 117">Fols. 110v, 111r, 111v, 112r, 112v</locus>
                    blank
                    </desc>
                    </item>

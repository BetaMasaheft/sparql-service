               </msIdentifier>
               <msContents>
                  <summary>Sword of Divinity, Image of the Trinity, Sword of Divinity, Book of Crown of Victory<locus target="#2r">fol. 2r</locus> and passim mention an owner, ገብረ ወልድ.</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="60v" facs="005">Fols 1r–60v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2295Sayfam">Sayfa malakot</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="61r" to="73r" facs="065">Fols 61r–73r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2736RepCh20">Malkǝʾa
                                                  Śǝllāse</title>
                    <incipit xml:lang="gez">ሰላም፡ ለህላዌክሙ፡ ዘይመውዕ፡ ህላዌያተ።</incipit>
                  </msItem>

                  <msItem xml:id="ms_i3">
                    <locus from="73v" to="80r" facs="078">Fols 73v–80r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2295Sayfam">Sayfa malakot</title>
                  </msItem>

                  <msItem xml:id="ms_i4">
                    <locus from="80r" to="110r" facs="084">Fols 80r–110r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4008Mashaf">Book of the diadem
                                                  of victory and book of the harp</title>
                    <colophon xml:id="coloph1">
                      <locus target="#110r" facs="114">Fol. 110r</locus>
                      A colophon has been started, but left incomplete. 
                      It reads: <q><foreign xml:lang="gez">ዝንቱ፡ መጽሐፍ፡ ዘ</foreign></q>, 
                      <q>“This book, which is”</q>
                    </colophon>
                  </msItem>
                  </msContents>

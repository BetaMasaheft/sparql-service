               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="3v">2r-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3291IHA">صلوات لسيدنا خضر</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>بسم الله الرحمن الرحيم / صل وسلم على سيدنا السراج النوار  </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>صل وسلم على سيد المتدرع بدرع الامان المنطق بمنطقة الرضوان الموصوف بالجود والاحسان نعمة الوجود والامداد والاسلام والايمان وصلى الله على سيدنا وعلى اله وصحبه وسلم تمت</explicit>
                     <note>text on folio 2r is partially unclear</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="5r">4r-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3301IHA">نظم الحبيب المقرب الطيب المطيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>بسم الله الرحمن الرحيم / الحبيب المقرب الطيب المطيب السحيق المسك والعنبر الاشهب صل وسلم على سيدنا الكيس المكيس </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>[صل وسلم على سيدنا رسول [الملاح 
 المكين  الدعائم تالى الايات الهائم محي الليالي القائم العاقب الماحى الخاتم وصلى الله عليه وعلى اله عدد الجمادات والبهائم تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="6v" to="7v">6v-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3302IHA">صلاة على النبي الصلاة والسلام عليك يا نبي الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus> بسم الله الرحمن الرحيم /
الصلاة والسلام عليك يا نبي الله 
والصلات والسلام عليك يا رسو الله 
والصلات والسلام عليك يا حبيب الله 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7v">-7v</locus>الصلاة والسلام عليك يا نبي الزكي الصلاة والسلام عليك يا نبي الأمي تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="8r" to="23v">8r-23v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3303IHA">خطب العيدين</title>
                     <incipit xml:lang="ar">
                        <locus target="#8r">-8r</locus> بسم الله الرحمن الرحيم / ألحمد لله ألصلاة والسلام على رسول لله أطيعوا لله رحمكم الله
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#23v">-23v</locus> وذكروا الله العظيم يذكركم وشكروه على نعمه يزدكم ولذكرالله أكبز  والله يعلم ما تصنعون
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="23v" to="28r">23v-28r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3308IHA">تلقين الميت</title>
                     <incipit xml:lang="ar">
                        <locus target="#23v">-23v</locus>بِسمِ اللهِ الرَحمَنِ الرَحِيمِ / اَلحَمدُ لِله مُدَبِّرِ القَدَرِ  بقَعقَعَةِ المطر ومرسل الموت كمثل الرعد </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#28r">-28r</locus>سبحان ربك رب العزة عما يصفون والسلام على المرسلين والحمد الله رب العامين وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم تمت تلقين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="28v" to="45r">28v-45r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1120IHA">دعاء عدد معلوماتك ومداد كلماتك</title>
                     <incipit xml:lang="ar">
                        <locus target="#28v">-28v</locus>صلاة دائمة بدوامك عدد ألائك ونعامك عدد معلوماتك ومداد كلماتك عدد الأفلاك والنجوم وما فوق الأرض </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#45r">-45r</locus>صلاة تجلي بها عن قائلها الصدى وترزقه بها عيش واسعار غدا المخاطب بقوله عز وجل في كتابه المبين وقل ربي أنزلني منزلا مباىركا وأنت خيرالمنزلين   </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="46v" to="53v">46v-53v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3312IHA">مخمس بدأت ذكري نور حسين</title>
                     <incipit xml:lang="ar">
                        <locus target="#46v">-46v</locus>/ اللهم ارحم نور حسين
/ اللهم ارحم نور حسين
/ اللهم ارحم نور حسين  
/ اللهم رحم نور حسين عد ما لك في الدارين
/ بسم الله والحمد الله 
/ على المصطفى صلى الله
/ ال وصحب أسد الله
/ صلي عليهم يا الله وعلى كل النبيين 
بدأت ذكري نور حسين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#53v">-53v</locus>/ قلت حيلتي نور حسين انت معين المساكين
/ صلاة الله المؤبد
/ وسلامه المسرمد 
/ على سيد محمد
اله الركع السجد نجوم الهدي بااليقين تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="53v" to="57v">53v-57v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT3316IHA">توسل اغثنا أغثنا نور حسين</title>
                     <incipit xml:lang="ar">
                        <locus target="#53v">-53v</locus>اغثنا أغثنا سيد نور حسين يا سريعا الغوث المزاب الرحمة الحمد لله مزيل الكربة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#57r">-57r</locus> النهي يا كريم [أظمالي] عمر ودبر أمره يسر للعسر<note>Explicit is drawn from 57r because text on 57v is illegible. </note>
                     </explicit>
                     <note>All pages missing lower right/left corner which renders the last two lines partially illegible.
Entire text on 57v is worn and largely illegible. 
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="58v" to="65v">58v-65v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0049IHA#s10IHA">قران, Third ǧuz’ (3/30)</title>
                     <incipit xml:lang="ar">
                        <locus target="#58v">-58v</locus>تلك الرسل فضلنا بعضهم على بعض منهم 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#65v">-65v</locus>يؤتى الحكمة من يشاء ومن يؤت الحكمة فقد اوتي خيرا كثيرا وما يذكر الا اولوا الالباب وما انفقتم</explicit>
                     <note>Contains Qur’ān 2:253 - 2:270.
Black script w. taǧwīd markers in red. 
Pages partially damaged by rodents. </note>
                     <note/>
                  </msItem>

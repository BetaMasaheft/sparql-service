               <msContents>
                  <summary/> 
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r">Fols 1r and following</locus>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT3506CatholicEpis">Catholic
                                                  Epistles</title>
                     <textLang mainLang="gez"/>
                
                     <msItem xml:id="ms_i1.1">
                        <locus from="1r">Fols 1r and following</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT3507Epistle">End of 1 Peter (from 4:10b)</title>
                        <textLang mainLang="gez"/>
                        <explicit type="subscriptio" xml:lang="gez">መልአት፡ መልእክተ፡ ጴጥሮስ፡ ቀዳሚት፡ ወስብሐት፡ ለእግዚአብሔር፡ ለዓለመ፡ ዓለም፡
                    አሜን፡ ወአሜን፡</explicit>
                     </msItem>
                
                     <msItem xml:id="ms_i1.2">
                        <locus from="3r">Fols 3r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3508Epistle">መልእክተ፡ ጴጥሮስ፡ ዳግሚት።</title>
                        <textLang mainLang="gez"/>
                        <note>There are numbered chapter divisions at the following places:
                    <p>1 (1:2); 2 (1:12); 3 (1:15); 4 (1:19)</p>
                           <p>5 (2:1); 6 (2:9)</p>
                           <p>7 (3:1); 8 (3:8); 9 (3:12)</p>
                        </note>
                     </msItem>
                
                     <msItem xml:id="ms_i1.3">
                        <locus from="8v">Fols 8v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3509Epistle">ዘዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡
                    ወንጌላዊ፡ ሐዋርያሁ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ጸሎቱ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <textLang mainLang="gez"/>
                        <note>There are numbered chapter divisions at the following places:
                    <p>1 (1:1)</p>
                           <p>2 (2:1); 3 (2:7); 4 (2:18); 5 (2:24); 6 (2:29)</p>
                           <p>7 (3:11)</p>
                           <p>4:7; 4:13</p>
                           <p>5:1; 5:15</p>
                        </note>
                     </msItem>
                
                     <msItem xml:id="ms_i1.4">
                        <locus from="17r">Fols 17r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3510Epistle">መልእክተ፡ ዮሐንስ፡ ዳግሚት።</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                
                     <msItem xml:id="ms_i1.5">
                        <locus from="18r">Fols 18r and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3511Epistle">Third Epistle of
                                                  John</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">መልአት፡ መልእክተ፡ ዮሐንስ፡ ወልደ፡ ዘብዴዎስ፡ ሣልሲት፡ ወስብሐት፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </explicit>
                     </msItem>
                
                     <msItem xml:id="ms_i1.6">
                        <locus from="19r">Fols 19r and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3512Epistle">ዘያዕቆብ፡ ሐዋርያ።</title>
                        <textLang mainLang="gez"/>
                        <note>There are numbered chapter divisions at the following places:
                    <p>1 (1:1); 2 (1:13); 3 (1:22)</p>
                           <p>4 (2:2); 5 (2:14); 6 (2:21)</p>
                           <p>7 (4:1); 8 (4:11)</p>
                           <p>9 (5:1); 10 (5:9)</p>
                        </note>
                     </msItem>
                
                     <msItem xml:id="ms_i1.7">
                        <locus from="27v">Fols 27v and following</locus>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3513Epistle">በስመ፡ 
                    <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                    መልእክተ፡ ይሁዳ፡ እኁሁ፡ ለያዕቆብ።</title>
                        <textLang mainLang="gez"/>           
                        <note>There are chapter divisions at the following places: 1:5; 1:9; 1:14.</note>
                     </msItem>
                  </msItem>
            
                  <msItem xml:id="ms_i2">
                     <locus from="31r">Fols 31r and following</locus>
                     <title type="incomplete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1019Actsof">ግብረ፡ ልኡኩን፡ ዝንቱ፡ ዜና፡ 
                ሐዋርያት፡ ቅዱሳን፡ ጸሎቶሙ፡  
                <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>። ጸሐፈ፡ ሉቃስ፡ ቅዱስ፡ ጠቢብ፡
                ሶበ፡ ተስእሎ፡ ታኦፊላ። ይቤ፡ ቀዳሚ፡ ጸሐፍኩ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </title>
                     <textLang mainLang="gez"/>
                     <note>The pericopes are marked in the margin.</note>
                     <note>The following passages are missing:
              4:5-18; 9:5b-18; 13:11b-24; 16:17b-29 (omitted by the copyist)</note>
                     <note>This manuscript's text is older than that of <ref type="mss" corresp="https://betamasaheft.eu/BNFet41">Paris, Bibliothèque nationale de France, BnF Éthiopien 41</ref>.
                It has many variants, errors and small lacunae of words or phrases.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <colophon xml:id="coloph1">
                        <note> The final note states that this manuscript was produced 
                  for the convent of the Apostles at     <placeName ref="https://betamasaheft.eu/INS0308DQ">Dayr al-Muḥarraq</placeName>
                  by two monks of the house of <persName ref="https://betamasaheft.eu/PRS11232HouseSam">House of Sāmuʾel of Wāldǝbbā</persName>, 
                  <persName cert="low" ref="https://betamasaheft.eu/PRS9197Taklase">Takla Ṣǝyon</persName> and <persName ref="https://betamasaheft.eu/PRS10997Galawdeyos">Galāwdǝyos</persName>
                  (<foreign xml:lang="gez">
                              <persName ref="https://betamasaheft.eu/PRS11232HouseSam">ደቂቀ፡ አባ፡ ሳሙኤል፡ ዘበዲመ፡ ዋሊ፡</persName>
                           </foreign>)</note>
                     </colophon>
                  </msItem>
               </msContents>
          

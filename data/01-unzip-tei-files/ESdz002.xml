               <msContents>
                  <summary>I) Maṣḥafa gǝnzat “Book of the Funeral Ritual” (fols. 2r-75v),
                     incomplete
 - Homily of ʾabbā Salāmā, Metropolitan of Ethiopia (fols. 18ra,
                     l.7 – 22ra, l.5).</summary>
                  <msItem xml:id="ms_i1">

                     <title>
                        Maṣḥafa gǝnzat
                     </title>
                     <note>
                        <locus target="#54">54</locus> placed in the wrong position (recto for verso
                        and vice versa).</note>
                     <msItem xml:id="ms_i1.1">
                        <title>Homily of ʾabbā Salāmā, Metropolitan of Ethiopia</title>
                     </msItem>
                  </msItem>
                 
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">75.0</measure> folios, of which
                              <measure unit="leaf" type="blank">1.0</measure> blank 1, in <measure unit="quire">8.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">215</height>
                              <width unit="mm">190</width>
                              <depth unit="mm">50</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>Quires I, V
                           and VIII are not clearly identifiable. f. 25 has been torn off
                           quire III. Reinforcing parchment strips are inserted between most
                           of the quires.
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">9</dim>
                                 <locus from="1r" to="9v"/>I(9/fols. 1r-9v, s.l. 1, no stub) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="10r" to="17v"/> II(8/fols. 10r-17v) </item>
                              <item xml:id="q3">
                                 <dim unit="leaf">8</dim>
                                 <locus from="18r" to="25v"/> III(8/fols. 18r-25v) </item>
                              <item xml:id="q4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="26r" to="33v"/> IV(8/fols. 26r-33v; s. l.: 2, 7, stubs after 1,
                                 6) </item>
                              <item xml:id="q5">
                                 <dim unit="leaf">10</dim>
                                 <locus from="34r" to="45v"/> V(fols. 34r-45v) </item>
                              <item xml:id="q6">
                                 <dim unit="leaf">12</dim>
                                 
                                 <locus from="46r" to="57v"/> VI(12/fols. 46r-57v) </item>
                              <item xml:id="q7">
                                 <dim unit="leaf">10</dim>
                                 
                                 <locus from="58r" to="67v"/> VII(10/fols. 58r-67v) </item>
                              <item xml:id="q8">
                                 <dim unit="leaf">8</dim>
                                 <locus from="68r" to="75v"/>
                                 VIII(fols. 68r-75v).</item>
                           </list>
                        </collation>
                        <condition key="deficient">Some fols. at the end of the Ms. are missing,
                           some are misplaced. The threads of the binding are broken. Many leaves
                           have fallen apart, some are held together by means of parchment aguards
                           or crude stitches (e.g., fols. 2, 53, 71, 72, 73).</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="18">
                           <dimensions unit="mm">
                              <height>125</height>
                              <width>130</width>
                              <dim type="intercolumn">10</dim>
                           </dimensions>
                           <dimensions type="margin">
                              <dim type="top">30</dim>
                              <dim type="bottom">50</dim>
                              <dim type="right">40</dim>
                              <dim type="left">13</dim>

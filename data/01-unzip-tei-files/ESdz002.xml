                           <note>
                              <locus target="#26r">26r</locus>
                           </note>
                           <ab type="ruling"/>
                           <ab type="pricking">Ruling and pricking are visible.</ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A-1A1A/0-0/0-0/C.</ab>
                           <ab type="pricking"> Primary pricks are partly visible (s. <locus target="#53v">53v</locus>).</ab>
                           <ab type="pricking"> Ruling pricks are mostly visible (s. <locus target="#50r">50r</locus>).</ab>
                           <ab type="ruling"> The upper line is written above the ruling.</ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Late 17th - early-18-century.</date>
                        <list type="abbreviations">
                           <item>ይካ፡ for ይብል፡ ካህን፡</item>
                           <item>ይዲ፡ for ይብል፡ ዲያቆን፡</item>
                           <item>ይሕ፡ for ይብል፡ ሕዝብ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; incipits or headings of texts; the
                           words እገሌ፡ and እገሊት፡ standing for the name of the deceased; elements of
                           the punctuation signs; elements of Ethiopic numerals.
 
 The text
                           in fol. 2r is written alternately in red and black lines.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">1) Chain of black and red dots (<locus target="#12rb">12rb</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d2">2) Chain of black and red dots (<locus target="#18ra">18ra</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d3">3) Chain of black and red dots (<locus target="#22ra">22ra</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d4">4) Chain of black and red dots (<locus target="#44va">44va</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d5">5) Chain of black and red dots (<locus target="#51ra">51ra</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d6">6) Chain of black and red dots (<locus target="#53rb">53rb</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d7">7) Chain of black and red dots (<locus target="#59rb">59rb</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d8">8) Alternating rows of nine dot asterisks
                        and chains of red and black dots (<locus target="#63ra">63ra</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d9">9) Alternating rows of nine dot asterisks
                        and chains of red and black dots (<locus target="#70vb">70vb</locus>)</decoNote>
                     <decoNote type="frame" xml:id="d10">10) Chain of black and red dots (<locus target="#75vb">75vb</locus>).</decoNote>
                     <decoNote type="miniature" xml:id="d11"/>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">- Red thread inserted in the right upper corner of
                                 <locus target="#6v">fol. 6v</locus>, for navigation in the
                              text.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>- Fols. 7r, 42r, in the upper margin. Crude notes. - Fols. 9v-10r, in the upper margin. Supplication for the soul of ʾAtnatewos, the donor. - Fols. 32v-33r, in the upper margin. Crude note, partly in Amharic.</desc>
                        </item>
                     </list>
                  </additions>

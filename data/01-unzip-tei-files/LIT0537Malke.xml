      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0537</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለፅንሰትኪ፡ በሩካቤ፡ ዘበሕግ፨</l>
                  <l n="2">እምብርከ፡ አበው፡ አዕሩግ፨</l>
                  <l n="3">ሰዋስወ፡ ኅሬ፡ ማርያም፡ እንተ፡ ሰማያት፡ ምዕራግ፨</l>
                  <l n="4">ከመ፡ እንግር፡ ዜና፡ ፅንሰትኪ፡ ወልደትኪ፡ በደርግ፨</l>
                  <l n="5">ማየ፡ ጥበብኪ፡ ይምላእ፡ በልብየ፡ አይግ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለልደትኪ፡ ዘተባረከ፡ ዕለት፨</l>
                  <l n="2">እምቤተ፡ ሌዊ፡ ካህን፡ ወእምቤተ፡ ንጉሥ፡ ዳዊት፨</l>
                  <l n="3">ቀሰተ፡ ኤልሳዕ፡ ማርያም፡ ወእንተ፡ ሠሉስ፡ ገራኅት፨</l>
                  <l n="4">ምርሕኒ፡ ከመ፡ ስምኪ፡ በሰዓተ፡ ፍዳ፡ ወቅስት፨</l>
                  <l n="5">ኀበ፡ ኢሀለዉ፡ መከራ፡ ወሞት፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ወለሥዕርትኪ፡ እምዓለሙ፨</l>
                  <l n="2">ለክርስቶስ፡ ህየንተ፡ ስሙ፨</l>
                  <l n="3">ማርያም፡ ድንግል፡ በልደትኪ፡ መጠነ፡ ዐቅሙ፨</l>
                  <l n="4">አዳም፡ ይዌድሰኪ፡ ምስለ፡ ደቂቁ፡ ኵሎሙ፨</l>
                  <l n="5">እስመ፡ ለአዳም፡ ብኪ፡ ተስእረ፡ መርገመ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ ኀበ፡ ተደለወ፡ መካን፨</l>
                  <l n="2">እንተ፡ እዝነ፡ ሰብእ፡ ኢሰምዐ፡ ወዘኢርእየ፡ ዐይን፨</l>
                  <l n="3">ዘተወለድኪ፡ ማርያም፡ እምነ፡ ቡርክት፡ ማሕፀን፨</l>
                  <l n="4">አድኅንኒ፡ እምነገሮሙ፡ ለሰብአ፡ ዐማጺት፡ ዘመን፨</l>
                  <l n="5">እለ፡ ይትናገሩ፡ በክልኤ፡ ልሳን፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ በዘትአጠየቀ፡ ወአእመረ፨</l>
                  <l n="2">መድኃኒተ፡ ሕሙም፡ ማርያም፡ እስመ፡ ኪያከ፡ ፈጠረ፨</l>
                  <l n="3">ወበእንተዝ፡ በሊዮ፡ አመ፡ ኀቤነ፡ አንጸረ፨</l>
                  <l n="4">ለአይ፡ ትፈትሕ፡ ለኃጥኣን፡ ወትጼግዎሙ፡ አሣረ፨</l>
                  <l n="5">እስመ፡ በይነ፡ እሉ፡ ሰተይከ፡ ሐሞተ፡ መሪረ፨</l>
               </lg>
            </div>
         </div>
      </body>

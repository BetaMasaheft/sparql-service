                  <summary>Gospel of John, ወንጌል፡ ዘዮሐንስ፡</summary>
                    <msItem xml:id="ms_i1">
                      <locus from="1r" to="83r" facs="003">Fols 1r–83r</locus>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                      <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                      <note>Arranged for the days of the week:</note>

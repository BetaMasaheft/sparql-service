         <t:listPerson>
            <t:person sex="2">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መነን፡ አስፋው፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Manan ʾAsfāw</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="baptismal">ወለተ፡ ጊዮርጊስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Walatta Giyorgis</t:persName>
               
               <t:persName>
                  <t:roleName type="title">ʾǝtege</t:roleName>
               </t:persName>
               
               
               <t:occupation type="political">Queen</t:occupation>
               <t:birth when="1889"/>
               
               
               <t:floruit notBefore="1911" notAfter="1962"> She was the wife of <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</t:persName>, 
                  married to him in <t:date>1911</t:date>. She had six children with him, 
                  of whom only  three survived. The marriage lasted over half a century and there was much sympathy between them. She was crowned on 
                  the occassion of her husband's coronation cermony in <t:date>1930</t:date>. Manan shared her husband's exile though having had 
                  a traditional education and not being acquainted with foreign languages she passed her 
                  public role in support of her husband to her Swiss educated daughter, <t:persName ref="https://betamasaheft.eu/PRS8337Sahayha">Ḍäḥay Ḫaylä Śǝllase</t:persName>.
                  
               </t:floruit>
               <t:death when="1962"/>
               
            </t:person>
            
            
         </t:listPerson>
         
         
         

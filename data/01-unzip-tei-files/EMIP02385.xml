                    <decoNote type="miniature" xml:id="d1"><locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> with two <term key="angel" ana="#angel"/>s holding <term key="sword" ana="#sword"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iiiv(erso)" facs="004">Fol. iiiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#ivr(ecto)" facs="004">Fol. ivr(ecto)</locus><desc>The Binding of <ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref></desc></decoNote>

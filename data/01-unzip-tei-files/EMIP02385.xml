                  <additions>
                  <list>
                    <item xml:id="a1">
                      <desc>Arranged for the days of the week in a different hand
                        <locus target="#19v" facs="020">fol. 19v</locus><hi rend="margin">Saturday</hi>
                        <locus target="#25r" facs="026">25r</locus><hi rend="margin">Tuesday</hi>
                        <locus target="#44r" facs="046">44r</locus><hi rend="margin">Saturday</hi>
                        <locus target="#63r" facs="055">63r</locus><hi rend="margin">Thursday</hi>
                        <locus target="#79v" facs="065">79v</locus><hi rend="margin">Friday</hi>
                        <locus target="#89r" facs="055">89r</locus><hi rend="margin">Sunday</hi>

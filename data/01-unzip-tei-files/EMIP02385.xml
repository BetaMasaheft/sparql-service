                    <decoNote type="miniature" xml:id="d7"><locus target="#24r" facs="028">Fol. 24r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> with <term key="sword" ana="#sword"/> and <term key="scabbard" ana="#scabbard"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#37r" facs="041">Fol. 37r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1010Entombment">Entombment of Jesus</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#47r" facs="051">Fol. 47r</locus><desc>Ornate <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#52r" facs="056">Fol. 52r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#53r" facs="057">Fol. 53r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d12"><locus target="#70r" facs="074">Fol. 70r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName> from the dead</desc></decoNote>
                    <decoNote type="miniature" xml:id="d13"><locus target="#79r" facs="083">Fol. 79r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two <term key="angel" ana="#angel"/>s holding <term key="sword" ana="#sword"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d14"><locus target="#97r" facs="101">Fol. 97r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1062CoronationMary">Coronation of Mary</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d15"><locus target="#100r" facs="104">Fol. 100r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>

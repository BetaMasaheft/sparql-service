                     <list>
                        <item xml:id="a1">
                           <locus target="#1v">f. 1v</locus>
                           <desc>: Excerpt from Mazmur, Antiphones for seasons of the year.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> The excerpt is carelessly written in the same hand as Additio 3.

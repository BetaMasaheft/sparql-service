                            <handDesc>
                                <handNote script="Ethiopic" xml:id="h1">
                                    <desc>Good hand of the <date>18th century</date>
                                    </desc>
                                    <date notBefore="1700" notAfter="1800" resp="PRS10171Wright"/>
                                </handNote>
                            </handDesc>
                            <additions>
                                <list>
                                    <item xml:id="e1">
                                        <desc type="MixedNote">
                                            The name of the first owner has been erased, and that of <foreign xml:lang="gez">
                                                <persName role="owner" ref="https://betamasaheft.eu/PRS13465KenfaM">ክንፈ፡ ሚካኤል፡</persName></foreign>substituted.
                                        </desc>
                                    </item>
                                </list>
                            </additions>
                        </physDesc>
                    </msPart>
                    
                    <msPart xml:id="p2">
                        <msIdentifier/>
                        <msContents>
                            <summary/>
                            <msItem xml:id="p2_i1">
                                <title type="complete" ref="https://betamasaheft.eu/LIT2169Pateri">መጽሐፈ፡ ዜናሆሙ፡ ለአበው፡</title>
                                <textLang xml:lang="gez"/>
                            </msItem>
                        </msContents>
                        <physDesc>
                            <objectDesc>
                                <supportDesc>
                                    <support>
                                        <material key="parchment">parchment</material>
                                    </support>
                                </supportDesc>
                                <layoutDesc>
                                    <layout columns="2" writtenLines="18 20" cert="high"/>
                                </layoutDesc>
                            </objectDesc>
                            <handDesc>
                                <handNote script="Ethiopic" xml:id="h2">
                                    <desc>Well written of the earlier part of the <date>18th century</date>.
                                    </desc>
                                    <date notBefore="1700" notAfter="1730" resp="PRS10171Wright"/>
                                </handNote>
                            </handDesc>
                            <additions>
                                <list>
                                    
                                    <item xml:id="a1">
                                        <locus target="#1r">f. 1r</locus>
                                        <desc type="OwnershipNote">
                                            The note states that the manuscript belongs to the church of <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.
                                        </desc>
                                        <q xml:lang="gez">
                                            ዜና፡ አበው፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName></q>
                                    </item>
                                    
                                    <item xml:id="a2">
                                        <locus target="#155v">f. 155v</locus>
                                        <desc type="GuestText">
                                            <title ref="https://betamasaheft.eu/LIT3027RepCh307">A hymn to the Christian church</title>
                                        </desc>
                                        <q xml:lang="gez"><seg part="I">ኃይልኪ፡ ተዓውቀ፡ ወበርኅበ፡ ዓለም፡ ሰፈነ። በመዋዕለ፡ ሕይወት፡ ወበወርኃ፡ ሞት፡ እስመ፡ አድምዓ፡ ሥልጣነ።</seg></q>
                                    </item>
                                    
                                    <item xml:id="a3">
                                        <locus target="#155v">f. 155v</locus>
                                        <locus target="#156">f. 156</locus>
                                        <locus target="#157">f. 157</locus>
                                        <desc type="MixedNote">
                                            Notes in Amharic from the reigns of <persName ref="https://betamasaheft.eu/PRS3692egwalas">Gʷālu</persName>, <persName ref="https://betamasaheft.eu/PRS5637IyoasI">ʾIyoʾās</persName>
                                            , <persName ref="https://betamasaheft.eu/PRS5619IyasuIV">ʾIyāsu IV</persName> and <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Theodore</persName>.
                                        </desc>
                                        <q xml:lang="am"/>
                                    </item>
                                    <item xml:id="e2">
                                        <desc>
                                            The name of the first owner <foreign xml:lang="gez">አ<gap reason="lost"/>ተ፡ ክርስቶስ፡</foreign><locus target="#38r">f. 38r </locus>
                                            has been generally altered in <foreign xml:lang="gez"> <persName role="owner" ref="https://betamasaheft.eu/PRS13464SeelaK">ሥዕለ፡ ክርስቶስ፡</persName>
                                            </foreign>, and this has in its turn been frequently erased e. g. on <locus target="#115v">f. </locus>
                                            , <locus target="#155r">f.155</locus>.
                                        </desc>
                                    </item>
                                </list>
                            </additions>
                        </physDesc>

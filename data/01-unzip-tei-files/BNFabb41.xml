                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="403"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6368PsaltComm">The
                       Ethiopic Psalter with Amharic commentary </title>
                     <note>The commentary comes close to a thorough translation of the
                       Ethiopic text. The works <ref type="work" corresp="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</ref>
                     and <ref type="work" corresp="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</ref> are
                   not included in the Psalter.</note>

                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="403"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6368PsaltComm#Psalms">Amharic Commentary on the Psalter, Psalms of David with Amharic commentary</title>
                        <textLang mainLang="am" otherLangs="gez"/>
                        <incipit xml:lang="gez">
                        <locus target="#1"/>
                      <lb n="1"/><hi rend="rubric">ተግሣጽ፡ ለጻድቃን፡ ወለኃጥአን።</hi>
                      <lb n="2"/>የጻድቃንን፡ የኃጥአንን፡ ግብራቸውን፡ ትርጓሜ፡ ይሚነግር፡ ይህ፡ ነው፨
                      <lb n="3"/><hi rend="rubric">መዝሙር፡ ዘዳዊት፡ ሃሌ፡ ሉያ።</hi>
                      <lb n="4"/>የዳዊት፡ ነገር፡ ነው፡ ማለት፡ ፍቁር፡ ኅሩይ፡ ማለት፡ ነው፨
                      <lb n="5"/><hi rend="rubric">፩ብፁዕ፡ ብእሲ፡ ዘኢሖረ፡ በምክረ፡ ረሲዓን።</hi>
                    <lb n="6"/>እግዚአብሔር፡ የለም፡ ቀድሞም፡ ፍጥረታትን፡ አልፈጠረም፡ ዛሬም፡ ዓ
                       <lb n="7"/>ለምን፡ አይመግብም፡ በሚሉ፡ ምክር፡ ያልሔደ፡ ንዑድ፡ ሰው፡ ነው።
                       <lb n="8"/>ወዘኢቆመ፡ ውስተ፡ ፍኖተ፡ ኃጥአን፨
                       <lb n="9"/>በአምልኮትም፡ አለን፡ ሲሉ፡ ኃጢአት፡ በሚሰሩ፡ ሰው፡ በሟያቸው፡ ያልተገነ፡ ሰው፡ ንዑድ፡ ነው።
                      </incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="403" to="471"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6368PsaltComm#CanticlesProphets">Amharic Commentary on the Psalter, Canticles of the Prophets with Amharic commentary</title>
                        <textLang mainLang="am" otherLangs="gez"/>

                        <msItem xml:id="ms_i1.2.1">
                           <locus from="403" to="406"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT6368PsaltComm#SongsProphetsMoses1">Amharic Commentary on the Psalter,  SongsProphetsMoses1</title>
                           <incipit xml:lang="gez">
                           <locus target="#403"/>
                            <lb n="1"/> <hi rend="rubric">መኃልየ፡ ነቢያት፡ ወጸሎቱ፡ ለሙሴ። የነቢያት፡ ምስጋና፡ የሙሴም፡
                          ጸሎት፡ ይኽ፡ ነው።</hi>
                      <lb n="2"/>፩፡ ንሴብሖ፡ እግዚአብሔር፡ ስቡሕ፡ ዘተሰብሐ፨
                        <lb n="3"/>ቀድሞ፡ በመላእክት፡ አፍ፡ አሁንም፡ ግብጽን፡ በማጥፋት፡ የተመሰገነ፡
                         <lb n="4"/>እግዚአብሔርን፡ እናመሰግነዋለን።
                          <lb n="5"/>ፈረስ፡ ወመስተፅዕናነ፡ ወረወ፡ ውስተ፡ ባሕር፨
                       <lb n="6"/>የፈርዖን&gt; ሠራዊት፡ ፈረሱን፡ ከለሰራሪው፡ በኤርትራ፡ ስላስጠመ፨
                          <lb n="7"/>ረዳኤ፡ ወመሰውረ፡ ኮነኒ፡ ለአድኅኖትየ፨
                          <lb n="8"/>ለኔ፡ ግን፡ ረጅ፡ ኾነኝ፡ ፍርዖንም፡ በተከተለኝ፡ ጊዜ፡ ያድኅነኝ፡ ዘንድ፡
                          ደመና፡ ጋርዶ፡ <seg rend="above">ሰወረኝ</seg>፨
                         </incipit>

                        </msItem>


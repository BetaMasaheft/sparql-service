               <msContents>
                  <summary>Table Blessing, Nine Miracles of Jesus, ተአምረ፡ ኢየሱስ፡</summary>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="12r" facs="009">Fols 4r–12r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5069Prayer">Saʾalnāka maḥari
                                                  saʾalnāka faṭāri</title>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="12v" to="30v" facs="026">Fols 12v–30v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme">Taʾammǝra
                                                  ʾIyasus</title>

                      <msItem xml:id="ms_i2.1">
                        <locus from="12v" to="14r" facs="026">Fols 12v–14r</locus>
                        <title>The witness of John the Baptist, John 1:1–9</title>
                      </msItem>
                      <msItem xml:id="ms_i2.2">
                        <locus from="14r" to="16v" facs="029">Fols 14r–16v</locus>
                        <title>How the child Jesus rode the ray of the sun</title>
                      </msItem>
                      <msItem xml:id="ms_i2.3">
                        <locus from="16v" to="20r" facs="034">Fols 16v–20r</locus>
                        <title>How the child Jesus made real birds from mud</title>
                      </msItem>
                      <msItem xml:id="ms_i2.4">
                        <locus from="20r" to="22r" facs="041">Fols 20r–22r</locus>
                        <title>Jesus on his first day in school</title>
                      </msItem>
                      <msItem xml:id="ms_i2.5">
                        <locus from="22r" to="24v" facs="045">Fols 22r–24v</locus>
                        <title>The stolen calf</title>
                        <note>(Grébaut, Jésus II, pp. 776–79)</note>
                      </msItem>
                      <msItem xml:id="ms_i2.6">
                        <locus from="24v" to="26v" facs="040">Fols 24v–26v</locus>
                        <title>Jesus ordered his followers to observe the Sabbath</title>
                      </msItem>
                      <msItem xml:id="ms_i2.7">
                        <locus from="26v" to="28v" facs="054">Fols 26v–28v</locus>
                        <title>The choice of Mary to be the Mother of the Son</title>
                      </msItem>
                      <msItem xml:id="ms_i2.8">
                        <locus from="28v" facs="058">Fols 28v and following</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2272salota#Simeon">Now you
                                                  dismiss, Simeon</title>
                      </msItem>
                      <msItem xml:id="ms_i2.9">
                        <locus from="28v" to="30v" facs="058">Fols 28v–30v</locus>
                        <title>The story of the Nativity</title>
                        <note>(Grébaut, Jésus I, pp. 583–89)</note>
                      </msItem>
                  </msItem>

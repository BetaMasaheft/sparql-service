                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="4r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT4065Prayer#MondayTuesday">Prayer of thanksgiving for the offering of the incense: Prayers for Monday and Tuesday</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            ጸሎተ፡ ዕጣን፡ ዘያነብብ፡ ቀሲስ፡ ጊዜ፡ ቦአ፡ ቤተ፡ መቅደስ፡ ወበግብአቱ፡ አፍአ፡ እመንጦላዕት፡ ቀዊሞ፡ ይብል፡
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <locus from="42v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4691Prayer#Sunday">
                            <certainty locus="value" match="../@ref" cert="low"/>
                            ወበእሑድ፡
                          </title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i3">
                          <locus from="47r"/>
                          <title type="complete" xml:lang="gez">አንብሮ፡ እድ፡ ዘ፱ ሰዓት፡</title>
                          
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i4">
                          <locus from="47v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT4285Prayer">
                            <certainty locus="value" match="../@ref" cert="low"/>
                            ዘሠርክ፡
                          </title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i5">
                          <locus from="48r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT4263Prayer">
                            <certainty locus="value" match="../@ref" cert="low"/>
                            Prayers for the first, second, and ninth hours of the night
                          </title>
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i6">
                          <locus from="55r"/>
                          <title type="complete" xml:lang="en">Prayer for the morning</title>
                          
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i7">
                          <locus from="62v"/>
                          <title type="complete" xml:lang="gez">ጸሎተ፡ ራእይ፡</title>
                          
                          <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i8">
                          <locus from="64r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            በእንተ፡ ትምህርተ፡ ኅቡአት
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i9">
                          <locus from="69r"/>
                          <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT1100Anapho">
                            Morning prayers and eucharistic service
                          </title>
                          <textLang mainLang="gez"/>
                          <incipit xml:lang="gez">
                            መጽሐፈ፡ ኪዳን፡ ዘነገሮሙ፡ ለሐዋርያት፡ <sic>እምድኅረ፡</sic> ዕርገቱ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ።
                          </incipit>
                        </msItem>
                        <msItem xml:id="ms_i10">
                          <locus from="94v"/>
                          <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1807Litonz">ዘሰኑይ፡ ሊጦን፡ ዘነግህ፡</title>
                          <textLang mainLang="gez"/>
                        </msItem>

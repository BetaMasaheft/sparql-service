                    <history>
                        <origin>
                          The manuscript was copied for the priest
                          <persName role="owner" ref="https://betamasaheft.eu/PRS13603GabraM">Gabra Mikāʾel</persName>.
                            <origDate notBefore="1861" notAfter="1867" evidence="reign nomenclature">
                              The manuscript was copied during the reign of
                              <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName>, when
                              <persName ref="https://betamasaheft.eu/PRS3500Demetriu">Demetrius II of Alexandria</persName> was patriarch, and
                              <persName ref="https://betamasaheft.eu/PRS8388SalamaI">Salāmā III</persName> was metropolitan (<locus target="#7r"/>).
                            </origDate>
                        </origin>
                        <provenance>The manuscript had very probably belonged to a church in the <placeName ref="https://betamasaheft.eu/LOC3577Gondar">Gondar</placeName> area,
                            from where it was taken by
                            <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> and brought to <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>. It was then looted
                            by the British <persName ref="https://betamasaheft.eu/PRS7484Napier">Napier</persName> expedition in <date>1868</date>.</provenance>
                    </history>

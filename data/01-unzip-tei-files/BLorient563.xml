                        <additions>
                          <list>
                            <item xml:id="a1">
                              <locus target="#1r"/>
                              <desc type="GuestText">Hymn to Takla Hāymānot</desc>
                              <q xml:lang="gez">
                                <seg part="I">
                                  በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ሥላሴ። ተክለ፡ ሃይማኖት፡ ዳግማይ፡
                                  ሙሴ። አማን፡ በአማን፡ ኮንከ፡ ኃጢአተ፡ ዓለም፡ ደምሳሴ። ሃ፡ ሃ፡ ሃ።
                                </seg>
                              </q>
                            </item>
                            <item xml:id="a2">
                              <locus target="#3r"/>
                              <desc type="GuestText">Hymn to Jesus Christ, incomplete</desc>
                              <q xml:lang="gez">
                                <seg part="I">
                                  ስብሐተ፡ ፍቁር፡ ዘኢየሱስ፡ ክርስቶስ፡
                                </seg>
                              </q>
                            </item>
                            <item xml:id="a3">
                              <locus target="#3v"/>
                              <desc type="GuestText">Prayer</desc>
                              <q xml:lang="gez"/>
                            </item>
                            <item xml:id="a4">
                              <locus target="#116v"/>
                              <desc type="GuestText">
                                <title type="complete" ref="https://betamasaheft.eu/LIT3131Prayer">
                                <certainty locus="value" match="../@ref" cert="low"/>
                                </title>
                              </desc>
                              <q xml:lang="gez">
                                <seg part="I">
                                  አብ፡ ወወልድ፡ ወምንፈስ፡ ቅዱስ፡ ሰዳዲሆሙ፡ ለአጋንንት።
                                </seg>
                              </q>
                            </item>
                            <item xml:id="a5">
                              <locus target="#117r"/>
                              <desc type="GuestText">
                                <title type="incomplete" ref="https://betamasaheft.eu/LIT2332serata">Śǝrʿāta beta krǝstiyān</title>,
                                 incomplete at the end
                              </desc>
                              <q xml:lang="am">
                                <seg part="I">
                                  ገረገራ፡ በመላእክት፡ ይተረጐማል፡ ዓፀድ፡ በነገደ፡ መላእክት፡ ይ፡ ቤተ፡ ክርስቲያን፡
                                  በአብ፡ ይ፡ ግድግዳ፡ በመንፈስ፡ ቅዱስ፡ ይ፡
                                </seg>
                              </q>
                            </item>
                            <item xml:id="e1">
                              <locus target="#56v"/>
                              <desc>The name of <persName ref="https://betamasaheft.eu/PRS9345taytuBe">ወለተ፡ ሚካእል፡</persName>
                             is mentioned.</desc>
                            </item>
                          </list>

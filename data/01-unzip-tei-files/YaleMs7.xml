          <msContents>
            <summary>Psalter, ዳዊት፡ with the Psalms of the Virgin, given in 1881 by William Simpson,
              taken at Maqdala </summary>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="209r" facs="004"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT3985Mazmura">The Psalter of the Virgin is a special
                form of the Psalter in which a five-line rhyming hymn to Mary is affixed to the end
                of each Psalm. Each poem begins with the first line of the Psalm, the subsequent
                four lines all rhyme with the first and the content is directed toward Mary</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <msItem xml:id="ms_i1.1">
                <locus from="1r" to="160v" facs="004"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Psalm 151 is the short version</title>
                <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual">Mazmura Dāwit, Psalm 118 including the Spritual Meaning of the Hebrew Letters</ref>, employs the
                  formulae from the expanded common new system</note>
              </msItem>
              <msItem xml:id="ms_i1.2">
                <locus from="161r" to="179r" facs="164"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                <note>The fourth canticle is described as Prayer of Hana, mother of Samuel,
                  Prophet</note>
              </msItem>
              <msItem xml:id="ms_i1.3">
                <locus from="179r" to="189v" facs="182"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                <note>Scholars’ (or Hebraic) edition</note>
              </msItem>
              <msItem xml:id="ms_i1.4">
                <locus from="190r" to="204r" facs="193"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                <note>beginning with Monday</note>
              </msItem>
              <msItem xml:id="ms_i1.5">
                <locus from="204r" to="209r" facs="207"/>
                <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
              </msItem>
            </msItem>
          </msContents>

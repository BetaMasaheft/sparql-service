                            <title type="complete" ref="https://betamasaheft.eu/LIT5048Hassabat">Ḥassābāt</title>
                            <textLang mainLang="gez"/>


                     <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="10r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT5048#Circle"><span xmlns="" class="w3-tag w3-red">No item: LIT5048, could not check for Circle</span></title>
                        <incipit xml:lang="gez">

  </incipit>
                        <note>Thirty chapters, each containing fifteen formulas for predictions on various occasions.</note>
                        <msItem xml:id="ms_i1.1.1">
                           <locus target="#1r"/>
                           <title type="complete">አንቀጽ፡ በ፲፭ግድፍ፡ ሰአልት፡ ስሙ፡ ወስማ፡ ጋብቻ፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ሶበ፡ ተሓፂ፡ ብእሲተ፡ አልቦ፡ ሠናይ።
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.2">
                           <locus from="1r" to="1v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ሞቅሕ። ስሞወርህ፡ ዕለተ፡ ወንጌል። </title>
                           <incipit xml:lang="gez">
      ፩፡ ሶበ፡ ተትሞቃሕ፡ ኢትፍራህ፡ ፍጡነ፡ ትትፈታሕ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.3">
                           <locus target="#1v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ሾፋጭ፡ ስሞወርህ፡ ዕለት፡ ከመዳር፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ሶበ፡ ይመጽእ፡ ብካይ፡ ታመስጥ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.4">
                           <locus from="1v" to="2r"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ <gap reason="illegible"/>
     ወንጌላዊ፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ሶ፡ ተሐዝን፡ ኢትሕዝን፡ መዋዒ፡ ትመውዕ፡ አንተ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.5">
                           <locus from="2r" to="2v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ዕድሜ፡ ስም፡ እም፡ ዓመ፡
    ሞቅሕ፡ ወንጌል፡</title>
                           <incipit xml:lang="gez">
      ፩፡ እድሜከ፡ ነዊህ፡ መዋዕሊከ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.6">
                           <locus target="#2v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ተቦሀሎ፡ ነገር፡ ስምከ፡
    ወስሙ፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ዘትቤ፡ ይትቄበል፡ ነገርየ፡ በአፍአ፡ ወበውስጥ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.7">
                           <locus from="2r" to="2v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ፍኖት፡ ስሞ፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ሶበ፡ ተሐውር፡ ፍኖት፡ ሠናይ፡ ለከ፡
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.8">
                           <locus from="3r" to="3v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ደዌ፡ ስም፡ እም፡ ዓመተ፡ ምሕረት፡
      ወንጌል፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ኢሞት፡ ይድኅን፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.9">
                           <locus target="#3v"/>
                           <title type="complete">አንቀጽ፡ ምጽዓተ፡ ጸላኢ፡ ወዓረብ፡ ስም፡ ሀገር፡
    ወርኅ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ምጽአተ፡ ጸላኢ፡ ሀሎ፡ ኢትሕዝን
    </incipit>

                        </msItem>
                        <msItem xml:id="ms_i1.1.10">
                           <locus from="3v" to="4r"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ነጊድ፡ ስም፡ ወንጌል፡ ወርህ፡
    ዕለት፡ አድባር፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ዘነገደ፡ ርኁቅ፡ ይገብእ፡ ፍጡነ፡ ምስለ፡ ነዋይ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.11">
                           <locus target="#4r"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ሲሳይ፡ ስም፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ትረክብ፡ ንዋየ፡ ዘሃለየ፡ ልብከ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.12">
                           <locus from="4r" to="4v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ጥፍአተ፡ ንዋይ፡ ስም፡ ሳመንዋ፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ዘጠፍአ፡ ንዋይ፡ ተሐዘብ፡ ኢየጠፍዕ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.13">
                           <locus from="4v" to="5r"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ጽልዕ፡ ስም፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ በጽልዕ፡ ኢይጠፍዕ፡ ንዋይከ፡ ይነውህ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.14">
                           <locus target="#5r"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ መልእክት፡ ዘይመጽእ፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ላእክ፡ ያመጽእ፡ ፍሥሐ፡ እሙን፡ ውእቱ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.15">
                           <locus from="5r" to="5v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ኃሢሠ፡ ንዋይ፡ ስም፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ተኃሥሥ፡ ነዋይ፡ አርምም፡ ተረክብ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.16">
                           <locus from="5r" to="4v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ጽልዕ፡ ስም፡ ወርህ፡ ዕለት፡</title>
                           <incipit xml:lang="gez">
      ፩፡ በጽልዕ፡ ኢይጠፍዕ፡ ንዋይከ፡ ይነውህ፡
    </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.1.17">
                           <locus target="#5v"/>
                           <title type="complete">አንቀጽ፡ በእንተ፡ ዘትወልድ፡ ወኢትወልድ፡ እም፡ ስም፡
    እማ፡ ስማ፡</title>
                           <incipit xml:lang="gez">
      ፩፡ ትወልድ፡ ወልደ
    </incipit>
                           <msItem xml:id="ms_i1.1.18">
                              <locus from="5v" to="6r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ደዌ ስም፡ ወርህ፡ ዕለት፡ ወንጌል፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘተሐምም፡ ጸሊ፡ ኀበ፡ ክርስቶስ፡ ትትፈወስ፡ ፍው፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.19">
                              <locus from="6r" to="6v"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ጥፍአተ፡ ንዋይ፡ ስም፡ ወርህ፡ ዕለት፡ ወንጌል፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘጠፍኦ፡ ንዋይ፡ ለዘድክመ፡ ትረክብ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.20">
                              <locus target="#6v"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ መንገድ፡ ስም፡ ወርህ፡
        ዕለት፡ ሀገር፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘተሐውር፡ ፍኖት፡ ሑር፡ ሠናይ፡ ለከ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.21">
                              <locus from="6v" to="7r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ፍቅር፡ ወተፋቅሮ፡
      ስም፡ ወስሙ፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ፍቅር፡ ያሥተፌሥሐከ፡ ጥቀ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.22">
                              <locus from="7r" to="7v"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ክህነት፡ ስም፡ ወርህ፡ ወንጌል፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ክህነት፡ ጥበበ፡ ባዕድ፡ ትረክብ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.23">
                              <locus target="#7v"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ምጽአተ፡ ነገር፡ ስም፡
      ወን፡ ወር፡ በለጉልት፡ </title>
                              <incipit xml:lang="gez">
        ፩፡ ዘተሐዘብከ፡ ይመጽእ፡ በለጋራከ፡ እሙን፡ ውእቱ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.24">
                              <locus from="7v" to="8r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ጥፍአተ፡ ሰብእ፡ ወነገር፡
      ስም፡ ወር፡ ወን፡ ዕለ፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘጠፍአ፡ ሰብእ፡ ይትመየጥ፡ ፍጡነ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.25">
                              <locus target="#8r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡  ሠይጥ፡ ወተሠይጦ፡
      ስም፡ ወርህ፡ ዕለ፡ ሰመንዋ፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘትሠይጥ፡ ሠናይ፡ ሢጥ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.26">
                              <locus from="8r" to="8v"/>
                              <title type="complete">አንቀጽ፡ ዘጥፍአተ፡ ሀገር፡ ስም፡
        ወርህ፡ ወንጌል፡ ሀገር፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ሶበ፡ ትፄሊ፡ ኢይጠፍእ፡ ሀገረ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.27">
                              <locus from="8v" to="9r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ነጊድ፡ ወሐረስ፡ ስም፡
        እምዓመ፡ ሀገር</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘትነግድ፡ ወተሐርሰ፡ ሠናይ፡ ለከ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.28">
                              <locus target="#9r"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ዘሀለየ፡ ሕሊና፡ ስም፡ እም፡
         ወርህ፡ ዕለት፡ ወንጌል፡</title>
                              <incipit xml:lang="gez">
        ፩፡ ዘሃለይከ፡ ይትፌትጸም፡ ለከ፡ አንተሰ፡ ብዙኃ፡ ትቤ፡
      </incipit>
                           </msItem>
                           <msItem xml:id="ms_i1.1.29">
                              <locus from="9r" to="9v"/>
                              <title type="complete">አንቀጽ፡ በእንተ፡ ፍርሃተ፡ ወዓሊ፡
        ስም፡ ወርህ፡ ዕለት፡</title>
                              <incipit xml:lang="gez">

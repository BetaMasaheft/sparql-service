                     <msItem xml:id="ms_i1.6">
                        <locus from="167r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1696Joshua">ኦሪት፡ ዘሆሴእ።</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ተፈጸመ፡ ኦሪት፡ ዘሆሴዕ። ስረዩ፡ 
                    <choice>
                              <sic resp="PRS10747Zotenbe">ወበርኩኒ፡</sic>

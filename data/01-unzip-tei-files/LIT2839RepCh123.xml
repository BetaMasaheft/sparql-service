            <t:div type="textpart" subtype="incipit" xml:lang="gez">
               <t:note>This incipit is recorded as <t:bibl corresp="http://zotero.org/groups/358366/items/7WA33SUX"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Chaine1913Rep"/><title level="a">Répertoire des Salam et Malkeʾe contenus dans les manuscrits éthiopiens des bibliothèques d’Europe</title><title level="j">Revue de l’Orient Chrétien</title><author><t:forename>Marius</t:forename><t:surname>Chaîne</t:surname></author><date>1913</date><biblScope unit="volume">18</biblScope><biblScope unit="issue">2 and 4 (Deuxième série, 8/2 and 8/4)</biblScope><biblScope unit="page">183–203 and 337–357</biblScope><note type="url">http://catholicapedia.net/Documents/Revue-de-l.Orient-chretien/18-1913_revue-de-l.orient-ch_paris.pdf</note><t:citedRange unit="item">122</t:citedRange></t:bibl></t:note>
               <t:ab>
                  ሰላም፡ ለዝክረ፡ ስምከ፡ ሰላመ፡ ዘኢይሔሱ።
               </t:ab>
            </t:div>
            <t:div type="textpart" xml:id="masgabiya">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ኢየሱስ፡ ኢየሱስ፡ ኢየሱስ፡ ክርስቶስ፨</t:l>
                  <t:l n="2">ዘሠረፅከ፡ እምቤተ፡ ሌዊ፡ ኮሬባዊ፡ መለኮታዊ፨</t:l>
                  <t:l n="3">ቃል፡ ሰማያዊ፡ እምድንግል፡ ተወልደ፨</t:l>
               </t:lg>
            </t:div>
            <t:div type="textpart" xml:id="malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይሔሱ፨</t:l>
                  <t:l n="2">በአንበረ፡ ቅድመ፡ እግዚአብሔር፡ በአትሮንሱ፨</t:l>
                  <t:l n="3">ኢየሱስ፡ ክርስቶስ፡ ለዳዊት፡ ባሕርየ፡ ከርሡ፨</t:l>
                  <t:l n="4">አክሊለ፡ ስምከ፡ እንዘ፡ ይትቄጸል፡ በርእሱ፨</t:l>
                  <t:l n="5">አህጉረ፡ ፀር፡ ወረሰ፡ ኢያሱ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ዘሥሙር፡ አብቋሉ፨</t:l>
                  <t:l n="2">ወጽፉቅ፡ ጥቀ፡ ለአርዘ፡ ሊባኖስ፡ አምሳለ፡ ቈጽሉ፨</t:l>
                  <t:l n="3">ኢየሱስ፡ ክርስቶስ፡ ሊቀ፡ ካህናት፡ ዘላዕለ፡ ኵሉ፨</t:l>
                  <t:l n="4">ይሠዐል፡ በልሳንየ፡ ለውዳሴ፡ ፊደሉ፨</t:l>
                  <t:l n="5">ኢይትገደፍ፡ ዲበ፡ ምድር፡ ንባቡ፡ ወቃሉ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="48">
                  <t:l n="1">ሰላም፡ ለዕርገትከ፡ ዘኢይትረከብ፡ መጠኑ፨</t:l>
                  <t:l n="2">ወለንብረትከ፡ ሰላም፡ ለአቡከ፡ ውስተ፡ የማኑ፨</t:l>
                  <t:l n="3">ኢየሱስ፡ ክርስቶስ፡ እለ፡ ኪያከ፡ ተአምኑ፨</t:l>
                  <t:l n="4">ቅዱሳነ፡ ዘእምኀቤከ፡ ወንጹሓነ፡ ይኩኑ፨</t:l>
                  <t:l n="5">ጰራቅሊጦስሃ፡ መንፈሰከ፡ ፈኑ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="49">
                  <t:l n="1">ሰላም፡ እብል፡ ለምጽአትከ፡ ከዋላ፨</t:l>
                  <t:l n="2">በደመና፡ ሰማይ፡ ብርህት፡ ዘትጸድል፡ እምሥነ፡ እብላ፨</t:l>
                  <t:l n="3">አመ፡ ትመጽእ፡ በስብሐት፡ ክርስቶስ፡ ርእሰ፡ መሐላ፨</t:l>
                  <t:l n="4">ጸውዐነ፡ ለአግብርቲከ፡ ውስተ፡ ዐጸደ፡ ፍግዕ፡ ወተድላ፨</t:l>
                  <t:l n="5">ናንሶሱ፡ ምስሌከ፡ በሐዳስ፡ ቀጸላ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="50">
                  <t:l n="1">እምሥራቀ፡ ፀሓይ፡ እስከ፡ ነዐረብ፡ ይትአኰት፡ ስሙ፡ ለእግዚአብሔር፡ አምላክነ፨</t:l>
                  <t:l n="2">ኪያከ፡ ወልዶ፡ ዘፈነወ፡ ለነ፨</t:l>
                  <t:l n="3">ኢየሱስ፡ ክርስቶስ፡ ሊቀ፡ ካህናቲኒ፨</t:l>
                  <t:l n="4">አስተጋብአነ፡ ኀበ፡ ትረፍቅ፡ መካነ፨</t:l>
                  <t:l n="5">ትሑታነ፡ አግብርቲከ፡ ንሕነ፨</t:l>
               </t:lg>
            </t:div>
            <t:div type="textpart" xml:id="tarafa-malke">
               <t:lg type="stanza" n="1">
                  <t:l n="1">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ ሥዕርትየ፨</t:l>
                  <t:l n="2">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ አዕጽምትየ፨</t:l>
                  <t:l n="3">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ ዘተርእየ፨</t:l>
                  <t:l n="4">ስብሐት፡ ለከ፡ አምላኪየ፡ በኍልቈ፡ ኵሉ፡ ዘኢያስተርአየ፨</t:l>
                  <t:l n="5">ስብሐተ፡ ሥላሴከ፡ ወትረ፡ ይነግር፡ አፉየ፨</t:l>
               </t:lg>
               <t:lg type="stanza" n="2">
                  <t:l n="1">እምኵሉ፡ ይኄይስ፡ በሥላሴከ፡ ተአምኖ፨</t:l>
                  <t:l n="2">ወበወላዲትከ፡ ተማሕፅኖ፨</t:l>
                  <t:l n="3">ኢየሱስ፡ ክርስቶስ፡ እምቤተ፡ መንግሥት፡ ወተክህኖ፨</t:l>
                  <t:l n="4">ተሰብኦተከ፡ እመቦ፡ ዘያስተሐቅር፡ መኒኖ፨</t:l>
                  <t:l n="5">ያንኰርኵር፡ ታሕተ፡ ደይን፡ ግዱፈ፡ ከዊኖ፨</t:l>
               </t:lg>
            </t:div>
         </t:div>
         
      </t:body>
   </t:text></TEI>
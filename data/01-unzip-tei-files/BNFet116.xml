                  <msItem xml:id="ms_i1">
                    <locus from="6ra" to="36ra"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions">Dǝrsāna madḫāne ʿālam</title>

                  <msItem xml:id="ms_i1.1">
                    <locus from="6ra" to="7ra"/>
                    <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#Introduction">Dǝrsāna madḫāne ʿālam: Introduction (same as LIT6616HomilyPassionIntro)</title>
                        <incipit xml:lang="gez">
                        <locus target="#6ra"/>
                      <hi rend="rubric">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘእንበለ፡ ቅድም፡ </hi>
                        ወተድኅሮ። በግጻዌሁ፡ ይትረአ<hi rend="rubric">ይ፡ ዘአስተዋሀደ፡ ምክሮ።
                        በጠፈረ፡ በረ</hi>ድ፡ ወነድ፡ ዘሐነፀ፡ ማኅደሮ። ወበአርእስተ፡
                        ኪሩቤል፡ ርቱዓ፡ ዘአማዕዘነ፡ መንበሮ። ክንፈ፡ እሳት፡ ዘገብረ፡ ምሕዋሮ።</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                       <locus from="7ra" to="14vb"/>
                       <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyMonday">Dǝrsāna madḫāne ʿālam:  HomilyMonday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#7ra"/>
                          ናንቅሕ፡ ርእሰ፡ ሕሊናነ፡ ወናስተሐውስ፡ እስራወ፡ ልሳንነ፡ ንክሥት፡ አፉነ፡ ወናስተናብብ፡ ከናፍሪነ፡
                        ከመ፡ ንንግር፡ ዜና፡ ሕማማቲሁ፡ ለመድኀኒነ፡
                      </incipit>
                        <note>The incipit is not rubricated.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                       <locus from="14vb" to="19va"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyTuesday">Dǝrsāna madḫāne ʿālam: Homily for Holy Tuesday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#14vb"/>
                          <hi rend="rubric">ንግባእኬ፡ ከመ፡ ንፈጽም፡ ዜና፡ ሕማሙ፡</hi> ለመድኃኒነ፡
                           ወአንግሁ፡ ይእተ፡ ኵላ፡ ሌሊተ፡ እንዘ፡ ይዘብጥዎ፡ ወይጸፍዕዎ፡ ወእምዝ፡ ዓቀሙ፡ ሎቱ፡ ሰማዕተ፡ ሐሰት፨</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                       <locus from="19va" to="24vb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyWednesday">Dǝrsāna madḫāne ʿālam: Homily for Holy Wednesday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#19va"/>
                          <hi rend="rubric">ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረነ፡ ወበጊዜ፡</hi>
                          ፱ሰዓት፡ ተከሥተ፡ ፀሐይ፡ በዓውደ፡ ሰማይ፨ ወሶበ፡ ርእያ፡</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.5">
                       <locus from="24vb" to="29vb"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyThursday">Dǝrsāna madḫāne ʿālam: Homily for Maundy Thursday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#24vb"/>
                          <hi rend="rubric">ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረ፡ ዘ፱ሰዓት፡</hi>
                          ወይእተ፡ ጊዜ፡ ሶበ፡ ርእዩ፡ ነቢያት፡ ቀደምት፡ ወአበው፡ ቀደምት፡ ሞቶ፡</incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.6">
                       <locus from="29vb" to="33ra"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilyFriday">Dǝrsāna madḫāne ʿālam: Homily for Good Friday</title>
                      <textLang mainLang="gez"/>
                      <incipit xml:lang="gez">
                        <locus target="#29vb"/>
                      <hi rend="rubric">ንግባዕኬ፡ ከመ፡ ንፈጽም፡ ነገረ፡ ዘምሴተ፡</hi>
                      ዓርበ፡ እስመ፡ ይቤ፡ ዘካርያስ፡ ይእቲ፡ ዕለት፡ እምብርት፡ በኀበ፡ እግዚአብሔር፡ ኢኮነት፡
                    </incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.7">
                       <locus from="33ra" to="35ra"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilySaturday">Dǝrsāna madḫāne ʿālam: Homily for Holy Saturday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#33ra"/>
                        ንንግርኬ፡ ኅዳጠ፡ ዜናሁ፡ ለፀልቦ፡ <hi rend="rubric">መድኃኒነ፡</hi>
                        መስቀል፡ ዘከመ፡ ተብህለ፡ ሀሎ፡ ምስለ፡ እግዚአብሔር፡ እምቀድመ፡ ኵሉ፡ ፍጥረት፡
                      </incipit>
                      <note>The incipit is not rubricated.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.8">
                       <locus from="35ra" to="36ra"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT6193HomiliaryPassions#HomilySunday">Dǝrsāna madḫāne ʿālam: Homily for Passion Sunday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">
                          <locus target="#35ra"/>
                          ንግባዕኬ፡ ከመ፡ ንሰብሖ፡ ወንወድሶ፡ ለእግዚአብሔር፡
                          እንዘ፡ ንብል፡ ጥዑመ፡ ስም፡ <hi rend="rubric">መድኃኒነ፡</hi>
                           ለሊሁ፡ ንጉሥ፡ ወእሙ፡ መቅደስ፡ ወመስቀሉ፡ አትሮንስ፡
                      </incipit>

                     <explicit xml:lang="gez">
                       <locus target="#36ra"/>
                        ነዋ፡ መጽሐፈ፡ ተዝካር፡ ዘደረሰ፡ ፩፡ ግዩር፡ ትንቢተ፡ ነቢያት፡ እንዘ፡ ይፌክር፡
                        ወሃይማኖተ፡ ሐዋርያት፡ እንዘ፡ ይዜምር። በእንተ፡ ዝንቱ፡ ነገር፡ ጸልዩ፡ ሎቱ፡
                        <gap reason="ellipsis" resp="PRS10747Zotenbe" extent="unknown"/>
                     </explicit>

                     <explicit xml:lang="gez" type="supplication">
                       <locus from="36ra" to="36va"/>
                        ለዘጸሐፎ፡ ወለዘአጽሐፎ፡ ለዝንቱ፡ ድርሳን፡ እግዚአብሔር፡ ይጽሐፍ፡ ስሞ፡ በአምደ፡ <cb n="b"/>
                        ብርሃን፡
                        ወያርፍቆ፡ በደብረ፡ ጽዮን፡ መካን፡ በሥላሴሁ፡ አመ፡ ይመጽእ፡ መስለ፡ መላእክቲሁ፡ ተጉሃን፡ ለዓለመ፡
                         ዓለም፨
                        ለዘአጽሐፈ፡ ለዛቲ፡ ተውዳስ፡ <persName role="patron" ref="https://betamasaheft.eu/PRS11217AdfaD">አጽፈ፡ ድንግል</persName>፡
                        ወትረ፡ የሀሉ፡ በሞገስ፡ በሥጋ፡ ወነፍስ፨
                        <gap reason="ellipsis" resp="DN"/>
                     </explicit>
                     </msItem>
                     </msItem>




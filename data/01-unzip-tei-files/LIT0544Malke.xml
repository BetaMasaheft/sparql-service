      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0544</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ እቍረ፡ ማየ፡ ወርቅ፡ ዝጉብ፨</l>
                  <l n="2">ወቍናማተ፡ ኵሉ፡ ጥበብ፨</l>
                  <l n="3">ቤተ፡ ክርስቲያን፡ ቅድስት፡ መርዓተ፡ በግዑ፡ ለአብ፨</l>
                  <l n="4">ሐሊብ፡ ሐሊብ፡ ፍቅርኪ፡ ሐሊብ፨</l>
                  <l n="5">በሰሚዖቱ፡ ይጸግብ፡ ርኁብ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ከመ፡ ቀርሜሎስ፡ አምሳሉ፨</l>
                  <l n="2">በቀድመ፡ ሰማዕታት፡ ዘዔሉ፨</l>
                  <l n="3">ቤተ፡ ክርስቲያን፡ ውድስት፡ ወስብሕት፡ በአፈ፡ ኵሉ፨</l>
                  <l n="4">ቤተ፡ ክርስቲያን፡ እምላዕለ፡ ኵሉ፨</l>
                  <l n="5">ቤተ፡ ክርስቲያን፡ በረከትኪ፡ ምስሌየ፡ የሀሉ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ኀይልኪ፡ ተዐውቀ፡ ወበርኅበ፡ ዓለም፡ ሰፈነ፨</l>
                  <l n="2">እንተ፡ ላዕለ፡ ሕይወት፡ ወሞት፡ ደበ፡ አድምዐ፡ ሥልጣነ፨</l>
                  <l n="3">ቤተ፡ ክርስቲያን፡ ቅድስት፡ ተራድእኒ፡ ፍጡነ፨</l>
                  <l n="4">ፀርየሰ፡ ኵሎ፡ ዘመነ፡ ከመ፡ ፈቀዱ፡ ከመ፡ እጥፋዕ፡ አነ፨</l>
                  <l n="5"/>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ እብል፡ ለፍጻሜ፡ ስምኪ፡ እሙ፨</l>
                  <l n="2">መለኮተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨</l>
                  <l n="3">ጌራ፡ መድኃኒት፡ ቤተ፡ ክርስቲያን፡ ቅድስት፡ ቤተ፡ ክርስቲያን፨</l>
                  <l n="4">ንጽሕት፡ ሰላመ፡ መልክእኪ፡ ለለጌሠሙ፨</l>
                  <l n="5">ውስተ፡ ጽላሌ፡ ሕግ፡ ዘኢይጠፍዕ፡ ቀለሙ፨</l>
               </lg>
            </div>
         </div>
      </body>

            </listRelation></standOff><t:text xmlns:t="http://www.tei-c.org/ns/1.0" xml:base="https://betamasaheft.eu/">
        <t:body>
            
            <t:div type="bibliography"/>
            <t:div type="edition" xml:lang="gez" resp="https://betamasaheft.eu/MV">
                <t:div type="textpart" subtype="chapter" xml:id="ch4" n="4" corresp="https://betamasaheft.eu/NAR0013pelican"> 
                    <t:div type="textpart" subtype="sentence" xml:id="ch4se1" n="1">
                        <t:ab>ክፍል፡ <t:app>
                        <t:lem wit="# D #F #M #V">ሳድስ፡ ናና፡</t:lem>
                        <t:rdg wit="#E">፮ናና፡</t:rdg>
                     </t:app> ካልእ፡ ዖፍ፡ ዘይሰመይ፡ 
                            <t:app>
                        <t:lem wit="#D #E #F">ጰልቃን፡</t:lem>
                        <t:rdg wit="#M #V">ጳልቃን፡</t:rdg>
                     </t:app> ዘውእቱ፡ 
                            <t:app>
                        <t:lem wit="#D #E #F #M">ግራብ፡</t:lem>
                        <t:rdg wit="#V">ግብ፡</t:rdg>
                     </t:app>
                  </t:ab>
                    </t:div>
                    <t:div type="textpart" subtype="sentence" xml:id="ch4se2" n="2">
                        <t:ab>ዘይቤ፡ ዳዊት፡ በእንቲአሁ፡ <t:ref cRef="betmas:LIT2000Mazmur.101.7">ተመሰልኩ፡ <t:app>
                           <t:lem wit="#D #E #F">ጰልቃን፡</t:lem>
                           <t:rdg wit="#M #V">ጳልቃን፡</t:rdg>
                        </t:app> ዘገዳም።</t:ref> 
                  </t:ab>
                    </t:div>
                    <t:div type="textpart" subtype="sentence" xml:id="ch4se3" n="3">
                        <t:ab>
                     <t:app>
                        <t:lem wit="#D #E #F #M">ወፊስአልጎስኒ፡</t:lem>
                        <t:rdg wit="#V">ፊስሖልጎስኒ፡</t:rdg>
                     </t:app> ይቤ፡ በእንቲአሁ፡ እስመ፡ መፍቀሬ፡ ደቂቅ፡ 
                            ውእቱ፡ በሕቁ። 
                            <t:app>
                        <t:lem wit="#D #M #V">ሶበ፡</t:lem>
                        <t:rdg wit="#E #F">ወሶበ፡</t:rdg>
                     </t:app> ይወልድ፡ 
                            <t:app>
                        <t:lem wit="#D #F">ውሉደ፡</t:lem>
                        <t:rdg wit="#M #V">ውሉደ፡</t:rdg>
                        <t:rdg wit="#E">ወልደ፡</t:rdg>
                     </t:app> 
                     <t:ref cRef="urn:cts:greekLit:tlg0031.tlg001.perseus-grc1:26.67">ይጸፍዑ፡ ውሉድ፡ 
                            <t:app>
                           <t:lem wit="#D #F #M #V">ገጸ፡</t:lem>
                           <t:rdg wit="#E">ገጾ፡</t:rdg>
                        </t:app>
                     </t:ref> 
                     <t:app>
                        <t:lem wit="#D #E #F #M">ወላድያኒሆሙ፡</t:lem>
                        <t:rdg wit="#V">ወላዲያኒሆሙ፡</t:rdg>
                     </t:app> 
                            ወወላድያንሂ፡ <t:app>
                        <t:lem wit="#D #F #M #V">የኀድጉ፡</t:lem>
                        <t:rdg wit="#E">የኅድጉ፡</t:rdg>
                     </t:app> በእንተዝ፡ 
                            <t:app>
                        <t:lem wit="#D #E #F #M">ወይርሕቁ፡</t:lem>
                        <t:rdg wit="#V">ይርኃቁ፡</t:rdg>
                     </t:app> እምዐቂበ፡ ውሉዶሙ፡ እስከ፡ 
                            <t:app>
                        <t:lem wit="#D #E #M #V">ይመውቱ፡</t:lem>
                        <t:rdg wit="#F">ይመወቱ፡ እስከ፡ ይመውቱ፡</t:rdg>
                     </t:app> ውሉድ። 
                            ባሕቱ፡ <t:app>
                        <t:lem wit="#D #E #M #V">እምድኅረ፡</t:lem>
                        <t:rdg wit="#F">እምድረ፡</t:rdg>
                     </t:app> 
                     <t:app>
                        <t:lem wit="#D #E #F #V">ሣልስት፡</t:lem>
                        <t:rdg wit="#M">ሥልስት፡</t:rdg>
                     </t:app> ዕለት፡ ትመጽእ፡ 
                            እሞሙ፡ <t:app>
                        <t:lem wit="#D #E #F #M">ወታንጸፈጽፍ፡</t:lem>
                        <t:rdg wit="#V">ወኢታንጸፍጽፍ፡</t:rdg>
                     </t:app> ደመ፡  ገቦሃ፡ መልዕልተ፡ ውሉዳ፡ 
                            እለ፡ ሞቱ፡ ወኮኑ፡ ውዱቃነ፡ ዲበ፡ ምድር፡ ወታነሥኦሙ። </t:ab>
                    </t:div>
                    <t:div type="textpart" subtype="sentence" xml:id="ch4se4" n="4">
                        <t:ab>ምሳሌ፡ ዝንቱሰ፡ ነገር፡ ተፈጸመ፡ በእግዚእነ፡ <t:app>
                        <t:lem wit="#D #F #M #V">ኢየሱስ፡</t:lem>
                        <t:rdg wit="#E">
                           <t:note>om.</t:note>
                        </t:rdg>
                     </t:app> 
                            ክርስቶስ፡ በከመ፡ ይቤ፡ ኢሳይያስ፡ ነቢይ፡ ውሉደ፡ ወለድኩ፡ ወአልሀቁ፡ እሙንቱሰ፡ 
                            ዐለዉኒ። ህየንተ፡ <t:app>
                        <t:lem wit="#D #E #F">ወለደነ፡</t:lem>
                        <t:rdg wit="#M #V">ወለድነ፡</t:rdg>
                     </t:app> ለነ፡ ወአምጽአ፡ ኵሎ፡ 
                            <t:app>
                        <t:lem wit="#D #E #F #M">ፍጥረታተ፡</t:lem>
                        <t:rdg wit="#V">ፍጥረራት፡</t:rdg>
                     </t:app> 
                     <t:app>
                        <t:lem wit="#D #F #M #V">እምኀበ፡</t:lem>
                        <t:rdg wit="#E">ኀበ፡</t:rdg>
                     </t:app> 
                            <t:app>
                        <t:lem wit="#D #E #V">ኢሀልዎ፡</t:lem>
                        <t:rdg wit="#F #M">ኢሀለዎ፡</t:rdg>
                     </t:app> 
                     <t:app>
                        <t:lem wit="#D #E #F">ኀበ፡</t:lem>
                        <t:rdg wit="#M #V">
                           <t:note>om.</t:note>
                        </t:rdg>
                     </t:app> 
                            <t:app>
                        <t:lem wit="#D #E">ሀልዎ፡</t:lem>
                        <t:rdg wit="#F #M #V">ኢሀለዎ፡</t:rdg>
                     </t:app> 
                     <t:app>
                        <t:lem wit="#D #E #F #M">ለመግቦትነ፡</t:lem>
                        <t:rdg wit="#V">ለመልየትነ፡</t:rdg>
                     </t:app> 
                            <t:app>
                        <t:lem wit="#D #E #F #M">በአሠንዮቱ።</t:lem>
                        <t:rdg wit="#V">በአሠንየቱ፡</t:rdg>
                     </t:app> ወንሕነሰ፡ ኀደግነ፡ 
                            <t:app>
                        <t:lem wit="#D #E #F">አምልኮቶ፡</t:lem>
                        <t:rdg wit="#M #V">በአምልኮቶ፡</t:rdg>
                     </t:app> 
                     <t:app>
                        <t:lem>ወፈደይናሁ፡</t:lem>
                     </t:app> 
                            እኪተ፡ ወጸፋዕነ፡ <t:app>
                        <t:lem wit="#D #E #F #M">መላትሒሁ፡</t:lem>
                        <t:rdg wit="#V">መልታሄሑ፡</t:rdg>
                     </t:app>  
                            እስከ፡ ዐርገ፡ <t:app>
                        <t:lem wit="#M #V">ዲበ፡</t:lem>
                        <t:rdg wit="#D #E #F">ላዕለ፡</t:rdg>
                     </t:app> ዕፀ፡ መስቀል፡ ወተረግዘ፡ 
                            ገቦሁ፡ <t:app>
                        <t:lem wit="#D">ወአንጸፍጸፈ፡</t:lem>
                        <t:rdg wit="#E #M">ወአንጽፍጸፈ፡</t:rdg>
                        <t:rdg wit="#F #V">ወአንጸፍጸፍ፡</t:rdg>
                     </t:app> ለነ፡ 
                            ደመ፡ <t:app>
                        <t:lem wit="#D #M">ንስሓ፡</t:lem>
                        <t:rdg wit="#E">ንሕስሐ፡</t:rdg>
                        <t:rdg wit="#F">ንሐሐ፡</t:rdg>
                        <t:rdg wit="#V">ንጹሐ፡</t:rdg>
                     </t:app> 
                            ወማየ፡ ስርየት።</t:ab>
                    </t:div>
                </t:div>
            </t:div>
        </t:body>
    </t:text></TEI>
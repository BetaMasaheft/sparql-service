               <msContents>
                  <summary>Ff. 1r-92r: Epistles of Paul, መልእክታተ፡ ጳውሎስ፡; Ff. 92v-95r: The Beauty of Creation; Ff. 95r-130r: Acts of the Apostles;  Ff. 130v-145v: Revelation, ራዕየ፡ ዮሐንስ።;  Ff. 145v-159r: General Epistles. F. 159r: Colophon, mentioning scribe, date. </summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="92r">Fols 1r–92r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3505PaulineEpis">Pauline Epistles</title>
                     <textLang mainLang="gez">Gǝʿǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="92v" to="95r">Fols 92v–95r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2314senafe">Śǝna fǝṭrat (General record)</title>
                     <textLang mainLang="gez">Gǝʿǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="95r" to="130r">Fols 95r–130r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1019Actsof">Gǝbra ḥawāryāt</title>
                     <textLang mainLang="gez">Gǝʿǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="130v" to="145v">Fols 130v–145v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3179Revela">Revelation of John</title>
                     <textLang mainLang="gez">Gǝʿǝz</textLang>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="145v" to="159r">Fols 145v–159r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3506CatholicEpis">Catholic Epistles</title>
                     <textLang mainLang="gez">Gǝʿǝz</textLang>
                     <colophon xml:id="coloph1">
                        <locus target="#159r">Fol. 159r</locus>
                        Colophon, mentioning scribe and date
                     </colophon>
                  </msItem>
               </msContents>

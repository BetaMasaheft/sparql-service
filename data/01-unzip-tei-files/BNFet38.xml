               <msContents>
                  <summary/> 
            
                  <msItem xml:id="ms_i1">
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</title>
                     <textLang mainLang="gez"/>
                     <note>The text of this manuscript mainly agrees with that of 
                <ref type="mss" corresp="https://betamasaheft.eu/BNFet35">Paris, Bibliothèque nationale de France, BnF Éthiopien 35</ref>.</note>
                     <note>The chapters and canons of <persName ref="https://betamasaheft.eu/PRS3912Eusebius">Eusebius of Caesarea</persName>
                are marked in the margins.</note>
            
                     <msItem xml:id="ms_i1.1">
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2709Matthew">Bǝsrāta Mātewos</title>
                        <textLang mainLang="gez"/>
                        <note>The following are missing: Matthew 8:22b-10:21; Matthew 12:43-13:1; Matthew 26:59 to the end.</note>
                     </msItem>
            
                     <msItem xml:id="ms_i1.2">
                        <locus from="94r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2711Mark">Bǝsrāta Mārqos</title>
                        <textLang mainLang="gez"/>
                     </msItem>
            
                     <msItem xml:id="ms_i1.3">
                        <locus from="156r"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2713Luke">Bǝsrāta Luqās</title>
                        <textLang mainLang="gez"/>
                        <note>This manuscript contains Luke 1:1-2:21.</note>
                     </msItem>
                  </msItem>
               </msContents>
          

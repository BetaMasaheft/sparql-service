                            <item xml:id="a3">
                              <locus target="#2r"/>
                              <desc type="GuestText">
                                <title type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Yǝweddǝsǝwwa malāʾǝkt la-Māryām</title>
                              </desc>
                              <q xml:lang="gez"><seg part="I">
                                 ይዌድስዋ፡ መላእክት፡ ለማርያም፡ በውስተ፡ ውሳጤ፡ መንጦላዕት፡
                              </seg></q>
                            </item>
                            <item xml:id="a4">
                              <locus target="#3r"/>
                              <desc type="OwnershipNote">The note states that the manuscript belongs to the church of
                                  <placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">Madḫāne ʿĀlam</placeName>.</desc>
                              <q xml:lang="gez">ዜና፡ አይሁድ፡ ዘ<placeName ref="https://betamasaheft.eu/INS0101MadhaneAlam">ቅዱስ፡ መድኃኔ፡ ዓለም።</placeName>
                            </q>
                            </item>
                            <item xml:id="e1">
                              <locus target="#e1"/>
                              <desc>The name of the owner has been erased.</desc>
                            </item>
                            <item xml:id="e2">
                              <locus target="#161r"/>
                              <desc>A few glosses and notes.</desc>
                            </item>
                            </list>

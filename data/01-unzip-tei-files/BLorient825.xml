                            <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i1.6">
                            <locus from="100r" to="117v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2598Yosipp#Kefl6">No item: LIT2598Yosipp, could not check for Kefl6</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ዜናሁ፡ ለዮካናን፡ ገሊላዊ፡ ወውእቱ፡ ዳግም፡ እምእለ፡ ያርብኅ፡
                            እለ፡ ኮኑ፡ ምክንያተ፡ ለንስተተ፡ መቅደስ፡ ወድምሳሴ፡ ሕዝብ፡ በዘ፡ ገብርዎ፡ በሮም።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.7">

               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus target="#1a"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4644MagicPr">Ṣalot baʾənta ḥəmāma ʿāynat bāryā wa-ʿāyna sabʾ ʾəkuy
          wa-legewon</title>
                     
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> አስማተ፡ ሰሎሞን፡ ዘረከቦሙ፡ ለአጋንንት፡ ከመ፡ መርበብተ፡ ዓሣ፡ 
                        ዘባሕር፡ እንዘ፡ ይብል፡ ስድራኤል፡ ስዴቃኤል፡ አዳታኤል፡ አርማኤል፡ አናኤል፡
                     </incipit>
                     <explicit xml:lang="gez">
                           <sic>ወለፍላሻ፡</sic>
                         ለእስላም፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                        ወእምኵሉ፡ ሕማም፡ አድኅኖ፡ ለገብርከ፡ ተስፋ፡ ጊዮር<supplied reason="omitted">ጊ</supplied>ስ፡
                     </explicit>
                     <note>The name of the owner <persName ref="https://betamasaheft.eu/PRS11696TasfaGi">Tasfā Giyorgis</persName> is mentioned in the supplication formula at the end of the text.</note>
                  </msItem> 
                  
                  <msItem xml:id="ms_i2">
                     <locus target="#1a"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4559Salot">Ṣalot baʾǝnta māʾǝsaromu la-ʾagānǝnt</title>
                     
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ማእሰሮሙ፡ 
                           <sic>ወመሸብሮሙ፡</sic>
                         
                        ለአጋንንት፡ ወለሰይጣናት፡ በአዊን፡ እሳት፡ በገዲን፡ <supplied reason="omitted">እሳት፡</supplied> በኢጀርታኤል፡ እሳት፡ በአውድታኤል፡ እሳት፡ በብርስበሔል፡ እሳት፡
                     </incipit>
                  </msItem> 
                  
                  <msItem xml:id="ms_i3">
                     <locus target="#1a"/>
                     <title>Excerpt from <ref type="work" corresp="https://betamasaheft.eu/LIT1882MarkGo">Wangel za-Mārqos</ref> 5:1-13</title>
                     <note>
                        The biblical excerpt is followed by a short invocation to St Mark, which begins as follows: 
                        <q xml:lang="gez">ጸሎቱ፡ ወበረከቱ፡ ለቅዱስ፡ ማርቆስ፡ ይዕቀቦ፡ ለገብሩ፡ ተስፋ፡ ጊዮርጊስ፡ ወያድኅኖ፡ እምሕማመ፡ አጋንንት፡ ወሰይጣናት፡ ለባርያ፡ ወለጌዎን፡</q>. 
                        The name of the owner <persName ref="https://betamasaheft.eu/PRS11696TasfaGi">Tasfā Giyorgis</persName> is mentioned in the supplication formula at the beginning of the invocation.
                     </note>
                  </msItem>
                  
                  <msItem xml:id="ms_i4">
                     <locus target="#1b"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4692MagicPr">Ṣalot baʾǝnta fǝtḥata śǝrāy za-kin wa-za-ṭǝbab</title>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ፍትሐተ፡ ሥራይ፡ ዘኪን፡ ወዘጥበብ፡ 
                        <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ዝንቱ፡ አስማት፡ ዘተቀድሐ፡ እም፹፩መጻሕፍት፡ 
                        
                           <sic>ወመቃጽርተ፡</sic>
                         ሐብደረጅን፡ ሐብደረጅን፡ ሐብ<supplied reason="omitted">ደ</supplied>ረጀን፡
                     </incipit>
                     <explicit xml:lang="gez">
                        በዝንቱ፡ አስማቲከ፡ ፍታሕ<gap reason="lost"/> ወዘርዝር፡ ሠአር፡ ወመንዝ<supplied reason="lost">ር፡</supplied> ኵሎ፡ ሥራየ፡ ወኵሎ፡ አስማተ፡ ዘተደግመ፡ ኀበ፡ ነፍሱ፡ 
                        ወስጋሁ፡ ለገብርከ፡ ተስፋ፡ ጊዮርጊስ፡ ሰንበቱ።
                     </explicit>
                     <note>The name of the owner <persName ref="https://betamasaheft.eu/PRS11696TasfaGi">Tasfā Giyorgis</persName> is mentioned in the supplication formula at the end of the text.</note>
                  </msItem>  
                  
                  <msItem xml:id="ms_i5">
                     <locus target="#1b"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4570MagicPr">Ṣalot baʾǝnta maftǝḥe śǝrāy</title>
                     
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራይ፡ በስመ፡ ራፎን፡ ራፎን፡ ራፎን፡ 
                        ወበስመ፡ ራኮን፡ ራኮን፡ ራኮን፡ አዊን፡ አዊን፡ አዊን፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ይሠአር፡ ሥራያቲሆሙ፡ ወአስማቲሆሙ፡ ለመሠርያን፡ እምላዕለ፡ ገብርከ፡ ተስፋ፡ ጊዮርጊስ፡
                     </explicit>
                     <note>The name of the owner <persName ref="https://betamasaheft.eu/PRS11696TasfaGi">Tasfā Giyorgis</persName> is mentioned in the supplication formula at the end of the text.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i6">
                     <locus target="#1b"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4623Prayer">Ṣalot baʾǝnta ḥǝmāma qʷǝrṭat</title>
                     <incipit xml:lang="gez">
                        ጸሎት፡ በእን<supplied reason="omitted">ት</supplied>፡ ሕማመ፡ ቍርፀት፡ <choice>
                           <sic>ወመገኛ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ወመጋኛ፡</corr>
                        </choice> 
                        በፓኮስ፡ ስምከ፡ በደፌል፡ ስምከ፡ በሕርዮኖስ፡ ስምከ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ከማሁ፡ አርግዕ፡ ሕማመ፡ ቍርፀት፡ ወ<supplied reason="omitted">መ</supplied>ጋኛ፡ ለገብርከ፡ ተስፋ፡ ጊዮርጊስ፡
                     </explicit>
                     <note>The name of the owner <persName ref="https://betamasaheft.eu/PRS11696TasfaGi">Tasfā Giyorgis</persName> is mentioned in the supplication formula at the end of the text.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i7">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4624Prayer">Ṣalot baʾǝnta ḥǝmāma wǝgāt</title>
                     <incipit xml:lang="gez">
                        ጸሎት፡ በእንተ፡ ሕማመ፡ ውግዓት፡ ምድምድያም፡ ምድምድያስ፡ <choice>
                           <sic>ምድድምያስ፡</sic>
                           <corr resp="bm:GrebTiss1935Codices">ምድምድያስ፡</corr>
                        </choice> 
                        የሃቂ፡ የሀቂ፡ የሃቂ፡
                     </incipit>
                     <note/>
                  </msItem>       
                  
                  <msItem xml:id="ms_i8">
                     <title type="complete" ref="https://betamasaheft.eu/LIT4693MagicPr">Ṣalot baʾǝnta ʿayna za-yǝsallǝb lǝbba sabʾ</title>
                     <incipit xml:lang="gez">
                        ጸሎት፡ በእንተ፡ 
                           <sic>አይነ፡</sic>
                         ዘይሰልብ፡ ልበ፡ ሰብአ፡ ሳዶር፡ አላዶር፡ ዳናት፡ አዲራ፡ ሮደስ፡
                     </incipit>
                     <note/>
                  </msItem> 
               </msContents>
          

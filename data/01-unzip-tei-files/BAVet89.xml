                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="2r" to="28r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas">Sayfa Śǝllāse</title>
                     <msItem xml:id="ms_i1.1">
                        <locus from="2r" to="5v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Monday">Sayfa Śǝllāse, Praise for Monday</title>
                        <incipit xml:lang="gez">
                           <supplied reason="explanation">በስ</supplied>መ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> 
                           እነቅህ፨ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፤ እትነሣእ፡ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፤ አአምን፨ በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፤
                        </incipit>
                        <explicit xml:lang="gez">
                           አአምን፤ በባሕርየ፤ ስሙ፤ ለመንፈስ፤ ቅዱስ፤ 
                              <sic>ሕበረ፡</sic>
                              <sic>ተአኵቶ</sic>
                            ምስለ፡ አብ፡ ወወልድ፡ ዘንተ፤ ሥላሴ፡ እንዘ፡ 
                           አአምን፡ እክህደከ፤ ሰይጣን፤ ለዓለመ፤ ዓለም፤ አሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="5v" to="10r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Tuesday">Sayfa Śǝllāse, Praise for Tuesday</title>
                        <incipit xml:lang="gez">
                           ኦአብ፡ ፍጽምየ፨ በመለኮተ፡ ስሉስ፡ ቅዱስ፨ አኃትም፡ ከዋላየ፡ በመለኮተ፤ ሥሉስ፡ ቅዱስ፡ አኃትም፡ የማንየ፡ በመለኮተ፤ ሥሉስ፡ ቅዱስ፡ አኃትም፡ ጸጋምየ፡ በመለኮተ፤ ሥሉስ፡ ቅዱስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           በዝንቱ፡ ህላዌ፨ ሥላሴ፡ ቅድስት፡ ተማኅፀንኩ፡ ወአማኅፀንኩ፤ ነፍስየ፡ ወሥጋየ፡ ከመ፡ ያስጥመኒ፤ ሥሉስ፡ ቅዱስ፤ በቀላየ፤ ምሕረቱ፤ ዘኢይየብስ፡ ሊተ፡ ለገበርከ፤ ዘመስቀል፡
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="10r" to="13r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Wednesday">Sayfa Śǝllāse, Praise for Wednesday</title>
                        <incipit xml:lang="gez">
                           አብ፡ ወወል<supplied reason="omitted">ድ፡</supplied> ኅቡረ፡ ሀልዎቶሙ፡ ሥሉስ፡ በተገጽዎቶሙ፤ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በጽማሬ፡ ሥሉስ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           በዝንቱ፡ ሥላሴ፡ ኅቡር፤ ተማህፀንኩ፡ ወአማህፀንኩ፡ ነፍስየ፡ ወሥጋየ፡ ከመ፤ ይምሐሩኒ፡ ወይሣሃሉኒ፡ ሥሉስ፡ ቅዱስ፡ በእንተ፡ ሥላሴሁ፡ ሊተ፡ ለገበርከ፡ ዘመስቀል፡ 
                           <add place="interlinear">ኃብተ፡ ወልደ፡</add> ለዓለመ፡ ዓለም፤ አሜን፨
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text. The name of another person, <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName>, possibly a 
                           later owner, is written interlineally in red ink.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="13r" to="17v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Thursday">Sayfa Śǝllāse, Praise for Thursday</title>
                        <incipit xml:lang="gez">
                           አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱ<supplied reason="omitted">ስ፡</supplied> በግጻዌ፡ ሥሉስ፡ በሥላሴ፡ ዋህድ፡ አምላክ፡ ፫አዕማደ፡ ብርሃን፡ ፩አምጣኖሙ፡ ወ፩ስኖሙ፡ ፫መባርቅት፡ 
                           ፩ንጥረ፡ መለኮት፡
                        </incipit>
                        <explicit xml:lang="gez">
                           በዝንቱ፡ ስመ፡ ሥላሴ። ተማኅፀንኩ፡ ከመ፡ ይክፍለነ፤ ለሥሉሥ፡ ቅዱስ፡ እምተሳትፎ፡ ቅዱሳን፤ እንተ፤ ይእቲ፡ ደብተራ፡ ጽድቅ፡ ጽዮን፡ ለገብርከ፡ ዘመስቀል፡ <add place="interlinear">ወልደ፡ 
                              ሥላሴ፡</add> ለዓለመ፤ ዓለም፤ አሜን፨
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text. The name of another person, <persName ref="https://betamasaheft.eu/PRS11694WaldaSe">Walda Śǝllāse</persName>, is written 
                           interlineally in red ink.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="17v" to="22r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Friday">Sayfa Śǝllāse, Praise for Friday</title>
                        <incipit xml:lang="gez">
                           አይ፡ ልሳን፡ ወአይ፡ ከናፍር፡ ዘይክል፤ ነቢበ፡ ዕበየ፡ ክብሩ፡ ለሥላሴ፤ አይ፤ ልቡና፤ ወአይ፡ ሰሚዕ፡ ዘይክል፡ አእምሮ፤ ህላዌሁ፡ ለስላሴ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ስብ<supplied reason="explanation">ሐት</supplied>፡ ለእግዚአብሔር፡ ጠቢብ፡ በምክሩ፡ ስብ<supplied reason="explanation">ሐት</supplied>፡ ለእግዚአብሔር፡ 
                           ሰብእ፡ ወመላእክት፡ 
                              <sic>ዘኢየአምርዎ፤</sic>
                            ለምክሩ፡ ወለምሥጢሩ፤ ለዓለመ፤ ዓለም፤ አሜን፨ <add place="interlinear">ለአግብርቲከ፡ ዘመስቀል፡ 
                           ኃብተ፡ ወልድ፡</add>
                           <note>The names of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> and that of 
                              <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName> have been added interlineally in the supplication formula at the end of the 
                              text.</note>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="22r" to="25r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Saturday">Sayfa Śǝllāse, Praise for Saturday</title>
                        <incipit xml:lang="gez">
                           ሰላም፡ ለፍቅረ፡ መለኮት፤ በትስብእቱ፤ ዘጾመ፡ እንበይነ፡ ዚአሁ፡ አርአያሁ፤ ከመ፡ የሀበነ፤ ሰ<supplied reason="explanation">ላም</supplied>፡ ለፍቅረ፡ መለኮት፡ ዘይጼአን፡ ላዕለ፡ 
                           ኪሩቤል፡ በትስብእቱ፡ ተፅዕነ፡ ዲበ፡ ዕዋል፤
                        </incipit>
                        <explicit xml:lang="gez">
                           ግናይ፡ ወቡራኬ፤ ስባሔ፡ ወዝማሬ፡ ይደሉ፡ ለሥላሴ፡ በሰማይ፤ ወበምድር፡ በየብስ፡ ወበባሕር፤ ዲበ፡ ኵሉ፡ ፍጡር፡ ወግቡር፡ ላዕለ፡ ክሡት፤ ወስውር፨ መባሕተ፡ 
                              <sic>ኩነኔ፡</sic>
                            
                           ይደሉ፡ 
                              <sic>መለኮት፤</sic>
                            አብ፤ ወወልድ፤ ወመንፈስ፤ ቅዱስ፤ ለገብርከ፡ ዘመስቀል፤ <add place="interlinear">ኃብተ፡ ወልድ፡</add> ለዓለመ፤ 
                           ዓለም፤ አሜን፨
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text. The name of <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName> has been added 
                           interlineally in red ink.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="25r" to="25v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Daily">ዘዘወትር፡</title>
                        <incipit xml:lang="gez">
                           ይትባረክ፡ እግዚአብሔር፡ አብ፡ ወላዴ፡ ወልድ፡ ቅዱስ፤ ይት<supplied reason="explanation">ባረክ፡</supplied> እግዚአብሔር፡ ወልድ፡ 
                              <sic>ወልድ፤</sic>
                            
                           አብ፡ ዋህድ፡ ይት<supplied reason="explanation">ባረክ፡</supplied> እግዚአብሔር፡ ጰራቅሊጦስ፡ መንፈሰ፡ አብ፡ ወወልድ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ስ<supplied reason="explanation">ብሐት</supplied>፡ ለሥላሴ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ለሥላሴ፡ ምልዕት፡ በኵለሄ፤ ለሥላሴ፡ ይደሉ፡ ስባሄ፡ ሥላሴ፤ ዕውቅ፤ በሱራኄ፡ አድኅኖ፡ 
                           ወዕቀቦ፡ ለገብርከ፤ ዘመስቀል፡ <add place="interlinear">ኃብተ፡ ወልድ፡</add> ለዓለመ፤ ዓለም፤ አሜን፨
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text. The name of <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName> has been added 
                           interlineally in red ink.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus from="25v" to="28r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2296Sayfas#Sunday">Sayfa Śǝllāse, Praise for Sunday</title>
                        <incipit xml:lang="gez">
                           አኃሥሥ፡ 
                              <sic>ጽደቀ።</sic>
                            እምኀቤከ፡ ኦቀመረ፡ ጽድቅ፡ አኃሥሥ፡ ጥበበ፡ እምኔከ፡ ኦሙዳየ፤ ጥበብ፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ወበደኃሪት፤ ዕለት፡ ትባልሕ፡ እሞት፤ ወታወርስ፡ መንግሥተ፡ ሰማያት፤ ለገብርከ፡ ዘመስቀል፤ <add place="interlinear">ኃብተ፡ ወልድ፡</add> ለዓለመ፤ ዓለም፤ አሜን፨
                        </explicit>
                        <note>The name of the owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> is written in the supplication 
                           formula at the end of the text. The name of <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName> has been added 
                           interlineally in a different hand in red ink.</note>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="28r" to="28v"/>
                     <title ref="https://betamasaheft.eu/LIT2286ZenaSellase">Zenā nagaromu la-Śǝllāse</title>
                     
                     <incipit xml:lang="gez">
                        ተአምራቲሆሙ፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ጸሎቶሙ፡ ወበረከቶሙ፡ የሀሉ፡ ምስሌነ፡ ወሀሎ፤ 
                           <sic>፩መኮንን፡</sic>
                         ውስተ፡ ሀገረ፤ ፍልስጥኤም፡ ወበአኃቲ፡ 
                        ዕለት፤ አዘዞሙ፡ ለኃራሁ፨ ከመ፤ ይምፅዑ፡ ኀቤሁ፡
                     </incipit>
                     <explicit xml:lang="gez">
                        ወኮኑ፤ ከመ፡ መላእክት፡ ንጹሐን፡ ዘኢለከፎሙ፡ ርስሐተ፤ ዓለም፤ ወነበሩ፤ ምስለ፡ አብ፡ ወወልድ፡ ወመንፈስ፤ ቅዱስ፡ በትፍስሕት፡ ወበሐሤት፡ መፍቀሬ፡ ምሕረት፤ ለሰብእ፤ መዝገበ፡ ሣህል፡ ወበረከት፡ 
                        ምሕረቶሙ፤ ወሣህሎሙ፡ ትኩን፡ ምስለ፡ ገብሮሙ፡ <del rend="effaced">ዘመስቀል፡</del>
                        <add place="overstrike">ወልደ፡ ማርያም፡ ወልደ፡ ማርያም፡</add> 
                        <add place="interlinear">ኃብተ፡ ወልድ፡</add>
                     </explicit>
                     <note>The name of the prior owner <persName role="owner" ref="https://betamasaheft.eu/PRS11691Zamasqal">Zamasqal</persName> was written in the supplication 
                        formula at the end of the text and deleted. Other names, possibly later owners of the book, have been added in a different hand: that of 
                        <persName ref="https://betamasaheft.eu/PRS11692WaldaMa">Walda Māryām</persName>, written twice (the second time in red ink), and that of 
                        <persName ref="https://betamasaheft.eu/PRS11693HabtaWald">Habta Wald</persName>, written interlineally in red ink and deleted.</note>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">

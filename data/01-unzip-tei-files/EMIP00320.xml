               <msContents>

                  <summary>Psalter, ዳዊት፡</summary>

                     <msItem xml:id="ms_i1">
                       <locus from="1r" to="125r" facs="003">Fols 1r–125r</locus>
                       <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                       <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                       <msItem xml:id="ms_i1.1">
                         <locus from="1r" facs="003">Fols 1r and following</locus>
                         <title>Introductory Poem</title>
                         <incipit xml:lang="gez">
                           መዝሙረ: ዳዊትስ: ገነተ: ይመስል: ይብል።
                           በእንተ: ዝንቱ: ተሠርዓ: አንብቦቱ: በኵሉ: መዋዕል።
                           በኈልቈ: ሕዋሳት: ኀምስ: ዘውስተ: አባል።
                           ጠቢባነ: አይሁድ: ይክፍልዎ: መጽሐፈ: አትናቴዎስ: ይብል።
                           ወዝውእቱ: ቀዳማዊ: ክፍል።</incipit>
                         </msItem>
                       <msItem xml:id="ms_i1.2">
                         <locus from="1r" facs="003">Fols 1r and following</locus>
                         <title type="incomplete" ref="https://betamasaheft.eu/LIT3985Mazmura">Mazmura
                                                  Dǝngǝl</title>
                         <note>The Psalms of David begin with a selection of these</note>
                       </msItem>
                       <msItem xml:id="ms_i2">
                         <locus from="1r" to="95v" facs="003">Fols 1r–95v</locus>
                         <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                         <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                       </msItem>
                       <msItem xml:id="ms_i3"><locus from="95v" to="105v" facs="098">Fols 95v–105v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title></msItem>
                       <msItem xml:id="ms_i4"><locus from="105v" to="111v" facs="108">Fols 105v–111v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title></msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="74v">1r-74v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0176IHA">تخميس الوترية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>فقربه الرحمن قرب عناية / وخاطية حقا بغير رواية / فلما تولا بحسن ولاية / اراه من الايات اكبر اية فما زاع حاشا ان يزيغ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#74v">-74v</locus>وجايرتى يوم القيمة قربه / نعم إن بالاسلام أنعم ربه / يمينا بريى ان قلبي يحبه وذاك رجاىى في الممات وفي المحيا</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="paper"/>
                        </support>

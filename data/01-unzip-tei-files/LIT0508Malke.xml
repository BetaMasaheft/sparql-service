      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0508</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ገድልከ፡ ኮነ፡ ከመ፡ ዕለቱ፡ ለቃና፨</l>
                  <l n="2">ዘየዐውዶ፡ ስብሐት፡ በአርአያሁ፡ ለደመና፨</l>
                  <l n="3">አረጋዊ፡ ዘጾርከ፡ በትረ፡ ሃይማኖት፡ ወትድስና፨</l>
                  <l n="4">አስኬማከኒ፡ ንብረታ፡ ጽሙና፨</l>
                  <l n="5">አስኬማከኒ፡ አስኬማከኒ፡ አልባቲ፡ ሙስና፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ማሕየዊ፨</l>
                  <l n="2">ለዘወጠንክዎ፡ ሥመር፡ ሕንጻ፡ ሥላሴከ፡ አረጋዊ፨</l>
                  <l n="3">እንበለ፡ ፍጻሜ፡ ኢይትርፍ፡ ከመ፡ ሕንጻ፡ ናምሩድ፡ ዐላዊ፨</l>
                  <l n="4">እግረ፡ ልቡናየ፡ ባርክ፡ እግዚኦ፡ እምሐቅለ፡ ኀልዮ፡ አፍአዊ፨</l>
                  <l n="5">ከመ፡ ልቡናሁ፡ ኢይጻእ፡ ለኤፍራም፡ ለብሓዊ፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ሰላም፡ ለልደትከ፡ እማሕፀነ፡ ቅድስት፡ እድና፨</l>
                  <l n="2">በእንቲአየ፡ ሰአላ፡ አረጋዊ፡ ብዙኀ፡ ቀኖና፨</l>
                  <l n="3">ለወልጦ፡ ልብየ፡ ትምጻእ፡ ማርያም፡ ምስለ፡ ሕፃና፨</l>
                  <l n="4">ኅድግሰ፡ ዕበደ፡ ወልጦ፡ በከዊነ፡ ሠናይ፡ ኅሊና፨</l>
                  <l n="5">ማየ፡ መሳብክት፡ አውየኖ፡ በከብካብ፡ ዘቃና፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እንተ፡ አልቦቱ፡ ድምሳሴ፨</l>
                  <l n="2">ኀበ፡ ጸሐፍዎ፡ ቅድመ፡ ዲበ፡ ዐምደ፡ ወርቅ፡ ሥላሴ፨</l>
                  <l n="3">አምጣነ፡ ኢይክል፡ ወድሶ፡ እንተ፡ ከማከ፡ ብእሴ፨</l>
                  <l n="4">ነዓ፡ ነዓ፡ ምስለ፡ ገብረ፡ ክርስቶስ፡ ወሙሴ፨</l>
                  <l n="5">ታይድአኒ፡ አረጋዊ፡ ዘለከ፡ ውዳሴ፨</l>
               </lg>
               <lg type="stanza" n="38">
                  <l n="1">ሰላም፡ ለዕርገትከ፡ በዘነበ፡ አርዌ፡ ደብረ፡ ዳሞ፨</l>
                  <l n="2">እንዘ፡ ሚካኤል፡ በሰይፉ፡ የዐቅበከ፡ ቀዊሞ፨</l>
                  <l n="3">አረጋዊ፡ ማቴዎስ፡ ሰባኬ፡ ወንጌል፡ በኢያርምሞ፨</l>
                  <l n="4">ሀብተ፡ ጸጋከ፡ ሀበነ፡ ለውሉድከ፡ ተዘኪረከ፡ ሕማሞ፨</l>
                  <l n="5">ለዘበእንቲአነ፡ ወልድ፡ አንጸፍጸፈ፡ ደሞ፨</l>
               </lg>
               <lg type="stanza" n="44">
                  <l n="1">በዛቲ፡ ጸሎት፡ ሶበ፡ ንጼውዐከ፡ ንሕነ፨</l>
                  <l n="2">አረጋዊ፡ የዋህ፡ እንበለ፡ ጐንድዮ፡ ስምዐነ፨</l>
                  <l n="3">ወብእሴ፡ ሐሰት፡ እመቦ፡ ዘዕብየከ፡ መነነ፨</l>
                  <l n="4">ኢተወለድኩ፡ ብሂሎ፡ እምወላዴ፡ አእላፍ፡ አቡነ፨</l>
                  <l n="5">ርስተ፡ ጸጋከ፡ ኢይረስ፡ ምስሌነ፨</l>
               </lg>
            </div>
         </div>
      </body>

         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">አሐዱ፡ አብ፡ ቅዱስ፡ አሐዱ፡ ወልድ፡ ቅዱስ፨</l>
                  <l n="2">ወአሐዱ፡ አንተ፡ መንፈስ፡ ቅዱስ፨</l>
                  <l n="3">ቀድሰኒ፡ ሊተ፡ ዳእሙ፡ ወአንጽሐኒ፡ እምርኵስ፨</l>
                  <l n="4">ነፍስት፡ ተዐጽብ፡ አኮኑ፡ እምስኢለዐራዝ፡ ወልብስ፨</l>
                  <l n="5">እምፍቅደ፡ ሲሳይ፡ እስመ፡ የዐጽብ፡ ነፍስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ነአኵቶ፡ ለእግዚአብሔር፡ ገባሬ፡ ሠናያት፡ ላዕሌነ፨</l>
                  <l n="2">መንፈሰ፡ ልቡና፡ ወአእምሮ፡ መጠነ፡ ሀለወ፡ ብነ፨</l>
                  <l n="3">ወንስአሎ፡ ካዕበ፡ ኪያሁ፡ ከመ፡ ይዕቀበነ፨</l>
                  <l n="4">በዛቲ፡ ዕለት፡ ቅድስት፡ ወኵሎ፡ መዋዕሊነ፨</l>
                  <l n="5">በኵሉ፡ ሰላም፡ እምሰይጣን፡ ፀርነ፨</l>
                  <l n="6">አኀዜ፡ ኵሉ፡ ውእቱ፡ አምላክነ፨</l>
               </lg>
               <lg type="stanza" n="45">
                  <l n="1">እምዘ፡ አብኡ፡ አብዕልት፡ ውስተ፡ ሙዳየ፡ ምጽዋት፡ ቅዱስ፨</l>
                  <l n="2">እምተረፈ፡ ብዙኅ፡ ብዕል፡ ወአኮ፡ ንኡስ፨</l>
                  <l n="3">ቍርባነ፡ ትሕትናየ፡ ዘንተ፡ ተወከፍ፡ ክርስቶስ፨</l>
                  <l n="4">ዘተወከፍኮን፡ ለአፅሩቀ፡ ዐቢይ፡ ተጽናስ፨</l>
                  <l n="5">እለ፡ ይትበሀላ፡ ቆንድራቆንቲስ፨</l>
               </lg>
               <lg type="stanza" n="46">
                  <l n="1">ለአሐዱ፡ ቀሲስ፡ በደዌ፡ ኀጢአት፡ ዘሐመ፨</l>
                  <l n="2">መናፍስተ፡ ርኩሳን፡ ውስተ፡ አፉሁ፡ እስከ፡ ረስዩ፡ ልጓመ፨</l>
                  <l n="3">ሶበ፡ ለተልእኮ፡ ይለብስ፡ አልባሰ፡ ቅዳሴ፡ ግሩም፨</l>
                  <l n="4">እንበይነ፡ ክብረዝ፡ ቍርባን፡ በከመ፡ ተጽሕፎ፡ ቀደመ፨</l>
                  <l n="5">እስመ፡ ኵለንታሁ፡ ይከውን፡ እሳተ፡ ፍጹመ፨</l>
               </lg>
            </div>
         </div>
      </body>

      <body>
         <t:listPerson>
            <t:person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">አብራንዮስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾAbrānyos</persName>
               
               <persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               <t:floruit notBefore="1600" notAfter="1699"> 
                  He was a saint of the 17th century, contemporary of 
                  <persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName>Susǝnyos</persName>. 
                  At the age  of twelve, he went to the monastery of 
                  <placeName ref="https://betamasaheft.eu/LOC2352DabraS">Dabra Dabsān</placeName>
                  to take monastic orders and was ordained priest by the metropolitan ṗāṗṗās 
                 
                  <persName ref="https://betamasaheft.eu/PRS6071Krestodo"> 
                     <t:roleName type="title">ʾabuna</t:roleName>Krǝstodolu [II]</persName>.
                  As a follower of <persName ref="https://betamasaheft.eu/PRS3934Ewostate">ʾEwosṭātewos</persName>, 
                  he professed the Unionist doctrine during the Christological controversies. 
                  Because of his beliefs, <persName ref="https://betamasaheft.eu/PRS1280Abranyos">ʾAbrānyos</persName> 
                  was imprisoned by 
                  <persName ref="https://betamasaheft.eu/PRS9152TaklaHa">
                     <t:roleName type="title">ʾaṣe</t:roleName>Takla Hāymānot I</persName> 
                  and released by 
                  <persName ref="https://betamasaheft.eu/PRS9449Tewoflos">
                     <t:roleName type="title">ʾaṣe</t:roleName>Tewoflos</persName>. Thereafter, 
                  he returned to his monastery <placeName ref="https://betamasaheft.eu/LOC2390DabraT">Dabra Ṭǝllul</placeName>
                  where he remained until his death.
                  He was succeeded by <persName ref="https://betamasaheft.eu/PRS1580AkalaKr">ʾAkāla Krǝstos</persName>.
                  
                  
               </t:floruit>
           
               
            </t:person>
            
         </t:listPerson>

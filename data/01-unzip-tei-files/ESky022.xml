                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular, by a trained hand</seg>
                        <seg type="ink">Black, red</seg>
                        <date>18th century (?)</date>
                        <list type="abbreviations">
                           <item>
                              <abbr>ሰ፡ (ቅ፡)</abbr> for <expan>ሰአሊ፡ ለነ፡ ቅድስት፡ </expan> (Text
                              I-4)</item>
                           <item>
                              <abbr>ወ፡ (ሣ፡) ሰ፡</abbr> for <expan>ወልድኪ፡ ሣህሎ፡ ይክፈለነ፡ ሰአሊ፡ ለነ፡ ቅድስት፡
                              </expan> (Text I-5)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; titles and numbers of the Pss.,
                           Canticles and Songs; names of the Hebrew letters and initial lines of
                           each portion in Ps. 118; the second and fourth letters in each line of
                           Ps. 150 and Canticle 10 (fols. 122r; 131v-132v); incipits of each daily
                           portion and of smaller text units in Text I-4; elements of the
                           punctuation signs.
 
 A few lines (alternating with black lines)
                           on the incipit page of Text I-1.</seg>
                     </handNote>
                  </handDesc>

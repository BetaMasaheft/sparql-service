        <body>
            <div type="bibliography">
                <listBibl type="editions">
                    <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
                </listBibl>
                
            </div>
            <div type="edition" xml:lang="gez">
                <note>The following text is taken from <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>.</note>
                <div type="textpart" xml:id="masgabiya">
                    <lg type="stanza" n="1">
                        <l n="1">ሰላም፡ ለተፈጥሮትከ፡ ምስለ፡ መላእክት፡ ኅቡረ፨</l>
                        <l n="2">እንዘ፡ ኢትከውን፡ ቅድመ፡ ወእንዘ፡ ኢትዴኀር፡ ድኅረ፨</l>
                        <l n="3">ሰዳዴ፡ ሰይጣናት፡ ፋኑኤል፡ እምላዕለ፡ ሰብእ፡ ወትረ፨</l>
                        <l n="4">ስድዶሙ፡ ለአጋንንት፡ ወአርእዮሙ፡ ኀሳረ፨</l>
                        <l n="5">ከመ፡ ኢይግበሩ፡ ኪያየ፡ ማኅደረ፨</l>
                    </lg>
                </div>
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">በመለኮተ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አፈ፡ ዚአየ፡ ወጠነ፨</l>
                        <l n="2">ማሕሌተ፡ ፋኑኤል፡ መልአክ፡ ወዘመልክኡ፡ ድርሳነ፨</l>
                        <l n="3">እመሰ፡ ላዕላዐ፡ ልሳንየ፡ ኮነ፨</l>
                        <l n="4">ፋኑኤል፡ ነዓ፡ ትርድአኒ፡ ወታንብበኒ፡ ፍጡነ፨</l>
                        <l n="5">እንዘ፡ ለስምከ፡ እእኅዝ፡ ወእዌጥን፡ አነ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">ሰላም፡ ለሢመትከ፡ እምእግዚአብሔር፡ ንጉሥ፨</l>
                        <l n="2">አመ፡ ሠሉሱ፡ ለወርኀ፡ ታኅሣሥ፨</l>
                        <l n="3">ሊቀ፡ መላእክት፡ ፋኑኤል፡ ለባሴ፡ ቁስ፡ መንፈስ፨</l>
                        <l n="4">አንቅሀኒ፡ እምሐሌትየ፡ ለስብሐቲከ፡ ሐዲስ፨</l>
                        <l n="5">ወተራድአኒ፡ በሥጋ፡ ወነፍስ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘመንክር፡ ጣዕሙ፨</l>
                        <l n="2">ወሐዋዝ፡ ዓዲ፡ ለአዳም፡ እምዝክረ፡ ስሙ፨</l>
                        <l n="3">ፋኑኤል፡ ትኩን፡ መተንብለ፡ ሰብእ፡ ኵሎሙ፨</l>
                        <l n="4">ኪያከ፡ እመላእክት፡ እለ፡ ምስሌከ፡ ተሕትሙ፨</l>
                        <l n="5">ሥላሴ፡ አጋዕዝቲከ፡ ኀረዩ፡ ወሤሙ፨</l>
                    </lg>
                    <lg type="stanza" n="4">
                        <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስከ፡ ወለርእስከ፡ ሥርገወ፡ ብርሃን፨</l>
                        <l n="2">ወለገጽከ፡ መብረቅ፡ ዘያንጸበርቅ፡ ለዐይን፨</l>
                        <l n="3">ሊቀ፡ ካህናት፡ ፋኑኤል፡ ምዑዘ፡ ረድኤት፡ ዕጣን፨</l>
                        <l n="4">ሰይፈከ፡ ምላኅ፡ እግዚኦ፡ ዲበ፡ ፀርየ፡ ሰይጣን፨</l>
                        <l n="5">ወይክድኖ፡ ለገጽየ፡ ዘገጽ፡ ሥን፨</l>
                    </lg>
                    <lg type="stanza" n="25">
                        <l n="1">ሰላም፡ እብል፡ እንተ፡ አካልከ፡ ቆመ፨</l>
                        <l n="2">ወለመልክእከ፡ ኣቀርብ፡ አምኃ፡ ወሰላመ፨</l>
                        <l n="3">ፋኑኤል፡ ዝክርከ፡ እምቀናንሞስ፡ ዘጥዕመ፨</l>
                        <l n="4">አልክፈኒ፡ በጕጠትከ፡ ሥጋ፡ መለኮት፡ ፍሕመ፨</l>
                        <l n="5">ከመ፡ እምላዕሌየ፡ ያሰስል፡ ሕማመ፨</l>
                    </lg>
                    <lg type="stanza" n="26">
                        <l n="1">ምንተ፡ እዌድስ፡ ኪያከ፡ ውዱሰ፨</l>
                        <l n="2">ወምንተ፡ እቄድስ፡ ኪያከ፡ ቅዱሰ፨</l>
                        <l n="3">እስመ፡ ረሰይኩከ፡ አበ፡ ወረሰይኩከ፡ መንፈሰ፨</l>
                        <l n="4">ፋኑኤል፡ ሀበኒ፡ እሞገስከ፡ ሞገሰ፨</l>
                        <l n="5">እንበለ፡ ምግባር፡ ወገድል፡ ዘያጸድቅ፡ ነፍሰ፨</l>
                    </lg>
                    <lg type="stanza" n="27">
                        <l n="1">አዕርክተ፡ ንጉሥ፡ ምድራዊ፡ ኀበ፡ ንጉሦሙ፡ ይተነብሉ፨</l>
                        <l n="2">ሢመተ፡ ወክብረ፡ ለፍቁራኒሆሙ፡ ዘይደሉ፨</l>
                        <l n="3">ፋኑኤል፡ ሰአል፡ እምእግዚአ፡ ኵሉ፨</l>
                        <l n="4">አመ፡ ምንዳቤየ፡ ይናዝዘኒ፡ በቃሉ፨</l>
                        <l n="5">ወአመ፡ ሞትየ፡ ይርከበኒ፡ ሣህሉ፨</l>
                    </lg>
                </div>
            </div>
            
            <div type="edition">
                <note>The following text is taken from <ref type="mss" corresp="https://betamasaheft.eu/EMIP00616">Addis Ababa, Mekane Yesus Seminary Library, Mekane Yesus Seminary 16</ref>.</note>
                <div type="textpart" subtype="incipit" xml:lang="gez">
                    <ab>በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ጠጠነ፡ ማኅሌተ፡ ክቡር፡ ፋኑኤል፡ ወዘመልክዑ፡ ድርሳነ፡ እመሰ፡ ልሳንየ፡ ላዕላዓ፡ ኮነ፡ ነዓ፡ ፋኑኤል፡ ትርድአኒ፡ ወታድኅነኒ፡
                    ፍጡነ፡ እንዘ፡ ላዕከ፡ አኃዝ፡ ወእዌጥን፡ አነ፨ ሰላም፡ ለተፈጥሮትከ፡ ምስለ፡ መላእክት፡ ኅቡረ፡ እንዘ፡ ይትከውን፡ ቅድመ፡ ወእንዘ፡ ኢትከውን፡ ድኅረ፡ ሰዳዴ፡ ሰይጣናት፡
                    ፋኑኤል፡ እምላዕለ፡ ሰብእ፡ ወትረ፡ ስድዶሙ፡ ለሰይጣናት፡ ወአርእዮሙ፡ ኃሣረ፡ ከመ፡ ኢይግበሩ፡ ኪያየ፡ ማደረ፨</ab>
                </div>
                <div type="textpart" subtype="explicit" xml:lang="gez">
                    <ab>አዕርግተ፡ ንጉሥ፡ ምድራዊ፡ ኀበ፡ ንጉሦሙ፡ ይተነብሉ፡ ሢመተ፡ ወክብረ፡ ለፍቁራኒሆሙ፡ ይስእሉ፡ ከማሆሙ፡ ሰአሎ፡ ፋኑኤል፡ በእንቲአየ፡ ለእግዚአብሔር፡ ኵሉ፡
                    አመ፡ ምንዳቤየ፡ ይናዝዘኒ፡ በቃሉ፡ ወአመ፡ ምንዳቤየ፡ ካዕበ፡ ይብጸሐኒ፡ ሣህሉ።</ab>
                </div>
            </div>
        </body>
    </text></TEI>
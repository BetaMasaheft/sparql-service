                          <lb/>ቀበኒ፤ እመከራ፤ ሥ
                          <lb/>ጋ፡ ወነፍ<supplied reason="omitted">ስ</supplied>፨ አድኅ
                          <lb/>ኖ፡ ለገብርከ፡ <persName ref="https://betamasaheft.eu/PRS13201Gabra">ገብረ<supplied reason="omitted">፡</supplied>
                          <lb/>ኢየሱስ።</persName>
                          <lb/>አመ፡ ትመጽዕ<supplied reason="omitted">፡</supplied>
                          <lb/>ለኰንኖ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                      </msItem>

                      <msItem xml:id="ms_i8">
                        <locus target="#48v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3049RepCh329">Hymn to Jesus Christ</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኢየሱ<supplied reason="omitted">ስ</supplied>፡ ሕፃን፡ ስብሐት፡ ለከ፡ ዘድ<supplied reason="omitted">ን</supplied>ግል፡ ፍሬ፡ <choice><sic>ማኀፀን፡</sic><corr>ማኅፀን፡</corr></choice> ኢየሱስ፡ ክርስቶስ፡ <choice><sic>ቀርባን</sic><corr>ቍርባን<supplied reason="omitted">፡</supplied></corr></choice> መብልዖሙ፡ ለርኁባን፡ ኢየሱስ፡ ወይን፡ <choice><sic>ሰቲሆሙ፡</sic><corr>ስቴሆሙ፡</corr></choice> ለጽሙዓን፡</incipit>
                        <explicit xml:lang="gez">ፈጽም<supplied reason="omitted">፡</supplied> ሊተ፡ ዘትቤ፡ ዘበልዓ፡ ሥጋየ፡ በአሚን፡ ወሰትየ፡ ደምየ፡ በኑኀ፡ ዘመን፡ ለዓለመ፡ <add place="above">ዓለም<supplied reason="omitted">፡</supplied></add> የሀዩ፡ <sic>እምኩነኔ፡</sic> ወደይን፡ ሃሌ፡ ሉያ፡</explicit>
                        <explicit xml:lang="gez" type="supplication">
                          <lb/>በብዝኃ፡ ኂሩትከ<supplied reason="omitted">፡</supplied>
                          <lb/>ኢየሱስ፡ <choice><sic>ዕቀበነ፡</sic><corr>ዕቀበኒ፡</corr></choice> እ
                          <lb/>መከራ፡ ሥጋ፡ ወ
                          <lb/><supplied reason="omitted">ነ</supplied>ፍስ፡ ለገብ<supplied reason="omitted">ር</supplied>ከ፡ <persName ref="https://betamasaheft.eu/PRS13201Gabra">ገብረ<supplied reason="omitted">፡</supplied>
                          <lb/>ኢየሱስ፨</persName>
                        </explicit>
                      </msItem>


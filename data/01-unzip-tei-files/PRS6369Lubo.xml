      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">ሉቦ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Lubo</persName>
               
               <persName>
                  <roleName type="title">daǧǧāzmāč</roleName>
               </persName>
               <occupation type="political"> governor</occupation>
               
               <nationality type="Ethiopia"/>
               <faith type="Orthodox"/>
               
               <floruit notBefore="1759" notAfter="1783">He was an important official of 
                  <persName ref="https://betamasaheft.eu/PRS5636IyoasI">
                     <roleName type="title">ʾaṣe </roleName>ʾIyoʾās I</persName> between <date>1759-1783</date>. He was a principal protector 
                  of the throne of
                  <persName ref="https://betamasaheft.eu/PRS5636IyoasI">
                     <roleName type="title">ʾaṣe </roleName>ʾIyoʾās I</persName> 
                  with his brother <persName ref="https://betamasaheft.eu/PRS3647Dulo">Dulo</persName>. 
                  Initially, he appears in the historical record in <date>1759</date>,
                  with his appointment as šālaqā of the Kanisā troops. 
                  Five years later, in <date>1764</date>,  he was appointed
                  as <persName ref="https://betamasaheft.eu/PRS6369Lubo">
                     <roleName type="title">daǧǧāzmāč</roleName>
                  </persName>
                  of <placeName ref="https://betamasaheft.eu/LOC6568Amhara">ʾAmhārā</placeName>. 
                  He became a principal rival of 
                  <persName ref="https://betamasaheft.eu/PRS7091Mikael"> 
                     <roleName type="title">rās</roleName>
                     Mikāʾel Sǝḥul</persName> and 
                  following the assassination of 
                  <persName ref="https://betamasaheft.eu/PRS5636IyoasI">
                     <roleName type="title">ʾaṣe </roleName>
                     ʾIyoʾās I</persName> in <date>1769</date>,
                  he was demoted from his position and soon dropped out of contention. But he reappeared as a notable in <date>1783</date>
                  and met 
                  <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">
                     <roleName type="title">ʾaṣe </roleName>
                     Takla Giyorgis I</persName> and was baptized, along with many of his followers.
               </floruit>
              
               
            </person>
            
            
         </listPerson>

                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ወልድ፡ ሠዓላ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Wald Śaʿālā</t:persName>
                  <t:persName xml:lang="gez" xml:id="n2" type="regnal">ሥልጣን፡ ሞገሳ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">Śǝlṭān Mogasā</t:persName>
                  
                  
               <t:persName>
                  <t:roleName type="title">ʾǝtege </t:roleName>
               </t:persName>
                  
                  <t:occupation type="political">queen</t:occupation>
              
                  
                  
               <t:floruit notBefore="1600" notAfter="1661">She was the most important of
                  the wives  of 
                  <t:persName ref="https://betamasaheft.eu/PRS9038Susenyos">
                     <t:roleName type="title">ʾaṣe</t:roleName> Susǝnyos</t:persName>. She was a member of an influential clan from <t:placeName ref="https://betamasaheft.eu/LOC6167Walaqa">Walaqā</t:placeName>. 
                  Initially, she was one of the main opponents of the Jesuit missionaries at the court.
                     
                  </t:floruit>
                  <t:death when="1661" evidence="internal"/> 
                  
               </t:person>
               
         </t:listPerson>
         

                    </item>
                    <item xml:id="e4">
                    <desc>
                    Numbered quires: quires 1–14
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <locus target="#13r #17v #18r #19v #23v" facs="015 020 022 026">Fols. 13r, 17v, 18r, 19v, 23v</locus>
                    <desc>etc., words of text are written interlinearly;

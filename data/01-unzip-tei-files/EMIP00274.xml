          <msContents>
            <summary/>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="78r" facs="003">Fols 1r–78r</locus>
              <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer">Protective prayers
                                                  for the seven weekdays</title>
              <note>arranged for the days of the week</note>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡<gap reason="omitted"/> ጸሎቱ፡ ለጴጥሮስ፡ ዝውእቱ፡ ዘየዓቢ፡
                እምሐዋርያቲሁ፡ ዘሐረዮ፡ ክርስቶስ፡ እምቅድመ፡ ኵሎሙ፡ ሐዋርያቲሁ፡ ለኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ወጸውዖሙ፡
                ለኵሎሙ፡ ሐዋርያቲሁ፡<gap reason="omitted"/></incipit>
            </msItem>

            <msItem xml:id="ms_i2">
              <locus from="78v" to="85v" facs="081">Fols 78v–85v</locus>
              <title type="incomplete" ref="https://betamasaheft.eu/LIT2928RepCh209">Malkǝʾ-hymn to
                                                  John the Evangelist</title>
              <note>incomplete at the end</note>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
              <incipit xml:lang="gez">ሰላም፡ ለፅንሠትከ፡ ወለልደትከ፡ እማኅፀና፡<gap reason="omitted"/></incipit>
            </msItem>

          </msContents>

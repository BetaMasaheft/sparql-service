            <handDesc>
              <handNote xml:id="h1" script="Ethiopic">
                <seg type="rubrication">
                  <foreign xml:lang="gez">ጰትሮስ፡</foreign>
                  <foreign xml:lang="gez">ኢየሱስ፡ ክርስቶስ፡</foreign>
                  <foreign xml:lang="gez">ኢግዚአብሔር፡</foreign>
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                </seg>
                <desc>The words Peter, Jesus Christ, God and Mary are rubricated</desc>
              </handNote>
            </handDesc>
            <decoDesc>
              <decoNote type="miniature" xml:id="d1"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref></desc></decoNote>
              <decoNote type="miniature" xml:id="d2"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
              <decoNote type="miniature" xml:id="d3"><locus target="#7v" facs="010">Fol. 7v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref> surrounded by the four living
                  creatures (a small miniature). All three members of the trinity have their hands
                  on one orb and there are no distinct lines dividing their
                garments</desc></decoNote>
              <decoNote type="miniature" xml:id="d4"><locus target="#12r" facs="014">Fol. 12r</locus><desc>The
                  Creation of Monday. Instruction, in blue pen: <q>“[Paint] the creation of
                    Monday.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d5"><locus target="#15r" facs="017">f. 15r (column
                  2)</locus>The <desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                  <persName ref="https://betamasaheft.eu/PRS4377Gabriel">Gabriel</persName> rescues the three young men in the fiery furnace.
                  Instructions: <q>“[Paint] Saint Gabriel rescuing the three young
                  children.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d6"><locus target="#15r" facs="017">f. 15r, col. 1,
                  bottom</locus><desc>Four-fold palindrome chart on the name Ananǝya, one of the
                  three children</desc></decoNote>
              <decoNote type="miniature" xml:id="d7"><locus target="#20r" facs="022">Fol. 20r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref> (left), on a cloud, creating
                  vegetation on Tuesday. Instruction: <q>“[Paint] Tuesday’s
                creation.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d8"><locus target="#24r" facs="026">Fol. 24r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref> surrounded by the three living
                  creatures (a small miniature). All three members of the trinity have their own
                  sphere and there are distinct lines dividing their garments. Instruction:
                    <q>“[Paint] icon of the Trinity.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d9"><locus target="#25r" facs="027">Fol. 25r</locus><desc>Two
                  charts of letters: top, nine-by-nine chart of letters described in the caption as
                    <q>“about the wild animals of the sea” and “about lions;”</q> bottom,
                  eleven-by-twelve chart of letters described with the following enigmatic text:
                    <foreign xml:lang="gez">በእንተ ሶበ ሤጋል ዝመ ወተሐሲ ቆጽለ</foreign>)</desc></decoNote>
              <decoNote type="miniature" xml:id="d10"><locus target="#26r" facs="028">f. 26r,
                  lower</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> and lion (left);
                  angel, ox, and bird (right). Instruction: <q>“[Paint] Michael, Gabriel, and
                    Kirubel.”</q>
                </desc></decoNote>
              <decoNote type="miniature" xml:id="d11"><locus target="#27r" facs="029">Fol. 27r</locus><desc>The
                  sun, moon, stars, and <ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref> floating
                  in a cloud (a small miniature). Instruction: <q>“[Paint] creation of
                    Wednesday.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d12"><locus target="#29r" facs="031">Fol. 29r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>, all three members of the Trinity have
                  their own sphere and there are distinct lines dividing their garments (a small
                  miniature). Instruction: <q>“[Paint] the Holy Trinity.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d13"><locus target="#33r" facs="035">Fol. 33r</locus><desc>The
                    <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref>
                  <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName> stabbing an evil angel with a <term key="sword" ana="#sword"/>
                  (a small miniature). Instruction: <q>“[Paint] Saint Michael punishing
                    Sataniel.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d14"><locus target="#44r" facs="046">Fol. 44r</locus><desc>Creation of Thursday. <ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref>,
                  hovering on a cloud, pointing toward birds in flight. Instruction: <q>“[Paint]
                    Creation of Thursday.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d15"><locus target="#48v" facs="051">Fol. 48v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>
                  <q>“[Paint] With Her beloved Son.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d16"><locus target="#49r" facs="051">Fol. 49r</locus><desc>The
                  Lamb carrying a processional <ref type="authFile" corresp="https://betamasaheft.eu/AT1071Cross">Cross</ref>, on a
                  round seal of yellow background and bordered with two red lines (a small
                  miniature). Instruction: <q>“[Paint] Behold the Lamb of
                God.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d17"><locus target="#56r" facs="058">Fol. 56r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>. <q>“[Paint] Icon of the
                    Crucifixion.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d18"><locus target="#57v" facs="060">Fol. 57v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref>, hovering in a cloud, points
                  toward a man and a woman. Instruction: <q>“[Paint] Creation of
                Friday.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d19"><locus target="#58r" facs="060">Fol. 58r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref>. Instruction: <q>“[Paint] Mary
                    with Her Beloved Son.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d20"><locus target="#65r" facs="067">Fol. 65r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref>, hovering on a cloud.
                  Instruction: <q>“[Paint] Saturday.”</q></desc></decoNote>
              <decoNote type="miniature" xml:id="d21"><locus target="#72v" facs="075">Fol. 72v</locus><desc>An <ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (probably <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>) stabs Satan with a spear</desc></decoNote>
              <decoNote type="miniature" xml:id="d22"><locus target="#77r" facs="079">Fol. 77r</locus><desc>A man
                  (the patron, Täklä Giyorgis) holding a book and prayer beads</desc></decoNote>
              <decoNote type="miniature" xml:id="d23"><locus target="#78r" facs="080">Fol. 78r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1101GodtheFather">God the Father</ref> hovering on a cloud; three <term key="angel" ana="#angel"/>s’ faces nearby. Instructions erased</desc></decoNote>
              <decoNote type="miniature" xml:id="d24"><locus target="#86r" facs="088">Fol. 86r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
              <decoNote type="miniature" xml:id="d25"><locus target="#86v" facs="089">Fol. 86v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref></desc></decoNote>
              <decoNote type="miniature" xml:id="d26"><locus target="#87r" facs="089">Fol. 87r</locus><desc>Three
                    <ref type="authFile" corresp="https://betamasaheft.eu/AT1041HolyMen">Holy Men Potrait</ref> with hand <term key="cross" ana="#cross"/>es
                  and fly swatters standing; one saint prostrate</desc></decoNote>
              <decoNote type="miniature" xml:id="d27"><locus target="#87v" facs="090">Fol. 87v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1049Resurrection">Resurrection of Jesus</ref>, raising <persName ref="https://betamasaheft.eu/PRS1386Adam">Adam</persName> and <persName ref="https://betamasaheft.eu/PRS3926Eve">Eve</persName></desc></decoNote>
              <decoNote type="miniature" xml:id="d28"><locus target="#88r" facs="090">Fol. 88r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>, hands crossed across his chest,
                  stands before a seated man</desc></decoNote>
              <decoNote type="frame" xml:id="d29"> Decorative designs: <locus target="#19v #25r #28r #35r #76r #78r #83v #85r" facs="022 027 030 037 078 086 087">fols. 19v, 25r, 28r, 35r, 76r, 78r, 83v, 85r</locus> (multiple full stops) </decoNote>
            </decoDesc>
            <additions>
              <list>
                <item xml:id="e1">
                  <desc>
                    <locus target="#ir(ecto) #iv(erso) #88v" facs="001 002 091">Fols. ir(ecto), iv(erso), 88v</locus> blank </desc>
                </item>
                <item xml:id="a1">
                  <desc type="OwnershipNote">
                    <locus target="#3v" facs="006"> f. 3v and passim</locus> Prayer for Täklä
                    Giyorgis, presumed owner </desc>
                </item>
                <item xml:id="e2">
                  <desc> Numbered quires: quires 1–2 </desc>
                </item>
                <item xml:id="a">
                  <desc> Scribal intervention: erasure markings are visible (<locus target="#71v #76r" facs="074 078">fols. 71v, 76r</locus>) </desc>
                </item>
              </list>
            </additions>
            <bindingDesc>
              <binding xml:id="binding" contemporary="true">
                <decoNote xml:id="b1">Parchment, 184 x 141 x 37 mm, four Coptic chain stitches
                  attached with bridle attachments to rough-hewn boards of the traditional wood,
                  covered with tooled leather.</decoNote>
                <decoNote xml:id="b2" type="bindingMaterial">
                  <material key="parchment"/>
                  <material key="wood"/>
                  <material key="leather"/>
                </decoNote>
              </binding>
            </bindingDesc>

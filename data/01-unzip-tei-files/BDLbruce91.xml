                  <summary/>
                  
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="30">Fols 1–30</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4633Chronicle">Chronicle of Bakāffā</title>
                     <textLang mainLang="gez"/> 
                     
                     <msItem xml:id="ms_i1.1">
                        <locus from="1" to="11">Fols 1–11</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4633Chronicle#Part1">Chronicle of Bakāffā, Part1</title>
                        <textLang mainLang="gez"/> 
                     </msItem>
                     
                     <msItem xml:id="ms_i1.2">
                        <locus from="11" to="23">Fols 11–23</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4633Chronicle#Part2">Chronicle of Bakāffā, Part2</title>
                        <textLang mainLang="gez"/> 
                        <incipit xml:lang="gez">
                           <locus target="#11">Fol. 11</locus>
                           ዝውእቱ፡ መጽሐፈ፡ ታሪክ፡ ዘእጽሕፎ፡ እምአመ፡ አብጽሐኒ፡ ጠቢብ፡ ወማእምረ፡ ልብ፡ 
                           <persName ref="https://betamasaheft.eu/PRS2377Bakaffa">   
                              <roleName type="title">ንጉሥ፡ </roleName> በካፋ፡</persName> እስከዝ፡ መዓርገ፡ ሢመት፡
                           ዘውእቱ፡ ጸሐፊ፡
                        </incipit>
                        <colophon xml:id="coloph1">
                           <locus target="#23">Fol. 23</locus>
                           ወአመ፡ ፯ ለነሐሴ፡ አዕረፈ፡ <persName ref="https://betamasaheft.eu/PRS8871Sinoda">
                              <roleName type="title">አዛዥ፡ </roleName> ሲኖዳ፡ </persName> ዐቢይ፡ ካህን፡ 
                           መምህረ፡ ደቂቀ፡ ንጉሥ፡ ወጸሐፌ፡ ታሪክ፡ ዘጊቤ፡ ወጃዊ፡ ወላስታ፡
                           ወውእቱ፡ ዘጸሐፈ፡ መጽሐፈ፡ ሰዋስው፡ ዘበጽሐ፡ ውስተ፡ ኵሉ፡ ዓለም። ወዓዲ፡ ደረሰ፡ መዝሙረ፡ 
                           <persName ref="https://betamasaheft.eu/PRS5616IyasuI">
                              <roleName type="title">ሐፄ፡</roleName> ኢያሱ፡</persName>  ሰማዕት፡ ሐዲስ።
                           ባሕቱ፡ እግዚአብሔር፡ ያዕርፍ፡ ነፍሶ፡ ውስተ፡ ሕፅነ፡ አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡
                        </colophon>
                     </msItem>
                     
                     <msItem xml:id="ms_i1.3">
                        <locus from="23" to="30">Fols 23–30</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4633Chronicle#Part3">Chronicle of Bakāffā, Part3</title>
                        <textLang mainLang="gez"/> 
                        <incipit xml:lang="gez">ወእምዝ፡ ጸሐፈ፡ ወልዱ፡ <persName ref="https://betamasaheft.eu/PRS5941KenfaMi">ክንፈ፡ ሚካኤል፡</persName>
                        </incipit>
                        <explicit xml:lang="gez">በዝየ፡ ተፈጸመ፡ ታሪከ፡ ንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS2377Bakaffa">በካፋ፡</persName> በሰላመ፡ እግዚአብሔር፡ አሜን፡</explicit>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="31" to="104">Fols 31–104, </locus>
                     <locus from="111" to="116">111–116</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4634Chronicle">Chronicle of ʾIyāsu II</title>
                     <textLang mainLang="gez"/> 
                     <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/4QA6WBFG"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Guidi1954IyasuII"/><title level="m">Annales regum ʹIyāsu II et ʹIyoʹas</title><title level="s">Corpus Scriptorum Christianorum Orientalium</title><editor><forename>Ignazio</forename><surname>Guidi</surname></editor><pubPlace>Louvain</pubPlace><publisher>Imprimerie Orientaliste, L. Durbecq</publisher><date>1954</date><series><title level="s">Corpus Scriptorum Christianorum Orientalium</title><biblScope unit="volume">66, Scriptores Aethiopici, 29</biblScope></series><biblScope unit="volume">66, Scriptores Aethiopici, 29</biblScope><note type="tags"><note type="tag">bm:Guidi1954IyasuII</note></note><note type="tag">bm:Guidi1954IyasuII</note></bibl>
                     </listBibl>
                     <note>The work is divided into 48 chapters, of which 13 treat the life of <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ʾIyāsu II</persName>
                     before his reign.</note>
                     
                     <msItem xml:id="ms_i2.1">
                        <locus from="31" to="33">Fols 31–33</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4634Chronicle#GenealogyIyasu">Chronicle of ʾIyāsu II, Genealogy of  ʾIyāsu II (same as LIT3854KingList)</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ዜና፡ ልደቶሙ፡ ለነገሥት፡ እምአዳም፡ እስከ፡ ይእዜ።</incipit>
                     </msItem>
                     
                     <msItem xml:id="ms_i2.2">
                        <locus from="33" to="35">Fols 33–35</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4634Chronicle#GenealogyMentewwab">Chronicle of ʾIyāsu II,  Genealogy of Bǝrhān Mogasā</title>
                        <textLang mainLang="gez"/> 
                        <incipit xml:lang="gez">ወዳግመ፡ ንጽሕፍ፡ ኍልቈ፡ ልደት፡ ዘይቴጌ፡ <persName ref="https://betamasaheft.eu/PRS2682BerhanM">ምንትዋብ፡</persName> 
                           <sic resp="PRS3562Dillmann">ዘኮነ፡</sic> 
                           እምቤተ፡
                           መንግሥተ፡<persName ref="https://betamasaheft.eu/PRS7102Minas">
                              <roleName type="title"> ሐፄ፡</roleName>  ሚናስ።</persName>
                        </incipit>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="105" to="110">Fols 105–110, </locus>
                     <locus from="117" to="154">117–154</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4635Chronicle">Chronicle of ʾIyoʾas</title>
                     <textLang mainLang="gez"/> 
                     <note>The work is divided into 15 chapters. The last year treated is
                     <date calendar="world">7261</date>, corresponding to
                     <date>1769</date>.</note>
                     <explicit xml:lang="gez">ናሁ፡ ፈጸምነ፡ ታሪከ፡ ዚአሆሙ፡ ለንጉሥነ፡ <persName ref="https://betamasaheft.eu/PRS5617IyasuII">ኢያሱ፡</persName> ወለንጉሥነ፡ 
                        <persName ref="https://betamasaheft.eu/PRS5638Iyoas">ኢዮአስ፡</persName> ወለንግሥትነ፡ <persName ref="https://betamasaheft.eu/PRS2682BerhanM">ወለተ፡ ጊዮርጊስ፡</persName> በረድኤተ፡ እግዚአብሔር፡ አሜን፡ ወአሜን፡ ለይኩን፡
                     ለይኩን።</explicit>
                  </msItem>
                  

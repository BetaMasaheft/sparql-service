      <profileDesc>
         <particDesc>
            <listPerson>
               <person>
                  <p>The name of the commissioner is Wäldä Kiros (see fols. <locus target="#16v #18r #21v #31r"/>); on fol. <locus target="#31r"/>he is referred to as šum kälkǝl, i.e. the governor of Kälkǝl (i.e. Kämkäm, a district in Bägemdǝr, today’s wäräda in South Gondär Zone?).</p>
                  
               </person>
            </listPerson>

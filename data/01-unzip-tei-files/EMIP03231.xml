               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="4r" to="18r" facs="004">Fols 4r–18r</locus><title>Asmat Prayer of Saint John told to him by God, when he tended the tomb of Saint Mary, for Wealth and Against Enemies. interwoven with various Images, e.g., of Saint John, beginning: <foreign xml:lang="gez">ሰላም፡ ለፅንሰትከ፡ ወለልደትከ፡ መአድም፡</foreign></title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i2"><locus from="19r" to="19v" facs="019">Fols 19r–19v</locus><title>Asmat Prayer for Protection</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i3"><locus from="20v" to="31r" facs="021">Fols 20v–31r</locus><title type="complete" ref="https://betamasaheft.eu/LIT3085RepCh365">Hymn to Raguel the
                                                  Archangel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i4"><locus from="31r" to="31v" facs="031">Fols 31r–31v</locus><title>Asmat prayer </title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
                  <msItem xml:id="ms_i5"><locus from="34r" to="33v" facs="034">Fols 34r–33v</locus><title>Asmat prayer of the Cross</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>beginning like John 1:1</note>
                </msItem>
                  <msItem xml:id="ms_i6"><locus from="34r" to="41r" facs="034">Fols 34r–41r</locus><title>Asmat Prayer invoking the image of Raguel</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>

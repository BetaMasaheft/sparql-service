                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#3r" facs="003">Fol. 3r</locus><desc>Photograph of an artwork of <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS7049Michael">Michael</persName>, pasted onto the paper</desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#6v" facs="007">Fol. 6v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#8r" facs="008">Fol. 8r</locus><desc>How the Lord embraced John</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#9v" facs="010">Fol. 9v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS5695John">John</persName>, holding his gospel</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#11r" facs="011">Fol. 11r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> (<persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName>) with <term key="sword" ana="#sword"/> drawn, before the moon</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#12r" facs="012">Fol. 12r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> wth <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> and <persName ref="https://betamasaheft.eu/PRS5695John">John</persName> on either side</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#13r" facs="013">Fol. 13r</locus><desc>Photograph of an artwork of <ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref>, pasted onto the paper</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#13v" facs="014">Fol. 13v</locus><desc>The Transfiguration: Moses, Elijah, on Mount Tabor</desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#14r" facs="014">Fol. 14r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1012Equestrian">Equestrian Saint</ref> spearing a serpent</desc></decoNote>
                    <decoNote type="miniature" xml:id="d10"><locus target="#16r" facs="016">Fol. 16r</locus><desc>A cutting of a printed picture of <ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> surrounded by <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d11"><locus target="#16v" facs="017">Fol. 16v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS10245Yared">Yāred</persName> with prayer stick and sistrum</desc></decoNote>
                    <decoNote type="miniature" xml:id="d12"><locus target="#17r" facs="017">Fol. 17r</locus><desc>Two <term key="angel" ana="#angel"/>s and <ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d13"><locus target="#20r" facs="020">Fol. 20r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d14"><locus target="#22r" facs="022">Fol. 22r</locus><desc>Asmat Talsam Table</desc></decoNote>
                    <decoNote type="miniature" xml:id="d15"><locus target="#23r" facs="023">Fol. 23r</locus><desc>Ouroboros</desc></decoNote>
                    <decoNote type="miniature" xml:id="d16"><locus target="#23v" facs="024">Fol. 23v</locus><desc>An animal and two snakes; the portrait of the animal looks much like the Lamb who takes away the sin of the world</desc></decoNote>
                    <decoNote type="miniature" xml:id="d17"><locus target="#25v" facs="026">Fol. 25v</locus><desc>Talsam Table, magical drawing </desc></decoNote>
                    <decoNote type="miniature" xml:id="d18"><locus target="#26r" facs="026">Fol. 26r</locus><desc>Two serpents, each holding a spear in its mouth</desc></decoNote>
                    <decoNote type="miniature" xml:id="d19"><locus target="#27r" facs="027">Fol. 27r</locus><desc>Four serpents, surrounding a text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d20"><locus target="#29r" facs="029">Fol. 29r</locus><desc>Talsam Table, text</desc></decoNote>
                    <decoNote type="miniature" xml:id="d21"><locus target="#29v" facs="030">Fol. 29v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref> surrounded by Four Living Creatures</desc></decoNote>
                    <decoNote type="miniature" xml:id="d22"><locus target="#30r" facs="030">Fol. 30r</locus><desc>Lamb or God, who Takes Away the Sin of the World</desc></decoNote>
                    <decoNote type="miniature" xml:id="d23"><locus target="#31v" facs="032">Fol. 31v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> with <term key="spear" ana="#spear"/> on the left and another object on the right</desc></decoNote>
                    <decoNote type="miniature" xml:id="d24"><locus target="#32v" facs="033">Fol. 32v</locus><desc>a Four headed bird</desc></decoNote>
                    <decoNote type="miniature" xml:id="d25"><locus target="#35r" facs="035">Fol. 35r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName> with <term key="sword" ana="#sword"/> drawn, above two snakes with <term key="spear" ana="#spear"/>s in their mouths</desc></decoNote>
                    <decoNote type="miniature" xml:id="d26"><locus target="#36r" facs="036">Fol. 36r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1030Trinity">The Trinity</ref> surrounded by Four Living Creatures</desc></decoNote>
                    <decoNote type="miniature" xml:id="d27"><locus target="#37r" facs="037">Fol. 37r</locus><desc>a Four headed bird</desc></decoNote>
                    <decoNote type="miniature" xml:id="d28"><locus target="#38r" facs="038">Fol. 38r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d29"><locus target="#39r" facs="039">Fol. 39r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS8065Raguel">Raguel</persName></desc></decoNote>
                    <decoNote type="miniature" xml:id="d30"><locus target="#40r" facs="040">Fol. 40r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> flanked by two guardian <term key="angel" ana="#angel"/>s</desc></decoNote>
                    <decoNote type="miniature" xml:id="d31"><locus target="#41r" facs="041">Fol. 41r</locus><desc>Bird, standing</desc></decoNote>
                  </decoDesc>
                  <additions>

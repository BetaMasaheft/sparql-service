      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0443</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘመዓድም፡ ዜናሁ፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘፀምረ፡ ጌዴዎን፡ አርአያሁ፨</l>
                  <l n="3">ዳንኤል፡ ያዕቆብ፡ ለእግዚአብሔር፡ ቍልዔሁ፨</l>
                  <l n="4">ባርኮሙ፡ ለደቂቅከ፡ እለ፡ ውስተ፡ እዴከ፡ ናሁ፨</l>
                  <l n="5">ከመ፡ ተባረከ፡ ኤፍሬም፡ እምክቡር፡ አቡሁ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለርእስከ፡ ዘአሰነዮ፡ ምርታዳ፨</l>
                  <l n="2">ወለገጽከ፡ ፍሡሕ፡ አምሳለ፡ ፀሓይ፡ ዘወርኀ፡ መርሙዳ፨</l>
                  <l n="3">ዳንኤል፡ ፍቁሩ፡ ለጊዮርጊስ፡ ኮከበ፡ ልዳ፨</l>
                  <l n="4">ዕቀበነ፡ ለደቂቅከ፡ አመ፡ ዕለተ፡ በቀል፡ ወፍዳ፨</l>
                  <l n="5">ከመ፡ እም፡ ተዐቅብ፡ እምእኩይ፡ ወልዳ፨</l>
               </lg>
               <lg type="stanza" n="25">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በዓፅፈ፡ ሃይማኖት፡ ዘለይ፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ በደብረ፡ ማርያም፡ ዓባይ፨</l>
                  <l n="3">ዳንኤል፡ አቡሁ፡ ለኤዎስጣቴዎስ፡ ኅሩይ፨</l>
                  <l n="4">ለእመ፡ ገብሩ፡ ተዝካረከ፡ እስከነ፡ ኅፍነ፡ ቈሪር፡ ማይ፨</l>
                  <l n="5">አኮኑ፡ በዓለ፡ ጸጋ፡ ይድኅን፡ ነዳይ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">አምኃ፡ ሰላም፡ አቅረብኩ፡ በዘተክህለኒ፡ ፍቅረ፨</l>
                  <l n="2">እምነ፡ ብዝኀ፡ ፍቅርከ፡ ዘኢየኀልቅ፡ ነገረ፨</l>
                  <l n="3">ዳንኤል፡ አቡየ፡ ዘትገብር፡ መንክረ፨</l>
                  <l n="4">አምኃከ፡ ንሣእ፡ እግዚኦ፡ በዘይመጽእ፡ ድኅረ፨</l>
                  <l n="5">ለዛማይ፡ ክረምት፡ ኂሩትከ፡ የሀቡ፡ መዝሙረ፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">ይትባረክ፡ እግዚአብሔር፡ በአፈ፡ ዘሥጋ፨</l>
                  <l n="2">ዘወሀበኒ፡ ቃለ፡ ከመ፡ እወድስከ፡ እንበለ፡ ንትጋ፨</l>
                  <l n="3">ዳንኤል፡ ፍቁሩ፡ ለገብረ፡ ናዝራዊ፡ ምሉአ፡ ጸጋ፨</l>
                  <l n="4">በገዳም፡ ሰላማዊት፡ ዐቃቤ፡ ሥርዓታ፡ ወሕጋ፨</l>
                  <l n="5">ወለረድኤትከ፡ ውስተ፡ ምድርነ፡ ያስተርኢ፡ ፈለጋ፨</l>
               </lg>
            </div>
         </div>
      </body>

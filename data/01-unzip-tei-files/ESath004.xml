               <msContents>
                  <summary>I) Maṣḥafa krǝstǝnnā “Book of the Christening” (fols. 1r-25v)</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="25v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1940Mashaf">Maṣḥafa ṭǝmqat</title>
                     <incipit xml:lang="gez" type="embedded"><locus target="#1r"/>መጽሐፈ፡ ጥምቀት፡</incipit>
                     <note>Called Maṣḥafa ṭǝmqat in the incipit (<locus target="#1r">1r</locus>).</note>
                     
                     <note>Contains an embedded colophon (<locus target="#25v">25v</locus>)
                        which mentions the Coptic, Arabic and Gǝʿǝz languages (but it is unclear,
                        probably corrupted) and possibly the name of the scribe, 
                        <persName role="scribe" ref="https://betamasaheft.eu/PRS12060AsfaKrestos">ʾAṣfa Krǝstos</persName>.</note>
                  </msItem>
                  
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                        </support>
                        <extent>Made of <measure unit="leaf">25.0</measure> folios, in <measure unit="quire">4.0</measure> quires . <dimensions type="outer">
                              <height unit="mm">150</height>
                              <width unit="mm">140</width>
                              <depth unit="mm">20</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>
                              <item xml:id="q1">
                                 <dim unit="leaf">5</dim>
                                 <locus from="1r" to="5v"/>I(5; s.l.: 5, no stub/fols. 1r-5v) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="6r" to="13v"/> II(8/fols. 6r-13v) </item>
                              <item xml:id="q3">

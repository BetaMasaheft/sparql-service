                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">The boards have been made of thin leather
                           or parchment.</decoNote>
                        <decoNote xml:id="b5">None.</decoNote>
                     </binding>
                  </bindingDesc>

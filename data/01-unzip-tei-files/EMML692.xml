               <msContents>
                  <summary>Pp. 1-80: Acts of the Apostles, ግብረ፡ ሐዋርያት።; Pp. 83-259: Pauline Epistles; Pp. 260-296: General Epistles; Pp. 297-335: Revelation, ራዕየ፡ ዮሐንስ።. P. 395: Colophon. Paginated in Ge'ez numbers</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1" to="40">1-80</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT1019Actsof">Gǝbra ḥawāryāt</title>
                     <note>The text is divided according to both the traditional and the modern chapters. The verses are indicated in the margin.</note>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="42r" to="130r">83-259</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3505PaulineEpis">Pauline Epistles</title>
                     <note>The text is divided according to both the traditional and the modern chapters. The verses are indicated in the margin.</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="130v" to="148v">260-296</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3506CatholicEpis">Catholic Epistles</title>
                     <note>The text is divided according to both the traditional and the modern chapters. The verses are indicated in the margin.</note>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="149r" to="168r">297-335</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT3179Revela">Revelation of John</title>
                     <note>The text is divided according to both the traditional and the modern chapters. The verses are indicated in the margin.</note>
                     <colophon xml:id="coloph1">
                        <locus target="#168r">pp. 168r</locus>
                        <date calendar="ethiopian" when-custom="1957" notBefore="1964" notAfter="1965">1957 EC</date>
                     </colophon>
                  </msItem>
               </msContents>

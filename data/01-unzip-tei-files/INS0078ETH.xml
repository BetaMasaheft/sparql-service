         <listPlace>
            <t:place type="church monastery gatar" subtype="institution">

               <t:placeName xml:id="n1" xml:lang="gez">እምበይቶ፡ተክለ፡ ሃይማኖት፡</t:placeName>
               <t:placeName corresp="#n1" xml:lang="gez" type="normalized">ʿƎmbayto Takla Hāymānot</t:placeName>
               <t:placeName type="alt" xml:lang="gez" xml:id="n2">ተክለ፡ ሃይማኖት፡ እምበይቶ፡</t:placeName>
               <t:placeName type="normalized" xml:lang="gez" corresp="#n2">Takla Hāymānot ʿƎmbayto</t:placeName>



               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>

               <t:settlement type="warada" when="2011-11-19" ref="https://betamasaheft.eu/LOC3640GuloMa">Gulo Maḵadā</t:settlement>

               <t:settlement when="2011-11-19" type="tabiya" ref="https://betamasaheft.eu/LOC6547Haban">Ḥaban</t:settlement>

               <t:settlement when="2011-11-19" type="qushat" ref="https://betamasaheft.eu/LOC7156Embayto">ʿƎmbayto</t:settlement>

               <t:location>
                  <t:geo>14.396753 39.457975</t:geo>
                  <t:height unit="m">2248.0</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1800" notAfter="1900">1800-1900</t:date>
                  <t:desc type="foundation">Founder: "Goytana Ḫaylu" (<t:persName ref="https://betamasaheft.eu/PRS5252hayluTa">Ḫaylu Tawalda Madḫǝn</t:persName> of Ḥāmāsen?).
                     According to the local tradition, it was founded by “goytana Ḫaylu” (<t:persName ref="https://betamasaheft.eu/PRS5252hayluTa">Ḫaylu Tawaldä Mädḫǝn</t:persName> of <t:placeName ref="https://betamasaheft.eu/LOC3764Hamase">Ḥāmāsen</t:placeName>?) in the time of <t:persName ref="https://betamasaheft.eu/PRS9434Tewodros">Tewodros II</t:persName> (r. <t:date>1855-1869</t:date>).
                     As a rare case, the ʾalaqā of the church knew the tradition about the history of the church, and also the genealogy of “goytana Ḫaylu”.</t:desc>
                  <t:ab type="history">Gaṭar. 
                     An old teacher of qǝne, aqqʷāqʷām and zemā lived at the church for the time of the visit.
                     According to his own words, he is the native of this place, studied many years in Gondar (<t:placeName ref="https://betamasaheft.eu/LOC1676Baata">Baʾatā church</t:placeName>), and then returned to ʿƎmbayto.
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/ETH.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>
                     12 Mss. were photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth001">ETH-001</t:ref> "Miracles of Jesus"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth002">ETH-002</t:ref> "The Book of the Funeral Rite"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth003">ETH-003</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth004">ETH-004</t:ref> "Vita of Täklä Haymanot"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth005">ETH-005</t:ref> "Homily of St. Gabriel"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth006">ETH-006</t:ref> "The Book of the Chants"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth007">ETH-007</t:ref> "Vita of Täklä Haymanot"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth008">ETH-008</t:ref> "Homily of St. Michael"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth009">ETH-009</t:ref> "Homily of the Sabbath"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth010">ETH-010</t:ref> "Missal"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth011">ETH-011</t:ref> "Four Gospels"; <t:ref type="mss" corresp="https://betamasaheft.eu/ESeth012">ETH-012</t:ref> "The Book of the Baptismal Rite"</t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="3"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10775Trinity">Trinity</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</t:persName>.
                     <t:note>The church is said to have been linked to another church of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10322Yemata">ʾabuna Yǝmʾātā</t:persName>, located somewhere around. </t:note></t:ab>
               </t:note>
            </t:place>
         </listPlace>

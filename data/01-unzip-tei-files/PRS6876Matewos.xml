         <listPerson>
            <person sex="1" sameAs="wd:Q63356526">
               <persName xml:lang="gez" xml:id="n1" type="birth">ማቴዎስ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">Mātewos X</persName>
               <persName>
                  <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾabuna</t:roleName>
               </persName>
               <occupation type="ecclesiastic">metropolitan</occupation>
               <nationality type="Egypt"/>
               <faith type="Coptic"/>
               <birth when="1843"/>

               <floruit when="1889">He was the metropolitan of the Ethiopian Orthodox Church,
                  consecrated by <persName ref="https://betamasaheft.eu/PRS3258CyrilIV">Cyril IV</persName>
                  in <date>1889</date>. He arrived to Ethiopia in <date>1881</date>
                  together with the three other bishops: <persName ref="https://betamasaheft.eu/PRS13100Marqos">Mātewos</persName>,
                  <persName ref="https://betamasaheft.eu/PRS6404Luqas">Luqās</persName> and <persName ref="https://betamasaheft.eu/PRS7830Petros">Ṗeṭros IV</persName> requested by
                  Emperor <persName ref="https://betamasaheft.eu/PRS10378Yohanne">Yoḥannǝs IV</persName>.
                  He was a bishop of <placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</placeName> from <date>1881</date>
                  to <date>1889</date>. Following the death of  Emperor <persName ref="https://betamasaheft.eu/PRS10378Yohanne">Yoḥannǝs IV</persName> in <date>1889</date>,
                  when <persName ref="https://betamasaheft.eu/PRS7006Menilek">Mǝnilǝk II</persName> became Emperor he received permission from Coptic patriarch
                  <persName ref="https://betamasaheft.eu/PRS3258CyrilIV">Cyril IV</persName> and he replaced  ʾabuna <persName ref="https://betamasaheft.eu/PRS7830Petros">Ṗeṭros IV</persName>as a metropolitan.
               </floruit>
               <death> He died on <date> 20 October 1926</date>.
               </death>
            </person>
            
         </listPerson>

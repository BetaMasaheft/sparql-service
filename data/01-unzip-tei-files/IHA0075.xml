               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="5r" to="179v">5r-179v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0020IHA#s5IHA">منهاج الطالبين, From the beginning of kitāb
                    al-waṣāyā to kitāb ummahāt al-awlād (second half) 2/2</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>كتاب الوصايا يا نصح وصية مكلفٍ حرٍ وان كان كافرا او كذا محجور عليه لسفه على المذهب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#179v">-179v</locus>لا يعتقون يموت السيد وله بيعهم وعتق المستولدة من راس المال والله اعلم وبالله التوفيق الحمد لله رب العالمين</explicit>
                     <note>Some of the words are divided into two different lines</note>
                     <note/>
                  </msItem>
               </msContents>

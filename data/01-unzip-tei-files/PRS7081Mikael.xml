      <t:body>
         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሚካኤል፡ አረጋዊ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Mikāʾel ʾAragāwi</t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="Christianity"/>
               <t:occupation type="ecclesiastic">missionary</t:occupation>
               <t:birth notBefore="1848" notAfter="1849">He was born at 
                  <t:placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</t:placeName>.</t:birth>
                  
               <t:floruit notBefore="1850" notAfter="1931">He was a prominent Ethiopian missionary who worked among the 
                  <t:persName ref="https://betamasaheft.eu/ETH1274Betaes">Beta ʾƎsrāʾel</t:persName> 
                  during the second half of  the 19th century and the beginning of the 20th century as representative 
                  of the London society for promoting Christianity among the Jews. 
                  His father gave him at the age of seven to <t:persName ref="https://betamasaheft.eu/PRS4132Flad">Flad</t:persName> to raise him.
                  Then, <t:persName ref="https://betamasaheft.eu/PRS4132Flad">Flad</t:persName> sent him to an orphanage in <t:placeName ref="https://www.wikidata.org/entity/Q183">Germany </t:placeName> in <t:date>1866</t:date>. 
                  After he completed his education in <t:date>1873</t:date>, he returned to <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> as a missionary, where he served until his death. </t:floruit>
                  
                  <t:death when="1931"/>
               </t:person>
               
         </t:listPerson>
         
         

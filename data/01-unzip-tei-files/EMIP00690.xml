                            <msItem xml:id="ms_i1.6.1">
                              <title>Hymn for the Feast Dat of the Assumption</title>
                              <incipit xml:lang="gez">
                                አመ፡ ፲ወ፯፡ ዋዜማ፡ ዘፍልሰታ፡ ማርያም፡
                              </incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.6.2">
                              <locus from="171r" facs="175">Fols 171r and following</locus>
                              <title type="complete" ref="https://betamasaheft.eu/LIT4420Winter1">Wāzemā
                                                  za-kǝramt</title>
                              <incipit xml:lang="gez">
                                ዋዜማ፡ ዘዝውተር፡ በ፮አውሥአ፡ ኢየሱስ፡<gap reason="omitted"/> ወይቤሎሙ፡ ናሁ፡ ወጽአ፡ ይዝራዕ፡
                              </incipit>
                            </msItem>
                        </msItem>


                        <title>Magical prayers</title>
                        <msItem xml:id="p2_i2.1">
                           <locus from="75v"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT4507Prayer">Prayer of Manasseh</title>
                           <incipit xml:lang="gez">
                              ዝንቱ፡ አስማተ፡ ሞቅሕ፡ ዘነገረ፡ እግዚአብሔር፡ ለምናሴ፡ ገብሩ፡ ሶበ፡ ነስሐ፡ ወተመይጠ፡ ኀበ፡ እግዚአብሔር።
                           </incipit>
                           <explicit xml:lang="gez">
                              ወአሐዘ፡ ይትፈታሕ፡ ወከማሁ፡ ፍትሖ፡ ለነፍሰ፡ 
                                 <sic>ገብረከ፡</sic>
                               እገሌ፡
                           </explicit>
                        </msItem>
                        <msItem xml:id="p2_i2.2">

                  <additions>
                     <t:list xmlns:t="http://www.tei-c.org/ns/1.0">
                        <item xml:id="a5_863">
                           <locus target="#169v">-169v</locus>
                           <q xml:lang="ar">Short prayers and pen trials</q>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a2_863">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Ǧuz' markers: concentric circles in red and black, details vary. Ṯumn markers.</q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a3_863">
                           <locus target="#Throughout">-Throughout</locus>
                           <q xml:lang="ar">Verse markers (dots/three dots), and titles of the sūras in red. </q>
                           <desc>Drawings / Decorations</desc>
                           <note/>
                        </item>
                        <item xml:id="a4_863">
                           <locus target="#169r-169v">-169r-169v</locus>
                           <q xml:lang="ar">ولصدورنا [.؟.] وكفارة لذنوبنا ما خفى منها وما بدا اللهم ارزقنا به [.؟.] وانلنا به منالة الشهدا واجعلنا ممن اهتديه [...] النبيين وعلى اله وصحبه اجمعين سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين تمت</q>
                           <note>Acephalous fragment of an unidentified duʿā' ḫatm al-Qurān. The folio is partly torn.</note>
                           <note>
                              <term key="Devotional" ana="#Devotional"/>
                           </note>
                        </item>
                        <item xml:id="a1_863">
                           <locus target="#Throghout">-Throghout</locus>
                           <q xml:lang="ar">قرا ابن عامر وكل برفع اللام بالالف</q>
                           <desc>Marginalia</desc>
                           <note>Variants of other Qur'anic readings. Example on fol. 36r</note>
                           <note>
                              <term key="Koran" ana="#Koran"/>
                           </note>
                        </item>
                        <item xml:id="a0_863">
                           <locus target="#Throughout">-Throughout</locus>
                           <desc>Marginalia</desc>
                           <note>in the margins. </note>
                           <note>
                              <term key="Koran" ana="#Koran"/>
                           </note>
                        </item>
                     </t:list>

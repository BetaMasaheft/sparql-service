               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="169v">1r-169v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT0049IHA">قران</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>نَادِيَه

سَنَدْعُ الزَّبَانِيَةَ

كَلاَّ لا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبْ<note>Verse 96:17</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#168v">-168v</locus>فمن كان يرجوا لقا ربه فليعمل عملا صالحا ولا يشرك بعبادة ربه احدا<note>Verse 18:110</note>
                     </explicit>
                     <note>Fragments from different Qur'ān manuscripts bound together. Some of the folios bound in wrong order and upside down.</note>
                     <note/>
                  </msItem>
               </msContents>

                        <msItem xml:id="ms_i1">
                            <locus from="3v"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne ʿālam</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘኢረከቡ፡ ተፍጻሜተ፡ <choice><sic resp="PRS10171Wright">መላእተ፡</sic> <corr resp="DR">መላእክተ፡</corr></choice> ሰማይ፡ ወምድር፡ እለ፡ ለመዱ፡ ስብሐተ፡ መድኃኔ፡ ዓለም፡</incipit>
                        </msItem>


                            <colophon xml:id="coloph1" xml:lang="gez">
                                <locus target="#140r"/>
                                ዝመጽሐፍ፡ ዘ<persName role="owner" ref="https://betamasaheft.eu/PRS5205haylaMa"><roleName type="title">እራስ፡</roleName> ኃይለ፡ መለኮት፡</persName>
                                ንጉሠ፡ ኢትዮጵያ፡ ወጸሐፊሁ፡ <persName role="scribe" ref="https://betamasaheft.eu/PRS12907NahuS">ናሁ፡ ሠናይ፡ ወልደ፡ አብ።</persName>
                            </colophon>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="140r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">Malkǝʾa ʾAbuna Takla Hāymānot</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለጽንሰትከ፡ ወለልደትከ፡ እምከርሥ፡ አመ፡ ፳ወረቡዑ፡ ለወርኃ፡ ታኅሣሥ፡ ተክለ፡ ሃይማኖት፡ በኵሉ፡ ወበውስተ፡ ኵሉ፡ ውዱስ።</incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="145r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2740RepCh24">Malkǝʾ-hymn to Jesus Christ</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><choice resp="DR"><sic>ሰላ፡</sic><corr>ሰላም፡</corr></choice> ለሐውቌ፡ ኀይለ፡ አርያም፡ ዘቀነተ። ወለአቍያጺከ፡ ፪ቱ። ሶበ፡ ታወጽእ፡ ነፍሳተ። እግዚአብሔር፡ መሓሪ፡ መድኃኔ፡ ዓለም፡ አንተ። 
                            ጊዜ፡ ሑረትየ፡ ምርሐኒ፡ ፍኖተ።</incipit>
                        </msItem>

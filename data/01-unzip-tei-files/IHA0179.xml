               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="3r">2r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0539IHA">رسالة في علم الحروف ورقى</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>باب حساب المريض فاحسب اسمه واسم امه واسم اليوم الذى \ سألك فألف ثمانية فإن بقى واحد فمرضه من سحر الأشجار \ والأوتار وايامه الثلاثة وشفاءه غنم احمر أو كبش اسود</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>باب للكلب المجنون اذا مس الإنسان تكتب \ وتشرب ثلاثة ايام يتعافا بإذن الله تعالى بسم الله الرحمان \ الرحيم يرح ه و ه ع ع ع ه ه ه هرهرهرولاحول ولا قوة \ الا بالله العظيم وصلى الله على سيدنا محمد وأله وصحبه وسلام
</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

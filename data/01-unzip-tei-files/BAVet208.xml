                      <msItem xml:id="ms_i1">
                        <locus from="3r" to="23r" facs="0007"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">Lǝssāna sabʾ</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="ellipsis" extent="unknown" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ልሳነ፡ ሰብእ፡ ልሳነ፡ ምቀኛ፡ ወተን<choice><sic>ኮ</sic><corr>ኰ</corr></choice>ለኛ፡ ልሳነ፡ እስላም፡ ወክርስቲያን።</incipit>
                        <explicit xml:lang="gez">ወኢትትርፍከ፡ አሐቲ፡ በዕለተ፡ ኵነኔ፡ መሐራ፡ ለነፍስየ፡ ዛቲ፨ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡ ወአድኅነኒ፡ እምልሳነ፡ ዘመድ፡ ወባዕድ<supplied reason="omitted">፡</supplied> ወእምልሳነ፡ ኵሉ፡ ፍጥረት፡ ለገብርከ፡ ወልደ፡ ሥላሴ፡ ግዛው፡</explicit>
                      </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="24r" to="26r" facs="0049"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT5690MagicPrayer">Ṣalot baʾǝnta ḥǝmāma ʿaynat</title>
                        <textLang mainLang="gez"/>
                        <explicit xml:lang="gez">ወአውእይዋ፡ በእሳት፡ ወዝርውዋ፡ በነፋስ፡ ምሥራቀ፡ ወምዕራበ፡ ሰሜነ፡ ወደቡበ፡ ከመ፡ ይጥፋዕ፡ ዝክረ፡ ስሙ፡ ለዓይነት፡ ወለዓይነ፡ ወርቅ፡ እምላዕለ፡ ገብረ፡ እግዚአብሔር፡ ወልደ፡ ሥላሴ።</explicit>
                      </msItem>


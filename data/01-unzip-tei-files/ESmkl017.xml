                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre, irregular.</seg>
                        <seg type="ink">Black, red.</seg>
                        <date>18th century</date>
                        <list type="abbreviations">
                           <item>ይዲ፡ for ይቤ፡ ዲያቆን፡</item>
                           <item>ይካ፡ for ይቤ፡ ካህን፡</item>
                           <item>እ፡ for እማሬ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the donors; initial lines or
                           words of readings in Text I; directives to the ministers and their
                           abbreviations in Text I; word “ǝmare” and its abbreviation in fols. 9v;
                           incipit of Text II-1); incipit of the subsections of Text II-2); elements
                           of the punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">The handwriting is characterized by
                        thick strokes, pronounced hairlines, bifurcated
                        serifs.</handNote>
                  </handDesc>

                  <additions>
                     <list>
                        <item xml:id="a1">
                           <desc type="Letter">Amharic note at the beginning of the volume</desc>
                           <q xml:lang="am">  
                              
                              <lb n="1"/> ጦማር፡ ዘራስ፡ <persName ref="https://betamasaheft.eu/PRS8346sahlase">ሣህለ፡ ሥላሴ፡</persName>
                              ንጉሠ፡ <placeName ref="https://betamasaheft.eu/LOC5597Sawa">ሸዋ፡</placeName> ወርቱዓ፡ ሃይማኖት፡ 
             ወመፍቀሬ፡ ምጽዋት፡ ታልነበርንበት፡ ጨለማ፡ ወዳለንበት፡ ብርሃን።
                              <lb n="2"/>  ባስገኘን፡ በእግዚአብሔር፡ ኃይል፡ ትብጻሕ፡ ኀበ፡ <persName ref="https://betamasaheft.eu/PRS6364LouisPh">Louis Philippe I<hi rend="rubric">ሊዊ፡ ፊሊብ።</hi></persName>
                              ሃይማኖቱ፡ እቀና፡ ክርስትናውእጠና። ጋሻው፡ እበረደደ።
               <lb n="3"/>መንግሥቱ፡ እስተወደደ።
               <lb n="4"/> በፈቃደ፡ እግዚአብሔር፡ እተቀመጠ፡ ከብዙ፡ ነገሥታት፡ እበለጠ። ከብቱ፡ እንዳሻዋ፡
               <lb n="5"/> እማይሰፈር።
               <lb n="6"/> አሽከሩ፡ እንደኮከብ፡ እማይቆጠር።
                              <lb n="7"/>  ወደ<persName ref="https://betamasaheft.eu/PRS6364LouisPh">Louis Philippe I<hi rend="rubric">ሊዊ፡ ፊሊብ፡</hi></persName>
                              <lb n="8"/>  እሥልጣነ፡ <placeName ref="https://www.wikidata.org/entity/Q142">ፈረንሲስ፡</placeName> ዘንድ።
               <lb n="9"/>   ይህቺ፡ ዳዊት፡ ትድረስ።</q>
                        </item>
         
                        <item xml:id="a2">
                           <desc type="Unclear">Note in which the king <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</persName> complains about the British.  </desc>
                           <q xml:lang="am">ሃይማኖትህ፡ ሃይማኖቴ፡ ነው፡ አገርህ፡ አገሬ፡ ነው።
                              አገሬ፡ አገርህ፡ ነውና፡ እንግሊሶች፡ ወዳገሬ፡ 
                              <supplied reason="explanation" resp="PRS10747Zotenbe">ወደ፡ አገሬ፡</supplied> 
                              መንጣት፡ አስበዋልአሉና፡ አንተ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                           </q>
                        </item>
         
                        <item xml:id="a3">
                           <desc type="Unclear">  The name of <persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</persName> has been substituted for the name of the previous owner,
             <persName ref="https://betamasaheft.eu/PRS10813WalattaH">Wälättä Ḥǝywät</persName> at the end of the volume.  </desc>
                        </item>
         
                        <item xml:id="a4">
                           <desc type="Unclear">A prayer to Mary for healing of some illnesses has been added later at the end of the volume.</desc>
                        </item>
                     </list>

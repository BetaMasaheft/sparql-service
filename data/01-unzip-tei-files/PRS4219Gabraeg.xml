         <t:listPerson>
            <t:person sex="1">
               
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ገብረ፡ እግዚአብሔር፡ ኤልያስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gabra ʾƎgziʾabǝḥer ʾElyās</t:persName>
               
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               <t:occupation type="literary">artist</t:occupation>
               
               <t:birth when="1892">He was born at <t:placeName ref="https://betamasaheft.eu/LOC2976Entott">Ǝnṭoṭṭo</t:placeName> in<t:date>1892</t:date>.</t:birth>
               
               
               
               <t:floruit notBefore="1912" notAfter="1969">He was a painter, poet, polemicist and historian. 
                  He received a traditional church education at the age of five in <t:placeName ref="https://betamasaheft.eu/LOC2981Entott">Ǝnṭoṭṭo Raguʾel</t:placeName>.
                  After he attended traditional eduaction in various churches,
                  he became a teacher of qǝne. 
                  Then, he worked as assistant head in the customs and later as a caligrapher and illustrator at the Ministry of Pen. 
                
                  He was also a court historian writing the royal chronicle for the period <t:date>1908-1934</t:date>
                  covering the reigns of
                 
                  <t:persName ref="https://betamasaheft.eu/PRS5620IyasuV"> 
                     <t:roleName type="title">lǝg</t:roleName> 
                  </t:persName> and <t:persName ref="https://betamasaheft.eu/PRS10671Zawditu">Zawditu</t:persName>. 
                 
               </t:floruit>
               <t:death when="1969">He died at <t:placeName ref="https://betamasaheft.eu/LOC4977Nazare">Nazareth</t:placeName> in <t:date>1969</t:date>. </t:death>
               
               
            </t:person>
            
         </t:listPerson>
         
         
         

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1922IHA">نظم فكيف كنت يا سيد الوراك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>اللهم صل على محمد اللهم صل على محمد اللهم صل على محمد. فكيف كنت يا سيد الوراك</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#1r">-1r</locus>يا الله عليكم انظرو إلين| يا قمر مكه</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="6r">1v-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1923IHA">نظم صفة الخلق من المرسلين</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>صفة الخلق من المرسلين| نور كل العلم نجماسعودنا سيد الانبيا سماى سعود</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>بعد دا الأشياء دائما الأنصر ام | ما هام المحب ساعت ابا لمدام ابي خير أهل الخزم والجود.
قد تم</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="6v" to="7v">6v-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1924IHA">نظم بدأت بسم الله الرحمن الرحيم</title>
                     <incipit xml:lang="ar">
                        <locus target="#6v">-6v</locus>صلى الله عليك محمد إمام لواءنا فى يوم القيام| بدئت بسم الله الرحمن الرحيم| مدح سيدنا مصطفى الأتام| ثم صلاة الله وكذ السلام</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7v">-7v</locus>احسن ختامنا يا رب الأنام| بحرمه زين أبا القاسم| تمت يد محمد ن[و]ر</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="7v" to="8v">7v-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1925IHA">نظم حمد لله ذا الجلال</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v">-7v</locus>يا رب يصل على شمس دار طيبة يا رب يصل على نور دار طيبة [...]
حمد لله ذا الجلال شكر الله المتعال الهاد من الضلال وبأفضل ملة الصلاة الاسلام يني خير الأنام </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus>وختم لنا يا رحيم بجاه نبي لكريم ونورى لقديم بحسن لخاتمة أدركانى يا سيد بالله خذ بيد أسقخاي يا سيد من بحر لمودة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="8v" to="13v">8v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1324IHA">نظم الحمد لله الكريم الجواد</title>
                     <incipit xml:lang="ar">
                        <locus target="#8v">-8v</locus>اللهم صل على محمد سر العالم وسر لوجود.
الحمد لله لكريم الجواد| حمدا دئما بغير نفاد| حيث فضلنا بنبي لهاد| أ صلاة وسلام عليه أبد وعلى أله وصحب اسجد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>ما قال المداح بأنواع الأحوال فى مدح سيدي مصطفى لو جود تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="14r" to="16r">14r-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1466IHA">نظم تجلى بدر الصفاء من أفاق طيبة</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>صل الله عليك يا مصطفى ذ خيرة وسلم عليك يا غوث يوم الشدة.
تجل بدر لصفا من أفاق طيبة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>ألف صلاة لمتين على مصطفى لأمين وأكى تحية| وألبه لطاهرين وصحبه لأحرمين نجوم لهدية. تمت
سنة ١٣٨٩</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="17r" to="19r">17r-19r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1928IHA">نظم لما عوقتنى حبال الجفوة</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>اللهم صلى على  محمد ريحان طيبة شمس الحقيقة.
لما عوقتنى حبال لجفوة |عن السير إلى ذاك الحضرات</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17r">-17r</locus>يا نور ظهر قبل قبل الذره | طيفه أنار قلوب السدات</explicit>
                     <note>Upside down</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="19v" to="23v">19v-23v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1089IHA">نظم طلعت انوار من نواحى الغيب فاشرقت</title>
                     <incipit xml:lang="ar">
                        <locus target="#23v">-23v</locus>اللهم صل على محمد امامحرم شفيع درك طلعت أنوار من نحى الغيب فأشرقت بها سموات القلب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19v">-19v</locus>أنتم يا سيدء ترياق فؤد وغاية مرادى وعين مردى عزى ومرامى منتهى أمل [ملابر ء] مغبثى مرهم عللى</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

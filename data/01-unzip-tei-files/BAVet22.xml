               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="5r" to="22v"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4065Prayer">Prayer of thanksgiving for the offering of the incense</title>
                     <listBibl type="text">
                        <bibl corresp="http://zotero.org/groups/358366/items/8UWD3FCM"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Petrus1548Test"/><title level="m">Testamentum Novum: Cum Epistola Pauli Ad Hebreos tantum, cum concordantijs Evangelistarum Eusebii &amp; numeratione omnium verborum eorundem. Missale cum benedictione incensi cerae et c. Alphabetum in lingua ግእዝ፡ gheez, idest libera quia a nulla alia originem duxit, &amp; vulgo dicitur Chaldea, Quae omnia Fr. Petrus Ethyops auxilio piorum sedente Paulo. III. Pont. MAx. &amp; Claudio illius regni Imperatore imprimi curavit</title><author><t:name xmlns:t="http://www.tei-c.org/ns/1.0">Petrus Ethyops</t:name></author><pubPlace>Romae</pubPlace><publisher>Impensis Petri Comos Ethiopis, Valerius Doricus</publisher><date>1548</date><note type="url">https://books.google.de/books?id=KPNa9Mc5gjYC</note><citedRange>174 col. 1 l. 9 - f. 176v col. 2 l. 13</citedRange></bibl>
                     </listBibl>
                     <incipit xml:lang="gez">
                        በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/> ወሶበ፡ ተዐጥን፡ ዕጣነ፡ በቤተ፡ ክርስቲያን፡ ከመዝ፡ ትብል፨ 
                        ሃሌ፡ ሉያ፡ ለአብ፡ ሃሌ፡ ሉያ፡ ለወልድ። ሃሌ፡ ሉያ፡ ለመንፈስ፡ ቅዱስ፡ ሠለስተ፡ ጊዜ፡ ትብል፡ ከመዝ፡ ወእምዝ፡ ያዐርግ፡ ዕጣነ፡ ቀሲስ፡ 
                        እንዘ፡ ይብል፡ ተወከፍ፡ እምኔየ፡ እግዚኦ፡ አነ፡ ኃጥእ፡ ወአባሲ፡ ዘንተ፡ ንጹሐ፡ ዕጣነ፡ ለስርየተ፡ ኀጢአትየ፡ ወለኵሉ፡ ሕዝብከ፡ አሜን፨
                     </incipit>
                     <explicit xml:lang="gez">
                        
                           <sic>እኵት፡</sic>
                         ወስቡሕ፡ 
                           <sic>ስመከ፡</sic>
                         እግዚኦ፨ በኢያኤድ፡ 
                           <sic>ስመከ፡</sic>
                         
                        ዘእምቅድመ፡ ዓለም፨ ተዳኤል፡ 
                           <sic>ስመከ፡</sic>
                         ዘኢይትመዋእ፡ ለፀር። ሴቃ፡ ወፄቃ፡ 
                           <sic>ስመከ፡</sic>
                         ወበአማኑኤል፡ 
                        
                           <sic>ስመከ፡</sic>
                         ተማሕፀንኩ፡ አነ፡ ገበርከ፡ እምይእዜ፡ ወእስከ፡ ለዓለመ፡ ዓለም፡ አሜን፨
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i2">
                     <locus from="22v" to="32r"/>
                     <title type="complete" ref="https://betamasaheft.eu/LIT4263Prayer">Prayers for the night</title>
                     <incipit xml:lang="gez">
                        ጸሎተ፡ ሌሊት፡ ናስተበቍዕ፡ ዘኵሎ፡ ይእኅዝ፡ እግዚአብሔር፡ አብ፡ ለእግዚእ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፨ እንዘ፡ ናአኵቶ፡ በኵሉ፡ ውስተ፡ ኵሉ፨ እስመ፡ ከደነነ፡ ወረድአነ፡ ወሶቀነ፡ 
                        ወ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="omitted">አ</t:supplied>ብጽሐነ፡ እስከ፡ ዛቲ፡ ሰዕት፨
                     </incipit>
                     <explicit xml:lang="gez">
                        
                           <sic>አብዳን፡</sic>
                         ወአጥብብ፡ 
                           <sic>ወሕጉላን፡</sic>
                         ሚጥ፡ እለ፡ ውስተ፡ ሞቅሕ፡ አድኅን፡ ወለኵልነ፡ ኩን፡ ጸወን፨ እስመ፡ ለከ፡ 
                        እግዚኦ፡ አምላክነ፡ መንግሥት፡ ቡሩክ፨ 
                     </explicit>
                  </msItem>
                  
                  <msItem xml:id="ms_i3">
                     <locus from="32r" to="60v"/>
                     <title>Litanies for the morning</title>
                     <msItem xml:id="ms_i3.1">
                        <locus from="32r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1807Litonz">ጸሎተ፡ ነግህ፡</title>
                        <note>The litany is followed by <ref type="work" corresp="https://betamasaheft.eu/LIT4711Mastabqwe">Mastabqʷǝʿān</ref>.</note>
                       <explicit xml:lang="gez">
                           ወተናገር፡ ውስተ፡ ልቡ፡ በእንተ፡ ቅድስት፡ ቤተ፡ ክርስቲያንከ፡ ፍጡነ፡ ይርከበነ፡ ሣህልከ፡ እግዚኦ፨ ን፡ ሀቦ፡ ዘእነበለ፡ ስሕተት፡ ይዕቀብ፡ 
                              <sic>ልቦና፡</sic>
                            ዘበእንተ፡ 
                           ሃይማኖት፡ ውስተ፡ ሠናይ፡ አምልኮትከ፡ በ፩ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.2">
                        <locus from="39r"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT4859Litany">ጸሎተ፡ ነግህ፡</title> 
                        <note>Conclusion of the <ref type="work" corresp="https://betamasaheft.eu/LIT1807Litonz">preceding litany</ref>.</note>
                        
                        <incipit xml:lang="gez">
                           ወካዕበ፡ ናስተበቍዖ፡ ለአምላከ፡ ምሕረት፡ ዘረዳእኮ፡ ለአብርሃም፡ አመ፡ ይቀትሎሙ፡ ለነገሥት፡ ዘአድኀንኮ፡ ለይስሐቅ፡ በውስተ፡ 
                              <sic>መጥበኅት፨</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ወፈኑ፡ 
                              <sic>ውእተ፡</sic>
                            
                           
                              <sic>መንፈስከ፡</sic>
                            
                           
                              <sic>ቅዱስ፡</sic>
                            ዐማዴ፡ ሰማይ፡ 
                           ወምድር፨ 
                              <sic>ባርከ፡</sic>
                            
                           
                              <sic>ማኅበርነ፡</sic>
                            በኵሉ፡ 
                              <sic>ጌዜ፡</sic>
                            ወበኵሉ፡ 
                           ሰዐት፨ በ፩፡ ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.3">
                        <locus from="40v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4265Litonz">ጸሎተ፡ ነግህ፡</title>
                        <incipit xml:lang="gez">
                           ቀዳሜ፡ ጸጋ፡ ኢየሱስ፡ ክርስቶስ፡ ኀይሉ፡ ወጥበቡ፡ ለአቡሁ፨ እስመ፡ አንተ፡ ውእቱ፡ በግዑ፡ ለእግዚአብሔር፡ ዘያአትት፡ ኀጢአተ፡ ዓለም፨
                        </incipit>
                        <explicit xml:lang="gez">
                           ተስፋሆሙ፡ ለቅቡፃን፡ 
                              <sic>መንሥኤሆሙ፡</sic>
                            ለምዉታን፡ ኢየሱስ፡ ክርስቶስ፡ ኀይሉ፡ ወጥበቡ፡ ለአቡሁ፡ ኪያከ፡ ናአኵት፡ ይእዜኒ፡ ወዘልፈኒ፡ ወለዓለመ፡ ዓለም፡ አሜን፨
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.4">
                        <locus from="41v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4266Litonz">ሊጦን፡ ዘነግህ፡</title>
                        <incipit xml:lang="gez">
                           ለትሩጽ፡ እግዚኦ፡ 
                              <sic>ምሕረተከ፡</sic>
                            ላዕሌነ፡ ወብርሃነ፡ ገጽከ፡ ላዕለ፡ ነፍስነ፡ 
                              <sic>ይምጸእ፡</sic>
                            ምሕረትከ፡ ዘያሐይወነ፡ 
                           ወያስተርኢ፡ ኂሩትከ፡ ዘያስተፌሥሐነ፡ 
                        </incipit>
                        <explicit xml:lang="gez">
                           ወመኑ፡ አምላክ፡ ዐቢይ፡ ወቅዱስ፡ ዘከማከ፡ 
                              <sic>ተሠሀለነ፡</sic>
                            በከመ፡ ዕበየ፡ ሣህልከ፡ ወበከመ፡ ብዝኀ፡ ምሕረትከ፡ ደምስስ፡ 
                              <sic>አበሰነ፨</sic>
                           
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.5">
                        <locus from="42v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4264Salota">ሊጦን፡ ዘነግህ፡</title>
                        <incipit xml:lang="gez">
                           ከመ፡ ታድኅነነ፡ እግዚኦ፡ እምዕለት፡ እኪት፡ ወእምሰዐታተ፡ መንሱት፡ ወእምኵሉ፡ ዘእኩያን፡ 
                              <sic>ትመየተ፡</sic>
                           
                        </incipit>
                        <explicit xml:lang="gez">
                           ርድአነ፡ ንትቀነይ፡ ለከ፡ ዘእንበለ፡ ሀኬት፡ 
                              <sic>ወድከም፡</sic>
                            ወትረ፡ በኵሉ፡ ጊዜ፡ ወበኵሉ፡ ሰዓት፡ በአሐዱ፡ ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.6">
                        <locus from="44r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4267Prayer">Prayers for the sleepers</title>
                        
                        <incipit xml:lang="gez">
                           በእንተ፡ እለ፡ ኖሙ፡ 
                              <sic>ወከዕበ፡</sic>
                            ናስተበቍዕ፡ ዘኵሎ፡ ይእኅዝ፡ እግዚአብሔር፡ አብ፡ ለእግዚእ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ። እግዚኣ፡ ሕያዋን፡ ሕይወተ፡ 
                           ምዉታን፡ ተስፋ፡ ቅቡፃን፡ ወረዳኤ፡ ምንዱባን፡
                        </incipit>
                        <explicit xml:lang="gez">
                           ናዝዞሙ፡ ወአስተፈሥሖሙ፡ በክርስቶስ፡ በ፩ወልድከ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.7">
                        <locus from="46r" to="47v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2605Zayena">Za-yǝnaggǝs</title>
                        <incipit xml:lang="gez">
                           ዘይነግሥ፡ 
                              <sic>ወከዕበ፡</sic>
                            ናአኵቶ፡ ወንሴብሖ፡ ለእግዚአ፡ ኵሉ፡ አምላክነ፡ አኃዜ፡ ኵሉ፡ አቡሁ፡ ለእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘይነግሥ፡ ለኵሉ፡ ዓለም።
                        </incipit>
                        <explicit xml:lang="gez">
                           ዕቀበነ፡ ዘእንበለ፡ ኀጢአት፡ ወመንሱት፨ በዋሕድ፡ ወልድከ፡ እግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ዘቦቱ፡ ለከ፡ <gap reason="omitted" extent="unknown" resp="bm:GrebTiss1935Codices"/>
                        </explicit>
                     </msItem>
                     <msItem xml:id="ms_i3.8">
                        <locus from="47v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4268Tazakkar">Litany</title>
                        <incipit xml:lang="gez">
                           ተዘከር፡ እግዚኦ፡ ለለ፡ ፩፩፡ ስእለቶ፡ ተዘከር፡ እግዚኦ፡ ለለ፡ ፩፩፡ እምከርሠ፡ እሙ፨ ተዘከር፡ እግዚኦ፡ ብዙኃነ፡ 
                              <sic>አሕዘብ፡</sic>
                            እለ፡ 
                           
                              <sic>በርቱዐ፡</sic>

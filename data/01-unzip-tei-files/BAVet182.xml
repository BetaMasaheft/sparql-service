                    <summary/>
                    
                    <msItem xml:id="ms_i1">
                      <locus from="5r" to="42r"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                      <textLang mainLang="gez"/>
                      <explicit xml:lang="gez">
                        ስብሐት፡ ለአብ፡ ወለወልድ፡ <choice><corr>አእኵቶ</corr><sic>አአኵቶ</sic></choice>፤
                        ለ<del rend="erasure" extent="1 letter"/>መንፈስ፡ ቅዱስ፡ ሰላም፡ ለዘአክሀለኒ፡ <choice><corr>ተርጕሞቶ</corr><sic>ተርጉሞቶ</sic></choice>፨
                        ለማኅሌተ፡ ጽጌኪ፡ ድንግል፡ ጊዜ፡ ወጠንኩ፡ አንብቦቶ፨
                        ለእግረ፡ ህሊናየ፡ ሠርሂ፡ ፍኖቶ፤
                        ወለልቡናየ፡ ፈጽሚ፡ ተምኔቶ፨

                        ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ መላእክት፡ ትጉሓን፨
                        ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ነቢያት፡ ቅዱሳን፨
                        ስብሐት፡ ለኪ፡ ማርያም፡ በጽጌ፡ ሐዋርያን፡ ፍንዋን፨
                        ወስብሐት፡ <del>ይ</del>ይደሉ፡ ለማኅሌተ፡ ጽጌኪ፡ ወይን፨
                        እስመ፡ በተአምርኪ፨ ወይን፡ ይትፌሣሕ፡ ኅዙን፨

                        ኦእግዝእትየ፡ ማርያም፡ ሣህልኪ፡ ወምሕረትኪ፡ የሃሉ፡ ምስለ፡ ገብርኪ፨ ወልደ፡ አምላክ። ለዓለመ፡ ዓለም፨ ዓሜን፨
                      </explicit>
                    </msItem>
                    
                    <msItem xml:id="ms_i2">
                      <locus from="42v" to="55v"/>
                      <title type="complete" ref="https://betamasaheft.eu/LIT2285Saqoqa">Saqoqāwa dǝngǝl</title>
                      <textLang mainLang="gez"/>
                      <explicit xml:lang="gez">
                        ዘእንበሌኪ፡ ባዕድ፡ አልብየ፡ ማዕምረ፡ 
                        ፃማ፡ ጐይዮትኪ፡ እግዝእትየ፡ ብካየ፡ ኮነኒ፡ ሀልዮቱ፨
                        ለወልድኪ፡ ሕፃን፡ ወስተ፡ ደብረ፡ ቍስቋም፡ ጊዜ፡ ርደቱ፨
                        ቅድመ፡ <choice><corr>ይስማዕ፡</corr><sic>ይሰምዕ፡</sic></choice> አዕዛኑ፡ ወይርአያ፡ አዕይንቱ፨
                        ኃዘነ፡ ወለቱ፡ እንዘ፡ አሐቲ፡ ሎቱ፨
                        ሠናይኬ፡ ለአቡኪ፡ ሞቱ፨

                        ስብሐት፡ ለኪ፡ <gap reason="ellipsis"/> ሰላመ፡ ክዓዊ፡ 
                      </explicit>
                    </msItem>
                    </msContents>

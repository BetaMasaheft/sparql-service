                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Careful.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>First half of the 19th century (?)</date>
                        <seg type="rubrication">Numbers and titles of psalms; second lines of most
                           psalms; numbers of portions in Ps. 118 (the names of Hebrew letters in
                           black); numbers and titles of other texts; second lines of other texts;
                           nomina sacra; elements of punctuation signs; incipits of texts (certain
                           parts); abbreviations for repeated parts in “Praise of Mary” and “The
                           Gate of Light”.</seg>
                     </handNote>
                  </handDesc>
                  <decoDesc>

                     <decoNote type="frame" xml:id="d1">
                        <locus target="#2r">2r</locus>: elaborate coloured ornamental bands;
                        interlaces, zoomorphic motifs.</decoNote>
                     <decoNote type="frame" xml:id="d2">
                        <locus target="#8r">8r</locus>, 15r, 22r, 31v: interlaces etc.</decoNote>
                     <decoNote type="frame" xml:id="d3">
                        <locus target="#103v">103v</locus>: unfinished ornamental band.</decoNote>
                     <decoNote type="miniature" xml:id="d4">
                        <locus target="#1v">Fol. 1v: </locus>
                        <desc>Angel and the donor.</desc>Painted on unruled leaf.</decoNote>
                     <decoNote type="miniature" xml:id="d5">
                        <locus target="#134v">Fol. 134v: </locus>
                        <desc>St. Mary and the donor (?).</desc>
                     </decoNote>
                  </decoDesc>

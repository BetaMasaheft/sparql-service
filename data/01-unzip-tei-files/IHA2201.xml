               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="30v">1v-30v</locus>
                     <title ref="https://betamasaheft.eu/LIT4278IHA">كتاب الأوراد للشيخ هاشم</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم / يا رب هيء لنا من أمرنا رشدا - واجعل معونتك الحسنى لنا مددا / ولاتكلنا الى تدبير انفسنا - والنفس تعجز عن اصلاح ما فسدا
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30v">-30v</locus>أن لا اله الا انت نستغفرك ونتوب اليك - سبحان ربك رب العزة عما يصفون / وسلام على المرسلين والحمد للة رب العلمين - أمين أمين أمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1v" to="2v">1v-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2009IHA">انشودة يا رب هيئ لنا من امرنا رشدا</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم / يا رب هيء لنا من أمرنا رشدا - واجعل معونتك الحسنى لنا مددا / ولا تكلنا الى تدبير انفسنا - والنفس تعجز عن اصلاح ما فسدا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>خفية فارتقب من بعدها فرجا - وكل بؤس له حد ومقدار
وفي خطو[.?.] الدنيا لناعبر - وفي السماء لمن في الأرض أخبار</explicit>
                     <note>
                        <note>
        Manuscript item  7005 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7005</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="13v" to="16r">13v-16r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4336IHA">نظم صلاة وتسليم وأزكي تحية علي نور عرش الله حاوي
                    المفاخر</title>
                     <incipit xml:lang="ar">
                        <locus target="#13v">-13v</locus>صلاة وتسليم وأزكي تحية - علي نور عرش الله حاوي المفاخر</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#16r">-16r</locus>وأل وأصحاب هدان شرائف - مدى زمزم الحادي على كل ضامر / تمت</explicit>
                     <note>
                        <note>
        Manuscript item  7064 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7064</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="16v" to="19r">16v-19r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4338IHA">دعاء اللهم صل على زين الوجود وسراج يوم الموعود</title>
                     <incipit xml:lang="ar">
                        <locus target="#16v">-16v</locus>بسم الله الرحمن الرحيم / اللهم صل على زين الوجود وسراج يوم الموعود سيدنا ومولانا محمد وعلى أله وصحبه وسلم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#19r">-19r</locus>اللهم صل صلاة كاملة وسلم سلاما تاما على نبي تنحل به العقد وتنفرج به الكرب وتقضي به الحواج وتنال به الرغائب وحسن الخواتم ويستسقي الغمام بوجهه رعلى آله وصحبه صل على قرة عين عبادل الصلحين وتقبلنا بجاهه أمين</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="19r" to="22r">19r-22r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4347IHA">نظم بدأت ببسم الله والحمد أولا</title>
                     <incipit xml:lang="ar">
                        <locus target="#19r">-19r</locus>بسم الله الرحم الحيم / بدأت ببسم الله والحمد أولا - على نعم لم تحص فيما تنزلا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22r">-22r</locus>بجاه إمام الأنبياء وقطبهم - شفيع الورى في يوم أقدامي عاريا / عليه صلاة الله ثم سلامه - ورضوانه والأل ما دمت باقيا</explicit>
                     <note>
                        <note>
        Manuscript item  7077 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7077</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="22r" to="22v">22r-22v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4169IHA">دعاء اللهم اني اسألك واتوسل اليك باسمائك</title>
                     <incipit xml:lang="ar">
                        <locus target="#22r">-22r</locus>اللهم إنّي أسئلك وأتوسل إليك بالأسماء الحسنى كلها جملة وباسم الحاوي تعدادها جملة إسمك </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#22v">-22v</locus>ولا حول ولا قوة إلا بالله العلي العظيم وصلى الله على سيدنا محمد وعلى آله وأصحابه وأزواجه وسلم تسليما والحمد لله رب العلمين </explicit>
                     <note>
                        <note>
        Manuscript item  7093 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7093</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="23r" to="26v">23r-26v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0714IHA">تخميس نظم يا رسول الله عونا مدد</title>
                     <incipit xml:lang="ar">
                        <locus target="#23r">-23r</locus>بسم الله الرحمن الرحيم \ ثق بمولاك ولا تسأل احد \ وبطه لذ اذا خطب ورد \ وبجد قل فمن جد وجد \ يا رسول الله غوثا ومدد انتم الوالد والعبد الولد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26v">-26v</locus>ما همى دمع بخدّ ساجما \ ما عصى صبٌّ عذولا لائما \ وتمادي في هواه دائما \ كدوام الله يبقى دائما - فهم أعلى العلا ثم الرشد
تمت</explicit>
                     <note>
                        <note>
        Manuscript item  7098 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7098</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="27r" to="30v">27r-30v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT0839IHA">مصطفى بالغة الهررية</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>بسم الله الرحمن الرحيم , ولا حول ولا قوة إلا بالله العلي العظيم , بسم الله الفتاح العليم , بسم الله العزيز الحكيم , كم چر بسم الله الرحمن الرحيم , كم چر لا اله الله الله , كم چر محمد رسول الله 
</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30v">-30v</locus>أن لا اله الا أنت نستغفرك ونتوب اليك سبحان ربك رب العزة عما يصفون وسلام على المرسلين والحمد لله رب العلمين أمين أمين أمين</explicit>
                     <note>
                        <note>
        Manuscript item  7101 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7101</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="2v" to="2v">2v-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3857IHA">نظم كم لله من لطف</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>وكم لله من لطف خفى يدق خفاه عن فهم الزكى / وكم يسر أتا من بعد عسر وفرج كربة القلب الشجي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>وصل على عريض الجاه طه - رسول الله سيدنا النبي</explicit>
                     <note>
                        <note>
        Manuscript item  7006 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7006</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="3r" to="4r">3r-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4017IHA">تخميس القصيدة العينية في المناجات</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>بسم الله الرحمن الرحيم / بجمال وجهك سيدي أتشفع / ولباب جوداع بالدعا أتضرع / يا من لقدرته  لجبابر تخضع / من يرى ما في الضمير ويسمع - أنت المعد لكل ما يتوقع
<note/>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v - 4r">-3v - 4r</locus> حاشا لجودك أن تقنط عاصيا - الفضل أجزل والمواهب أوسع / مولاي جئت لباب عفوك أضرع / وبمصطفاك محمد أتشفع / هب لي ذنوبي بت منها أقزع / الصلاة على أمير يشفع - للمذنبين إذ الخلائق يجمع</explicit>
                     <note>
                        <note>
        Manuscript item  7028 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7028</note>
                     </note>
                     <note>The last word of each original bayt is written vertically on the page and in pink. </note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="4r" to="5r">4r-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4313IHA">نظم يا خالق الخلق يا رب العباد أغث</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>يا خالق الخلق يا رب العباد أغث - عبدا أسيرا من الزلات والعلل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>كلنا منك راجون الشفاعة من - هوا أطعناه أو ذنب جنيناه / 
قبل توسلنا يا سيدي سندي - فإننا ضيفكم والضيف محترم 
تمت</explicit>
                     <note>
                        <note>
        Manuscript item  7040 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7040</note>
                     </note>
                     <note>Poem with changing end rhyme: 
verse 1 - 18 - ل
verse 19 - 30 - ي
verse 31 - 34 - ه
verse 35 - م

</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="5v" to="9v">5v-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0710IHA">تخميس القصيدة المضرية</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله الرحمن الرحيم /
إذا أردت سلوك الخير في زمر / 
قم في غدو وأصال وفي سحر /
وقل الهي بلا عجز ولا ضجر /
يا رب صل على المختار من مضر - والأنبيا وجميع الرسل ما ذكروا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>حلى صلاة وتسليما مضاعفة /
على النبي إله الخلق نامية /
تزكوا وتسموا على الكرسي عالية /
كذالك الرسل والأملاك قاطبة - والأل والصحب والأتباع ما ذكروا</explicit>
                     <note>
                        <note>
        Manuscript item  7047 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7047</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="10r" to="10v">10r-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0308IHA">مدح عبد القادر الجيلانى شي لله يا جيلاني ولي
                    للرحمن</title>
                     <incipit xml:lang="ar">
                        <locus target="#10r">-10r</locus>شي لله يا جيلاني  شي لله يا جلاني عبد القادر جيلاني ولي للرحم / على الأوليا ألقيت سري وبرهاني - فها موابه في سر سري وإعلاني</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>وعار على حامي الحما وهو قادر - إذا ضاع في البيد اعقالو [ابعيري؟]
تمت</explicit>
                     <note>
                        <note>
        Manuscript item  7051 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7051</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="10v" to="11v">10v-11v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0724IHA">قصيدة أغيب وذو اللطائف لا يغيب</title>
                     <incipit xml:lang="ar">
                        <locus target="#10v">-10v</locus>إلاهي ياإلاهي ياإلاهي إلاهي تب علي عسي أتوب / 

[اغيب] وذواالطائف لا يغيب - وأرجوه رجا لا يخيب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#11v">-11v</locus>وصل على نبيك كل وقت - وسلم في الصباح وفي الغروب</explicit>
                     <note>
                        <note>
        Manuscript item  7054 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7054</note>
                     </note>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="11v" to="12v">11v-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4325IHA">مدح الشيخ هاشم شي لله شيخ هاشم شي لله شيخ هاشم سيدي يا
                    هاشم المداد يا هاشم</title>
                     <incipit xml:lang="ar">
                        <locus target="#11v - 12r">-11v - 12r</locus>شي لله شيخ هاشم شي لله شيخ هاشم سيدي يا هاشم المداد يا هاشم \ [.؟.] أحترز , شر من همز , بك أرتكز \ [.؟.]كم نجزا , عبدكم حرزا , مدحكو برزا 
<note>The first words of the verse lines are unreadable due to close binding.</note>
                     </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>ما توالى الشهور واشتدار الدهور أو تماجى البخور / تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="12v" to="13v">12v-13v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0753IHA">قصيدة طف بحالي</title>
                     <incipit xml:lang="ar">
                        <locus target="#12v">-12v</locus>الله الله الله الله الله صلواتي على النبي وسلاني / طف بحاني سبعا وقف بزمامي - وتجرد لزورتي كل عامي</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#13v">-13v</locus>فالحمد للحمي الحليم الكريم - العليم القدير محيي العظامي</explicit>
                     <note>
                        <note>
        Manuscript item  7061 relates to manuscript item 7003</note>
                        <note>
        Manuscript item  7003 relates to manuscript item 7061</note>
                     </note>
                     <note/>

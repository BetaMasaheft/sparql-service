<msContents>

  <msItem xml:id="ms_i1">
  <locus from="1r"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām, or Encomium of the blessed Virgin Mary, arranged in portions
  for the days of the week</title>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i2">
  <locus from="19r"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3108RepCh388">Hymn to the Virgin Mary</title>
  <incipit xml:lang="gez">ይዌድስዋ፡ መላእክት፡ ለማርያም፡ በውስተ፡ ውሣጤ፡ መንጦላዕት፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i3">
  <locus from="21v"/>
  <title xml:lang="en" type="complete">A prayer</title>
  <incipit xml:lang="gez">ኦእግዚእትየ፡ ማርያም፡ ኦብፅዕት፡ ዘአልባቲ፡ ርስሐት፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4">
  <locus from="23r"/>
  <title xml:lang="en" type="complete">Hymns and prayers</title>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.1">
  <locus from="23r"/>
  <title xml:lang="en" type="incomplete">To the blessed Virgin Mary</title>
  <note>Imperfect at the beginning.</note>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.2">
  <locus from="23vb"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT3088RepCh368">Hymn to the Virgin Mary</title>
  <incipit xml:lang="gez">ኦርኅርኅተ፡ ሕሊና፡ አፍቅሮተ፡ ሰብእ፡ ልማዳ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.3">
  <locus from="28r"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2839RepCh123">Hymn to our Lord</title>
  <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይሔሱ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.4">
  <locus from="38r"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2883RepCh164">Hymn to the Saviour of the World <foreign xml:lang="gez">መድኃኔ፡ ዓለም፡</foreign></title>
<incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘኢረከቡ፡ ተፍጻሜተ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.5">
  <locus from="46r"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Hymn to St. Michael</title>
  <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሳተፈ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.6">
  <locus from="54v"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">To the angel Gabriel</title>
  <incipit xml:lang="gez">በሰላመ፡ ገብሬል፡ መልአክ፡ በላዕለ፡ ማርያም፡ ዘአዕረፈ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.7">
  <locus from="60r"/>
  <title xml:lang="en" type="complete">A prayer to our Lord</title>
  <incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ወወልደ፡ ማርያም፡ ሥግው፡ ዕቀበኒ፡ እምኵሉ፡ እኩይ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.8">
  <locus from="71v"/>
  <title>Another prayer</title>
  <incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ በእንተ፡ ማርያም፡ ወላዲትከ፡ ርድአኒ፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

  <msItem xml:id="ms_i4.9">
  <locus from="76v"/>
  <title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT2729RepCh13">A hymn</title>
  <incipit xml:lang="gez">ሚካኤል፡ ዘትቀውም፡ በየማና፡ ለማርያም፡ ድንግል፡</incipit>
  <textLang mainLang="gez"/>
  </msItem>

</msContents>


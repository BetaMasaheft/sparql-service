               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1" to="100">p. 1-100</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3088IHA">هداية الناشئين في القرآن الكريم والتهذيب والدين</title>
                     <incipit xml:lang="ar">
                        <locus target="#p. 2">-p. 2</locus>مقدمة بسم الله الرحمن الرحيم الحمد لله رب العالمين والصلاة والسلام على سيدنا محمد خاتم النبيين وبعد فهذا كتاب يتضمن دروس القرآن الكريم والدين والتهذيب على حسب المنهج الحديث الذى أقرته وزارة التربية والتعليم لمدارس المرحلة الأولى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#p. 99">-p. 99</locus>فإن شقى من مرضه بعد ذلك وكان ما تركه يساوى صلوات يوم وليلة أعاد ما تركه فإن زاد على ما يعادل صلوات يوم وليلة فلا يعيد ولا يحاسب على ما تركه من الصلاة </explicit>
                     <note>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/D6L4ETD9"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:IHABook617"/><title level="m">Hidāyat al-nāši'īn fī al-Qur'ān al-karīm wa al-tahḏīb wa al-dīn</title><author><name>Maḥmūd Muḥammad Ḥamza</name></author><author><name>Muṣṭafā al-Saqā</name></author><pubPlace>al-Qāhira</pubPlace><publisher>Dar al-Maʻārif</publisher><date>1959</date><note type="tags"><note type="tag">bm:IHABook617</note></note><note type="tag">bm:IHABook617</note></bibl>
                        </listBibl>

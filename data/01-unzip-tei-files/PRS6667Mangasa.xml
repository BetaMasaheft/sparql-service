         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መንገሻ፡ ይልማ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Mangašā Yǝlmā</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="horse">አባ፡ ተብብ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n2" type="normalized">ʾAbbā Tabǝb</t:persName>
               
               <t:persName>
                  <t:roleName type="title">daǧǧāzmāč</t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               
               <t:occupation type="military">leader</t:occupation>
               
               
               
               
               
               <t:floruit notBefore="1930" notAfter="1936">He was a 20th century military leader. He was a son of <t:persName ref="https://betamasaheft.eu/PRS10309YelmaM">Yǝlma Mäkwännǝn</t:persName>
                  who was the eldest son of 
                  <t:persName ref="https://betamasaheft.eu/PRS6567Makwanne">
                     <t:roleName type="title">rās</t:roleName>
                  </t:persName>. 
                  During the first years of <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</t:persName>'s reign Mangašā Yǝlmā was 
                  appointed to the newly formed administration of the southern border districts of <t:placeName ref="https://betamasaheft.eu/LOC4413Maji">Maǧi</t:placeName> and <t:placeName ref="https://betamasaheft.eu/LOC3560Goldiy">Goldiya</t:placeName>.</t:floruit>
               <t:death when="1936">He died in the battle of <t:placeName ref="https://betamasaheft.eu/LOC4667MayCaw">Māy Č̣aw</t:placeName> in<t:date>1936</t:date>.</t:death>
               
               
               
            </t:person>
            
         </t:listPerson>
         
         
         

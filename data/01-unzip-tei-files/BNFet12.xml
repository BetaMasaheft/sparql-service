               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="104r" facs="f7"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez"/>

                     <msItem xml:id="ms_i1.1">
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <textLang mainLang="gez"/>
                        <note>The following are missing: <p>The beginning until Ps. 7:7;</p>
                           <p>Ps. 80:9b-Ps. 82:7.</p>
                        </note>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="104r" to="115v" facs="f213"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="116r" to="122v" facs="f237"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                     </msItem>

                     <msItem xml:id="ms_i1.4">
                        <locus from="123ra" to="151va" facs="f251"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT3946Salotat">Ṣalotāt za-saʿātāt</title>
                        <incipit xml:lang="gez">በስመ፡ አብ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/> ንቀድም፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/> በእንተ፡ ጽሒፈ፡ ጸሎታት፡ ዘሰዓታት፡ ዘሌሊት፡
                           ወዘመዓልት።</incipit>
                        <note>These prayers correspond probably to the ones in <ref type="mss" corresp="https://betamasaheft.eu/BNFet9#ms_i3">Paris, Bibliothèque nationale de France, BnF Éthiopien 9:  ms_i3</ref> and are different from the ones in <ref type="mss" corresp="https://betamasaheft.eu/BNFet11#ms_i3">Paris, Bibliothèque nationale de France, BnF Éthiopien 11: Ṣalotāt za-saʿātāt (in ms_i3)</ref>.</note>
                        <note>
                           <ref type="work" corresp="https://betamasaheft.eu/LIT3198Prayer">Prayer of the First Hour</ref> includes an invocation on
                              <locus target="#125v"/> for <persName ref="https://betamasaheft.eu/PRS10626ZaraY">Zarʾa Yāʿqob</persName>.</note>
                     </msItem>

                     <msItem xml:id="ms_i1.5">
                        <locus from="151va" to="160vb" facs="f308"/>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                        
                        <msItem xml:id="ms_i1.5.1">
                           <locus from="151va" to="152va" facs="f308"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Monday">Wǝddāse Māryām: : Monday</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5.2">
                           <locus from="152va" to="154rb" facs="f310"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Tuesday">Wǝddāse Māryām: : Tuesday</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5.3">
                           <locus from="154rb" to="156ra" facs="f313"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas#Wednesday">Wǝddāse Māryām: : Wednesday</title>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5.4">
                           <locus from="156ra" to="156vb" facs="f317"/>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas#Thursday">Wǝddāse Māryām: : Thursday</title>
                           <note>The end of the hymn is missing.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5.5">
                           <locus from="157ra" to="157rb" facs="f319"/>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas#Saturday">Wǝddāse Māryām: : Saturday</title>
                           <note>The beginning is missing.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.5.6">
                           <locus from="160rb" to="160vb" facs="f325"/>
                           <title type="incomplete" ref="https://betamasaheft.eu/LIT2509Weddas#Sunday">Wǝddāse Māryām: : Sunday</title>
                           <note>The end of the hymn is missing.</note>
                        </msItem>
                        <note>The hymn for Friday, 
                           <ref type="work" corresp="https://betamasaheft.eu/LIT2509Weddas#Friday">Wǝddāse Māryām: : Friday</ref>, 
                           is missing.</note>
                     </msItem>
                  </msItem>
                  
                  <msItem xml:id="ms_i1.6">
                     <locus from="157rb" to="159vb" facs="f319"/>
                     <title type="incomplete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                  </msItem>

               </msContents>


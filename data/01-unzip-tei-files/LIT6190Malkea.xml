        <body>
            <div type="bibliography"><listBibl type="editions">
                <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl></div>

            <div type="edition" xml:lang="gez">
                <div type="textpart" xml:id="malke">
                    <lg type="stanza" n="1">
                        <l n="1">ለወሀቤ፡ ሀብታት፡ እግዚአብሔር፡ ዘሠናይ፡ ሀብቱ፡</l>
                        <l n="2">ወለወላዲቱ፡ ድንግል፡ ወሀቢተ፡ ጸጋ፡ በከንቱ፨</l>
                        <l n="3">አስተብቍዒዮሙ፡ እድና፡ ወአልዕሊዮሙ፡ በእንተ፡ ዝንቱ፨</l>
                        <l n="4">የሀቡኒ፡ ሀብተ፡ ክሂል፡ ዘግብረ፡ ተሥእኖ፡ አልቦቱ፨</l>
                        <l n="5">መሐልየ፡ መልክዕ፡ ለኪ፡ ከመ፡ እኅሊ፡ ቦቱ፨</l>
                    </lg>
                    <lg type="stanza" n="2">
                        <l n="1">እምብእሲተ፡ ሄኖክ፡ እድና፡ ወእምሄውቱ፡ ለለሜሕ፡</l>
                        <l n="2">ወእሙ፡ ለማቱሳላ፡ ዘመዋዕሊሁ፡ ብዙኅ፨</l>
                        <l n="3">ትከብሪ፡ እድና፡ ወዐብዪ፡ በንጽሕ፨</l>
                        <l n="4">እስመ፡ አንጽሐኪ፡ እምርስተ፡ ዓለም፡ ልሱሕ፨</l>
                        <l n="5">በደመ፡ ገቦሁ፡ ቀይሕ፡ ወልደ፡ አብ፡ መሲሕ፨</l>
                    </lg>
                    <lg type="stanza" n="3">
                        <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘኍልቈ፡ ፊደሉ፡ ሠላስ፨</l>
                        <l n="2">ወይሄሉ፡ ጽሑፈ፡ በሰሌዳ፡ ህልው፡ ሞገሥ፨</l>
                        <l n="3">ንግሥትየ፡ እድና፡ ወለተ፡ ሮማዊ፡ ንጉሥ፨</l>
                        <l n="4">ሴስይኒ፡ እክለ፡ ሣህልኪ፡ በመዋዕለ፡ ረኀብ፡ ዘከርስ፨</l>
                        <l n="5">ወበጊዜ፡ እርቃን፡ ይክድነኒ፡ ምሕረትኪ፡ ልብስ፨</l>
                    </lg>
                    <lg type="stanza" n="28">
                        <l n="1">ሰላም፡ ለመቃብርኪ፡ ዘኢተከስተ፡ ለዓይነ፡ ሰብእ፡</l>
                        <l n="2">ከመ፡ መቃብሩ፡ ለሙሴ፡ ነቢየ፡ ምሥጢር፡ ኅቡዕ፨</l>
                        <l n="3">መቅደሰ፡ ቅድሳት፡ እድና፡ ቅድስተ፡ ቅዱሳን፡ ታስዕ፨</l>
                        <l n="4">እስይኒ፡ ዕሴተ፡ ጽድቅ፡ ለብእሴ፡ ኃጢአት፡ ኃጥእ፨</l>
                        <l n="5">በፍጻሜ፡ ዝንቱ፡ ማኅሌት፡ ወዝኩ፡ መልክዕ፨</l>
                    </lg>
                    <lg type="stanza" n="29">
                        <l n="1">በእንተ፡ ብካዮን፡ ለአኀት፡ ወሰቆቃዎሙ፡ ለአኃው፨</l>
                        <l n="2">አመ፡ ሞተ፡ ዚአኪ፡ ዮም፡ እምነ፡ ሐይው፨</l>
                        <l n="3">ለባዊት፡ እድና፡ እመ፡ አረጋዊ፡ ልብው፨</l>
                        <l n="4">ናዝዝኒ፡ እምትካዝየ፡ በኑዛዜኪ፡ ፍትው፨</l>
                        <l n="5">ወአስተፍሥሕኒ፡ እምላሕዎ፡ ለብእሲ፡ ልሕው፨</l>
                    </lg>
                    <lg type="stanza" n="30">
                        <l n="1">ስብሐት፡ ይደሉ፡ ለክርስቶስ፡ ወለማርያም፡ እሙ፨</l>
                        <l n="2">እስመ፡ አብሑኒ፡ እንብብ፡ ለፍቅደ፡ መልክዕኪ፡ ቃለ፡ ሰላሙ፨</l>
                        <l n="3">ቅድስተ፡ ባሕርይ፡ እድና፡ ካልእተ፡ ቅዱሳን፡ ኵሎሙ፨</l>
                        <l n="4">ኅትሚ፡ ገጽየ፡ ወፍጽምየ፡ በማኅተመ፡ ገጹ፡ ወፍጽሙ፨</l>
                        <l n="5">ለበዐለ፡ ወንጌል፡ ዮሐንስ፡ ዘተአኵተ፡ ስሙ፨</l>
                    </lg>
                </div>
            </div>
            

            

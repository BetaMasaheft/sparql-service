              <additions>
                  <list>
                      <item xml:id="a1">
                          <locus target="#1r"/>
                          <desc type="ProtectivePrayer">Prayer for the destruction of a herd by wild
                          animals.</desc>
                          <q xml:lang="gez">ይናዠልሞን፡ አሻኮር፡ <gap reason="ellipsis"/> ሰላም፡ ለወራባ፡ ለዠብ፡
                              ወለነብር፡ ወለኵሎሙ፡ አራዊተ፡ ገዳም፡ <gap reason="ellipsis"/> እስከ፡ ይፈረፍሮ፡ ሥጋሁ፡ ወእስከ፡ ይጸነጽን፡ አጽንቱ፡ ለንዋየ፡ 
                              ገብርከ፡
                          </q>
                      </item>
                      <item xml:id="a2">
                          <locus target="#1r"/>
                          <desc type="ProtectivePrayer">Prayer for the protection of the herd.</desc>
                          <q xml:lang="am">ኤላዝሞን፡ ኤላትሮን፡ <gap reason="ellipsis"/> 
                              ጨጠማ<supplied reason="omitted">፡</supplied> ጅብ፡ ደንደሳማ፡ አንበሳ፡ ጋማማ።
                              <gap reason="ellipsis"/> 
                              <choice><sic>ብጅ፡</sic><corr>ጅብ፡</corr></choice> ጽፍራማ፡ ጀራታማ፡ ቀበሮ፡ ጀራታማ፡ አትንካ፡ <gap reason="ellipsis"/> ለንዋየ፡ ገብርከ፡ እገሌ፡</q>
                      </item>
                      <item xml:id="a3">
                          <locus target="#1r"/>
                          <desc type="ProtectivePrayer">Prayer for the protection of the owner of

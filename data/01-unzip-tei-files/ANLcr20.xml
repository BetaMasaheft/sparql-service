                        <msContents>
                        <summary/>
                        
                            <msItem xml:id="p1_i1">
                            <locus from="3ra" to="6vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>
                            <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ለፅንስትከ፡ መሰረተ፡ ነገር፡ ወውጣኔ<supplied reason="omitted">፡</supplied></incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i2">
                                <locus from="7ra" to="18vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2930RepCh211">Malkǝʾa ʾAbuna Takla Hāymānot</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ለፅንስትከ፡ ወ<supplied reason="omitted">ለ</supplied>ልደትከ፡ እምከርሥ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i3">
                                <locus from="19ra" to="32vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">Malkǝʾa Giyorgis</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘሰሌዳ፡ ሞገስ፡ መጽሐፉ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i4">
                                <locus from="33ra" to="43rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3085RepCh365">Malkəʾa Rāguʾel</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">እጼውዕ፡ ስመከ፡ ወእኤምኅ፡ በተድላ፡ ራጉኤል፡ መንፈስ፡ ለዓለም፡
                                    መስተበቅላ፤</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i5">
                                <locus from="43va" to="55ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2835RepCh119">Malkǝʾa Mikāʾel</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ምስለ፡ ስመ፡ ልዑል፡ ዘተሣተፈ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i6">
                                <locus from="55va" to="63rb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2965RepCh246">Malkǝʾa Gabrǝʾel</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላመ፡ ገብርኤል፡ መልአክ፡ በላዕለ፡ <sic>ማርያያም፡</sic> ዘአእ<add place="below">ረ</add>ፈ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i7">
                                <locus from="63va" to="68va"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2940RepCh221">Malkǝʾ-hymn to Our Lady Mary</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ሰላም፡ ሰላም፡ ለዝክረ፡ ስምኪ፡ በአምኃ። 
                                    ሰርከ<supplied reason="omitted">፡</supplied> ወነግሀ።</incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i8">
                                <locus from="68vb" to="71vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba ṭabibān</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ኦእግዚአብሔር፡ ጠቢበ፡ ጠቢባን፡
                                    <supplied reason="omitted">፡</supplied> ከ<sic>መ</sic>ሃሊ፡ እስከ፡ ለዓለም፡ 
                                    እምጥንት፡ እንተ፡ ኢትበሊ፡ ድኩመ፡ ሕሊና<supplied reason="omitted">፡</supplied>
                                    ገብርከ፡ ወልደ፡ <space reason="owner"/>
                                    ወፈራሄ፡ ልበ፡ ኢተሐባሊ። እስመ፡ ኀቤከ፡ እግዚኦ፡ ጸሎተ፡ አድኅኖ፡ እጹሊ። አድኅነኒ፡ አድኅነኒ፡
                                    እምኵሉ፡ ቀታሊ።
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i9">
                                <locus from="83ra" to="100ra"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT6279EqabanniGen">ʿƎqabanni (general record)</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ 
                                    ወልደ፡ እግዚአብሔር፡ ሕያው፡ ወልደ፡ ማርያም፡ ሥግው፡ ዕቀበኒ፡ ለገብርከ፡ 
                                    <persName ref="https://betamasaheft.eu/PRS14895AmmehaG">አምኃ፡ ጊዮርጊስ፡</persName> በእንተ፡ ዘኀደርከ፡ በከርሠ፡ ማር<cb n="b"/>ያም፡ ድንግል፡ ፱ አውራኃ፡ ወ፭ ዕለተ<supplied reason="omitted">፡</supplied>
                                    ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ ዕቀበኒ፡ ለገብርከ፡ 
                                    <persName ref="https://betamasaheft.eu/PRS14895AmmehaG"><choice><corr>አምኃ፡</corr><orig>ገብረ፡</orig></choice> ጊዮርጊስ፡</persName> በእንተ፡ ማርያም፡ ድንግል፡ አፍቂረከ፡ 
                                    ዘኀደርከ፡ ውስተ፡ ማኅፀና፡ ኦእግዝእትየ፡ ማርያም፡ ዕቀብኒ፡ 
                                    ለገብረ፡ አምኃ፡ ጊዮርጊ<pb n="83v"/><cb n="a"/><supplied reason="omitted">ስ፡</supplied>
                                    በእንተ፡ ዘወለድኪ፡ መድኅነ፡ ኦእግዝእትየ፡ ቅድስት፡ <supplied reason="omitted">፡</supplied>
                                    ድንግል፡ ማርያም፡ ዕቀብኒ፡ ለገብርኪ፡ 
                                    <persName ref="https://betamasaheft.eu/PRS14895AmmehaG">አምኃ፡ ጊዮርጊስ፡</persName> በእንተ፡ ፍቅሩ፡
                                    ለእግዚእነ፡ ወበእንተ፡ ዘሐቀፍኪዮ፡ በአዕደውኪ፤ ወበእንተ፡ ዘአጥበውኪዮ፡ ሀሊበ፡ እምአጥባትኪ<supplied reason="omitted">፡</supplied>
                                    ለውእቱ፡ ሕፃን፡ ኢየሱስ፡ ክርስቶስ፡ አንተኬ፡ ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶ<cb n="b"/>ስ፡ ዕቀበኒ።
                             </incipit>
                            </msItem>
                            
                            <msItem xml:id="p1_i10">
                                <locus from="100ra" to="100vb"/>
                                <title type="complete" ref="https://betamasaheft.eu/LIT7540PPSnakes">LIT7540PPSnakes</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ዘተነድፈ፡ 
                                    እምአርዌ<supplied reason="omitted">፡</supplied> ምድር፡ ወተመን፡ ወእምከመ፡
                                    በጽሐ፡ ላዕክ፡ ሐሰውከ፡ ፫ ጊዜ፡ ብሎ፡ በስመ፡ እግዚ<cb n="b"/>አብሔር፡ ቀዳማዊ፡ ወበስመ፡ 
                                    እግዚአብሔር፡ በሰማይ፡ ወበምድር፡
                                </incipit>
                            </msItem>
                    </msContents>
                    

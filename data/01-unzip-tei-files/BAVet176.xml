                            <msItem xml:id="p1_i1">
                              <locus from="3r" to="34v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1834Mahlet">Māḫleta ṣǝge</title>
                              <textLang mainLang="gez"/>
                              <explicit xml:lang="gez">
                                  እምኵሉ<supplied reason="omitted">፡</supplied> ይኄይስ፡ በድንጋሌኪ፡ ተውክሎ፨
                                  ወለወልድኪ፡ ለቤዛ፡ ዕጉሠ፡ ቅንዋት፡ ወተሰቅሎ፨
                                  <sic>ምዕራን፡</sic> አንብዑ፡ ማርያም፡ ለዳዊት፡ ነቢየ፡ ሴሎ፨
                                  አዕርጊ፡ ጸሎትየ፡ ወቃለ፡ ጽራኅየ፡ ኵሎ፨
                                  ፈንዊ፡ ሊተ፡ ለወልድኪ፡ ምሕረቶ፡ ወሣህሎ፨
                              </explicit>
                            </msItem>
                            
                            <msItem xml:id="p1_i2">
                              <locus from="34v" to="46v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT2285Saqoqa">Saqoqāwa dǝngǝl</title>
                              <textLang mainLang="gez"/>
                              <explicit xml:lang="gez">
                                  ባዕድ፡ አልብየ፡ ማእምረ፡
                                  ሶበ፡ ፈቀደ፡ ቀቲለ፡ ሕፃናት፡ ሄሮድስ፡ ክሃዲ፨
                                  ተድኅለት፡ እሙ፡ ዘምስለ፡ ሕፃና፡ እብናዲ፨
                                  ውስተ፡ <sic>ደብረ፡</sic> ርጉዕ፡ ኀበ፡ <choice><corr>ይሰማዕ፡</corr><sic>ይስማዕ፡</sic></choice> ቃለ፡ ዓዋዲ፨
                                  እፎ፡ ነበረ፡ <choice><corr>ጐያየ፡</corr><sic>ጐይያ፡</sic></choice> ከመ፡ ፩ነጋዲ፨
                                  ዘመነ፡ ወአዝማነ፡ ወመንፈቀ፡ ዓዲ፨
                              </explicit>
                            </msItem>
                            
                            <msItem xml:id="p1_i3">
                              <locus from="46v" to="50r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT2894RepCh175">Malkǝʾa Qʷǝsqʷām</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="p1_i4">
                              <locus from="50v" to="66r"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                              <textLang mainLang="gez"/>
                            </msItem>
                            
                            <msItem xml:id="p1_i5">
                              <locus from="66r" to="66v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT3063RepCh343">Hymn to Our Lady Mary</title>
                              <textLang mainLang="gez"/>
                              <incipit xml:lang="gez">
                                  እሴብሕ፡ ጸጋኪ፡ ኦእግዝእትየ፡ <space reason="rubrication" cert="low"/> ዖፈ፡ ብርጋና፡ ዘቀላይ፡
                                  ዘእንቈ፡ ባሕርይ፡ ሙዳይ፡
                                  ፀዳለ፡ ስንኪ፡ የሐቱ፡ እምብርሃነ፡ ፀሐይ፡
                              </incipit>
                              <explicit xml:lang="gez">
                                  ስብሐት፡ ለኪ፡ ሰጊድ፡ ለፍሬ፡<supplied reason="omitted">፡</supplied> ከርሥኪ፡ <sic>ወምሕረቶ፡</sic> ለሕዝብኪ፡ ላዕለ፡ ኵልነ፡ አግብር<supplied reason="omitted">ት</supplied>ኪ፡ ወአዕማትኪ፡ ለዓለመ፡ ዓለም፡ አሜን<supplied reason="omitted">፨</supplied>
                              </explicit>
                            </msItem>


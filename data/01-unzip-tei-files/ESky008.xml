                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#3ra">f. 3ra</locus>
                           <desc>-vb: Miracle of the Archangel Michael.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> Written in a careless hand. </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#156va">f. 156va</locus>
                           <desc>-vb: Regulation concerning the preparation of the blessed bread
                              (ʾawlogiya) followed by a prayer.</desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> </note>
                        </item>
                        <item xml:id="a3">
                           <locus target="#156vb">f. 156vb</locus>
                           <desc>: Donation note.</desc>
                           <quote xml:lang="gez">
                              <locus target="#156vb">156vb</locus>: ዝመጽሀፍ፡ ዘዘመደማርያም፡ ዘወሐበቶ፡ ለቅዱስ፡
                              ዮሀንስ፡ መጥምቅ፡ ዘአጥረየቶ፡ በንዋያ፡ ዘሰረቆ፡ ወዘፈሀቆ፡ በስልጣነ፡ ጴጥሮስ፡ ወጳውሎስ፡ ውጉዝ፡
                              ይኩን፡</quote>
                           <quote xml:lang="en">
                              <locus target="#156vb">156vb</locus>: This is the book of Zämädä
                              Māryām who donated it to (the church of) St John the Baptist, who
                              acquired it with her money. He who steals it or erases (its text)
                              shall be excommunicated by the authority of Peter and Paul.</quote>
                           <note> Written by a semi-literate person (rare spelling variants,
                              non-existing variation of the last letter in the word ውጉዝ፡). </note>
                        </item>
                        <item xml:id="e1">- A piece of white paper glued on to the folio, with the
                           title ቅዳሴ, in blue ink: <locus target="#1r">1r</locus>. 
 - Names of
                           the donors crudely written in the upper margin, in the same hand as
                           Additio 3: <locus target="#52r">52r</locus>, 57v, 69r, 101v, 107r, 116r,
                           131r, 141r.
 - Crude notes (writing exercises?), pen trials: <locus target="#2r">2r</locus>, 3r, 3v, 37v, 38r, 109r, 125r, 131v,
                           132r.</item>
                        <item xml:id="e2">
                           <desc type="findingAid">Rubricated notes indicate occasions for celebration
                              of the respective Anaphoras, written in the upper margin of the fols.
                              in the main hand: fols. 52r, 65r, 69r, 79r, 88r, 96r, 101v, 107r,
                              110r, 116r, 122v, 131r, 141r.</desc>
                        </item>
                     </list>

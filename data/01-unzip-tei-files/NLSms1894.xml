                             </incipit>
                             <explicit xml:lang="gez">
                             <locus target="#136rb"/>
                                 ጸሐፈ፡ ዘን<unclear>ተ</unclear><gap reason="lost" quantity="2" unit="chars"/><lb/>ር፡ ከመ፡ <gap reason="lost" quantity="3" unit="chars"/><lb/>ውእቱ፡ ስምዑ። <gap reason="lost" quantity="1" unit="chars"/><lb/>ቦ፡ ባዕደኒ፡ ዘገብረ<gap reason="lost" quantity="1" unit="chars"/>
                             </explicit>

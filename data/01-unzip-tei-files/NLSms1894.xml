                                                <desc><term key="arch" ana="#arch">Arch</term> resting on <term key="curtain" ana="#curtain">curtained</term> 
                                                    <term key="column" ana="#column">columns</term> with three <foreign xml:lang="gez">ጢር፡</foreign> 
                                                    <term key="bird" ana="#bird">birds</term> and four <foreign xml:lang="gez">ከራዊያ፡</foreign> birds 

                             <title type="complete" ref="https://betamasaheft.eu/LIT1882MarkGo#TituliMark">Wangel za-Mārqos, Tituli of the Gospel of Mark</title>
                             <incipit xml:lang="gez">
                                 <hi rend="rubric">፩</hi> በእንተ፡ ዘጋኔን። <lb/><hi rend="rubric">፪</hi> በእንተ፡ ሐማተ፡ ጴጥሮስ፡ <lb/><hi rend="rubric">፫</hi> በእንተ፡ እለ፡ ተፈወሱ፡ እምብዙኅ፡ ደዌ።
                             </incipit>
                             <explicit xml:lang="gez">
                             <locus target="#45vb"/>
                                 <hi rend="rubric">፵፯</hi> በእንተ፡ ዘአግብኦ፡ ይሁዳ። <lb/><hi rend="rubric">፵፰</hi> በእንተ፡ ዘከመ፡ ክሕዶ፡ ጴጥሮስ። <lb/><hi rend="rubric">፵፱</hi> በእንተ፡ ስእለተ፡ ሥጋሁ፡ ለእግዚእነ።
                             </explicit>
                        </msItem>
                        <msItem xml:id="ms_i1.3.2">
                           <locus from="65ra" to="106ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1882MarkGo#MarkGospel">No item: LIT1882MarkGo, could not check for MarkGospel</title>
                             <incipit xml:lang="gez">
                                 ቀዳሚሁ፡ ለወን<lb/><hi rend="rubric">ጌለ፡ ኢየሱስ፡ ክር</hi><lb/>ስቶስ፡ ወልደ፡ እ<lb/><hi rend="rubric">ግዚኣብሔር፡</hi> <lb/>በከመ፡ ጽሑፍ፡ ው<lb/><hi rend="rubric">ስተ፡ ነቢያት፡ ና</hi><lb/>ሁ፡
                             </incipit>
                             <explicit xml:lang="gez">
                                 ወወፂኦሙ፡ እሙን<lb/>ቱ፡ ሰበኩ፡ ኵልሄ፡ <lb/>እንዘ፡ እግዚአብሔ<lb/>ር፡ ይረድእ፡ ወቃሎ፡ <lb/>ያጸንዕ፡ በተአምር፡ <lb/>ዘይተሉ፡ አሜን፨
                             </explicit>
                          </msItem>
                        </msItem>

                          <msItem xml:id="ms_i1.4">
                              <locus from="106rb" to="160ra"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke">Wangel za-Luqās</title>
                          <msItem xml:id="ms_i1.4.1">
                             <locus from="106rb" to="107rb"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke#TituliLuke">Wangel za-Luqās, Tituli of the Gospel of Luke</title>
                             <incipit xml:lang="gez">
                                 <hi rend="rubric">፩</hi> በእንተ፡ ጸሐፊ፡ <lb/><hi rend="rubric">፪</hi> በእንተ፡ እለ፡ ይሔልዉ፨ ኖሎት፨ <lb/><hi rend="rubric">፫</hi> በእንተ፡ ስምዖን፨
                             </incipit>
                             <explicit xml:lang="gez">
                                 <hi rend="rubric">፹፩</hi> በእንተ፡ እለ፡ ይበክያ፡ አንስት። <lb/><hi rend="rubric">፹፪</hi> በእንተ፡ ዘተነስሐ፡ ፈያታዊ። <lb/><hi rend="rubric">፹፫</hi> በእንተ፡ ዘሰአለ፡ ሥጋሁ፡ ለእግዚዝነ።
                             </explicit>
                          </msItem>
                          <msItem xml:id="ms_i1.4.2">
                             <locus from="108ra" to="160ra"/>
                             <title type="complete" ref="https://betamasaheft.eu/LIT1812GospelLuke#LukeGospel">No item: LIT1812GospelLuke, could not check for LukeGospel</title>
                             <incipit xml:lang="gez">
                             <locus target="#108ra"/>
                                 <hi rend="rubric">እስመ፡ ብዙኃን፡ እ</hi> <lb/>ለ፡ ወጠኑ፡ ይንግሩ፡  <lb/><hi rend="rubric">ወይምሀሩ፡ በእን</hi><lb/>ተ፡ ግብር፡ ዘአምኑ፡  <lb/><hi rend="rubric">በላዕሌነ፡ በከመ፡</hi> <lb/>መሀሩነ፡ እለ፡ ቀደሙ<lb/><hi rend="rubric">ነ፡</hi> 
                             </incipit>
                             <explicit xml:lang="gez">
                             <locus target="#106ra"/>
                                 ወነበሩ፡ በቤተ፡ መ<lb/>ቅደስ፡ ዘልፈ፡ እንዘ፡ <lb/>ይባርክዎ፡ ወይሴብ<lb/>ሕዎ፡ ለእግዚአብ<lb/>ሔር፡ ለዓለም፡ አሜን።
                             </explicit>
                          </msItem>
                        </msItem>
                          
                        <msItem xml:id="ms_i1.5">

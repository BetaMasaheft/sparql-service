                            <incipit xml:lang="gez">
                                <locus target="#160vb"/><hi rend="rubric">አርእስተ፡ ነገር፡ እምወንጌለ፡ ቅዱስ፡ ዮሐንስ።</hi> <lb/><hi rend="rubric">፩</hi> በእንተ፡ ከብካብ፡ ዘቃና፡ <lb/><hi rend="rubric">፪</hi> በእንተ፡ ዘሰደደ፡ እመኵራብ፡ <lb/><hi rend="rubric">፫</hi> በእንተ፡ ኒቆዲሞስ፡
                            </incipit>
                            <explicit xml:lang="gez">
                            <locus target="#106vb"/>
                                <hi rend="rubric">፲፯</hi> በእንተ፡ ዘከመ፡ ኀፀበ፡ አርዳኢሁ። <lb/><hi rend="rubric">፲፰</hi> በእንተ፡ ጰራ<sic>ቀ</sic>ሊጦስ። <lb/><hi rend="rubric">፲፱</hi> በእንተ፡ ስእለተ፡ ሥጋሁ፡ ለእግዚእነ፡
                            </explicit>

                      <msItem xml:id="ms_i1">
                          <locus from="1r" to="202vb"/>
                          <title type="incomplete" ref="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</title>
                          <note>The very last folios are missing, and the first leaves are partly disarranged.</note>
                          <textLang mainLang="gez"/>
                          
                      <msItem xml:id="ms_i1.1">
                            <locus from="73ra" to="73vb"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1548Gessaw">
                                <hi rend="rubric">ግጻዌ፡ ሥርዓት፡ በእንተ፡ ኅብረተ፡ ቃላት፡ ዘ፬፡ ወንጌላት<supplied reason="subaudible">፡</supplied></hi>
                            </title>
                          <note>The text is found on the first part of a loose bifolio, currently found lying in the inner 
                          of the manuscript and foliated 73r–74v. However, based on its placement in other manuscripts, one
                          may presume that it was originally part of the preliminary matters.</note>
                            <incipit xml:lang="gez">
                            <locus target="#73ra"/>
                                እንዘ፡ ይተሉ፡ ረድኤተ፡ ክልኤተ፡ ባሕቲቶሙ፡ ጸሐፉ፡ እንከ፡ 
                                ወንጌል፡ እምሐ<sic>ዊ</sic>ርያት፡ ወክልኤቱ፡ እመትሎሆሙ፡ አሐዱ፡ ዘጳውሎስ፡ 
                                ወአሐዱ፡ ዘጴጥሮስ፡ ወዘጴጥሮስ፡ ረድአ፡ ዚአሁ፡ ምስለ፡ ዮሐንስ፡ ወማቴዎስ፡
                            </incipit>
                            <explicit xml:lang="gez">
                                <locus target="#73vb"/>
                                በእንተ፡ ኅብረተ፡ ቃላት፡ ዘቅዱሳን፡ አርባዕቱ፡ ወንጌላት።=፨
                            </explicit>
                        </msItem>
                          
                        <msItem xml:id="ms_i1.2">
                            <locus from="9ra" to="63ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1558Matthew">Wangel za-Mātewos</title>
                            <note>In the current state of the manuscript, there is no list of tituli for Matthew.</note>
                            <incipit xml:lang="gez">
                                <hi rend="rubric">መጽሐፈ፡ ልደቱ፡ ለ</hi><lb/>ኢየሱስ፡ ክርስቶስ፡ <lb/><hi rend="rubric">ወልደ፡ ዳዊት፡ ወልደ፡</hi> <lb/>አብርሃም፨ አብር<supplied reason="omitted">ሃ</supplied><lb/><hi rend="rubric">ም፡ ወለዶ፡ ለይስሐቅ፡</hi> <lb/>ወይስሐቅኒ፡ ወለዶ፡ <lb/>ለያዕቆብ፡
                            </incipit>
                            <explicit xml:lang="gez">
                                ወናሁ፡ <lb/>አነ፡ ሀለውኩ፡ ምስ<lb/>ሌክሙ፡ በኵሉ፡ መ<lb/>ዋዕል፡ እስከ፡ ኅል<lb/>ቀተ፡ ዓለም፡ አሜን፨
                            </explicit>
                        </msItem>

                        <msItem xml:id="ms_i1.3">
                            <locus from="63rb" to="106ra"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1882MarkGo">Wangel za-Mārqos</title>

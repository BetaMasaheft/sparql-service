      <t:body>
         <t:listPerson>
            <t:person sex="1">
                   <t:persName xml:lang="gez" xml:id="n1" type="birth">ገብረ፡ ሥላሴ፡ ወልደ፡ አረጋይ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gabra Śǝllāse Walda ʾAragāy</t:persName>

               <t:persName>
                  <t:roleName type="title">Ṣaḥāfe tǝʾǝzāz</t:roleName>
                  <t:roleName type="title">&gt;Nǝbura ʾǝd</t:roleName>
               </t:persName>
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>

                  <t:occupation type="literary">chronicler</t:occupation>
               <t:residence>
                  <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName>
               </t:residence>

               <t:birth when="1844">He was born at <t:placeName ref="https://betamasaheft.eu/LOC2246DabraB">
                  Dabra Bǝrhan</t:placeName> in <t:date>1844</t:date>. </t:birth>

               <t:floruit notBefore="1870" notAfter="1912">He was
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName>  Mǝnilǝk II</t:persName>'s
                  private secretary and minister of Pen.
                  He was also served as the dean of the churches of <t:placeName ref="https://betamasaheft.eu/LOC2981Entott">ʾƎnṭoṭṭo Rāguʾel</t:placeName> near
                  <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> and
                  <t:placeName ref="https://betamasaheft.eu/LOC1219AddisA">ʾAddis ʾAlam Māryām</t:placeName>.
                  He began his career as a clerk in the court of
                  <t:persName ref="https://betamasaheft.eu/PRS2342Bafana">
                     <t:roleName type="title">wayzaro</t:roleName> Bāfanā</t:persName>
                  and was transferred to the service of the king in the late<t:date>1870</t:date>s.
                  In <t:date>1889</t:date>, he was promoted to the position of
                  <t:persName ref="https://betamasaheft.eu/PRS4359Gabrase">
                     <t:roleName type="title">Ṣaḥāfe tǝʾǝzāz </t:roleName>
                  </t:persName>
                  and
                  was thereafter regarded as one of the most influential officials of
                  <t:persName ref="https://betamasaheft.eu/PRS7006Menilek">
                     <t:roleName type="title">ʾaṣe</t:roleName> Mǝnilǝk II</t:persName>.
                   In <t:date>1907</t:date> he was appointed Minister of the Pen. Around <t:date>1910</t:date>
                 he moved to <t:placeName ref="https://betamasaheft.eu/LOC1218AddisA">Addis ʿAläm</t:placeName> with the title
               <t:roleName type="title">nǝbura ʾǝd</t:roleName>.</t:floruit>
               <t:death when="1912">He died at <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> in <t:date>1912</t:date>. </t:death>

               </t:person>
               
         </t:listPerson>


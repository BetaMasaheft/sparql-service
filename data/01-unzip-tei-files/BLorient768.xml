<msItem xml:id="ms_i2.1">
<locus from="111r" to="128v"/>
<title xml:lang="en" type="complete">Short anecdotes and sayings numbered from 1 to 48</title>
<incipit xml:lang="gez">ኮነ፡ መነኮስ፡ ጽሙድ፡ ወመስተጋድል፡ ፈድፋደ፡ በጾም፡ ወበጸሎት፡ ዘዓደወ፡ ዓቅሙ፡ እምዓቅመ፡ መነኮሳተ፡ ውእቱ፡ ዘመን።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.2">
<locus from="128v" to="141r"/>

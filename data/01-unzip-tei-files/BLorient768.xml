<textLang mainLang="gez"/>


<msItem xml:id="ms_i2.2.1">
<locus from="128v" to="133v"/>
<title xml:lang="en" type="complete">First letter of John Chrysostom to the monk Theodore</title>
<incipit xml:lang="gez">መልእክት፡ ዘጸሐፋ፡ ቅዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ኀበ፡ ቴያድሮስ፡ ዘወድቀ፡ ወኀደገ፡ ምንኵስና።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.2.2">
<locus from="133v" to="138r"/>
<title xml:lang="en" type="complete">Second letter of John Chrysostom to the monk Theodore</title>
<incipit xml:lang="gez">መልእክት፡ ደጋሚት፡ እምቅዱስ፡ ዮሐንስ፡ አፈ፡ ወርቅ፡ ኀበ፡ ቴዎድሮስ፡ ወልደ፡ እኅተ፡ ዮናስ፡ ሊቀ፡ ጳጳሳተ፡ ሮሜ፡ ዘከልአ፡ እምኔሁ፡ አልባሰ፡ ምንኵስና፡ ወአውሰበ።</incipit>
<textLang mainLang="gez"/>
</msItem>
</msItem>

<msItem xml:id="ms_i2.3">
<locus from="138r" to="141r"/>
<title xml:lang="en" type="complete" ref="https://betamasaheft.eu/LIT4290Dersan">A discourse of Mār Yǝṣḥaq, on seeking after God and renouncing the world</title>
<incipit xml:lang="gez">ድርሳን፡ ዘደረሰ፡ ቅዱስ፡ አባ፡ ይስሐቅ፡ መምህር፡ በእንተ፡ ተኅሥሦ፡ አምላክ፡ ወበተራኅቆ፡ እምዓለም።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.4">
<locus from="141r"/>
<title xml:lang="en" type="complete">Monastic instructions of Isaiah of Scete</title>
<incipit xml:lang="gez">ትእዛዘ፡ አብ፡ ቅዱስ፡ አባ፡ ኢሳይያስ፡ ባሕታዊ፡ ለመንኮሳት፡ ውጡናን።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.5">
<locus from="146v"/>
<title xml:lang="en" type="complete">Doctrine of ʾabbā Bulā</title>
<incipit xml:lang="gez">ኅዳጥ፡ ትምህርት፡ እምአቡነ፡ አባ፡ ቡላ፡ ኅበ፡ ቡሩክ፡ ዝክረ፡ መፍቀርያነ፡ አምላክ፡ ወምክር፡ ክብርት፡ ፈድፋደ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.6">

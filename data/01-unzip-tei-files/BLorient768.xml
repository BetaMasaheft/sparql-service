<msItem xml:id="ms_i1.38">
<locus from="101v"/>
<title xml:lang="en" type="complete">Anecdote narrated by Isaac the Syrian</title>
<incipit xml:lang="gez">ዝንቱ፡ እስትግቡእ፡ ዘጸሐፋ፡ ፩እምቅዱሳን፡ እምቃለ፡ ውዱስ፡ ይስሐቅ፡ ሶርያዊ፡ ሶበ፡ ተስእልዎ፡ አኃው፡ መነኮሳት፡ ነገረ፡ ኑዛዜ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.39">
<locus from="106r"/>
<title xml:lang="gez" type="complete">ዘ፩እምቅዱሳን፡</title>
<incipit xml:lang="gez">ኮነ፡ ኦአኃውየ፡ ወፍቁራንየ፡ ዘውስተ፡ ሀገር፡ ዘይትበሀል፡ ላቲ፡ ሀገረ፡ መዝገበ፡ መኰንን።</incipit>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i1.40">
<locus from="108r"/>
<title xml:lang="gez" type="complete">ዜናሃ፡ ለቅድስት፡ ሱርስት፡</title>
<incipit xml:lang="gez">ኮነ፡ ብእሲ፡ እምአበው፡ ቅዱሳን፡ ዘይትበሀል፡ ሎቱ፡ ሲላስ፡ ዘድልው፡ ለንጽሕ።</incipit>
<textLang mainLang="gez"/>
</msItem>

<colophon xml:lang="gez" xml:id="coloph1">
<locus target="#110v"/>
ተፈጸመ፡ እምዘተረክበ፡ እመጽሐፈ፡ ፵ዜና፡ ዘትሰመይ፡ ገነተ፡ መነኮሳት፡
</colophon>


<title xml:lang="en" type="complete">Anecdotes of Daniel of Scete</title>
<note>Numbered from <foreign xml:lang="gez">፶፩</foreign> to <foreign xml:lang="gez">፶፯</foreign>.</note>
<textLang mainLang="gez"/>
</msItem>

<msItem xml:id="ms_i2.7">

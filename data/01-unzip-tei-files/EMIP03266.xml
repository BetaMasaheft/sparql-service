         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3266/" n="191" corresp="https://betamasaheft.eu/api/iiif/EMIP03266/manifest">Antippas 16</idno>
               </msIdentifier>
               <msContents>
                  <summary>Psalter</summary>
                  <msItem xml:id="ms_i1"><locus from="4r" to="184r" facs="004">Fols 4r–184r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="4r" to="145r" facs="004">Fols 4r–145r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <textLang mainLang="gez">Gǝ'ǝz</textLang>
                      <note>employs the old system of <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> contains only one of the plusses of the long version: the word <foreign xml:lang="gez">ወአድኃኒ፡</foreign></note>
                    </msItem>
                  <msItem xml:id="ms_i1.2"><locus from="145r" to="159r" facs="145">Fols 145r–159r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <note>The fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>“Prayer of Hana, mother of Samuel, prophet.”</q></note>
                  </msItem>
                  <msItem xml:id="ms_i1.3"><locus from="159r" to="166v" facs="159">Fols 159r–166v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Common edition</note>
                </msItem>
                  <msItem xml:id="ms_i1.4"><locus from="167r" to="178v" facs="167">Fols 167r–178v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  <note>Arranged for the days of the week beginning on Monday and culminating on Sunday</note>
                </msItem>
                  <msItem xml:id="ms_i1.5"><locus from="178v" to="184r" facs="179">Fols 178v–184r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
              </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">184</measure>
                           <dimensions type="outer" unit="mm">
                              <height>170</height>
                              <width>170</width>
                              <depth>80</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="17">
                         <locus from="4r" to="166v" facs="004">Fols 4r–166v</locus>
                       </layout>
                       <layout columns="2" writtenLines="17">
                         <locus from="3r" to="3v" facs="003">Fols 3r–3v, </locus>
                         <locus from="167r" to="184r" facs="167">167r–184r</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                      <seg type="rubrication">
                      </seg>
                      <desc>The word for God is unrubricated</desc>
                      <desc><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps150"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps150</span></ref> and <ref type="work" corresp="https://betamasaheft.eu/LIT1566hababa#ThreeYouths3"><span xmlns="" class="w3-tag w3-red">No item: LIT1566hababa#ThreeYouths3</span></ref> display columetric layout of text</desc>
                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote xml:id="d1">
                      <desc>There is a harag or line of alternating red and black lines at the heads of sections of ten Psalms</desc>
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                      <locus target="#2r" facs="002">Fol. 2r</locus>
                      <desc type="Asmat"><title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> and instruction for protection, in heavy black ink in a hand of the twentieth century, in Amharic and in Ge’ez</desc>
                    </item>
                    <item xml:id="a2">
                      <locus target="#3r" facs="003">Fol. 3r</locus>
                      <desc type="Asmat"><title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title> against enemies near and far</desc>
                    </item>
                    <item xml:id="a3">
                      <locus target="#3v" facs="004">Fol. 3v</locus>
                      <desc>List of the feast days for the year</desc>
                    </item>
                    <item xml:id="e1">
                      <locus target="#1v" facs="002">Fol. 1v</locus>
                      <desc>Poem for pen trial</desc>
                    </item>
                    <item xml:id="e2">
                      <locus target="#75r" facs="075">Fol. 75r</locus>
                      <desc>The midpoint of the Psalms is unmarked</desc>
                    </item>
                    <item xml:id="a4">
                      <locus target="#166v" facs="167">Fol. 166v</locus>
                      <desc type="OwnershipNote">
                        The book of Dan’el, <foreign xml:lang="gez">ዳንዔል፡</foreign>,  and to [his] wife, <foreign xml:lang="gez">ወለተ፡ ሳሙኤል፡</foreign>,
                        Walatta Samuel, and to his son, <foreign xml:lang="gez">ዮሐንስ</foreign>, Yohanes
                      </desc>
                    </item>
                    <item xml:id="e3">
                      <desc>Strings are sewn into the fore edge of folios as a navigation system to indicate the location of the major works in the Psalter and for sections of Psalms</desc>
                    </item>
                    <item xml:id="a5">
                      <locus target="#184r" facs="184">Fol. 184r</locus>
                      <desc type="OwnershipNote">
                        Of the original owner: <foreign xml:lang="gez">አርአያ፡ ክርስቶስ.</foreign>, who asks for prayer from the clergy
                      </desc>
                    </item>
                  </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1" type="bindingMaterial">
                        <material key="parchment"/>
                        <material key="wood"/>
                        <material key="leather"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1700" notAfter="1750">Early-eighteenth century</origDate>
                  </origin>
               </history>
            </msDesc>

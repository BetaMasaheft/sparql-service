      <body>
         <listPerson>
            <person sex="1">
               <persName xml:lang="gez" xml:id="n1" type="birth">አርአያ፡ ሥላሴ፡ ድምጹ፡</persName>
               <persName xml:lang="gez" corresp="#n1" type="normalized">ʾArǝʾayā Śǝllāse Dǝmṣu</persName>
               <persName>
                  <roleName type="title">rās</roleName>
               </persName>
               <nationality type="Ethiopia"/>
               <faith type="EOTC"/>
               <occupation type="political">governor</occupation>
               <birth when="1810"/>
               
               
               <floruit notBefore="1829" notAfter="1889">He was a maternal uncle of 
                  <persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                     <roleName type="title">ʾaṣe</roleName>
                  </persName>
                 . 
                  He had aspired to rule over <placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</placeName> 
                  after the death of <persName ref="https://betamasaheft.eu/PRS8265Sabagadi">
                     <roleName type="title">daǧǧāzmāč</roleName>
                  </persName>
                     at the battle of <placeName ref="https://betamasaheft.eu/LOC4676MayEsl">May Ǝslamay</placeName> in <placeName ref="https://betamasaheft.eu/LOC5749Sire">Šire</placeName> 
                     in <date>1829</date>. But 
                  <persName ref="https://betamasaheft.eu/PRS10102Webeha">
                     <roleName type="title">daǧǧāzmāč</roleName>
                  </persName> incorporated <placeName ref="https://betamasaheft.eu/LOC6569Tegray">Tǝgrāy</placeName>
                     with <placeName ref="https://betamasaheft.eu/LOC5498Sallam">Ṣallamt</placeName>, 
                     <placeName ref="https://betamasaheft.eu/LOC6144Wagara">Wagarā</placeName>, <placeName ref="https://betamasaheft.eu/LOC5443Sagade">Ṣägade</placeName>. 
                     He held a high commands under his nephew
                     <persName ref="https://betamasaheft.eu/PRS10378Yohanne">
                  ʾaṣe Yoḥannǝs IV
               </persName> successively as governor of <placeName ref="https://betamasaheft.eu/LOC2947Endart">ʾƎndartā</placeName>, 
                  <placeName ref="https://betamasaheft.eu/LOC1298Akkala">Akkälä Guzay</placeName> and 
                     <placeName ref="https://betamasaheft.eu/LOC2481Dambey">Dambǝyā</placeName>.
                        
                        
                        
                     
            
               </floruit>
               <death when="1889">He died at the battle of <placeName ref="https://betamasaheft.eu/LOC4637Matamm">መተማ፡</placeName>.</death>
               
            </person>  
            
         </listPerson>

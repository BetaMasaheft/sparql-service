                        <additions>
                          <list>
                        <item xml:id="a1">
                            <locus from="1v" to="2r"/>
                            <desc type="GuestText">Declination of the verb <foreign xml:lang="gez">ገብረ፡</foreign>
                           </desc>
                          </item>
                          <item xml:id="a2">
                            <locus from="3v" to="4r"/>
                            <desc type="MalkeHymn"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                              ተሰአልዎ፡ አይሁድ፡ ለኢየሱስ፡</q>
                            <note>With music notation.</note>
                          </item>
                          <item xml:id="a3">
                            <locus from="5v" to="6r"/>
                            <desc type="MalkeHymn"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                              ወሃቤ፡ ሰላም፡ ዘበልዑላን፡</q>
                            <note>With music notation.</note>
                          </item>
                          <item xml:id="a4">
                            <locus target="#7v"/>
                            <desc type="GuestText"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                              ወበከናፍሪነ፡ ለከ፡ ንፌኑ፡ ስብሐት፡ (sic)</q>
                              <note>With music notes.</note>
                          </item>
                          <item xml:id="a5">
                            <locus target="#7v"/>
                            <desc type="GuestText"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                               ቅን፡ ዜነዋ፡ ገብርኤል፡ ለማርያም፡</q>
                              <note>With music notes.</note>
                          </item>
                          <item xml:id="a6">
                            <locus target="#7v"/>
                            <desc type="GuestText"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                              ዕዝ፡ ወረደ፡ ገብርኤል፡ እምሰማያት፡</q>
                              <note>With music notes.</note>
                          </item>
                          <item xml:id="a7">
                            <locus from="57r" to="57v"/>
                            <desc type="MalkeHymn">Part of a malkǝʾ-hymn in honor of <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName>.</desc>
                            <q xml:lang="gez"/>
                          </item>
                          <item xml:id="a8">
                            <locus from="60v" to="63v"/>
                            <desc type="MalkeHymn">Part of a malkǝʾ-hymn in honor of <persName ref="https://betamasaheft.eu/PRS4306GabraMa">Gabra Manfas Qǝddus</persName>.</desc>
                            <q xml:lang="gez"/>
                          </item>
                          <item xml:id="a9">
                            <locus from="64r" to="64v"/>
                            <desc type="GuestText">List of commemoration days of Apostles.</desc>
                            <q xml:lang="gez"/>
                          </item>
                          <item xml:id="a10">
                            <locus from="65r" to="72v"/>
                            <desc type="MalkeHymn"/>
                            <note>Following is the incipit</note>
                            <q xml:lang="gez">
                              ስብሐት፡ ለአብ፡ ስብሐት፡ ለወልድ፡ ስብሐት፡ ለመንፈስ፡ ቅዱስ፡ ሃሌ፡ ሉያ፡</q>
                              <note>With music notes.</note>
                          </item>

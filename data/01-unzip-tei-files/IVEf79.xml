                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="9r" to="72v"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2293Sawase">Sawāsǝw (general record)</title>
                          <textLang mainLang="gez" otherLangs="am"/>

                          <msItem xml:id="ms_i1.1">
                            <locus from="9r" to="37r"/>
                            <title type="complete"> Gǝʿǝz-Amharic vocabulary. </title>
                            <textLang mainLang="gez" otherLangs="am"/>
                            <incipit xml:lang="gez">ሰዋስው፡ ብሂል፡ መሸጋገርያ፡ ወመሰላል፡ ወዓዲ፡ መሰላል፡ ዲበ፡ ላዕለ፡ መልዕልተ፡ ብ፡ በላይ፡ እንዘ፡ ብሂል፡ ሰ፡
                            </incipit>
                        </msItem>
                        <msItem xml:id="ms_i1.2">
                          <locus from="37v" to="38r"/>
                          <title type="complete" xml:lang="gez">ዘይትበልዑ፡</title>
                          <textLang mainLang="gez"/>
                          <note>On the names of edible things.</note>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="38v" to="39r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ አዕዋፈ፡ (sic)</title>
                        <textLang mainLang="gez"/>
                        <note>Names of birds</note>
                          </msItem>
                        <msItem xml:id="ms_i1.4">
                          <locus from="39v" to="45v"/>
                          <title type="complete" xml:lang="gez">ነገረ፡ ዕፀዋት፡</title>
                          <textLang mainLang="gez"/>
                            <note>Names of trees</note>
                    </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="46r" to="46v"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ዕቃ፡ (sic)</title>
                        <textLang mainLang="gez"/>
                        <note>Names of vessels and other things</note>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus target="#47r"/>
                        <title type="complete" xml:lang="en">Names of waters and other things</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="47v" to="48r"/>
                        <title type="complete" xml:lang="gez">ነገረ፡ ፊደል፡</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሀ፡ ብ፡ ሀልዎቱ፡ ለአብ፡</incipit>
                        <note>Spiritual alphabet</note>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus target="#48v"/>
                        <title type="complete" xml:lang="gez">እጽሕፍ፡ ነገረ፡ ሲኖዶስ፡</title>
                        <textLang mainLang="gez"/>
                        <note>Explanation of hierarchical terms</note>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus from="49r" to="51v"/>
                        <title type="complete" xml:lang="gez">እጽሕፍ፡ ነገረ፡ ጳውሎስ፡</title>
                        <textLang mainLang="gez"/>
                        <note>Explanation of difficult words in <ref type="work" corresp="https://betamasaheft.eu/LIT3505PaulineEpis">Pauline Epistles</ref>
                        </note>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="52r" to="52v"/>
                        <title type="complete" xml:lang="gez">ጣዖት፡</title>
                        <note>List of idols's names and other things.</note>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="53r" to="59v"/>
                        <title type="complete" xml:lang="en">List of verbs with direct objects in alphabetical order of the last letter.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ፍኖተ፡ ጼሐ፡ ፍኖተ፡ ተመርሐ፡ እምፍኖት፡ </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="60r" to="72v"/>
                        <title type="complete" xml:lang="en">Glossary.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ሶረፔ፡ ብ፡ ቅዱስ፡ ኤልኮረፕ፡ ብ፡ ሥጋ፡</incipit>
                     </msItem>

                        </msItem>

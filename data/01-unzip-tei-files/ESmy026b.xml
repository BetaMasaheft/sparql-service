               <msContents>
                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="2r" to="3v"/>
                      <title type="incomplete" ref="https://betamasaheft.eu/LIT6176MalkaSadeqanB">Malkǝʾa Ṣādǝqān za-Bāraknāhā</title>
                      <incipit>
                        <locus target="#2r"/>
                         <foreign xml:lang="gez"/>
                         <hi rend="rubric">ሰላም፡</hi> ለአእጋሪክሙ፡ በጽገዓ፡ ሐይማኖት፡ ቅዋሜ፡
                         ምስለ፡ ስኳንው፡ ዘኬደ፡ አርእስተ፡ አርዌ፡
                         ማሕመሜ፡ <hi rend="rubric">ኦጻድቃን፡</hi> እቀቡኒ፡ እስከ፡
                         ፍጻሜ፡ ስዕርተ፡ ርእስየ፡ <sic resp="DN">ጊሜ፡ ምስለ፡</sic> <gap reason="lost"/>ሥሐ፡ ዘበንስሐ፡ ጸግወኒ፡ እድሜ፡
                         </incipit>
                     <note>The text starts with stanza 24 (<bibl corresp="http://zotero.org/groups/358366/items/RSA6WCVU"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Raineri1980Sadqan"/><title level="a">Vita dei giusti: missionari dell'Etiopia nel sesto secolo: varianti e inno</title><title level="j">Ephemerides Carmeliticae</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Osvaldo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Raineri</t:surname></author><date>1980</date><biblScope unit="volume">31</biblScope><biblScope unit="issue">2</biblScope><biblScope unit="page">377-413</biblScope><citedRange unit="page">393-394</citedRange></bibl>) and continues to the end (stanza 32);
                     stanzas 1-23 are missing.
                     </note>

                  </msItem>
               </msContents>

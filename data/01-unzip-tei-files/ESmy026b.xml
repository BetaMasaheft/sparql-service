                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                          <seg type="script">Nineteenth-century script.</seg>
                          <seg type="ink">Black; red (brilliant vermillion).</seg>
                            <date notBefore="1800" notAfter="1899"/>

                        <seg type="rubrication"><foreign xml:lang="gez">ሰላም፡</foreign>
                         and <foreign xml:lang="gez">ጻድቃን፡</foreign> or <foreign xml:lang="gez">ኦጻድቃን፡</foreign>;
                          the word <foreign corresp="gez">አምኃ</foreign> (<locus target="#4v"/>). Elements of the punctuation
                           signs.</seg>
                           <desc>Careful, but irregular, crude; by a poorly trained scribe.
                             The same hand as <ref target="h1">Hand 1</ref> of Ms. MY-026a.</desc>
                     </handNote>
                  </handDesc>
                  <additions>

                                <desc type="Correction">Erasures marked with parallel red and black lines.</desc>
                              </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="Ethiopian">
                        <decoNote xml:id="b1">No boards. One pair of sewing stations, with remains of a thread.
                          The leaves are held together by tackets (thick threads; twisted strips of parchment are visible in the centre fold between
                             <locus target="#4v"/> and <locus target="5r"/>).</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                        </decoNote>

                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="StampExlibris">Ex libris of <persName ref="https://betamasaheft.eu/PRS2916Bruce">James Bruce</persName> glued on the inner front board, containing
                              shelfmarks of the manuscript: 71. Aeth. Cat. 1.
                              Bruce of Kinnaird Nº 1</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>A pagemark of blue textile sewn to the headband.</desc>
                        </item>
                        <item xml:id="e3">
                           <desc>There are occasional small marks and strikes in the margins, possibly by a European hand,
                              for example on <locus target="#33vb">fols. 33vb, </locus>, <locus target="#38ra">38ra, </locus>, <locus target="#46vc">46vc, </locus>, <locus target="#69ra">69ra</locus></desc>
                        </item>
                        <item xml:id="e4">
                           <desc>There are occasional marginal additions of numerals, possibly by a European hand,
                              for example on <locus target="#37v">fols. 37v, </locus> ("v.5"), <locus target="#10vb">10vb, </locus> ("17"), <locus target="#5vc">5vc</locus> ("5").</desc>
                        </item>
                     </list>
                  </additions>
                  
                  <bindingDesc>
                     <binding xml:id="binding">
                        <decoNote xml:id="b1">European binding, red leather with gilded borders. Imprinted on the spine: Old Testam Tom I.
                           Cover of the inner board and first fly-leaf gilded paper with floral pattern.
                           The text block has been trimmed and its edges were gilded. Two paper fly leaves, containing a watermark, at the
                        front and back.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="leather"/>
                           <material key="paper"/>
                        </decoNote>
                     </binding>

                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <date notBefore="1769" notAfter="1771"/>
                        <seg type="script">Written in a fine and beautiful handwriting by one hand.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">The beginning of chapters is indicated by rubrications.</seg>
                     </handNote>

                  <msItem xml:id="ms_i1">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5137MagicPrayer">Magic Prayer</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘእንበለ፡ ቀዲሙ፡ ወተድኅኖ፡ በግጻዊሁ፡ ይትረአይ፡ ዘአስተዋሐደ፡ ምክሮ፡ ለጸላዒ፡ በጠፈረ፡ በረድ፡ ወነድ፡ ዘሐነጸ፡ ማደሮ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5139MagicPrayer">Magic Prayer for Undoing Charms</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ዝንቱ፡ መፍትሔ፡ ሥራይ፡ በኃይለ፡ ዝንቱ፡ አስማቲከ፡ ሠአራ፡ ሥራይ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <title type="complete" ref="https://betamasaheft.eu/LIT5138MagicPrayer">Magic Prayer for Undoing Charms</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ አንተ፡ ዘነበብነ፡ በአፋነ፡ ወበልሳንነ፡</incipit>
                  </msItem>
                </msContents>

      <t:body>
         <t:listPerson>
            <t:person sex="1">
              
                  <t:persName xml:lang="gez" xml:id="n1" type="birth">ገብረ፡ ሕይወት፡ ባይከዳኝ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Gabra Ḥǝywat Bāykadāñ</t:persName>
               <t:persName xml:lang="gez" xml:id="n2" type="alt">“Gabrihet Soernej”</t:persName>
                  
               <t:persName>
                  <t:roleName type="title">naggādrās</t:roleName>
               </t:persName>
                  
                  <t:nationality type="Ethiopia"/>
                  <t:faith type="EOTC"/>
                  
                  
                  <t:occupation type="other">civil servant</t:occupation>
               <t:occupation type="academic">scholar</t:occupation>
               <t:birth when="1886">He was born in the district of <t:placeName ref="https://betamasaheft.eu/LOC1263Adwa">ʿĀdwā</t:placeName> in <t:date>1886</t:date>.</t:birth>
                  
                  
               <t:floruit notBefore="1907" notAfter="1919">He was the most incisive and profound of 
                  the Ethiopian reformist intellectuals of the early 20th century. At his early age,
                  he travelled to <t:placeName ref="https://www.wikidata.org/entity/Q40">Austria</t:placeName> where he was adopted by a family and got medical
                  education in <t:placeName ref="https://www.wikidata.org/entity/Q183">Germany</t:placeName>. 
                  Returning to <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>, he served the Imperial government. 
                  However, he was unhappy to the general adulation of the post-ʾAdwā 
                  <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>, 
                  he pinned his hopes for <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>'s progress and
                  he wrote his book <t:ref type="work" corresp="https://betamasaheft.eu/LIT1160AteMen">Aṭe Mǝnilǝkǝnna Ityoṗya</t:ref> as a recipe for reform that the young prince, 
                  <t:persName ref="https://betamasaheft.eu/PRS5620IyasuV">ʾIyāsu</t:persName> would adopt. 
                  During the early reign of <t:persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</t:persName>,
                  he was an inspector of the Addis Ababa-Djibouti railway in <t:date>1916</t:date>. 
                  He also published his second major work <t:ref type="work" corresp="https://betamasaheft.eu/LIT1874Manges">Mängǝśtǝnna yäḥǝzb astädadär</t:ref>, 
                  a treatise on the political economy of <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName>. </t:floruit>
                 <t:death when="1919"/>
                  
               </t:person>
               
               
         </t:listPerson>
         
         

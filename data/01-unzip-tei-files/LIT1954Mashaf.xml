         <t:div type="edition">
            <t:div type="textpart" subtype="chapter" n="1" xml:id="Treatise1">
               <t:label>First Treatise</t:label>
               <t:div type="textpart" subtype="chapter" xml:id="Treatise1.1">
                  <t:label>
                     <t:foreign xml:lang="gez">Dǝrsān</t:foreign> about Genesis and Exodus</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" xml:id="Treatise1.2">
                  <t:label>
                     <t:foreign xml:lang="gez">Tǝrgʷāme</t:foreign> upon a passage of Ezekiel</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" xml:id="Treatise1.3">
                  <t:label>
                     <t:foreign xml:lang="gez">Rāʾǝy</t:foreign> upon ultimate things</t:label>
               </t:div>
            </t:div>
         
            <t:div type="textpart" subtype="chapter" n="2" xml:id="Treatise2">
               <t:label>Original <t:foreign xml:lang="gez">tǝrgʷāme</t:foreign> on the Revelation of John</t:label>
               <t:div type="textpart" subtype="chapter" n="2.1" xml:id="Treatise2.1">
                  <t:label>Title</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.2" xml:id="Treatise2.2">
                  <t:label>Burial of Moses</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.3" xml:id="Treatise2.3">
                  <t:label>Names of the angels of the seven Asian churches</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.4" xml:id="Treatise2.4">
                  <t:label>The book with seven seals</t:label>
                  <t:desc>The book with seven seals signifies Adam</t:desc>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.5" xml:id="Treatise2.5">
                  <t:label>The lamb with seven horns and seven eyes</t:label>
                  <t:desc>The seven eyes signify the seven books of the Church: <t:ref type="work" corresp="https://betamasaheft.eu/LIT1560Gospel">Four Gospels</t:ref>, <t:ref type="work" corresp="https://betamasaheft.eu/LIT3506CatholicEpis">Catholic
                                                  Epistles</t:ref>, 
                  <t:ref type="work" corresp="https://betamasaheft.eu/LIT1019Actsof">Gǝbra
                                                  ḥawāryāt</t:ref>, <t:ref type="work" corresp="https://betamasaheft.eu/LIT3505PaulineEpis">Pauline
                                                  Epistles</t:ref>,
                  <t:ref type="work" corresp="https://betamasaheft.eu/LIT2317Senodo">Senodos</t:ref>, <t:ref type="work" corresp="https://betamasaheft.eu/LIT3179Revela">Revelation of
                                                  John</t:ref>, <t:ref type="work" corresp="https://betamasaheft.eu/LIT2461Testam">Testamentum
                                                  Domini</t:ref> with <t:ref type="work" corresp="https://betamasaheft.eu/LIT2432Teachi">Teaching of the 318
                                                  Nicene Fathers on the right faith and the monastic
                                                  life</t:ref>.</t:desc>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.6" xml:id="Treatise2.6">
                  <t:label>Explanation of the seven seals</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.7" xml:id="Treatise2.7">
                  <t:label>The blasts of the angels' trumpets</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.8" xml:id="Treatise2.8">
                  <t:label>The mystery of John ʾAbu Qalamsis</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.9" xml:id="Treatise2.9">
                  <t:label>The hidden scriptures</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.10" xml:id="Treatise2.10">
                  <t:label>The seven hidden gifts</t:label>
                  <t:desc>Among the seven gifts which Adam received from God are kingdom and priesthood.</t:desc>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.11" xml:id="Treatise2.11">
                  <t:label>Incredulity when faced with the exposition of the mystery</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.12" xml:id="Treatise2.12">
                  <t:label>The origin of the prophets</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.13" xml:id="Treatise2.13">
                  <t:label>Abraham</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.14" xml:id="Treatise2.14">
                  <t:label>The names of the fathers and mothers of the prophets</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.15" xml:id="Treatise2.15">
                  <t:label>The apostles</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.16" xml:id="Treatise2.16">
                  <t:label>Exegesis of some biblical texts</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.17" xml:id="Treatise2.17">
                  <t:label>Symbolism of the word "lion"</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.18" xml:id="Treatise2.18">
                  <t:label>The wound of the beast</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.19" xml:id="Treatise2.19">
                  <t:label>The number of the beast</t:label>
               </t:div>
               <t:div type="textpart" subtype="chapter" n="2.20" xml:id="Treatise2.20">
                  <t:label>The seven bowls</t:label>

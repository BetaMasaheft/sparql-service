                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Regular, fluent, by well-trained hand.</seg>
                        <seg type="ink">Black; red.</seg>
                        <date>Late 18th cent.</date>
                        <list type="abbreviations">
                           <item>ይ፡ ካ፡ or ይካ፡ for ይበል፡ ካህን፡</item>
                           <item>ይ፡ ዲ፡ or ይዲ፡ for ይበል፡ ዲያቆን፡</item>
                           <item>ይ፡ ሕ፡ or ይሕ፡ for ይበል፡ ሕዝብ፡</item>
                           <item>
                              <abbr>ሕዝ፡</abbr> for <expan>(ይበል፡) ሕዝብ፡ </expan> (s. <locus target="#10ra">10ra</locus>)</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; names of the Patriarch and
                           Metropolitan; headings and incipits of the texts; directives for the
                           ministers; some of the musical notation signs above the lines;
                           abbreviations; elements of the punctuation signs; elements of Ethiopic
                           numerals.
 On fol. 1r, the two upper lines of each column are
                           rubricated.</seg>
                     </handNote>
                  </handDesc>

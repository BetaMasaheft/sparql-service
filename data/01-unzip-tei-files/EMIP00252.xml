                    <title>Office Prayers</title>
                    <incipit xml:lang="gez">በስመ አብ ወወልድ… ለእመ ኮነ በሰንበት ተሠሃልከ እግዚኦ ሃሌ ሃሌ ሉያ ሃሌ ሃሌ ሉያ ሃሌ ሉያ<gap reason="omitted"/></incipit>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <notatedMusic><desc>with musical notation</desc></notatedMusic>
                  </msItem>


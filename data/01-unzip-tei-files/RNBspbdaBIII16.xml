                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="5r"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer">Ṣalotu la-Ṗeṭros</title>
                            <textLang mainLang="gez"/>

                     <msItem xml:id="ms_i1.1">
                        <locus from="5r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Monday">Protective prayer for Monday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎቱ፡ ለጴጥሮስ፡ ዝውእቱ፡ ዘየዐቢ፡ እምሐዋርያቲሁ፡ ዘኃረዮ፡ ክርስቶስ፡ እምቅድመ፡ ኲሎሙ፡ ሐዋርያቲሁ፡ ለኢየሱስ፡
    ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ወጸውዖሙ፡ ለኲሎሙ፡ ሐዋርያቲሁ፡ ምስሌሆሙ፡ ወባረኮሙ፡ <foreign xml:lang="en">In the name <gap reason="ellipsis" resp="PRS9602Turaev"/> a prayer of Peter, the chief Apostle of Him,
  chosen by Christ in front of all Apostles of Jesus Christ, Son of the living God. He summoned all His Apostles, stayed with them and blessed them.</foreign>
                        </incipit>
                     </msItem>

                     <msItem xml:id="ms_i1.2">
                        <locus from="11r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps90">Psalm 90.</title>
                        <textLang mainLang="gez"/>
                     </msItem>

                     <msItem xml:id="ms_i1.3">
                        <locus from="12r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday1">Protective prayer for Tuesday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎት፡ በእንተ፡ መልከ፡ ጼደቅ፡ ወበእንተ፡ ጰራቅሊጦስ፡ <foreign xml:lang="en">In the name of
    <gap reason="ellipsis" resp="PRS9602Turaev"/> a prayer of Melchizedek and Paraclete.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="15v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Tuesday2">The second protective prayer for Tuesday.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ጸሎተ፡ ምሕረት፡ ዘጸለዩ፡ መላእክት፡ ወሰማዕት፡ ጳጳሳት፡ ካህናት፡ <foreign xml:lang="en">Prayer of mercy, which is pronounced by angels, martyrs, bishops, priests.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="19r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps120">Psalm 120.</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="19v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Wednesday3">Ṣalotu la-Ṗeṭros, Another prayer for Wednesday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎተ፡ ሥርዓተ፡ እምነቶሙ፡ ለሐዋርያት፡ ወድኃኒተ፡ ነፍስ፡ ወሥጋ፡ ወመንጽሔ፡ ኃጢአት፡ <foreign xml:lang="gez">The prayer
    of the ordination of the faith of the Apostles, the salvation of soul and body, and purification of sins.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="23r"/>
                        <title type="complete" corresp="LIT4668Prayer#Wednesday2">Protective prayer for Thursday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ወይቤልዎ፡ መላእክት፡ ታስተኃፍሮሙ፡ ለእለ፡ ደገምዎ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.8">
                        <locus from="30r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Friday">Protective prayer for Friday.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ቅዱሳን፡ አስማቲሁ፡ ለክርስቶስ፡</incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.9">
                        <locus from="36r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Saturday">Protective prayer for Saturday.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎተ፡ ሥርየተ፡ ኃጢአት፡ ወሥርየተ፡ እምነቶሙ፡ ለሐዋርያት፡ ወለኲሎሙ፡ ፸ወ፪አርድእት፡ ከማሁ፡ ይቤሎሙ፡ ለአርዳኢሁ፡
    ኢየሱስ፡ አንትሙ፡ ውእቱ፡ አዕርክትየ፡ <foreign xml:lang="en">The prayer of remission of sins and forgiveness of the faith of the Apostles and all 72 disciples, as Jesus said to His disciples: 'You are my friends!'</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.10">
                        <locus from="43r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps139">Psalm 139</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.11">
                        <locus from="44r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Sunday">Protective prayer for Sunday.</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> በርናኤል፡ አጉዳኤል፡ ፍለኤል፡ ዘንተ፡ እስማተ፡ ዘወሀቦ፡ እግዚአብሔር፡ ለአናንያ፡ ወአዛርያ፡ ወሚሳኤል፡
      <foreign xml:lang="en">In the name of <gap reason="ellipsis" resp="PRS9602Turaev"/> Barnāʾel, ʾAgudāʾel, Fǝlaʾel - these are the names, which God gave to Ananias, Azariah, and Mishael.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.12">
                        <locus from="48r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Andrew">Another protective prayer for Sunday</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> አስማተ፡ ዘነገሮ፡ እግዚእነ፡ ለቅዱስ፡ እንድርያስ፡ ረድዕ፡ ሐዋርያ፡ ወሰማዕት፡ <gap reason="ellipsis" resp="PRS9602Turaev"/>
    ወይቤሎ፡ ሑር፡ በሀገረ፡ በላዕተ፡ ሰብእ፡ <foreign xml:lang="en">In the name of <gap reason="ellipsis" resp="PRS9602Turaev"/> Names, which Our Lord told to St Andrew, the disciple, Apostle, and martyr
  <gap reason="ellipsis" resp="PRS9602Turaev"/> And he told him: 'Go to the country of cannibals!'</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.13">
                        <locus from="52r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps51">Psalm 51.</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.14">
                        <locus from="52r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps66">Psalm 66.</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.15">
                        <locus from="53v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Daily">Daily prayer</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ተማኅፀንኩ፡ ከመ፡ ኢይሙት፡ ዘእንበለ፡ ጊዜየ፡ <foreign xml:lang="en">I received in trust that I would not die untimely.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.16">
                        <locus from="54v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer#Enoch">Prayer that was revealed to Enoch by angels</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="PRS9602Turaev"/> ጸሎት፡ ዘነገርዎ፡ መላእክት፡ ለሄኖክ፡ <foreign xml:lang="en">In the name of <gap reason="ellipsis" resp="PRS9602Turaev"/> Prayer, that angels revealed to Enoch.</foreign>
                        </incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.17">
                        <locus from="57r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps19">Psalm 19.</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.18">
                        <locus from="57r"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps20">Psalm 20.</title>
                        <textLang mainLang="gez"/>
                     </msItem>
                     <msItem xml:id="ms_i1.19">
                        <locus from="58v"/>
                         <title type="complete" ref="https://betamasaheft.eu/LIT2082Otawar">Hymn to Jesus Christ</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">ኦዘወረድከ፡ እምሰማይ፡ በእንቲአነ፡ <foreign xml:lang="en">Oh, You, who descended fron the heaven on behalf of us!</foreign>
                        </incipit>
                         <notatedMusic><desc>With musical notation.</desc></notatedMusic>
                     </msItem>
                     <msItem xml:id="ms_i1.20">
                        <locus from="59v"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1191Baenta">Baʾǝnta śǝllāseka</title>
                        <textLang mainLang="gez"/>
                        <incipit xml:lang="gez">በእንተ፡ ሥላሴከ፡ እግዚኦ፡ ተሣሀለነ፡ በእንተ፡ ህላዌከ፡ እግዚኦ፡ ተሣሃለነ፡ <foreign xml:lang="gez">Have mercy on us on behalf of Your Trinity, have mercy on us on behalf of Your Nature</foreign>
                        </incipit>
                     </msItem>
                        </msItem>

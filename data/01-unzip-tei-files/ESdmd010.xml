                              <dim type="left">6</dim>
                              <dim type="intercolumn">8</dim>
                           </dimensions>
                           <note>All data are for <locus target="#3r">3r</locus>.</note>
                           <ab type="ruling"/>
                           <ab type="pricking">Pricking and ruling are visible. </ab>
                           <ab type="ruling" subtype="pattern"> Ruling pattern:
                              1A-1A-1A1A/0-0/0-0/C. </ab>
                           <ab type="pricking"> Primary pricks are partly visible. </ab>
                           <ab type="pricking"> Ruling pricks are partly visible. </ab>
                           <ab type="ruling"> The upper line is written above the ruling. </ab>
                           <ab type="ruling"> The bottom line is written above the ruling.</ab>
                           <ab type="ruling" subtype="pattern"> On <locus target="#19">19</locus>
                              and 26, ruling pattern: 1A-1A-1A1A/0-0/0-0/C.</ab>
                        </layout>
                        <layout/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine and careful.</seg>
                        <seg type="ink">Black, vivid red, deep vermilion.</seg>The handwriting is
                        similar, but not identical to that of scribe <persName role="scribe" ref="https://betamasaheft.eu/PRS10788WaldaMuse">Walda Muse</persName> (of Mǝdra Ruba
                           Śǝllāse).<date>18th cent.</date>
                        <seg type="rubrication">Nomina sacra (only St Mary); name of the
                           protagonist, name of the donor Walda Mikāʾel (only on fol. 2rb); incipit
                           of the text and of each miracle; elements of the punctuation signs;
                           elements of Ethiopic numerals.
 The title ʾabuna is added to the
                           names of the donors by secondary hand in deep vermilion (fols. 4va, 5va,
                           7rb).</seg>
                     </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <desc type="findingAid">Several short stitches with a green thread at the
                              outer margin of <locus target="#13">fol. 13</locus>.</desc>
                        </item>
                        <item xml:id="e2">
                           <desc>Incipit of each miracle is crudely encircled in pencil. </desc>
                        </item>
                        <item xml:id="e3">
                           <desc>Scribbles and crude drawings in recent hands: fols. 1rv, 6v, 8v, 9v, 14v, 21rv, 26v.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="false">
                        <decoNote xml:id="b1">Two wooden boards (front board is broken and

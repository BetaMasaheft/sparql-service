                        </support>
                        <extent>Made of <measure unit="leaf">26.0</measure> folios, in <measure unit="quire">5.0</measure> quires ((A+4)). <dimensions type="outer">
                              <height unit="mm">197</height>
                              <width unit="mm">135</width>
                              <depth unit="mm">125</depth>
                           </dimensions>
                        </extent>
                        <foliation/>
                        <collation>
                           <list>

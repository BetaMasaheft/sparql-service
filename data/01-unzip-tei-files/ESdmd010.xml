                                 <dim unit="leaf">1</dim>
                                 <locus target="#1"/>
                                 A(1; s.l.: 1, stub after 1/fols. 1r - 1v) </item>
                              <item xml:id="q2">
                                 <dim unit="leaf">10</dim>
                                 I(10/fol. 2r - 11v) </item>
                              <item xml:id="q3">

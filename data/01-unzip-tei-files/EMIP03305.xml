               <msContents>
                  <summary>Book of Asmat Prayers</summary>
                  <msItem xml:id="ms_i1"><locus from="2r" to="55v" facs="002">Fols 2r–55v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2866RepCh147">, with Asmat Prayers</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">55</measure>
                           <dimensions type="outer" unit="mm">
                              <height>123</height>
                              <width>94</width>
                              <depth>60</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="12"/>
                     </layoutDesc>
                  </objectDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#10v" facs="011">Fol. 10v</locus><desc>A male <ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#11r" facs="011">Fol. 11r</locus><desc>A female <ref type="authFile" corresp="https://betamasaheft.eu/AT1105HolyWoman">Holy Woman</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#19v" facs="020">Fol. 19v</locus><desc>Man standing</desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#24v" facs="025">Fol. 24v</locus><desc>chart of 10 columns and 9 rows</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#25r" facs="025">Fol. 25r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> standing with a prostrate person behind.  To the left is a chart of 4 columns and 7 rows</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#30r" facs="030">Fol. 30r</locus><desc>chart of 8 columns and 7 rows</desc></decoNote>
                    <decoNote type="miniature" xml:id="d7"><locus target="#35v" facs="036">Fol. 35v</locus><desc>two snakes devouring the other’s tail.  This is a unique version of this visual theme in that the snakes do not form a circle</desc></decoNote>
                    <decoNote type="miniature" xml:id="d8"><locus target="#37r" facs="037">Fol. 37r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> standing with a prostrate person behind.  To the left is a chart of 3 columns and 6 rows</desc></decoNote>
                    <decoNote type="miniature" xml:id="d9"><locus target="#46v" facs="047">Fol. 46v</locus><desc>text inside of a placard with ornate edges</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#20r" facs="020">Fol. 20r</locus>
                    <desc>
                    Arranged for the days of the week by the original hand: Wednesday
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    The folios are stained and worn. A second set of images were made with infrared lens.  This second set of images follows the first set of images with normal lens
                    </desc>
                    </item>
                  </list>
                </additions>

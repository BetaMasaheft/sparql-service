      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ወበዋሕናሁ፡ ተክፍሎ፨</l>
                  <l n="2">ወበተክፍሎቱ፡ ዋሕድና፡ አምሳለ፡ ፀሓይ፡ ዘትማሰሎ፨</l>
                  <l n="3">ውዳሴ፡ መልክዑ፡ እጽሕፍ፡ እንዘ፡ እሴብሕ፡ ወአሌዕሎ፨</l>
                  <l n="4">ለጴጥሮስ፡ ሰማዕት፡ አመ፡ በእንተ፡ ሕዝብ፡ ሰአሎ፨</l>
                  <l n="5">ተፍጻሜተ፡ ሰማዕት፡ እንተ፡ ዘአምላክ፡ ይቤሎ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ ወልደ፡ ዮና፡ ክቡር፨</l>
                  <l n="2">ወለሥዕርትከ፡ ሰላም፡ ዘጠለ፡ ዮርዳኖስ፡ ፀምር፨</l>
                  <l n="3">ሊቀ፡ ጳጳሳት፡ ጴጥሮስ፡ ወሰማዕተ፡ ሥቃይ፡ መሪር፨</l>
                  <l n="4">አሐሊ፡ ለከ፡ ማሕሌተ፡ ከመ፡ በዐሥር፡ አውታር፨</l>
                  <l n="5">ንጉሠ፡ እስራኤል፡ ሐለየ፡ ለታቦት፡ ዘጾር፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በሕገ፡ ጳጳሳት፡ ክቡራን፨</l>
                  <l n="2">ወለመቃብሪከ፡ ሰላም፡ በእስክንድርያ፡ ምካን፨</l>
                  <l n="3">ተፍጻሜተ፡ ደሞሙ፡ ለሰማዕታተ፡ ጽድቅ፡ አሚን፨</l>
                  <l n="4">አሰበ፡ ጽራኅየ፡ በነቢበ፡ ዝንቱ፡ ድርሳን፨</l>
                  <l n="5">ዕረፍተ፡ ሥሩሓን፡ ሀበኒ፡ በሐዳስ፡ ዘመን፨</l>
               </lg>
            </div>
            <div type="textpart" xml:id="tarafa-malke">
               <lg type="stanza" n="1">
                  <l n="1">ማዕረረ፡ ገድልከ፡ አባ፡ ሶበ፡ አልጸቀ፡ ተቅራማ፨</l>
                  <l n="2">አዋልደ፡ ክብር፡ አክሊላት፡ መልዕልተ፡ ርእስከ፡ ቆማ፨</l>
                  <l n="3">አስካለ፡ መልክእከ፡ ዘንት፡ እምገራህተ፡ ልሳን፡ ይቅስማ፨</l>
                  <l n="4">እስመ፡ ዮም፡ ሕዋሲቲከ፡ አዋልደ፡ ብዙኀ፡ ጻማ፨</l>
                  <l n="5">ግብረ፡ ዘወሀ፡ በኮን፡ ፈጽሞ፡ ፈጸማ፨</l>
               </lg>
               <lg type="stanza" n="5">
                  <l n="1">ሰላም፡ እብል፡ ለጴጥሮስ፡ የማኖ፨</l>
                  <l n="2">ሊቀ፡ ጳጳሳት፡ በተክህኖ፨</l>
                  <l n="3">ለአርዮስ፡ ዕልው፡ ግዘተ፡ ሥጋሁ፡ ኰነኖ፨</l>
                  <l n="4">ለወልደ፡ ማርያም፡ ሶበ፡ ነጸረ፡ ሥኖ፨</l>
                  <l n="5">እንዘ፡ እኁዝ፡ በእዴሁ፡ ሥጡጠ፡ ገርዜኖ፨</l>
               </lg>
               <lg type="stanza" n="6">
                  <l n="1">ሰላም፡ ለከ፡ ሰባኬ፡ ሃይማኖት፡ በጥንቃቄ፨</l>
                  <l n="2">አምሳለ፡ ጳውሎስ፡ ዘአተሰሎንቄ፨</l>
                  <l n="3">ዕፀ፡ መድኃኒት፡ ጴጥሮስ፡ ወዕፀ፡ ሐዲስ፡ ኢሎቄ፨</l>
                  <l n="4">አዕዋፈ፡ ሰማይ፡ ዘሞርሞቄ፡ እንተ፡ ጸለይከ፡ እምዕንቈ፨</l>
                  <l n="5">እፎኑመ፡ ጊዜ፡ ሰርክ፡ አውዐየከ፡ መርቄ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
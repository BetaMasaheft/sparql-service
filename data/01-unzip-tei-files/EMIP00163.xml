                    <list>
                      <item xml:id="a1">
                        <locus target="#1r #1v #2r #2v #3r #3v #182r #182v #183r #183v #184r #184v" facs="001 002 003 004 182 183 184 185">Fols. 1r, 1v, 2r, 2v, 3r, 3v, 182r, 182v, 183r, 183v, 184r, 184v</locus>

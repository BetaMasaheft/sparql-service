                      <locus target="#48r #157r #177r" facs="048 157 177">48r, 157r, 177r, </locus> (a line of alternating red and black dots);
                      <locus target="#141v #182r" facs="142 182">141v, 182r</locus> (a line of full stops between lines of alternating red and black dots)
                    </decoNote>

      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምክሙ፡ ዘሀሎ፡ ወይሄሉ፨</l>
                  <l n="2">ለሥዕርተ፡ ርእስክሙ፡ ወለገጽክሙ፡ ወለዐይንክሙ፡ ብርሃነ፡ ኵሉ፨</l>
                  <l n="3">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ለንግሥክሙ፡ በብዝኀ፡ ሣህሉ፨</l>
                  <l n="4">እምአዕይንትየ፡ ንዋመ፡ ዝንጋዔ፡ አብጥሉ፨</l>
                  <l n="5">ወርእሰ፡ ኅሊናየ፡ ዘልፈ፡ ሉዓሌ፡ አልዕሉ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለአእዛኒክሙ፡ ወለመላትሒክሙ፡ ምስለ፡ አእናፍ፨</l>
                  <l n="2">ለከናፍሪክሙ፡ ወለአፉክሙ፡ ቀቀበ፡ ጰራቅሊጦስ፡ ሰይፍ፨</l>
                  <l n="3">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ከመ፡ ዜነወ፡ መጽሐፍ፨</l>
                  <l n="4">ምሉእ፡ ሥላሴክሙ፡ እስከነ፡ ጽንፉ፡ ለጽንፍ፨</l>
                  <l n="5">ዘኢይበጽሐ፡ እግረ፡ ብእሲ፡ ወመልአክ፡ በክንፍ፨</l>
               </lg>
               <lg type="stanza" n="11">
                  <l n="1">ሰላም፡ ለመልክእክሙ፡ ዘባን፡ እንተ፡ ድኅር፨</l>
                  <l n="2">እምርእስ፡ ቀዳሚ፡ እስከ፡ አእጋር፨</l>
                  <l n="3">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ምሉኣነ፡ ሰማይ፡ ወምድር፨</l>
                  <l n="4">በከመ፡ ሰማዕነ፡ ባሕቱ፡ ንአግር፨</l>
                  <l n="5">እመፈ፡ ሙሴ፡ ነቢይ፡ ወኦኤጥሮስ፡ መምህር፨</l>
               </lg>
               <lg type="stanza" n="12">
                  <l n="1">ስብሐት፡ ወክብር፡ ይደሉ፡ ለአብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፨</l>
                  <l n="2">እምጽንፉ፡ ለባሕር፡ እስከ፡ ማⷍለቅታ፡ ለየብስ፨</l>
                  <l n="3">እምአፈ፡ መላእክት፡ ወሰብእ፡ ወእመፈ፡ ቅሲስ፨</l>
                  <l n="4">እንዘ፡ ይብል፡ ጊዜ፡ ነግህ፡ ንሤልስ፨</l>
               </lg>
               <lg type="stanza" n="13">
                  <l n="1">አብ፡ ወላዲ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ እንዘ፡ ትብሉ፡ ንክዐው፡ ነገሮሙ፨</l>
                  <l n="2">ድኅረ፡ ተሠገወ፡ እማርያም፡ ቃለ፡ ዚአክሙ፨</l>
                  <l n="3">በውስተ፡ ዮርዳኖስ፡ ወበታቦር፡ መካነ፡ ስብሐት፡ ዘስሙ፨</l>
                  <l n="4">እስመ፡ ተጠየቀ፡ ሥላሴክሙ፡ በበ፡ አርአያሁ፡ ወአቅሙ፨</l>
                  <l n="5">ኅሊና፡ መላእክት፡ ወሰብእ፡ ይገኒ፡ ለክሙ፨</l>
               </lg>
            </div>
         </div>
      </body>

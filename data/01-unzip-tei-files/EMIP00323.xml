               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="100r" facs="001">Fols 1r–100r</locus><title type="incomplete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                  <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  <note>Psalms of David, beginning at the second part of Ps. 72</note>
                  <note>Psalm 118 does not contain the spiritual meanings of the Hebrew letters</note>
                </msItem>
               </msContents>

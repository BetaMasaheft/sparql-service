                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1">
                        <locus target="#Inside front cover" facs="001">Fols. Inside,, </locus>
                        <desc>Sketch of a church (top), sketch of church (bottom), sketches of people a sketch of Alaqä Kahnu, under an umbrella, with a student nearby with caption <q>"Däbra Ḍäḥay," “He learned from Qoma (a well-known church) and taught at Däbra Ḍäḥay,” “student”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d2">
                        <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                        <desc>A soldier with a rifle with caption <q>“Kidanä Wäldä Täklu”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d3">
                        <locus target="#52v" facs="055">Fol. 52v</locus>
                        <desc>Hand-Drawn Seal of the owner: Sign of the Cross with the name of Kahnu written into the sign</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d4">
                        <locus target="#53r" facs="055">Fol. 53r</locus>
                        <desc>Drawing of the church, in pencil</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d5">
                        <locus target="#53v" facs="056">Fol. 53v</locus>
                        <desc>Drawing of the church, in pencil with caption <q>“This is the Church of Saint George,” “The painter is Lǝj Śahǝlu Kidanä Wäld”</q>
                        </desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d6">
                        <locus target="#54r" facs="056">Fol. 54r</locus>
                        <desc>Drawing of the teacher and his students, in pencil</desc>
                     </decoNote>
                    <decoNote type="miniature" xml:id="d7">
                        <locus target="#Inside back cover" facs="057">Fols. Inside,, </locus>
                        <desc>sketches of the church</desc>
                     </decoNote>
                    <decoNote type="frame" xml:id="d8">
                      Decorative designs:
                      <locus target="#11r #29r #46v #49r #52v" facs="013 031 049 051 055">fols. 11r, 29r, 46v, 49r, 52v</locus> (line of alternating red and black dots)
                    </decoNote>

          <msContents>
            <summary/>
            <msItem xml:id="ms_i1">
              <locus from="1r" to="49r" facs="002"/>
              <title type="complete" ref="https://betamasaheft.eu/LIT3851Hassab">We have written a computus that we will remember in order not
          to congregate with apostates...</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i2">
              <locus from="51r" to="64v" facs="052"/>
              <title>Twenty-eight charts for the calculation of the epact, feast days, and other
                holy days, each containing 19 columns</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i3">
              <locus from="66r" to="70v" facs="067"/>
              <title>Twenty-eight further charts for the calculation of the epact, feast days, and
                other holy days, each containing five or six columns</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i4">
              <locus from="70v" facs="072"/>
              <title>A chart for the calculation of the time of the day and night, containing 12
                columns</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i5">
              <locus from="71r" to="71v" facs="072"/>
              <title>Two charts, each with seven columns, about the days of the week from Wednesday
                through Tuesday</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i6">
              <locus from="72r" to="73r" facs="073"/>
              <title>Seven charts, each with nine columns, for the calculation of feast days,
                especially Easter</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i7">
              <locus from="73r" facs="074"/>
              <title>Two charts, each of eight columns, based on the cycle of the years of the
                Evangelists (Matthew, Mark, Luke, John)</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i8">
              <locus from="73v" facs="075"/>
              <title>Four charts, each with five columns, detailing morning, noon and night
                (columns), for the months (rows)</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i9">
              <locus from="74r" facs="075"/>
              <title>One circular chart, divided into 28 segments, organized around the geography of
                the known world and the movement of time through the months of the year</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i10">
              <locus from="74v" facs="076"/>
              <title>Two charts, each with nine columns, detailing aspects of each of the months of
                the year (across the columns)</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
            <msItem xml:id="ms_i11">
              <locus from="77r" to="78r" facs="078"/>
              <title>Three circular charts depicting the Half of Heaven (<foreign xml:lang="gez">መንፈቀ ሰማይ</foreign>), arranged according to the cardinal points: West at top,
                South on the right, East on the bottom, North on the left</title>
              <textLang mainLang="gez">Gǝ'ǝz</textLang>
            </msItem>
          </msContents>

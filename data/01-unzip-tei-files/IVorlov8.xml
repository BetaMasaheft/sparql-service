                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">                 
                          <seg type="script">19th century</seg>
                        <seg type="ink">Black, red</seg>
                        <desc>The name of the scribe, <persName role="scribe" ref="https://betamasaheft.eu/PRS12623TaklaMaryam">Takla Māryām</persName>, is mentioned on 
                           <locus target="#74"/>; B. Turaev indicates that the text has been written in several hands.
                 </desc>
                     </handNote>
                  </handDesc>


                  <decoDesc>
                     <decoNote type="other" xml:id="d1">
                        <locus target="#1v"/>
                        <desc>Headpiece (ornamental band) filled with floral motifs (coloured leaves).</desc>
                     </decoNote>

                  </decoDesc>

                  <additions>


                       <list>

                          <item xml:id="a1">
                             <desc type="PoemQene"><term key="Qene" ana="#Qene">Poem, possibly qəne</term></desc>
                             <locus target="#75r"/>
                           <q xml:lang="gez">
                              <l n="1">ዮም፡ ኮኑ፡ ሰዓተ፡ ሐተታ፡ ፩ደ፡ መርዔት፡ ቅድመ፡ ገጸ፡ መምህር፡ ፪ቱ፡</l>
                              <l n="2">መምህረ፡ ዚአነ፡ ዓይን፡ እስመ፡ ለንጉስ፡ ማህቶቱ፡</l>
                              <l n="3">ወእመ፡ ዜና፡ አእምሮ፡ ልብ፡ እንዘ፡ ወላዲቱ፡</l>
                              <l n="4">ይእቲ፡ ዓመቱ፡ ወንግሥተ፡ ጻድቅ፡ ሃይማኖቱ፡</l>
                              <l n="5">ለተዋህዶ፡ ቃል፡ ዮሴፍ፡ እንበለ፡ ኑፋቄ፡ ፍህርቱ፡</l>
                              <l n="6">ካህዶናትሂ፡ ውስተ፡ ልቡና፡ ለእመ፡ ሐተታ፡ ሐተቱ፡</l>
                              <l n="7">ንጽሓ፡ ልብ፡ ወንጽሓ፡ ሥጋ፡ ለፈቀደ፡ እግዚእ፡ ደቂቀ፡ ቤቱ፡</l>
                              <l n="8">አምጣነ፡ ትሕትና፡ ወፍቅር፡ እምኀበ፡ ዚአሁ፡ ተከሥቱ፡</l>
                              <l n="9">ወደቂቀ፡ አብርሃም፡ ምግባራት፡ እምቅድመ፡ ገጹ፡ ይትዓተቱ። </l>
                           </q>

                          </item>
                          </list>

                  </additions>

                  <bindingDesc>
                     <binding contemporary="true" xml:id="binding">

            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0301IV">Institut Vostočnyh Rukopisej Rossijskoj Akademii Nauk</repository>
                  <idno>IV Orlov 8</idno>

                  <altIdentifier>
                    <idno>IV Ef. 59</idno>
                    </altIdentifier>

                    <altIdentifier>
                     <idno>Turaev cat. III.17</idno>
                  </altIdentifier>
                        </msIdentifier>

                        <msContents>
                            <summary/>
                            <msItem xml:id="ms_i1">
                                <locus from="9r" to="75r"/>
                                <title ref="https://betamasaheft.eu/LIT1097Ammest">ቃለ፡፡ሃይማኖት፡</title>
                                <note>Despite the different title, <persName ref="https://betamasaheft.eu/PRS9602Turaev">Turaev</persName> identifies the
                                  text as ʾAmmǝstu ʾaʿǝmāda mǝśṭir</note>

                                <msItem xml:id="ms_i1.1">
                                    <locus from="9r"/>
                                   <title type="incomplete" ref="https://betamasaheft.eu/LIT1546Genesi">ስነ፡፡ፍጥረት፡፡ኦሪት፡፡ዘልደት፡</title>
                                    <textLang mainLang="gez"/>
                                    <note>The first four chapters of Genesis.</note>
                                </msItem>


                                <msItem xml:id="ms_i1.2">
                                    <locus from="19v"/>
                                    <title ref="https://betamasaheft.eu/LIT1097Ammest#Trinity">Chapter about the mystery of the Trinity
                                    </title>
                                      <textLang mainLang="am"/>
                                   <incipit xml:lang="am">ክፍል፡፡የምሥጢረ፡፡ሥላሴ፡፡እንዴት፡</incipit>
                                </msItem>

                                <msItem xml:id="ms_i1.3">
                                    <locus from="42v"/>
                                    <title ref="https://betamasaheft.eu/LIT1097Ammest#BaptismMystery">Chapter about the mystery of the Baptism</title>
                                    <textLang mainLang="am"/>
                                   <incipit xml:lang="am">የምሥጢረ፡፡ጥምቀትሰ፡፡ነገረ፡፡እንዴት፡</incipit>
                                </msItem>

                                <msItem xml:id="ms_i1.4">
                                    <locus from="54v"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1097Ammest#Eucharist">Mystery of the Incarnation</title>
                                    <textLang mainLang="am"/>
                                   <incipit xml:lang="am">የምሥጢረ፡፡ቍርባንሰ፡</incipit>
                                  </msItem>

                                <msItem xml:id="ms_i1.5">
                                    <locus from="62r"/>
                                    <title type="incomplete" ref="https://betamasaheft.eu/LIT1097Ammest#Resurrection">Mystery of the Resurrection</title>
                                    <textLang mainLang="am"/>
                                    <note>The beginning is missing.</note>
                                </msItem>

                                <msItem xml:id="ms_i1.6">
                                    <locus from="70r"/>
                                    <title ref="https://betamasaheft.eu/LIT1097Ammest#Introduction">
                                      Introduction</title>
                                      <textLang mainLang="am"/>
                                      <note>Introduction has been missed by the scribe,
                                         who wrote it, very carelessly, after <locus target="#73">fol. 73</locus>, 
                                         indicating with the words <foreign xml:lang="gez">ዘተረስዓ፡ መቅድም፡</foreign> 
                              <foreign xml:lang="en">Introduction that was forgotten</foreign>.</note>
                                </msItem>


                            </msItem>
                        </msContents>

               


               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">ii + 185</measure>
                           <dimensions type="outer" unit="mm">
                              <height>155</height>
                              <width>162</width>
                              <depth>85</depth>
                           </dimensions>

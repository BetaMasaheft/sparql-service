               <msContents>
                  <summary>Psalter, ዳዊት፡</summary>
                  <msItem xml:id="ms_i1"><locus from="1r" to="184v" facs="003">Fols 1r–184v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>

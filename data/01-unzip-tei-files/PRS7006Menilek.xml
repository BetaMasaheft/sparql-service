         <listPerson>
            <person sex="1" sameAs="wd:Q244748">
               <persName xml:lang="gez" xml:id="n1" type="regnal">ምኒልክ፡</persName>
               <persName xml:lang="en" corresp="#n1" type="normalized">Mǝnilǝk <addName>II</addName></persName>
               <persName xml:lang="gez" xml:id="n2" type="alt">ዳግማዊ ምኒልክ፡</persName>
               <persName xml:lang="gez" corresp="#n2" type="normalized">Dāgmāwi Mǝnilǝk</persName>
               <persName xml:lang="gez" xml:id="n3" type="birth">ምኒልክ፡</persName>
               <persName xml:lang="gez" corresp="#n3" type="normalized">Mǝnilǝk</persName>
               <persName xml:lang="gez" xml:id="n4" type="baptismal">ሣህለ፡ ማርያም፡</persName>
               <persName xml:lang="gez" corresp="#n4" type="normalized">Śahla Māryām</persName>
               
               <persName>
                  <roleName type="title">ʾaṣe</roleName>
               </persName>
               
               <faith type="EOTC"/>
               
               
               <occupation type="ruler">Emperor</occupation>
               
               <birth when="1844">He was born at <placeName ref="https://betamasaheft.eu/LOC1465Ankoba">Ankobär</placeName> in <date when="1844">1844</date>. </birth>
               <floruit notBefore="1889" notAfter="1913">Mǝnilǝk is regarded as the founder of the modern Ethiopian state. 
                  After the death of his father King <persName ref="https://betamasaheft.eu/PRS5205haylaMa">Ḫāyla Malakot</persName>,   
                  in the course of the proclamation of King <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName> in <date when="1855">1855</date>, Mǝnilǝk, then aged 11, 
                  was taken into captivity to the imperial court at <placeName ref="https://betamasaheft.eu/LOC4547Maqdal">Maqdalā</placeName>. There, he was treated with much respect, 
                  and married
                  to <persName ref="https://betamasaheft.eu/PRS9430Tewodros">Tewodros</persName>’s daughter <persName ref="https://betamasaheft.eu/PRS1771AltasTe">Alṭaš Tewodros</persName>. In <date when="1865">1865</date>, as the 
                  emperor’s power waned, 
                  Mǝnilǝk escaped from <placeName ref="https://betamasaheft.eu/LOC4547Maqdal">Maqdalā</placeName> and was received 
                  with joy in <placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</placeName> as its rightful king. 
                  During the period from <date from="1878" to="1889">1878  until 1889</date>, Mǝnilǝk 
                  was a quasi independent ruler of <placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</placeName>, 
                  where he laid the foundation of his subsequent rule as emperor. 
               </floruit>
               <death when="1913" evidence="internal"/>
               
            </person>
            
            

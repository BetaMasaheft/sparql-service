         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Weiner</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/2297/" n="24" corresp="https://betamasaheft.eu/api/iiif/EMIP02297/manifest">Weiner Codex 291</idno>
               </msIdentifier>
               <msContents>
                  <summary>Asmat prayer for protection from evil based on Luke 8:43ff, the story of the healing of the woman with the hemorrhage who touched the hem of Jesus’ garment.Amulet accordion fold book, prepared for the tourist industry.</summary>
                <msItem xml:id="ms_i1">
                  <locus from="1r1" to="1r48" facs="001">First side of manuscript lines 1-48</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer">ʾAsmāt-prayer
                                                  (general record)</title>
                  <textLang mainLang="gez">Gǝ'ǝz</textLang>
                </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <dimensions type="outer" unit="mm">
                              <height>78</height>
                              <width>77</width>
                              <depth>26</depth>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="48"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic"><seg type="rubrication"><foreign xml:lang="gez">ኢየሱስ፡</foreign></seg></handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#1r" facs="001">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref>,<persName ref="https://betamasaheft.eu/PRS4585Georgeo">St George of Lydda</persName> and the <term key="dragon" ana="#dragon"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#1r" facs="002">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1031VirginAndChild">Virgin and Child</ref> with two figures</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#1r" facs="003">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#1r" facs="004">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1082Angel">Angel</ref> seated on a cloud</desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#1r" facs="005">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> before four figures, two of which are shown in profile. Perhaps the Resurrection of Jesus Christ, raising Adam and Eve from the dead?</desc></decoNote>
                    <decoNote type="miniature" xml:id="d6"><locus target="#1r" facs="006">Fol. 1r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref> with two figures shown in profile</desc></decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1">
                        <desc>This is an accordion-fold codex oriented as a wall hanging and prepared for the tourist industry.
                          A braided rope is bound into the top cover. This rope can be used both to hold the codex closed as well as to hang the codex</desc>
                      </item>
                    </list>
                  </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                      <decoNote xml:id="b1">Accordion-fold codex attached to covers covered with tooled leather, two strips of parchment.</decoNote>
                      <decoNote xml:id="b2" type="bindingMaterial">
                        <material key="leather"/>
                        <material key="parchment"/>
                      </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>

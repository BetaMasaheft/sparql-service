                <msContents>
                  <summary>
                  </summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r1" to="1r34">Fols 1r1–1r34</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4599Salot">Ṣalot baʾǝnta māʾśaromu la-ʾagānǝnt wa-bāryā wa-legewon budā<certainty locus="value" match="../@ref" cert="medium"/></title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">
                      በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ፡ ጸሎት፡ በእንተ፡ ማዕሠሮሙ፡
                    ለአጋንንት፡ ባርያ፡ ወሌጌዎን፡ ዘይሰልብ፡ ልበ፡ ሰብእ፡</incipit>
                  </msItem>
                  <msItem xml:id="ms_i2">
                    <locus from="1r35" to="1r69">Fols 1r35–1r69</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2709Matthew">Bǝsrāta Mātewos</title>
                    <textLang mainLang="gez"/>
                    <note>8.28-32</note>
                  </msItem>
                  <msItem xml:id="ms_i3">
                    <locus from="1r70" to="1r127">Fols 1r70–1r127</locus>
                    <title type="incomplete" ref="https://betamasaheft.eu/LIT2711Mark">Bǝsrāta Mārqos</title>
                    <textLang mainLang="gez"/>
                    <note>1.23-28</note>
                  </msItem>
                  <msItem xml:id="ms_i4">
                    <locus from="1r128" to="1r195">Fols 1r128–1r195</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1763Legend">Ṣalot za-qǝddus Susǝnyos baʾǝnta ʾasassǝlo dawe</title>
                    <textLang mainLang="gez"/>
                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ማዕሠሮሙ፡ ለአጋንንት፡ ባርያ፡ ወሌጌዎን፡
                      በእንተ፡ ሱስንዮስ፡ ወበእንተ፡ አሰስሎ፡ ደዌ፡ እምሕፃናት፡
                    </incipit>
                  </msItem>

                            <origDate notBefore="1700" notAfter="1895">18th/19th century, but not after 1895.</origDate>
                        </origin>
                        <provenance>A strip from a scroll, probably the last of three or four strips. Another smaller strip, probably forming the part of
                            the scroll immediately before, is preserved as <ref type="mss" corresp="https://betamasaheft.eu/BLorient4943">London, British Library, BL Oriental 4943</ref> in the same library.
                            Two consecutive owners are mentioned in one of the strips: 
                            <persName role="owner" ref="https://betamasaheft.eu/PRS14646GabraTH">Gabra Takla Hāymānot</persName> and
                            <persName role="owner" ref="https://betamasaheft.eu/PRS14647GabraKidan">Gabra Kidān</persName>
                        </provenance>
                        <acquisition>Bought from <persName role="owner" ref="https://betamasaheft.eu/PRS14645WAJudah">W. A. Judah</persName>.
                            <date when="1895-09-25"/>.</acquisition>

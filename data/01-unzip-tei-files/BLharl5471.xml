                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1" to="3">Fols 1–3</locus>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT1398Fethat">Formula of absolution (<foreign xml:lang="gez">ፍትሐት፡</foreign>)</title>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="4" to="14">Fols 4–14</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur#Ps119">Psalms of David, Psalmus 119</title>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="14v" to="26">Fols 14v–26</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                            <note>Divided into five sections</note>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="26" to="38">Fols 26–38</locus>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1113Anqasa">ውዳሴ፡ ማርያም</title>
                            <incipit xml:lang="gez">
                                <locus target="#26">Fol. 26</locus>
                                ቅድስት፡ ወብፅዕት፡ ስብሕት፡ ወቡርክት፡ ወልዕልት፡ አንቀጸ፡ ብርሃን፡ መዓርገ፡ ሐይወት፡ ወማኅደረ፡ መለኮት፡ ቅድስተ፡ ቅዱሳን፡ <gap reason="omitted" extent="unknown" resp="PRS4805Grebaut PRS9530Tisseran"/>
                            </incipit>
                            <note>Called <ref type="work" corresp="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</ref> in the title, the work is in reality the ʾAnqaṣa bǝrhān</note>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="39" to="58">Fols 39–58</locus>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT2246salotz">ጸሎታ፡ ለእግዝእትነ፡ ማርያም፡ ዘጸለየት፡ አመ፡ <choice>
                           <sic resp="PRS3562Dillmann">፳ወ፬ለወርሐ፡</sic>
                           <corr resp="MV">፳ወ፩ለወርኀ፡</corr>
                        </choice> ስኔ፡ በደብረ፡ ጎልጎታ፡ ዝውእቱ፡ መቃብረ፡ እግዝእትነ፡</title>
                        </msItem>

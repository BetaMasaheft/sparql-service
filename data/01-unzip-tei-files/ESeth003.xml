                  <handDesc>
                     
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Mediocre but careful.</seg>
                        <seg type="ink">Black; reddish-brown; dark red (names of the donors in
                           supplication formulas).</seg>
                        <date>Late 19th – early 20th cent.</date>
                        <list type="abbreviations">
                           <item>(ይ)ካ፡ for (ይበል፡) ካህን፡</item>
                           <item>(ይ)ዲ፡ for (ይበል፡) ዲያቆን፡</item>
                           <item>(ይ)ሕ፡ for (ይበል፡) ሕዝብ፡</item>
                           <item>ቡራ፡ for ቡራኬ፡</item>
                        </list>
                        <seg type="rubrication">Nomina sacra; name of the ruling King (not always,
                           s. fol. 30rb); names of the donors; incipits and headings of the texts;
                           directives for the ministers; the word ሃሌ፡ ሉያ፡; some of the musical
                           notation signs above the lines; abbreviations (sometimes partially
                           rubricated); elements of the punctuation signs; elements of Ethiopic
                           numerals.
 
 In fols. 3r, 16r, 43r, 53r and 56r, the text is
                           written alternately in red and black lines.</seg>
                     </handNote>
                  </handDesc>

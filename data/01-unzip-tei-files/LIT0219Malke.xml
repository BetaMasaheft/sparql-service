      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">አውሎግሶን፡ አውሎግሶን፡ አውሎግሶን፡ ጌርዮስ፨</l>
                  <l n="2">እንዘ፡ እብል፡ ሥልሰ፡ በስመ፡ ኢየሱስ፡ ክርስቶስ፨</l>
                  <l n="3">ማሕሌተ፡ ስምከ፡ እጽገይ፡ ይምርሐነ፡ ክርስቶስ፡ ቀሲስ፨</l>
                  <l n="4">ስቅየኒ፡ ለገነትከ፡ እምአስራበ፡ መንፈስ፡ ቅዱስ፨</l>
                  <l n="5">ወገዳመ፡ ልብየ፡ አርዊ፡ በጠልከ፡ ፈውስ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ለዘበአሚን፡ ይስሚ፨</l>
                  <l n="2">ዘያስተፌሥሕ፡ አልባበ፡ አምሳለ፡ ስቴ፡ ወይን፡ ከራሚ፨</l>
                  <l n="3">ይምርሐነ፡ ክርስቶስ፡ ካህን፡ ትእዛዘ፡ ወንጌል፡ ፈጻሚ፨</l>
                  <l n="4">ክድነኒ፡ ትርሲተ፡ መርዐ፡ ዘኢተኬነዎ፡ አናሚ፨</l>
                  <l n="5">ርእዮ፡ ይትኀፈር፡ ዐይነ፡ ፀር፡ ማሕማሚ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሰላም፡ ለመቃብሪከ፡ እስትጉቡአ፡ ዘኮነ፨</l>
                  <l n="2">እምአመ፡ ድርሳኑ፡ ተወጥነ፨</l>
                  <l n="3">ይምርሐነ፡ ክርስቶስ፡ ከማከ፡ ዘአዕረገ፡ ቍርባነ፨</l>
                  <l n="4">እንበለ፡ መልከ፡ ጼዴቅ፡ ኄር፡ ኢሰማዕነ፨</l>
                  <l n="5">እምቀደምት፡ አበዊነ፡ ድንግል፡ ወካህን፡ ነሢኦ፡ ሥልጣነ፨</l>
               </lg>
               <lg type="stanza" n="22">
                  <l n="1">አስተማሲልየ፡ ፍጥረታተ፡ ዕሥር፡ ወክልኤተ፨</l>
                  <l n="2">ዘአቅረብኩ፡ ለከ፡ ተወኪፈከ፡ ማሕሌተ፨</l>
                  <l n="3">ይምርሐነ፡ ክርስቶስ፡ ባዕል፡ እስመ፡ አምሰይኩ፡ ምሴተ፨</l>
                  <l n="4">ኢታንትገኒ፡ እግዚየ፡ እምቀደምትየ፡ ፍጥረተ፨</l>
                  <l n="5">ወኢትፍልጠኒ፡ ሊተ፡ እምርስትከ፡ ርስተ፨</l>
               </lg>
            </div>
         </div>
      </body>

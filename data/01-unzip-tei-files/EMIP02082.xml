                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="34v" facs="003">Fols 1r–34v</locus>
                     <title>Chants called School Chants <foreign xml:lang="gez">ቃልየ፡, የቃል፡ ትምህርት፡</foreign></title>

                     <locus from="43v" to="64v" facs="046">Fols 43v–64v</locus>
                     <title>Chants called School Chants <foreign xml:lang="gez">ስምዓኒ፡, የቃል፡ ትምህርት፡</foreign></title>
                     <incipit xml:lang="gez">‎ስምዓኒ፡ እግዚኦ፡ ጸሎትየ፡ ሃሌ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉ፡ ሃሌ፡ ‎‎ሉያ፡ ወይ፡ ሃሌ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ‎‎ወኢትሚጥ፡ ገጸከ፡ እምኔየ፡<gap reason="omitted"/></incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                     <notatedMusic><desc>with musical notation</desc></notatedMusic>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="65r" to="80v" facs="067">Fols 65r–80v</locus>
                     <title>School Chants for Feast Days</title>
                     <incipit xml:lang="gez">እትፌሳሕ፡ ልሳንየ፡ በጽድቀ፡ ዚአከ፡ <gap reason="omitted"/> ትከሥት፡ ከ[ና]ፍርየ፡ ወአፉየ፡ ያየድአ፡ ስብሐቲከ፡ <gap reason="omitted"/>
                     </incipit>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                  </msItem>

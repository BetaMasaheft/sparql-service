               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="2v">1r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0126IHA">نظم نحمد الله ربّي على جلّ نعمه</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>اواى سلام عليك اواى سلام عليك اواى سلام عليك صلواة الله عليك. نحمد الله ربى على جل نعمه| ببعث رسول الله صفوة الحضرة| وبنعمة الاسلام تفضل علينا| وبجعلنا أيضا من اخير أمة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>وعلى آله كذا وازواجه جمعا| وعلى أنصاره وكل الصحابة| فيا رب أحينا حياة طيبة |امتنا عند الأجل بحسن الخاتمة</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="2v" to="3v">2v-3v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1722IHA">نظم حمدا لك ربنا خالق الأشياء</title>
                     <incipit xml:lang="ar">
                        <locus target="#2v">-2v</locus>يا مصطفى الانام يا مصطفى الأنام يا مصطفى الأنام عليك السلام. حمدا لك ربنا خالق الاشياء| اوجدت لنا سرا من درة البهاء| هو النبى المحبوب صدر المقربين| به طابت الارواح طربا بالهناء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>وأبدع خلق الله مستغرق الجمال |سفينة السيار الى بحر الأسرار | ومحل الأنوار ومقام الكمال</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="3v" to="5r">3v-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1104IHA">نظم يا امام الحرام كنز مطلسم</title>
                     <incipit xml:lang="ar">
                        <locus target="#3v">-3v</locus>اللهم صل على محمد اللهمو صل على محمد يا امام الحرم كنز مطلسم. قام ببابنا سر من الحب| فاسكر قلبا شراب منهم| طاب لنا المراد ابدا لنا الجواد| سرا مكرما قلبا يهيم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>على أصحابه ءاووّ نصروا| والهداية بهم أنجم| ما دام السيار ينفتح له| أسرار غيوب كان مكتم. تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="5v" to="6r">5v-6r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1106IHA">نظم محمد بحر الهداية محمد برق العناية</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>محمد سلام عليكم صلاة الله على خير البرايا. محمد بحر الهدايه| محمد برق العناية| أيا حادى المطايا| إلى أخير البرايا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#6r">-6r</locus>وكذا على الاصحاب| هم ولاة ذاك الباب |ما ذاق أهل المحبه شرابا يقلع اللبا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="6r" to="7v">6r-7v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT1111IHA">نظم محمد ذخر الهداية محمد بؤق العناية</title>
                     <incipit xml:lang="ar">
                        <locus target="#6r">-6r</locus>محمد سلام عليكم سيدى سلام عليكم صلاة الله على خير البرايا. محمد ذخر الهدايه| محمد برق العنايه| محمد ظل الالاه| يا له من ظل اللاه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7v">-7v</locus>صلاة الذات العليه | على الحضرة السنيه| ومع الأل الولاة| قدوة ذوى الخيرات</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="7v" to="8v">7v-8v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0129IHA">نظم جمال بدأ من فوق العزّ</title>
                     <incipit xml:lang="ar">
                        <locus target="#7v-8r">-7v-8r</locus>أوىنبى أوى نبى اوى نبى أوى نبى محمد نبى سلام عليكم. جمال[بد]  من فوق العز| دل محتاجا فقال هزى| ايا عاشقين هلموا إلى نجر سرا عن قطب لؤى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#8v">-8v</locus>وعلى الأل وكل الأصحاب |من أول الكرام وكذ الأحباب

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="8v" to="9v">8v-9v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0130IHA">نظم أول نشء الوجود وسر الله الودود</title>
                     <incipit xml:lang="ar">
                        <locus target="#8v">-8v</locus>صلى الله على محمد صلى الله على محمد محمد علم الهدى محمد. أول نشأ الوجود| وسر الله الودود| وسر الله المطلسم |ألسر السارى المزمزم</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9v">-9v</locus>على أفضل الوجود| معدن الفضل والجود| مع صحبه والأل| ولمن له موالى

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i7">
                     <locus from="9v" to="10v">9v-10v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0182IHA">نظم تجلى من أحبه كرامًا</title>
                     <incipit xml:lang="ar">
                        <locus target="#9v">-9v</locus>صلاة الله سلام الله من محمد هاشمى عرب. تجلى من أحبه كرما| فأبدا لى من سناه عجيب|حمياه طابت لنا ورودا| دارت كأسالن بها طرب</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#10v">-10v</locus>وعلى الأل والأصحاب طرى| ما قال الحب هاشمي عرب

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i8">
                     <locus from="10v" to="12v">10v-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0193IHA">نظم هبت نسيمات الأسرار</title>
                     <incipit xml:lang="ar">
                        <locus target="#10v">-10v</locus>الصلاة والسلام على النبى خير الأنام. هبت نسيمات الأسرار| ليلة الخميس فى الأسحار| أبدت لنا خيال من| اصل الجمال والأنوار</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>صل وسلم عليه| بهج بجماله| وعلى الأل والاصحاب| ما دام الكون بربه

</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i9">
                     <locus from="12v" to="12v">12v-12v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT1425IHA">نظم طاف بنا ظبي كامل</title>
                     <incipit xml:lang="ar">
                        <locus target="#12v">-12v</locus>رب صل وسلم على النبى المبجل رب صل وسلم على النبى المبجل. طاف بنا ظبى كامل بين تلك المنازل| فلاز لنا نتمايل كالأغصان الممايل</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#12v">-12v</locus>بين عيسى وكليم بين نوح وخليل| يا جيبا</explicit>
                     <note/>
                     <note/>
                  </msItem>

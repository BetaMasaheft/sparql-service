        <t:profileDesc xmlns:t="http://www.tei-c.org/ns/1.0">
            <t:creation/>
            <t:abstract>
                <t:p>A miniature showing two or more Holy Women, typically 
                    <t:persName ref="https://betamasaheft.eu/PRS6820MaryMag">Mary Magdalene</t:persName> and Marta,
                    advance towards an empty Tomb that symbolizes the resurrection of 
                    <t:persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus</t:persName> and an Angel. The soldiers sent to 
                    guard the Tomb are often included.
                </t:p>
            </t:abstract>

                  <additions>
                                    <list>
                           <item xml:id="a1">
                              <desc type="OwnershipNote"/>
                              <locus target="#2v"/>
                              <q xml:lang="ar"/>
                              <q xml:lang="en">This book is a property of the monastery of <placeName ref="https://betamasaheft.eu/INS0302SantoStefano"> St. Stephan </placeName>  in the vicinity of St. Peter in Vatican; it is meant to be deposited (here) forever, for
                                 the use of the Coptic and Ethiopian monks who reside there. Acquiring it in whatever way is forbidden.
                               </q>
                           </item>
                             </list>
                     <list>
                        <item xml:id="a2">
                           <desc type="CalendaricNote"/>
                           <locus target="#102r"/>
                           <q xml:lang="gez">ጾመ፡ ነኔዌ፡ ለእመ፡ ረከብከ፡ ፪ወስክ፡ ፲ወ፬ወስክ። በአተ፡ ጾም፡ ትረክብ፡ ፪ወስክ፡
                              ፲ወ፬ወስክ፡ ደብረ፡ ዘይት፡ ትረክብ፡ ፱ወስክ፡ ፋሲካ፡ ትረክብ። ፫ወስክ፡ ረክብ፡ ትረክብ፡ ፲ወ፰ወስክ፡ በዓለ፡
                              ፵ትረክብ፡ ፳ወ፰ወስክ፡ በዓለ፡ ፶ትረክብ፡ ፫ወስክ፡ ምህላድኅነት፡ ትረክብ፡ </q>
                           <q xml:lang="en"> If you have found the Fast of Nineveh, add 12. You will find the
                              beginning of the Fast. Add 2, add 14, you will find Dabra Zayt. Add 9,
                              you will find Easter. Add 3, you will find Rakǝb. Add 18, you will
                              find the feast of 30 (days). Add 28. you will find Pentecost. Add 3,
                              you will find the Rogation of Salvation </q>
                        </item>

                        <item xml:id="a3">
                           <desc type="OwnershipNote"/>
                           <locus target="#103v"/>
                           <q xml:lang="gez">ዛቲ፡ መጽሐፍ፡ ዘቢ፡ ዘን፡ ወንጌለ፡ ዮሐንስ፡ ወቀለምሲስ፡ ዘሰረቃ፡ ወዘተአገላ፡ ዘእንበለ፡ ድስጡር፡ ባእለ፡ ቤት፡ ትእዛዝ፡ ሐዋርያት፡ ይኩኖ </q>
                           <q xml:lang="en">This book is of <placeName ref="https://betamasaheft.eu/LOC2251DabraB">Dabra Bizān</placeName>,  the Gospel of John and Qalamsis;
                              the one who steals it and takes it away
                              without sertificate, the chief of the house of the apostolic order will punish him</q>
                           <note>The translation is unclear</note>

                        </item>
                     </list>


                  </additions>


                  <bindingDesc>
                     <binding contemporary="false" xml:id="binding">
                        <decoNote xml:id="b1"> 
                           <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> states that the binding is made of leather, is not Ethiopian.
                           On the microfilm it is possible to discern that
                        the binding is composed of two wooden boards covered with (blind-tooled?) leather.
                        The volume is probably sewn on two pairs of sewing stations</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                              <material key="wood"/>
                                 <material key="leather"/>
                        </decoNote>
                     </binding>

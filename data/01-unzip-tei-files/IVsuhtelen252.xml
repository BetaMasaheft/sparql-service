                  <summary/>

                  <msItem xml:id="ms_i1">
                    <locus from="1ra" to="65vb"/>
                    <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1693John">Gospel of John</title>
                     <textLang mainLang="gez"/>
                     <incipit xml:lang="gez">
                        <hi rend="rubric">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩አምላክ፡</hi>ብስራተ፡ ቅዱስ፡ ዮሐንስ፡ ወልደ፡
                        ዘብዴዎስ፡ ሐዋርያ፡ ቡሩክ፡ ጸሎቱ፡ የሃሎ፡ ምስሌነ፡
                        ለዓለመ፡ ዓለም፡ አሜን፡ </incipit>
                     <explicit xml:lang="gez">
                        <hi rend="rubric">ተፈጸመ፡ ወንጌል፡</hi>ዘዮሐንስ፡ በዝየ፡ ቃሉ፡ ፳፻ወ፯፻። ወኵሉ፡ ቃላቲሁ፡ ለወንጌል፡ ጽድቅ፡ ወእምርእሱ፡ እስከ፡ ተፍጻሜቱ፡ ለሊሁ፡
                        ወልድ፡ ተናገረ። ጸልዩ፡ ለዘአጽሐፎ፡ ወንጌለ፡ መለኮት፡ ወውእቱ፡ ፅዩአ፡ ኃጢአት፡ እምቦ፡ ዘገደፍኩ፡ እምቃሉ፡ ከመ፡ ይስረይ፡ ለተ።
                     </explicit>
                     <note> &gt;The text is divided into 19 chapters <q xml:lang="gez">mǝʿǝrāf</q>;
                        <persName ref="https://betamasaheft.eu/PRS9602Turaev">Boris Turaev</persName> does not indicate exactly how it is done, in the body of the text or through indications in the margins </note>
                     </msItem>

                    <msItem xml:id="ms_i1.2">
                        <locus from="66ra" to="99vb"/>
                       <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3179Revela">Revelation of John</title>
                       <incipit xml:lang="gez">
                        <hi rend="rubric">ዘዮሐንስ፡ እጲስ፡</hi> ቆጶስ፡ ዘቍስጥንጥያ፡ ምጥረ፡ ጶሊስ፡ አመ፡ ሀለዎ፡ ይሰደድ፡ ራእዮ፡ ለዮሐንስ፡ ዘከመ፡ ርእዮ፡ ለኢየሱስ፡
                          ክርስቶስ፡ ዘወሀቦ፡ እግዚኣብሔር፡ ከመ፡ ያርእዩሙ፡ ለአግብርቲሁ፡ ዘሀሎ፡ ይኩን፡ ፍጡነ።
                           </incipit>
                       <explicit xml:lang="gez">ዝየ፡ ተፈጸመ፡ ራእየ፡ ዮሐንስ፡ አቡቀለምሲስ፡ ዘውእቱ፡ ብሂል፡ ዘርእየ፡ በሕይወቱ፡ ራእየ፨
                          ወእመቦ፡ ዘገደፍኩ፡ ወዘወሰኩ፡ በኢያእምሮ፡ ስረዩ፡ ወባረኩ፡ ላዕሌየ፡ ወኢትርስዑኒ፡ በሞትየ፡ ወበሕይወትየ፡ ሶበ፡ አንበብክምዋ።
                       </explicit>

                  </msItem>
                                             

               </msContents>


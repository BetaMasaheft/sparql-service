                     <relation name="syriaca:has-relation-to-place" ref="http://syriaca.org/documentation/relations.html#has-relation-to-place" active="https://betamasaheft.eu/PRS13306BaMaryam" passive="https://betamasaheft.eu/INS0071FBM">

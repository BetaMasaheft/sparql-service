                     <locus from="37r" to="39v" facs="041">Fols 37r–39v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat prayer of the Archangel Michael</title>
                  </msItem>
                  <msItem xml:id="ms_i7.2">
                     <locus from="39v" to="40r" facs="044">Fols 39v–40r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat prayer of the Archangel Gabriel</title>
                  </msItem>
                  <msItem xml:id="ms_i7.3">
                     <locus from="40r" to="40r" facs="044">Fols 40r–40r</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT5888AsmatPrayer"> Asmat prayer of the Archangel Rufael</title>
                  </msItem>
                  <msItem xml:id="ms_i7.4">

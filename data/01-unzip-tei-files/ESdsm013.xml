                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">Hand a: <locus from="1r" to="24v">1r-24v</locus>
                        <seg type="script">Fine, regular, with up-right
                           letters.</seg>
                        <seg type="ink">Black, red (vivid vermilion)</seg>
                        <date>17th century</date>
                        <seg type="rubrication">Nomina sacra; name of the donor (?); some lines on
                           the incipit page, alternating with black lines; two initial lines of each
                           sub-section of tText I; the words: ʿadi (fol. 6rc), elements of punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>
                     
                     <handNote xml:id="h2" script="Ethiopic"> Hand b: <locus from="25r" to="152v">25r-152v</locus>
                        <seg type="script">Fine, but somewhat inferior, with smaller letters, up-right or
                           slightly right sloping, with small
                           hairlines.</seg>
                        <seg type="ink">Black, red (vivid vermilion)</seg>
                        <seg type="rubrication">Nomina sacra; name of the donor (?); some lines on
                        the incipit page, alternating with black lines; two initial lines of each
                        sub-section of tText I; the words:  kǝfl (e.g., fols.
                        41rb, 62vc, 63rc), fǝkkāre (e.g., fols. 136ra, 137ra, 139rc), śalǝs
                        (e.g., fols. 137rc, 138rb, 139rc), yǝbe (e.g., fols.147ra, 147vb, 148ra);
                        elements of punctuation signs; elements of Ethiopic numerals.</seg>
                     </handNote>

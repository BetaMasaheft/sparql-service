                     <msItem xml:id="ms_i1.16">
                        <locus from="169v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1900Martyr">ስምዕ፡ ዘሠላስ፡ ደናግል፡ ዘበ፡ ሮሜ፡ እለ፡ 
                  አስማቲሆን፡ ጲስጢስ፡ ወአላጲስ፡ ወአጋጲስ።</title>
                        <incipit xml:lang="gez">
                     ዘወድአ፡ ተዘርአ፡ ፍጹም፡ ቃል፡ ውስተ፡ ኵሉ፡ ዘመትሕተ፡ ሰማይ፡ በእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ወመድኀኒነ፡ ወመሐረ፡ ፍጥረተ፡ ሰብእ፡ ዘገብረ፡ ይእመኑ፡
                   በእግዚአብሔር፡
                  </incipit>
                     </msItem>
                
                     <colophon xml:id="coloph1" xml:lang="gez">
                        <note>The colophon states that the manuscript was written at the monastery of <placeName ref="https://betamasaheft.eu/INS0336EAG">ʾƎndā ʾAbbā Garimā</placeName> at the order of
                    its administrator <persName ref="https://betamasaheft.eu/PRS8744Semon">Sǝmʿon</persName>.</note>
                  ተጽሕፈት፡ ዛቲ፡ መጽሐፍ፡ ገድል፡ ሰማዕት፡ በ<placeName ref="https://betamasaheft.eu/LOC4388Madara">መደራ</placeName>፡ በ<placeName ref="https://betamasaheft.eu/INS0336EAG">ቤተ፡ አባ፡ ገሪማ፡</placeName> በቅዱስ፡ መካን።
                        ወዘአጽሐፋ፡ <persName role="patron" ref="https://betamasaheft.eu/PRS8744Semon">ስምዖን፡</persName>
                        <persName ref="https://betamasaheft.eu/PRS8744Semon">
                           <roleName type="office">ንቡረ፡ እድ፡</roleName>
                        </persName>
                        ዘ<placeName ref="https://betamasaheft.eu/INS0336EAG">ቤተ፡ አባ፡ ገሪማ።</placeName> ወለዘ፡ አጽሐፋ፡ ወለዘ፡ ጸሐፋ፡ ሕቡረ፡
                  ይምሐሮሙ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                     </colophon>
                  </msItem>
              

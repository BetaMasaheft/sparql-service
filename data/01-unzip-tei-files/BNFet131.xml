                     <msItem xml:id="ms_i1.1">
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1898Martyr">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ።
                      ዝንቱ፡ ዜናሁ፡ ለቅዱስ፡ ማማስ፡ ሰማዕት፡ ወአቡሁ፡ ቴዎዶጦስ፡ ወእሙ፡ ቴዎፊና፡ ጸሎቶሙ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez">
                      ወኮነ፡ ስምዖሙ፡ ለኵሎሙ፡ ቅዱሳን፡ በሕማም፡ ወምንዳቤ፡ ወከመ፡ አባግዕ፡ ዘይጠንኁ፡ ከማሁ፡ ይገብሩ፡ ላዕለ፡ ሰማዕቱ፡ ለክርስቶስ።
                      ወበፍሥሓ፡ ወሐሤት፡ ፍጡነ፡ ይረውጹ፡ ውስተ፡ ስምዕ።
                      ወኮነ፡ በውእቱ፡ መዋዕል፡ ብእሲ፡ እምሰብአ፡ ሀገር፡ እንተ፡ ስማ፡ ቴቅላ፡ ዘመንገለ፡ ምዕራበ፡ ብሔረ፡ ሮሜ። ወዝንቱሰ፡ ቴዎዶጦስ፡ 
                      ወብእሲቱ፡ ቴዎፊና፡ እምዐበይት፡ ወእምቀደምት፡ እለ፡ የኀድሩ፡ ውስተ፡ ይእቲ፡ ሀገር፡ ወጥቀ፡ ሠናይ፡ ግብሮሙ፡
                    </incipit>
                        <note>The leaves have been misplaced during binding and should be in the order:
                    <locus target="#1"/>, <locus target="#13"/>, <locus target="#15"/>,
                    <locus from="11" to="12"/>, <locus target="#16"/>, <locus target="#14"/>,
                      <locus from="2" to="10"/>. <locus from="17" to="18"/>.</note>
                     </msItem>
                
                     <msItem xml:id="ms_i1.2">
                        <locus from="18v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1895Martyr">ገድል፡ ወስምዕ፡ ዘቅዱስ፡ ኤውስጣቴዎስ፡
                    ወብእሲቱ፡ ወክልኤ፡ ደቂቁ፡ ዘኮኑ፡ ሰማዕተ፡ በመዋዕለ፡ መርቂያኖስ፡ ንጉሥ፡ ጸሎቶሙ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez">
                    ወኮነ፡ በሣልሳይ፡ ዓመተ፡ መንግሥቱ፡ ለመርቅያኖስ፡ ንጉሥ፡ ላዕለ፡ ሮሜ፡ ብእሲ፡ ዘስሙ፡ እብራቄዴስ፡ ሊቀ፡ ሐራሁ፡ ለንጉሥ፡ ጽኑዕ፡ ወኀያል፡ ምሁረ፡ ቀትል፡
                    ወንዒወ፡ ወይንዑ፡ ሀየላተ፡ ወቶራ፡ ወወይጠለ፡ ወኵሎ፡ አራዊተ፡ ወእንስሳ። ወስማ፡ ለብእሲቱ፡ ጥጥዩና፡ ወቦሙ፡ ክልኤ፡ ደቀቀ፡ 
                  </incipit>
                     </msItem>
                  
                     <msItem xml:id="ms_i1.3">
                        <locus from="32v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3159Cyprian">ስምዕ፡ ዘቅዱስ፡ ቆጵርያኖስ፡ ወዘቅድስት፡ 
                  ኢዩስጣ።</title>
                        <incipit xml:lang="gez">ቃሎሙ፡ ለነቢያት፡ እንዘ፡ ይትፌጸም፡ በዝ፡ መዋዕል፡ ወቃሉ፡ ለእግዚእነ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </incipit>
                     </msItem>
                
                     <msItem xml:id="ms_i1.4">
                        <locus from="36v"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3163Romanus">ስምዕ፡ ዘቅዱስ፡ ሮማኖስ፡ ዘከመ፡
                  ተከለለ፡ በእንተ፡ እግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ።</title>
                        <incipit xml:lang="gez">
                    አስቀልጵያዶስ፡ መኰንን፡ ፈቀደ፡ ይባእ፡ ቤተ፡ ክርስቲያን፡ ወይስዶሙ፡ ለክርስቲያን። ወብፁዕ፡ ሮማኖስ፡ አቅደመ፡ ወነገሮሙ፡ ለእለ፡ ሀለዉ፡ ቤተ፡ ክርስቲያን፡ 
                    ወለዐጸውት፡ ወለሂ፡ ሂጲ፡ ዲያቆናት፡ ወይቤሎሙ፡ ከመ፡ ሰብእ፡ ጽኑዓን፡ ንቁም፡</incipit>
                     </msItem>
                
                     <msItem xml:id="ms_i1.5">
                        <locus from="45r"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3160Sergius">ገድል፡ ወስምዕ፡ ዘቅዱሳን፡ ወንጹሓን፡ ወቡሩካን፡
                    ሰርጊዮስ፡ ወባኮስ፡ ጸሎቶሙ፡ <gap reason="omitted" extent="unknown" resp="PRS10747Zotenbe"/>
                        </title>
                        <incipit xml:lang="gez">
                    ወኮነ፡ እምድኅረ፡ ዕርገቱ፡ ለእግዚእነ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፡ ውስተ፡ ሰማያት፡ በ፫፻፷ወ፯፡ ዓመት፡ በመዋዕለ፡ መንግሥቱ፡ ለመክስምያኖስ፡
                    ዘይገብር፡ ፈቃዶ፡ ለሰይጣን፡ ዓቢየ፡ ስደት፡ ወምንዳቤ፡ ላዕለ፡ ኵሎሙ፡ ሕዝበ፡ ክርስቲያን፡ እምኀበ፡ እለ፡ ያመልኩ፡ አማልክተ፡
                  </incipit>
                        <note>This version is different from the one in <bibl corresp="http://zotero.org/groups/358366/items/F8BZS6TU"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Bollandistes1770Octobris"/><title level="m">Acta Sanctorum Octobris ex Latinis &amp; Graecis, aliarumque gentium monumentis, servatâ primigeniâ veterum scriptorum phrasi, collecta, digesta, commentariisque &amp; observationibus illustrata a Constantino Suysenko, Cornelio Byeo, Jacobo Bueo, Josepho Ghuesquiero e Societate Jesu presbyteris Theologis. Tomus III, quo dies quintus, sextus &amp; septimus continentur.</title><title level="s">Acta Sanctorum</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Constantino</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Suysenko</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Cornelio</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Byeo</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Jacobo</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bueo</t:surname></author><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Josepho</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Ghuesquiero</t:surname></author><publisher>Apud Joannem Nicolaum Vander Beken</publisher><date>1770</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Acta Sanctorum</t:title></series><citedRange unit="page">863–866</citedRange></bibl>
                        </note>
                     </msItem>
                
                     <msItem xml:id="ms_i1.6">
                        <locus from="57rb" to="58Cra"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT3162Phileas">ስምዕ፡ ዘብፁዕ፡ ፊልያስ፡ ኤጲስ፡ ቆጶስ፡ ዘከመ፡
                  ተከለለ፡ በእንተ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ።</title>
                        <incipit xml:lang="gez">
                    አሜ፡ ዕሥራ፡ ወአሐዱ፡ ዓም፡ በዐሠሩ፡ ለወርኀ፡ ሜኬር፡ አቅረብዎ፡ ቅድመ፡ ምኵናን፡ ለፊልያስ፡ ኤጲስ፡ ቆጶስ፡ ዘብሔረ፡ ትሙይስ፡ ወበኀበ፡ ኵሉ፡ 
                    ይቤሎ፡ ቍልቍያኖስ፡
                  </incipit>
                        <listBibl type="secondary">
                           <bibl corresp="http://zotero.org/groups/358366/items/3W4RZM5Y"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Bausi2002ActaPhileae"/><title level="m">La versione etiopica degli &lt;hi rend="italics"&gt;Acta Phileae&lt;/hi&gt; nel &lt;hi rend="italics"&gt;Gadla samāʿtāt&lt;/hi&gt;</title><title level="s">Supplemento agli Annali</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Alessandro</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Bausi</t:surname></author><pubPlace>Napoli</pubPlace><publisher>Istituto Universitario Orientale</publisher><date>2002</date><series><t:title xmlns:t="http://www.tei-c.org/ns/1.0" level="s">Supplemento agli Annali</t:title><t:biblScope xmlns:t="http://www.tei-c.org/ns/1.0" unit="volume">60–61 (2000–2001), 92</t:biblScope></series><biblScope unit="volume">60–61 (2000–2001), 92</biblScope><note type="url">https://www.academia.edu/1151467/La_versione_etiopica_degli_Acta_Phileae_nel_Gadla_sam%C4%81_t%C4%81t</note></bibl>

                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Written in a fine handwriting</seg>
                        <date notBefore="1400" to="1499"/>
                        <seg type="ink">Black, red</seg>
                        <desc>
                          Old palaeographical features: 
                          ሎ has the loop marking the 7th order  attached directly to the body of the letter, without the linking line; 
                          the upper parts of ቆ, ቶ, የ, ደ, and ጸ are of triangular shape; 
                          ዐ is of angular shape.
                      </desc>
                        <seg type="rubrication">
                           Several groups of lines, alternating with black lines, on the incipit page of <ref target="#ms_i1"/> and <ref target="#ms_i2"/>; 
                           nomina sacra, elements of the Ethiopic numbers in <ref target="#ms_i2"/>; 
                           elements of the punctuation signs.
                        </seg>
                     </handNote>
                  </handDesc>

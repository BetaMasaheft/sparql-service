      <t:body>
         <t:listPerson>
            <t:person sex="1" sameAs="wd:Q346835">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሣህለ፡ ሥላሴ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Śahla Śǝllāse</t:persName>
               <t:persName xml:lang="gez" xml:id="n3" type="horse">አባ፡ ዲና፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n3" type="normalized">ʾAbbā Dinā</t:persName>
               <t:persName>
                  <t:roleName type="title">marǝd ʾazmāč, nǝguś, rās</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               <t:occupation type="political">king</t:occupation>
               <t:birth when="1795"/>
               <t:floruit notBefore="1813" notAfter="1847">He was the king of <t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">Šawā</t:placeName> 
                  from about <t:date>1813</t:date> to <t:date>1847</t:date>. 
                  When his father <t:persName ref="https://betamasaheft.eu/PRS10076WasanS">Wasan Sagad</t:persName> 
                  died, he was 18 years old and was brought from the village of <t:placeName ref="https://betamasaheft.eu/LOC5495SallaD">Sallā Dǝngāy</t:placeName>. 
                  <t:persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</t:persName> 
                  showed diplomatic skill and military ability from the very
                  beginning, which enabled him to restore order and peace in<t:placeName ref="https://betamasaheft.eu/LOC5597Sawa">
                     Šawā </t:placeName>. <t:persName ref="https://betamasaheft.eu/PRS8346sahlase">Śahla Śǝllāse</t:persName>
                  was made a <t:persName ref="https://betamasaheft.eu/PRS8346sahlase">
                     <t:roleName type="title">rās</t:roleName>  
                  </t:persName>
                  upon his assumption to power. 
              His reign is characterized by the unprecedented arrival of Europeans, travellers, missionaries as well as diplomats and explorers in his court. 
              He was succeeded by his firstborn son <t:persName ref="https://betamasaheft.eu/PRS5205haylaMa">Ḫayla Malakot</t:persName>. </t:floruit>
               
               <t:death when="1847"/>
            </t:person>
            
         </t:listPerson>

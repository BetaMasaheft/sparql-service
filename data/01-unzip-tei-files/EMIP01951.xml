               <msContents>
                  <summary>Prayer of Saint Peter, ጸሎተ፡ ጴጥሮስ፡, arranged for the days of the week</summary>
                    <msItem xml:id="ms_i1">
                     <locus from="1r" to="76r" facs="003">Fols 1r–76r</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT4668Prayer">Protective prayers
                                                  for the seven weekdays</title>
                    <textLang mainLang="gez">Gǝ‘ǝz</textLang>
                    <incipit xml:lang="gez">
                      ‎በስመ፡ ወወልድ፡ ጸሎቱ፡ ለጴጥሮስ፡ ዝንቱ፡ ውእቱ፡ ዘየዓቢ፡ ‎‎እምሐዋርያቲሁ፡ ወዘኃረዮ፡ ክርስቶስ፡ ወልደ፡ እግዚአብሔር፡ ሕያው፡ ‎‎እምቅድመ፡ ኵሎሙ፡ ሐዋርያቲሁ፡ ወጸውዖሙ፡ ለኵሎሙ፡ ሐዋርያቲሁ፡ ‎‎ወነበረ፡ ምስሌሆሙ፡ ወባረኮሙ <gap reason="omitted"/>‎
                    </incipit>

                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" facs="003">Fols 1r and following</locus>
                        <title>Monday</title>
                        </msItem>
                    <msItem xml:id="ms_i1.2">
                        <locus from="11v" facs="013">Fols 11v and following</locus>
                        <title>Tuesday</title>
                        </msItem>
                    <msItem xml:id="ms_i1.3">
                        <locus from="22r" facs="024">Fols 22r and following</locus>
                        <title>Wednesday</title>
                    </msItem>
                    <msItem xml:id="ms_i1.4">
                        <locus target="#38v" facs="040">Fol. 38v</locus>
                        <title>Thursday</title>
                        </msItem>
                    <msItem xml:id="ms_i1.5">
                        <locus from="51v" facs="053">Fols 51v and following</locus>
                        <title>Friday</title>
                        </msItem>
                    <msItem xml:id="ms_i1.6">
                        <locus target="#59r" facs="061">Fol. 59r</locus>
                        <title>Saturday</title>
                        </msItem>
                    <msItem xml:id="ms_i1.7">
                        <locus target="#66r" facs="068">Fol. 66r</locus>
                        <title>‎Sunday</title>
                    </msItem>
                    <msItem xml:id="ms_i1.8">
                        <locus target="#72r" facs="074">Fol. 72r</locus>
                        <title>Daily</title>
                        </msItem>

                  </msItem>


                        </msItem>
                        
                        <msItem xml:id="ms_i3"> 
                            <locus from="49v">Fols 49v and following</locus>
                            <title type="incomplete">Magical prayers and formulae</title> 
                            <textLang mainLang="gez"/> 
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="61r">Fols 61r and following</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT1758Lefafa">Lǝfāfa ṣǝdq</title> 
                            <textLang mainLang="gez"/> 
                            <note>Continuation of <locus target="#53">fol. 53</locus>.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i5"> 
                            <locus from="62r">Fols 62r and following</locus>
                            <title type="incomplete">Incomplete magical prayer</title> 
                            <textLang mainLang="gez"/> 
                        </msItem>
                       
                       

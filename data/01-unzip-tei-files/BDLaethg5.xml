                    <msContents>
                        <summary/>
                        
                        <msItem xml:id="ms_i1">
                            <locus from="3r">Fols 3r and following</locus>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh">Maṣḥafa ʾardǝʾt</title> 
                            <textLang mainLang="gez"/> 
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="3r">Fols 3r and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Monday">Maṣḥafa ʾardǝʾǝt, Prayers for Monday</title> 
                                <incipit xml:lang="gez">
                           <supplied reason="undefined" resp="PRS9622Ullendor">በስ</supplied>መ፡ አብ፡
                                    <gap reason="omitted" extent="unknown" resp="PRS9622Ullendor"/>
                                    <supplied resp="PRS9622Ullendor" reason="undefined">በእንተ፡</supplied> ፲ወ፪፡ 
                                    <supplied reason="undefined" resp="PRS9622Ullendor">አርድእት፡</supplied>
                                    <supplied resp="PRS9622Ullendor" reason="undefined"> ዘከ</supplied>መ፡ ነገሮሙ፡ ኢየሱስ፡</incipit>
                                <textLang mainLang="gez"/> 
                                <note>This section is largely illegible.</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="9r">Fols 9r and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Tuesday">Maṣḥafa ʾardǝʾǝt, Prayers for Tuesday</title> 
                                <textLang mainLang="gez"/> 
                            </msItem>
                            
                            <msItem xml:id="ms_i1.3">
                                <locus from="14v">Fols 14v and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Wednesday">Maṣḥafa ʾardǝʾǝt, Prayers for Wednesday</title> 
                                <textLang mainLang="gez"/> 
                                <incipit xml:lang="gez">ወአንበቡ፡ ዘንተ፡ አስማተ፡ ክርስቶስ፡</incipit>
                                <note>In <ref type="mss" corresp="https://betamasaheft.eu/BDLaethf13">Oxford, Bodleian Library, Bodleian Aeth. f. 13</ref>, the Wednesday portion begins at a place equivalent to
                                <locus target="#13r">fol. 13r</locus> this manuscript (after name of owner).</note>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="21r">Fols 21r and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Thursday">Maṣḥafa ʾardǝʾǝt, Prayers for Thursday</title> 
                                <textLang mainLang="gez"/> 
                            </msItem>
                            
                            <msItem xml:id="ms_i1.5">
                                <locus from="26r">Fols 26r and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Friday">Maṣḥafa ʾardǝʾǝt, Prayers for Friday</title> 
                                <textLang mainLang="gez"/> 
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <locus from="31r">Fols 31r and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Saturday">Maṣḥafa ʾardǝʾǝt, Prayers for Saturday</title> 
                                <textLang mainLang="gez"/> 
                            </msItem>
                            
                            <msItem xml:id="ms_i1.7">
                                <locus from="36v">Fols 36v and following</locus>
                                <title type="complete" ref="https://betamasaheft.eu/LIT3942ArdeetCh#Sunday">Maṣḥafa ʾardǝʾǝt, Prayers for Sunday</title> 
                                <textLang mainLang="gez"/> 
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">

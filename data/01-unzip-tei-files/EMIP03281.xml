         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Ethiopic Manuscript Imaging Project</repository>
                  <collection>EMIP</collection>
                  <idno facs="EMIP/Codices/3281/" n="82" corresp="https://betamasaheft.eu/api/iiif/EMIP03281/manifest">Weiner 477</idno>
               </msIdentifier>
               <msContents>
                  <summary> Prayer of the Covenant, Two Litanical Hymns, Nicene Creed, written in sections of alternating ink colors of blue, red, green, with three illuminations</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="5r" to="46v" facs="005">Fols 5r–46v</locus>
                    <title>Prayer of the Covenant for the Morning</title>
                      <msItem xml:id="ms_i1.1"><locus from="5r" to="5v" facs="005">Fols 5r–5v</locus><title>Introduction and prayer for the owner</title></msItem>
                      <msItem xml:id="ms_i1.2"><locus from="6r" to="36v" facs="006">Fols 6r–36v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1716Kidanz">Kidān za-nagh</title></msItem>
                    </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="37r" to="46v" facs="037">Fols 37r–46v</locus>
                    <title>Prayer of the Covenant for the Evening</title>
                      <msItem xml:id="ms_i2.1"><locus from="37r" to="46r" facs="037">Fols 37r–46r</locus><title type="complete" ref="https://betamasaheft.eu/LIT1717Kidanz">Kidān za-sark</title></msItem>
                      <msItem xml:id="ms_i2.2"><locus from="46r" to="46v" facs="046">Fols 46r–46v</locus><title>Concluding Prayer, and prayer for the owner</title></msItem>
                    </msItem>

                  <msItem xml:id="ms_i3"><locus from="46v" to="50v" facs="047">Fols 46v–50v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1191Baenta">Baʾǝnta
                                                  śǝllāseka</title></msItem>

                  <msItem xml:id="ms_i4"><locus from="51r" to="66v" facs="051">Fols 51r–66v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2082Otawar">ʾO
                                                  za-waradka...</title></msItem>

                  <msItem xml:id="ms_i5"><locus from="67r" to="72v" facs="067">Fols 67r–72v</locus><title type="complete" ref="https://betamasaheft.eu/LIT3308Nicene">Nicene Creed</title></msItem>

                  <msItem xml:id="ms_i6"><locus from="73r" facs="073">Fols 73r and following</locus><title>Prayer for forgiveness of sins for the owner and scribe</title><note>The scribe's name is erased, and secondary owner’s name added</note></msItem>

               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <extent>
                           <measure unit="leaf">74</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>
                              <width/>
                              <depth/>
                           </dimensions>
                        </extent>
                     </supportDesc>
                     <layoutDesc>
                       <layout columns="1" writtenLines="7"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                    <handNote xml:id="h1" script="Ethiopic">
                      <desc>The handwriting is extremely large (only 7 lines per page) and fine, written in colorful inks of red, green, blue (very rare)</desc>
                    </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#2v" facs="003">Fol. 2v</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <name ref="PRS4306GabraMa"/></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#3r" facs="003">Fol. 3r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1035HolyMan">Holy Man Portrait</ref> <persName ref="https://betamasaheft.eu/PRS9162TaklaHa">Takla Hāymānot</persName> and a patron (right)</desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#3v #4r" facs="004">Fols. 3v, 4r</locus><desc>A man (<ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref>?) with radiance emanating from the head and face, speaks to an audience of fourteen</desc></decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                      <desc type="GuestText">
                        <locus target="#1v #2r" facs="002">Fols. 1v, 2r</locus>Prayer to Mary, excerpt from <title type="incomplete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddase">Maṣḥafa qǝddāse, Śǝrʿāta qǝddāseሥርዓተ፡ ቅዳሴ፡</title>, mentioning <foreign xml:lang="gez">ወልደ፡ ሚካኤል፡</foreign>
                      </desc>
                    </item>
                    <item xml:id="a2">
                      <desc>
                        <locus target="#74v" facs="075">Fol. 74v</locus>
                        Comment on Death, in Amharic and Gǝ`ǝz, written in a later, untrained hand,
                        mentioning how the earth shook at the burial of one <foreign xml:lang="gez">ኃይለ ሥላሴ</foreign>.
                        Not likely the emperor, since the book was already in England by 1960
                      </desc>
                    </item>
                    <item xml:id="e1">
                    <desc>
                    Fine materials and good workmanship
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    Fine fabric is visible between the turn downs on the inside front and back covers
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    The headband and tail band include a strand of green leather
                    </desc>
                    </item>
                    <item xml:id="e5">
                    <desc>
                    <locus target="#1v" facs="002">Fol. 1v</locus>
                    has a nice example of an insertion symbol for an overlooked word, written in the upper margin
                    </desc>
                    </item>
                    <item xml:id="a3">
                    <desc type="OwnershipNote">
                    A letter is contained in the book.  The letter is from the British Museum and tells that the book was once owned by Mrs. M. R. Atkins, 29 Ovington Court, Brompton Road, London, S.W. 3. and offered to the British Museum in Nov. 1960, who turned it down
                    </desc>
                    </item>
                    <item xml:id="e6">
                    <desc>
                    Multi-colored yarn has been sewn into the fore edge of many pages to mark places of significance for the reader
                    </desc>
                    </item>
                    <item xml:id="a4">
                    <desc type="OwnershipNote">
                    <locus target="#5v #73r" facs="006 073">Fols. 5v, 73r</locus>
                    The owner is mentioned: <foreign xml:lang="gez">ተክላ ሚካኤል</foreign>, Takla Mika'el.
                    The scribe's name appeared originally on 73r, but has been erased
                    </desc>
                    </item>
                    <item xml:id="a5">
                    <desc>
                    <locus target="#5v" facs="006">Fol. 5v</locus>
                    mentions a secondary owner, <foreign xml:lang="gez">ወለተ፡ ተክለ፡ ሃይማኖት፡</foreign>
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate notBefore="1650" notAfter="1750">Late-seventeenth/early-eighteenth century</origDate>
                  </origin>
                  <provenance>
                    book was once owned by
                    Mrs. M. R. Atkins, 29 Ovington Court, Brompton Road, London, S.W. 3. and offered to the British Museum in Nov. 1960, who turned it down
                  </provenance>
               </history>
            </msDesc>
         </sourceDesc>

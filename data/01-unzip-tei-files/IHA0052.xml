                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="184v">2r-184v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT0088IHA#s47IHA">احياء علوم الدين, Sections 4–8 of the 4th
                    quarter</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>كتاب المحبة والشوق والانس والرضي وهو السادس من ربع المنجيات من كتب احيا علوم الدين تحرير الامام العامل العالم زين الدين والدنياربي حامد محمد بن محمد بن محمد الغزالي الطوسي رضي الله عنه امين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#184v">-184v</locus>وفي دار زوال الدار مقامة وفي دار حزن ونصب</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

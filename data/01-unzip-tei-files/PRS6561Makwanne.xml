         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">መኰንን፡ እንዳልካቸው፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Makʷannǝn ʾƎndālkāččaw</t:persName>
          
               
               <t:persName>
                  <t:roleName type="title">rās bitwadad</t:roleName>
               </t:persName>
               
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
               
               <t:occupation type="political"> minister </t:occupation>
               <t:occupation type="literary">writer</t:occupation>
               <t:birth when="1890"> He was born in <t:placeName ref="https://betamasaheft.eu/LOC1249Addisg">Addisge</t:placeName> in <t:date>1890</t:date>. </t:birth>
               
               
               <t:floruit notBefore="1916" notAfter="1963">He was both an accomplished politician and writer. 
                  He received a traditional education at <t:placeName ref="https://betamasaheft.eu/INS0341DL">Dabra Libānos</t:placeName> and 
                  was then educated at the Emperor's court. From <t:date>1916</t:date> until the time of Italian invasion, he served in various government posts. 
                  After the liberation, he embarked on a rapid career in the government. In May <t:date>1941</t:date>, he became the Minister of the Interior and Chairman of the Council of Ministers. 
                  In the following year, he was appointed a Prime Minister. In <t:date>1944</t:date>, he became the President of the Assembly established to renegotiate the agreement between 
                  <t:placeName ref="https://betamasaheft.eu/LOC3010Ethiop">Ethiopia</t:placeName> and <t:placeName ref="https://www.wikidata.org/entity/Q145">United Kingdom</t:placeName>. </t:floruit>
               
               <t:death when="1963"> He died in <t:placeName ref="https://betamasaheft.eu/LOC1216AddisA">ʾAddis ʾAbabā</t:placeName> in <t:date>1963</t:date>. </t:death>
               
            </t:person>
            
            
         </t:listPerson>
         
         

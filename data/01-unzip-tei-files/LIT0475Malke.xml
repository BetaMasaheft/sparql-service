         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ስቡሕ፡ በዝየ፡ ወከሐ፨</l>
                  <l n="2">ከመ፡ ይሰባሕ፡ ኀይልከ፡ ዘሕምዘ፡ አርዌ፡ አልስሐ፨</l>
                  <l n="3">አፉየ፡ ወጠነ፡ እመ፡ ተፍጻሜቱ፡ አብጽሐ፨</l>
                  <l n="4">ስመከኒ፡ ምስለ፡ ስመ፡ ጻድቃን፡ ቶስሐ፨</l>
                  <l n="5">እስመ፡ ተሰተፍከ፡ ጊዮርጊስ፡ ኀይሎሙ፡ ብዙኀ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ኀይልከ፡ ተለዐለ፡ እምኀይላተ፡ አበው፡ ኵሉ፨</l>
                  <l n="2">እምአዳም፡ አቡነ፡ ለትእዛዘ፡ ኦሪት፡ እስከ፡ ጥንተ፡ ቃሉ፨</l>
                  <l n="3">ጊዮርጊስ፡ ኢዮብ፡ ዕጉሠ፡ መከራት፡ ዘዘ፡ አምሳሉ፨</l>
                  <l n="4">እምወይነ፡ መዐትከ፡ ምሉእ፡ ዘኢይትከዐው፡ ጠሕሉ፨</l>
                  <l n="5">አዕይንተ፡ ኃጥእ፡ ፀርየ፡ በሰጊድ፡ የዐሉ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ኀይልከ፡ ተበውሐ፡ ከመ፡ ስመ፡ ያስሚ፨</l>
                  <l n="2">በጊዜ፡ አንቅዐ፡ ማየ፡ ለአጥምቆተ፡ ሕዝብ፡ ዘአረሚ፨</l>
                  <l n="3">ጊዮርጊስ፡ ሙሴ፡ መልአከ፡ እስራኤል፡ ወብንያሚ፨</l>
                  <l n="4">ስድድ፡ እምቤትከ፡ በሐብለ፡ ጥብጣቤ፡ ማሕመሚ፨</l>
                  <l n="5">ኪያየ፡ ቢጸ፡ በጽሚት፡ ዘይሐሚ፨</l>
               </lg>
               <lg type="stanza" n="18">
                  <l n="1">በኀይልከ፡ አእመርከ፡ ምሥጢረ፡ ኪሩብ፡ እለ፡ ገጸ፡ ንስር፡ ዘውገ፡ ጌጳ፨</l>
                  <l n="2">ጊዜ፡ ተነዝኀ፡ ደምከ፡ ከመ፡ በዕፀ፡ ጽሕድ፡ ወቈጽለ፡ ሆስጳ፨</l>
                  <l n="3">ጊዮርጊስ፡ ሕዝቅኤል፡ እምድኅረ፡ ነቢይ፡ ነጋዴ፡ ኢዮጳ፨</l>
                  <l n="4">ለነፍሰ፡ ፀርየ፡ ከመ፡ በጽማዌ፡ ትሂጳ፨</l>
                  <l n="5">አስተዳሉ፡ አሕፃከ፡ ወምላእ፡ ምጕንጳ፨</l>
               </lg>
               <lg type="stanza" n="19">
                  <l n="1">ሞአት፡ በኀይልከ፡ ሰይጣን፡ ዐማፄ፨</l>
                  <l n="2">ዘአልቦከ፡ ንግሥት፡ ቃለ፡ እንባቆም፡ ገሣጼ፨</l>
                  <l n="3">ጊዮርጊስ፡ ዳንኤል፡ መፈክረ፡ አሕላም፡ እንተ፡ ድንጋፄ፨</l>
                  <l n="4">ኢትኅድገኒ፡ ትቤለከ፡ ወነጽረኒ፡ በሕዋጼ፨</l>
                  <l n="5">እጓለ፡ እመሕያው፡ አኮ፡ ነፍስትየ፡ ዕፄ፨</l>
               </lg>
               <lg type="stanza" n="20">
                  <l n="1">ኀይልከ፡ አእመነ፡ ልበ፡ ከሓድያን፡ አእላፍ፨</l>
                  <l n="2">እንዘ፡ ያጠምቅ፡ በደም፡ ወበጥምቀተ፡ ማይ፡ ዘዘልፍ፨</l>
                  <l n="3">ጊዮርጊስ፡ ዮሐንስ፡ ዘተከለልከ፡ በሰይፍ፨</l>
                  <l n="4">ዘረገመኒ፡ በኅሊና፡ እንበለ፡ ይክሥት፡ በአፍ፨</l>
                  <l n="5">አይድዐኒ፡ ሊተ፡ እስመ፡ አንተ፡ ዖፍ፨</l>
               </lg>
               <lg type="stanza" n="21">
                  <l n="1">ሱባዔ፡ ሣልስ፡ ዐቅመ፡ ፊደላት፡ ሰባሕኩ፡ በአዝልፎ፨</l>
                  <l n="2">ጊዮርጊስ፡ ዐስብየ፡ ሀበኒ፡ እሴፎ፨</l>
                  <l n="3">ስምለ፡ ኀይሎሙ፡ ኀይለከ፡ በአስተማስሎ፡ ወአስተሳትፎ፨</l>
                  <l n="4">ከመ፡ አብጽሕሰ፡ ለዝክረ፡ ነቢያት፡ ተረፎ፨</l>
                  <l n="5">በፊደል፡ ጠዋይ፡ ሐተምኩ፡ መጽሐፎ፨</l>
               </lg>
            </div>
         </div>
      </body>

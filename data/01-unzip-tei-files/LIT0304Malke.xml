      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ ኢየሱስ፡ ክርስቶስ፡ እግዚእየ፡ ወአምላኪየ፨</l>
                  <l n="2">ወበስመ፡ ማርያም፡ ድንግል፡ ቃውመ፡ ነፍስየ፡ ወሥጋየ፨</l>
                  <l n="3">ማሕሌተ፡ ሰላም፡ ወጠንኩ፡ በስመ፡ ዚአከ፡ ፀሓየ፨</l>
                  <l n="4">ዮሐንስ፡ ለዕበይከ፡ እንዘ፡ ኣቄርብ፡ ግናየ፨</l>
                  <l n="5"/>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እምቅድመ፡ ፀሓይ፡ ዘሀሎ፨</l>
                  <l n="2">በኅሊና፡ አምላክ፡ ተሥዒሎ፨</l>
                  <l n="3">ረኣዬ፡ ኅቡኣት፡ ዮሐንስ፡ ሥርግወ፡ ዕበይ፡ ወተድንግሎ፨</l>
                  <l n="4">ሕገ፡ ተናበብከ፡ ለእግዚአብሔር፡ ወንጌሎ፨</l>
                  <l n="5">አንብበኒ፡ ሊተ፡ ውዳሴከ፡ ኵሎ፨</l>
               </lg>
               <lg type="stanza" n="26">
                  <l n="1">ሰላም፡ ለፍልሰትከ፡ በልብሰተ፡ ሥጋ፡ ወደም፨</l>
                  <l n="2">ሕያወከ፡ ትንብር፡ ውስተ፡ አርያም፨</l>
                  <l n="3">ዮሐንስ፡ ግንግል፡ ወርቀ፡ ጳሩሄም፡ አዳም፨</l>
                  <l n="4">ባልሐኒ፡ እምላህበ፡ ደዌ፡ በትንባሌከ፡ ቃውም፨</l>
                  <l n="5">አስተበቍዐከ፡ ብእሲ፡ ድኩም፨</l>
               </lg>
               <lg type="stanza" n="27">
                  <l n="1">አምኃ፡ ማሕሌት፡ ኅዳጠ፡ ቅድመ፡ ገጸ፡ አእላፍ፡ እንግልጋ፨</l>
                  <l n="2">እምዚአከ፡ ለከ፡ እንበይነ፡ ዘአቅረብኩ፡ እንበለ፡ ንትጋ፨</l>
                  <l n="3">ሠራዊተ፡ ሰማይ፡ ዘላዕሉ፡ ወደቂቀ፡ ዓለም፡ ልቡሳነ፡ ሥጋ፨</l>
                  <l n="4">ዮሐንስ፡ ለዕበይከ፡ እስከ፡ ያነክሩ፡ ሕጋ፨</l>
                  <l n="5">ህየንተ፡ ጸጋ፡ በዲበ፡ ጸጋ፡ ዕሥየኒ፡ ጸጋ፨</l>
               </lg>
            </div>
         </div>
      </body>

               <msContents>
                  <summary/>
            
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="4r" facs="0002"/>
                     <title type="complete">Titles of the Canons of the Council of Nicaea 1, 2.</title>
                     <textLang mainLang="la"/>
              
                     <msItem xml:id="ms_i1.1">
                        <locus target="#1r" facs="0002"/>
                        <title type="complete">Introduction to the titles of the Canons of the Council of Nicaea 1, 2, in Latin.</title>
                        <incipit xml:lang="la">Nicena prima Synodus Integra lxxxiiij canones continens, aethiopica lingua conscripta Argume<supplied reason="omitted">n</supplied>tu<supplied reason="explanation">m</supplied> 
                           cu<supplied reason="explanation">m</supplied> canonu<supplied reason="explanation">m</supplied> xx quos aethiopes 
                           etia<supplied reason="explanation">m</supplied>, sicut graeci, ac Latini habent, tu<supplied reason="explanation">m</supplied> etiam lxxxxiiij, quos 
                           ipsi praecepta uocant, statim inuentes.</incipit>
                        <textLang mainLang="la"/>
                     </msItem>
                
                     <msItem xml:id="ms_i1.2">
                        <locus target="#1v" facs="0003"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2687CanonsNicaea1T#t2latin">Titles of the Canons of the Council of Nicaea 1, in Latin.</title>
                        <incipit xml:lang="la">
                           Argumenta. xx. canonum qui cu<supplied reason="explanation">m</supplied> apud graecos, tum etiam apud latinos 
                           exta<supplied reason="omitted">n</supplied>t. De eunuchis, et qui se ipsos absciderunt, ac 
                           circu<supplied reason="omitted">m</supplied>ciseru<supplied reason="omitted">n</supplied>t.
                        </incipit>
                        <explicit xml:lang="la">De flectendo genua.</explicit>
                        <textLang mainLang="la"/>
                        
                     </msItem>
                  
                     <msItem xml:id="ms_i1.3">
                        <locus from="2r" to="3v" facs="0003"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2689CanonsNicaea2T#t2latin">Titles of the Canons of the Council of Nicaea 2, in Latin.</title>
                        <incipit xml:lang="la">
                           Argumenta lxxxxiiij canonu<supplied reason="explanation">m</supplied>, quos ipsi aethiopes, praecepta uocant, qui primum Niceae, ut 
                           testat<supplied reason="omitted">ur</supplied> D. Athanasius, aediti sunt. ex quibus xx. canones, quos nos habemus, tra<supplied reason="omitted">n</supplied>scripti 
                           su<supplied reason="omitted">n</supplied>t. De lunaticis non ordinandis
                        </incipit>
                        <explicit xml:lang="la">
                           De assistendo infirmis et pauperibus 84. Haec Argumenta invenies infra post xx. primos canones diuulgatos.
                        </explicit>
                        <textLang mainLang="la"/>
                        
                     </msItem>
              
                     <msItem xml:id="ms_i1.4">
                        <locus target="#4r" facs="0005"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2688CanonsNicaea2#Canon37">Canon 37 of the Council of Nicaea 2, in Latin</title>
                        <textLang mainLang="la">The text of <ref type="work" corresp="https://betamasaheft.eu/LIT2688CanonsNicaea2#Canon37"><span xmlns="" class="w3-tag w3-red">No item: LIT2688CanonsNicaea2#Canon37</span></ref> was translated into Latin on purpose.</textLang>
                        <incipit xml:lang="la">
                           Canones quidam latine co<supplied reason="omitted">n</supplied>uersi Canon xxxvij. De Numero Patriarchorum. Sint Patriarchae in orbe quatuor (...)
                        </incipit>
                        <explicit xml:lang="la">
                           Qui aute<supplied reason="explanation">m</supplied> prevaricatus fuerit hoc praeceptu<supplied reason="explanation">m</supplied>, quod nos, 
                           sanctoru<supplied reason="explanation">m</supplied> congregatio, constituimus. Anathema.
                        </explicit>
                     
                     </msItem>
                  </msItem>
            

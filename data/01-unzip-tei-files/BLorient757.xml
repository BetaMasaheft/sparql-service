                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                          <locus from="4r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT1948Mashaf">Maṣḥafa Mār Yǝṣhāq</title>
                          <textLang mainLang="gez"/>
                          <note>With many marginal notes <ref target="#a3"/>, some of them in Amharic. It is not
                        clear from the catalogue description whether these notes have been added later.</note>
                        </msItem>
                        <msItem xml:id="ms_i2">
                          <locus from="131r"/>
                          <title type="complete" ref="https://betamasaheft.eu/LIT2050Nagara">Nagara manakosāt</title>
                          <textLang mainLang="gez"/>

                          <msItem xml:id="ms_i2.1">
                            <locus from="131r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#IsaiahOfScete">
                            </title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ጥንተ፡ ቃል፡ እምነገረ፡ ጻድቅ፡ ኢሳይያስ፡ ወእንዘ፡ ሀሎኩ፡ አነ፡ በ፩ጊዜ፡ እምጊዜያት፡ ንቡረ፡ በጥቃ፡ ገቦሁ፡ ለቅዱስ፡ መቃርዮስ፡
                              መጽኡ፡ ጉባዔ፡ አኃው፡ እምሀገረ፡ እስክንድርያ። ከመ፡ ይስአልዎ፡ ሎቱ፡ እንዘ፡ ይብሉ፡ ንግረነ፡ ኦአቡነ፡ ዘከመ፡ እፎ፡ ንድኅን።
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.2">
                            <locus from="135r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#JohnClimacus">Nagara manakosāt: Extract from John Climacus of Mount Sinai</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ነገረ፡ ቅዱስ፡ ዮሐንስ፡ ገባሬ፡ መንክራት፡ ዘደብረ፡ ሲና፡ እንዘ፡ ይብል፡ ወበ፩ እምጊዜያት፡ እንተ፡ ሀሎኩ፡ ንቡረ፡ ውስተ፡ ገዳም፡
                              ውሣጣዊት፡ ወመጽአ፡ ኀቤየ፡ ፩ እምአኃው፡ ለሕዋፄ፡ እምነ፡ ደብር፡ ወተስእልክዎ፡ ዘከመ፡ እፎ፡ ሀለዉ፡ በደህና፡ በጸሎትክሙ፡
                              ወፈድፋደሰ፡ ተስእልክዎ፡ በእንተ፡ እኅው፡ ዘሰማዕኩ፡ ሕሠመ፡ ምግባሩ፤ ወይቤለነ፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.3">
                            <locus from="135v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Sayings1">
                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.4">
                            <locus from="137r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Albatariqun1">
                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.5">
                            <locus from="137v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Sayings2">
                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.6">
                            <locus from="138r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Albatariqun2">

                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.7">
                            <locus target="#138v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#JohnCrysostom">

                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.8">
                            <locus from="138v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Theodosius">

                          </title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ቴዎዶስዮስ፡ ዘየአቢ፡ ዘአስቈባኒ፡ ሶበ፡ ሐለየ፡ በሕሊናሁ፡ ቃለ፡ ሐዋርያ፡ ዘይብል፡ እስመ፡ ውእቱ፡ ኮነ፡ ይትጌበር፡ መዓልተ፡
                              ወሌሊተ፡ ከመ፡ ኢይኩን፡ ክበደ፡ ለመኑሂ፡ ወኮነት፡ ተግባረ፡ እዴሁ፡ ተአክሎ፡ ሎቱ።
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.9">
                            <locus target="#139r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Gannata">

                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.10">
                            <locus from="139v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Zena">

                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                          <msItem xml:id="ms_i2.11">
                            <locus from="140r"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Evagrius1">
                          </title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                              ነገራት፡ በእንተ፡ ፰ ሕሊናት፡ ዘአብ፡ ቅዱስ፡ ወግሪስ። ቀዳሚ፡ በእንተ፡ ስቡዓ፡ ከርሥ፡ ወመታሒ፡
                            </incipit>
                          </msItem>
                          <msItem xml:id="ms_i2.12">
                            <locus from="142v"/>
                            <title type="complete" xml:lang="en" ref="https://betamasaheft.eu/LIT2050Nagara#Evagrius2">
                          </title>
                            <textLang mainLang="gez"/>
                          </msItem>
                        </msItem>

                        <additions>
                            <list>
                              <item xml:id="a1">
                                <locus from="2v"/>
                                <desc type="Unclear">Index of chapters to <ref target="#ms_i1">Maṣḥafa Mār Yǝṣhāq</ref>.</desc>
                                <q xml:lang="gez"/>
                              </item>
                              <item xml:id="a2">
                                <locus from="3r"/>
                                <desc type="GuestText">Sayings of Greek Philosophers on the death of
                                <persName ref="https://betamasaheft.eu/PRS1666Alexande">Alexander the Great</persName>. Those
                              mentioned by name are <persName ref="https://betamasaheft.eu/PRS2032Aristotl">Aristotle</persName>,
                              Antiochus, Philemon
                              <foreign xml:lang="gez">ፊልሞን፡</foreign>,
                              <persName ref="https://betamasaheft.eu/PRS7902Plato">Plato</persName> (<foreign xml:lang="gez">አፍላጦን፡</foreign>),
                            <persName ref="https://betamasaheft.eu/PRS3585Diogenes">Diogenes</persName> (<foreign xml:lang="gez">ዲዎጋንስ፡</foreign>),
                            Pythagoras (<foreign xml:lang="gez">ፊታግሮስ፡</foreign>),
                          <persName ref="https://betamasaheft.eu/PRS4439Galen">Galen</persName> (<foreign xml:lang="gez">ጋሊኖስ፡</foreign>),
                          the others are merely designated as
                        <foreign xml:lang="gez">ካልእ፡</foreign>, 'another'. Last of all are mentioned Alexander's
                      wife and mother.</desc>
                      <q xml:lang="gez"><seg part="I">ወሶበ፡ ሞተ፡ እስክንድር፡ ወጠነ፡ ሎቱ፡ አርስጣጣሊስ፡ ይላኅዎ፡ እንዘ፡ ይብል፡ እመሰኮነ፡
                      ከመዝ፡ ተፍጻሜታ፡ በዛቲ፡ ዓለም፡ እምሐይሰ፡ አኅድጎታ፡ እምቀዲሙ። ወይቤ፡ አንጢያኮስ፡ በዛቲ፡ ፍኖት፡ ሀለወነ፡ ንሑር፡ ኀሥዎ፡
                    ለዘኢይበሊ፡ ወኀደግዎ፡ ለዘይበሊ።</seg></q>
                              </item>
                              <item xml:id="a3">
                                <locus from="4r" corresp="#ms_i1"/>
                                <desc type="MixedNote">Marginal notes, some of them in Amharic</desc>
                                <q xml:lang="gez"/>
                                <q xml:lang="am"/>
                              </item>
                            </list>
                        </additions>

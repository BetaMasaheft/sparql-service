               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="4r" to="4r">4r-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3457IHA">منظومة لا تركنن الى الهوى</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>بسم الله الرحمن الرحيم \ لا تركن الى الهوى , واذكر مفارقه الهواء يوما تصير الى الثرى , ويفوز غيرك بالثراء , كم من حفير فى رجا , بئر لمنقطع الرجاء </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>ولربما مجهور البنا , بعد الثانق والبناء , وسوى اهل الكبى , وذو التعطر فى الكباء , ولرىماء فى روى , من حيض يحتاح فيه الى الرواء , تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4v" to="60r">4v-60r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT0404IHA">كشف النقاب عن مخدرات ملحة الاعراب</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الله الرحمن الرحيم \ الحمد لله رب العلمين سبحانك لا احصى ثناء عليك انت كما اثنيت على نفسك واصل واسلم على محمد افضل من خصصته بروح قدسك وبعد وهذا تعليق وجيز على المقدمة الموضوعة في علم العربية المسماة بملحة الاعراب كافل بحل مبانيها وتوضيح معانيها وتفكيك نظامها وتعليل احكامها وسميته كشف النقاب عن مخدرات ملحة الاعراب

</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#60r">-60r</locus>ومات كذلك وعطف الصحب على الال لتشمل الصلاة باقيهم والدجى جمع دجية بالياء وهى ظلمة الليل والله اعلم وليكن هذا ءاخر ما تيسر جمعه فللله الحمد سبحانه لا احصي ثناء عليه كما هو اثنى على نفسه وحسبي الله ونعم الوكيل ولا حول ولا قوة الا بالله العلى العظيم والحمد لله رب العلمين تم</explicit>
                     <note/>
                     <note/>
                  </msItem>

               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2041IHA">باب للعبد الابق</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>باب للعبد الابق حتى لا يهرب جيد مجرب تكتب فى الخبر وتاكله العبد وهو هذه الله لا اله الا هو الحي القيوم يا مخيشا يا الله لمخيشا يا الله اربط ارجلهم واعمر ابصارهم اذ اراد يهرب او الابق وجعلنا من بين ايديهم سدا ومن خلفهم سدا فاغشيناهم فهم لا يبصرون لكن كره الله نبعاثهم فثبطهم وقيل اقعدوا مع القاعدين تمت</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="1r">1r-1r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2042IHA">باب للرعاف ولكثرة الحيض</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>باب للرعاف ولكثرة الحيض والمذي والودي ولمن يبول فى الفراش يكتب وعلق عليه ينقطع باذن الله تعالى وقيل يا ارض [بلعى] ماءك ويا سماء اقلعى وغيض الماء وقضى الامر وستوت على الجودي وقيل بعد اللقوم الظالمين قل ارديتم ان اصبح ماءكم غورا فمن ياتيكم بما معين والسماء والطارق وما ادراك ما الطارق النجم الثاقب ان كل نفس لما عليها حافظ فلينظر الانسان مم خلق خلق مماء دافق يخرج من الصلب والترائب انه على رجعه لقادر يوم [تبل] السرائر فما له من قوة ولا ناصر اه</incipit>
                     <explicit xml:lang="ar"/>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="1v" to="2r">1v-2r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2044IHA">باب اسم الله الاعظم المبارك</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>باب اسم الله الاعظم المبارك يكتب لعشرة اشياء اولها للمحبة عن جميع الناس من الرجال والنساء والثانى حجاب ساتر من كل عدو والثالث لقضاء كل حاجة والرابع لبركة المال</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2r">-2r</locus>وما كان لنا ان ناتيكم بسلطان مبين الا باذنه وعلى الله فليتوكل المؤمنون وصلى الله على سيدنا محمد وعلى اله وصحبه وسلم ولا حول ولا قوة الا باالله العلي العظيم \ ت م ت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="2r" to="2v">2r-2v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT2050IHA">خواص الاسماء الحسنى</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r-2v">-2r-2v</locus>والسلام شيخنا الالى قال الشيخ ابو وفى بن عبد الله رضى الله عنه وارصاه فمن اراد ان يمشى بين الناس | ولا يراه احد فليقرء يوم الاحد يا الله مائة وسبعون مرة  ومن اراد ان يطلع فى قلوب الناس فليقرء يوم الاثنين يا حفيظ ثلاث مأة مرة </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#2v">-2v</locus>ومن اراد ان يدخل النار ولم يحرقه النار فليقرأ يوم الثلاثا مأة مرة يا جليل ومن اراد ان يمشى على الماء ولم يبل قدماه فليقرأ يوم الاربعا يا هاد خمسمأة مرة ومن اراد ان يطير فى الهواء فليقرأ يوم الخميس يا نافع اربع مأة مرة اه تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

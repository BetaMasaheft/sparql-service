               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1v" to="3v">1v-3v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3866IHA">نظم أمنوا نبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#1v">-1v</locus>بسم الله الرحمن الرحيم | امنوا نب صلى عليك امنوا صلى الله عليك | بسم الله اولا ابتدائى والحمد لله ثانيا انتهائى | والصلاة على خير الانبياء نحمد نب أنت نور الأوليائى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3v">-3v</locus>اللهم صل على التماما حمدا كثيرا ثم الدواما الحمد لله الذي أنعم علينا وهدانا على دين الإسلاما | أمنوا نبيوا صل عليك | أمنوا صلى الله عليك</explicit>
                     <note>Some verses are written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="4r" to="4r">4r-4r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4311IHA">صلاة على النبي بنور محمدوا</title>
                     <incipit xml:lang="ar">
                        <locus target="#4r">-4r</locus>اللهم صل علي نورك احمد صلاة وتسليم بنعر محمد | بسم الله الرحمن الرحيم | وبالألف الفنايا محمدوا صلاة وتسليم بنور محمدوا | وبالبابيا ببرهان محمدوا صلاة وتسليم بنور محمدوا | وبالتا تلالا نوركا محمدوا صلاة وتسليم بنور محمد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#4r">-4r</locus>محمد حبيب الله محمدوا صلاة وتسليم بنور محمدوا | محمد رسول الله محمدوا صلاة بنور محمدوا | لك الحمد والشكر يا محمدوا صلاة وتسليم بنور محمدوا</explicit>
                     <note>Some verses are written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i10">
                     <locus from="23v" to="24r">23v-24r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4322IHA">نظم سلميوا</title>
                     <incipit xml:lang="ar">
                        <locus target="#23v">-23v</locus>بسم الله الرحمن الرحيم | سلام على الله سلميوا | سلام على ملكت سلميوا | سلام على سلميو كلميوا | سلام على جبريل سلميوا | سلام على اشرافيل سلميوا | سلام على ميكائيل سلميوا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24r">-24r</locus>الله حمدى خالق جان خنوت ل | حمدي نب أمت خنوت ل | الله حمدى دين إسلام ل | تمت</explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i11">
                     <locus from="24r" to="24v">24r-24v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4323IHA">Poem in Old Harari (7)</title>
                     <incipit xml:lang="ar">
                        <locus target="#24r">-24r</locus>بسم الله الرحمن الرحيم الله لى سمز | بسم الله بحقيق اللقأ والبقإ بى | سق حميمل زالاوأون تمامى | بحقيق اللقأ والبقا بى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#24v">-24v</locus>ستة الباقين سلام عليك مع الأل والصحب والأزواج | لك الحمد ودود ابدا الابدا لك الشكر معبود بلا عددا ~ اللهم احم شيخ او على افيف </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i12">
                     <locus from="24v" to="25v">24v-25v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4324IHA">Poem in Old Harari (8)</title>
                     <incipit xml:lang="ar">
                        <locus target="#24v">-24v</locus>بسم الله الرحمن الرحيم اللوا كفتلن زرحمت برأ اللوا كفتلن زرحمت بابا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#25v">-25v</locus>فارق الفرقين تعمر حوا ذى النورين تعثثمان حوا | رمي سمحين تعلى خواا أحمد أمين محمدوا | نبين سطين اللوا حمدي ايمان سطين اللوا حمدي | المرسين اللوا حمدي</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i13">
                     <locus from="25v" to="26r">25v-26r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4326IHA">Praise of the Prophet in Old Harari</title>
                     <incipit xml:lang="ar">
                        <locus target="#25v">-25v</locus>جمع ششاتى أصلح حياتى  واجعل وفاتى عند محمد | واجعل صلاتى عد البناتى فى طول حياتى على محمد </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#26r">-26r</locus>الله أعطاكم تم اصطفاكم زعرتم مولاكم نبي محمد | قيتا الصلاتى مع السلامى أختم كلامى نبى محمد | الله الله الله اللاه قيوم باقى والكل فانى</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i14">
                     <locus from="26r" to="27r">26r-27r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4327IHA">نظم بسم الله قرأ</title>
                     <incipit xml:lang="ar">
                        <locus target="#26r">-26r</locus>بسم الله الرحمن الرحيم | بسم الله قرأ الحمد الثنأ الصلاة رضأ | بسم الله ارأ | لأكلى هئيأ | الشراب مريأ</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#27r">-27r</locus>حمدجي بدأ | شكرجي بدأ ريض جي بدا | الحمد لله الشكر لله رب العالمين | تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i15">
                     <locus from="27r" to="30r">27r-30r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4329IHA">Poem in Old Harari (9)</title>
                     <incipit xml:lang="ar">
                        <locus target="#27r">-27r</locus>بسم الله بل يايين حمد الله ايمرينا | بسم الله الرحمن الرحيم نب صلى عليك | بسم الله أول مقدم | بسم الله أخر مختم </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30r">-30r</locus>بئجلوجر ببسم الله يبوردوجر الحمد لله سنتز رسول الله نب صلى عليك | نب صلى عليك صلى الله عليك نب صلى عليك نبوا صلى الله عليك </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i16">
                     <locus from="30r" to="30v">30r-30v</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4340IHA">نظم يا الهي</title>
                     <incipit xml:lang="ar">
                        <locus target="#30r">-30r</locus>بسم الله حرمتزوب يا إلهي ارتحملنا | الرحمن حرمتذوب يا للهى ترحملنا </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#30v">-30v</locus>قرب أونلتي؟ الرحمن | سم أتلنا | عجل ب أونلنا والرحمن جاف خان تنا | نفسو قنلني؟ الرحمن أتقبيلنا </explicit>
                     <note>Part of the text is written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i17">
                     <locus from="31r" to="31r">31r-31r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4341IHA">Poem in Old Harari (10)</title>
                     <incipit xml:lang="ar">
                        <locus target="#31r">-31r</locus>حال عمل اماج لزالرحمن | حال اما جلني | حال ذرفوا ماج لزالرحمن</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#31r">-31r</locus>حمد حلاخياروا ذن خانا | الله لحمدي | حمد يحبابيوا؟ اخع خانا | الله لحمدي | بنور خبن حون تعتقن | الله ل حمدي |بنور خاب متقان ذ جليلا الله ل حمدي 
</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i18">
                     <locus from="31r" to="31v">31r-31v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4343IHA">مدح النبي الف الصلاة عليك يا محمد</title>
                     <incipit xml:lang="ar">
                        <locus target="#31r">-31r</locus>ألف الٔلاة عليك يا محمد الف السلام عليك يا محمد | ألف الإحاطة بالجاتين كلها قد قومت للهاشمي محمد</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#31v">-31v</locus>والحمد لله الذي يمم الورى بالجود والإحسان لاجل محمد | والله يرحم من يقول بعزمه بالقلب والأركان بال محمد</explicit>
                     <note>Part of the text is written in vertical in the margins.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i19">
                     <locus from="32r" to="36v">32r-36v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4346IHA">صلأ على النبي صلاة الله عليه</title>
                     <incipit xml:lang="ar">
                        <locus target="#32r">-32r</locus>بسم الله الرحمن الرحيم | ابتدا ذكرنا ببسم الله مولانا ٕحمد الله ربنا صلأ الله عليه | إن الصلاة النبي بركة كثيرا وبرهان كثيرا صلاة الله عليه</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#36v">-36v</locus>ألف وسبع وسبعون مضت سنة من بعد هجرته صلاة الله عليه | ستون أبياتها عشر مع مائتين كذا وأربعون معا صلاة الله عليه | خمسون أبياتها مع مائتين كذا وتسعة معها صلاة الله عليه | واسم ناظمها محمد الجوزي ومادح النبي صلاة الله عليه </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="4v" to="5r">4v-5r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4312IHA">نظم بسم الله حرمتب</title>
                     <incipit xml:lang="ar">
                        <locus target="#4v">-4v</locus>بسم الرحمن الرحيم [كذا] | بسم الله حرمتب ترحملنا الهى الرحمن متب ترحمنا الهى | الرحيم حرمتبى ترحملنا الهى محمد حرمتبى ترحملنا الهى | صديقق خ حرمتبى ترحملنا الهى عمر خ حرمتبى ترحلنا الهى</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#5r">-5r</locus>وكيل ذن الله قل هو الله احد الله واحد ولا شريك الله مالك الملوكا نحمدوا نحيعا حمد خان بن وحوببنا حمدوا ذ ياد يا الله ذا شلوا ذ عاقات</explicit>
                     <note>Some verses are written in vertical in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i20">
                     <locus from="33r" to="33r">33r-33r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4351IHA">مدح النبي نب امينوا</title>
                     <incipit xml:lang="ar">
                        <locus target="#33r">-33r</locus>نب امنوا سلام على نبو سلام على صلى الله | نبيوا اوايوا سراج بلا الله خير خلق الله | يا رسول الله يا حبيب الله ابن عبد الله </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#33r">-33r</locus>خاتم رسل الله تصديق تقي الله | تعمر قوي الله تعتمان سخي الله | تعلي ردى الله </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i21">
                     <locus from="33r" to="34r">33r-34r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="apodous" ref="https://betamasaheft.eu/LIT4354IHA">نظم اسمعوا يا مسلمين</title>
                     <incipit xml:lang="ar">
                        <locus target="#33r">-33r</locus>بسم الله الرحمن الرحيم | اسمعوا يا مسلمين امدحوا نور الأمين وصفه مبين صلوات الله عليه | النبي ليس يا طويل ثم ليس بالقصير وجهه وجه المنير صلوات الله عليه </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#34r">-34r</locus>بذكر الله والقران يفوز العبد عند الله وانتم يا أولى الابصار سرات القوم حزب الله | انستم به ثناء الله فما احلى ثنآ الله ظفرتم بالمناطبتم طولى لكم ويشرى الله | الى الله الذى يبقى انيبوا يا عباد الله وتوبوا أيها الاخوان الى الرحمن جل الله</explicit>
                     <note>
                        <note>
        Manuscript item  7091 relates to manuscript item 7256</note>
                     </note>
                     <note>Part of the text is written in the margin in vertical; the manuscript and the text continue at DWL00030-9B3.
</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i3">
                     <locus from="5v" to="7r">5v-7r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4036IHA">دعاء الله قل هو الله</title>
                     <incipit xml:lang="ar">
                        <locus target="#5v">-5v</locus>بسم الله ارحمن الرحيم | الله قل هو الله | الله لا اله الا الله | الله احمد الله | الله لا اله الا الله | الله صمد الله | الله لا اله اله الله | الله ولدم ايلا | الله لا اله الا الله الله والدم ايلا</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#7r">-7r</locus>احذروا فى القهواتى | لفظة من لغواتى | اشربوها متقابل | غير حال متدابر | وصل اللهم احمد وعلى محمد | نحمد الله نشكر الله | ذلك الفضل من الله | تمت </explicit>
                     <note>Some verses are written in verticla in the margin.</note>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i4">
                     <locus from="7r" to="17r">7r-17r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT1511IHA">مدح النبي أبدأ القول ببسم الله ثم أثني الحمد لله</title>
                     <incipit xml:lang="ar">
                        <locus target="#7r">-7r</locus>بسم الله الرحمن الرحيم | أبدأ القول بسم الله ثم اثنى بحمد الله وثالثها بصلاة الله على المصطفى يا حبيب الله | انى بصلواتك ابتدا لكل صدا مجلا دواتخون لجميع  دآ صلواتك فى بشفآ </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#17r">-17r</locus>دبا بلوا دابلين حمدي دبلتزنا ودبلت زرحمت اوني | ودود معبود فلك الحمد اللوا حمدى جيرخا والبوردا | اللوا حمدي جدخاب يمشزال اللهم ارحم اروافل </explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i5">
                     <locus from="17r" to="20r">17r-20r</locus>
                     <textLang xml:lang="x-oh">Old Harari</textLang>
                     <title ref="https://betamasaheft.eu/LIT4314IHA">نظم بسم الله نبدأ الله لحمد نحيا</title>
                     <incipit xml:lang="ar">
                        <locus target="#17r">-17r</locus>بسم الله الرحمن الرحيم | بسم الله نبدأ الله ل حمد نجنا بشركين بريأ خلق جمعل بارأ نبى | نبيوا مبرأ وجهزوا انلوؤلؤا من الشمو اضوأ نور له يتلالا نبى </incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20r">-20r</locus>مثل ذوارس تصديق خوا مثل ذواصدر تعمر خوا | مثل ذوابطن معثمان خوا مثل ذوارجل تعلى خوا | نور تصديق خوا اتعمر خوا نور تعثمان خوا تعلى خوا</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i6">
                     <locus from="20r" to="20v">20r-20v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT4316IHA">نظم الحمد لله العليم الصمد الوتر الحليم</title>
                     <incipit xml:lang="ar">
                        <locus target="#20r">-20r</locus>لا اله الا الله احدوا الا الله | بسم الله الرحمن الرحيم | الحمد لله العليم الصمد الوتر الحليم | اذا زينت قصورها مقربين جارها | الجنة للمتقين الجحيم للمنافقين</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#20v">-20v</locus>الله للمعطى حبيب | الله للداعى مجيب | انت القريب للعبيد | اقربد من حبل الوريد | اسئلك بالنبي الحبيب | اسمع ندائى يا قريب | اللهمنى العلم فى مصيب | واجعل التقوى لي نصيب</explicit>
                     <note>Part of the text written in vertical in the margin.</note>
                     <note/>
                  </msItem>

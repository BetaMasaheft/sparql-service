                        <locus from="2ra" to="9rb"/>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme#Introduction">Taʾammǝra ʾIyasus, Introduction (same as LIT6396MJIntroduction)</title>
                        <textLang mainLang="gez"/>
                        <msItem xml:id="ms_i1.1.1">
                           <locus from="2ra" to="5rb"/>
                           <title type="complete" ref="https://betamasaheft.eu/LIT2382Taamme#John">Taʾammǝra ʾIyasus, On John the Evangelist as the author of the book; on the creation and the fall of the angels</title>
                           <textLang mainLang="gez"/>
                        </msItem>
                        <msItem xml:id="ms_i1.1.2">

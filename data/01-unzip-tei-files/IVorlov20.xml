                            <msItem xml:id="p1_i16">
                              <locus from="10r" to="10v"/>
                              <title type="complete" ref="https://betamasaheft.eu/LIT4991Months">Names of the months in Ethiopic and various other languages,
          such as Arabic, Coptic, Greek, Latin, Hebrew etc. (General record)</title>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">
                             <locus target="#10r"/> ወካዕበ፡ እጽሕፍ፡ ሠርቀ፡ አውራኂሆሙ፡ ለዕብራውያው፡
                             ወለሮማውያን፡ ኅቡራን፡ ሠርቅ፡ አምጣነ፡ መዋዕሊሆሙ። ወባሕቱ፡ ዓውደ፡ ዓመታቲሆሙ፡ ሊሉይ። በወርኃ፡ መስከረም፡ ዘሮማውያን፡
                           ወበወርኃ፡ ሚያዝያ፡ ዘዕብራውያን።</incipit>
                                <note>The text has been edited in <bibl corresp="http://zotero.org/groups/358366/items/CT7FHNL9"><seg type="journalArticle"><!-- attributes from original bibl--></seg><ptr target="bm:Gusarova2021Nazvanija"/><title level="a">Nazvanija mesjacev različnyh kalendarnyh sistem v efiopskoj rukopisnoj tradicii ('Names of the months from various calendrical systems in the Ethiopian manuscript tradition’)</title><title level="j">Vestnik PSTGU: Serija III: Filologija</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Ekaterina</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Gusarova</t:surname></author><date>2021</date><biblScope unit="volume">69</biblScope><biblScope unit="page">23-33</biblScope><citedRange unit="page">25-26</citedRange></bibl></note>
                            </msItem>

                            <msItem xml:id="p1_i17">

                    <decoNote type="frame" xml:id="d2">
                      Decorative designs: <locus target="#1r #12v" facs="002 014">folss. 1r, 12v, </locus> (simple red and black ḥarägs); <locus target="#24v" facs="026">24v</locus> (red and black lines and dots</decoNote>
                  </decoDesc>
                  <additions>
                    <list>
                      <item xml:id="e1"><desc><locus target="#ir(ecto) #iv(erso) #25r #25v" facs="001 002 026 027">Fols. ir(ecto), iv(erso), 25r, 25v</locus> blank</desc></item>
                      <item xml:id="a1"><desc type="OwnershipNote">Owner: Ǝgwalä Dawit (<locus target="#24v" facs="026">fol. 24v</locus> and passim)</desc></item>
                      <item xml:id="a2"><desc type="ScribalSignature"> Gäbrä Mika’el (<locus target="#24v" facs="026">fol. 24v</locus> and passim)</desc></item>
                      <item xml:id="e2"><desc>
                        words of text are written interlinearly (<locus target="#3r" facs="004">fols. 3r, </locus>);
                        and in the margin with a symbol (┬) marking the location where the text is to be inserted (<locus target="#17r" facs="018">17r, </locus>, line 3; <locus target="#20v" facs="022">20v, </locus>, line 5);
                        text has been removed (e.g., <locus target="#5r #9r #19v" facs="006 010 021">5r, 9r, 19v</locus>)</desc></item>
                    </list>
                  </additions>

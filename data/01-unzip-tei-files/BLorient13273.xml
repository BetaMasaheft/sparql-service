                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="5r" to="15r"/>
                            <title ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
                            <incipit xml:lang="gez">ኪዳን፡ ዘመሐሮሙ፡ እግዚእነ፡ ለአርዳኢሁ፡ እምድኅረ፡ ተንሣኤሁ። ቅዱስ፡ እግዚአብሔር፡ ቅዱስ፡ ኃያል፡ ቅዱስ፡ ሕያው፡ 
                                ዘኢይመውት፡ ዘተወልደ፡ እማርያም፡ እምቅድስት፡ ድንግል፡ ተሣሃለነ፡ እግዚኦ። </incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="15v" to="24r"/>
                            <title ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                            <incipit xml:lang="gez">በእንተ፡ ትምሕርተ፡ ኅቡዓት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="24v" to="58r"/>
                            <title ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse Māryām</title>
                            <note>Arranged by the days of the week, with Monday's lesson first.</note>
                            <msItem xml:id="ms_i3.1">
                                <locus from="24v"/>
                                <title ref="https://betamasaheft.eu/LIT2811RepCh95">Malkǝʾ-hymn to Our Lady Mary</title>
                                <incipit xml:lang="gez">ሰላም፡ ለኪ፡ እንዘ፡ ንሰግድ፡ ንብለኪ፡ ማርያም፡ እምነ፡ ናስተበቍዓኪ። እምአርዌ፡ ነአዊ፡ ተማኅፀነ፡ ብኪ። በእንተ፡ ሐና፡ እምኪ፡ 
                                    ወኢያቂም፡ አቡኪ። ማኅበረነ፡ ዮም፡ ድንግል፡ ባርኪ። </incipit>
                            </msItem>
                            <msItem xml:id="ms_i3.2">
                                <locus from="25v"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Monday">Wǝddāse Māryām: : Monday</title>
                            </msItem>
                            <msItem xml:id="ms_i3.3">
                                <locus from="29v"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Tuesday">Wǝddāse Māryām: : Tuesday</title>
                            </msItem>
                            <msItem xml:id="ms_i3.4">
                                <locus from="34v"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Wednesday">Wǝddāse Māryām: : Wednesday</title>
                            </msItem>
                            <msItem xml:id="ms_i3.5">
                                <locus from="40r"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Thursday">Wǝddāse Māryām: : Thursday</title>
                            </msItem>
                            <msItem xml:id="ms_i3.6">
                                <locus from="46v"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Friday">Wǝddāse Māryām: : Friday</title>
                            </msItem>
                            <msItem xml:id="ms_i3.7">
                                <locus from="51r"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Saturday">Wǝddāse Māryām: : Saturday</title>
                            </msItem>     
                            <msItem xml:id="ms_i3.8">
                                <locus from="54v"/>
                                <title ref="https://betamasaheft.eu/LIT2509Weddas#Sunday">Wǝddāse Māryām: : Sunday</title>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="58v" to="74v"/>
                            <title ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa bǝrhān</title>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="75r" to="98v"/>
                            <title ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ቅድስት፡ ድንግል፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ዘነበበ፡ 
                                በመንፈስ፡ ቅዱስ፡ አባ፡ ሕርያቆስ፡ ኤጲስ፡ ቆጶስ፡ ዘሀገረ፡ ብሕንሳ። </incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <locus from="99r" to="108v"/>
                            <title ref="https://betamasaheft.eu/LIT6956MalkeaMadAlam">Malkǝʾa Madḫāne ʿālam</title>
                            <note>In 33 stanzas, 29 of which beginning with <foreign xml:lang="gez">እሰግድ፡ </foreign>.</note>
                            <incipit xml:lang="gez">ሰላም፡ ዕብል፡ ለልደትከ፡ መድምም።
                                                                         እምድንጋሌ፡ ሥጋ፡ ኅቱም፤
                                                                         ኢየሱስ፡ ክርስቶስ፡ መድኃኔ፡ ዓለም።
                                                                         ልብየ፡ አንቅህ፡ ወነፍስየ፡ ለስብሐቲከ፡ አዳም።
                                                                         ለሥጋየስ፡ አኃዞ፡ ድካም።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus from="109r" to="121r"/>
                            <title ref="https://betamasaheft.eu/LIT2883RepCh164">Malkǝʾa madḫāne ʿālam</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘኢረከቡ፡ ተፍጻሜተ። </incipit>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <locus from="121v" to="127r"/>
                            <title ref="https://betamasaheft.eu/LIT6967PrayerPassion">Prayer on the Passion of Jesus Christ, which Jesus
          revealed to Matilda, Bridget and Elizabeth</title>
                            <note>In twenty-six stanzas.</note>
                            <incipit xml:lang="gez">ኦእግዚእየ፡ ኢየሱስ፡ ክርስቶስ፡ መድኅነ፡ ዓለም። ኈልቈ፡ ሕማማቲከ፡ ዘከሠትከ፡ ሎን፡ ለሠላስ፡ ደናግል፡ ቅዱሳት፡ እለ፡ ይሰመያ፡ ቅድስት፡ 
                                ቢርዜዳ። ወቅድስ<supplied reason="undefined" resp="PRS8999Strelcyn">ት</supplied>፡ ሚልቲዳ። ወቅድስት፡ ኤልሳቤጥ፡ እላ፡ እማንቱ፡ 
                                ዘነጸራከ፡ ሥራይ፡ ኃጢአትየ። እስመ፡ አነ፡ ኃጥእ፡ ገብርከ፡ <gap reason="illegible"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <locus from="127v" to="132r"/>
                            <title ref="https://betamasaheft.eu/LIT4154Prayer">Prayer on the holy names revealed by Jesus to the apostle
          Andrew</title>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> አስማተ፡ ዘነገሮ፡ እግዚእነ፡ ለቅዱስ፡ እንድርያስ፡ ረድእ፡ ሐዋርያ፡ ወሰማዕት፡ ጸሎቱ፡ 
                                ወበረከቱ፡ የሃሉ፡ ምስለ፡ ፍቁሩ፡ <gap reason="illegible"/> ለዓለመ፡ ዓለም፡ አሜን፡ </incipit>
                        </msItem>
                        <msItem xml:id="ms_i10">
                            <locus from="132r" to="146r"/>
                            <title ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa ʾIyasus</title>
                            <incipit xml:lang="gez">ሰላም፡ ለዝክረ፡ ስምከ፡ ስመ፡ መሐላ፡ ዘኢይኄሱ። </incipit>
                        </msItem>

               <msContents>
                  <summary>Psalter, ዳዊት፡; Image of Jesus Christ, መልክአ፡  ኢየሱስ፡, made in the government scriptorium</summary>
                  <msItem xml:id="ms_i1">
                     <locus from="1r" to="183v" facs="004">Fols 1r–183v</locus>
                     <title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                     <textLang mainLang="gez">Gǝ‘ǝz</textLang>

                      <msItem xml:id="ms_i1.1">
                        <locus from="1r" to="138v" facs="004">Fols 1r–138v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                        <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref></note>
                      </msItem>
                      <msItem xml:id="ms_i1.2">
                        <locus from="139r" to="153v" facs="142">Fols 139r–153v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      </msItem>
                      <msItem xml:id="ms_i1.3">
                        <locus from="154r" to="162v" facs="157">Fols 154r–162v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                        <note>Common version, with unique superscriptions</note>
                        <msItem xml:id="ms_i1.3.1">
                          <locus target="#162v" facs="166">Fol. 162v</locus>
                          <title>Concluding prayer</title>
                          <incipit xml:lang="gez">
                          ሰአል፡ ለነ፡ ሰሎሞን።ቅድመ፡ መንበሩ፡ ለመድኅን።
                          ኦ፡ አምላከ፡ ሰሎሞን፡።
                          አድኅነነ፡ እመ፡ ትካዝ፡ ወኃዘን።
                          ከመ፡ ታቁመነ፡ በየማን፡ ምስለ፡ አባግዒከ ቡሩካን።
                          ወአሥርቅ፡ ለነ፡ ጥበበ፡ ብርሃን።
                          ለዓለመ፡ ዓለም፡ አሜን፡</incipit>
                        </msItem>
                      </msItem>
                      <msItem xml:id="ms_i1.4">
                        <locus from="163r" to="177r" facs="166">Fols 163r–177r</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                        <note>Arranged for the days of teh week</note>
                      </msItem>
                      <msItem xml:id="ms_i1.5">
                        <locus from="177r" to="183v" facs="180">Fols 177r–183v</locus>
                        <title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title>
                      </msItem>
                      </msItem>

                      <msItem xml:id="ms_i2">
                        <locus from="183v" to="186v" facs="187">Fols 183v–186v</locus>
                        <title type="incomplete" ref="https://betamasaheft.eu/LIT2839RepCh123">Malkǝʾa
                                                  ʾIyasus</title>
                        <note>incomplete at the end, written in another hand, with a different shade of red ink</note>
                      </msItem>

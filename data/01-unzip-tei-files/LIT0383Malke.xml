      <body>
         
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note></bibl>
            </listBibl>
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">በስመ፡ እግዚአብሔር፡ ሥሉስ፡ ዘበኀበ፡ ኵሉ፡ ውዱስ፨</l>
                  <l n="2">ናሁ፡ ወጠንኩ፡ ድራስነ፡ ራጉኤል፡ ርኡስ፨</l>
                  <l n="3">ተወከፍ፡ ወትረ፡ ጸሎትየ፡ ከመ፡ ኬና፡ ዕጣን፡ ቅዱስ፨</l>
                  <l n="4">ዘተወከፍኮ፡ ለዳዊት፡ ንጉሥ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ነዓ፡ ኀቤየ፡ ራጉኤል፡ መልአክ፨</l>
                  <l n="2">ጸሎትየ፡ ትስማዕ፡ ጊዜ፡ ነግህ፡ ወሰርክ፨</l>
                  <l n="3">መገሥጸ፡ ፀር፡ አንተ፡ ወለመልአከ፡ ሞት፡ ምዑክ፨</l>
                  <l n="4">ገሥጾሙ፡ ለአፅራርየ፡ በመዐትከ፡ ድሩክ፨</l>
                  <l n="5">ወደምስሶሙ፡ በኀዘን፡ ወሀውክ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለተፈጥሮትከ፡ ግብረ፡ መንፈስ፡ ቅዱስ፡ ምንክር፨</l>
                  <l n="2">እምነፋስ፡ ወነድ፡ ራጉኤል፡ ግቡር፨</l>
                  <l n="3">ካህነ፡ ሥላሴ፡ መዐርዒረ፡ ዜማ፡ መዝሙር፨</l>
                  <l n="4">ለአፅራርየ፡ በመዐትከ፡ መሪር፨</l>
                  <l n="5">ወፍሬሆሙኒ፡ ሠዓር፡ እምድር፨</l>
               </lg>
               <lg type="stanza" n="4">
                  <l n="1">ሰላም፡ ለሢመትከ፡ ኀይለ፡ ግርማ፡ ሞገስ፡ ዘለብሰ፨</l>
                  <l n="2">በከመ፡ ኃዊት፡ ኀታል፡ ላዕለ፡ ጎልያድ፡ ዘነግሠ፨</l>
                  <l n="3">ዘውገ፡ ሱራፊ፡ ራጉኤል፡ ዘተሞጣሕከ፡ ሞገሰ፨</l>
                  <l n="4">ተሀበኒ፡ ኀይለ፡ ግርማከ፡ ወስብሐቲከ፡ ሐዲሰ፨</l>
                  <l n="5">አስተብቍዐከ፡ ገብርከ፡ አንሰ፨</l>
               </lg>
               <lg type="stanza" n="7">
                  <l n="1">ሰላም፡ ለአክሊለ፡ ርእስከ፡ ዘያኀቱ፡ በብዙኅ፨</l>
                  <l n="2">እምወርኀ፡ ሰማይ፡ ወቤዝ፡ ወእምነ፡ ጸሓይ፡ ብሩህ፨</l>
                  <l n="3">ክሉለ፡ ግርማ፡ ራጉኤል፡ አምሳለ፡ መብረቅ፡ መፍርህ፨</l>
                  <l n="4">ክልለኒ፡ ጌራ፡ መዊእ፡ በልብሰ፡ ብርሃን፡ ንጹሕ፨</l>
                  <l n="5">ለፀማድከ፡ ጊዜ፡ ሰርክ፡ ወነግህ፨</l>
               </lg>
               <lg type="stanza" n="16">
                  <l n="1">ሰላም፡ ለፊደለ፡ ስምከ፡ ዘኍላቌ፡ ስሙ፡ ወግብሩ፨</l>
                  <l n="2">ከመ፡ ገጸ፡ ኪሩብ፡ አርባዕ፡ ርእሰ፡ እለ፡ ቄጥሩ፨</l>
                  <l n="3">ራብዕ፡ እምሊቃናት፡ ወሱባዔ፡ ኀይላት፡ ዝክሩ፨</l>
                  <l n="4">ራጉኤል፡ አንተ፡ ለልዑል፡ መልአከ፡ ምክሩ፨</l>
                  <l n="5">ምክረ፡ ጸላእት፡ ሠዐር፡ ወፀርየ፡ ዝሩ፨</l>
               </lg>
            </div>
         </div>
      </body>

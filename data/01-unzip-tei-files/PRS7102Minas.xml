               <persName xml:lang="gez" xml:id="n3" type="regnal">አድማስ፡ ሰገድ፡</persName>
		             <persName xml:lang="gez" corresp="#n3" type="normalized">ʾAdmās Sagad</persName>

		             <occupation type="ruler">Emperor</occupation>
               <birth when="1526"/>
               <floruit notBefore="1559" notAfter="1563">He 
                  was the third son of  
                  <persName ref="https://betamasaheft.eu/PRS6229LebnaDe">Lǝbna Dǝngǝl</persName>
                  .
                  As a boy, Minās was prisoner of <persName ref="https://betamasaheft.eu/PRS1522Ahmadb">ʾAḥmad b. ʾIbrāhīm al-Ġāzī</persName>.
                  He was then freed in a prisoner exchange in <date>1544</date>. 
                  He succeeded his brother 
                  <persName ref="https://betamasaheft.eu/PRS4428Galawdew">
                     <t:roleName xmlns:t="http://www.tei-c.org/ns/1.0" type="title">ʾaṣe</t:roleName>
                     Galāwdewos</persName> in <date>1559</date>.  </floruit>
               <death when="1563" evidence="internal"/> 
            </person>
            
            
            
                     
                  

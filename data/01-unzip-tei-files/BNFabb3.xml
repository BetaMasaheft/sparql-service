                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#128r"/>
                           <desc type="Unclear">
                             A note related to tributes,
                             possibly in the region of <placeName ref="https://betamasaheft.eu/LOC1572Asgade">Asgäde</placeName>.</desc>
                          <q xml:lang="am">
                            ከ<placeName ref="https://betamasaheft.eu/LOC1572Asgade">አስገዴ፡</placeName> ፭፻፵፱ለሸለቃ፡ ሽቴ፡ ፫፻፺፭ለአዕበዮ፡ አራ፡
                            ፬፻፸፩ለገብራይ፡ አድአቀይት፡ ፬፻፹፫ለ<foreign xml:lang="ti">አሰላፊ፡</foreign> ወልደ፡ ሚካኤል፡ <sic resp="DN">፫፻፺፮ለ<foreign xml:lang="ti">ወድ፡</foreign>
                          </sic> ሸለቃ፡ ፍሥሐ፡ ፫፻፷፪ለተስፋይ፡ ግባ፡ ደግ፡ <sic resp="DN">፬፻ለ<foreign xml:lang="ti">ወድ፡</foreign></sic> ሸለቃ፡ ፍሥሐ፡ ገብረ፡ ሚካኤል።
                              </q>
                              <note>French translation in <bibl corresp="http://zotero.org/groups/358366/items/MZC4PZ7D"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1914Notice"/><title level="m">Notice sur les manuscrits éthiopiens de la Collection d’Abbadie</title><title level="s">Extrait du Journal Asiatique</title><author><forename>Carlo</forename><surname>Conti Rossini</surname></author><pubPlace>Paris</pubPlace><publisher>Imprimerie nationale</publisher><date>1914</date><series><title level="s">Extrait du Journal Asiatique</title></series><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note><citedRange unit="page">49</citedRange></bibl>; a few words
                            are noted as Tǝgrǝñña forms.</note>
                        </item>

                        <item xml:id="a2">
                           <locus target="#129r"/>
                           <desc type="Unclear">A note concerning the <foreign xml:lang="gez">rim</foreign>-land of a
                            a church, from the time of the king <persName ref="https://betamasaheft.eu/PRS9142TaklaGi">Takla Giyorgis</persName></desc>
                           <q xml:lang="am">
                             <persName ref="https://betamasaheft.eu/PRS13326GabraMaryam"><sic resp="PRS3182ContiRo">አበ፡</sic> ገብረ፡ ማርያም፡</persName> የወንደባሪ፡ ልጅ፡ አገሩ፡ <placeName ref="https://betamasaheft.eu/LOC1413Ambass">አምባሴል፡</placeName>
                            <placeName ref="https://betamasaheft.eu/LOC1390AmbaGe">ግሼን፡</placeName>
                             ጉልቱ፡ አስፋ፡ ገዚ፡ የናቱ፡ ቤት፡ አገሩዋ፡ <placeName ref="https://betamasaheft.eu/LOC6287Wecale">ዎጫሊ፡
                           </placeName> ምላቼ፡ አባቱዋን፡ አቶ፡ ሞቲ፡ <sic resp="PRS3182ContiRo">እርሶዋን፡</sic> መነን፡ <sic resp="PRS3182ContiRo">ወንድሞዎ፡</sic> <persName ref="https://betamasaheft.eu/PRS13325Adilu">አዲሉ</persName>።
                              </q>
                              <note>French translation in <bibl corresp="http://zotero.org/groups/358366/items/MZC4PZ7D"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:ContiRossini1914Notice"/><title level="m">Notice sur les manuscrits éthiopiens de la Collection d’Abbadie</title><title level="s">Extrait du Journal Asiatique</title><author><forename>Carlo</forename><surname>Conti Rossini</surname></author><pubPlace>Paris</pubPlace><publisher>Imprimerie nationale</publisher><date>1914</date><series><title level="s">Extrait du Journal Asiatique</title></series><note type="tags"><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note></note><note type="tag">Ethiopic</note><note type="tag">Cataloguing</note><note type="tag">Bibliothèque Nationale</note><note type="tag">bm:ContiRossini1914Notice</note><citedRange unit="page">49</citedRange></bibl>.</note>
                        </item>

                        <item xml:id="a3">
                           <locus target="#129r"/>
                           <desc type="Unclear">A note added by <persName ref="https://betamasaheft.eu/PRS1071dAbbadi">Antoine dʼAbbadie
                           </persName>, referring to one of the two persons
                           mentioned in <ref target="#a2">Addition 2</ref>,
                           most probably to <persName ref="https://betamasaheft.eu/PRS13325Adilu">ʾAdilu</persName>.</desc>
                           <q xml:lang="fr">
                            Cʼest le nom de celui qui me lʼa donné (le manuscrit); à la guerre
                            on le nommait Bitul.
                              </q>
                        </item>
                     </list>
                  </additions>

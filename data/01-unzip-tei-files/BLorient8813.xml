                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="16v"/>
                            <title ref="https://betamasaheft.eu/LIT2260salota">Ṣalota kidān</title>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="17r" to="29r"/>
                            <title ref="https://betamasaheft.eu/LIT2444Temher">Tǝmhǝrta ḫǝbuʾāt</title>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="29r" to="36r"/>
                            <title ref="https://betamasaheft.eu/LIT3083RepCh363">ʾƎgziʾabǝḥer za-bǝrhānāt ʾǝgziʾabǝḥer za-śǝlṭānāt</title>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="36r" to="43v"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT1960Mashaf#SerataQeddaseChapter3">Excerpt from Śǝrʿāta Qǝddāse</title>
                            <incipit xml:lang="gez">በእንተ፡ ቅድስት፡ ሰማያዊት፡ ሰላመ፡ ናስተበቍዕ፡ ከመ፡ እግዚአብሔር፡ ያስተሳልመነ፡ በሣህለ፡ ዚአሁ፡ </incipit>
                            <note>Excerpt from chapter III, starting from §66 as attested in 
                                <bibl corresp="http://zotero.org/groups/358366/items/GYMLI3WV"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:1962Qeddase"/><title level="m">&lt;hi rend="italics"&gt;መጽሐፈ፡ ቅዳሴ። በግዕዝና፡ በአማርኛ። (&lt;/hi&gt;Maṣḥafa qǝddāse. Bagǝʿǝzǝnnā baʾamārǝññā&lt;hi rend="italics"&gt;, ‘Book of the Missal. In Gǝʿǝz and Amharic’)&lt;/hi&gt;</title><editor><t:name xmlns:t="http://www.tei-c.org/ns/1.0">[Tasfā Gabra Śǝllāse]</t:name></editor><pubPlace>ʾAddis ʾAbabā</pubPlace><publisher>Tasfā māttamiyā bet</publisher><date>1969</date><citedRange unit="page">26</citedRange></bibl>.</note>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="43v" to="64v"/>
                            <title ref="https://betamasaheft.eu/LIT1398Fethat">Fǝtḥat za-wald</title>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <locus from="65r" to="77v"/>
                            <title ref="https://betamasaheft.eu/LIT3012RepCh292">Bǝḍǝʿt ʾanti</title>
                            <incipit xml:lang="gez">ንዒ፡ ማርያም። 
                                እንዘ፡ ትነብሪ፡ በአር<supplied reason="undefined" resp="PRS8999Strelcy">ያ</supplied>ም፡ 
                                ወንዒ፡ ፍቅርየ፡ ዘገነት፡ ኤዶም። 
                                ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ፡ 
                                ብፀዕት፡ አንቲ፡ ወንግሥተ፡ ጽድቅ። 
                                ዘትሜንንኒ፡ ማርያም፡ መንገለ፡ ምስራቅ። 
                                ታቦትነ፡ አንቲ፡ እንተ፡ ወርቅ። 
                                ሃሃሃ። </incipit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus from="77v" to="84r"/>
                            <title ref="https://betamasaheft.eu/LIT2801RepCh85">Malkǝʾ-hymn to St George</title>
                            <incipit xml:lang="gez">ሰላም፡ ለከ፡ ጊዮርጊስ፡ ናሁ፡ ወጠንኩ፡ ዝክረ፡ ውዳሴከ፡ ባሕቱ፡ ምንትኑ፡ ውዳሴከ። ወምንት፡ ውእቱ፡ አምሳ<pb n="78r"/>ሊከ። 
                                ሃሃሃ፡ ዘሐረጸከ፡ ዱድያኖስ፡ ወወገረከ፡ ደብረ፡ ይድራስ። </incipit>
                        </msItem>

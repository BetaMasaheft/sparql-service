         <sourceDesc>
            <msDesc xml:id="ms">
               <msIdentifier>
                  <repository ref="https://betamasaheft.eu/INS0447EMIP">Shover</repository>
                  <collection>EMIP</collection>
                  <idno n="30" facs="EMIP/Codices/294/" corresp="https://betamasaheft.eu/api/iiif/EMIP00294/manifest">Shover Codex 3</idno>
               </msIdentifier>
               <msContents>
                  <summary>Anaphora of Mary attributed to Cyriacus of Bähänsa, ቅዳሴ፡ ማርያም፡</summary>
                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="30v" facs="003">Fols 1r–30v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1">
                    <locus from="1r" to="16r" facs="003">Fols 1r–16r</locus>
                    <title>Office Prayers</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>

                  <msItem xml:id="ms_i1.1.1">
                    <locus from="1r" to="5r" facs="003">Fols 1r–5r</locus>
                    <title>Liṭon, <foreign xml:lang="gez">ሊጦን</foreign>, arranged for the days of the weeks</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.1.2">
                    <locus from="5r" to="10v" facs="007">Fols 5r–10v</locus>
                    <title>Supplications, Mästäbqwu‘ǝ, <foreign xml:lang="gez">መስተብቍዕ</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>

                  <msItem xml:id="ms_i1.1.3">
                    <locus from="10v" to="16r" facs="013">Fols 10v–16r</locus>
                    <title>God Enthroned, <foreign xml:lang="gez">ዘይነግሥ</foreign></title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                </msItem>

                  <msItem xml:id="ms_i1.2">
                    <locus from="16v" to="30v" facs="019">Fols 16v–30v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT1099Anapho">ʾAkkʷateta qʷǝrbān
                                                  za-qǝddus Hǝryāqos za-hagara Bǝhnǝsā</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                  </msItem>
                </msItem>

               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                           <material key="parchment"/>
                        </support>
                        <extent>
                           <measure unit="leaf">ii + 30</measure>
                           <measure unit="quire">Protection sheet + 4</measure>
                           <dimensions type="outer" unit="mm">
                              <height>185</height>
                              <width>125</width>
                              <depth>40</depth>
                           </dimensions>
                        </extent>
                        <collation>
                          <note>Quire descriptions: protection sheet and quires 1–4 balanced. Navigation system: green yarn is sewn into the fore edge of <locus target="#3" facs="005">fol. 3</locus> to mark content.</note>
                          <list>
                              <item xml:id="q1" n="a">
                                 <dim unit="leaf">2</dim>
                                 <locus from="i" to="ii" facs="001">Fols i–ii</locus>
                              Protection Sheet
                            </item>
                              <item xml:id="q2" n="1">
                                 <dim unit="leaf">8</dim>
                                 <locus from="1" to="8" facs="003">Fols 1–8</locus>
                              Quire 1
                            </item>
                              <item xml:id="q3" n="2">
                                 <dim unit="leaf">8</dim>
                                 <locus from="9" to="16" facs="012">Fols 9–16</locus>
                              Quire 2
                            </item>
                              <item xml:id="q4" n="3">
                                 <dim unit="leaf">6</dim>
                                 <locus from="17" to="22" facs="019">Fols 17–22</locus>
                              Quire 3
                            </item>
                              <item xml:id="q5" n="4">
                                 <dim unit="leaf">8</dim>
                                 <locus from="23" to="30" facs="025">Fols 23–30</locus>
                              Quire 4
                            </item>
                          </list>
                        </collation>
                     </supportDesc>
                     <layoutDesc>
                       <layout>
                           <dimensions type="margin" unit="mm">
                              <dim type="top">18</dim>
                              <dim type="bottom">37</dim>
                              <dim type="right">23</dim>
                              <dim type="left">7</dim>
                           </dimensions>
                       </layout>
                       <layout columns="1" writtenLines="18 21">
                           <locus from="17v" to="30v" facs="020">Fols 17v–30v</locus>
                       </layout>
                       <layout columns="2" writtenLines="18 21">
                           <locus from="1r" to="16v" facs="003">Fols 1r–16v</locus>
                       </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  <foreign xml:lang="gez">ማርያም፡</foreign>
                  </seg>
                  <desc>The word Mary is rubricated</desc>
                  </handNote>
                  </handDesc>
                  <decoDesc>
                    <decoNote type="miniature" xml:id="d1"><locus target="#iv(erso)" facs="002">Fol. iv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> and <persName ref="https://betamasaheft.eu/PRS5684JesusCh">Jesus Christ</persName> as a boy.  An <term key="angel" ana="#angel"/> hovers in the clouds above with caption <q>“How she (Mary) spanked him (Jesus)” (cf. Nägärä Maryam)</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d2"><locus target="#iir(ecto)" facs="002">Fol. iir(ecto)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1084JesusChrist">JesusChrist</ref> (left) brings water to <persName ref="https://betamasaheft.eu/PRS5764Joseph">Joseph</persName> (right). An <term key="angel" ana="#angel"/> hovers in the clouds above with caption <q>“How he caused water to spring forth.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d3"><locus target="#iiv(erso)" facs="003">Fol. iiv(erso)</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> giving water to the dog with caption <q>“How she gave water (to the dog).” </q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d4"><locus target="#9r" facs="011">Fol. 9r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1099StMary">St Mary</ref> and an <term key="angel" ana="#angel"/> with caption <q>“How she was praying.”</q></desc></decoNote>
                    <decoNote type="miniature" xml:id="d5"><locus target="#17r" facs="019">Fol. 17r</locus><desc><ref type="authFile" corresp="https://betamasaheft.eu/AT1005Crucifixion">Crucifixion of Jesus</ref>. <persName ref="https://betamasaheft.eu/PRS6819Mary">St Mary</persName> grieves on the left; <persName ref="https://betamasaheft.eu/PRS5695John">John</persName> on the right. The stars fall from the sky with caption <q>“Crucifixion.”</q></desc></decoNote>
                    <decoNote type="frame" xml:id="d6">
                    Decorative designs:
                    <locus target="#2v #5r #6r #10v #16r" facs="005 007 013 018">folss. 2v, 5r, 6r, 10v, 16r, </locus> (multiple full stops);
                    <locus target="#16v" facs="019">16v</locus> (ḥaräg)
                    </decoNote>
                  </decoDesc>
                  <additions>
                  <list>
                    <item xml:id="e1">
                    <desc>
                    <locus target="#ir(ecto)" facs="001">Fol. ir(ecto)</locus>
                    pen trials or blank
                    </desc>
                    </item>
                    <item xml:id="a1">
                    <desc>
                    <locus target="#7v" facs="010">Fol. 7v</locus>
                    Mentions Mǝnilǝk (1889–1913).  The manuscript may have been started during the time of Mǝnilǝk and added to later
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <desc>
                    <locus target="#15r" facs="017">Fol. 15r</locus>
                    Mentions “our king Ḫaylä Śǝllase” (1930–1974)
                    </desc>
                    </item>
                    <item xml:id="e2">
                    <desc>
                    <locus target="#3r" facs="005">Fol. 3r</locus>
                    green yarn is sewn into the fore edge to mark content
                    </desc>
                    </item>
                    <item xml:id="e3">
                    <desc>
                    <locus target="#15r #23r" facs="017 025">Fols. 15r, 23r</locus>
                    words of text are written interlinearly
                    </desc>
                    </item>
                  </list>
                </additions>
                  <bindingDesc>
                    <binding xml:id="binding" contemporary="true">
                        <decoNote xml:id="b1">Parchment, 185 x 125 x 40 mm, four Coptic chain stitches attached with bridle attachments to rough-hewn boards of the traditional wood.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="parchment"/>
                           <material key="wood"/>
                        </decoNote>
                    </binding>
                  </bindingDesc>
               </physDesc>
               <history>
                  <origin>
                     <origDate when="1935">Begun during the reign of Mǝnilǝk (1889–1913, <locus target="#7v" facs="010">fols. 7v, </locus>) and completed during the reign of Ḫaylä Śǝllase” (1930–1974, <locus target="#15r" facs="017">15r, </locus>), specifically completed on Yäkkatit 2, 1927 EC (= February 9, 1935, <locus target="#30v" facs="033">30v, </locus>) (the change in hand may occur at <locus target="#7v" facs="010"> f. 7v, col. 2</locus>).</origDate>
                  </origin>
               </history>
            </msDesc>

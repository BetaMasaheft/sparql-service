                  <idno facs="EMIP/Codices/3225/" n="212" corresp="https://betamasaheft.eu/api/iiif/EMIP03225/manifest">Sobania 4</idno>
               </msIdentifier>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1"><locus from="1r" to="198v" facs="001">Fols 1r–198v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2701Dawit">Psalter</title>
                    <textLang mainLang="gez">Gǝ'ǝz</textLang>
                    <msItem xml:id="ms_i1.1"><locus from="1r" to="147v" facs="001">Fols 1r–147v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2000Mazmur">Mazmura Dāwit</title>
                      <note><ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps118Spiritual"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps118Spiritual</span></ref> from the common new system</note>
                      <note>
                        <locus target="#147r #147v" facs="147 148">Fols. 147r, 147v</locus>
                        <ref type="work" corresp="https://betamasaheft.eu/LIT2000Mazmur#Ps151"><span xmlns="" class="w3-tag w3-red">No item: LIT2000Mazmur#Ps151</span></ref> has only the first of the four plusses that make up the long version, i.e.,<foreign xml:lang="gez">ወአድኃኒ፡</foreign>
                      </note>
                    </msItem>
                    <msItem xml:id="ms_i1.2"><locus from="147v" to="163v" facs="148">Fols 147v–163v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1828Mahale">Book of Odes</title>
                      <note><locus target="#152v" facs="153">Fol. 152v</locus>, the fourth biblical canticle <ref type="work" corresp="https://betamasaheft.eu/LIT2257salota#Hannah"><span xmlns="" class="w3-tag w3-red">No item: LIT2257salota#Hannah</span></ref> is <q>“[Prayer of Hana, mother of Samuel,] Prophetess.”</q></note>
                    </msItem>
                    <msItem xml:id="ms_i1.3"><locus from="163v" to="172v" facs="164">Fols 163v–172v</locus><title type="complete" ref="https://betamasaheft.eu/LIT2362Songof">Song of Songs</title>
                      <note>In the common edition</note>
                    </msItem>
                    <msItem xml:id="ms_i1.4"><locus from="173r" to="191r" facs="173">Fols 173r–191r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2509Weddas">Wǝddāse
                                                  Māryām</title>
                      <note>Laid out in one column, arranged for the days of the week, beginning with Monday and culminating with Sunday</note>
                    </msItem>
                    <msItem xml:id="ms_i1.5"><locus from="191r" to="198v" facs="191">Fols 191r–198v</locus><title type="complete" ref="https://betamasaheft.eu/LIT1113Anqasa">ʾAnqaṣa
                                                  bǝrhān</title></msItem>

                    <colophon xml:id="coloph1">
                      <locus target="#198v" facs="199">Fol. 198v</locus>
                      Notice of completion.  Owner is <foreign xml:lang="gez">ስነ፡ ጊዮርጊስ፡</foreign>, Sena Giyorgis, with his mother <foreign xml:lang="gez">ቢሩታዊት፡</foreign>, Birutawit,
                      and the scribe is <foreign xml:lang="gez">ስርፀ፡ [ጠ]ቢብ፡</foreign>, Sardsa [Ta]bib
                    </colophon>
                  </msItem>

                  <msItem xml:id="ms_i2"><locus from="199r" to="203r" facs="199">Fols 199r–203r</locus><title type="complete" ref="https://betamasaheft.eu/LIT2804RepCh88">Malkǝʾ-hymn to Our
                                                  Lady Mary</title>
                    <incipit xml:lang="gez">ሰላም፡ ለኪ፡ ማርያም፡ ለኖኀ፡ ሐመሩ፡ ሰላም፡ ለኪ፡ ለአሮን፡ በትሩ፡</incipit>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           
                        </support>
                        <extent>
                           <measure unit="leaf">206</measure>
                           <dimensions type="outer" unit="mm">
                              <height/>

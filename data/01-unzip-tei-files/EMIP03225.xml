                  <handDesc>
                  <handNote xml:id="h1" script="Ethiopic">
                  <seg type="rubrication">
                  </seg>
                  <desc>The word for God is unrubricatred</desc>
                  <desc>There is no columetric rubrication in the manuscript</desc>
                  </handNote>
                  </handDesc>
                  <additions>
                  <list>
                    <item xml:id="a1">
                    <locus target="#203v #204r" facs="204">Fols. 203v, 204r</locus>
                    <desc>
                    Medical prescriptions for stomach pain and Syphillis, written in Amharic, in an untrained hand. Incipit: <foreign xml:lang="am">መጽሐፈ፡ መድኃኒት፡ ውግዓት፡ ለሐመመ፡ አስረትን፡ እስኪ፡ ጠልቅ፡ የምስዋል፡ ሙጨ፡ የሚመስል፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="a2">
                    <locus target="#204v" facs="205">Fol. 204v</locus>
                    <desc type="Asmat">
                    Asmat prayer against eye disease, in a trained hand. Incipit: <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ <gap reason="omitted"/> ተወኪፈኪ፡ ስእለቶ፡ ወሀለወኪ፡ መንፈሳዊ፡ ዘቀብዓኪ፡ ዓይኖ፡</foreign>
                    </desc>
                    </item>
                    <item xml:id="e1">
                    <locus target="#73v" facs="074">Fol. 73v</locus>
                    <desc>
                    The midpoint of the Psalms is unmarked
                    </desc>
                    </item>
                    <item xml:id="a7">
                    <locus target="#172v #199r" facs="173 199">Fols. 172v, 199r</locus>
                    <desc>
                      The name <foreign xml:lang="gez">ኃይለ፡ ሥላሴ፡</foreign>, <persName ref="https://betamasaheft.eu/PRS5226haylase">Ḫāyla Śǝllāse I</persName> is written by a secondary hand in the section divider
                    </desc>
                    </item>
                  </list>
                </additions>
                <bindingDesc>
                  <binding xml:id="binding" contemporary="true">
                    <decoNote xml:id="b1" type="bindingMaterial">
                      <material key="parchment"/>
                      <material key="wood"/>
                      <material key="leather"/>
                    </decoNote>
                  </binding>
                </bindingDesc>

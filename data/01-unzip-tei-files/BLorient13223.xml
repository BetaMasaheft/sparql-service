                        <handDesc>
                            <handNote script="Ethiopic" xml:id="h1">
                                <locus from="3r" to="31v"/>
                                <desc>Written by <persName role="scribe" ref="https://betamasaheft.eu/PRS14344WaldaGabreel">ወልደ፡ ገብርኤል፡</persName>.</desc>
                                <date notBefore="1900" notAfter="1978" resp="PRS8999Strelcyn"/>
                            </handNote>
                            <handNote script="Ethiopic" xml:id="h2">
                                <locus from="34v" to="44v"/>
                                <desc>Written by <persName role="scribe" ref="https://betamasaheft.eu/PRS14345KidanaMaryam">Kidāna Māryām</persName>.</desc>
                                <date notBefore="1900" notAfter="1978" resp="PRS8999Strelcyn"/>
                            </handNote>
                        </handDesc>
                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus from="32r" to="34r"/>
                                    <desc type="GuestText">Beginning of the Gǝʿǝz text of <ref type="work" corresp="https://betamasaheft.eu/LIT2051Nagara">Nagara Māryām</ref>.</desc>
                                    <q xml:lang="gez">በስመ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ ጽሒፈ፡ ነገረ፡ ማርያም፡ ጸሎታ፡ ወበረከታ፡ የሃሉ፡ ምስለ፡ ገብራ፡ 
                                        <persName role="owner" ref="https://betamasaheft.eu/PRS14346WaldaAb">ወል<t:corr xmlns:t="http://www.tei-c.org/ns/1.0" resp="PRS8999Strelcyn">ደ፡</t:corr> አብ፡</persName> 
                                        ለዓለመ፡ አለም፡ አሜን። ወኮነ፡ በመዋዕለ፡ ስደታ፡ ለእግዝ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="undefined" resp="PRS8999Strelcyn">እ</t:supplied>ትነ፡ 
                                        ማርያም፡ በጽሐት፡ ምድረ፡ ይሁዳ፡</q>
                                </item>
                                <item xml:id="a2">
                                    <locus from="1v" to="2v"/>
                                    <desc type="GuestText">Magic prayer against <persName ref="https://betamasaheft.eu/ETH1310Buda">budā</persName>.</desc>
                                    <q xml:lang="gez">በስመ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ጸሎ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="undefined" resp="PRS8999Strelcyn">ት</t:supplied>፡
                                        በእ<t:supplied xmlns:t="http://www.tei-c.org/ns/1.0" reason="undefined" resp="PRS8999Strelcyn">ንተ</t:supplied>፡ ሕማመ፡ 
                                        <persName ref="https://betamasaheft.eu/ETH1310Buda">ቡዳ፡</persName> ወቁመኛ፡ ሐሮፖሮስ፡ ፯ጊዜ፡ </q>
                                </item>
                                <item xml:id="a3">
                                    <locus from="1v" to="2v"/>
                                    <desc type="GuestText">Magic prayer against small-pox (<foreign xml:lang="gez">fanṣāṣā</foreign>).</desc>
                                    <q xml:lang="gez">በስመ፡ <t:gap xmlns:t="http://www.tei-c.org/ns/1.0" reason="ellipsis"/> ጸሎት፡ በእንተ፡ ፈንፃፃ፡ በያደን፡ በያድሕን፡ ለክእሹን፡ </q>
                                </item>
                                <item xml:id="a4">
                                    <locus from="45r" to="46v"/>
                                    <title ref="https://betamasaheft.eu/LIT6940IncarnationAmh">Commentary on the Mystery of the Incarnation in
          Amharic</title>
                                    <desc type="GuestText">Amharic composition concerning the unity of the human and the divine nature of Christ.</desc>
                                    <q xml:lang="am">የትስብእትና፡ የመለኮት፡ ተዋህዶ፡ እንዴት፡ ነው፡</q>
                                </item>
                                <item xml:id="e1">
                                    <locus target="#44v"/>
                                    <desc type="OwnershipNote">The owner was <persName role="owner" ref="https://betamasaheft.eu/PRS14346WaldaAb">Walda ʾAb</persName>.</desc>
                                </item>
                                <item xml:id="e2">
                                    <locus target="#31v"/>
                                    <desc type="ScribalNoteCompleting">The name of the scribe of <ref target="#ms_i1"/> was 
                                        <persName role="scribe" ref="https://betamasaheft.eu/PRS14344WaldaGabreel">ወልደ፡ ገብርኤል፡</persName>.</desc>
                                </item>
                                <item xml:id="e3">
                                    <locus target="#44v"/>
                                    <desc type="ScribalNoteCompleting">The name of the scribe of <ref target="#ms_i2"/> was 
                                        <persName role="scribe" ref="https://betamasaheft.eu/PRS14345KidanaMaryam">Kidāna Māryām</persName>.</desc>
                                </item>
                                <item xml:id="e4">
                                    <locus target="#1r #1v"/>
                                    <desc>Pen trials, scribbles.</desc>  
                                </item>
                            </list>
                        </additions>

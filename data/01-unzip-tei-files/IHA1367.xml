               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="2r" to="3r">2r-3r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3129IHA">نظم ايها النبي يا دواء قلبي</title>
                     <incipit xml:lang="ar">
                        <locus target="#2r">-2r</locus>ايها النبي يا دوا قلبي| محمد نبي|| أحمد ربي على النعمة| واشكره كل لحظة</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#3r">-3r</locus>صلاة الله أزكى التحية| على المصطفى خير البرية|| وعلى الآل والصحب الكرام| والجد الاعظم نبراس الظلام</explicit>
                     <note/>
                     <note/>
                  </msItem>
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="9r">3r-9r</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title ref="https://betamasaheft.eu/LIT3128IHA">نظم اللهم صلى على محمد مفتاح الخيرات سر الكائنات</title>
                     <incipit xml:lang="ar">
                        <locus target="#3r">-3r</locus>اللهم صلى على محمد مفتاح الخيرات سر الكائنات|| احمد ربنا بعدد الاشياء| منعفا مضاعفا بنسبة النعماء| حمد ايوجب لي رضى رب النعماء</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#9r">-9r</locus>جميع الصلاة وكذ اللام| على نور الجود والأل الكرام| ما دام الليالي بعد الأنعام| عليك صلاتي وازكى اللام ورزقنا يا كريم أحسن الختام|| تمت</explicit>
                     <note/>
                     <note/>
                  </msItem>
               </msContents>

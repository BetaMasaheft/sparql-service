                    <msContents>
                        <msItem xml:id="ms_i1">
                            <locus from="3" to="25"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2393tabiba">Ṭabiba ṭabibān</title>
                            <bibl corresp="http://zotero.org/groups/358366/items/TQ2NBVAC"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1866Chrestomathia"/><title level="m">Chrestomathia Aethiopica edita et glossario explanata</title><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Christian Friedrich August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></editor><pubPlace>Lipsiae</pubPlace><publisher>T. O. Weigel</publisher><date>1866</date><note type="url">https://archive.org/details/bub_gb_V2XoxZmczckC</note><citedRange unit="page">108-131</citedRange></bibl>
                        </msItem>
                        
                        <msItem xml:id="ms_i2">
                            <locus from="27" to="36"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3034RepCh314">Hymn to Jesus Christ</title> 
                            <note>It contains 41 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ናሁ፡ ተማኅፀንኩ፡ በኆኅተ፡ ስምከ፡ ካፍ።
                                <lb n="2"/>ወበቀዳማይ፡ የውጣ፡ ዘጥንተ፡ ፊደሉ፡ አሌፍ።
                                <lb n="3"/>ከመ፡ ታድኅነኒ፡ ክርስቶስ፡ እምትንሣኤ፡ ልሳን፡ ወአፍ።
                                <lb n="4"/>እስመ፡ ልሳን፡ ቀተሎሙ፡ ለማኅበረ፡ ሰማዕታታ፡ አእላፍ።
                                <lb n="5"/>በነገረ፡ ውዴት፡ ጽኑዕ፡ ዘይበልሕ፡ እምሰይፍ። 
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="37" to="41"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2733RepCh17">Māḫbara mǝʾǝmanān</title>
                            <note>It contains 21 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ማኅበረ፡ ምዕመናን፡ ወምዕመናን፡ እለ፡ ኪያከ፡ ተአምኑ።
                                <lb n="2"/>ለነሢአ፡ ሥጋከ፡ ወትረ፡ ኀበ፡ ተአየኑ።
                                <lb n="3"/>ወልደ፡ ክርስቶስ፡ ዘኢትትፈለጥ፡ እምሕጽኑ።
                                <lb n="4"/>እሰክብ፡ ሕማመከ፡ ወመስቀለከ፡ እዜኑ።
                                <lb n="5"/>ፀጋ፡ መንፈስ፡ ቅዱስ፡ ሊተ፡ እምሰማይ፡ እፈኑ። 
                                </q>
                            </note>
                            <listBibl type="text">
                            <bibl corresp="http://zotero.org/groups/358366/items/TQ2NBVAC"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1866Chrestomathia"/><title level="m">Chrestomathia Aethiopica edita et glossario explanata</title><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Christian Friedrich August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></editor><pubPlace>Lipsiae</pubPlace><publisher>T. O. Weigel</publisher><date>1866</date><note type="url">https://archive.org/details/bub_gb_V2XoxZmczckC</note><citedRange unit="page">131-136</citedRange></bibl>
                            </listBibl>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="42" to="44"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2898RepCh179">Malkǝʾ-hymn to the Church</title>
                            <note>It contains 10 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለዝክረ፡ ስምኪ፡ እንተ፡ ላዕለ፡ ሕይወት፡ ወሞት፡ ሶበ፡ 
                              <sic>አድምዓ፡</sic>
                            ሥልጣነ።
                                <lb n="2"/>ቤተ፡ ክርስቲያን፡ ቅድስት፡ ተራድእኒ፡ ፍጡነ።
                                <lb n="3"/>ለፀረ፡ ዚአየ፡ ኵሎ፡ ዘመነ።
                                <lb n="4"/>እስመ፡ መፍቅድ፡ ከመ፡ ኢንትፋዕ፡ 
                              <sic>ዓነ።</sic>
                           
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="44v" to="56"/>
                            <title type="incomplete" ref="https://betamasaheft.eu/LIT3082RepCh362">Hymn to Our Lady Mary</title>
                            <note>It contains 42 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>እግዚአብሔር፡ ወሃቤ፡ ዘይሤለስ፡ በአካሉ።
                                <lb n="2"/>እንዘ፡ ተዋህዶ፡ ያጸንዕ፡ በመለኮቱ፡ ወኀይሉ።
                                <lb n="3"/>ዐይነ፡ ልቡናየ፡ ያብርህ፡ በማኅቶተ፡ ጥበብ፡ ስነ፡ ጸዳሉ።
                                <lb n="4"/>ከመ፡ <choice>
                              <sic>እራይ፡</sic>
                              <corr resp="PRS3562Dillmann">እርአይ፡</corr>
                           </choice> ገጸ፡ ነገር፡ ለኪ፡ ... ዘይደሉ።
                                <lb n="5"/>ማርያም፡ እግዝእተ፡ ኵሉ፡ ታሕቱ፡ ወላዕሉ።
                                </q>
                            </note>
                            <explicit xml:lang="gez">ለነባቤ፡ ዝንቱ፡ ድርሶት፡ ፵ወ፪።</explicit>
                            <bibl corresp="http://zotero.org/groups/358366/items/TQ2NBVAC"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Dillmann1866Chrestomathia"/><title level="m">Chrestomathia Aethiopica edita et glossario explanata</title><editor><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Christian Friedrich August</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dillmann</t:surname></editor><pubPlace>Lipsiae</pubPlace><publisher>T. O. Weigel</publisher><date>1866</date><note type="url">https://archive.org/details/bub_gb_V2XoxZmczckC</note><citedRange unit="page">136-146</citedRange></bibl>
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="56" to="58"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2967RepCh248">Poem to Our Lady Mary</title>
                            <note>It contains 12 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>በሰማይ፡ ወበምድር፡ አልብየ፡ ባዕደ።
                                <lb n="2"/>አበ፡ ወእመ፡ እኅተ፡ ወውሉደ።
                                <lb n="3"/>ማርያም፡ ድንግል፡ እትአመነኪ፡ ገሃደ።
                                <lb n="4"/>ኪያኪ፡ ተስፋ፡ ኪያኪ፡ መፍቅደ።
                                <lb n="5"/>ኪያኪ፡ አውቀ፡ ኪያኪ፡ ዘመደ።
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i7">
                            <locus from="58" to="64"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT3055RepCh335">Hymn to God</title>
                            <note>It contains 21 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>እሰግድ፡ ለመለኮትከ፡ ለዘፈጠርከ፡ ጽልመተ።
                                <lb n="2"/>እምቅድመ፡ ብርሃን፡ ትግበር፡ ወታስተባሪ፡ መዓልተ።
                                <lb n="3"/>እግዚአብሔር፡ ፩እንተ፡ ኮንከ፡ ፪ተ።
                                <lb n="4"/>በስምሰ፡ ይሰመዩ፡ ፫ተ።
                                <lb n="5"/>እንዘ፡ በመለኮት፡ ዋህድ፡ ወብሁት፡ አንተ።
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i8">
                            <locus from="64" to="67"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2910RepCh191">Malkǝʾ-hymn to Abraham, Isaac and Jacob</title>
                            <note>It contains 15 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለዝክረ፡ ስምክሙ፡ ፀሐየ፡ ልቡና፡ ሠረቀ።
                                <lb n="2"/>ዜና፡ ቃለ፡ መጽሐፍ፡ ቅድመ፡ ከመ፡ አጠየቀ።
                                <lb n="3"/>በላዕለ፡ አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ እግዚአብሔር፡ ተአውቀ።
                                <lb n="4"/>ከመ፡ እዜኑ፡ ዕበዮሙ፡ ወስብሐቲሆሙ፡ ጥዩቀ።
                                <lb n="5"/>ኃይለ፡ ኪዳኖሙ፡ የሀበኒ፡ ጥበበ፡ ወጽፍቀ።
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i9">
                            <locus from="67v" to="76"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2999RepCh279">Hymn to John the Baptist</title>
                            <note>It contains 28 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>በስመ፡ እግዚአብሔር፡ እሳት፡ በሐቀለ፡ ህሊና፡ ነዳዲ።
                                <lb n="2"/>ወበስመ፡ ማርያም፡ ድንግል፡ መጥበቢተ፡ ዓለም፡ አባዲ።
                                <lb n="3"/>ማኅቶተ፡ ጸዳል፡ ዮሐንስ፡ ጽልመተ፡ አበሳ፡ ሰዳዲ።
                                <lb n="4"/>ከመ፡ እዜኑ፡ ኂሩትከ፡ ዕዳ፡ ኀጣውኢየ፡ ፍዲ።
                                <lb n="5"/>በአየረ፡ ሰማይ፡ ዘይጸርሕ፡ ቃልከ፡ ዓዋዲ።
                                </q>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i10">
                            <locus from="76v" to="80"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2915RepCh196">Malkəʾa Gabra Manfas Qəddus</title>
                            <note>It contains 15 stanzas.</note>
                        </msItem>
                        
                        <msItem xml:id="ms_i11">
                            <locus from="81" to="98"/>
                            <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1956Mashaf">መጽሐፈ፡ ኑዛዜ፡</title>
                            <note>
                            </note>
                        </msItem>
                        
                        <msItem xml:id="ms_i12">
                            <locus from="98" to="103"/>
                            <title type="complete" ref="https://betamasaheft.eu/LIT2897RepCh178">Malkǝʾ-hymn to Anna</title>
                            <note>It contains 14 stanzas. The first one is the following:
                                <q xml:lang="gez">
                                <lb n="1"/>ሰላም፡ ለዝክረ፡ ስምኪ፡ እምዝክረ፡ ማኅሌት፡ አዳም።
                                <lb n="2"/>ለርእስኪ፡ ሰ<supplied reason="omitted">ላ</supplied>ም፡ ወለስእርትኪ፡ ጸሊም።
                                <lb n="3"/>እመ፡ ማርያም፡ ሐና፡ ሕይወተ፡ ኵሉ፡ ዓለም።
                                <lb n="4"/>ብኪ፡ ተሣረሩ፡ እለ፡ ዘሥጋ፡ ወደም።
                                <lb n="5"/>ወመላእክት፡ ዘልዑል፡ አርያም።
                                </q>
                            </note>
                        </msItem>
                        

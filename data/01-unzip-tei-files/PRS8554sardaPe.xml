         <t:listPerson>
            <t:person sex="1">
               <t:persName xml:lang="gez" xml:id="n1" type="birth">ሠርፀ፡ ጴጥሮስ፡</t:persName>
               <t:persName xml:lang="gez" corresp="#n1" type="normalized">Śarḍa Ṗeṭros</t:persName>
          
               <t:persName>
                  <t:roleName type="title">ʾabbā</t:roleName>
               </t:persName>
               <t:nationality type="Ethiopia"/>
               <t:faith type="EOTC"/>
               
             
               <t:floruit notBefore="1450" notAfter="1500"> He was a saint of Ethiopia who was active in the second
                  half of the 15th century. 
                  He was a contemporary Ethiopian
                  Kings from King <t:persName ref="https://betamasaheft.eu/PRS3429DawitII">Dāwit II</t:persName> to <t:persName ref="https://betamasaheft.eu/PRS2334BaedaM">Baʾǝda Māryām I</t:persName>. 
          He is credited with re-establishing the monastery of <t:placeName ref="https://betamasaheft.eu/LOC2393DabraW">Dabra Warq</t:placeName>, 
                  destroyed by the Muslims during the reign of King <t:persName ref="https://betamasaheft.eu/PRS8595SayfaAr">Sayfa ʾArʿad</t:persName>
               </t:floruit>
               <t:death/>
            </t:person>  
            
         </t:listPerson>

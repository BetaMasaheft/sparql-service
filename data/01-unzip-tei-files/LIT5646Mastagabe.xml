            <t:div type="edition">
                <t:note>Division and text based on <t:bibl corresp="http://zotero.org/groups/358366/items/UJRPQJ7A"><seg type="book"><!-- attributes from original bibl--></seg><ptr target="bm:Velat1966MeerafText"/><title level="m">Meʿerāf: Commun de l'office divin éthiopien pour toute l'année, Texte éthiopien avec variantes</title><title level="s">Patrologia Orientalis</title><author><forename>Bernard</forename><surname>Velat</surname></author><editor><forename>Bernard</forename><surname>Velat</surname></editor><pubPlace>Paris</pubPlace><publisher>Firmin-Didot et C&lt;sup&gt;ie&lt;/sup&gt;, éditeurs</publisher><date>1966</date><series><title level="s">Patrologia Orientalis</title><biblScope unit="volume">34/1–2</biblScope></series><biblScope unit="volume">34/1–2</biblScope><note type="tags"><note type="tag">Chants</note><note type="tag">bm:Velat1966MeerafText</note></note><note type="tag">Chants</note><note type="tag">bm:Velat1966MeerafText</note><t:citedRange unit="page">34-46</t:citedRange></t:bibl></t:note>
                <t:div type="textpart" xml:id="Monday">
                    <t:label>Monday</t:label>
                    <t:div type="textpart" xml:id="MondayEzl">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>ወለቡ፡ ጽራኅየ።
                            ወአፅምአኒ፡ ቃለ፡ ስእለትየ።</t:ab>
                        </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="MondayGez">                    
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>Gǝʿz</t:label>
                        <t:ab>አምላኪየ፡ አምላኪየ፡ ነጽረኒ፡ ወለምንት፡ ኀደገኒ።
                            ርሑቅ፡ እምአድኅኖትየ፡ ቃለ፡ ኀጢአትየ።</t:ab>
                        </t:div>
                    </t:div>
                </t:div>
                <t:div type="textpart" xml:id="Tuesday">
                    <t:label>Tuesday</t:label>
                    <t:div type="textpart" xml:id="TuesdayEzl">                    
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>ቅረቡ፡ ኀቤሁ፡ ወያበርህ፡ ለክሙ።
                            ጠዐሙ፡ ወታእምሩ፡ ከመ፡ ኄር፡ እግዚአብሔር።</t:ab>
                       </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="TuesdayGez">                    
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>Gǝʿz</t:label>
                                 <t:ab>ለምንት፡ ይዜኀር፡ ኀያል፡ በእከዩ።
                                  ወትዔምፅ፡ እምትንብብ፡ ጽድቀ።</t:ab>
                        </t:div>
                    </t:div>
                </t:div>
                <t:div type="textpart" xml:id="Wednesday">
                    <t:label>Wednesday</t:label>
                    <t:div type="textpart" xml:id="WednesdayEzl">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>በልዎ፡ አእግዚአብሔር፡ ግሩም፡ ግብርከ።
                            ኵላ፡ ምድር፡ ትሰግድ፡ ወትገኒ፡ ለከ።
                        </t:ab>
                        </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="WednesdayGez">
                         <t:div type="textpart" subtype="incipit" xml:lang="gez">
                             <t:label>Gǝʿz</t:label>
                            <t:ab>እግዚኦ፡ <t:sic>ኰ</t:sic>ነኔከ፡ ሀቦ፡ ለንጉሥ።
                            ኰንን፡ በጽድቅ፡ ነዳያነ፡ ሕዝ<t:sic>በ</t:sic>ከ።
                            </t:ab>
                         </t:div>
                    </t:div>
                </t:div>
                <t:div type="textpart" xml:id="Thursday">
                    <t:label>Thursday</t:label>
                    <t:div type="textpart" xml:id="ThursdayEzl">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>እግዚኦ፡ አምላከ፡ ኀያላን፡ ስምዐኒ፡ ጸሎትየ።
                            ሣህል፡ ወርትዕ፡ ተራከባ።
                        </t:ab>
                        </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="ThursdayGez">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>Gǝʿz</t:label>
                        <t:ab>ስምዐኒ፡ እግዚኦ፡ ጸሎትየ።
                            እስመ፡ ኀልቀ፡ ከመ፡ ጢስ፡ መዋዕልየ።
                        </t:ab>
                        </t:div>
                    </t:div>
                </t:div>
                <t:div type="textpart" xml:id="Friday">
                    <t:label>Friday</t:label>
                    <t:div type="textpart" xml:id="FridayEzl">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>ጸዋዕኩ፡ ስመ፡ እግዚአብሔር።
                            እግዚኦ፡ ባልሓ፡ ለነፍስየ።
                        </t:ab>
                        </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="FridayGez">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>Gǝʿz</t:label>
                        <t:ab>ተፈሣሕኩ፡ እስመ፡ ይቤሉኒ፡ ቤተ፡ እግዚአብሔር፡ ነሐውር።
                            ሕዝበ፡ እግዚአብሔር፡ ስምዐ፡ እስራኤል።
                        </t:ab>
                        </t:div>
                    </t:div>
                </t:div>
                <t:div type="textpart" xml:id="Saturday">
                    <t:label>Saturday</t:label>
                    <t:div type="textpart" xml:id="SaturdayEzl">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>ʿƎzl</t:label>
                        <t:ab>ናሁ፡ ይባርክዎ፡ ለእግዚአብሔር። 
                            ኵሎሙ፡ አግብርተ፡ እግዚአብሔር።</t:ab>
                        </t:div>
                    </t:div>
                    <t:div type="textpart" xml:id="SaturdayGez">
                        <t:div type="textpart" subtype="incipit" xml:lang="gez">
                            <t:label>Gǝʿz</t:label>
                        <t:ab>ቃልየ፡ ኀበ፡ እግዚአብሔር፡ <t:sic>ጻ</t:sic>ራኅኩ።
                            አንተ፡ እግዚኦ፡ ተአምር፡ ፍኖትየ።
                        </t:ab>
                        </t:div>
                    </t:div>
                </t:div>
            </t:div>
         
        </t:body>

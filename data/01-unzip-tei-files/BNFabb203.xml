                    <msContents>
                      <msItem xml:id="ms_i1">
                        <locus from="1r" to="63ra"/>
                        <title type="complete" xml:lang="gez" ref="https://betamasaheft.eu/LIT1546Genesi">ኦሪት፡ ዘልደት፡ </title>

                            <incipit xml:lang="gez">
                              <locus target="#1ra"/><hi rend="rubric">ኦሪት፡ ዘልደት፡ ፡
                                ምዕራፍ፩፡ በቀዳሚ፡ ገብረ፡ እግዚአብሔር፡ </hi> ሰማየ፡ ወምድረ። ወምድርሰ፡ ሀለወት፡ ዕራቃ።
                          </incipit>
                          <explicit xml:lang="gez">
                            <locus target="#63ra"/>እምዝየ፡ ምስለክሙ፡ ወሞተ፡ ዮሴፍ፡ በ፻ወ፲ዓመት፡ ወአምዓዝዎ፡ ወሤምዎ፡ በነፍቅ፡ ውስተ፡ ብሔረ፡ ግብጽ።
                        </explicit>
                        <note>The explicit on <locus target="#63ra"/>
                      is written by <persName ref="https://betamasaheft.eu/PRS9683Urbino">Giusto da Urbino</persName>.</note>


                             <colophon xml:lang="gez" xml:id="coloph1">
                                <locus from="63ra"/>
                               ተፈጸመ፡ ኦሪት፡ ዘልደት፡ ስብሐት፡ ለእግዚአብሔር፡ ፈጣሪ፡ ኵሉ፡ ፍጥረታት። ተጽሕፈ፡  <placeName ref="https://betamasaheft.eu/LOC3577Gondar">በጐንደር</placeName>፡
                               <date>፸፻፡  ወ፫፻ወ፵፪፡ እምፍጥረተ፡ ዓለም</date>። <date>ወእም፡ ልደተ፡ ፡
                                 ክርስቶስ፡ በ፲፻ወ፰፻ወ፵፪፡ በዘመነ፡ ማርቆስ</date>።
                               ወዘንተ፡ መጽሐፈ፡ ተሣየተ፡ <persName ref="https://betamasaheft.eu/PRS9683Urbino">
                                 አባ፡ ዮስጦስ፡ ሮማዊ፡ </persName>በ፩ብሩር፡ እም፡ <persName ref="https://betamasaheft.eu/PRS8972Stella">አባ፡  ዮሐንስ፡ ዘተሰምየ፡  ስተላ፡ ዘበትርጓሜሁ፡ ኮከብ</persName>።
                                </colophon>
                                <note>Written obviously by <persName ref="https://betamasaheft.eu/PRS9683Urbino">Giusto da Urbino</persName>
                                (<ref target="#h2"/>)
                                who provides the production date as <date>1850 AD</date>.</note>

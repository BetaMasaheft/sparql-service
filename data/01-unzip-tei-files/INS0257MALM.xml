               <t:placeName>Malakusayto Qǝddǝst Māryām</t:placeName>
               <t:placeName type="alt">Māryām Malakusayto</t:placeName>
               <t:country ref="https://betamasaheft.eu/LOC3010Ethiop">ʾItyoṗyā</t:country>
               <region notBefore="1991" type="RegionalState" ref="https://betamasaheft.eu/LOC5932Tegray">Bǝḥerāwi Kǝllǝlāwi Mangǝśti Tǝgrāy</region>

               <t:settlement type="warada" from="2012-11-12" to="2012-11-13" ref="https://betamasaheft.eu/LOC3293GantaA">Gāntā ʾAfašum</t:settlement>
               <t:settlement type="tabiya" from="2012-11-12" to="2012-11-13" ref="https://betamasaheft.eu/LOC7256Bahera">Bāḥǝrā-Sǝḥetā</t:settlement>

               <t:settlement from="2012-11-12" to="2012-11-13" type="qushat" ref="https://betamasaheft.eu/LOC7258Malakusayto">Malakusayto</t:settlement>

               <t:location>
                  <t:geo>14.192339 39.466972</t:geo>
                  <t:height unit="m">2551.78</t:height>
               </t:location>
               <t:note>
                  <t:date type="foundation" notBefore="1700" notAfter="1800">1700-1800</t:date>
                  <t:desc type="foundation">Local tradition claims the foundation in the year of mercy 336. The original founder is said to have been a certain <t:persName ref="https://betamasaheft.eu/PRS12537Azzay">ʾAzzāy Ba-Kʷǝllu</t:persName> (?). Later it is said to be re-established by <t:persName ref="https://betamasaheft.eu/PRS12536GabraDengel">
                        <t:roleName type="title">ʾayta</t:roleName> Gabra Dǝngǝl</t:persName>.
                     The written account about the church foundation (<t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm004">MALM-004</t:ref>) differs from the oral story.</t:desc>
                  <t:ab type="history">Dabr. Two churches located at the site: the older is placed on the rock, the recent, very modest and still under construction is located on the slope closer to the road. 
</t:ab>
                  <t:ab type="description">
                     <t:figure>
                        <t:graphic url="Sites/MALM.tif">
                           <t:desc>The church photographed by Denis Nosnitsin during the Ethio-SPaRe project.</t:desc>
                        </t:graphic>
                     </t:figure>18 Mss. photographed: <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm001">MALM-001</t:ref> “ The Harp of the praise”;
                     <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm002">MALM-002</t:ref> “Homiliary for the feasts of St. Michael”;
                     <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm003">MALM-003</t:ref> “Homiliary for the Feasts of St. Michael”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm004">MALM-004</t:ref> “Four Gospels”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm005">MALM-005</t:ref> “Miracles of Mary”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm006">MALM-006</t:ref> “Missal”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm007">MALM-007</t:ref> “Book of the Funeral Rite”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm008">MALM-008</t:ref> “Praise of God ”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm009">MALM-009</t:ref> “Homily for commemeration  of the Saviour of the World”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm010">MALM-010</t:ref> “Vita of Gäbrä Mikaʾel”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm011">MALM-011</t:ref> “Book of the letter; Regulations concerning the priest; Excerpts from Zǝmmare”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm012">MALM-012</t:ref> “Book of the  letter; Regulations concerning the priest; Excerpt from Zǝmmare”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm013">MALM-013</t:ref> “Psalter”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm014">MALM-014</t:ref> “Loosening of Spell”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm015">MALM-015</t:ref> “Miracles of Jesus”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm016">MALM-016</t:ref> “Vita of Gäbrä Mikaʾel”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm017">MALM-017</t:ref> “Magical prayers against evil eye and diseases”; <t:ref type="mss" corresp="https://betamasaheft.eu/ESmalm018">MALM-018</t:ref> “Homily on the 24 Heavenly priests; Vita of  ʾAbba Yoḥanni”.</t:ab>

                  <t:ab type="tabot">
                     <t:measure quantity="3"/>Tābots of <t:persName type="tabot" ref="https://betamasaheft.eu/PRS6819Mary">Mary</t:persName>, <t:persName type="tabot" ref="https://betamasaheft.eu/PRS10581Zamika">ʾAragāwi</t:persName> (old church), <t:persName ref="https://betamasaheft.eu/PRS4345GabraMi">Gabra Mikāʾel</t:persName> (new church).</t:ab>

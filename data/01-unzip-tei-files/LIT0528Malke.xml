      <body>
         <div type="bibliography">
            <listBibl type="editions">
               <bibl corresp="http://zotero.org/groups/358366/items/BL5NWGBV"><seg type="webpage"><!-- attributes from original bibl--></seg><ptr target="bm:MgWebsite"/><title level="a">መልክአ፡ ጉባኤ፡ Malkǝʾa gubāʾe</title><author><t:forename xmlns:t="http://www.tei-c.org/ns/1.0">Augustine</t:forename><t:surname xmlns:t="http://www.tei-c.org/ns/1.0">Dickinson</t:surname></author><date>2020</date><note type="accessed">2024-09-24</note><note type="url">https://malkeagubae.com/</note><citedRange>0528</citedRange></bibl>
            </listBibl>
            
         </div>
         <div type="edition" xml:lang="gez">
            <div type="textpart" xml:id="malke">
               <lg type="stanza" n="1">
                  <l n="1">ኣእኵቶቶ፡ ኣቀድም፡ ለእግዚአብሔር፡ ዘወሀበነ፨</l>
                  <l n="2">አንተ፡ ላሊበላ፡ ንጉሥ፡ ወመስቀል፡ ክብራ፡ እምነ፨</l>
                  <l n="3">ውእቶሙ፡ ሕዝበ፡ እመ፡ ኢያትረፈ፡ ለነ፨</l>
                  <l n="4">ከመ፡ ሰዶም፡ ሥርወ፡ ዐመፃ፡ ወከመ፡ ገሞራ፡ እምኮነ፨</l>
                  <l n="5">ፍዳ፡ ጌጋይ፡ ወሞት፡ እምተሰልጠ፡ ላዕሌነ፨</l>
               </lg>
               <lg type="stanza" n="2">
                  <l n="1">ሰላም፡ ለፅንሰትኪ፡ በዘርአ፡ ኢመፍትው፡ ሩካቤ፨</l>
                  <l n="2">ወለልደትኪ፡ ምዑዝ፡ እምልደተ፡ አንስት፡ ከርቤ፨</l>
                  <l n="3">መስቀል፡ ክብራ፡ ንበሪ፡ ከመ፡ ሊቀ፡ ሐዳስ፡ ይባቤ፨</l>
                  <l n="4">ዘያሔሊ፡ ወድሶተኪ፡ ምልአ፡ ኅሊናየ፡ ዐቃቤ፨</l>
                  <l n="5">ወነገረ፡ ዘርቅ፡ አፉየ፡ ኢይኩን፡ ነባቤ፨</l>
               </lg>
               <lg type="stanza" n="3">
                  <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘተጸውዐ፡ ሠናየ፨</l>
                  <l n="2">በአስተፍሥሖቱ፡ ነዳየ፨</l>
                  <l n="3">መስቀል፡ ክብራ፡ መርዐቱ፡ ለላሊበላ፡ አቡየ፨</l>
                  <l n="4">ዘክልኤክሙ፡ ሩካቤ፡ እምንጽሐ፡ መላእክት፡ ዐብየ፨</l>
                  <l n="5">ወንጽሐ፡ ክልኤቱ፡ አዕሩግ፡ ዘማዌ፡ ተሰምየ፨</l>
               </lg>
               <lg type="stanza" n="30">
                  <l n="1">ሰላም፡ ለመቃብርኪ፡ ለምድረ፡ ባዕዳን፡ ካልእታ፨</l>
                  <l n="2">ድኅረ፡ መቃብሩ፡ ተነግረ፡ ለላሊበላ፡ በጎልጎታ፨</l>
                  <l n="3">መስቀል፡ ክብራ፡ ኩንኒ፡ መራሒተ፡ ጽድቅ፡ ፍና፡ ሐተታ፨</l>
                  <l n="4">ኢተሀሉ፡ ነፍሰ፡ ዚአየ፡ በፍናወ፡ ነገር፡ መንታ፨</l>
                  <l n="5">እንዘ፡ ፍና፡ ጽድቅ፡ ዋሕድ፡ ሀለወተኒ፡ በቤታ፨</l>
               </lg>
               <lg type="stanza" n="31">
                  <l n="1">ሰላም፡ ለላሊበላ፡ ወለመስቀል፡ ክብራ፡ ጠባብ፨</l>
                  <l n="2">ወሕፃን፡ ይትባረክ፡ ዘልደተ፡ ግብሩ፡ ዕጹብ፨</l>
                  <l n="3">ይምርሐነ፡ ክርስቶስ፡ ገብረ፡ ማርያም፡ ወነአኵቶ፡ ለአብ፨</l>
                  <l n="4">ትወስኩ፡ ዕድሜ፡ ንስሓ፡ ላዕለ፡ ዕድሜየ፡ ቅሩብ፨</l>
                  <l n="5">እትመሐፀን፡ ገብርክሙ፡ በዝንቱ፡ ንባብ፨</l>
               </lg>
               <lg type="stanza" n="32">
                  <l n="1">ለዘአቅረብኩ፡ በስሞሙ፡ አምኃ፡ ስብሐት፡ ወውዳሴ፨</l>
                  <l n="2">መስቀል፡ ክብራ፡ ብእሲተ፡ ወላሊበላ፡ ብእሴ፨</l>
                  <l n="3">በፍና፡ አሐዱ፡ ከዊን፡ እለ፡ ፈጠሩ፡ ሥላሴ፨</l>
                  <l n="4">ያብኡኒ፡ ተማሕፀንኩ፡ አመ፡ ደኃራዊ፡ ድምሳሴ፨</l>
                  <l n="5">ውሳጤ፡ መንጦላዕት፡ ሳብዕ፡ ዘነጸረ፡ ሙሴ፨</l>
               </lg>
            </div>
         </div>
      </body>
   </text></TEI>
               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i0">
                     <locus from="1r" to="148v">1r-148v</locus>
                     <textLang xml:lang="ar">Arabic</textLang>
                     <title type="acephalous apodous lacunous" ref="https://betamasaheft.eu/LIT1209IHA">مجموع اقوال صوفية</title>
                     <incipit xml:lang="ar">
                        <locus target="#1r">-1r</locus>من حيث الوضوح بحيث لا تتصور مشاهدة وكشف اظهر منه ولا يكون مستفادا من المعلومات بل تكون المعلومات مستفادة من وخاصيته تحصيل العلم والمعرفة فمن لازمه عرف الله حق معرفة على الوجه الذى يليق به</incipit>
                     <explicit xml:lang="ar">
                        <locus target="#148v">-148v</locus>وتخرج هناك غير واحد كالشيخ العارف بالله سيدى الحاج احمد منقول العروسى وهو معروف فى ناحيته بالعلم والتقوى ثم انه رحمه الله الرحمة الواسعة وامطر عليه من ينابيع مغفرته الها معه لم يزل بعد الرمضان من الارشاد والتربية والترقية والتعليم فى قريته المذكورة الى النصف الثانى من ربيع الاول فسمع بمرضه لاستاذ سيدى كمال الدين الزبى فقام لعيادته مع كثرة الناس فوصل اليه وهو</explicit>
                     <note>
                        <p>
                           Mentioned
                        : <persName ref="https://betamasaheft.eu/PRS0850IHA"> كمال الدين الزبى الابي</persName>
                        </p>
                        <p>
                           Mentioned
                        : <persName ref="https://betamasaheft.eu/PRS0850IHA"> كمال الدين الزبى الابي</persName>
                        </p>
                        <p>
                           Mentioned
                        : <persName ref="https://betamasaheft.eu/PRS0834IHA"> الدانى الاول احمد بن آدم شهاب الدين</persName>
                        </p>
                        <p>
                           Mentioned
                        : <persName ref="https://betamasaheft.eu/PRS0834IHA"> الدانى الاول احمد بن آدم شهاب الدين</persName>

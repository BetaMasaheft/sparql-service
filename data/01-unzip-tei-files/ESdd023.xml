                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Late 18th-century script.</seg>

                        <seg type="ink">Black, red, crimson.</seg>

                        <desc>Fine and careful.</desc>
                        <seg type="rubrication">Divine names; names of the donors; 1st, 3rd and 5th
                           line of the incipit of each text (occasionally in both columns); Ethiopic
                           numerals and the first two lines of the chapters; first two lines of the

                           final prayers of each text and the supplication prayers of  <ref target="#ms_i1.7">Text 1.7</ref>;
                           names of the days of the week written in the upper margin throughout the
                           manuscript, and the name ‘Falaskinos’ (fols. <locus target="#146v #147r #149r #151r"/>); the word
                           <foreign xml:lang="gez">mǝʾrāf</foreign> ‘chapter’; elements of the punctuation signs and Ethiopic numerals.</seg>

                     </handNote>
                  </handDesc>

                  <msContents>
                     <summary/>
                     <msItem xml:id="p1_i1">
                        <locus from="3a" to="68a">Fols 3a–68a</locus>
                        <title type="supplied">Collection of discourses for each day of the week called "The Disciples" [Arde't], in which Christ reveals to his Disciples his secret names [asmāt].</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>Apparently incomplete in the film because ff. 68b-70a were not microfilmed.</note>
                     </msItem>
                     <msItem xml:id="p1_i2">
                        <locus from="71a" to="85b">Fols 71a–85b</locus>
                        <title type="supplied">The Praises of Mary [Weddāsē Māryām], for the days of the week.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p1_i3">
                        <locus from="85b" to="86a">Fols 85b–86a</locus>
                        <title type="supplied">Prayer made up of versicles from the Psalms.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note>In complete at the end. There is a progression in the psalms chosen Pss. 5, 6, 11, 12, 16, 18, 19, 20 and 21 being represented in the fragment that remains.</note>
                     </msItem>
                     <msItem xml:id="p1_i4">
                        <locus target="#70b">Fol. 70b</locus>
                        <title type="supplied">Beginning of St. John's Gospel, as a pen trial.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p1_i5">
                        <locus target="#70b">Fol. 70b</locus>
                        <title type="supplied">Isolated name, Tasammā Zaggāy.</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                     <msItem xml:id="p1_i6">
                        <locus target="#86a">Fol. 86a</locus>
                        <title type="supplied">'Hotel, Weqro Asfāh (place name in Tigrē province).</title>
                        <textLang mainLang="gez">Gǝʿǝz</textLang>
                        <note/>
                     </msItem>
                  </msContents>

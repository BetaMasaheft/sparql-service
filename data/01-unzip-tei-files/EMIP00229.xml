               <msContents>
                  <textLang mainLang="am" otherLangs="gez">Amharic and Gǝʿǝz</textLang>

                  <msItem xml:id="ms_i1">
                    <locus from="1r" to="11r" facs="003">Fols 1r–11r</locus>
                    <title>Theological Treatise about the Three-Birth Controversy </title>
                    <incipit xml:lang="am">
                      በስመ፡ አብ፡ ወወልድ <gap reason="omitted"/>ተዋሕዶ፡ ሃይማኖትን፡ እንናገራለን። ይህንን ሃይማኖት፡ በደጃዝማች ውቤ፡ ጊዜ፡ አቡነ፡
                      ሰላማ፡ ከመንበረ፡ ማርቆስ አጽፈው፡ አስመጡት።<gap reason="omitted"/></incipit>
                      <note>At the time of <persName ref="https://betamasaheft.eu/PRS10102Webeha">Wǝbe Ḫaylä Maryam</persName>(famous for his participation in the battle of Tabor)</note>
                    </msItem>

                  <msItem xml:id="ms_i2">
                    <locus from="11r" to="70v" facs="013">Fols 11r–70v</locus>
                    <title type="complete" ref="https://betamasaheft.eu/LIT5938CommAmmestu">Amharic
                                                  Commentary on the Pillars of Mystery</title>

                  <msItem xml:id="ms_i2.1">
                    <locus from="11r" to="43r" facs="013">Fols 11r–43r</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT5937CommCommandments">Amharic
                                                  Commentary on the Ten Commandments</title>
                  <incipit>
                    <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ:<gap reason="omitted"/></foreign>
                    <foreign xml:lang="am">የ፭ቱ፡ አዕማደ፡ ምሥጢር፡ መቅድምን፡ ፲ሠርቱ፡ ቃላትን፡ እንናገራለን፡</foreign>
                    <foreign xml:lang="gez">፩ዱ፡ ኢታምልኩ፡ ባዕደ፡ አምላከ:<gap reason="omitted"/></foreign>
                    </incipit>
                    </msItem>

                  <msItem xml:id="ms_i2.2"><locus from="43r" to="55v" facs="045">Fols 43r–55v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT5963CommTrinity">Amharic
                                                  Commentary on the Mystery of the Trinity</title>
                  <incipit>
                    <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ:<gap reason="omitted"/></foreign>
                    <foreign xml:lang="am">፭ቱ፡ አዕማደ፡ ምሥጢርን፡ እንናገራለን፡</foreign>
                    <foreign xml:lang="gez">እፈቅድ እንግር፡ ፭ተ፡ ቃላተ፡ አዕማዲሃ፡ ለቤተ፡ ክርስቲያን፡</foreign>
                    <foreign xml:lang="am">እንዳለ፡ ጳውሎስ፡<gap reason="omitted"/></foreign>
                  </incipit>
                </msItem>

                  <msItem xml:id="ms_i2.3">
                    <locus from="55v" to="70v" facs="058">Fols 55v–70v</locus>
                  <title type="complete" ref="https://betamasaheft.eu/LIT5964CommIncarnation">Commentary
                                                  on the Mystery of the Incarnation</title>
                  <incipit>
                    <foreign xml:lang="gez">በስመ፡ አብ፡ ወወልድ:<gap reason="omitted"/></foreign>
                    <foreign xml:lang="am">ምሥጢረ፡ ሥጋዌን፡ እንናገራለን፡ ምሥጢረ፡ ሥጋዌ፡ እንዴት፡ ነው፡ ቢሉ፡ ከዓለም፡ በፊት፡ ከዓለም፡ በኋላ፡ እግዚአብሔር ዘለዓለም:<gap reason="omitted"/></foreign>
                  </incipit>
                </msItem>

                </msItem>




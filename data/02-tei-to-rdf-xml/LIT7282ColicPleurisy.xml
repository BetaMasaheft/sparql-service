      <crm:P102_has_title rdf:resource="https://betamasaheft.eu/LIT7282ColicPleurisy%2Ftitle%2Ft2"
                          xml:lang="gez"/>
      <dc:title xml:lang="gez">Gānen ʾAwyen ba-zǝntu ʾasmātika ʾadḫǝno ʾǝm-makʷānǝnta ṣǝlmat</dc:title>
      <dc:title xml:lang="en">Demon ʾAwyen, by these ʾasmāt I will save him from the judges of the shadow...</dc:title>
      <dc:title xml:lang="gez">፯ ጊዜ፡ ድገም፡ በማዕተብ፡ ወበማይ፡ ለሆድ፡ ቍርፀት፡ ወለጉሥምት፡</dc:title>
      <crm:P102_has_title rdf:resource="https://betamasaheft.eu/LIT7282ColicPleurisy%2Ftitle%2Ft3"
                          xml:lang="gez"/>
      <dc:title xml:lang="gez">7 gize dǝgam ba-mātab wa-ba-māy la-hod qʷǝrḍat wa-la-guśǝmt</dc:title>
      <dc:title xml:lang="en">... repeat 7 times by the sign (of the cross) and by the water (of baptism) to (heal) the 
                    stomach-colic and to (heal) the pleurisy</dc:title>
